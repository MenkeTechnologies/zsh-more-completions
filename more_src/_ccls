#compdef ccls

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--index=[project root]:directory:_directories' \
  '--init=[JSON initialization options]:json' \
  '--log-file=[log to file]:file:_files' \
  '--log-file-append=[append log to file]:file:_files' \
  '-v=[log verbosity]:level' \
  '--log-all-to-stderr[log all messages to stderr]' \
  '--test-index=[run index test]:file:_files' \
  '-j=[number of indexer threads]:threads'
