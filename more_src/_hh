#compdef hh hstr

# Zsh completion for hstr/hh - shell history suggest box

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(- *)--show-configuration[show configuration for bash]' \
  '(- *)--show-zsh-configuration[show configuration for zsh]' \
  '(- *)--show-bash-configuration[show configuration for bash]' \
  '-n[non-interactive mode]' \
  '-f[show favorites]' \
  '-s[show suggest box]' \
  '-b[show blacklist]' \
  '-k[kill last command]' \
  '-1[show only one result]' \
  '-V[show version]'
