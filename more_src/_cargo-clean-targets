#compdef cargo-clean-targets
# Documentation: https://github.com/FGRibreau/cargo-clean-targets
# Strip Cargo target/ caches across a tree, keep compiled binaries

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --dry --dry-run)'{-n,--dry,--dry-run}'[preview directories that would be removed]' \
  '(-v --verbose)'{-v,--verbose}'[print every path acted on]' \
  '*:path:_files -/' && ret=0

return ret
