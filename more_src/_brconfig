#compdef brconfig
# Documentation: man brconfig(8)
# Source: netbsd/src sbin/brconfig — network bridge configuration (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-a[show status of all bridge devices]' \
    '1:bridge:_default' \
    '2::command:(up down add delete addr maxaddr timeout deladdr flush flushall discover -discover ipf learn -learn protect -protect static stp -stp maxage fwddelay hellotime priority ifpriority ifpathcost)' \
    '*::interface or value:_default' \
    && ret=0

return ret
