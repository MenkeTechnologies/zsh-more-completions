#compdef dxf2svg
# Documentation: https://qcad.org/en/qcad-command-line-tools
# QCAD: convert DXF/DWG drawings to SVG

local ret=1

_arguments -s -S \
  '(-f -force)'{-f,-force}'[overwrite existing output file]' \
  '(-o -outfile)'{-o+,-outfile=}'[output file]:outfile:_files -g "*.svg"' \
  '(-s -scale)'{-s+,-scale=}'[scale factor]:scale:' \
  '(-e -equal-margins)'{-e+,-equal-margins=}'[set all page margins uniformly]:margin:' \
  '(-c -circle)'{-c+,-circle=}'[export points as circles with radius]:radius:' \
  '(-g -preserve-geometry)'{-g,-preserve-geometry}'[maintain original geometry]' \
  '-layer=[export specific layers (comma-separated, regex)]:layers:' \
  '(-h -help)'{-h,-help}'[display help]' \
  '*:DXF/DWG file:_files -g "*.(dxf|dwg|DXF|DWG)"' && ret=0

return ret
