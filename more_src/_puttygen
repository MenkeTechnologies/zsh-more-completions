#compdef puttygen
# Documentation: man 1 puttygen (manpages.debian.org/bookworm/putty-tools)
# Reference accessed: 2026-05-29
# PuTTY Key Generator — create, modify, and convert SSH keys.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)--pgpfp[display PuTTY PGP master-key fingerprints]' \
  '-t+[key type]:type:(rsa dsa ecdsa eddsa ed25519 ed448 rsa1)' \
  '-b+[key size in bits (default 2048 for rsa/dsa)]:bits:' \
  '--primes=[prime generation method]:method:(probable proven proven-even)' \
  '--strong-rsa[use strong primes for RSA key factors]' \
  '-q[suppress progress display during generation]' \
  '--random-device=[entropy source device]:device:_files' \
  '-C+[set or change comment string]:comment:' \
  '-P[change the passphrase]' \
  '--certificate=[attach an OpenSSH-style certificate]:file:_files' \
  '--remove-certificate[remove any attached certificate]' \
  '--reencrypt[refresh encryption without changing passphrase]' \
  '*--ppk-param=[adjust PPK file format details (key=value)]:param:' \
  '--old-passphrase=[read old passphrase from file]:file:_files' \
  '--new-passphrase=[read new passphrase from file]:file:_files' \
  '-O+[output type]:format:(private public public-openssh private-openssh private-openssh-new private-sshcom fingerprint text cert-info)' \
  '-o+[write output to file]:file:_files' \
  '-l[shorthand for fingerprint output]' \
  '-L[shorthand for public-openssh format]' \
  '-p[shorthand for public format]' \
  '--cert-info[display certificate information]' \
  '--dump[output textual key components]' \
  '-E+[fingerprint algorithm]:algo:(sha256 md5)' \
  '*:key file:_files -g "*.(ppk|pem|pub)"' && ret=0

return ret
