#compdef nft-monitor nftables-monitor
# _nft-monitor — netfilter nftables monitor (real-time stream of every change to the nftables ruleset; subcommands: rules, tables, chains, sets, objects, all (default); -e events filter, -t terse output, -j JSON output, -n no name resolution, --version, --help; same backend as the nft monitor command)
# upstream: https://git.netfilter.org/nftables
# Subcommands from netfilter/nftables src/monitor.c on tip.

_nft-monitor() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-e+[events filter]:events:(new del newrule delrule newchain delchain newtable deltable newset delset newobj delobj newgen genfamily)' \
        '-t[terse output]' \
        '-j[JSON output]' \
        '-n[no name resolution]' \
        '1::object class:(rules tables chains sets objects all)'
}

_nft-monitor "$@"
