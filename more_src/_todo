#compdef todo
# _todo — sirupsen/todo Go CLI (terminal TODO-list manager; subcommands: add, ls, list, edit, done, undo, rm, mv, search, sync, status; -p priority, -t tag, -d deadline; -i inbox id when manipulating items)
# upstream: https://github.com/sirupsen/todo
# Subcommands from todo cmd/todo.go on tip.

_todo() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'todo command' \
                '(add a ls list ll edit e done check undo uncheck rm remove mv search find sync status show open archive clean)'
            ;;
        args)
            _arguments \
                '-p+[priority]:priority:(low normal high)' \
                '-t+[tag]:tag:' \
                '-d+[deadline]:date:' \
                '-i+[item id]:id:' \
                '*:item:'
            ;;
    esac
}

_todo "$@"
