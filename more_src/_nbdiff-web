#compdef nbdiff-web
# Documentation: https://nbdime.readthedocs.io/en/latest/cli.html
# nbdiff-web - rich rendered web diff of two Jupyter notebooks

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show program version]' \
  '--config[list valid config keys and current values]' \
  '--log-level=[set logging verbosity]:level:(DEBUG INFO WARN ERROR CRITICAL)' \
  '(-p --port)'{-p,--port}'=[port for the server]:port:' \
  '(-b --browser)'{-b,--browser}'=[browser to launch]:browser:' \
  '--ip=[interface to listen on]:ip:' \
  '(-w --workdirectory)'{-w,--workdirectory}'=[server working directory]:dir:_files -/' \
  '--base-url=[URL path prefix]:url:' \
  '--persist[keep server running after remote close requests]' \
  '--show-unchanged[show unchanged cells by default]' \
  '--identical-lines-margin=[margin of identical lines to collapse in editor]:n:' \
  '(-s --sources)'{-s,--sources}'[process/ignore sources]' \
  '(-o --outputs)'{-o,--outputs}'[process/ignore outputs]' \
  '(-a --attachments)'{-a,--attachments}'[process/ignore attachments]' \
  '(-m --metadata)'{-m,--metadata}'[process/ignore metadata]' \
  '(-i --id)'{-i,--id}'[process/ignore identifiers]' \
  '(-d --details)'{-d,--details}'[process/ignore details]' \
  '--text-similarity-threshold=[minimum similarity ratio for text]:ratio:' \
  '*:notebook:_files -g "*.ipynb"' && ret=0

return ret
