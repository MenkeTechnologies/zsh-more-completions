#compdef fzmapper
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/gsfml — plot a map of fracture zone traces over a VGG grid

local ret=1

_arguments -s \
  '-A[overlay color-coded analysis from fzanalyzer]' \
  '-F+[original digitized FZ traces file]:file:_files' \
  '-G+[VGG grid for background]:file:_files' \
  '-L+[labeling interval for profiles]:inc:_default' \
  '-O[write PostScript overlay to stdout]' \
  '-S[overlay smoothed FZ trace from fzblender]' \
  '-T+[file name prefix (default fztrack)]:prefix:_default' \
  '-W+[width of Mercator map]:width:_default' \
  '*-V[verbose (stackable)]' \
  '*:input file:_files' \
  && ret=0

return ret
