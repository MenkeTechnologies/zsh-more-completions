#compdef flink-cluster start-cluster.sh stop-cluster.sh flink-cluster-cli
# _flink-cluster — Apache Flink flink-cluster CLI command-line frontend wrapping the Apache Flink stream processing distributed batch processing engine cluster lifecycle start stop status master worker jobmanager taskmanager session-cluster per-job-cluster historyserver standalone yarn kubernetes mesos start-task-executor (Apache Flink team, Java); custom argparse
# upstream: https://flink.apache.org/

_flink-cluster() {
    local -a sub=(
        'start:start cluster'
        'stop:stop cluster'
        'status:show cluster status'
        'jobmanager:JobManager operations'
        'taskmanager:TaskManager operations'
        'historyserver:HistoryServer operations'
        'session:session cluster'
        'application:application cluster'
        'kubernetes:Kubernetes cluster'
        'yarn:YARN cluster'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config dir]:dir:_files -/' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--zookeeper-quorum=+[host:port]:str:' \
        '--zookeeper-root=+[path]:str:' \
        '--rest.bind-address=+[host]:_hosts' \
        '--rest.bind-port=+[port]:n:' \
        '--rest.address=+[host]:_hosts' \
        '--rest.port=+[port]:n:' \
        '--jobmanager.memory.process.size=+[size]:str:' \
        '--taskmanager.memory.process.size=+[size]:str:' \
        '--taskmanager.numberOfTaskSlots=+[N]:n:' \
        '--parallelism.default=+[N]:n:' \
        '--state.backend=+[b]:b:(filesystem hashmap rocksdb)' \
        '--state.checkpoints.dir=+[path]:str:' \
        '--state.savepoints.dir=+[path]:str:' \
        '--high-availability=+[mode]:m:(NONE ZOOKEEPER KUBERNETES)' \
        '--high-availability.storageDir=+[path]:str:' \
        '--cluster-id=+[id]:str:' \
        '-Dkey=value+[k=v]:str:' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'flink-cluster subcommand' sub ;;
    esac
}

_flink-cluster "$@"
