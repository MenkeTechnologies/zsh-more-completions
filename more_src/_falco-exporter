#compdef falco-exporter

# falco-exporter: Prometheus exporter for Falco events
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--listen-address=[listen address]:host:port:' \
  '--metrics-path=[metrics path]:path:' \
  '--telemetry-address=[telemetry address]:host:port:' \
  '--falco-grpc-address=[Falco gRPC address]:host:port:' \
  '--ca-cert=[CA cert]:file:_files' \
  '--client-cert=[client cert]:file:_files' \
  '--client-key=[client key]:file:_files' \
  '--timeout=[timeout]:duration:' \
  '--unix-socket=[unix socket]:file:_files' \
  '*::falco-exporter args:_files' && ret=0
return ret
