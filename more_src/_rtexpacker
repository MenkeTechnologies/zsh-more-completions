#compdef rtexpacker
# Documentation: https://www.raylibtech.com/rtexpacker/
# rTexPacker - raylib textures packer and font atlas generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and usage info]' \
  '(-v --version)'{-v,--version}'[show tool version]' \
  '(-i --input)'{-i,--input}'[define input files]:files:_files' \
  '(-o --output)'{-o,--output}'[define output filename]:output:_files' \
  '(-ad --atlas-desc)'{-ad,--atlas-desc}'[atlas descriptor output format]:fmt:(0 1 2 3 4)' \
  '(-ai --atlas-image)'{-ai,--atlas-image}'[atlas image output format]:fmt:(0 1 2 3)' \
  '(-af --atlas-format)'{-af,--atlas-format}'[atlas image output pixel format]:fmt:(0 1 2 3 4 5 6)' \
  '(-as --atlas-size)'{-as,--atlas-size}'[define atlas size]:size:(128 256 512 1024 2048 4096 8192 16384)' \
  '(-pa --pack-algorithm)'{-pa,--pack-algorithm}'[atlas packing algorithm]:algo:(0 1)' \
  '(-ph --pack-heuristic)'{-ph,--pack-heuristic}'[atlas packing heuristic]:heur:(0 1)' \
  '(-pd --padding)'{-pd,--padding}'[define sprites padding]:padding:' \
  '(-sp --spacing)'{-sp,--spacing}'[define sprites spacing in atlas]:spacing:' \
  '(-ta --trim-alpha)'{-ta,--trim-alpha}'[request sprites alpha trimming]' \
  '*:input file:_files' && ret=0

return ret
