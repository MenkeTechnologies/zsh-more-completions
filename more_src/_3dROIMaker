#compdef 3dROIMaker
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dROIMaker.html
# AFNI create a labelled set of ROIs from functional maps

local ret=1

_arguments -s -S \
  '-inset[3D volume of functional values]:dataset:_files' \
  '-thresh[value threshold for delineating ROI islands]:minthr:' \
  '-prefix[output file name prefix]:prefix:' \
  '-refset[reference volume with integer labels]:dataset:_files' \
  '-volthr[minimum cluster size in voxels]:minvol:' \
  '-only_some_top[keep only the N highest-valued voxels]:n:' \
  '-only_conn_top[grow N voxels from peak through neighbors]:n:' \
  '-inflate[voxels to pad each ROI for GM inflation]:n_infl:' \
  '-trim_off_wm[exclude white matter voxels from input]' \
  '-wm_skel[white matter skeleton to guide inflation]:dataset:_files' \
  '-skel_thr[threshold for the white matter skeleton]:thr:' \
  '-skel_stop[stop inflation at skeleton locations]' \
  '-skel_stop_strict[strict stop preventing inflation into skeleton]' \
  '-csf_skel[CSF mask for trimming]:dataset:_files' \
  '-mask[brain mask constraining thresholding]:mask:_files' \
  '-neigh_face_edge[voxels sharing faces or edges are neighbors]' \
  '-neigh_upto_vert[voxels sharing vertices are neighbors]' \
  '-nifti[output in NIfTI format]' \
  '-preinfl_inset[white matter ROI for pre-inflation]:dataset:_files' \
  '-preinfl_inflate[initial inflation size for pre-inflation]:pn:' \
  '-dump_no_labtab[disable labeltable on output files]' \
  '*:dataset:_files' && ret=0

return ret
