#compdef eboard
# Documentation: https://man.archlinux.org/search?q=eboard
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--quick-fics[quick connect to FICS]' \
  '--fics-server=[FICS server host:port]:host:' \
  '--guest-login[log in as guest]' \
  '--user=[FICS username]:user:' \
  '--password=[FICS password]:pw:' \
  '*:file:_files -g "*.pgn"' && ret=0

return ret
