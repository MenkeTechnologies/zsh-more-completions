#compdef tleap
# Documentation: https://man.archlinux.org/search?q=tleap
# Reference accessed: 2026-05-16

# Amber tleap: terminal-mode interactive system builder
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-help[show help]' \
  '-f[execute script file]:file:_files' \
  '-s[run silent (no warnings)]' \
  '-I[add include path]:dir:_files -/' \
  '*::tleap script:_files' && ret=0
return ret
