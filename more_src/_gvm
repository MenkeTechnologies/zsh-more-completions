#compdef gvm

# Zsh completion for gvm - Go Version Manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'version:show gvm version'
  'get:update gvm'
  'use:select a go version to use'
  'diff:view changes to GVM source'
  'help:display help'
  'implode:complete uninstall of gvm'
  'install:install go versions'
  'uninstall:uninstall a go version'
  'cross:install go cross compilers'
  'list:list installed go versions'
  'listall:list all available go versions'
  'alias:manage go version aliases'
  'pkgset:manage Go package sets'
  'pkgenv:edit package set environment'
)

_gvm_installed_versions() {
  local -a versions
  versions=(${(f)"$(gvm list 2>/dev/null | awk '/go[0-9]/ {print $NF}')"})
  _describe -t versions 'installed go version' versions
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gvm command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (use|uninstall)
        _arguments \
          '--default[set as default]' \
          '1:go version:_gvm_installed_versions' && ret=0
        ;;
      (install)
        _arguments \
          '(-s --source)'{-s,--source}'[install from source]' \
          '(-b --binary)'{-b,--binary}'[install binary]' \
          '(-B --prefer-binary)'{-B,--prefer-binary}'[prefer binary over source]' \
          '--with-build-tools[install build tools]' \
          '--with-protobuf[install with protobuf]' \
          '1:go version:' && ret=0
        ;;
      (cross)
        _arguments \
          '1:go version:_gvm_installed_versions' \
          '2:target OS:(linux darwin windows freebsd netbsd openbsd plan9 solaris)' \
          '3:target arch:(amd64 386 arm arm64 mips mipsle ppc64 ppc64le s390x)' && ret=0
        ;;
      (pkgset)
        _arguments \
          '1:subcommand:(create delete list use)' \
          '--local[operate on local package set]' \
          '2:pkgset name:' && ret=0
        ;;
      (alias)
        _arguments '1:subcommand:(create list delete)' \
          '2:alias name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
