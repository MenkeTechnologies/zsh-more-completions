#compdef typeshare

_typeshare_commands() {
  local -a commands=(
    'generate:Generate type definitions'
    'completions:Generate shell completions'
  )
  _describe 'command' commands
}

_typeshare() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--version[Print version]' \
    '--help[Show help]' \
    '1:command:_typeshare_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        generate)
          _arguments \
            '(-l --language)'{-l,--language}'[Target language]:language:(typescript swift kotlin go)' \
            '(-o --output-file)'{-o,--output-file}'[Output file]:file:_files' \
            '(-c --config-file)'{-c,--config-file}'[Config file]:config:_files -g "*.toml"' \
            '--java-package[Java package for Kotlin]:package:' \
            '--module-name[Swift module name]:name:' \
            '--swift-prefix[Swift type prefix]:prefix:' \
            '--follow-links[Follow symbolic links]' \
            '1:source directory:_directories'
          ;;
        completions)
          _arguments \
            '1:shell:(bash zsh fish elvish powershell)'
          ;;
      esac
      ;;
  esac
}

_typeshare "$@"
