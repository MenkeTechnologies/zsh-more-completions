#compdef xrdcp
# Documentation: https://man.archlinux.org/search?q=xrdcp
# Reference accessed: 2026-05-16

# xrdcp: copy files using xrootd protocol
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '--force[force overwrite]' \
  '-f[force overwrite]' \
  '--continue[continue interrupted transfer]' \
  '-C[continue interrupted transfer]' \
  '--coerce[coerce target file size]' \
  '-d[debug level]:n:' \
  '--silent[silent]' \
  '-s[silent]' \
  '--posc[persist on successful close]' \
  '-P[persist on successful close]' \
  '--proxy=[proxy URL]:url:' \
  '--recursive[recursive]' \
  '-r[recursive]' \
  '--retry=[retry count]:n:' \
  '--retry-policy=[retry policy]:policy:(force continue)' \
  '--streams=[parallel streams]:n:' \
  '--tpc=[third-party copy]:val:(only first second)' \
  '--xrate=[avg xfer rate (B/s)]:rate:' \
  '--server[server-mode]' \
  '--allow-http[allow HTTP source]' \
  '--cksum=[checksum spec]:spec:' \
  '--checksum=[checksum spec]:spec:' \
  '--debug[debug logging]' \
  '--sources=[max source replicas]:n:' \
  '--no-pbar[disable progress bar]' \
  '--zip=[zip archive entry]:archive:' \
  '--dynamic-source[dynamic source]' \
  '--verbose[verbose]' \
  '-v[verbose]' \
  '*:src dst:_files' && ret=0
return ret
