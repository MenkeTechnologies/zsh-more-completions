#compdef xrdcp
# Documentation: https://man.archlinux.org/man/xrdcp.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# xrdcp: copy files using xrootd protocol.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[display usage information]' \
  '(- *)'{-H,--license}'[display license terms]' \
  '(- *)'{-V,--version}'[show version information]' \
  {-C,--cksum}'+[obtain and verify checksums]:type:(adler32 crc32 md5 zcrc32)' \
  '--rm-bad-cksum[remove target file if checksum verification fails]' \
  {-d,--debug}'+[set debug level]:level:(1 2 3)' \
  {-v,--verbose}'[display summary output]' \
  {-s,--silent}'[suppress summary and progress bar]' \
  {-N,--nopbar}'[hide progress bar]' \
  {-f,--force}'[recreate file if it already exists]' \
  {-F,--coerce}'[ignore destination file locking semantics]' \
  {-r,--recursive}'[recursively copy from source directory]' \
  {-P,--posc}'[enable persist-on-successful-close processing]' \
  '--continue[resume interrupted copy]' \
  {-S,--streams}'+[use parallel data streams (max 15)]:n:' \
  {-y,--sources}'+[use multiple sources for copying]:n:' \
  {-X,--xrate}'+[limit copy speed]:rate:' \
  '--xrate-threshold=[force source change if speed drops below threshold]:rate:' \
  '--parallel=[run simultaneous copy jobs]:n:' \
  '--tpc=[enable third-party copy between servers]:mode:(first only)' \
  {-D,--proxy}'+[specify SOCKS4 proxy (not implemented)]:url:' \
  '--notlsok[allow fallback to unencrypted communication]' \
  '--tlsnodata[encrypt control stream only]' \
  '--tlsmetalink[treat metalink URLs as roots/xroots]' \
  {-z,--zip}'+[extract file from ZIP archive]:archive:' \
  {-Z,--dynamic-src}'[allow source size changes during copy]' \
  {-I,--infiles}'+[specify file with input file list]:file:_files' \
  '--xattr[preserve extended attributes]' \
  '--zip-mtln-cksum[use metalink checksum for ZIP extracts]' \
  '*:src dst:_files' && ret=0
return ret
