#compdef descheduler
# _descheduler — Kubernetes Descheduler (kubernetes-sigs/descheduler)
# upstream: https://github.com/kubernetes-sigs/descheduler
# Flags from cmd/descheduler/app/options/options.go on tip.

_descheduler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--descheduling-interval=[descheduler loop interval (0 = run once)]:dur:' \
        '--kubeconfig=[(deprecated) kubeconfig file]:file:_files' \
        '--client-connection-kubeconfig=[kubeconfig file]:file:_files' \
        '--client-connection-qps=[Kubernetes client QPS]:f:' \
        '--client-connection-burst=[Kubernetes client burst]:n:' \
        '--policy-config-file=[descheduler policy YAML file]:file:_files -g "*.(yml|yaml)(-.)"' \
        '--dry-run=[run in dry-run mode]:bool:(true false)' \
        '--disable-metrics=[disable Prometheus metrics endpoint]:bool:(true false)' \
        '--bind-address=[metrics/healthz bind address]:ip:' \
        '--secure-port=[metrics/healthz HTTPS port]:port:' \
        '--enable-http2=[allow HTTP/2 on metrics/health]:bool:(true false)' \
        '--otel-collector-endpoint=[OpenTelemetry collector endpoint]:host\:port:' \
        '--otel-transport-ca-cert=[OTEL gRPC CA cert]:file:_files' \
        '--otel-service-name=[OTEL trace service name]:name:' \
        '--otel-trace-namespace=[OTEL trace namespace]:ns:' \
        '--otel-sample-rate=[OTEL trace sample rate (0.0-1.0)]:f:' \
        '--otel-fallback-no-op-on-error=[fallback to NoOp tracer on error]:bool:(true false)' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '-v[klog verbosity level]:n:'
}

_descheduler "$@"
