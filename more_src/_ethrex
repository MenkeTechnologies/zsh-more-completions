#compdef ethrex
# _ethrex — Rust Ethereum L1/L2 execution client (lambdaclass/ethrex)
# upstream: https://github.com/lambdaclass/ethrex
# Top-level + subcommand flags from cmd/ethrex/cli.rs (clap derive).

_ethrex() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--network=[genesis file path or known network name]:network:_files' \
        '*--bootnodes=[comma-separated enode URLs for P2P bootstrap]:enodes:' \
        '--datadir=[base database directory]:dir:_files -/' \
        '--force[delete the database without confirmation]' \
        '--syncmode=[sync mode]:mode:(full snap)' \
        '--metrics[enable metrics collection]' \
        '--metrics.addr=[metrics bind address]:addr:' \
        '--metrics.port=[Prometheus metrics port]:port:' \
        '--dev[run a local devnet without a Consensus Client]' \
        '--log.level=[log verbosity]:level:(error warn info debug trace)' \
        '--log.color=[log color mode]:mode:(auto always never)' \
        '--log.dir=[directory for log files]:dir:_files -/' \
        '--no-migrate[do not migrate an existing DB to the network subdir]' \
        '--no-precompile-cache[disable per-block precompile result cache]' \
        '--no-bal-parallel-exec[disable BAL-driven parallel transaction execution]' \
        '--no-bal-prefetch[disable BAL-driven state-prefetch warmer thread]' \
        '--no-bal-parallel-trie[disable BAL-driven parallel trie merkleization]' \
        '--mempool.maxsize=[mempool maximum size]:n:' \
        '--http.addr=[HTTP JSON-RPC bind address]:addr:' \
        '--http.port=[HTTP JSON-RPC port]:port:' \
        '--http.namespaces=[comma-separated JSON-RPC namespaces]:namespaces:' \
        '--ws.addr=[WebSocket JSON-RPC bind address]:addr:' \
        '--ws.port=[WebSocket JSON-RPC port]:port:' \
        '--authrpc.addr=[Engine API bind address]:addr:' \
        '--authrpc.port=[Engine API port]:port:' \
        '--authrpc.jwtsecret=[Engine API JWT secret file]:file:_files' \
        '--p2p.disabled[disable P2P networking]' \
        '--p2p.addr=[P2P listen address]:addr:' \
        '--p2p.ip=[P2P advertised IP]:ip:' \
        '--p2p.port=[TCP P2P port]:port:' \
        '--discovery.port=[UDP discovery port]:port:' \
        '--max-peers=[maximum peer count]:n:' \
        '--extra-data=[block extra-data]:bytes:' \
        '--gas-limit=[block gas limit]:gas:' \
        '--max-blobs=[max blobs per block]:n:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_ethrex_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                removedb)
                    _arguments \
                        '--datadir=[database directory]:dir:_files -/' \
                        '--force[remove without confirmation]' && ret=0 ;;
                import)
                    _arguments \
                        '--removedb[remove existing DB before importing]' \
                        '--l2[treat the import as L2 blocks]' \
                        '1:RLP chain file or folder:_files' && ret=0 ;;
                import-bench)
                    _arguments \
                        '--removedb[remove existing DB before importing]' \
                        '--l2[treat the import as L2 blocks]' \
                        '--export-bal=[export BALs from sequential execution to FILE]:file:_files' \
                        '--with-bal=[load BALs from FILE and use parallel execution]:file:_files' \
                        '1:RLP chain file or folder:_files' && ret=0 ;;
                export)
                    _arguments \
                        '1:output RLP file path:_files' && ret=0 ;;
                compute-state-root)
                    _arguments \
                        '--datadir=[database directory]:dir:_files -/' && ret=0 ;;
                repl)
                    _arguments \
                        '--rpc-url=[JSON-RPC endpoint]:url:' && ret=0 ;;
                l2)
                    _arguments \
                        '*:l2 subcommand args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ethrex_commands] )) ||
_ethrex_commands() {
    local -a commands
    commands=(
        'removedb:remove the database'
        'import:import blocks (RLP) into the database'
        'import-bench:import blocks for benchmarking (with BAL options)'
        'export:export current-chain blocks to an RLP file'
        'compute-state-root:recompute and print the state root'
        'repl:interactive REPL for Ethereum JSON-RPC'
        'l2:Layer-2 specific commands'
    )
    _describe -t commands 'ethrex command' commands
}

_ethrex "$@"
