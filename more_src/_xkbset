#compdef xkbset
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/xkbset.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a features

# Features documented in xkbset(1). Each toggleable feature has a long and
# short name; trailing `-` (e.g. m-, sl-) disables.
features=(
  'q:print current settings'
  'exp:print expiry settings'
  'bell:control bell'
  'b:control bell'
  'repeatkeys:control autorepeat'
  'r:control autorepeat'
  'mousekeys:control mousekeys'
  'm:control mousekeys'
  'mousekeysaccel:set mousekeys acceleration'
  'ma:set mousekeys acceleration'
  'accessx:control accessx'
  'a:control accessx'
  'sticky:control stickykeys'
  'st:control stickykeys'
  'slowkeys:control slowkeys'
  'sl:control slowkeys'
  'bouncekeys:control bouncekeys'
  'bo:control bouncekeys'
  'feedback:control feedback'
  'f:control feedback'
  'overlay1:control overlay1'
  'ov1:control overlay1'
  'overlay2:control overlay2'
  'ov2:control overlay2'
  'ignoregrouplock:ignore group lock'
  'groupswrap:set groups wrap mode'
  'nullify:nullify modifier'
  'ignorelock:ignore modifier lock'
  'b-:disable bell'
  'r-:disable autorepeat'
  'm-:disable mousekeys'
  'a-:disable accessx'
  'st-:disable stickykeys'
  'sl-:disable slowkeys'
  'bo-:disable bouncekeys'
  'f-:disable feedback'
  'ov1-:disable overlay1'
  'ov2-:disable overlay2'
)

_arguments -C '*: :->arg' && ret=0

case $state in
  (arg) _describe -t feat 'feature' features && ret=0 ;;
esac

return ret
