#compdef xkbset
# Documentation: https://man.archlinux.org/search?q=xkbset
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a features

features=(
  'q:print current settings'
  'exp:print expiry settings'
  'a:set accessx feature'
  'accessx:set accessx feature'
  'sl:set slowkeys'
  'slowkeys:set slowkeys'
  'bo:set bouncekeys'
  'bouncekeys:set bouncekeys'
  'm:set mousekeys'
  'mousekeys:set mousekeys'
  'mousekeysaccel:set mousekeys acceleration'
  'st:set stickykeys'
  'sticky:set stickykeys'
  'feedback:control feedback'
  'overlay1:set overlay1'
  'overlay2:set overlay2'
  'r:control autorepeat'
  'repeatkey:control autorepeat'
  'repeatkeys:control autorepeat'
  'a-:disable accessx'
  'sl-:disable slowkeys'
  'bo-:disable bouncekeys'
  'm-:disable mousekeys'
  'st-:disable stickykeys'
)

_arguments -C \
  '-display+[X display]:display:' \
  '*: :->arg' && ret=0

case $state in
  (arg) _describe -t feat 'feature' features && ret=0 ;;
esac

return ret
