#compdef dbgate dbgate-bin
# Documentation: https://man.archlinux.org/search?q=dbgate
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '/AddToDesktop[add desktop shortcut (Windows)]' \
  '/AddToStart[add start menu shortcut (Windows)]' \
  '--port=[web server port]:port:' \
  '--listen=[listen address]:host:_hosts' \
  '--config=[config file]:file:_files -g "*.json"' \
  '*:database_file:_files -g "*.{db,sqlite,sqlite3,db3,mdb}"' && ret=0

return ret
