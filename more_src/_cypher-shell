#compdef cypher-shell

# Zsh completion for cypher-shell - Neo4j Cypher Shell

_arguments -s -S \
  '(-u --username)'{-u,--username}'=[username]:user:' \
  '(-p --password)'{-p,--password}'=[password]:password:' \
  '(-a --address)'{-a,--address}'=[server address (bolt://host:port)]:address:' \
  '(-d --database)'{-d,--database}'=[database name]:database:' \
  '--format=[output format]:format:(auto verbose plain)' \
  '--encryption=[encryption mode]:encryption:(true false default)' \
  '*--param=[set a parameter (KEY=VALUE)]:parameter:' \
  '--non-interactive[force non-interactive mode]' \
  '--sample-rows=[number of sample rows for table width]:rows:' \
  '--wrap[wrap output to terminal width]' \
  '--debug[enable debug mode]' \
  '--fail-fast[exit on first failure in non-interactive mode]' \
  '--fail-at-end[exit after all statements in non-interactive mode]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--driver-version[show driver version]' \
  '(-h --help)'{-h,--help}'[show help]'
