#compdef netserver
# netperf server daemon

local ret=1

_arguments -s -S \
  '-d[increase debug level]' \
  '-D[do not daemonize]' \
  '-f[do not fork]' \
  '-h[show help]' \
  '-L[specify local address]:address:_hosts' \
  '-p[specify port number]:port:' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '-v[set verbosity level]:level:' \
  '-Z[passphrase for CPU binding]:passphrase:' && ret=0

return ret
