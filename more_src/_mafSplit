#compdef mafSplit
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: split multiple alignment files

local ret=1

_arguments -s -S \
  '-byTarget[make one file per target sequence (splits.bed is ignored)]' \
  '-outDirDepth=[with -byTarget, create N levels of output directory]:n' \
  '-useSequenceName[with -byTarget, use unique number from target sequence name]' \
  '-useFullSequenceName[with -byTarget, use the target sequence name for output]' \
  '-useHashedName=[with -byTarget, use an N-bit hash of the sequence name]:n' \
  '1:splits bed:_files -g "*.bed"' \
  '2:output root:' \
  '*:maf file:_files -g "*.maf"' && ret=0

return ret
