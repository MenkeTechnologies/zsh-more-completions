#compdef genpng
# Documentation: https://www.libpng.org/pub/png/libpng-manual.txt
# Source: glennrp/libpng contrib/tools/genpng.c — generate synthetic PNG from shape primitives (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '--8bit[output 8-bit PNG (default 16-bit)]' \
    '1:width:_default' \
    '2:height:_default' \
    '*:shape spec (square|circle|line color radius):_default' \
    && ret=0

return ret
