  '(+Fa --all-frames)'{+Fa,--all-frames}'[select all frames]' \
  '(+Rl --rotate-left)'{+Rl,--rotate-left}'[rotate image left (-90 degrees)]' \
  '(+Rr --rotate-right)'{+Rr,--rotate-right}'[rotate image right (+90 degrees)]' \
  '(+Rtd --rotate-top-down)'{+Rtd,--rotate-top-down}'[rotate image top-down (180 degrees)]' \
  '(+Lh --flip-horizontally)'{+Lh,--flip-horizontally}'[flip image horizontally]' \
  '(+Lv --flip-vertically)'{+Lv,--flip-vertically}'[flip image vertically]' \
  '(+Lhv --flip-both-axes)'{+Lhv,--flip-both-axes}'[flip image horizontally and vertically]' \
