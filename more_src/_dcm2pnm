  '(+Pd --predictor-default)'{+Pd,--predictor-default}'[no LZW predictor (default, TIFF)]' \
  '(+Pn --predictor-none)'{+Pn,--predictor-none}'[LZW predictor 1: no prediction (TIFF)]' \
  '(+Ph --predictor-horz)'{+Ph,--predictor-horz}'[LZW predictor 2: horizontal differencing (TIFF)]' \
  '(+Rs --rows-per-strip)'{+Rs+,--rows-per-strip=}'[rows per strip (TIFF, default: 0)]:rows:' \
