  '(+op --write-raw-pnm)'{+op,--write-raw-pnm}'[write 8-bit binary PGM/PPM]' \
  '(+opb --write-8-bit-pnm)'{+opb,--write-8-bit-pnm}'[write 8-bit ASCII PGM/PPM (default for stdout)]' \
  '(+opw --write-16-bit-pnm)'{+opw,--write-16-bit-pnm}'[write 16-bit ASCII PGM/PPM]' \
  '(+opn --write-n-bit-pnm)'{+opn+,--write-n-bit-pnm=}'[write n-bit ASCII PGM/PPM (1..32)]:n:' \
