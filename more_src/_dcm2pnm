  '(+i --interpolate)'{+i+,--interpolate=}'[use interpolation algorithm n when scaling]:algorithm:' \
  '(-i --no-interpolation)'{-i,--no-interpolation}'[no interpolation when scaling]' \
  '(-S --no-scaling)'{-S,--no-scaling}'[no scaling, ignore pixel aspect ratio (default)]' \
