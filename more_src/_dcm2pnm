  '(+Omt --ovl-threshold)'{+Omt,--ovl-threshold}'[use overlay mode "Threshold Replace"]' \
  '(+Omc --ovl-complement)'{+Omc,--ovl-complement}'[use overlay mode "Complement"]' \
