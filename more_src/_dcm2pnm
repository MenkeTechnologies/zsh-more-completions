  '(+w6 --workaround-pred6)'{+w6,--workaround-pred6}'[enable workaround for predictor 6 overflow]' \
  '(+wi --workaround-incpl)'{+wi,--workaround-incpl}'[enable workaround for incomplete JPEG data]' \
