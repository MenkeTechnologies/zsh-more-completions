#compdef taxii taxii-cli taxii2-cli
# _taxii-cli — OASIS TAXII taxii-cli CLI client to TAXII Trusted Automated Exchange of Intelligence Information v1 v2 v2.1 servers polling collections subscribing API-root TAXII-discovery channels pushing pulling STIX1 STIX2 STIX21 content envelopes for federated CTI sharing pipeline (OASIS team, Python); click
# upstream: https://oasis-open.github.io/cti-documentation/taxii/intro.html

_taxii-cli() {
    local -a sub=(
        'discovery:discovery service'
        'collections:list available collections'
        'collection-info:show collection details'
        'objects:fetch objects from a collection'
        'object:fetch single object'
        'versions:fetch versions of an object'
        'manifest:fetch object manifest'
        'add:push objects to a collection'
        'status:fetch upload status'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[url]:str:' \
        '--url=+[url]:str:' \
        '--user=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '--ca-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--insecure[ignore TLS errors]' \
        '--api-root=+[name]:str:' \
        '--collection-id=+[id]:str:' \
        '--added-after=+[date]:str:' \
        '--limit=+[N]:n:' \
        '--next=+[token]:str:' \
        '--match=+[k=v]:str:' \
        '-f+[format]:f:(json yaml stix1 stix2 stix2.1 envelope)' \
        '--format=+[format]:f:(json yaml stix1 stix2 stix2.1 envelope)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'taxii-cli subcommand' sub ;;
        args)
            case $words[1] in
                objects|object|versions|manifest) _arguments '*:id:' ;;
                add) _arguments '*:file:_files -g "*.json"' ;;
            esac
            ;;
    esac
}

_taxii-cli "$@"
