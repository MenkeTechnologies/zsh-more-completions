#compdef cargo-godot
# Documentation: https://github.com/sanpii/cargo-godot
# Source: sanpii/cargo-godot src/opt.rs — cargo subcommand for building Rust Godot extensions.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _cg_cmds
_cg_cmds=(
    'build:build extension'
    'b:build extension (alias)'
    'create:create a new class'
    'debug:launch game via LLDB'
    'editor:launch project in Godot'
    'export:export game'
    'init:create a new project in an existing directory'
    'run:run game'
    'r:run game (alias)'
    'script:execute a GD script'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'cargo-godot command' _cg_cmds && ret=0
        ;;
    args)
        case $words[1] in
            build|b|debug|editor|script)
                _arguments \
                    '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
                    && ret=0
                [[ $words[1] == script ]] && _arguments '1:script:_files'
                ;;
            create)
                _arguments \
                    '--class=[base Godot class (default Node)]:class:_default' \
                    '--dir=[output directory (default ./src/)]:dir:_files -/' \
                    '1:name:_default' \
                    && ret=0
                ;;
            export)
                _arguments \
                    '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
                    '--release[build and export in release mode]' \
                    '1:preset:_default' \
                    '2::output-path:_files -/' \
                    && ret=0
                ;;
            init)
                _arguments '--name=[set the project name]:name:_default' && ret=0
                ;;
            run|r)
                _arguments \
                    '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
                    '--editor-pid=[editor PID]:pid:_default' \
                    '--debug=[debug overlay categories]:debug:(collisions navigation)' \
                    '*::scene:_default' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
