#compdef acra-keymaker
# _acra-keymaker — Acra key generator (cossacklabs/acra)
# upstream: https://github.com/cossacklabs/acra
# Flags from cmd/acra-keymaker/acra-keymaker.go (flag).

_acra-keymaker() {
    _arguments \
        '(- *)-h[show help]' \
        '-client_id=[client ID for keys]:id:' \
        '-keys_output_dir=[private keys output dir]:dir:_files -/' \
        '-keys_public_output_dir=[public keys output dir]:dir:_files -/' \
        '-generate_acrawriter_keys[create keypair for data encryption]' \
        '-generate_hmac_key[create HMAC key]' \
        '-generate_log_key[create log-integrity key]' \
        '-generate_symmetric_storage_key[generate symmetric AcraBlock key]' \
        '-generate_master_key=[generate master key and save to file]:file:_files' \
        '-generate_poisonrecord_keys[generate poison-record keys]' \
        '-keystore=[keystore format]:fmt:(v1 v2)' \
        '-kms_key_policy=[KMS key policy]:policy:(create reuse skip)' \
        '-tls_client_id_cert=[TLS cert to derive client_id]:file:_files -g "*.(pem|crt)"' \
        '-tls_identifier_extractor_type=[TLS client-id extractor]:type:(distinguished_name serial_number)'
}

_acra-keymaker "$@"
