#compdef stella
# Documentation: https://github.com/stella-emu/stella
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: Stella has hundreds of dotted runtime options exposed via its settings system (e.g. -tia.zoom, -audio.volume, -joydeadzone) and no flat command-line reference is published; cannot safely enumerate without inventing.

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '*:rom:_files -g "*.{a26,bin,A26,BIN,zip,gz}"' && ret=0
return ret
