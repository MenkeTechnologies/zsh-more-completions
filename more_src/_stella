#compdef stella

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-fullscreen+[fullscreen]:flag:(0 1)' \
  '-cspeed+[clock speed]:speed:' \
  '-romviewer+[ROM browser size]:n:' \
  '-launcherpos+[launcher position]:WxH:' \
  '-debug[start in debugger]' \
  '-bs+[bank switching scheme]:scheme:(AUTO 0840 2K 3E 3F 4A50 4K 4KSC AR CV CTY DPC DPC+ E0 E7 EF EFSC F0 F4 F4SC F6 F6SC F8 F8SC FA FA2 FE MC SB UA UASW WD X07)' \
  '-tv+[TV mode]:mode:(NTSC PAL SECAM PAL60)' \
  '-pp+[pixel processor]:flag:' \
  '-pal+[palette]:pal:' \
  '-snaploaddir+[snapshot load directory]:dir:_files -/' \
  '-snapsavedir+[snapshot save directory]:dir:_files -/' \
  '-statedir+[state directory]:dir:_files -/' \
  '-romdir+[ROM directory]:dir:_files -/' \
  '-cheatfile+[cheat file]:file:_files' \
  '-palettefile+[palette file]:file:_files' \
  '-propsfile+[properties file]:file:_files' \
  '-nvramdir+[NVRAM directory]:dir:_files -/' \
  '-cfgdir+[config directory]:dir:_files -/' \
  '-listrominfo[print ROM info as PSV]' \
  '*:rom:_files -g "*.{a26,bin}"' && ret=0

return ret
