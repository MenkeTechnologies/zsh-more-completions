#compdef airflow-scheduler
# _airflow-scheduler — Apache Airflow scheduler (drives DAG runs, schedules tasks to queues, monitors completions; -p pidfile, -D daemonize, --num-runs N exit after N scheduling loops, --skip-serve-logs skip log endpoint, --subdir dag folder, --stderr/--stdout/--log-file file paths)
# upstream: https://github.com/apache/airflow
# Flags from Apache Airflow airflow/cli/commands/scheduler_command.py on tip.

_airflow-scheduler() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-D[daemonize]' \
        '--daemon[daemonize]' \
        '-p+[pidfile]:file:_files' \
        '--pid+[pidfile]:file:_files' \
        '-n+[number of runs]:n:' \
        '--num-runs+[number of runs]:n:' \
        '--subdir+[DAG folder]:dir:_files -/' \
        '-S+[DAG folder]:dir:_files -/' \
        '--stderr+[stderr file]:file:_files' \
        '--stdout+[stdout file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--log-file+[log file]:file:_files' \
        '--skip-serve-logs[skip log endpoint]'
}

_airflow-scheduler "$@"
