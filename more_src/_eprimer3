#compdef eprimer3
# Documentation: https://manpages.debian.org/testing/emboss/eprimer3.1e.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS eprimer3: PCR primer design via primer3 (EMBOSS wrapper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input DNA sequence(s)]:DNA USA:_files' \
  '-task=[primer3 task]:task:(0 1 2 3 4)' \
  '-hybridprobe[also design hybridisation probe]' \
  '-numreturn=[number of primer pairs to return]:n:' \
  '-includedregion=[region to include (start..end)]:range:' \
  '-targetregion=[target region (start..end)]:range:' \
  '-excludedregion=[region(s) to exclude]:range:' \
  '-forwardinput=[forward primer hint]:seq:' \
  '-reverseinput=[reverse primer hint]:seq:' \
  '-osize=[optimum primer size]:size:' \
  '-minsize=[minimum primer size]:size:' \
  '-maxsize=[maximum primer size]:size:' \
  '-otm=[optimum primer Tm]:temp:' \
  '-mintm=[minimum primer Tm]:temp:' \
  '-maxtm=[maximum primer Tm]:temp:' \
  '-maxdifftm=[max Tm difference]:temp:' \
  '-ogcpercent=[optimum primer %GC]:pct:' \
  '-mingc=[minimum %GC]:pct:' \
  '-maxgc=[maximum %GC]:pct:' \
  '-saltconc=[Na+ concentration (mM)]:mM:' \
  '-dnaconc=[primer DNA concentration (nM)]:nM:' \
  '-maxpolyx=[max single-base run]:n:' \
  '-productosize=[optimum product size]:size:' \
  '-productsizerange=[product size range]:range:' \
  '-productotm=[optimum product Tm]:temp:' \
  '-productmintm=[min product Tm]:temp:' \
  '-productmaxtm=[max product Tm]:temp:' \
  '-mispriminglibraryfile=[mispriming library file]:file:_files' \
  '-maxmispriming=[max single-template mispriming score]:score:' \
  '-pairmaxmispriming=[max pair mispriming score]:score:' \
  '-explainflag[explain why primer3 picked these primers]' \
  '-outfile=[output report file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
