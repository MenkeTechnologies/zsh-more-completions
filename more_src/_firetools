#compdef firetools
# Documentation: https://github.com/netblue30/firetools
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--autostart[run automatically in system tray on X11 session]' \
  '--debug[print debug messages]' && ret=0

return ret
