#compdef czkawka-cli czkawka_cli

local curcontext="$curcontext" state line ret=1

_czkawka_commands() {
  local -a commands=(
    'duplicates:find duplicate files'
    'empty-folders:find empty folders'
    'big-files:find the biggest files'
    'empty-files:find empty files'
    'temporary-files:find temporary files'
    'similar-images:find similar images'
    'same-music:find same music files'
    'invalid-symlinks:find invalid symlinks'
    'broken-files:find broken files'
  )
  _describe -t commands 'czkawka command' commands
}

_czkawka_common_options() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-d --directories)'{-d,--directories}'[directories to search]:directories:_files -/' \
    '(-e --excluded-directories)'{-e,--excluded-directories}'[directories to exclude]:directories:_files -/' \
    '(-x --excluded-items)'{-x,--excluded-items}'[excluded items pattern]:pattern' \
    '(-f --file-to-save)'{-f,--file-to-save}'[file to save results]:file:_files' \
    '(-n --not-recursive)'{-n,--not-recursive}'[do not search recursively]' \
    "$@"
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:_czkawka_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      duplicates)
        _czkawka_common_options \
          '(-i --minimal-file-size)'{-i,--minimal-file-size}'[minimal file size]:size' \
          '(-o --maximal-file-size)'{-o,--maximal-file-size}'[maximal file size]:size' \
          '--delete-files[delete found duplicate files]' \
          '--hash-type[hash type]:type:(Blake3 CRC32 XXH3)' \
          '--search-method[search method]:method:(Name Size Hash)' \
          '--allow-hard-links[allow hard links]' && ret=0
        ;;
      big-files)
        _czkawka_common_options \
          '(-i --minimal-file-size)'{-i,--minimal-file-size}'[minimal file size]:size' \
          '(-o --maximal-file-size)'{-o,--maximal-file-size}'[maximal file size]:size' \
          '--delete-files[delete found files]' && ret=0
        ;;
      similar-images)
        _czkawka_common_options \
          '(-i --minimal-file-size)'{-i,--minimal-file-size}'[minimal file size]:size' \
          '(-o --maximal-file-size)'{-o,--maximal-file-size}'[maximal file size]:size' \
          '--delete-files[delete found files]' && ret=0
        ;;
      same-music)
        _czkawka_common_options \
          '(-i --minimal-file-size)'{-i,--minimal-file-size}'[minimal file size]:size' \
          '(-o --maximal-file-size)'{-o,--maximal-file-size}'[maximal file size]:size' \
          '--delete-files[delete found files]' && ret=0
        ;;
      empty-folders|empty-files|temporary-files|invalid-symlinks|broken-files)
        _czkawka_common_options \
          '--delete-files[delete found files]' && ret=0
        ;;
    esac
    ;;
esac

return ret
