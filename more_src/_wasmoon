#
# THE wasmoon CLI
#
# wasmoon is invoked as:
#   wasmoon [OPTIONS] [script.lua] [args...]
#
# Common invocations:
#   # Run a Lua script
#   wasmoon hello.lua
#
#   # Run with arguments (available as `arg` table in Lua)
#   wasmoon script.lua arg1 arg2 arg3
#
#   # Mount additional files into the Lua VFS (-l, multi)
#   wasmoon -l util.lua -l helpers.lua main.lua
#
#   # Mount a directory of Lua modules
#   wasmoon -l ./lib main.lua
#
#   # Force interactive REPL after script execution
#   wasmoon -i script.lua
#
#   # Pure REPL mode (no script)
#   wasmoon
#
#   # Pipe Lua code via stdin (process.stdin.isTTY = false)
#   echo 'print("Hello, Lua 5.4")' | wasmoon
#
# OPTIONS (sourced directly from
# https://github.com/ceifa/wasmoon/blob/main/bin/wasmoon):
#
#   -l FILE_OR_DIR             Mount file or directory into the
#                              Lua virtual filesystem (multi);
#                              accessible to `require` + `dofile`
#                              from Lua
#   -i                         Force interactive REPL mode after
#                              script execution (otherwise REPL
#                              runs only when no script + isTTY)
#
# Positional:
#   <script.lua>               Lua source file to execute
#   <args...>                  Arguments passed to the script
#                              (available as global `arg` table
#                              in Lua)
#
# File extensions:
#   .lua                       Lua source code
#
# Lua version: 5.4
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '*-l[mount file/dir into Lua virtual filesystem (multi)]:file:_files' \
    '-i[force interactive REPL after script execution]' \
    '1:Lua script:_files -g "*.lua"' \
    '*::argument:_default' \
    && ret=0

return ret
