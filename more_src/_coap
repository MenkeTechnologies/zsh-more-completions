#compdef coap
# ============================================================================
# _coap — zsh completion for avency/coap-cli, the canonical npm CoAP CLI
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/avency/coap-cli
#   Author     : avency
#   License    : (not standard SPDX in repo)
#   Stars      : 81
#   Language   : JavaScript (Node.js)
#   npm        : coap-cli v0.11.1
#   Binary     : coap  (package.json bin maps `coap` → `index.js`)
#   Last push  : 2024-01-01
#
# WHAT IT IS
#   coap-cli (npm-published as `coap-cli`, installed as the `coap` command)
#   is "a command line interface for CoAP built on node-coap" — a thin
#   commander-based wrapper around Matteo Collina's canonical Node.js CoAP
#   client/server library (`coap` on npm, github.com/coapjs/node-coap).
#   The binary issues a single CoAP RFC 7252 request to a `coap://host/path`
#   URL, with full support for the CoAP feature surface:  GET / PUT / POST /
#   DELETE methods, OBSERVE option (-o) for push-style subscriptions,
#   confirmable vs non-confirmable (-c) messaging, block-wise transfer
#   (-b/--block2), arbitrary CoAP options via -O <number>,<value>, and
#   Content-Format / Accept option negotiation.
#
# CLI ARGUMENT GRAMMAR  (verbatim from index.js commander chain)
#   coap [OPTIONS] <method> <url>
#
#   Methods (each registered as a commander subcommand via the
#   `['GET','PUT','POST','DELETE'].forEach(...)` loop):
#     get <URL>              perform a CoAP GET request
#     put <URL>              perform a CoAP PUT request
#                              (use -p to set the payload)
#     post <URL>             perform a CoAP POST request
#                              (use -p to set the payload)
#     delete <URL>           perform a CoAP DELETE request
#
#   <URL> must be a `coap://host[:port]/path?query` URL parsed by uri-js;
#   any other scheme (coaps:, http:, etc.) is rejected.
#
#   Options:
#     -o, --observe                Observe the given resource         [false]
#     -n, --no-new-line            No newline at end of stream         [true]
#     -p, --payload <PAYLOAD>      Payload for PUT/POST requests
#     -b, --block2 <SIZE>          Set the Block2 size option (parseInt)
#     -q, --quiet                  Do not print status codes          [false]
#     -c, --non-confirmable        Send as non-confirmable             [false]
#     -t, --timeout <SECONDS>      Maximum send time in seconds        [30]
#     -T, --show-timing            Print request time (perf tests)    [false]
#     -O, --coap-option <OPT>      Add CoAP option, e.g. `-O 2048,HelloWorld`
#                                  (repeatable; format: NUMBER,VALUE)
#     -C, --content-format <FMT>   Include Content-Format option
#     -a, --accept <ACCEPT>        Include Accept option
#     -V, --version                Show version (commander auto-flag)
#     -h, --help                   Show help (commander auto-flag)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `coap ^1.0.11` declared in package.json
#   `"dependencies"` block — mcollina/node-coap, "an OMA Lightweight M2M
#   Working Group reference implementation" of CoAP for Node.js,
#   maintained by Matteo Collina (Node.js TSC member; the canonical npm
#   `coap` package, github.com/coapjs/node-coap).  The CLI loads it as
#   `const coap = require('coap')` then dispatches `coap.request(params)`
#   per the user's subcommand + URL.  Verified via:
#     gh api repos/avency/coap-cli/contents/index.js
#     npm view coap-cli dependencies
#       → coap: ^1.0.11
#   This entry is the TS-Node=115 leader bump that CLOSES Axis 60
#   (CoAP IoT Protocol Library) at 1/1/1 three-language symmetry —
#   COMPLETING THE THREE-SCORE AXIS LANDMARK:
#     Rust   = coap-lite 0.4.0      (R829, `coap-client`,         ryankurte)
#     Go     = plgd-dev/go-coap/v3  (R830, `ingress-coap-client`, diwise)
#     TS-Node = coap (mcollina)      (R831, `coap`,                avency)
#   Reaches the triple-115 landmark Rust=Go=TS-Node=115.
#
#   No completion for `coap` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.  The
#   existing `more_src/_coap-cli` in this corpus is the unrelated Go
#   absmach/coap-cli implementation (binary name `coap-cli`, not `coap`).
# ============================================================================

_coap() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-o --observe)'{-o,--observe}'[observe the given resource]' \
        '(-n --no-new-line)'{-n,--no-new-line}'[no newline at end of stream]' \
        '(-p --payload)'{-p+,--payload=}'[payload for PUT/POST requests]:payload:' \
        '(-b --block2)'{-b+,--block2=}'[set the Block2 size option]:block2 size:' \
        '(-q --quiet)'{-q,--quiet}'[do not print status codes of received packets]' \
        '(-c --non-confirmable)'{-c,--non-confirmable}'[send as non-confirmable]' \
        '(-t --timeout)'{-t+,--timeout=}'[maximum send time in seconds (default 30)]:seconds:' \
        '(-T --show-timing)'{-T,--show-timing}'[print request time (handy for perf tests)]' \
        '*'{-O+,--coap-option=}'[add CoAP-Option (NUMBER,VALUE; repeatable)]:option:' \
        '(-C --content-format)'{-C+,--content-format=}'[include Content-Format option]:content format:' \
        '(-a --accept)'{-a+,--accept=}'[include Accept option]:accept:' \
        '(- *)'{-V,--version}'[show version]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_coap_methods' \
        '2:CoAP URL (coap://host[:port]/path):_coap_urls' && ret=0

    return ret
}

(( $+functions[_coap_methods] )) ||
_coap_methods() {
    local -a methods
    methods=(
        'get:perform a CoAP GET request'
        'put:perform a CoAP PUT request (use -p for payload)'
        'post:perform a CoAP POST request (use -p for payload)'
        'delete:perform a CoAP DELETE request'
    )
    _describe -t methods 'coap method' methods
}

(( $+functions[_coap_urls] )) ||
_coap_urls() {
    if [[ -prefix coap:// ]]; then
        _message 'CoAP URL'
    else
        _alternative \
            'examples:CoAP URL:(coap://localhost:5683/.well-known/core coap://localhost:5683/ coap://device.local:5683/sensor)'
    fi
}

_coap "$@"
