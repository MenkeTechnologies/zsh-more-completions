#compdef pcp-ss
# _pcp-ss — PCP-based ss(1)-style socket statistics (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/ss/pcp-ss.py (argparse).

_pcp-ss() {
    _arguments \
        '(- *)'{-V,--version}'[show version]' \
        '(-n --numeric)'{-n,--numeric}'[no service-name resolution]' \
        '(-a --all)'{-a,--all}'[show listening and non-listening states]' \
        '(-l --listening)'{-l,--listening}'[only listening sockets]' \
        '(-o --options)'{-o,--options}'[show timer info]' \
        '(-e --extended)'{-e,--extended}'[show extended socket info]' \
        '(-m --memory)'{-m,--memory}'[show socket memory usage]' \
        '(-i --info)'{-i,--info}'[show internal TCP info]' \
        '(-4 --ipv4)'{-4,--ipv4}'[only IPv4 sockets]' \
        '(-6 --ipv6)'{-6,--ipv6}'[only IPv6 sockets]' \
        '(-t --tcp)'{-t,--tcp}'[only TCP sockets]' \
        '(-u --udp)'{-u,--udp}'[only UDP sockets]' \
        '(-H --noheader)'{-H,--noheader}'[suppress header line]' \
        '(-O --oneline)'{-O,--oneline}'[one line per socket]'
}

_pcp-ss "$@"
