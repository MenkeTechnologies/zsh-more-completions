#compdef xdg-desktop-icon
# _xdg-desktop-icon — XDG xdg-desktop-icon (install/uninstall a .desktop file as a shortcut on the user's desktop directory; install/uninstall stems take a single .desktop file)
# upstream: https://gitlab.freedesktop.org/xdg/xdg-utils
# Subcommands from xdg-utils scripts/xdg-desktop-icon.in on tip.

_xdg-desktop-icon() {
    _arguments \
        '--help[show help]' \
        '--manual[show full manual]' \
        '--version[show version]' \
        '1:command:(install uninstall)' \
        '2:desktop file:_files -g "*.desktop"'
}

_xdg-desktop-icon "$@"
