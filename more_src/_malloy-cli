#compdef malloy-cli
# Documentation: https://docs.malloydata.dev/documentation/malloy_cli/index
# malloy-cli - command-line interface for executing Malloy and SQL

local ret=1

_arguments -s -C \
  '--version[show version]' \
  '--config[configuration directory/file location]:config:_files' \
  '--help[show help]' \
  '1:command:(run compile build help)' \
  '*::arg:_files' && ret=0

return ret
