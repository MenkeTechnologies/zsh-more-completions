#compdef mplotqueries
# mtools plot MongoDB log file data on various graph types

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--logscale[enable logarithmic scale for applicable plots]' \
  '--title=[overwrite default plot title]:title' \
  '--optime-start[plot operations at start time instead of finish time]' \
  '--output-file=[write plot to file (format from extension)]:file:_files' \
  '--checkpoints[show slow WiredTiger checkpoint information]' \
  '--dns[identify and plot slow DNS resolution]' \
  '--oplog[show information about slow oplog operations]' \
  '--group=[group data by attribute]:group:(namespace hostname filename operation thread log2code pattern regex)' \
  '--group-limit=[limit groups to top N by frequency]:n' \
  '--type=[plot type]:type:(scatter histogram durline event range rsstate connchurn nscanned/n)' \
  '--overlay=[manage overlays]:action:(add list reset)' \
  '(--bucketsize -b)'{--bucketsize=,-b+}'[bucket size in seconds for histogram/connchurn]:seconds' \
  '--yaxis=[y-axis value]:field:(duration nscanned nupdated ninserted ntoreturn nreturned numYields r w)' \
  '--gap=[interrupt range plot bars when gaps exceed LEN seconds]:seconds' \
  '*:logfile:_files' && ret=0

return ret
