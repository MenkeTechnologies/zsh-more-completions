#compdef raspi-gpio
# Documentation: https://github.com/RPi-Distro/raspi-gpio/blob/master/README.md
# Dump and modify BCM283x GPIO state (deprecated in favour of pinctrl)

local ret=1

_arguments -s \
  '1:command:(get set funcs raw help)' \
  '*:: :->args' && ret=0

case $state in
  args)
    _values 'set option' \
      'ip[set GPIO as input]' \
      'op[set GPIO as output]' \
      'a0[alternate function alt0]' \
      'a1[alternate function alt1]' \
      'a2[alternate function alt2]' \
      'a3[alternate function alt3]' \
      'a4[alternate function alt4]' \
      'a5[alternate function alt5]' \
      'pu[set pull up]' \
      'pd[set pull down]' \
      'pn[set pull none]' \
      'dh[drive high level]' \
      'dl[drive low level]' && ret=0
    ;;
esac

return ret
