#compdef pluck
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss158.html
# KAPPA: plucks slices from an NDF at arbitrary positions

local ret=1

_arguments -s \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF or container file]:ndf:_files -g "*.sdf"' \
  'AXES=[WCS axes to retain in the output]:axes' \
  'MODE=[how initial coordinates are obtained]:mode:(Interface Catalogue File)' \
  'POS=[coordinates of the slice to extract]:pos' \
  'COIN=[text file of slice coordinates]:file:_files' \
  'INCAT=[catalogue of positions]:catalogue:_files' \
  'CONTAINER=[write slices to one HDS container]:bool:(TRUE FALSE)' \
  'DESCRIBE=[describe the coordinate Frame]:bool:(TRUE FALSE)' \
  'METHOD=[resampling interpolation scheme]:method' \
  'PARAMS=[additional interpolation parameters]:params' \
  'TOL=[max tolerable geometrical distortion]:value' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
