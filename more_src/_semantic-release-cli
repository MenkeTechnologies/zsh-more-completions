#compdef semantic-release-cli
# _semantic-release-cli — bootstrap semantic-release in a project (semantic-release/cli)
# upstream: https://github.com/semantic-release/cli
# Flags from src/index.js (nopt knownOptions).

_semantic-release-cli() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--tag=[npm tag to install]:tag:(latest next beta alpha rc)' \
        '--no-keychain[do not use keychain for passwords]' \
        '--keychain[use keychain for passwords (default)]' \
        '--ask-for-passwords[ask for passwords even if stored]' \
        '--gh-token=[GitHub auth token]:token:' \
        '--npm-token=[npm auth token]:token:' \
        '--circle-token=[CircleCI auth token]:token:' \
        '--npm-username=[npm username]:user:' \
        '1:command:(setup init)'
}

_semantic-release-cli "$@"
