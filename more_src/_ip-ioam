#compdef ip-ioam
# Documentation: https://man.archlinux.org/man/ip-ioam.8.en
# ip ioam - configure IPv6 In-situ OAM internal parameters

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip ioam command' \
      'namespace[namespace operations]' 'schema[schema operations]' \
      'monitor[monitor IOAM6 events]' \
      'show[display entries]' 'add[add entry]' 'del[delete entry]' 'set[set entry]' \
      'data[32-bit data field]' 'wide[64-bit data field]' 'schema[link schema]' && ret=0
    ;;
esac

return ret
