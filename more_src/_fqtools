#compdef fqtools
# Documentation: https://github.com/alastair-droop/fqtools
# FASTQ file processing toolkit

local ret=1

_arguments -s -S \
  '-h[show this help message and exit]' \
  '-v[show the program version and exit]' \
  '-d[allow DNA sequence bases (ACGTN)]' \
  '-r[allow RNA sequence bases (ACGUN)]' \
  '-a[allow ambiguous sequence bases (RYKMSWBDHV)]' \
  '-m[allow mask sequence base (X)]' \
  '-u[allow uppercase sequence bases]' \
  '-l[allow lowercase sequence bases]' \
  '-p+[set pair replacement character (default %)]:char:' \
  '-b+[set input buffer size]:bufsize:' \
  '-B+[set output buffer size]:bufsize:' \
  '-q+[set quality score encoding]:qualtype:' \
  '-f+[set input file format]:format:' \
  '-F+[set output file format]:format:' \
  '-i[read interleaved input file pairs]' \
  '-I[write interleaved output file pairs]' \
  '1:command:(view head count header sequence quality header2 fasta basetab qualtab type validate find trim qualmap)' \
  '*:fastq file:_files' && ret=0

return ret
