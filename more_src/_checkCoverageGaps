#compdef checkCoverageGaps
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# Check for biggest gap in coverage for a list of tracks

local ret=1

_arguments -s -S \
  '-allParts[check all parts]' \
  '-female[use female genome]' \
  '-noComma[do not format numbers with commas]' \
  '*:database track:_files' && ret=0

return ret
