#compdef knoxcli.sh knoxcli
# Documentation: https://raw.githubusercontent.com/apache/knox/master/gateway-server/src/main/java/org/apache/knox/gateway/util/KnoxCLI.java
# Reference accessed: 2026-05-19
# Verified: upstream KnoxCLI.java command dispatch and option parsing.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'version:display version information'
  'create-master:persist the master secret'
  'set-master:update the master secret'
  'create-cert:create a self-signed gateway identity certificate'
  'export-cert:export the gateway public certificate'
  'list-alias:list configured aliases'
  'create-alias:create a credential alias'
  'create-aliases:create multiple credential aliases'
  'create-list-aliases:create and list credential aliases'
  'delete-alias:delete a credential alias'
  'list-topologies:list deployed topologies'
  'validate-topology:validate a topology definition'
  'redeploy:redeploy topologies'
  'service-test:test service connectivity'
  'list-registry-clients:list remote configuration registry clients'
  'upload-descriptor:upload a descriptor to a registry'
  'delete-descriptor:delete a descriptor from a registry'
  'delete-provider-config:delete a provider configuration from a registry'
  'system-user-auth-test:test system user authentication'
  'user-auth-test:test user authentication against LDAP'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--master=[master secret]:secret:' \
  '--force[overwrite existing files]' \
  '--hostname=[hostname]:host:_hosts' \
  '--cluster=[topology/cluster name]:cluster:' \
  '--topology=[topology name]:topology:' \
  '--alias=[alias name]:alias:' \
  '--value=[alias value]:value:' \
  '--path=[file or registry path]:path:_files' \
  '--port=[port]:port:' \
  '--type=[entity type]:type:' \
  '--generate[generate a value]' \
  '--d[delete]' \
  '--g[generate aliased value]' \
  '--p[password]:password:' \
  '--u[user name]:user:_users' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'knoxcli subcommand' subcommands && ret=0
    ;;
esac

return ret
