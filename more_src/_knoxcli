#compdef knoxcli knoxcli.sh knox

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'version:show Knox version'
  'create-master:persist the master secret'
  'set-master:set/update the master secret'
  'create-cert:create a self-signed certificate for the gateway'
  'export-cert:export the gateway public certificate'
  'list-alias:list password aliases'
  'create-alias:create a password alias'
  'delete-alias:delete a password alias'
  'list-topologies:list available topologies'
  'validate-topology:validate a topology file'
  'redeploy:redeploy a topology'
  'service-test:test a topology service'
  'list-descriptors:list provider descriptors'
  'list-provider-configs:list shared provider configs'
  'remote-registry-client:remote registry client operations'
  'jwk:JSON Web Key operations'
  'jwt:JSON Web Token operations'
  'export-saml-metadata:export SAML metadata'
  'system-user-auth-test:test system user authentication'
  'user-auth-test:test user authentication'
  'ldap-bind-test:test LDAP bind'
  'topology-convert:convert legacy topology'
  'list-registry-clients:list ZooKeeper registry clients'
  'remote-config-monitor:monitor remote config'
  'rotate:rotate keys'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--master=[master secret]:secret:' \
  '--gateway=[gateway home]:dir:_files -/' \
  '--persist-master[persist master secret]' \
  '--force[overwrite existing files]' \
  '--hostname=[hostname]:host:_hosts' \
  '--cluster=[cluster name]:cluster:' \
  '--topology=[topology name]:topology:' \
  '--alias=[alias name]:alias:' \
  '--value=[alias/secret value]:value:' \
  '--provider=[provider config name]:name:' \
  '--descriptor=[descriptor name]:name:' \
  '--service=[service name]:service:' \
  '--user=[user name]:user:_users' \
  '--password=[password]:password:' \
  '--g[generate aliased value]' \
  '--type=[entity type]:type:' \
  '--registry-client=[registry client name]:name:' \
  '--out=[output file]:file:_files' \
  '--in=[input file]:file:_files' \
  '--config=[config file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'knox subcommand' subcommands && ret=0
    ;;
esac

return ret
