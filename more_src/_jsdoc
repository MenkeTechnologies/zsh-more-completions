#compdef jsdoc

# Zsh completion for jsdoc - JavaScript documentation generator

_arguments -s -S \
  '(-c --configure)'{-c,--configure}'[path to configuration file]:file:_files' \
  '(-d --destination)'{-d,--destination}'[output directory]:directory:_directories' \
  '(-e --encoding)'{-e,--encoding}'[encoding for reading source files]:encoding' \
  '--match[only run tests whose names contain this value]:pattern' \
  '(-P --package)'{-P,--package}'[path to package.json file]:file:_files' \
  '(-p --private)'{-p,--private}'[include symbols marked as private]' \
  '(-R --readme)'{-R,--readme}'[path to README file]:file:_files' \
  '(-r --recurse)'{-r,--recurse}'[recurse into subdirectories]' \
  '(-t --template)'{-t,--template}'[path to template directory]:directory:_directories' \
  '(-T --test)'{-T,--test}'[run tests and exit]' \
  '(-u --tutorials)'{-u,--tutorials}'[path to tutorials directory]:directory:_directories' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug[log information for debugging JSDoc]' \
  '--explain[dump all doclets to console and exit]' \
  '--pedantic[treat errors as fatal errors and warnings as errors]' \
  '--query[query string to parse for @link tags]:string' \
  '--verbose[log detailed information to console]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:files:_files -g "*.{js,jsx,ts,tsx}"' && return 0
