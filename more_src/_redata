#compdef redata

# EMBOSS redata: retrieve restriction enzyme details from REBASE
# Input: enzyme name(s). Output: text/HTML report with isoschizomers,
# suppliers, and primary literature references.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show command-line help and exit]' \
  '-auto[turn off all interactive prompts; use defaults for missing data]' \
  '-stdout[write report to stdout instead of an output file]' \
  '-filter[read stdin, write stdout (pipeline mode)]' \
  '-options[force prompts for every standard ACD qualifier]' \
  '-debug[log debug info to program.dbg]' \
  '-verbose[print informational messages]' \
  '-warning[report warnings (default on)]' \
  '-error[report error messages (default on)]' \
  '-fatal[report fatal errors (default on)]' \
  '-die[report program-dying messages (default on)]' \
  '-version[print EMBOSS version and exit]' \
  '-outfile=[report output file (default redata.out)]:file:_files' \
  '-enzymes=[restriction enzymes to query (comma-list, "all" for everything)]:enzymes:' \
  '-isoschizomers[include isoschizomers in report]' \
  '-references[include the REBASE bibliographic references]' \
  '-suppliers[include the list of commercial suppliers]' \
  '*:enzyme name (e.g. EcoRI, BamHI):' && ret=0

return ret
