#compdef wimlib-imagex
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex.1.html
# wimlib-imagex — extract, create, modify, or mount a WIM (Windows Imaging) archive

local ret=1

_arguments -s -S \
  '(- *)--help[show help and exit]' \
  '(- *)--version[show version and exit]' \
  '--quiet[suppress status and progress messages]' \
  '*:: :->cmds' && ret=0

case $state in
  cmds)
    local -a subcmds
    subcmds=(
      'append:capture an image and add it to an existing WIM'
      'apply:extract or deploy a full WIM image'
      'capture:create a new WIM file from a captured image'
      'delete:remove an image from a WIM file'
      'dir:list files contained in a WIM image'
      'export:copy images from one WIM to another'
      'extract:retrieve specific files or directories from a WIM image'
      'info:display or modify WIM file metadata'
      'join:combine a split WIM into a single file'
      'mount:mount a WIM image read-only via FUSE'
      'mountrw:mount a WIM image read-write via FUSE'
      'optimize:rebuild and recompress a WIM file'
      'split:divide a WIM file into multiple parts'
      'unmount:unmount a mounted WIM image'
      'update:add, delete, or rename files in an image'
      'verify:check validity and integrity of a WIM file'
    )
    _describe -t commands 'wimlib-imagex command' subcmds && ret=0
    ;;
esac

return ret
