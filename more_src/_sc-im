#compdef sc-im

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--autocalc[enable auto recalculation]' \
  '--nocurses[run without curses interface]' \
  '--numeric[numeric precision]:digits' \
  '--quit_afterload[quit after loading file]' \
  '--sheet=[sheet number to open]:number' \
  '--txtdelim=[text delimiter]:delimiter' \
  '--txt_header[first line is header]' \
  '-R[rows to show]:rows' \
  '-C[columns to show]:columns' \
  '*:file:_files -g "*.{sc,csv,tsv,xls,xlsx,ods,tab,txt}"'
