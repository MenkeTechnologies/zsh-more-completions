#compdef ot-redis-operator
# _ot-redis-operator — OT-Container-Kit Redis Operator (cobra multi-call: `manager` reconciles Redis/RedisCluster/RedisReplication/RedisSentinel CRs; `agent` runs as the Redis init/sidecar)
# upstream: https://github.com/ot-container-kit/redis-operator
# Subcommands + flags from cmd/main.go + internal/cmd/{manager,agent}/cmd.go on tip.

_ot-redis-operator() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                manager:'start the Redis operator manager (controller-runtime)'
                agent:'run the Redis init/sidecar agent (bootstrap)'
            )
            _describe -t commands 'ot-redis-operator subcommand' subs
            ;;
        args)
            case $line[1] in
                manager)
                    _arguments \
                        '--metrics-bind-address=[metric endpoint bind address]:addr:' \
                        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
                        '--pprof-bind-address=[pprof endpoint bind address (empty = disabled)]:addr:' \
                        '--leader-elect[enable leader election]' \
                        '--enable-webhooks=[enable admission webhooks (default from envs.IsWebhookEnabled)]:bool:(true false)' \
                        '--max-concurrent-reconciles=[max concurrent reconciles]:n:' \
                        '--feature-gates=[csv key=value feature gates for alpha/experimental features]:gates:'
                    ;;
                agent)
                    _arguments \
                        '1: :(bootstrap)'
                    ;;
            esac
            ;;
    esac
}

_ot-redis-operator "$@"
