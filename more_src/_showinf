#compdef showinf
# Documentation: https://bio-formats.readthedocs.io/en/stable/users/comlinetools/display.html
# bio-formats: display image and metadata on the console

local ret=1

_arguments -s \
  '-noflat[do not flatten resolutions into individual series]' \
  '-series[display a different series]:series number:' \
  '-omexml[display the OME-XML metadata]' \
  '-nopix[suppress image reading, metadata only]' \
  '-option[pass options as key/value pairs]:key: :value:' \
  '-range[open a subset of images]:start: :end:' \
  '-crop[open a small tile]:x,y,width,height:' \
  '-no-upgrade[disable version update checks]' \
  '-novalid[disable OME-XML validation]' \
  '-nocore[suppress most output]' \
  '-omexml-only[display the OME-XML alone]' \
  '-debug[enable debugging output]' \
  '-fast[display an image as quickly as possible]' \
  '-autoscale[adjust display range to min/max pixel values]' \
  '-cache[cache the reader under the input file directory]' \
  '-cache-dir[base directory to cache the reader]:directory:_files -/' \
  '-swap[override the default input dimension order]:dimension order:' \
  '-format[specify the reader to open the file]:format:' \
  '-fill[set fill value for undefined pixels]:value:' \
  '*:file:_files' && ret=0

return ret
