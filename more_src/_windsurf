#compdef windsurf

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-n,--new-window}'[force to open a new window]' \
  {-r,--reuse-window}'[force to open a file in an already opened window]' \
  {-w,--wait}'[wait for the files to be closed before returning]' \
  {-d,--diff}'[compare two files]:file 1:_files:file 2:_files' \
  {-g,--goto}'[open file at path on specific line and column (path\:line\:column)]:file\:line\:column' \
  '--folder-uri=[open a folder by URI]:folder URI' \
  '--file-uri=[open a file by URI]:file URI' \
  '--install-extension=[install an extension]:extension id' \
  '--list-extensions[list installed extensions]' \
  '--uninstall-extension=[uninstall an extension]:extension id' \
  '--enable-proposed-api=[enable proposed API for extension]:extension id' \
  '--locale=[locale to use]:locale' \
  '--verbose[print verbose output]' \
  '--log=[log level]:level:(critical error warn info debug trace off)' \
  {-s,--status}'[print process usage and diagnostics]' \
  '--prof-startup[run CPU profiler during startup]' \
  '--disable-extensions[disable all installed extensions]' \
  '--disable-extension=[disable a specific extension]:extension id' \
  '--inspect-extensions=[port for extension host debugging]:port' \
  '--inspect-brk-extensions=[port for extension host debugging with break]:port' \
  '--disable-gpu[disable GPU hardware acceleration]' \
  '--telemetry[show telemetry status]' \
  '--max-memory=[max memory size for a window in MB]:size' \
  '*:file or folder:_files' && ret=0

return ret
