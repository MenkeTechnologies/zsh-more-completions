#compdef las2shp
# Documentation: https://github.com/LAStools/LAStools
# LAStools: convert LAS/LAZ points to an ESRI shapefile

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help output]' \
  '-version[report tool version]' \
  '-gui[start with files loaded into GUI]' \
  '-demo[run in demo mode]' \
  '-license[show license information]' \
  '(-v -verbose)'{-v,-verbose}'[show extra information]' \
  '-vv[print extensive detail]' \
  '-silent[output only on errors/warnings]' \
  '-quiet[suppress all output]' \
  '-force[continue despite serious warnings]' \
  '-errors_ignore[continue despite errors]' \
  '-parse+[parsing string to access point values]:parse string' \
  '-record+[shapefile output record size (default 1024)]:n' \
  '-record_size+[shapefile output record size (default 1024)]:n' \
  '-single_points[use SHP point type 11 instead of MultiPointZ]' \
  '-week_to_adjusted+[convert GPS week to adjusted standard]:week' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-lof+[use input from list-of-files]:file:_files' \
  '-merged[merge multiple input files]' \
  '-o+[output file]:output:_files' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output file suffix]:suffix' \
  '-cores+[process inputs on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
