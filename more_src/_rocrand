#compdef rocrand-test rocrand-benchmark
# _rocrand — AMD ROCm rocRAND pseudo-random and quasi-random number generators test and benchmark runners (ROCm team, C++); custom argparse
# upstream: https://github.com/ROCm/rocRAND

_rocrand() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--gtest_filter=+[pattern]:str:' \
        '--gtest_list_tests[list tests]' \
        '--gtest_repeat=+[N]:n:' \
        '--gtest_random_seed=+[N]:n:' \
        '--gtest_color=+[mode]:m:(yes no auto)' \
        '-e+[engine]:e:(xorwow philox_4x32_10 mrg32k3a mtgp32 sobol32 scrambled_sobol32 sobol64 scrambled_sobol64 mt19937 threefry2x32_20 threefry4x32_20 threefry2x64_20 threefry4x64_20 lfsr113)' \
        '--engine=+[engine]:e:(xorwow philox_4x32_10 mrg32k3a mtgp32 sobol32 scrambled_sobol32 sobol64 scrambled_sobol64 mt19937 threefry2x32_20 threefry4x32_20 threefry2x64_20 threefry4x64_20 lfsr113)' \
        '-d+[distribution]:d:(uniform-uint uniform-half uniform-float uniform-double normal-half normal-float normal-double lognormal-half lognormal-float lognormal-double poisson)' \
        '--dis=+[distribution]:d:(uniform-uint uniform-half uniform-float uniform-double normal-half normal-float normal-double lognormal-half lognormal-float lognormal-double poisson)' \
        '-s+[size]:n:' \
        '--size=+[size]:n:' \
        '-t+[iterations]:n:' \
        '--trials=+[iterations]:n:' \
        '--offset=+[N]:n:' \
        '--seed=+[seed]:n:' \
        '--lambda=+[F]:f:' \
        '--mean=+[F]:f:' \
        '--stddev=+[F]:f:' \
        '--dim=+[N]:n:' \
        '--device=+[id]:n:' \
        '--name=+[name]:str:'
}

_rocrand "$@"
