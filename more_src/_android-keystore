#compdef android-keystore
# Documentation: https://github.com/codemagic-ci-cd/cli-tools/tree/master/docs/android-keystore
# Codemagic CLI tools - manage your Android app code signing keystores

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-s --silent)'{-s,--silent}'[suppress log output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--no-color[disable colored output]' \
  '--log-stream=[log output destination]:stream:(stderr stdout)' \
  '1:command:(create create-debug-keystore certificate certificates verify)' \
  '*::args:->args' && ret=0

return ret
