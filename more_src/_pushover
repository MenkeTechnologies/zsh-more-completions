#compdef pushover pushover.sh
# _pushover — bash Pushover.net notification sender (jnwatts/pushover.sh)
# upstream: https://github.com/jnwatts/pushover.sh
# Flags from pushover.sh usage().

_pushover() {
    _arguments \
        '-c+[callback URL]:url:' \
        '-d+[device name]:device:' \
        '-D+[unix timestamp]:ts:' \
        '-e+[expire seconds (priority 2)]:secs:' \
        '-f+[config file]:file:_files' \
        '-p+[priority (-2..2)]:n:(-2 -1 0 1 2)' \
        '-r+[retry interval seconds]:secs:' \
        '-t+[message title]:title:' \
        '-T+[Pushover API token (30 chars)]:token:' \
        '-m+[message body file]:file:_files' \
        '-s+[notification sound]:sound:' \
        '-u+[supplementary URL]:url:' \
        '-U+[Pushover user key (30 chars)]:user:' \
        '-a+[supplementary URL title]:title:' \
        '*:message:'
}

_pushover "$@"
