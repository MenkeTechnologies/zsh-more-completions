#compdef bnfc
# Documentation: https://bnfc.readthedocs.io/en/latest/user_guide.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--haskell[generate Haskell code (default)]' \
  '--agda[generate Agda bindings]' \
  '--java[generate Java code]' \
  '--c[generate C code]' \
  '--cpp[generate C++ code]' \
  '--ocaml[generate OCaml code]' \
  '--antlr[generate ANTLRv4 parser/lexer]' \
  '--pygments[generate Pygments lexer]' \
  '-d[place generated files into subdirectory]' \
  '-m[generate a Makefile]' \
  '--functor[positions in Agda syntax trees]' \
  '--positions=[positions]:mode:(start range)' \
  '*:grammar file:_files -g "*.cf"'
