#compdef whatsup
# _whatsup — LLNL whatsup cluster node-status client; queries whatsupd to report up/down node sets, integrates with genders
# upstream: https://github.com/chaos/whatsup

_whatsup() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-u[print up nodes only]' \
        '-d[print down nodes only]' \
        '-b[print both up and down nodes]' \
        '-t[print node counts]' \
        '-l[print as newline-separated list]' \
        '-c[print as comma-separated list]' \
        '-s[print as space-separated list]' \
        '-q[hostrange output]' \
        '-n[show node names]' \
        '-i[invert output]' \
        '-f+[genders file]:file:_files' \
        '-o+[whatsupd host]:host:_hosts' \
        '-p+[whatsupd port]:port:' \
        '-m+[backend module]:module:(ganglia hostsfile genders)' \
        '*:node:'
}

_whatsup "$@"
