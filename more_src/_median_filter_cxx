#compdef median_filter_cxx
# Documentation: https://healpix.sourceforge.io/doc/html/Healpix_cxx/facilities.html
# HEALPix C++: apply a median filter to a HEALPix map

local ret=1

_arguments -s -S \
  '1:input map:_files' \
  '2:output map:_files' \
  '3:filter radius in arcmin:' && ret=0

return ret
