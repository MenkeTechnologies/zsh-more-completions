#compdef surfit
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss197.html
# KAPPA: fit a polynomial or bi-cubic spline surface to two-dimensional data

local ret=1

_arguments -s \
  'BINDIM=[x-y dimensions of a binning bin]:bindim' \
  'CLIP=[clipping limits during binning]:clip' \
  'ESTIMATOR=[bin representative-value method]:estimator:(Mean Ksigma Mode Median)' \
  'EVALUATE=[method to evaluate the output array]:evaluate' \
  'FITCLIP=[clipping limits for the binned array]:fitclip' \
  'FITTYPE=[type of fit]:fittype:(Polynomial Spline)' \
  'GENVAR=[create a constant variance array]:genvar:(TRUE FALSE)' \
  'LOGFILE=[file to log the binned array]:file:_files' \
  'IN=[input NDF with the 2D data array]:NDF:_files' \
  'KNOTS=[number of interior knots for spline]:knots' \
  'ORDER=[orders of the polynomial fits]:order' \
  'OUT=[output NDF with the fitted array]:NDF:_files' \
  'THRHI=[upper exclusion threshold]:thrhi' \
  'THRLO=[lower exclusion threshold]:thrlo' \
  'TITLE=[title for the output NDF]:title' \
  'WLIM=[minimum fraction of good pixels in a bin]:wlim' \
  '*:NDF:_files' && ret=0

return ret
