#compdef bass
# ---------------------------------------------------------------------------
# bass — low fidelity scripting language for project infrastructure (Go, 424★)
#
# upstream: https://github.com/vito/bass
# author : Alex Suraci  (vito — also created Concourse CI, runs vito.io)
# license: Apache-2.0
#
# Source-direct completion: every flag below is verbatim from cmd/bass/main.go
# spf13/pflag init() block on the bass tip — flags.StringSliceVarP /
# BoolVarP / StringVarP / IntVar / BoolVar registrations.
#
# Direct deps from go.mod (selected):
#   github.com/alecthomas/chroma     ← canonical Go syntax highlighter
#                                      (this axis) — drives bass REPL +
#                                      LSP semantic-tokens output
#   github.com/spf13/pflag           (POSIX-style CLI flag parser)
#   github.com/moby/buildkit/util/appcontext  (signal-aware ctx)
#   go.uber.org/zap, go.uber.org/zap/zapcore (structured logging)
#
# bass is a scripting language for project infrastructure built on top of
# BuildKit thunks — every "thunk" is a hermetic, content-addressable
# execution unit that bass orchestrates over local runtimes or remote
# SSH-served runners.
#
# === AXIS 159 CONTINUES — syntax highlighting library ecosystem ===
# Axis position: Go=214 continues Axis 159 (slot 2/0/0).  Canonical Go
# syntax highlighter is `alecthomas/chroma` by Alec Thomas (also kong,
# participle, kingpin, kompose) — a Go port of Pygments' lexer grammar
# format powering Hugo's code-block highlighting, gitea/gitlab web
# rendering, charm.sh's glow markdown renderer, gh CLI, glamour, Pterodactyl,
# soft-serve, Lemmy.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=214   _basic-http-server   ← previous round (axis 159 OPENS at 1/0/0)
#   Go=214     ← THIS FILE          (axis 159 continues, slot 2/0/0)
#   TS-Node=214 ← next round        (axis 159 CLOSES at triple-214, slot 1/1/1)
# ---------------------------------------------------------------------------

_bass() {
    _arguments -s -S \
        '*'{-i,--input=}'[input to encode as JSON on *stdin*, name=value (value may be a path)]:name=value:' \
        '(-e --export)'{-e,--export}'[write thunk path to stdout as a tar stream (or log the tar contents on tty)]' \
        '--run[run a thunk read from stdin in JSON format]' \
        '(-b --bump)'{-b,--bump}'[re-generate all calls in bass.lock files]' \
        '(-p --prune)'{-p,--prune}'[release data and caches retained by runtimes]' \
        '(-r --runner)'{-r,--runner=}'[serve locally configured runtimes over SSH]:addr:' \
        '--lsp[run the bass language server]' \
        '--lsp-log-file=[write language server logs to this file]:file:_files' \
        '--frontend[run the bass buildkit frontend]' \
        '--profile=[port number to bind for Go HTTP profiling]:port:_ports' \
        '--cpu-profile=[take a CPU profile and save it to this path]:path:_files' \
        '--debug[show debug logs]' \
        '(- *)'{-v,--version}'[print the version number and exit]' \
        '(- *)'{-h,--help}'[show bass usage and exit]' \
        '*:bass script:_files -g "*.bass"'
}

_bass "$@"
