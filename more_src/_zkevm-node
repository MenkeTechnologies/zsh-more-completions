#compdef zkevm-node
# _zkevm-node — Polygon Labs zkevm-node L2 sequencer-aggregator node for the Polygon zkEVM zero-knowledge rollup batching txs sending state-roots and proofs to L1 (0xPolygonHermez team, Go); urfave/cli
# upstream: https://github.com/0xPolygonHermez/zkevm-node

_zkevm-node() {
    local -a sub=(
        'version:show version'
        'run:run node components'
        'approve:approve MATIC for sequencer'
        'encrypt-key:encrypt private key'
        'dump-state:dump state'
        'restore:restore state'
        'snapshot:snapshot state'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--cfg=+[config file]:file:_files -g "*.toml *.yaml"' \
        '-c+[config file]:file:_files -g "*.toml *.yaml"' \
        '--network=+[net]:n:(mainnet cardona custom)' \
        '-n+[net]:n:(mainnet cardona custom)' \
        '--custom-network-file=+[file]:file:_files -g "*.json"' \
        '--components=+[csv]:str:' \
        '--http.api=+[apis]:str:' \
        '--http.port=+[port]:n:' \
        '--ws.port=+[port]:n:' \
        '--metrics.port=+[port]:n:' \
        '--metrics.profile-port=+[port]:n:' \
        '--prover.uri=+[url]:str:' \
        '--executor.uri=+[url]:str:' \
        '--hashdb.uri=+[url]:str:' \
        '--state-db.host=+[host]:h:_hosts' \
        '--state-db.port=+[port]:n:' \
        '--pool-db.host=+[host]:h:_hosts' \
        '--pool-db.port=+[port]:n:' \
        '--event-db.host=+[host]:h:_hosts' \
        '--event-db.port=+[port]:n:' \
        '--key-store-encryption-password=+[password]:str:' \
        '--migrations[run migrations]' \
        '--http-port-range=+[range]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zkevm-node subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--components=+[csv]:str:' \
                    '--http.api=+[apis]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_zkevm-node "$@"
