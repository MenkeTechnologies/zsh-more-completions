#compdef cadence
# _cadence-cli — CLI for Uber's Cadence workflow engine (uber/cadence)
# upstream: https://github.com/uber/cadence

_cadence-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--address=[Cadence frontend address]:addr:' \
        '--domain=[Cadence domain]:domain:' \
        '--env=[environment]:env:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_cadence_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                domain)
                    local -a domain_subs=(
                        'register:register a new domain'
                        'describe:describe a domain'
                        'update:update a domain'
                    )
                    _describe -t cmds 'domain subcommand' domain_subs && ret=0 ;;
                workflow)
                    local -a wf_subs=(
                        'start:start a workflow execution'
                        'run:start and wait for a workflow'
                        'cancel:cancel a workflow execution'
                        'signal:signal a workflow execution'
                        'terminate:terminate a workflow execution'
                        'describe:describe a workflow execution'
                        'show:show workflow history'
                        'query:query a workflow execution'
                        'stack:query workflow stack trace'
                        'list:list workflow executions'
                        'count:count workflow executions'
                        'scan:scan workflow executions'
                        'observe:observe a workflow execution'
                        'reset:reset a workflow execution'
                        'reset-batch:batch reset workflow executions'
                    )
                    _describe -t cmds 'workflow subcommand' wf_subs && ret=0 ;;
                tasklist)
                    local -a tl_subs=(
                        'describe:describe a task list'
                        'list-partition:list task list partitions'
                    )
                    _describe -t cmds 'tasklist subcommand' tl_subs && ret=0 ;;
                admin)
                    local -a admin_subs=(
                        'workflow:admin workflow operations'
                        'shard:admin shard operations'
                        'history:admin history operations'
                        'domain:admin domain operations'
                        'queue:admin queue operations'
                        'cluster:admin cluster operations'
                        'dlq:admin dead-letter queue operations'
                        'db:admin database operations'
                        'config:admin config operations'
                        'async-queue:admin async queue operations'
                    )
                    _describe -t cmds 'admin subcommand' admin_subs && ret=0 ;;
                cluster)
                    local -a cl_subs=(
                        'add:add a new cluster'
                        'remove:remove a cluster'
                        'list:list clusters'
                        'upsert-domains:upsert domains in a cluster'
                    )
                    _describe -t cmds 'cluster subcommand' cl_subs && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_cadence_commands] )) ||
_cadence_commands() {
    local -a commands
    commands=(
        'domain:manage Cadence domains'
        'workflow:manage workflow executions'
        'tasklist:manage task lists'
        'admin:admin operations'
        'cluster:manage clusters'
    )
    _describe -t commands 'cadence command' commands
}

_cadence-cli "$@"
