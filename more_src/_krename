#compdef krename
# Documentation: https://man.archlinux.org/search?q=krename
# Reference accessed: 2026-05-16

# KRename: KDE batch file renamer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--test[just test the renaming, no changes]' \
  '-r[rename mode (default)]' \
  '--rename[rename mode (default)]' \
  '-c[copy mode]' \
  '--copy[copy mode]' \
  '-m[move mode]' \
  '--move[move mode]' \
  '-l[link mode]' \
  '--link[link mode]' \
  '--header[treat first line of rename file as header]' \
  '*:files:_files' && ret=0
return ret
