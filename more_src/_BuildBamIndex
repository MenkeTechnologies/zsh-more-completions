#compdef BuildBamIndex
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/BuildBamIndex.java
# Picard: generate a BAM index (.bai) for a coordinate-sorted BAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[coordinate-sorted BAM or GA4GH url]:file:_files -g "*.bam"' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output BAM index file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
