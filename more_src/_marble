#compdef marble marble-qt
# Documentation: https://man.archlinux.org/search?q=marble
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug-info[show debug info]' \
  '--enable-file-view[enable file view]' \
  '--latlon=+[lat,lon]:loc:' \
  '--distance=+[distance]:n:' \
  '--map=+[map theme]:theme:' \
  '--display=+[X display]:disp:' \
  '*:file:_files -g "*.{kml,gpx,osm}"' && ret=0

return ret
