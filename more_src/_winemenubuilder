#compdef winemenubuilder winemenubuilder.exe

# winemenubuilder: Wine internal helper that installs desktop integration
# from Windows shortcuts / URL files. Invoked automatically by Wine.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-a[associate all file extensions]' \
  '-r[install Windows shortcut file (.lnk or .url)]:lnk file:_files -g "*.(lnk|url)"' \
  '-u[uninstall Windows shortcut file]:lnk file:_files -g "*.(lnk|url)"' \
  '-w[wait for changes to file]' \
  '-t[install icon to filename]:resource:' \
  '*:lnk/url file:_files -g "*.(lnk|url)"' && ret=0

return ret
