#compdef walker
# Documentation: https://man.archlinux.org/search?q=walker
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--gapplication-service[run as background service]' \
  '*--modules=[restrict to module]:module:(applications calc clipboard commands custom_commands dmenu emojis finder runner ssh symbols translation websearch windows)' \
  '--password[run as password input]' \
  '--password-mnemonic[mnemonic password input]' \
  '--placeholder=[placeholder text]:text:' \
  '--theme=[theme name]:theme:' \
  '--style=[style sheet path]:file:_files' \
  '--config=[config file path]:file:_files' \
  '--label=[window label]:label:' \
  '--bench[benchmark mode]' \
  '(-d --dmenu)'{-d,--dmenu}'[dmenu mode]' \
  '--forceprint[force print to stdout]' \
  '--keepsort[keep input order]' && ret=0

return ret
