#compdef sanoid
# Documentation: https://github.com/jimsalterjrs/sanoid
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sanoid - ZFS snapshot management and replication

_arguments -s -S \
  '--configdir=[configuration directory]:directory:_directories' \
  '--cache-dir=[cache directory]:directory:_directories' \
  '--run-dir=[run directory]:directory:_directories' \
  '--take-snapshots[create new snapshots]' \
  '--prune-snapshots[prune expired snapshots]' \
  '--cron[create and prune snapshots (equivalent to --take-snapshots --prune-snapshots)]' \
  '--readonly[run in readonly mode, no changes made]' \
  '--quiet[suppress non-error output]' \
  '--verbose[verbose output]' \
  '--debug[debug output]' \
  '--force-update[update the cache file even if no snapshots were taken]' \
  '--monitor-health[monitor health of zpool]' \
  '--monitor-snapshots[monitor snapshot age and count]' \
  '--monitor-capacity[monitor zpool capacity]' \
  '--help[display help message]'
