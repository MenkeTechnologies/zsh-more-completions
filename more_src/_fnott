#compdef fnott

_arguments \
  '-c[path to configuration file]:file:_files' \
  '-s[path to socket]:file:_files' \
  '-S[path to notification sound file]:file:_files' \
  '-v[print version and exit]' \
  '-h[print help and exit]' \
  '-l[set log level]:level:(info warning error none)' \
  '--log-colorize[colorize log output]:bool:(yes no auto)' \
  '--log-no-syslog[disable syslog logging]'
