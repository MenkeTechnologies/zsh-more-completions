#compdef samplot
# Documentation: https://github.com/ryanlayer/samplot
# samplot - plot structural variants from BAM/CRAM alignments

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((plot\:"plot a structural variant region" vcf\:"generate samplot images for a VCF"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      plot)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-n --titles)'{-n,--titles}'[space-delimited list of plot titles]:titles' \
          '(-r --reference)'{-r,--reference}'[reference file for CRAM]:fasta:_files' \
          {-z,--z}'[number of stdevs from the mean for outliers]:z' \
          '(-b --bams)'{-b,--bams}'[space-delimited list of bam/cram files]:bams:_files' \
          '(-o --output_file)'{-o,--output_file}'[output file name]:file:_files' \
          '--output_dir[output directory]:dir:_files -/' \
          '(-s --start)'{-s,--start}'[start position of region/variant]:start' \
          '(-e --end)'{-e,--end}'[end position of region/variant]:end' \
          '(-c --chrom)'{-c,--chrom}'[chromosome]:chrom' \
          '(-w --window)'{-w,--window}'[window size in bp on either side]:window' \
          '(-d --max_depth)'{-d,--max_depth}'[max number of normal pairs to plot]:depth' \
          '(-t --sv_type)'{-t,--sv_type}'[SV type]:type:(DEL DUP INV BND INS TRA)' \
          '(-T --transcript_file)'{-T,--transcript_file}'[GFF3 of transcripts]:gff:_files' \
          '--max_coverage_points[max points to plot for coverage]:n' \
          '(-A --annotation_files)'{-A,--annotation_files}'[space-delimited list of bed.gz annotations]:beds:_files' \
          '--coverage_tracktype[coverage track type]:type:(stack superimpose)' \
          '(-a --print_args)'{-a,--print_args}'[print commandline arguments]' \
          '(-H --plot_height)'{-H,--plot_height}'[plot height]:height' \
          '(-W --plot_width)'{-W,--plot_width}'[plot width]:width' \
          '(-q --include_mqual)'{-q,--include_mqual}'[min mapping quality to include]:mqual' \
          '--separate_mqual[plot low-quality reads separately]:mqual' \
          '(-j --json_only)'{-j,--json_only}'[output JSON only, no plot]' \
          '--start_ci[confidence interval file for start]:file:_files' \
          '--end_ci[confidence interval file for end]:file:_files' \
          '--long_read[min long-read length]:len' \
          '--ignore_hp[ignore HP tags]' \
          '--min_event_size[min event size for long reads]:size' \
          '--xaxis_label_fontsize[x-axis label font size]:size' \
          '--yaxis_label_fontsize[y-axis label font size]:size' \
          '--legend_fontsize[legend font size]:size' \
          '--annotation_fontsize[annotation font size]:size' \
          '--hide_annotation_labels[hide annotation labels]' \
          '--coverage_only[plot coverage only]' \
          '--max_coverage[max coverage to plot]:n' \
          '--same_yaxis_scales[use same y-axis scale for all plots]' \
          '--marker_size[marker size]:size' \
          '--jitter[jitter point locations]' \
          '--dpi[output dpi]:dpi' \
          '--annotation_scalar[scale annotation track height]:scalar' \
          '--zoom[zoom in to region of given size]:bp' \
          '--debug[print debug info]' && ret=0
        ;;
      vcf)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-v --vcf)'{-v,--vcf}'[VCF file with SVs]:vcf:_files' \
          '(-d --out-dir)'{-d,--out-dir}'[output directory]:dir:_files -/' \
          '--ped[PED file]:ped:_files' \
          '--dn_only[plot only de novo variants]' \
          '--min_call_rate[min variant call rate]:rate' \
          '--filter[filter on info field]:filter' \
          '(-O --output_type)'{-O,--output_type}'[output image type]:type:(png pdf jpg)' \
          '--max_hets[max number of heterozygotes]:n' \
          '--min_entries[min number of variants]:n' \
          '--max_entries[max number of variants]:n' \
          '--max_mb[max size in Mb to plot]:mb' \
          '--min_bp[min size in bp to plot]:bp' \
          '--important_regions[bed of important regions]:bed:_files' \
          '(-b --bams)'{-b,--bams}'[space-delimited list of bam/cram files]:bams:_files' \
          '--sample_ids[sample IDs to plot]:ids' \
          '--command_file[write commands to file]:file:_files' \
          '--format[output format]:format' \
          '--gff3[GFF3 of transcripts]:gff:_files' \
          '--downsample[downsample normal reads]:n' \
          '--manual_run[do not run, only print commands]' \
          '--plot_all[plot all variants]' \
          '(-t --threads)'{-t,--threads}'[number of threads]:n' \
          '--debug[print debug info]' && ret=0
        ;;
    esac
    ;;
esac

return ret
