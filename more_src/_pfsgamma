#compdef pfsgamma
# Documentation: http://pfstools.sourceforge.net/man1/pfsgamma.1.html
# pfstools: apply gamma correction to a pfs stream

local ret=1

_arguments -s -S \
  '(-g --gamma)'{-g,--gamma}'=[gamma correction input^(1/gamma) (default 1.0)]:gamma' \
  '(-i --inverse-gamma)'{-i,--inverse-gamma}'=[inverse gamma correction input^(gamma)]:inv-gamma' \
  '(-m --mul)'{-m,--mul}'=[multiply data by this value before gamma correction]:mul' \
  '--help[print list of command line options]' && ret=0

return ret
