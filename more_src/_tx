#compdef tx
# Documentation: https://github.com/transifex/cli
# Reference accessed: 2026-05-21
# Verified: upstream transifex/cli README.

# Transifex CLI (https://github.com/transifex/cli — brew transifex-cli)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create an empty .tx/config file'
  'add:add resources to local configuration'
  'push:upload language files to Transifex'
  'pull:download language files from Transifex'
  'status:display the existing configuration'
  'delete:remove resources from Transifex'
  'merge:merge branch resources with base resources'
  'migrate:migrate from older client versions'
  'update:self-update the application'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::arg:_default' && ret=0

case $state in
  (command)
    _describe -t commands 'tx command' commands && ret=0
    ;;
esac

return ret
