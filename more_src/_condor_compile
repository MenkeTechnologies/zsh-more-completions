#compdef condor_compile
# Documentation: https://man.archlinux.org/search?q=condor_compile
# Reference accessed: 2026-05-16

# condor_compile: link a program with the Condor standard universe libs
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '*:cmd:_command_names' && ret=0
return ret
