#compdef condor_compile
# Documentation: https://htcondor.readthedocs.io/en/v8_8/man-pages/condor_compile.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_compile: relink a program with the HTCondor standard-universe libraries.
# Note: standard universe was removed in HTCondor 8.9+; man page lives in the 8.8 archive.
# Usage: condor_compile cc|gcc|f77|g++|ld|make|...   (no flags of its own)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '*:cmd:_command_names' && ret=0
return ret
