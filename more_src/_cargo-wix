#compdef cargo-wix
# Documentation: https://github.com/volks73/cargo-wix
# Source: volks73/cargo-wix src/main.rs — cargo subcommand to build Windows installers via WiX Toolset.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _cw_cmds
_cw_cmds=(
    'clean:delete the target/wix folder'
    'init:generate files from a package manifest to create an installer'
    'print:print a template'
    'purge:delete target/wix and wix folders'
    'sign:sign an installer'
    'migrate:WiX project migration setup utilities'
)

_arguments -C \
    '(-b --bin-path)'{-b+,--bin-path=}'[path to the WiX Toolset bin folder]:dir:_files -/' \
    '(-c --culture)'{-c+,--culture=}'[culture code for localization]:culture:_default' \
    '(-C --compiler-arg)*'{-C+,--compiler-arg=}'[pass an argument to the WiX compiler]:arg:_default' \
    '(-t --target)'{-t+,--target=}'[cargo target to build the WiX installer for]:target:_default' \
    '(-d --dbg-build)'{-d,--dbg-build}'[build the package using the Debug profile]' \
    '(-D --dbg-name)'{-D,--dbg-name}'[append -debug to the installer file stem]' \
    '--profile=[build with the given profile]:profile:_default' \
    '(-I --include)*'{-I+,--include=}'[include an additional WiX source file]:file:_files -g "*.wxs"' \
    '(-p --package)'{-p+,--package=}'[name of the workspace package]:package:_default' \
    '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'cargo-wix command' _cw_cmds && ret=0
        ;;
esac

return ret
