#compdef cordova2
# _cordova2 — Apache Cordova cordova2 CLI command-line frontend wrapping the Apache Cordova originally PhoneGap Adobe Systems mobile development framework that allows software programmers to build applications for mobile devices using CSS3 HTML5 and JavaScript open-source written in JavaScript Node create help info platform plugin prepare compile build clean run emulate serve telemetry requirements platforms-android-ios-browser-electron-osx-windows plugin-add plugin-remove plugin-list config save-config (Apache Cordova team, JavaScript); commander
# upstream: https://cordova.apache.org/

_cordova2() {
    local -a sub=(
        'build:build app'
        'clean:clean platform'
        'compile:compile app'
        'config:configure CLI'
        'create:create a new app'
        'emulate:run on emulator'
        'help:show help'
        'info:show env info'
        'platform:platform operations'
        'plugin:plugin operations'
        'plugins:plugin operations (alias)'
        'prepare:prepare platforms'
        'requirements:check requirements'
        'restore:restore plugins/platforms'
        'run:run app on device'
        'save:save config'
        'serve:serve www directory'
        'telemetry:telemetry config'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--no-update-notifier[no update notifier]' \
        '--no-telemetry[no telemetry]' \
        '--nohooks=+[regex]:str:' \
        '--no-hooks[no hooks]' \
        '--release[release build]' \
        '--debug[debug build]' \
        '--device[run on device]' \
        '--emulator[emulator]' \
        '--target=+[name]:str:' \
        '-t+[target]:str:' \
        '--list[list]' \
        '--buildConfig=+[file]:file:_files -g "build.json *.json"' \
        '--keystore=+[file]:_files' \
        '--storePassword=+[password]:str:' \
        '--alias=+[name]:str:' \
        '--password=+[password]:str:' \
        '--keystoreType=+[t]:t:(pkcs12 jks)' \
        '--packageType=+[t]:t:(apk bundle)' \
        '--save[save]' \
        '--noprompt[no prompt]' \
        '--searchpath=+[paths]:str:' \
        '--variable=+[k=v]:str:' \
        '*--variable=+[k=v]:str:' \
        '--browserify[browserify]' \
        '--link[link]' \
        '--fetch[use fetch]' \
        '--ssl[use SSL]' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--copy-from=+[dir]:dir:_files -/' \
        '--link-to=+[dir]:dir:_files -/' \
        '--template=+[name]:str:' \
        '--archs=+[archs]:str:' \
        '--id=+[id]:str:' \
        '--name=+[name]:str:' \
        '--allarchs[all archs]' \
        '--noconfig[no config]' \
        '--gradleArg=+[arg]:str:' \
        '*--gradleArg=+[arg]:str:' \
        '--developmentTeam=+[id]:str:' \
        '--packageType=+[t]:t:(app-store enterprise ad-hoc development)' \
        '--codeSignIdentity=+[id]:str:' \
        '--provisioningProfile=+[id]:str:' \
        '--automaticProvisioning[automatic provisioning]' \
        '--list-targets[list targets]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cordova subcommand' sub ;;
        args)
            case $words[1] in
                platform|platforms) _arguments '1:op:(add remove list save update check)' '*:name:(android ios browser electron osx windows)' ;;
                plugin|plugins) _arguments '1:op:(add remove list save search)' '*:name:' ;;
                create) _arguments '1:path:_files -/' '2:id:' '3:name:' ;;
                build|run|emulate|prepare|compile|clean) _arguments '*:platform:(android ios browser electron osx windows)' ;;
                requirements) _arguments '*:platform:(android ios browser electron osx windows)' ;;
            esac
            ;;
    esac
}

_cordova2 "$@"
