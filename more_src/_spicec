#compdef spicec

_arguments -s \
  '(-h --host)'{-h,--host}'=[host]:host:_hosts' \
  '(-p --port)'{-p,--port}'=[port]:port:' \
  '(-s --secure-port)'{-s,--secure-port}'=[secure port]:port:' \
  '--secure-channels=[channels]:channels:(main display inputs cursor playback record all)' \
  '--unsecure-channels=[channels]:channels:(main display inputs cursor playback record all)' \
  '(-w --password)'{-w,--password}'=[password]:pw:' \
  '(-f --full-screen)'{-f,--full-screen}'=[full screen]:mode:(auto-conf)' \
  '--canvas-type=[canvas]:type:(cairo gdi)' \
  '--enable-channels=[channels]:channels:(main display inputs cursor playback record all)' \
  '--disable-channels=[channels]:channels:(main display inputs cursor playback record all)' \
  '--help[show help]'
