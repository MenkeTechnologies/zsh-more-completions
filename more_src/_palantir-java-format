#compdef palantir-java-format

# Zsh completion for palantir-java-format - Palantir's Java source code formatter

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[show version]'
  '(-i --replace)'{-i,--replace}'[modify files in place]'
  '(-n --dry-run)'{-n,--dry-run}'[check if files would be formatted]'
  '--set-exit-if-changed[exit 1 if any changes would be made]'
  '--palantir[use Palantir style (default)]'
  '--google[use Google style]'
  '--aosp[use AOSP style]'
  '--skip-sorting-imports[do not fix import order]'
  '--skip-removing-unused-imports[do not remove unused imports]'
  '--skip-reflowing-long-strings[do not reflow long strings]'
  '--skip-javadoc-formatting[do not format javadoc comments]'
  '--assume-filename[assume file name when reading from stdin]:filename:'
  '--lines[line range to format]:range:'
  '--offset[character offset to format]:offset:'
  '--length[character length to format]:length:'
  '*:java file:_files -g "*.java"'
)

_arguments -s $arguments
