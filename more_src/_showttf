#compdef showttf
# Documentation: https://manpages.debian.org/testing/fontforge-extras/showttf.1.en.html
# Decompose a TrueType/OpenType font file into its tables and display them

local ret=1

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[print additional information]' \
  '(-h --headers)'{-h,--headers}'[print headers only]' \
  '(-c --checkhead)'{-c,--checkhead}'[check head]' \
  '*:font file:_files' && ret=0

return ret
