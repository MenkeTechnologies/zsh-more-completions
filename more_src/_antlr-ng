#compdef antlr-ng
# _antlr-ng — next-generation ANTLR parser generator (antlr-ng/antlr-ng)
# upstream: https://github.com/antlr-ng/antlr-ng
# Flags from src/tool-parameters.ts (commander).

_antlr-ng() {
    local -a args
    args=(
        '(-o --output-directory)'{-o+,--output-directory=}'[output directory for generated code]:dir:_files -/'
        '--lib=[location of imported grammars / token files]:dir:_files -/'
        '--atn=[generate rule ATN diagrams]:bool:(true false)'
        '(-e --encoding)'{-e+,--encoding=}'[grammar file encoding (default utf-8)]:enc:(utf-8 utf-16le ucs-2 ascii latin1 hex base64)'
        '--message-format=[format for diagnostic messages]:format:(antlr gnu vs2005)'
        '--long-messages=[print long-form diagnostics]:bool:(true false)'
        '(-l --generate-listener)'{-l+,--generate-listener=}'[generate parse-tree listener (default true)]:bool:(true false)'
        '(-v --generate-visitor)'{-v+,--generate-visitor=}'[generate parse-tree visitor]:bool:(true false)'
        '(-p --package)'{-p+,--package=}'[target package / namespace for the generated code]:name:'
        '(-d --generate-dependencies)'{-d+,--generate-dependencies=}'[emit dependency-file output]:bool:(true false)'
        '*'{-D+,--define=}'[set / override a grammar-level option (key=value)]:key=value:'
        '(-w --warnings-are-errors)'{-w+,--warnings-are-errors=}'[treat warnings as errors]:bool:(true false)'
        '(-f --force-atn)'{-f+,--force-atn=}'[use the ATN simulator for all predictions]:bool:(true false)'
        '--log=[dump logging info to antlrng-timestamp.log]:bool:(true false)'
        '--exact-output-dir=[place all output in --output-directory regardless of paths]:bool:(true false)'
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '*:ANTLR grammar file:_files -g "*.g4"'
    )
    _arguments -s -S $args
}

_antlr-ng "$@"
