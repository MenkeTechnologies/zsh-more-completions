#compdef litex_cli
# Documentation: https://github.com/enjoy-digital/litex/blob/master/litex/tools/litex_client.py
# LiteX remote bus client (read/write SoC registers and memory via litex_server)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--csr-csv=[CSR configuration file]:file:_files' \
  '--host=[host ip address]:host:' \
  '--port=[host bind port]:port:' \
  '--binary[use binary format for displayed values]' \
  '--file=[file to read from or write to in binary mode]:file:_files' \
  '--endianness=[endianness for memory accesses]:endianness:(little big)' \
  '--timeout=[socket timeout]:seconds:' \
  '--strict-timeout[raise on remote read timeout]' \
  '--ident[dump SoC identifier]' \
  '--regs[dump SoC registers]' \
  '--filter=[registers filter (with --regs)]:filter:' \
  '--read=[MMAP read to SoC bus (addr/reg)]:addr:' \
  '--write=[MMAP write to SoC bus (addr/reg [data])]:addr:' \
  '--length=[MMAP access length]:length:' \
  '--gui[run GUI]' && ret=0

return ret
