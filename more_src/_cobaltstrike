#compdef cobaltstrike teamserver
# _cobaltstrike — Fortra HelpSystems cobaltstrike CLI launcher for the Cobalt Strike adversary simulation post-exploitation Threat Emulation framework starting the team server agent connecting to a teamserver with profile-driven malleable C2 configuration for authorized red-team engagements (Fortra team, Java); custom argparse
# upstream: https://www.cobaltstrike.com/

_cobaltstrike() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-X+[JVM args]:str:' \
        '--XX:+[JVM opts]:str:' \
        '-Xmx+[max heap]:str:' \
        '-Xms+[min heap]:str:' \
        '-Dlanguage=+[lang]:l:(en de fr ja zh ru ko es it pt)' \
        '-Dcobaltstrike.server_port=+[port]:n:' \
        '-Dcobaltstrike.server_bindto=+[host]:_hosts' \
        '-Dfile.encoding=+[encoding]:str:' \
        '-Djava.awt.headless=+[bool]:s:(true false)' \
        '-Dcobaltstrike.update_check=+[bool]:s:(true false)' \
        '*:profile or address:_files'
}

_cobaltstrike "$@"
