#compdef git-credential-store
# Documentation: man git-credential-store(1)
# Source: git/git Documentation/git-credential-store.adoc (master) — plaintext credential helper (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--file=[credentials file]:file:_files' \
    '1::action:(get store erase)' \
    && ret=0

return ret
