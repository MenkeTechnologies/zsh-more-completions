#compdef copa
# Documentation: https://man.archlinux.org/search?q=copa
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[print version]' \
  '--image=[container image reference]:image:' \
  '--patch[apply patches to image]' \
  '--output=[output image]:image:' \
  '--buildkit-addr=[buildkit address]:addr:' \
  '--timeout=[operation timeout]:duration:' \
  '*:pos: _default'
