#compdef bash
# Documentation: man 1 bash (Ubuntu jammy manpage)
# Reference accessed: 2026-05-29
# GNU Bourne Again SHell.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show usage information]' \
  '(- *)--version[show version details]' \
  '-c[read commands from first non-option argument]:command:' \
  '-i[start an interactive shell]' \
  '-l[activate login shell behavior]' \
  '--login[equivalent to -l]' \
  '-r[restricted shell mode]' \
  '-s[read commands from standard input]' \
  '-v[print shell input lines as read (verbose)]' \
  '-x[print commands and arguments as executed (xtrace)]' \
  '-D[output double-quoted strings preceded by $ for translation]' \
  '--debugger[activate extended debugging before startup]' \
  '--init-file=[load commands from file]:file:_files' \
  '--rcfile=[load commands from file (alias for --init-file)]:file:_files' \
  '--noediting[disable GNU readline for interactive use]' \
  '--noprofile[skip system and personal startup files]' \
  '--norc[avoid reading initialization files]' \
  '--posix[enable POSIX mode compliance]' \
  '--restricted[restricted shell mode]' \
  '--verbose[same as -v]' \
  '*:script or args:_files' && ret=0

return ret
