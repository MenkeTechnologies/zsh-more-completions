#compdef presto-server launcher

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run in foreground (no daemonize)'
  'start:start as daemon'
  'stop:stop the daemon'
  'restart:restart the daemon'
  'status:show daemon status'
  'kill:kill the daemon process'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--etc-dir=[etc directory]:dir:_files -/' \
  '--launcher-config=[launcher config file]:file:_files' \
  '--node-config=[node config file]:file:_files' \
  '--jvm-config=[JVM config file]:file:_files' \
  '--config=[config properties file]:file:_files' \
  '--secrets-config=[secrets config file]:file:_files' \
  '--log-levels-file=[log levels file]:file:_files' \
  '--jvm-dir=[JVM installation dir]:dir:_files -/' \
  '--data-dir=[data directory]:dir:_files -/' \
  '--pid-file=[PID file]:file:_files' \
  '--launcher-log-file=[launcher log file]:file:_files' \
  '--server-log-file=[server log file]:file:_files' \
  '*-J+[pass JVM option]:option:' \
  '*-D-[set Java system property key=value]:property:' \
  '1: :->subcommand' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'presto-server subcommand' subcommands && ret=0
    ;;
esac

return ret
