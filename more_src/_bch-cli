#compdef bch-cli bitcoin-cash-cli bitcoincash-cli
# _bch-cli — Bitcoin Cash bch-cli JSON-RPC client CLI for the Bitcoin Cash Node BCHN Knuth or BCH Unlimited full-node daemon issuing wallet getbalance sendtoaddress listunspent CashAddr sendmany generate getblockchaininfo getmempoolinfo (bitcoin-cash-node team, C++); custom argparse
# upstream: https://gitlab.com/bitcoin-cash-node/bitcoin-cash-node

_bch-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf bitcoin.conf bch.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-testnet[use testnet]' \
        '-testnet4[use testnet4]' \
        '-chipnet[use chipnet]' \
        '-regtest[use regtest]' \
        '-named[use named JSON-RPC]' \
        '-rpcconnect=+[host]:h:_hosts' \
        '-rpcport=+[port]:n:' \
        '-rpcwait[wait for RPC server]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcclienttimeout=+[seconds]:n:' \
        '-rpccookiefile=+[file]:file:_files' \
        '-stdin[read input from stdin]' \
        '-stdinrpcpass[read RPC password from stdin]' \
        '-getinfo[print info]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getnetworkinfo getmempoolinfo getmininginfo getbalance listunspent listtransactions sendtoaddress sendmany getnewaddress decodecashaddress validateaddress dumpprivkey importprivkey importwallet dumpwallet generate generatetoaddress getrawtransaction createrawtransaction signrawtransactionwithwallet sendrawtransaction addnode getpeerinfo getnettotals setban listbanned)'
}

_bch-cli "$@"
