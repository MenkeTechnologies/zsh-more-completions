#compdef auracle

# Zsh completion for auracle (AUR helper CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--color=[colorize output]:when:(auto never always)' \
  '--connect-timeout=[connection timeout in seconds]:seconds' \
  '--max-connections=[max simultaneous connections]:count' \
  '--quiet[output less]' \
  '--recurse[recurse through dependencies]' \
  '--literal[disable regex in search]' \
  '--searchby=[field to search by]:field:(name name-desc maintainer depends makedepends optdepends checkdepends)' \
  '--rsort=[reverse sort results by field]:field:(name version votes popularity firstsubmitted lastmodified)' \
  '--sort=[sort results by field]:field:(name version votes popularity firstsubmitted lastmodified)' \
  '-C+[change directory]:directory:_directories' \
  '--chdir=[change directory]:directory:_directories' \
  '-r[recurse through dependencies]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'buildorder:show build order for packages'
      'clone:clone package repositories'
      'info:show detailed package information'
      'outdated:list outdated installed AUR packages'
      'rawinfo:show raw JSON package info'
      'rawsearch:search AUR and show raw JSON'
      'search:search AUR for packages'
      'show:show package information'
      'sync:check for outdated packages'
      'update:update cloned package repos'
    )
    _describe -t commands 'auracle command' commands && ret=0
    ;;
  args)
    _arguments '*:package' && ret=0
    ;;
esac

return ret
