#compdef opencode

# Zsh completion for opencode - AI coding agent built for the terminal

local curcontext="$curcontext" state line ret=1

_opencode_commands() {
  local -a commands=(
    'run:run opencode with a message'
    'auth:manage credentials'
    'upgrade:upgrade opencode to the latest version'
    'serve:start opencode server'
    'models:list available models'
    'help:show help'
  )
  _describe -t commands 'opencode command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --cwd)'{-c,--cwd}'[working directory]:dir:_directories' \
  '--print-logs[print logs to stderr]' \
  '1: :_opencode_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments \
          '(-c --continue)'{-c,--continue}'[continue last session]' \
          '(-s --session)'{-s,--session}'[session ID]:session id' \
          '(-m --model)'{-m,--model}'[model to use (provider/model)]:model' \
          '--agent[agent to run]:agent' \
          '*:message' && ret=0
        ;;
      auth)
        _arguments \
          '1:subcommand:(list login logout)' \
          '*:provider' && ret=0
        ;;
      serve)
        _arguments \
          '(-p --port)'{-p,--port}'[port to listen on]:port' \
          '(-H --hostname)'{-H,--hostname}'[hostname to bind]:hostname' && ret=0
        ;;
    esac
    ;;
esac

return ret
