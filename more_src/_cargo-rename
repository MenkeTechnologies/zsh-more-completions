#compdef cargo-rename
# Documentation: https://crates.io/crates/cargo-rename
# atomically rename a Cargo package and update all references

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--color[control color output]:when:(auto always never)' \
  '(-q --quiet)'{-q,--quiet}'[decrease logging verbosity]' \
  '(-v --verbose)'{-v,--verbose}'[increase logging verbosity]' \
  '--move=-[move the package to a new directory]::dir:_files -/' \
  '--manifest-path[path to workspace Cargo.toml]:file:_files -g "*.toml"' \
  '(-n --dry-run)'{-n,--dry-run}'[preview changes without applying them]' \
  '(-y --yes)'{-y,--yes}'[skip interactive confirmation]' \
  '--allow-dirty[allow operation with uncommitted git changes]' \
  '1:old name:' \
  '2:new name:' && ret=0

return ret
