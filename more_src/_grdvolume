#compdef grdvolume
# Documentation: https://docs.generic-mapping-tools.org/latest/grdvolume.html
# Source: GenericMappingTools/gmt classic-mode grdvolume — area / volume / mean height bounded by contours.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[contour value(s)]:value:_default' \
    '-D[area+volume per horizontal slice]' \
    '-L+[add volume from contour down to base]:base:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[distance unit]:unit:(e f k M n u)' \
    '-T+[contour maximizing avg height]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-Z+[scale/shift transform on grid]:opts:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-o+[output column selection]:cols:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
