#compdef ovs-tcpundump
# _ovs-tcpundump — Open vSwitch ovs-tcpundump convert tcpdump -xx output back into binary packet form (openvswitch team, Python); argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-tcpundump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '*:tcpdump file:_files -g "*.txt *.dump *.tcpdump"'
}

_ovs-tcpundump "$@"
