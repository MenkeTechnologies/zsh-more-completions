#compdef deno-cli
# _deno-cli — Deno secure JavaScript/TypeScript runtime CLI alias (Deno Land, Rust); clap-rs
# upstream: https://github.com/denoland/deno

_deno-cli() {
    local -a sub=(
        'add:add npm/jsr dep'
        'remove:remove npm/jsr dep'
        'bench:run benchmarks'
        'bundle:bundle a module'
        'cache:cache module dependencies'
        'check:type-check module'
        'compile:compile script to standalone executable'
        'completions:generate shell completions'
        'coverage:print coverage report'
        'doc:show module documentation'
        'eval:eval a script'
        'fmt:format source files'
        'help:show help'
        'info:show info about a module'
        'init:init new project'
        'install:install a script as an executable'
        'uninstall:uninstall an installed script'
        'jupyter:install/start jupyter kernel'
        'lint:lint source files'
        'lsp:start language server'
        'publish:publish a module to JSR'
        'repl:start REPL'
        'run:run a script'
        'serve:serve an HTTP server'
        'task:run a task from deno.json'
        'test:run tests'
        'types:show TypeScript types'
        'upgrade:upgrade Deno itself'
        'vendor:vendor dependencies into local dir'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--unstable[enable unstable APIs]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--log-level=+[log level]:level:(debug info)' \
        '-L+[log level]:level:(debug info)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'deno subcommand' sub ;;
        args)
            case $words[1] in
                run|test|bench|task|repl|serve|eval) _arguments \
                    '--allow-all[allow all permissions]' \
                    '-A[allow all permissions]' \
                    '--allow-read=+[allow read]:list:_files' \
                    '--allow-write=+[allow write]:list:_files' \
                    '--allow-net=+[allow net]:list:' \
                    '--allow-env=+[allow env]:list:' \
                    '--allow-run=+[allow run]:list:' \
                    '--allow-sys=+[allow sys]:list:' \
                    '--allow-ffi=+[allow ffi]:list:' \
                    '--allow-import=+[allow import]:list:' \
                    '--deny-read=+[deny read]:list:_files' \
                    '--deny-write=+[deny write]:list:_files' \
                    '--deny-net=+[deny net]:list:' \
                    '--deny-env=+[deny env]:list:' \
                    '--deny-run=+[deny run]:list:' \
                    '--deny-sys=+[deny sys]:list:' \
                    '--deny-ffi=+[deny ffi]:list:' \
                    '--watch[watch mode]' \
                    '--watch-hmr[watch hmr]' \
                    '--no-clear-screen[no clear screen]' \
                    '--inspect=+[inspect host:port]:str:' \
                    '--inspect-brk=+[inspect-brk host:port]:str:' \
                    '--inspect-wait=+[inspect-wait host:port]:str:' \
                    '--no-check[no type check]' \
                    '--check[type check]' \
                    '--reload=+[reload urls]:list:' \
                    '-r+[reload urls]:list:' \
                    '--no-config[no config]' \
                    '--config=+[config file]:file:_files -g "deno.json deno.jsonc"' \
                    '-c+[config file]:file:_files -g "deno.json deno.jsonc"' \
                    '--no-lock[no lock file]' \
                    '--lock=+[lock file]:file:_files' \
                    '--unstable-bare-node-builtins[unstable bare node builtins]' \
                    '--unstable-byonm[unstable BYONM]' \
                    '--unstable-sloppy-imports[unstable sloppy imports]' \
                    '--cached-only[cached only]' \
                    '--seed=+[random seed]:n:' \
                    '--v8-flags=+[V8 flags]:str:' \
                    '--node-modules-dir=+[node modules dir]:b:(true false)' \
                    '--cert=+[custom CA cert]:file:_files' \
                    '--frozen=+[frozen lockfile]:b:(true false)' \
                    '*:script:_files' ;;
                install) _arguments \
                    '--root=+[install root]:dir:_files -/' \
                    '--name=+[install name]:str:' \
                    '-n+[install name]:str:' \
                    '--force[force install]' \
                    '-f[force install]' \
                    '--global[global install]' \
                    '-g[global install]' \
                    '*:script-or-package:_files' ;;
                compile) _arguments \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--target=+[target triple]:t:(x86_64-unknown-linux-gnu x86_64-pc-windows-msvc x86_64-apple-darwin aarch64-apple-darwin aarch64-unknown-linux-gnu)' \
                    '--include=+[include path]:list:_files' \
                    '--no-terminal[no terminal]' \
                    '*:script:_files' ;;
                add|remove) _arguments '*:package:' ;;
                completions) _arguments '1:shell:(bash zsh fish powershell)' ;;
                upgrade) _arguments \
                    '--version=+[version]:str:' \
                    '--canary[canary]' \
                    '--dry-run[dry run]' \
                    '--force[force upgrade]' \
                    '-f[force upgrade]' \
                    '--output=+[output path]:file:_files' ;;
            esac
            ;;
    esac
}

_deno-cli "$@"
