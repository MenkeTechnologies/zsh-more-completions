#compdef avidemux_cli
# Documentation: https://manpages.debian.org/testing/avidemux-cli/avidemux3_cli.1.en.html
# Avidemux command-line video editor/transcoder

local ret=1

_arguments -s \
  '--help[print help]' \
  '--load[load video file]:file:_files' \
  '--save[save output file]:file:_files' \
  '--video-codec[set video codec (copy, x264, xvid, ...)]:codec:' \
  '--audio-codec[set audio codec (copy, aac, mp3, ...)]:codec:' \
  '--output-format[set container format (MKV, MP4, AVI, TS, PS, OGM)]:format:' \
  '--begin[set start marker to a frame number for cutting]:frame:' \
  '--end[set end marker to a frame number for cutting]:frame:' \
  '--run[load and run an Avidemux project or Python script]:script:_files' \
  '--rebuild-index[rebuild the index with correct frame types]' \
  '--autoindex[generate required index files as necessary]' \
  '--quit[quit after operations complete]' \
  '*:file:_files' && ret=0

return ret
