#compdef tortoise_tts
# _tortoise-tts — TorToiSe text-to-speech (neonbjb/tortoise-tts)
# upstream: https://github.com/neonbjb/tortoise-tts

_tortoise-tts() {
    _arguments -s -S \
        '--text=[text to speak]:text:' \
        '--voice=[voice to use]:voice:' \
        '--preset=[quality preset]:preset:(ultra_fast fast standard high_quality)' \
        '--output-path=[output directory]:dir:_directories' \
        '--model-dir=[model directory]:dir:_directories' \
        '--candidates=[number of candidates]:n:' \
        '--seed=[random seed]:seed:' \
        '--produce-debug-state[save debug state]' \
        '--cvvp-amount=[CVVP weighting amount]:amount:' \
        '--top-p=[top-p sampling]:p:' \
        '--temperature=[sampling temperature]:temp:' \
        '--length-penalty=[length penalty]:penalty:' \
        '--repetition-penalty=[repetition penalty]:penalty:' \
        '--cond-free-k=[conditioning-free guidance scale]:k:' \
        '--diffusion-iterations=[diffusion iterations]:n:' \
        '--half[use half precision]' \
        '--help[show help]'
}

_tortoise-tts "$@"
