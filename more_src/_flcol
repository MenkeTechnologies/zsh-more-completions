#compdef flcol
# List FITS table column information

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "nlist=[number of columns to list]:" \
  "outfile=[output report file]:file:_files" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
