#compdef plumed-pesmd
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/pesmd.html
# PLUMED pesmd: biased Langevin dynamics on a PLUMED-defined energy surface

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--plumed=[input file with potential definition]:file:_files' \
  '--nstep=[number of steps of dynamics to run]:nstep' \
  '--tstep=[integration timestep in LJ units]:tstep' \
  '--temperature=[temperature in LJ units]:temperature' \
  '--friction=[friction for the Langevin thermostat]:friction' \
  '--dimension=[dimensionality of the energy landscape]:dimension' \
  '--ipos=[initial position of the system]:ipos' \
  '--idum=[random number seed]:seed' \
  '--periodic=[whether the input coordinates are periodic]:periodic' \
  '--min=[minimum value of a periodic domain]:min' \
  '--max=[maximum value of a periodic domain]:max' && ret=0

return ret
