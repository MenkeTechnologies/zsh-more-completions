#compdef deadfinder
# Documentation: https://github.com/hahwul/deadfinder
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments \
  '(-r --include30x)'{-r,--include30x}'[include 30x redirections as dead links]' \
  '(-c --concurrency)'{-c,--concurrency}'=[number of concurrent workers]:number' \
  '(-t --timeout)'{-t,--timeout}'=[timeout in seconds]:number' \
  '(-o --output)'{-o,--output}'=[file to write results]:file:_files' \
  '(-f --output_format)'{-f,--output_format}'=[output format]:format:(json yaml toml csv sarif)' \
  '(-H --headers)'{-H,--headers}'=[custom HTTP headers]:header' \
  '--worker_headers=[custom HTTP headers for workers]:header' \
  '--user_agent=[User-Agent string]:string' \
  '(-p --proxy)'{-p,--proxy}'=[proxy server]:url' \
  '--proxy_auth=[proxy authentication user:pass]:auth' \
  '(-m --match)'{-m,--match}'=[match URL regex]:pattern' \
  '(-i --ignore)'{-i,--ignore}'=[ignore URL regex]:pattern' \
  '(-s --silent)'{-s,--silent}'[silent mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '--debug[debug mode]' \
  '--limit=[limit number of URLs to scan]:number' \
  '--coverage[enable coverage tracking]' \
  '--visualize=[generate visualization PNG]:file:_files' \
  '1:command:(pipe file url sitemap completion version)' \
  '*::arg:_default'
