#compdef gdalmdimtranslate
# Documentation: https://gdal.org/en/stable/programs/gdalmdimtranslate.html
# Convert multidimensional data between different formats and perform subsetting

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '--help-general[show generic GDAL options]' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
  '*-if[input format/driver]:format' \
  '-of[output format]:format' \
  '*-co[creation option]:name=value' \
  '*-array[select array with optional operations]:array_spec' \
  '*-arrayoption[filter arrays via format-specific options]:name=value' \
  '*-group[select group with optional operations]:group_spec' \
  '*-subset[subset dimension using OGC WCS 2.0 syntax]:subset_spec' \
  '-scaleaxes[apply integral scaling to dimensions]:scaleaxes_spec' \
  '-strict[fail on translation errors]' \
  '*-oo[source dataset open option]:name=value' \
  '*:file:_files' && ret=0

return ret
