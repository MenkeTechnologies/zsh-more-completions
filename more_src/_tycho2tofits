#compdef tycho2tofits
# Documentation: http://astrometry.net/doc/build-index.html
# convert the Tycho-2 catalog to FITS binary tables

local ret=1

_arguments -s \
  '-h[show help]' \
  '-o+[output filename (or template, eg tycho2_hp%02i.fits)]:output:_files' \
  '-H[do healpixification]' \
  '-N+[healpix nside]:nside:' \
  '*:input file:_files' && ret=0

return ret
