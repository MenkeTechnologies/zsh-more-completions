#compdef kbatch
# Documentation: upstream cli.py at github.com/kbatch-dev/kbatch
# Reference accessed: 2026-05-30
# kbatch R61 — batch jobs on Kubernetes via JupyterHub-style API.
# Python Click CLI. Five top-level commands with three multi-action
# state machines (cronjob/job/pod).

local curcontext="$curcontext" state line ret=1

local -a _subcmds _cronjob_subs _job_subs _pod_subs _output_modes
_subcmds=(
  'configure:write a configuration file for future kbatch actions'
  'profiles:show the profiles used by the server'
  'cronjob:manage kbatch cronjobs'
  'job:manage kbatch jobs'
  'pod:manage job pods'
  'help:show help'
)

_cronjob_subs=(
  'show:display cronjob details'
  'delete:remove a cronjob and cancel running jobs'
  'list:display all cronjobs'
  'submit:create and submit a new cronjob to Kubernetes'
)

_job_subs=(
  'show:display job details'
  'delete:remove a job and cancel running pods'
  'list:display all jobs'
  'submit:create and submit a new job to Kubernetes'
  'logs:retrieve logs for a job'
)

_pod_subs=(
  'list:display all pods'
  'logs:retrieve logs for a pod'
)

_output_modes=( 'json:JSON output' 'name:name only (default)' )

# Shared flags for job/cronjob submit
local -a _submit_flags
_submit_flags=(
  '(-n --name)'{-n,--name}'=[name]:name:'
  '--image=[container image to use to execute job]:image:'
  '--command=[command to execute]:command:'
  '--args=[arguments to pass to the command]:args:'
  '(-e --env)'{-e,--env}'=[JSON mapping of environment variables]:json:'
  '(-d --description)'{-d,--description}'=[description (optional)]:text:'
  '(-c --code)'{-c,--code}'=[local file or directory of source code]:path:_files'
  '(-p --profile)'{-p,--profile}'=[profile name (see kbatch profiles)]:profile:'
  '(-f --file)'{-f,--file}'=[configuration file]:file:_files'
  '--kbatch-url=[URL to the kbatch server]:url:'
  '--token=[JupyterHub API token]:token:'
  '(-o --output)'{-o,--output}'=[output format]:format:(json name)'
  '--help[show help]'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'kbatch subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      configure)
        _arguments \
          '--kbatch-url=[URL to the kbatch server]:url:' \
          '--token=[JupyterHub API token]:token:' \
          '--help[show help]' && ret=0
        ;;
      profiles)
        _arguments \
          '--kbatch-url=[URL to the kbatch server]:url:' \
          '--token=[JupyterHub API token]:token:' \
          '--help[show help]' && ret=0
        ;;
      cronjob)
        _arguments -C \
          '(-): :->cronjob_sub' \
          '(-)*:: :->cronjob_sub_args' && ret=0
        case $state in
          cronjob_sub)
            _describe -t commands 'kbatch cronjob subcommand' _cronjob_subs && ret=0
            ;;
          cronjob_sub_args)
            case $words[1] in
              submit)
                _arguments \
                  $_submit_flags \
                  '--schedule=[cron schedule expression]:schedule:' && ret=0
                ;;
              show|delete|logs)
                _arguments \
                  '1:cronjob name:' \
                  '--kbatch-url=[URL to the kbatch server]:url:' \
                  '--token=[JupyterHub API token]:token:' \
                  '--help[show help]' && ret=0
                ;;
              list)
                _arguments \
                  '(-o --output)'{-o,--output}'=[output format]:format:(json name)' \
                  '--kbatch-url=[URL to the kbatch server]:url:' \
                  '--token=[JupyterHub API token]:token:' \
                  '--help[show help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      job)
        _arguments -C \
          '(-): :->job_sub' \
          '(-)*:: :->job_sub_args' && ret=0
        case $state in
          job_sub)
            _describe -t commands 'kbatch job subcommand' _job_subs && ret=0
            ;;
          job_sub_args)
            case $words[1] in
              submit)
                _arguments $_submit_flags && ret=0
                ;;
              show|delete|logs)
                _arguments \
                  '1:job name:' \
                  '--kbatch-url=[URL to the kbatch server]:url:' \
                  '--token=[JupyterHub API token]:token:' \
                  '--help[show help]' && ret=0
                ;;
              list)
                _arguments \
                  '(-o --output)'{-o,--output}'=[output format]:format:(json name)' \
                  '--kbatch-url=[URL to the kbatch server]:url:' \
                  '--token=[JupyterHub API token]:token:' \
                  '--help[show help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      pod)
        _arguments -C \
          '(-): :->pod_sub' \
          '(-)*:: :->pod_sub_args' && ret=0
        case $state in
          pod_sub)
            _describe -t commands 'kbatch pod subcommand' _pod_subs && ret=0
            ;;
          pod_sub_args)
            case $words[1] in
              logs)
                _arguments \
                  '1:pod name:' \
                  '--kbatch-url=[URL to the kbatch server]:url:' \
                  '--token=[JupyterHub API token]:token:' \
                  '--help[show help]' && ret=0
                ;;
              list)
                _arguments \
                  '(-o --output)'{-o,--output}'=[output format]:format:(json name)' \
                  '--kbatch-url=[URL to the kbatch server]:url:' \
                  '--token=[JupyterHub API token]:token:' \
                  '--help[show help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
