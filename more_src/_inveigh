#compdef inveigh
# Documentation: https://github.com/Kevin-Robertson/Inveigh
# cross-platform LLMNR/NBNS/mDNS/DNS spoofer and credential capture tool

local ret=1

_arguments -s \
  '-Inspect[traffic inspection only]:yn:(Y N)' \
  '-IPv4[enable IPv4 spoofing/capture]:yn:(Y N)' \
  '-IPv6[enable IPv6 spoofing/capture]:yn:(Y N)' \
  '-RunCount[exit after N credential captures]:n:' \
  '-RunTime[minutes before auto-exit]:minutes:' \
  '-Console[console verbosity level]:level:(0 1 2 3 4 5)' \
  '-ConsoleLimit[limit queued console entries]:n:' \
  '-ConsoleStatus[auto-display capture details interval]:minutes:' \
  '-ConsoleUnique[show only unique user/system combos]:yn:(Y N)' \
  '-FileDirectory[output directory path]:dir:_files -/' \
  '-FileOutput[enable real-time file output]:yn:(Y N)' \
  '-FilePrefix[prefix for output files]:prefix:' \
  '-FileUnique[output only unique hashes]:yn:(Y N)' \
  '-LogOutput[enable log entries]:yn:(Y N)' \
  '-DHCPv6[DHCPv6 spoofing]:yn:(Y N)' \
  '-DHCPv6TTL[DHCPv6 TTL]:ttl:' \
  '-DNS[DNS spoofing]:yn:(Y N)' \
  '-DNSHost[DNS host response]:host:_hosts' \
  '-DNSSRV[DNS SRV spoofing]:yn:(Y N)' \
  '-DNSSuffix[DNS suffix]:suffix:' \
  '-DNSTTL[DNS TTL]:ttl:' \
  '-DNSTYPES[DNS record types]:types:' \
  '-ICMPv6[ICMPv6 router advertisement]:yn:(Y N)' \
  '-ICMPv6Interval[ICMPv6 RA interval]:seconds:' \
  '-ICMPv6TTL[ICMPv6 TTL]:ttl:' \
  '-LLMNR[LLMNR spoofing]:yn:(Y N)' \
  '-LLMNRTTL[LLMNR TTL]:ttl:' \
  '-MDNS[mDNS spoofing]:yn:(Y N)' \
  '-MDNSQuestions[mDNS question types]:types:' \
  '-MDNSTTL[mDNS TTL]:ttl:' \
  '-MDNSTypes[mDNS record types]:types:' \
  '-MDNSUnicast[mDNS unicast response]:yn:(Y N)' \
  '-NBNS[NBNS spoofing]:yn:(Y N)' \
  '-NBNSTTL[NBNS TTL]:ttl:' \
  '-NBNSTypes[NBNS record types]:types:' \
  '-IgnoreDomains[domains to ignore]:domains:' \
  '-IgnoreIPs[IPs to ignore]:ips:' \
  '-IgnoreMACs[MACs to ignore]:macs:' \
  '-IgnoreQueries[queries to ignore]:queries:' \
  '-ReplyToDomains[only reply to domains]:domains:' \
  '-ReplyToIPs[only reply to IPs]:ips:' \
  '-ReplyToMACs[only reply to MACs]:macs:' \
  '-ReplyToQueries[only reply to queries]:queries:' \
  '-SpooferIP[response IPv4 address]:ip:' \
  '-SpooferIPv6[response IPv6 address]:ip:' \
  '-Repeat[continue attacks after capture]:yn:(Y N)' \
  '-Local[attack against host system]:yn:(Y N)' \
  '-Cert[TLS certificate]:cert:' \
  '-CertPassword[TLS certificate password]:password:' \
  '-Challenge[custom NetNTLM challenge]:hex:' \
  '-HTTP[HTTP listener]:yn:(Y N)' \
  '-HTTPAuth[HTTP auth type]:auth:(Anonymous Basic NTLM)' \
  '-HTTPPorts[HTTP listener ports]:ports:' \
  '-HTTPRealm[HTTP Basic realm]:realm:' \
  '-HTTPResponse[HTTP response content]:content:' \
  '-HTTPS[HTTPS listener]:yn:(Y N)' \
  '-HTTPSPorts[HTTPS listener ports]:ports:' \
  '-IgnoreAgents[HTTP user agents to ignore]:agents:' \
  '-LDAP[LDAP listener]:yn:(Y N)' \
  '-LDAPPorts[LDAP listener ports]:ports:' \
  '-ListenerIP[listener bind IPv4]:ip:' \
  '-ListenerIPv6[listener bind IPv6]:ip:' \
  '-MachineAccount[capture machine accounts]:yn:(Y N)' \
  '-Proxy[proxy auth capture]:yn:(Y N)' \
  '-ProxyAuth[proxy auth type]:auth:(Basic NTLM)' \
  '-ProxyPort[proxy listener port]:port:' \
  '-SMB[SMB sniffer/listener]:yn:(Y N)' \
  '-SMBPorts[SMB listener ports]:ports:' \
  '-WebDAV[WebDAV support]:yn:(Y N)' \
  '-WebDAVAuth[WebDAV auth type]:auth:(Anonymous Basic NTLM)' \
  '-WPADAuth[WPAD auth type]:auth:(Anonymous Basic NTLM)' \
  '-WPADResponse[WPAD response content]:content:' && ret=0

return ret
