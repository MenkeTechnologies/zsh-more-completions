#compdef bind_exporter
# _bind_exporter — Prometheus BIND DNS exporter (scrapes BIND's statistics-channel XML/JSON and exports DNS server metrics)
# upstream: https://github.com/prometheus-community/bind_exporter
# Flags from bind_exporter.go on tip + kingpinflag/web (--web.listen-address, --web.systemd-socket, --web.config.file) + promslog (--log.level, --log.format).

_bind_exporter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--bind.stats-url=[BIND statistics-channel URL]:url:_urls' \
        '--bind.timeout=[BIND scrape timeout]:dur:' \
        '--bind.pid-file=[path to BIND pid file (enables process metrics)]:file:_files' \
        '--bind.stats-version=[BIND statistics format]:fmt:(json xml xml.v3 auto)' \
        '--bind.stats-groups=[comma-separated statistics groups to collect]:list:' \
        '--web.telemetry-path=[path under which to expose metrics]:path:' \
        '*--web.listen-address=[listen address (repeatable for systemd socket activation)]:addr:' \
        '--web.systemd-socket[use systemd socket activation listener]' \
        '--web.config.file=[TLS/auth config file]:file:_files' \
        '--log.level=[log level]:level:(debug info warn error)' \
        '--log.format=[log format]:fmt:(logfmt json)'
}

_bind_exporter "$@"
