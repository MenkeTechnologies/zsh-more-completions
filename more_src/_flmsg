#compdef flmsg

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config-dir=+[config dir]:dir:_files -/' \
  '--server-port=+[server port]:port:' \
  '--server-address=+[server address]:addr:' \
  '--client-port=+[client port]:port:' \
  '--client-address=+[client address]:addr:' \
  '--auto-dir=+[autosend dir]:dir:_files -/' \
  '--flmsg-dir=+[flmsg dir]:dir:_files -/' \
  '--debug-level=+[debug level]:lvl:(0 1 2 3 4 5)' \
  '*:message file:_files' && ret=0

return ret
