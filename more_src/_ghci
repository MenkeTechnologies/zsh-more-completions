#compdef ghci
# _ghci — GHC interactive Haskell REPL CLI (GHC team / GHC HQ, Haskell); custom argparse
# upstream: https://github.com/ghc/ghc

_ghci() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--numeric-version[print numeric version]' \
        '--info[print system info]' \
        '--print-libdir[print lib dir]' \
        '--supported-extensions[print supported extensions]' \
        '--ignore-dot-ghci[do not read .ghci]' \
        '--read-dot-ghci[read .ghci]' \
        '--ghci-script=+[ghci script]:file:_files -g "*.ghci"' \
        '--interactive-print=+[interactive print function]:str:' \
        '-fforce-recomp[force recompilation]' \
        '-fno-force-recomp[no force recompilation]' \
        '-fbyte-code[byte code]' \
        '-fno-byte-code[no byte code]' \
        '-fobject-code[object code]' \
        '-fno-object-code[no object code]' \
        '-fbreak-on-exception[break on exception]' \
        '-fbreak-on-error[break on error]' \
        '-fghci-history[ghci history]' \
        '-fno-ghci-history[no ghci history]' \
        '-fghci-leak-check[ghci leak check]' \
        '-fghci-hist-size=+[history size]:n:' \
        '-fno-ghci-leak-check[no leak check]' \
        '-fprint-evld-with-show[print evaluated]' \
        '-fno-print-evld-with-show[no print evaluated]' \
        '-fshow-loaded-modules[show loaded modules]' \
        '-fno-show-loaded-modules[no show loaded modules]' \
        '-fimplicit-import-qualified[implicit qualified imports]' \
        '-fno-implicit-import-qualified[no implicit qualified imports]' \
        '-fghci-history-size=+[ghci history size]:n:' \
        '-fghci-extra-defaults=+[ghci extra defaults]:str:' \
        '-fdiagnostics-color=+[diagnostics color]:c:(auto always never)' \
        '--ghc-options=+[ghc option]:list:' \
        '-package+[package]:str:' \
        '-package-id+[package id]:str:' \
        '-package-db+[package db]:dir:_files -/' \
        '-no-user-package-db[no user package db]' \
        '-XOverloadedStrings[enable OverloadedStrings]' \
        '-XScopedTypeVariables[enable ScopedTypeVariables]' \
        '-XGADTs[enable GADTs]' \
        '-XTypeFamilies[enable TypeFamilies]' \
        '-XRankNTypes[enable RankNTypes]' \
        '-XKindSignatures[enable KindSignatures]' \
        '-XBangPatterns[enable BangPatterns]' \
        '-O0[no optimization]' \
        '-O1[basic optimization]' \
        '-O2[full optimization]' \
        '*:file:_files -g "*.hs *.lhs"'
}

_ghci "$@"
