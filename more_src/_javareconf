#compdef javareconf
# Documentation: https://cran.r-project.org/doc/manuals/r-release/R-admin.html
# R CMD javareconf: detect Java setup and update R configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '(-n --dry-run)'{-n,--dry-run}'[perform Java detection but do not touch config files]' \
  '-e[same as -n but export detected variables and run prog]:prog:_command_names' \
  '*:assignment:' && ret=0

return ret
