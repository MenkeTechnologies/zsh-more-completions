#compdef cnitool
# Documentation: https://github.com/containernetworking/cni/blob/main/cnitool/README.md
# cnitool - exercise CNI configurations against a network namespace

local ret=1

_arguments -s -S \
  '(-i --ifname)'{-i,--ifname}'=[interface name (default eth0)]:ifname:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(add del check gc status)' \
  '2:netname:' \
  '3:netns:_files' && ret=0

return ret
