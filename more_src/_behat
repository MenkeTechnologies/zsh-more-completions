#compdef behat

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[specify config file]:config file:_files -g "*.yml"' \
  '--config=[specify config file]:config file:_files -g "*.yml"' \
  '-p+[specify profile]:profile' \
  '--profile=[specify profile]:profile' \
  '-s+[specify suite]:suite name' \
  '--suite=[specify suite]:suite name' \
  '-f+[specify output format]:format:(pretty progress junit html)' \
  '--format=[specify output format]:format:(pretty progress junit html)' \
  '-o+[output to directory or file]:output:_files' \
  '--out=[output to directory or file]:output:_files' \
  '--format-settings=[format settings as JSON]:settings' \
  '--init[initialize Behat directory structure]' \
  '-d+[show definitions]:pattern' \
  '--definitions=[show definitions]:pattern' \
  '--append-snippets[append snippets to existing contexts]' \
  '--no-snippets[do not print snippets]' \
  '--strict[fail on pending and undefined steps]' \
  '--order=[set scenario execution order]:order:(default random)' \
  '--rerun[rerun failed scenarios]' \
  '--stop-on-failure[stop after first failure]' \
  '--dry-run[do not execute anything]' \
  '--no-colors[disable colors in output]' \
  '--colors[force colors in output]' \
  '-v[verbose mode]' \
  '-vv[more verbose mode]' \
  '-vvv[debug mode]' \
  '--tags=[only run scenarios with matching tags]:tags' \
  '--role=[only run scenarios for specified role]:role' \
  '--name=[only run scenarios matching name]:name pattern' \
  '*:feature file:_files -g "*.feature"' && ret=0

return ret
