#compdef apex
# Documentation: https://man.archlinux.org/search?q=apex
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'deploy:deploy Lambda functions to AWS'
  'delete:delete Lambda functions'
  'invoke:invoke a function with stdin payload'
  'logs:tail CloudWatch logs for a function'
  'list:list configured functions'
  'rollback:rollback a function to a previous version'
  'build:build a function zip without deploying'
  'init:bootstrap a new Apex project'
  'alias:manage function aliases'
  'exec:execute arbitrary commands inside Apex env'
  'infra:manage Terraform infrastructure'
  'metrics:show function CloudWatch metrics'
  'docs:open Apex docs'
  'version:show Apex version'
  'upgrade:upgrade Apex to latest release'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-C --chdir)'{-C+,--chdir=}'[change working directory]:dir:_files -/' \
  '(-D --dry-run)'{-D,--dry-run}'[dry run]' \
  '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(debug info warn error)' \
  '(-p --profile)'{-p+,--profile=}'[AWS profile]:profile:' \
  '(-e --env)'{-e+,--env=}'[environment]:env:' \
  '(-r --region)'{-r+,--region=}'[AWS region]:region:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'apex command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy)
        _arguments \
          '(-C --concurrency)'{-C+,--concurrency=}'[concurrent deploys]:n:' \
          '(-a --alias)'{-a+,--alias=}'[function alias]:alias:' \
          '*::function_name:' && ret=0 ;;
      (invoke)
        _arguments \
          '(-a --alias)'{-a+,--alias=}'[alias]:alias:' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '--logs[show CloudWatch logs after invoke]' \
          '--async[invoke asynchronously]' \
          '*::function_name:' && ret=0 ;;
      (logs)
        _arguments \
          '(-f --filter)'{-f+,--filter=}'[CloudWatch filter pattern]:pattern:' \
          '(-d --duration)'{-d+,--duration=}'[lookback duration]:duration:' \
          '*::function_name:' && ret=0 ;;
      (rollback)
        _arguments \
          '(-a --alias)'{-a+,--alias=}'[alias]:alias:' \
          '(-V --version)'{-V+,--version=}'[version to rollback to]:version:' \
          '*::function_name:' && ret=0 ;;
      (build)
        _arguments \
          '*::function_name:' && ret=0 ;;
      (alias)
        _arguments \
          '(-a --alias)'{-a+,--alias=}'[alias name]:alias:' \
          '*::function_name:' && ret=0 ;;
      (init)
        _arguments \
          '*::name:' && ret=0 ;;
      (infra)
        _arguments '*::sub:(plan apply destroy)' && ret=0 ;;
      (list)
        _arguments \
          '--json[output JSON]' && ret=0 ;;
      (metrics)
        _arguments \
          '(-d --duration)'{-d+,--duration=}'[duration]:duration:' \
          '*::function_name:' && ret=0 ;;
      (delete|exec)
        _arguments '*::function_name_or_args:' && ret=0 ;;
    esac ;;
esac

return ret
