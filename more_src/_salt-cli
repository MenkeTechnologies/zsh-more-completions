#compdef salt-cli
# _salt-cli — SaltStack salt main command to invoke functions on remote minions CLI alias (saltstack team, Python); argparse
# upstream: https://github.com/saltstack/salt

_salt-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--versions-report[show versions report]' \
        '-t+[timeout seconds]:n:' \
        '--timeout=+[timeout seconds]:n:' \
        '-s[static mode]' \
        '--static[static mode]' \
        '--async[async mode]' \
        '--subset=+[size]:n:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--show-timeout[show timeout]' \
        '--hide-timeout[hide timeout]' \
        '--show-jid[show JID]' \
        '-b+[batch size or percentage]:str:' \
        '--batch=+[batch size or percentage]:str:' \
        '--batch-size=+[batch size or percentage]:str:' \
        '--batch-wait=+[seconds]:n:' \
        '--failhard[fail hard]' \
        '--retcode-passthrough[retcode passthrough]' \
        '--module-executors=+[modules]:str:' \
        '--executor-opts=+[options]:str:' \
        '--metadata=+[metadata json]:str:' \
        '--username=+[user]:_users' \
        '--password=+[pass]:str:' \
        '--eauth=+[external auth]:str:' \
        '-a+[external auth]:str:' \
        '--token=+[token]:str:' \
        '-T[token mode]' \
        '--make-token[make token]' \
        '--regen-key[regen key]' \
        '--key-deploy[key deploy]' \
        '-c+[config dir]:dir:_files -/' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '--summary[summary]' \
        '--out=+[outputter]:o:(raw key txt highstate yaml json pprint nested overstate quiet table newline_values_only)' \
        '--output=+[outputter]:o:(raw key txt highstate yaml json pprint nested overstate quiet table newline_values_only)' \
        '--out-indent=+[indent]:n:' \
        '--out-file=+[file]:file:_files' \
        '--out-file-append[append to out file]' \
        '--no-color[no color]' \
        '--force-color[force color]' \
        '--state-output=+[state]:s:(none mixed terse full changes filter)' \
        '--state-verbose=+[bool]:b:(true false)' \
        '--log-file=+[file]:file:_files' \
        '--log-file-level=+[level]:l:(garbage trace debug info warning error critical quiet)' \
        '-l+[log level]:l:(garbage trace debug info warning error critical quiet)' \
        '--log-level=+[level]:l:(garbage trace debug info warning error critical quiet)' \
        '-G[grain match]' \
        '--grain[grain match]' \
        '--grain-pcre[grain pcre match]' \
        '-P[pcre match]' \
        '--pcre[pcre match]' \
        '-L[list match]' \
        '--list[list match]' \
        '-E[regex match]' \
        '--regex[regex match]' \
        '-N[nodegroup match]' \
        '--nodegroup[nodegroup match]' \
        '-R[range match]' \
        '--range[range match]' \
        '-C[compound match]' \
        '--compound[compound match]' \
        '-I[pillar match]' \
        '--pillar[pillar match]' \
        '--pillar-pcre[pillar pcre match]' \
        '-S[ipcidr match]' \
        '--ipcidr[ipcidr match]' \
        '*:target function arg:'
}

_salt-cli "$@"
