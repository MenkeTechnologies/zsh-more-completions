#compdef sa-compile

_arguments -s \
  '--list[print extracted base strings]' \
  '--sudo[run as root via sudo]' \
  '--quiet[quiet output]' \
  '--keep-tmps[keep temporary files]' \
  '(-C --configpath --config-file)'{-C,--configpath=,--config-file=}'[config path]:dir:_files -/' \
  '--siteconfigpath=[site config path]:dir:_files -/' \
  '--updatedir=[update directory]:dir:_files -/' \
  '*--cf=[config line]:line:' \
  '(-p --prefspath --prefs-file)'{-p,--prefspath=,--prefs-file=}'[prefs file]:file:_files' \
  '*'{-D,--debug=}'[debug areas]:areas:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
