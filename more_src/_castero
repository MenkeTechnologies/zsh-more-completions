#compdef castero
# Documentation: https://man.archlinux.org/search?q=castero
# Reference accessed: 2026-05-16

# Zsh completion for castero (podcast TUI client)

_arguments -s -S \
  '--import[import OPML feed list]:file:_files -g "*.opml *.xml"' \
  '--export[export OPML feed list]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && return 0
