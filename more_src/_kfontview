#compdef kfontview

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all options]' \
  '--display=[X display]:display:' \
  '*:font_file:_files -g "*.{ttf,otf,pfa,pfb,ttc,otc,woff,woff2}"' && ret=0

return ret
