#compdef voms-proxy-init

# voms-proxy-init: create a VOMS-extended GSI proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-q[quiet]' \
  '-quiet[quiet]' \
  '-verify[verify cert/key]' \
  '-noregen[do not regenerate proxy]' \
  '-cert[user cert]:file:_files' \
  '-key[user key]:file:_files' \
  '-certdir[CA cert dir]:dir:_files -/' \
  '-out[output proxy file]:file:_files' \
  '-include[file to include]:file:_files' \
  '-conf[config file]:file:_files' \
  '-confile[config file]:file:_files' \
  '-userconf[user config file]:file:_files' \
  '-hours[hours]:n:' \
  '-valid[valid HH\:MM]:duration:' \
  '-vomslife[VOMS proxy lifetime HH\:MM]:duration:' \
  '-bits[key size]:bits:(512 1024 2048 4096)' \
  '-voms[VO[/group][:cmd]]:vo:' \
  '-vomses[vomses file]:file:_files' \
  '-target[target hostname]:host:_hosts' \
  '-order[ordering]:vo:' \
  '-policy[policy file]:file:_files' \
  '-pl[policy file]:file:_files' \
  '-pwstdin[read password from stdin]' \
  '-noLifeTimeCheck[skip lifetime check]' \
  '-rfc[RFC 3820 compliant]' \
  '-old[legacy proxy]' \
  '-globus[Globus version]:ver:' \
  '*::voms-proxy-init args:_files' && ret=0
return ret
