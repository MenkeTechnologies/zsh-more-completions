#compdef voms-proxy-init
# Documentation: https://manpages.debian.org/testing/voms-clients-java/voms-proxy-init.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

# voms-proxy-init: create a VOMS-extended GSI proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[display usage]' \
  '--usage[display usage]' \
  '--version[display version]' \
  '--debug[enable detailed debugging output]' \
  '(-q --quiet)'{-q,--quiet}'[minimal output mode]' \
  '(-b --bits)'{-b,--bits}'=[key size]:bits:(512 1024 2048 4096)' \
  '--cert=[custom certificate location]:file:_files' \
  '--certdir=[custom trusted certificate directory]:dir:_files -/' \
  '--conf=[load options from configuration file]:file:_files' \
  '--dont_verify_ac[skip AC verification]' \
  '(-f --failonwarn)'{-f,--failonwarn}'[treat warnings as errors]' \
  '--hours=[set proxy validity duration in hours]:hours:' \
  '--ignorewarn[suppress warnings]' \
  '(-k --key)'{-k,--key}'=[custom private key location]:file:_files' \
  '--limited[generate limited proxy]' \
  '(-n --noregen)'{-n,--noregen}'[use existing proxy for attribute requests]' \
  '--old[create GT2-compliant proxy]' \
  '--order=[set primary attribute order]:fqan:' \
  '--out=[custom output location]:file:_files' \
  '--path_length=[limit proxy chain depth]:L:' \
  '--proxyver=[specify proxy version]:ver:(2 3 4)' \
  '--pwstdin[read passphrase from standard input]' \
  '(-r --rfc)'{-r,--rfc}'[create RFC 3820-compliant proxy]' \
  '--target=[target AC to specific hostname]:host:_hosts' \
  '--valid=[set proxy and AC validity period HH:MM]:duration:' \
  '--verify[validate user certificate]' \
  '--voms=[request VO attributes VO[:fqan]]:vo:' \
  '--vomsdir=[custom VOMS trust anchors location]:dir:_files -/' \
  '--vomses=[custom VOMS server configuration]:file:_files' \
  '--vomslife=[set AC validity HH:MM]:duration:' \
  '*::voms-proxy-init args:_files' && ret=0
return ret
