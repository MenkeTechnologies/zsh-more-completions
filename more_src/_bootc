#compdef bootc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'upgrade:upgrade to the latest container image'
      'switch:switch to a different container image'
      'edit:edit the container image reference'
      'status:show status'
      'rollback:rollback to a previous booted deployment'
      'install:install to disk or filesystem'
      'image:manage images'
      'internals:internal commands'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      upgrade)
        _arguments -s -S \
          '--apply[apply changes immediately]' \
          '--check[check for updates only]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      switch)
        _arguments -s -S \
          '--enforce-container-sigpolicy[enforce container signature policy]' \
          '--ostree-remote=[use specified ostree remote]:remote' \
          '--retain[retain existing deployments]' \
          '--apply[apply changes immediately]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:image' && ret=0
        ;;
      install)
        _arguments -s -S \
          '1:target:(to-disk to-filesystem to-existing-root)' && ret=0
        ;;
      status)
        _arguments -s -S \
          '--format=[output format]:format:(yaml json)' \
          '--format-version=[format version]:version' \
          '--booted[only show booted deployment]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      image)
        _arguments -s -S \
          '1:action:(list copy)' && ret=0
        ;;
    esac
    ;;
esac

return ret
