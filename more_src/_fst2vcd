#compdef fst2vcd
# Documentation: https://verilator.org/guide/latest/
# Convert FST dumpfiles to VCD

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help then exit]' \
  '(-f --fstname)'{-f+,--fstname=}'[specify FST input filename]:file:_files -g "*.fst"' \
  '(-o --output)'{-o+,--output=}'[specify optional VCD output filename]:file:_files -g "*.vcd"' \
  '(-e --extensions)'{-e,--extensions}'[emit FST extensions to VCD]' \
  '*:FST file:_files -g "*.fst"' && ret=0

return ret
