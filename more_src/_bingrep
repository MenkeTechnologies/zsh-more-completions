#compdef bingrep

# Zsh completion for bingrep - search through binaries like a pro (ELF/PE/Mach-O inspector)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[print debug output]' \
  '--color[force colored output]' \
  '(-t --truncate)'{-t,--truncate}'[max number of chars to truncate]:chars' \
  '(-s --search)'{-s,--search}'[search for string in binary]:string' \
  '--demangle[demangle C++/Rust names in output]' \
  '--hex[show as hex]' \
  '1:file:_files' && ret=0

return ret
