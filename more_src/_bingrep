#compdef bingrep
# Documentation: https://github.com/m4b/bingrep
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for bingrep - search through binaries like a pro (ELF/PE/Mach-O inspector)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-d[print debug representation of parsed binary]' \
  '--color[force colored output]' \
  '(-t --truncate)'{-t,--truncate}'[max number of chars to truncate]:chars' \
  '(-s --search)'{-s,--search}'[search for string in binary (ELF only)]:string' \
  '(-D --demangle)'{-D,--demangle}'[demangle C++/Rust names in output]' \
  '--hex[show as hex (work in progress)]' \
  '--ranges[display overview of file offset ranges]' \
  '1:file:_files' && ret=0

return ret
