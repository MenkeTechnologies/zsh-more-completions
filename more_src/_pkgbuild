#compdef pkgbuild

local -a arguments

arguments=(
    '--root[Root directory of payload]:root directory:_directories'
    '--component[Component to include]:component path:_files'
    '--install-location[Default install location]:install path:_directories'
    '--scripts[Scripts directory]:scripts directory:_directories'
    '--nopayload[Create package with no payload]'
    '--identifier[Package identifier]:identifier'
    '--version[Package version]:version'
    '--ownership[Ownership behavior]:behavior:(recommended preserve preserve-other)'
    '--sign[Sign with identity]:identity'
    '--keychain[Keychain to search for signing identity]:keychain:_files'
    '--cert[Certificate to include]:certificate:_files'
    '--timestamp[Include a trusted timestamp]'
    '--timestamp=-[Specify timestamp authority URL]:URL'
    '--no-timestamp[Do not include a timestamp]'
    '--filter[Filter files from payload]:filter pattern'
    '--compress[Compression algorithm]:algorithm:(gzip bzip2 lzma lz4 lzfse zstd none)'
    '--min-os-version[Minimum OS version]:version'
    '--component-plist[Component property list]:plist file:_files -g "*.plist"'
    '--info[Package info file (deprecated)]:info file:_files'
    '--analyze[Analyze root and produce component plist]'
    '--quiet[Suppress non-error output]'
    '*:output package:_files -g "*.pkg"'
)

_arguments -s -S $arguments
