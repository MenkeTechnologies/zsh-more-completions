#compdef dunstctl
# Documentation: https://github.com/dunst-project/dunst/blob/master/docs/dunstctl.pod
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dunstctl - dunst notification daemon control

local -a subcmds
local line state

subcmds=(
  'action:invoke default action or open context menu of notification'
  'close:close the topmost or specified notification'
  'close-all:close all displayed notifications'
  'context:open the context menu'
  'count:show notification counts (displayed/history/waiting)'
  'history:display notification history as JSON'
  'history-clear:delete all notifications from history'
  'history-pop:redisplay a notification from history'
  'history-rm:remove a notification from history by ID'
  'is-paused:check if dunst is paused'
  'set-paused:set pause state'
  'get-pause-level:show current pause level (0-100)'
  'set-pause-level:set pause level (0-100)'
  'rule:enable/disable/toggle a rule'
  'rules:list configured rules'
  'reload:reload dunst configuration'
  'debug:print debug information'
  'help:show help message'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::arguments:->args'

case "$state" in
  subcmd)
    _describe -t commands 'dunstctl subcommand' subcmds
    ;;
  args)
    case "$line[1]" in
      count)
        _arguments '1:type:(displayed history waiting)'
        ;;
      set-paused)
        _arguments '1:state:(true false toggle)'
        ;;
      set-pause-level)
        _arguments '1:level (0-100)'
        ;;
      history-pop)
        _arguments '1:notification ID'
        ;;
      history-rm)
        _arguments '1:notification ID'
        ;;
      rule)
        _arguments '1:rule name' '2:action:(enable disable toggle)'
        ;;
      rules)
        _arguments '--json[output rules as JSON]'
        ;;
    esac
    ;;
esac
