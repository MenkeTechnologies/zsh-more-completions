#compdef amazon-q-dev qchat
# _amazon-q-dev — Amazon Web Services amazon-q-dev legacy Amazon Q Developer for command-line CodeWhisperer auth login chat preceded by amazon-q (aws team, Rust); clap-derive
# upstream: https://github.com/aws/amazon-q-developer-cli

_amazon-q-dev() {
    local -a sub=(
        'install:install Q Developer'
        'uninstall:uninstall Q Developer'
        'update:update Q Developer'
        'login:login with Builder ID or IAM'
        'logout:logout and clear credentials'
        'whoami:show current user'
        'doctor:run diagnostics'
        'settings:show or set settings'
        'tweak:tweak setting'
        'theme:set theme'
        'inline:open inline suggestion'
        'translate:translate natural language to shell'
        'chat:start chat session'
        'integrations:integrations subcommands'
        'launch:launch Q app'
        'restart:restart background services'
        'feed:show what'\''s new'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amazon-q-dev subcommand' sub ;;
        args)
            case $words[1] in
                chat) _arguments \
                    '--no-interactive[non-interactive mode]' \
                    '--accept-all[auto-accept]' \
                    '--profile=+[AWS profile]:str:' \
                    '--region=+[AWS region]:r:(us-east-1 us-west-2 eu-west-1 ap-northeast-1)' \
                    '--trust-all-tools[trust all tools]' \
                    '*:prompt:' ;;
                translate) _arguments '*:natural language:' ;;
                settings) _arguments '1:key:' '2:value:' ;;
                integrations) _arguments '1:integration cmd:(install uninstall reinstall status)' ;;
                doctor) _arguments \
                    '--force[force]' \
                    '--strict[strict]' ;;
            esac
            ;;
    esac
}

_amazon-q-dev "$@"
