#compdef caffe2ncnn
# Documentation: https://github.com/Tencent/ncnn/wiki/use-ncnn-with-pytorch-or-onnx
# Convert a Caffe model to ncnn param/bin

local ret=1

_arguments -s -S \
  '1:caffe prototxt:_files -g "*.prototxt"' \
  '2:caffe model:_files -g "*.caffemodel"' \
  '3:output ncnn param:_files -g "*.param"' \
  '4:output ncnn bin:_files -g "*.bin"' && ret=0

return ret
