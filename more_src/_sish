#compdef sish
# Documentation: https://docs.ssi.sh/getting-started/cli
# Reference accessed: 2026-05-21
# Verified: upstream sish CLI docs at docs.ssi.sh.
# Removed from prior file: --http, --ssh (real names use addr suffix:
# --http-address / --ssh-address), --append-user-to-subdomain (not in
# upstream flag set), --bind-range, --idle-connection-timeout (no such
# upstream flag), --verify-ssl (real flag is --verify-ssl on per-host
# basis but documented form differs). Adding real flags.

_arguments -s -S \
  '(-a --ssh-address)'{-a,--ssh-address}'=[SSH listener address]:addr:' \
  '(-i --http-address)'{-i,--http-address}'=[HTTP listener address]:addr:' \
  '(-t --https-address)'{-t,--https-address}'=[HTTPS listener address]:addr:' \
  '--tcp-address=[TCP listener address]:addr:' \
  '(-d --domain)'{-d,--domain}'=[root domain for HTTP multiplexing]:domain:' \
  '--authentication[require SSH authentication]' \
  '(-u --authentication-password)'{-u,--authentication-password}'=[SSH access password]:pass:' \
  '(-k --authentication-keys-directory)'{-k,--authentication-keys-directory}'=[directory of authorized public keys]:dir:_directories' \
  '--authentication-key-request-url=[remote URL to validate keys]:url:' \
  '--banned-ips=[banned IPs (comma list)]:list:' \
  '--banned-countries=[banned countries (comma list)]:list:' \
  '--banned-subdomains=[banned subdomains (comma list)]:list:' \
  '(-w --whitelisted-ips)'{-w,--whitelisted-ips}'=[allowed IP list]:list:' \
  '(-y --whitelisted-countries)'{-y,--whitelisted-countries}'=[allowed country list]:list:' \
  '--bind-random-subdomains[force random HTTP subdomains]' \
  '--bind-random-ports[force random TCP ports]' \
  '--force-requested-subdomains[require exact subdomain matches]' \
  '--bind-hosts=[allowed custom hosts]:list:' \
  '--https[enable HTTPS listening]' \
  '(-s --https-certificate-directory)'{-s,--https-certificate-directory}'=[TLS cert directory]:dir:_directories' \
  '--https-ondemand-certificate[auto-fetch certs via Let'\''s Encrypt]' \
  '--debug[enable debug output]' \
  '--log-to-stdout[log to console]' \
  '--log-to-file[write logs to disk]' \
  '--admin-console[enable admin interface]' \
  '--service-console[enable per-service console]' \
  '--http-load-balancer[allow multiple clients per domain]' \
  '--tcp-load-balancer[allow multiple clients per port]' \
  '--sni-proxy[enable SNI proxying]' \
  '*: : _default'
