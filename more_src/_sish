#compdef sish
# Documentation: https://man.archlinux.org/search?q=sish
# Reference accessed: 2026-05-16

_arguments -s -S \
  '--http=[public HTTP address]:addr' \
  '--ssh=[SSH listen address]:addr' \
  '--authentication=[auth mode]:mode:(none password public-key)' \
  '--append-user-to-subdomain[append username in DNS]' \
  '--bind-random-subdomains[allocate random subdomain]' \
  '--bind-range=[port range for binds]:range' \
  '--idle-connection-timeout=[timeout duration]:duration' \
  '--log-level=[log level]:level' \
  '--verify-ssl[verify TLS to HTTP server]' \
  '*: : _default'
