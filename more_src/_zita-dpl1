#compdef zita-dpl1
# Documentation: https://github.com/jackaudio/jack-example-tools
# JACK look-ahead digital peak limiter

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-k+[number of channels, 1 to 16]:count' \
  '-name+[JACK client name]:name' \
  '-s+[JACK server name]:server' \
  '-g+[window position geometry]:geometry' && ret=0

return ret
