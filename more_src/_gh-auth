#compdef gh-auth
# _gh-auth — GitHub gh auth authentication subcommand alias (GitHub Inc., Go); spf13/cobra
# upstream: https://github.com/cli/cli

_gh-auth() {
    local -a sub=(
        'login:authenticate with a GitHub host'
        'logout:log out'
        'refresh:refresh stored credentials'
        'setup-git:configure git to use gh credentials'
        'status:show authentication status'
        'switch:switch active account'
        'token:print authentication token'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gh-auth subcommand' sub ;;
        args)
            case $words[1] in
                login) _arguments \
                    '--git-protocol=+[git protocol]:p:(ssh https)' \
                    '-p+[git protocol]:p:(ssh https)' \
                    '--hostname=+[GitHub hostname]:host:_hosts' \
                    '-h+[GitHub hostname]:host:_hosts' \
                    '--insecure-storage[insecure storage]' \
                    '--scopes=+[scopes csv]:list:' \
                    '-s+[scopes csv]:list:' \
                    '--web[login via browser]' \
                    '-w[login via browser]' \
                    '--with-token[read token from stdin]' \
                    '--skip-ssh-key[skip SSH key upload]' ;;
                logout) _arguments \
                    '--hostname=+[GitHub hostname]:host:_hosts' \
                    '-h+[GitHub hostname]:host:_hosts' \
                    '--user=+[user]:str:_users' \
                    '-u+[user]:str:_users' ;;
                refresh) _arguments \
                    '--hostname=+[GitHub hostname]:host:_hosts' \
                    '-h+[GitHub hostname]:host:_hosts' \
                    '--insecure-storage[insecure storage]' \
                    '--remove-scopes=+[remove scopes]:list:' \
                    '-r+[remove scopes]:list:' \
                    '--reset-scopes[reset scopes]' \
                    '--scopes=+[scopes csv]:list:' \
                    '-s+[scopes csv]:list:' ;;
                status) _arguments \
                    '--hostname=+[GitHub hostname]:host:_hosts' \
                    '-h+[GitHub hostname]:host:_hosts' \
                    '--show-token[show token]' \
                    '-t[show token]' \
                    '--active[show active only]' ;;
                switch) _arguments \
                    '--hostname=+[GitHub hostname]:host:_hosts' \
                    '-h+[GitHub hostname]:host:_hosts' \
                    '--user=+[user]:str:_users' \
                    '-u+[user]:str:_users' ;;
                token) _arguments \
                    '--hostname=+[GitHub hostname]:host:_hosts' \
                    '-h+[GitHub hostname]:host:_hosts' \
                    '--secure-storage[secure storage]' \
                    '--user=+[user]:str:_users' \
                    '-u+[user]:str:_users' ;;
                setup-git) _arguments \
                    '--force[force]' \
                    '-f[force]' \
                    '--hostname=+[GitHub hostname]:host:_hosts' \
                    '-h+[GitHub hostname]:host:_hosts' ;;
            esac
            ;;
    esac
}

_gh-auth "$@"
