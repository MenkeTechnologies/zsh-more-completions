#compdef derry
# Documentation: https://pub.dev/packages/derry
# derry - run script shortcuts defined in pubspec.yaml for Dart/Flutter projects

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(-d --description)'{-d,--description}'[include descriptions when listing]' \
  '(-a --absolute)'{-a,--absolute}'[show absolute path of the script file]' \
  '1:command:(ls source upgrade)' \
  '*::script:' && ret=0

return ret
