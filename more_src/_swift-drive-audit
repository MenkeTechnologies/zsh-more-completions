#compdef swift-drive-audit

# swift-drive-audit: scan kernel log for failed disks and unmount/repair
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '*:swift config file:_files -g "*.conf"' && ret=0
return ret
