#compdef apt-cache-cli
# _apt-cache-cli — Debian APT apt-cache query CLI alias (Debian project, C++); custom argparse
# upstream: https://salsa.debian.org/apt-team/apt

_apt-cache-cli() {
    local -a sub=(
        'gencaches:generate package and source caches'
        'showpkg:show general info about a package'
        'showsrc:show source records'
        'stats:show some basic statistics'
        'dump:show entire file (debug)'
        'dumpavail:print available file'
        'unmet:show unmet dependencies'
        'search:search the package list'
        'show:show a readable record'
        'depends:show raw dependency info'
        'rdepends:show reverse dependency info'
        'pkgnames:list the names of all packages in the system'
        'dotty:generate package graphs for GraphViz'
        'xvcg:generate package graphs for xvcg'
        'policy:show policy settings'
        'madison:show available versions across releases'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--names-only[search by package name only]' \
        '-n[search by package name only]' \
        '--full[full details]' \
        '-f[full details]' \
        '--installed[only installed]' \
        '-i[only installed]' \
        '--all-versions[all versions]' \
        '-a[all versions]' \
        '--no-all-versions[no all versions]' \
        '--no-installed[no installed]' \
        '--no-generate[no generate]' \
        '--pre-depends[pre-depends]' \
        '--depends[depends]' \
        '--recommends[recommends]' \
        '--suggests[suggests]' \
        '--conflicts[conflicts]' \
        '--breaks[breaks]' \
        '--replaces[replaces]' \
        '--enhances[enhances]' \
        '--important[important]' \
        '--recurse[recurse]' \
        '--option=+[apt option]:str:' \
        '-o+[apt option]:str:' \
        '--config-file=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'apt-cache subcommand' sub ;;
        args)
            case $words[1] in
                search|show|showpkg|showsrc|depends|rdepends|dotty|xvcg|policy|madison) _arguments '*:package-or-pattern:' ;;
            esac
            ;;
    esac
}

_apt-cache-cli "$@"
