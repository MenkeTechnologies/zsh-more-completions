#compdef extractor
# Extracts products (images, spectra, lightcurves) from input events files

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'filename=[input event filename or @file list]:event file:_files' \
  'eventsout=[output events file name]:output file:_files' \
  'imgfile=[output image file name]:image file:_files' \
  'binf=[binning factor for event coordinates]:factor:' \
  'phafile=[output spectrum file name]:pha file:_files' \
  'specbin=[binning factor for spectrum]:factor:' \
  'fitsbinlc=[output FITS binned light curve file name]:lc file:_files' \
  'qdpfile=[output QDP binned light curve file name]:qdp file:_files' \
  'binlc=[binsize for light curve construction]:binsize:' \
  'unbinlc=[output unbinned light curve file name]:lc file:_files' \
  'regionfile=[region file for spatial filtering]:region file:_files' \
  'timefile=[time filter file]:time file:_files' \
  'xcolf=[column name for X coordinate]:column:' \
  'ycolf=[column name for Y coordinate]:column:' \
  'tcol=[column name for event time]:column:' \
  'ecol=[column name for spectrum construction]:column:' \
  'gcol=[column name for GRADE or PATTERN filtering]:column:' \
  'gstring=[filter string for grades]:filter:' \
  'events=[extension name containing events]:extension:' \
  'gti=[extension name containing good time intervals]:extension:' \
  'copyall=[copy extra extensions to output event file]:flag:(yes no)' \
  'clobber=[overwrite existing output files]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
