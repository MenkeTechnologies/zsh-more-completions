#compdef pacman2
# _pacman2 — Arch Linux pacman2 CLI command-line frontend wrapping the pacman the official package manager for Arch Linux and derivatives open-source written in C originally Judd Vinet now Allan McRae Levente Polyak et al combines binary package format with easy-to-use build system Arch Linux Manjaro EndeavourOS Garuda BlackArch Artix sync remove query database files upgrade-from-file deptest help version no-confirm no-deps no-progress noprogress logs verbose root cache dir gpgdir hookdir-data dir disable-download-timeout disable-sandbox color print arch confirm sysroot key files (Arch Linux Judd Vinet Allan McRae Levente Polyak, C); custom argparse
# upstream: https://archlinux.org/pacman/

_pacman2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-Q[query database]' \
        '-S[sync packages]' \
        '-R[remove packages]' \
        '-D[modify database]' \
        '-U[upgrade from file]' \
        '-T[deptest]' \
        '-F[query files]' \
        '-b+[DB path]:dir:_files -/' \
        '--dbpath=+[dir]:dir:_files -/' \
        '-r+[root]:dir:_files -/' \
        '--root=+[dir]:dir:_files -/' \
        '--sysroot=+[dir]:dir:_files -/' \
        '--cachedir=+[dir]:dir:_files -/' \
        '--gpgdir=+[dir]:dir:_files -/' \
        '--hookdir=+[dir]:dir:_files -/' \
        '--logfile=+[file]:file:_files' \
        '--arch=+[arch]:str:' \
        '--color=+[c]:c:(always auto never)' \
        '--config=+[file]:file:_files -g "pacman.conf *.conf"' \
        '--noconfirm[no confirm]' \
        '--confirm[confirm]' \
        '--disable-download-timeout[no download timeout]' \
        '--disable-sandbox[no sandbox]' \
        '--needed[skip already installed]' \
        '--asdeps[install as dep]' \
        '--asexplicit[install as explicit]' \
        '--ignore=+[pkg]:str:' \
        '*--ignore=+[pkg]:str:' \
        '--ignoregroup=+[grp]:str:' \
        '*--ignoregroup=+[grp]:str:' \
        '--assume-installed=+[pkg]:str:' \
        '*--assume-installed=+[pkg]:str:' \
        '--noprogressbar[no progress]' \
        '--noscriptlet[no scriptlet]' \
        '--print[print only]' \
        '--print-format=+[fmt]:str:' \
        '-s+[search regex]:str:' \
        '--search=+[regex]:str:' \
        '-u[upgrades]' \
        '--sysupgrade[sysupgrade]' \
        '-y[refresh]' \
        '--refresh[refresh]' \
        '-yy[force refresh]' \
        '-uu[downgrade]' \
        '-d[no deps]' \
        '--nodeps[no deps]' \
        '-dd[no deps no version]' \
        '-c[clean]' \
        '--clean[clean cache]' \
        '-cc[clean all]' \
        '-w[download only]' \
        '--downloadonly[download only]' \
        '-i[info]' \
        '--info[info]' \
        '-l[list]' \
        '--list[list]' \
        '-g[groups]' \
        '--groups[groups]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-p[print]' \
        '--print[print]' \
        '-n[no save backups]' \
        '--nosave[no save]' \
        '-s[recursive]' \
        '--recursive[recursive]' \
        '-ss[unneeded recursive]' \
        '-e[explicitly installed]' \
        '--explicit[explicit]' \
        '-m[foreign]' \
        '--foreign[foreign]' \
        '-n[native]' \
        '--native[native]' \
        '-o+[owns file]:file:_files' \
        '--owns=+[file]:file:_files' \
        '-Qo+[owns]:_files' \
        '-Qp+[file]:file:_files' \
        '--check[check]' \
        '-k[check]' \
        '-Sl+[repo]:str:' \
        '-Si+[pkg]:str:' \
        '-Ss+[regex]:str:' \
        '-Sg+[group]:str:' \
        '-Fl[list files in package]' \
        '-Fy[refresh files DB]' \
        '-Fs+[search file]:str:' \
        '-Fo+[file]:file:_files' \
        '*:package:'
}

_pacman2 "$@"
