#compdef nap

_nap_commands() {
  local -a commands=(
    'list:List snippets'
    'fuzzy:Fuzzy find snippets'
    'edit:Edit a snippet'
    'copy:Copy a snippet to clipboard'
    'paste:Create snippet from clipboard'
    'new:Create a new snippet'
    'delete:Delete a snippet'
    'rename:Rename a snippet'
    'tags:List all tags'
    'export:Export snippets'
    'import:Import snippets'
    'help:Help about any command'
  )
  _describe 'command' commands
}

_nap() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '--config=[config file]:file:_files' \
    '1:command:_nap_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        edit|copy|delete|rename)
          _arguments \
            '1:snippet name'
          ;;
        new)
          _arguments \
            '(-l --language)'{-l,--language}'=[snippet language]:language' \
            '(-t --tag)'{-t,--tag}'=[snippet tag]:tag' \
            '1:snippet name'
          ;;
        list)
          _arguments \
            '(-t --tag)'{-t,--tag}'=[filter by tag]:tag' \
            '(-l --language)'{-l,--language}'=[filter by language]:language'
          ;;
        export|import)
          _arguments \
            '1:file:_files'
          ;;
      esac
      ;;
  esac
}

_nap "$@"
