#compdef nap
# Documentation: https://github.com/maaslalani/nap
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nap CLI exposes only a few non-interactive subcommands; most operations
# (edit/copy/paste/delete/rename) are TUI keybindings, not CLI commands.

local -a commands=(
  'list:list all snippets'
  'fuzzy:fuzzy-find snippets'
)

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '1:command-or-snippet:->cmd' \
  && return 0

case $state in
  (cmd)
    _describe -t commands 'nap command' commands
    ;;
esac
