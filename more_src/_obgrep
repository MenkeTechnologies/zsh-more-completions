#compdef obgrep
# obgrep — grep-like tool for chemical structures using SMARTS patterns

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-v[invert match (print non-matching molecules)]' \
  '-c[count matching molecules]' \
  '-f[full match (all atoms must match)]' \
  '-n[print molecule name only]' \
  '-t[print matching SMARTS target]' \
  ':SMARTS pattern:' \
  ':input file:_files -g "*.{sdf,mol,mol2,pdb,xyz,smi,cml}"'
