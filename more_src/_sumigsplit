#compdef sumigsplit
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/migration_inversion/sumigsplit.c
# Split-step depth migration for zero-offset data

local ret=1

_arguments -s -S \
  'vfile=[vfile]:vfile:' \
  'nz=[nz]:nz:' \
  'dz=[dz]:dz:' \
  'dt=[dt]:dt:' \
  'dx=[dx]:dx:' \
  'ft=[ft]:ft:' \
  'fz=[fz]:fz:' \
  'tmpdir=[tmpdir]:tmpdir:' \
  '*:file:_files' && ret=0

return ret
