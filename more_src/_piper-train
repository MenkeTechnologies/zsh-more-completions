#compdef piper-train piper-train-cli
# _piper-train — Mike Hansen rhasspy piper-train training utility for the Piper neural text-to-speech voices (rhasspy team, Python); argparse
# upstream: https://github.com/rhasspy/piper

_piper-train() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--dataset-dir=+[dataset dir]:dir:_files -/' \
        '--accelerator=+[accelerator]:a:(gpu cpu mps tpu auto)' \
        '--devices=+[N or list]:str:' \
        '--strategy=+[strategy]:str:' \
        '--batch-size=+[N]:n:' \
        '--validation-split=+[F]:f:' \
        '--num-test-examples=+[N]:n:' \
        '--max-epochs=+[N]:n:' \
        '--default-root-dir=+[work dir]:dir:_files -/' \
        '--checkpoint-epochs=+[N]:n:' \
        '--quality=+[quality]:q:(x-low low medium high)' \
        '--resume-from-checkpoint=+[ckpt]:file:_files -g "*.ckpt"' \
        '--precision=+[precision]:p:(16 32 64 bf16 16-mixed bf16-mixed)' \
        '--num-workers=+[N]:n:' \
        '--num-utterances-per-speaker=+[N]:n:' \
        '--speaker-id=+[id]:str:' \
        '--noise-scale=+[F]:f:' \
        '--length-scale=+[F]:f:' \
        '--noise-w=+[F]:f:' \
        '--sample-rate=+[Hz]:n:' \
        '--seed=+[N]:n:' \
        '--gradient-clip-val=+[F]:f:' \
        '--log-every-n-steps=+[N]:n:' \
        '--log-wandb[log to wandb]' \
        '--wandb-project=+[project name]:str:' \
        '--wandb-entity=+[entity]:str:' \
        '--log-tensorboard[log to TensorBoard]' \
        '--tensorboard-dir=+[dir]:dir:_files -/'
}

_piper-train "$@"
