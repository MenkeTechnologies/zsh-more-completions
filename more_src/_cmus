#compdef cmus

# Zsh completion for cmus - Console music player

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--listen[listen on address]:address:' \
  '--plugins[list available plugins]' \
  '--show-cursor[always visible cursor]' \
  '*:file:_files' && ret=0

return ret
