#compdef cmus
# Documentation: https://man.archlinux.org/man/cmus.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cmus: console music player
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--listen=[UNIX socket or addr to listen on]:address:' \
  '--plugins[list available plugins and exit]' \
  '--show-cursor[always display the cursor]' \
  '*:file:_files' && ret=0

return ret
