#compdef piactl
# Documentation: https://helpdesk.privateinternetaccess.com/hc/en-us/articles/46815372532123
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Private Internet Access `piactl` — VPN management CLI.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'connect:connect to VPN'
  'disconnect:disconnect from VPN'
  'get:retrieve setting/state from PIA daemon'
  'set:change setting in PIA daemon'
  'monitor:watch connection updates'
  'background:enable/disable background daemon'
  'login:authenticate user'
  'logout:end authentication session'
  'reset:reset settings to default'
  'help:show help topics'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[print debug logs]' \
  '(-t --timeout)'{-t+,--timeout=}'[timeout for commands]:seconds:' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'piactl' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
