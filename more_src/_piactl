#compdef piactl

# Private Internet Access `piactl` — VPN management (`piactl help`). Subcommands: connect, disconnect, get, set, monitor, background, etc.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'connect:connect VPN region'
  'disconnect:disconnect VPN'
  'get:query setting/state'
  'set:update setting'
  'monitor:watch connection'
  'background:toggle daemon'
  'help:online help topics'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'piactl' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
