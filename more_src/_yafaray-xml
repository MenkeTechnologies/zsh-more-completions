#compdef yafaray-xml
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/yafaray-xml.1.html
# YafaRay standalone XML scene renderer

local ret=1

_arguments -s \
  '-s[render strategy]:strategy:(threaded mono fork)' \
  '-c[number of processes or threads]:N' \
  '-r[render only part of frame min_x:max_x:min_y:max_y]:region' \
  '-z[gzip data passed between processes for cluster use]' \
  '-p[alternative path for the plugins]:path:_files -/' \
  '-v[show the program version]' \
  '*:xml:_files -g "*.xml"' && ret=0

return ret
