#compdef neuron

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'new:create a new zettel'
  'open:open a zettel'
  'search:search zettels'
  'query:query the zettelkasten'
  'rib:generate static site'
)

_arguments -s -S \
  '(-d --dir)'{-d,--dir}'[zettelkasten directory]:directory:_files -/' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'neuron subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (new)
        _arguments -s -S \
          '--id[zettel ID]:zettel ID:' \
          '--title[zettel title]:title:' \
          '(-e --editor)'{-e,--editor}'[editor to use]:editor:' && ret=0
        ;;
      (open)
        _arguments -s -S \
          '--id[zettel ID]:zettel ID:' \
          '(-e --editor)'{-e,--editor}'[editor to use]:editor:' && ret=0
        ;;
      (search)
        _arguments -s -S \
          '--search[search query]:query:' \
          '--open[open result]' && ret=0
        ;;
      (query)
        _arguments -s -S '*:query:' && ret=0
        ;;
      (rib)
        _arguments -s -S '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
