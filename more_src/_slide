#compdef slide
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss192.html
# KAPPA: shift an NDF by a given amount

local ret=1

_arguments -s \
  'ABS=[absolute pixel shifts along each axis]:abs' \
  'FID=[target position in pixel coordinates]:fid' \
  'IN=[input NDF to be translated]:NDF:_files' \
  'METHOD=[interpolation method for resampling]:method' \
  'OBJ=[source position in the input NDF]:obj' \
  'OUT=[output translated NDF]:NDF:_files' \
  'PARAMS=[resampling-method parameters]:params' \
  'STYPE=[shifts absolute or relative]:stype:(Absolute Relative)' \
  'TITLE=[title for the output NDF]:title' \
  '*:NDF:_files' && ret=0

return ret
