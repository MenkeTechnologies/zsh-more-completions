#compdef accton
# Documentation: man accton(8) (BSD)
# Source: BSD accton — enable/disable system process accounting.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:accounting file (omit to disable):_files' \
    && ret=0

return ret
