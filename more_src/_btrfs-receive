#compdef btrfs-receive
# Documentation: https://btrfs.readthedocs.io/en/latest/btrfs-receive.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-f[read from file]:input file:_files' \
  '-e[terminate after receiving end command in stream]' \
  '(-C --chroot)'{-C,--chroot}'[chroot before receiving]' \
  '(-E --max-errors)'{-E+,--max-errors=}'[maximum tolerated errors]:count:' \
  '-m[root mount point of the filesystem]:mount point:_directories' \
  '--dump[dump stream metadata, do not apply]' \
  '--force-decompress[decompress and overwrite compressed extents]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  ':destination:_directories' && ret=0

return ret
