#compdef btrfs-receive
# Documentation: https://man.archlinux.org/search?q=btrfs-receive
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-f[read from file]:input file:_files' \
  '-e[terminate after receiving end command]' \
  '-C[chroot before receiving]' \
  '--max-errors[maximum tolerated errors]:count' \
  '-m[root mount point of the filesystem]:mount point:_directories' \
  '--dump[dump stream metadata, do not apply]' \
  '--force[force overwrite of existing snapshots]' \
  {-q,--quiet}'[quiet mode]' \
  {-v,--verbose}'[verbose output]' \
  ':destination:_directories' && ret=0

return ret
