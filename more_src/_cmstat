#compdef cmstat

# Infernal cmstat: display summary statistics about CM(s)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-E[show calibration data E-value at probability p]:E:' \
  '-T[show calibration data score at probability p]:T:' \
  '-Z[set effective database size (Mb)]:Mb:' \
  '--cut_ga[show GA gathering cutoffs]' \
  '--cut_nc[show NC noise cutoffs]' \
  '--cut_tc[show TC trusted cutoffs]' \
  '*:CM file:_files' && ret=0
return ret
