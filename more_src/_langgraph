#compdef langgraph

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'new:create new project from template'
  'dev:run API server locally with hot reload'
  'up:launch API server in Docker'
  'build:build Docker image'
  'dockerfile:generate Dockerfile'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'langgraph subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (dev)
        _arguments \
          '--host=[bind host]:host:_hosts' \
          '--port=[bind port]:port:' \
          '--no-reload[disable auto-reload]' \
          '--debug-port=[debug port]:port:' \
          '--no-browser[do not open browser]' \
          '(-c --config)'{-c,--config=}'[config file]:file:_files -g "*.json"' && ret=0
        ;;
      (up)
        _arguments \
          '(-p --port)'{-p,--port=}'[bind port]:port:' \
          '--wait[wait for server]' \
          '--watch[watch for changes]' \
          '--verbose[verbose output]' \
          '(-c --config)'{-c,--config=}'[config file]:file:_files -g "*.json"' \
          '(-d --docker-compose)'{-d,--docker-compose=}'[docker compose file]:file:_files' && ret=0
        ;;
      (build)
        _arguments \
          '-t=[image tag]:tag:' \
          '--platform=[target platform]:platform:' \
          '--pull[pull base image]' \
          '--no-pull[do not pull base image]' \
          '(-c --config)'{-c,--config=}'[config file]:file:_files' && ret=0
        ;;
      (dockerfile)
        _arguments \
          '(-c --config)'{-c,--config=}'[config file]:file:_files' \
          ':save_path:_files' && ret=0
        ;;
      (new)
        _arguments \
          '--template=[template name]:template:' \
          ':path:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
