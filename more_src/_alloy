#compdef alloy

# Zsh completion for Grafana Alloy (formerly Grafana Agent Flow)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:run Alloy'
      'fmt:format Alloy config files'
      'convert:convert config from other formats'
      'tools:developer tools'
      'completion:generate shell completions'
    )
    _describe -t commands 'alloy command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--server.http.listen-addr=[HTTP listen address]:address' \
          '--server.http.ui-path-prefix=[UI path prefix]:prefix' \
          '--cluster.enabled[enable clustering]' \
          '--cluster.name=[cluster name]:name' \
          '--cluster.node-name=[cluster node name]:name' \
          '--cluster.join-addresses=[cluster join addresses]:addresses' \
          '--cluster.advertise-address=[cluster advertise address]:address' \
          '--storage.path=[data storage path]:path:_directories' \
          '--stability.level=[minimum stability level]:level:(experimental public-preview generally-available)' \
          '--disable-reporting[disable usage reporting]' \
          '*:config file:_files -g "*.alloy"' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-w[write result to file]' \
          '--write[write result to file]' \
          '*:config file:_files -g "*.alloy"' && ret=0
        ;;
      convert)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--source-format=[source format]:format:(prometheus promtail static otelcol)' \
          '--output=[output file]:file:_files' \
          '-o+[output file]:file:_files' \
          '--bypass-errors[bypass conversion errors]' \
          '--extra-args=[extra arguments]:args' \
          '*:source file:_files' && ret=0
        ;;
      tools)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:tool:(sample-config)' && ret=0
        ;;
    esac
    ;;
esac

return ret
