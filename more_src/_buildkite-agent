#compdef buildkite-agent

# Zsh completion for buildkite-agent (Buildkite CI/CD agent)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'start:start the buildkite agent'
      'annotate:annotate a build'
      'annotation:manage annotations on a build'
      'artifact:manage artifacts'
      'bootstrap:run a build bootstrap script'
      'env:interact with environment variables'
      'lock:manage agent locks'
      'meta-data:manage build metadata'
      'oidc:interact with OIDC tokens'
      'pipeline:manage pipeline uploads'
      'redactor:manage redactions'
      'secret:interact with secrets'
      'step:manage build step operations'
      'tool:utility commands'
    )
    _describe -t commands 'buildkite-agent command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (start)
        _arguments \
          '--token[agent registration token]:token' \
          '--name[agent name]:name' \
          '--priority[agent priority]:priority' \
          '--tags[agent tags]:tags' \
          '--tags-from-ec2-meta-data[load tags from EC2 metadata]' \
          '--tags-from-ec2-tags[load tags from EC2 tags]' \
          '--tags-from-gcp-meta-data[load tags from GCP metadata]' \
          '--tags-from-gcp-labels[load tags from GCP labels]' \
          '--build-path[path to build checkouts]:path:_files -/' \
          '--hooks-path[path to agent hooks]:path:_files -/' \
          '--plugins-path[path to agent plugins]:path:_files -/' \
          '--bootstrap-script[path to bootstrap script]:script:_files' \
          '--spawn[number of parallel agents]:count' \
          '--cancel-grace-period[seconds to wait for job cancellation]:seconds' \
          '--disconnect-after-job[disconnect after running a job]' \
          '--disconnect-after-idle-timeout[disconnect after being idle]:seconds' \
          '--config[path to config file]:config:_files' \
          '--debug[enable debug mode]' \
          '--experiment[enable experimental features]:feature' \
          '--no-color[disable color output]' && ret=0
        ;;
      (annotate)
        _arguments \
          '--context[annotation context]:context' \
          '--style[annotation style]:style:(success info warning error)' \
          '--append[append to existing annotation]' \
          '--job[job ID]:job' \
          '1:body' && ret=0
        ;;
      (artifact)
        local -a subcmds=(
          'upload:upload artifacts'
          'download:download artifacts'
          'search:search for artifacts'
          'shasum:print SHA of an artifact'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (meta-data)
        local -a subcmds=(
          'set:set metadata'
          'get:get metadata'
          'exists:check if metadata exists'
          'keys:list metadata keys'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (pipeline)
        _arguments \
          '1:subcommand:(upload)' \
          '2:pipeline file:_files -g "*.{yml,yaml,json}"' && ret=0
        ;;
      (step)
        local -a subcmds=(
          'get:get a step attribute'
          'update:update a step'
          'cancel:cancel a step'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
