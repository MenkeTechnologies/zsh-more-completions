#compdef try-runtime
# _try-runtime — Paritytech try-runtime-cli runtime upgrade tester replays state and runs migrations against forked Substrate chains (paritytech team, Rust); clap-derive
# upstream: https://github.com/paritytech/try-runtime-cli

_try-runtime() {
    local -a sub=(
        'on-runtime-upgrade:run runtime upgrade'
        'execute-block:execute a block'
        'follow-chain:follow chain for runtime upgrades'
        'offchain-worker:run an offchain worker'
        'create-snapshot:dump chain state to file'
        'fast-forward:advance chain N blocks'
        'commands:show available commands'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--runtime=+[wasm runtime]:file:_files -g "*.wasm"' \
        '-r+[wasm runtime]:file:_files -g "*.wasm"' \
        '--overwrite-state-version=+[version]:n:' \
        '--no-spec-check-panic[no spec check panic]' \
        '--export-proof=+[proof file]:file:_files' \
        '--state=+[state source]:s:(live snap)' \
        '--state-pruning=+[mode]:m:(archive 256 1024)' \
        '--blocktime=+[milliseconds]:n:' \
        '--no-info-logs[hide info logs]' \
        '--no-genesis[no genesis]' \
        '--chain=+[chain spec]:c:(polkadot kusama westend rococo dev local)' \
        '--wasm-execution=+[mode]:m:(interpreted compiled)' \
        '--heap-pages=+[N]:n:' \
        '--default-child-tries=+[N]:n:' \
        '--max-runtime-instances=+[N]:n:' \
        '--runtime-cache-size=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'try-runtime subcommand' sub ;;
        args)
            case $words[1] in
                on-runtime-upgrade) _arguments \
                    '--checks=+[checks]:c:(none all upgrade try-state pre-and-post)' \
                    '--no-weight-warnings[no weight warnings]' \
                    '--no-idempotency-checks[no idempotency]' \
                    '--disable-spec-name-check[disable spec-name check]' \
                    '--disable-spec-version-check[disable spec-version check]' \
                    '--disable-mbm-checks[disable mbm checks]' \
                    '*:state:' ;;
                execute-block) _arguments \
                    '--block-ws-uri=+[url]:url:_urls' \
                    '--try-state=+[try state mode]:str:' \
                    '*:block hash:' ;;
                follow-chain) _arguments \
                    '--uri=+[chain rpc]:url:_urls' \
                    '--try-state=+[try state mode]:str:' \
                    '--keep-connection[keep connection]' ;;
                offchain-worker) _arguments \
                    '--header-at=+[block hash]:str:' \
                    '*:state:' ;;
                create-snapshot) _arguments \
                    '--uri=+[chain rpc]:url:_urls' \
                    '--at=+[block hash]:str:' \
                    '*:path:_files' ;;
                fast-forward) _arguments \
                    '--n-blocks=+[N]:n:' \
                    '*:state:' ;;
            esac
            ;;
    esac
}

_try-runtime "$@"
