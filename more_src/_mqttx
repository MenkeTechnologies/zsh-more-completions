#compdef mqttx

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a common_flags=(
  '--hostname=[MQTT broker host]:host:_hosts'
  '--port=[MQTT broker port]:port'
  '--mqtt-version=[MQTT protocol version]:version:(3.1.1 5)'
  {-u,--username}'=[username]:username'
  {-P,--password}'=[password]:password'
  {-i,--client-id}'=[client ID]:client id'
  '--clean[enable clean session]'
  '--no-clean[disable clean session]'
  {-k,--keepalive}'=[keepalive interval in seconds]:seconds'
  '--reconnect-period=[reconnect period in ms]:milliseconds'
  '--protocol=[transport protocol]:protocol:(mqtt mqtts ws wss)'
  '--ca=[CA certificate file]:ca file:_files'
  '--cert=[client certificate file]:cert file:_files'
  '--key=[client key file]:key file:_files'
  '--insecure[disable TLS verification]'
  '--will-topic=[will topic]:topic'
  '--will-message=[will message]:message'
  '--will-qos=[will QoS level]:qos:(0 1 2)'
  '--will-retain[will message retain flag]'
  '--session-expiry-interval=[session expiry interval]:seconds'
  '--receive-maximum=[receive maximum]:count'
  '--maximum-packet-size=[maximum packet size]:bytes'
  '--topic-alias-maximum=[topic alias maximum]:count'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'conn:Create a connection'
      'sub:Subscribe to a topic'
      'pub:Publish a message'
      'bench:MQTT benchmark'
      'check:Check for updates'
      'ls:List connections'
      'init:Initialize configuration'
    )
    _describe -t commands 'mqttx command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      pub)
        _arguments -s -S \
          $common_flags \
          {-t,--topic}'=[topic to publish to]:topic' \
          {-m,--message}'=[message to publish]:message' \
          {-q,--qos}'=[QoS level]:qos:(0 1 2)' \
          {-r,--retain}'[retain message]' \
          {-d,--dup}'[mark as duplicate]' \
          {-M,--multiline}'[read message from stdin]' && ret=0
        ;;
      sub)
        _arguments -s -S \
          $common_flags \
          {-t,--topic}'=[topic to subscribe to]:topic' \
          {-q,--qos}'=[QoS level]:qos:(0 1 2)' \
          '--verbose[print received packets verbosely]' && ret=0
        ;;
      conn)
        _arguments -s -S $common_flags && ret=0
        ;;
      bench)
        local -a bench_cmds=(
          'pub:Benchmark publishing'
          'sub:Benchmark subscribing'
          'conn:Benchmark connections'
        )
        _describe -t commands 'bench subcommand' bench_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
