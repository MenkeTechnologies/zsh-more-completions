#compdef conda-verify
# Documentation: https://github.com/conda/conda-verify/blob/main/README.md
# conda-verify: verify conda recipes and packages

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--ignore=[ignore specific checks, comma-separated]:checks:' \
  '--exit[raise an exception after the first error is found]' \
  '*:path:_files' && ret=0

return ret
