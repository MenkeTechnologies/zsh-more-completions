#compdef upcrun

# upcrun: Berkeley UPC program launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-v[verbose]' \
  '-n[threads]:n:' \
  '-N[nodes]:n:' \
  '-bind-threads[bind threads to cores]' \
  '-stack-size=[per-thread stack size]:size:' \
  '-shared-heap=[per-thread shared heap]:size:' \
  '-localhost[run all threads on localhost]' \
  '-E[export env var]:var:' \
  '-hostfile=[hostfile]:file:_files' \
  '*:program:_command_names' && ret=0
return ret
