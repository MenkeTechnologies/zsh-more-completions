#compdef upcrun
# Documentation: https://upc.lbl.gov/docs/user/upcrun.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# upcrun: Berkeley UPC program launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '(- *)-help[show help]' \
  '-help-gasnet[show GASNet documentation]' \
  '(- *)-version[show version]' \
  '-i[display executable information]' \
  '-info[display executable information]' \
  '-noinfo[do not display executable information]' \
  '-n+[number of UPC threads]:n:' \
  '-np+[number of UPC threads]:n:' \
  '-N+[number of compute nodes]:n:' \
  '-nodes+[number of compute nodes]:n:' \
  '-c+[UPC threads per node]:n:' \
  '-cpus-per-node+[UPC threads per node]:n:' \
  '-p+[pthread count per process]:n:' \
  '-pthreads+[pthread count per process]:n:' \
  '-shared-heap+[per-thread shared memory]:size:' \
  '-pshm-width+[shared-memory supernode limit]:n:' \
  '-bind-threads[pin UPC threads to processors]' \
  '-polite-sync[yield during lock/barrier waits]' \
  '-trace[enable tracing]' \
  '-notrace[disable tracing]' \
  '-traceall[enable all event tracing]' \
  '-tracefile+[trace output destination]:file:_files' \
  '-freeze[freeze thread before main()]' \
  '-freeze=[freeze specific thread before main()]:threadid:' \
  '-freeze-early[freeze during runtime startup]' \
  '-freeze-early=[freeze during runtime startup on nodeid]:nodeid:' \
  '-freeze-earlier[freeze during GASNet initialization]' \
  '-freeze-on-error[freeze on crashes]' \
  '-nofreeze-on-error[do not freeze on crashes]' \
  '-abort[generate core files on errors]' \
  '-noabort[do not generate core files on errors]' \
  '-backtrace[enable stack backtraces]' \
  '-nobacktrace[disable stack backtraces]' \
  '-backtrace-type=[backtrace mechanisms]:list:' \
  '-conf=[alternate configuration file]:file:_files' \
  '-norc[skip configuration file reading]' \
  '-encode-args[safely encode arguments]' \
  '-encode-env[safely encode environment]' \
  '-encode[safely encode arguments and environment]' \
  '-q[suppress initialization messages]' \
  '-quiet[suppress initialization messages]' \
  '-noquiet[do not suppress initialization messages]' \
  '-v[verbose]' \
  '-verbose[verbose]' \
  '-noverbose[no verbose]' \
  '-t[show commands without executing]' \
  '-show[show commands without executing]' \
  '-noshow[do not show commands]' \
  '*:program:_command_names' && ret=0
return ret
