#compdef aws-network-policy-agent
# _aws-network-policy-agent — AWS VPC CNI Network Policy enforcement agent (eBPF; runs in aws-node DaemonSet)
# upstream: https://github.com/aws/aws-network-policy-agent
# Flags from main.go + pkg/config/{controller,runtime}_config.go on tip.

_aws-network-policy-agent() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[log level]:level:(debug info warn error fatal panic)' \
        '--log-file=[log file destination]:file:_files' \
        '--log-file-max-size=[max log file size before rotation]:n:' \
        '--log-file-max-backups=[max rotated log files retained]:n:' \
        '--max-concurrent-reconciles=[max concurrent reconciles per controller]:n:' \
        '--enable-policy-event-logs[collect + log policy decision events]' \
        '--enable-cloudwatch-logs[stream policy decision logs to CloudWatch (requires --enable-policy-event-logs)]' \
        '--enable-ipv6[run in IPv6 mode]' \
        '--enable-network-policy[initialize BPF maps and start reconciler]' \
        '--enable-profiling[enable pprof profiling]' \
        '--conntrack-cache-cleanup-period=[conntrack cache cleanup period (seconds)]:s:' \
        '--conntrack-cache-table-size=[conntrack cache table size]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--metrics-bind-addr=[metrics endpoint bind address]:addr:' \
        '--health-probe-bind-addr=[probe endpoint bind address]:addr:' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap log level that triggers a stacktrace]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '-v[klog verbosity level]:n:'
}

_aws-network-policy-agent "$@"
