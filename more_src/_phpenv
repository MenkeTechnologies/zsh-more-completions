#compdef phpenv
# PHP version manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'commands:list available commands'
  'global:set or show global PHP version'
  'local:set or show local PHP version'
  'shell:set or show shell-specific PHP version'
  'install:install a PHP version'
  'uninstall:uninstall a PHP version'
  'rehash:rehash phpenv shims'
  'version:show current PHP version'
  'versions:list installed PHP versions'
  'which:show full path of command'
  'whence:list versions containing command'
)

_arguments -s -S \
  '1:command:->command' \
  '--help[show help]' \
  '--version[show version]' \
  '*:argument:' && ret=0

case $state in
  (command)
    _describe -t commands 'phpenv command' commands && ret=0
    ;;
esac

return ret
