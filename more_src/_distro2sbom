#compdef distro2sbom
# Documentation: https://pypi.org/project/distro2sbom/
# generate an SBOM for an installed Linux/Windows distribution

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--distro=[distribution type]:distro:(rpm deb windows auto)' \
  '(-i --input-file)'{-i,--input-file}'=[input file]:file:_files' \
  '(-n --name)'{-n,--name}'=[name of distribution]:name:' \
  '(-r --release)'{-r,--release}'=[release of distribution]:release:' \
  '(-p --package)'{-p,--package}'=[package name]:package:' \
  '-s[include source files]' \
  '--root=[root directory]:directory:_files -/' \
  '--distro-namespace=[distribution namespace]:namespace:' \
  '--product-type=[product type]:type:(application framework library container operating-system device firmware file)' \
  '--product-name=[product name]:name:' \
  '--product-version=[product version]:version:' \
  '--product-author=[product author]:author:' \
  '-d[show debug information]' \
  '--sbom=[SBOM type]:type:(spdx cyclonedx)' \
  '--format=[output format]:format:(tag json yaml)' \
  '(-o --output-file)'{-o,--output-file}'=[output file]:file:_files' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
