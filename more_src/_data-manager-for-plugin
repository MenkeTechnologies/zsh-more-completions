#compdef data-manager-for-plugin datamgr
# _data-manager-for-plugin — Velero vSphere plugin data-manager controller (cobra; uploads/downloads snapshots between FCD and S3-compatible object storage)
# upstream: https://github.com/vmware-tanzu/velero-plugin-for-vsphere
# Subcommands from pkg/cmd/datamgr/datamgr.go on tip; server flags from pkg/cmd/datamgr/cli/server/server.go.

_data-manager-for-plugin() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                install:'install the data-manager into a cluster'
                server:'run the data-manager controller'
            )
            _describe -t commands 'data-manager-for-plugin subcommand' subs
            ;;
        args)
            case $line[1] in
                server)
                    _arguments \
                        '--client-burst=[max k8s API requests in a short period]:n:' \
                        '--profiler-address=[pprof profiler address]:addr:' \
                        '--vcenter-address=[vCenter address (with --use-secret=false)]:host:' \
                        '--vcenter-port=[vCenter port (with --use-secret=false)]:port:' \
                        '--vcenter-user=[vCenter username (with --use-secret=false)]:user:' \
                        '--cluster-id=[Kubernetes cluster id (with --use-secret=false)]:id:' \
                        '--insecure-Flag=[skip vCenter TLS verification (with --use-secret=false)]:bool:(true false)' \
                        '--use-secret=[retrieve vCenter configuration from a Secret]:bool:(true false)'
                    ;;
            esac
            ;;
    esac
}

_data-manager-for-plugin "$@"
