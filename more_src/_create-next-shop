#compdef create-next-shop
# Documentation: https://www.npmjs.com/package/create-saleor-app
# Reference accessed: 2026-05-24
# Verified: npx create-next-shop --help.

# Zsh completion for create-next-shop - Saleor Next.js shop scaffolder (create-saleor-app bin)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-V --version)'{-V,--version}'[show version]' \
  '--use-npm[use npm as package manager]' \
  '(-e --example)'{-e,--example=}'[example name or GitHub URL]:example:' \
  '--example-path=[path within example repo]:path:' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':project directory:_directories' && ret=0

return ret
