#compdef mstats
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss118.html
# KAPPA: combine a stack of NDFs into a single NDF using statistics

local ret=1

_arguments -s \
  'CLIP=[standard-deviation threshold for clipping]:clip' \
  'COMP=[NDF array component to analyse]:comp:(Data Quality Variance Error)' \
  'ESTIMATOR=[statistical estimator method]:estimator' \
  'IN=[input NDFs]:NDF:_files' \
  'OUT=[output NDF]:NDF:_files' \
  'POS=[position for single-pixel mode]:pos' \
  'SINGLE=[single-pixel or array mode]:single:(TRUE FALSE)' \
  'TITLE=[title for the output NDF]:title' \
  'TRIM=[intersection vs union of bounds]:trim:(TRUE FALSE)' \
  'VARIANCE=[use variance arrays as weights]:variance:(TRUE FALSE)' \
  'WLIM=[minimum good-pixel threshold]:wlim' \
  '*:NDF:_files' && ret=0

return ret
