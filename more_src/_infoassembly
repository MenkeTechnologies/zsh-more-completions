#compdef infoassembly
# EMBOSS: display information about assemblies

local ret=1

_arguments -s -S \
  '-assembly=[input assembly of sequence reads]:assembly:_files' \
  '-outassembly=[output assembly of sequence reads]:outassembly:_files' \
  '-gcbiasmetricsoutfile=[output file for GC bias metrics]:outfile:_files' \
  '-qualvaluesdistoutfile=[output file for quality value distribution]:outfile:_files' \
  '-refsequence=[reference sequences present in the assembly]:sequence:_files' \
  '-windowsize=[size of genomic windows for binning reads]:num' \
  '-bisulfite[assume reads underwent bisulfite treatment]' \
  '-auto[turn off prompts]' \
  '-stdout[write first file to standard output]' \
  '-filter[read from stdin, write to stdout]' \
  '-options[prompt for standard and additional values]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-die[report dying program messages]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '-version[report version number and exit]' && ret=0

return ret
