#compdef libinput-quirks

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list quirks affecting a device'
  'validate:validate quirks files'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--data-dir=[data directory]:dir:_files -/' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'libinput-quirks command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (list)
        _arguments \
          '*:device:_files -g "/dev/input/event*"' && ret=0 ;;
      (validate)
        _arguments \
          '--data-dir=[data directory]:dir:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
