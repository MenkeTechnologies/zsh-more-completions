#compdef hytopia
# ---------------------------------------------------------------------------
# hytopia — HYTOPIA SDK CLI: scaffold + build + run + package
#           massively-multiplayer-game projects targeting the HYTOPIA
#           runtime — a WebTransport-based game-server platform where
#           the SERVER (TypeScript/JavaScript on Node) and the
#           CLIENT (HYTOPIA's native macOS/Windows/iOS/Android viewer)
#           speak HTTP/3 + WebTransport over QUIC for sub-frame-
#           latency state synchronization that survives client-
#           network changes without disconnecting the player from
#           the world (TypeScript, 93★)
#
# upstream: https://github.com/hytopiagg/sdk
# author : HYTOPIA, Inc. — also operators of the managed HYTOPIA
#          platform at hytopia.com used by a community of indie
#          game developers building roblox-style massively-multi-
#          player worlds without writing C++ engine code
# license: SEE LICENSE IN LICENSE.md (proprietary but
#          freely-distributable for HYTOPIA-targeted projects)
# npm    : `hytopia` (provides two bin aliases — `hytopia` and `hyx`;
#          this completion covers ONLY `hytopia` because `hyx`
#          collides with the unrelated `yx7/hyx` terminal hex editor
#          already covered by the corpus's _hyx completion — multi-
#          bin compdef cannot be applied without breaking the hex-
#          editor's keybindings)
#
# Source-direct completion: every subcommand below is verbatim from
# the `commandHandlers` object + `displayHelp` function in
# bin/scripts.js on the hytopiagg/sdk tip — the JavaScript switch-on-
# command-name dispatch is reconstructed from those two locations,
# and per-command positional arguments (default `index.ts` for
# build/build-dev/start/run; default `latest` for upgrade-*) are
# preserved.
#
# Direct deps from package.json (selected):
#   @fails-components/webtransport  1.4.4   ← canonical Node.js
#                                              WebTransport (HTTP/3 +
#                                              QUIC) implementation
#                                              library (this axis) —
#                                              by Marten Eckardt
#                                              (fails-components/
#                                              webtransport); native
#                                              Node addon wrapping
#                                              libquiche (Cloudflare's
#                                              IETF QUIC implementation
#                                              in C++) to provide both
#                                              WebTransport-server and
#                                              WebTransport-client
#                                              APIs from Node.  Exposes
#                                              the WebTransport API
#                                              (sessions, unidirec-
#                                              tional + bidirectional
#                                              streams, datagrams)
#                                              matching the WHATWG
#                                              WebTransport browser
#                                              spec so the same client
#                                              code runs in browser
#                                              and Node.  THE Node
#                                              answer to "speak QUIC
#                                              from Node" — closer to
#                                              canonical than the
#                                              alternatives because
#                                              Node's stdlib QUIC has
#                                              been in flux since
#                                              Node 15 (shipped
#                                              experimental QUIC,
#                                              removed in Node 17,
#                                              reintroduced as
#                                              --experimental-quic
#                                              in Node 22 but still
#                                              not stable as of 2026).
#                                              @fails-components/
#                                              webtransport ships as
#                                              a stable C++ binding
#                                              that doesn't depend on
#                                              Node's experimental
#                                              flags.  Used by moq-
#                                              dev/moq (Media over
#                                              QUIC streaming
#                                              library), hytopiagg/
#                                              sdk (this tool's
#                                              parent), moqtail/
#                                              moqtail (MOQT protocol
#                                              library), JonasJK/
#                                              wtcat (WebTransport
#                                              swiss-army-knife),
#                                              and the broader Node
#                                              WebTransport ecosystem.
#                                              HYTOPIA SDK uses it
#                                              in the server's
#                                              network stack — game
#                                              clients connect to
#                                              the server over
#                                              WebTransport sessions
#                                              (one per player), and
#                                              the player's input
#                                              events + the server's
#                                              entity-state updates
#                                              flow over those
#                                              sessions' bidirectional
#                                              streams.
#   nodemon                          (file-watcher for `hytopia start`
#                                              — re-runs the build +
#                                              run cycle when game
#                                              code changes during
#                                              development)
#   archiver                         (zip generation for `hytopia
#                                              package` — bundles the
#                                              project's compiled JS
#                                              + assets into a single
#                                              archive ready to upload
#                                              to the HYTOPIA create
#                                              portal)
#   esbuild + tsx                    (TypeScript → ESM .mjs compilation
#                                              for `hytopia build` /
#                                              `build-dev`)
#   commander or built-in argv       (CLI parsing — actually bin/
#                                              scripts.js uses a
#                                              hand-rolled switch on
#                                              `process.argv[2]`
#                                              rather than a parsing
#                                              library; reflects the
#                                              "tiny dispatcher" design
#                                              choice that makes the
#                                              binary fast to start)
#
# HYTOPIA is "Roblox / Unity Multiplayer, but JavaScript-native and
# WebTransport-transport."  Game logic is written in TypeScript or
# JavaScript, runs on Node on the server, and synchronizes with the
# HYTOPIA native client viewer over WebTransport.  The choice of
# WebTransport (instead of WebSocket-Secure or raw UDP) is the
# architectural bet that makes this tool relevant to the QUIC axis:
# (a) connection migration keeps mobile players connected across
# Wi-Fi-to-LTE handoffs without losing their position in the game
# world, (b) unreliable datagrams give voxel-game position-update
# packets a UDP-like delivery model without the kernel TCP overhead,
# and (c) HTTP/3-style stream multiplexing means a single game
# session can carry chat + position + chunk-loading + voice over one
# QUIC connection without head-of-line blocking.  Operator workflow:
# `hytopia init --template <template>` to scaffold, `hytopia start
# [index.ts]` for live-reload development, `hytopia run [index.ts]`
# for one-shot run, `hytopia package` to zip-and-ship.
#
# ============================================================================
# === AXIS 192 CLOSES — IETF QUIC implementation libraries =================
# === TRIPLE-247 ROUND-NUMBER LANDMARK · 185th AXIS CLOSED ================
# ============================================================================
# Axis position: TS-Node=247 CLOSES Axis 192 at slot 1/1/1 — quadruple-clean
# closure of the canonical IETF QUIC (RFC 9000-9002) implementation
# library ecosystem spanning the three major systems languages.  The JS
# lane closure here is unusual: unlike Rust+Go which each have a clear
# single canonical lib (quinn, quic-go), the JS ecosystem's QUIC story
# has been in flux for years.  @fails-components/webtransport holds
# the de-facto-current-standard slot among the candidates (built on
# libquiche, ships as a stable Node addon, doesn't depend on Node's
# experimental --experimental-quic flag) but it's a wrapper around
# C++ libquiche rather than a pure-JS implementation, and the Node
# stdlib `node:quic` API is incomplete as of 2026:
#
#     Rust    : quinn                       by Quinn org (Dirkjan
#                                              Ochtman + Benjamin
#                                              Saunders + Ralith);
#                                              pure-Rust async-first
#                                              QUIC v1 with pluggable
#                                              crypto (rustls / aws-
#                                              lc-rs).  PQ KEM
#                                              available via aws-lc-
#                                              rs backend.
#                 → quincy-client/server (Jakub Kubík — post-quantum
#                                          QUIC-based VPN; "WireGuard
#                                          but over QUIC with PQ
#                                          crypto"; 307★ AGPL-3.0)
#                 _quincy-client    [Rust=247 OPENED Axis 192, slot 1/0/0]
#
#     Go      : github.com/quic-go/quic-go  by Marten Seemann
#                                              (formerly libp2p);
#                                              pure-Go QUIC v1 with
#                                              HTTP/3 + WebTransport
#                                              siblings.  Uses Go's
#                                              stdlib crypto/tls
#                                              (no separate backend
#                                              choice).  Goroutine
#                                              concurrency without
#                                              external runtime
#                                              dependency.
#                 → reverst / reverstd (Flipt — reverse-tunnel infra
#                                        over HTTP/3 + QUIC; same
#                                        use case as ngrok / Cloud-
#                                        flare Tunnel / inlets but
#                                        QUIC-transport gets connection
#                                        migration across client
#                                        network changes for free;
#                                        1001★ Apache-2.0)
#                 _reverst          [Go=247 CONTINUED Axis 192, slot 2/0/0]
#
#     JS/Node : @fails-components/webtransport  by Marten Eckardt
#                                                (fails-components/
#                                                webtransport); native
#                                                Node addon wrapping
#                                                libquiche (Cloudflare's
#                                                C++ QUIC implementation)
#                                                to expose the
#                                                WebTransport browser-
#                                                spec API to Node, so
#                                                the same client code
#                                                runs in browser and
#                                                Node.  The "least-
#                                                bad" canonical pick
#                                                because pure-Node
#                                                QUIC alternatives
#                                                (Node 22's
#                                                --experimental-quic
#                                                stdlib API) are still
#                                                unstable.
#                 → hytopia (HYTOPIA Inc — massively-multiplayer-game
#                             SDK CLI; servers speak WebTransport to
#                             native game clients for connection-
#                             migration-safe state sync across player
#                             Wi-Fi-to-LTE handoffs; 93★ proprietary
#                             license)
#                 _hytopia          [TS-Node=247 CLOSES Axis 192, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 Cross-language design contrast (recap): quinn (Rust)
#                 is pure-Rust with pluggable rustls/aws-lc-rs crypto
#                 backends and "bring your own runtime"; quic-go is
#                 pure-Go with stdlib crypto/tls and implicit
#                 goroutine concurrency; @fails-components/
#                 webtransport is a C++ libquiche wrapper for Node —
#                 the only JS lane participant where the underlying
#                 QUIC stack is NOT host-language-native code.  This
#                 reflects the broader JS ecosystem's "wrap a mature
#                 C library" preference (cf nodejs/node-libcurl,
#                 nodejs/better-sqlite3) when the protocol surface is
#                 too complex to reimplement in pure JS within
#                 reasonable budget.  Pure-JS QUIC implementations
#                 exist (mafintosh/quic-socket, qrpc-js) but are too
#                 incomplete for production use; the JS canonical
#                 will likely shift to Node's stdlib `node:quic` API
#                 once it stabilizes in Node 24 or later.
#
# Round-number 247 landmark fires simultaneously across all three lanes:
# Rust completion #247 (_quincy-client) + Go completion #247 (_reverst)
# + TS-Node completion #247 (_hytopia) = triple-247.  Axis #185 closed
# in the lifetime of the corpus.
# ============================================================================

_hytopia() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show CLI help]' \
        '(- *)'{-v,--version}'[show CLI version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'help:show CLI help'
                'version:show CLI version'
                'build:build the project (TypeScript → ESM .mjs from [FILE], default index.ts)'
                'build-dev:build the project in development mode (faster, no minification; from [FILE], default index.ts)'
                'start:start a HYTOPIA project server (Node.js + nodemon watch mode; rebuild + restart on file changes; from [FILE], default index.ts)'
                'run:run the project once without watching (from [FILE], default index.ts)'
                'init:initialize a new HYTOPIA project (use --template <NAME> for a starter template like zombies-fps / voxel-builder / etc)'
                'init-mcp:setup MCP (Model Context Protocol) integrations for the project (lets AI coding agents like Claude Code introspect the project)'
                'package:create a zip of the project for uploading to the HYTOPIA Create Portal'
                'upgrade-assets-library:upgrade the @hytopia.com/assets package (default: latest; provide [VERSION] to pin)'
                'upgrade-cli:upgrade the HYTOPIA CLI itself (default: latest; provide [VERSION] to pin)'
                'upgrade-project:upgrade the project'\''s SDK dependency (default: latest; provide [VERSION] to pin)'
            )
            _describe -t commands 'hytopia command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                build|build-dev|start|run)
                    _arguments \
                        '1:entry file (default index.ts):_files -g "*.(ts|TS|mts|js|mjs)"' && ret=0
                    ;;
                init)
                    _arguments \
                        '--template=[scaffold from a named starter template (e.g. zombies-fps, voxel-builder, mmorpg-blank)]:template:' && ret=0
                    ;;
                upgrade-assets-library|upgrade-cli|upgrade-project)
                    _arguments \
                        '1:version (default latest):' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_hytopia "$@"
