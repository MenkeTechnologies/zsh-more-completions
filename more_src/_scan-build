#compdef scan-build
# _scan-build — Clang static analyzer driver; wraps a build command, intercepts compiler invocations, runs the analyzer
# upstream: https://github.com/llvm/llvm-project/tree/main/clang/tools/scan-build

_scan-build() {
    _arguments \
        '-analyze-headers[also analyze headers]' \
        '-o+[output dir]:dir:_files -/' \
        '-h[show help]' \
        '--help[show help]' \
        '-k[keep going after errors]' \
        '--keep-going[keep going after errors]' \
        '--keep-empty[do not delete empty reports]' \
        '-plist[output plist files]' \
        '-plist-html[output plist + html]' \
        '-no-failure-reports[do not write failure reports]' \
        '-stats[print stats]' \
        '-maxloop+[max loop iterations]:n:' \
        '-no-condition-variables[disable condition vars]' \
        '-internal-stats[print internal stats]' \
        '-V[view results immediately]' \
        '--view[view results immediately]' \
        '-status-bugs[exit non-zero if bugs found]' \
        '--status-bugs[exit non-zero if bugs found]' \
        '-store+[store model]:model:(region basic)' \
        '-constraints+[constraint model]:model:(range basic)' \
        '-analyzer-config+[analyzer config]:key=val:' \
        '-enable-checker+[enable checker]:name:' \
        '-disable-checker+[disable checker]:name:' \
        '--use-cc+[CC compiler]:cc:_command_names -e' \
        '--use-c+++[CXX compiler]:cxx:_command_names -e' \
        '--use-analyzer+[analyzer]:path:_files' \
        '-v[verbose]' \
        '*::build command:_command_names -e'
}

_scan-build "$@"
