#compdef megaglest
# Documentation: https://wiki.megaglest.org/Command_line_options
# Reference accessed: 2026-05-16

# MegaGlest: cross-platform 3D real-time strategy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--server[run as server]' \
  '--client=[connect to server]:host:_hosts' \
  '--data-path=[data path]:dir:_files -/' \
  '--ini-path=[ini path]:dir:_files -/' \
  '--font-base-size=[base font size]:n:' \
  '--use-language=[language]:lang:' \
  '--list-maps[list maps]' \
  '--list-tilesets[list tilesets]' \
  '--list-techtrees[list techtrees]' \
  '--list-tutorials[list tutorials]' \
  '--list-scenarios[list scenarios]' \
  '--load-scenario=[load scenario]:name:' \
  '--load-tutorial=[load tutorial]:name:' \
  '--use-port=[server port]:port:' \
  '--load-saved-game=[load saved game]:file:_files' \
  '--full-screen[fullscreen]' \
  '--window[windowed]' \
  '--auto-test[run auto-test]' \
  '--show-cpu-frequency[show CPU frequency]' \
  '--validate-techtrees[validate techtrees]' \
  '--validate-factions[validate factions]' \
  '--no-sound[disable sound]' \
  '*::megaglest args:_files' && ret=0
return ret
