# MegaGlest: cross-platform 3D real-time strategy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--autostart-lastgame[auto-start using last game settings]' \
  '--load-saved-game=[load last/named save]:name:' \
  '--auto-test=[auto-test mode: secs,scenario,no-screenshots]:spec:' \
  '--connect=[auto-connect host x port y]:host\:port:' \
  '--connecthost=[auto-connect to host x]:host:_hosts' \
  '--starthost[host a server]' \
  '--headless-server-mode=[run headless masterserver mode]:spec:' \
  '--headless-server-status[show masterserver status and exit]' \
  '--server-title=[set server title]:title:' \
  '--use-ports=[server ports x,y,z]:ports:' \
  '--load-scenario=[load scenario by name]:scenario:' \
  '--load-mod=[load mod by pathname]:path:_files -/' \
  '--preview-map=[preview map: Map,Tileset]:spec:' \
  '--opengl-info[show OpenGL driver info and exit]' \
  '--sdl-info[show SDL driver info and exit]' \
  '--lua-info[show Lua info and exit]' \
  '--lua-debug[enable Lua debug logging]' \
  '--curl-info[show libcurl info and exit]' \
  '--xerces-info[show Xerces XML info and exit]' \
  '--validate-techtrees=[validate techtrees]:spec:' \
  '--validate-factions=[validate factions]:spec:' \
  '--validate-scenario=[validate scenario]:name:' \
  '--validate-tileset=[validate tileset]:name:' \
  '--translate-techtrees=[translate techtrees]:spec:' \
  '--list-maps[list maps and exit]' \
  '--list-techtrees[list techtrees and exit]' \
  '--list-scenarios[list scenarios and exit]' \
  '--list-tilesets[list tilesets and exit]' \
  '--list-tutorials[list tutorials and exit]' \
  '--data-path=[override data path]:dir:_files -/' \
  '--ini-path=[override ini path]:dir:_files -/' \
  '--log-path=[override log path]:dir:_files -/' \
  '--font-path=[override font path]:dir:_files -/' \
  '--show-ini-settings[show ini settings and exit]' \
  '--convert-models=[convert g3d models]:spec:' \
  '--use-language=[use language]:lang:' \
  '--show-map-crc=[show CRC for a map]:name:' \
  '--show-tileset-crc=[show CRC for a tileset]:name:' \
  '--show-techtree-crc=[show CRC for a techtree]:name:' \
  '--show-scenario-crc=[show CRC for a scenario]:name:' \
  '--show-path-crc=[show CRC for a path]:spec:' \
  '--disable-backtrace[disable backtrace on crash]' \
  '--disable-sigsegv-handler[disable SIGSEGV handler]' \
  '--disable-vbo[disable VBO usage]' \
  '--disable-vertex-interpolation[disable vertex interpolation]' \
  '--disable-sound[disable sound]' \
  '--enable-legacyfonts[enable legacy fonts]' \
  '--resolution=[force display resolution]:WxH:' \
  '--colorbits=[force color bits]:bits:' \
  '--depthbits=[force depth bits]:bits:' \
  '--fullscreen=[fullscreen on/off]:bool:(0 1 true false)' \
  '--set-gamma=[set gamma]:value:' \
  '--use-font=[use specific font]:font:' \
  '--font-basesize=[font base size]:n:' \
  '--disable-videos[disable in-game videos]' \
  '--disable-opengl-checks[skip OpenGL capability checks]' \
  '--disable-streflop-checks[skip streflop capability checks]' \
  '--debug-network-packets[debug network packets]' \
  '--debug-network-packet-sizes[debug network packet sizes]' \
  '--debug-network-packet-stats[debug network packet stats]' \
  '--enable-new-protocol[enable new network protocol]' \
  '--create-data-archives=[create data archives]:spec:' \
  '--steam[Steam mode]' \
  '--steam-debug[Steam debug mode]' \
  '--steam-reset-stats[reset Steam stats]' \
  '--verbose[verbose output]' \
  '*::extra args:_files' && ret=0
return ret
