#compdef megaglest megaglest_editor megaglest_g3dviewer
# Documentation: https://github.com/MegaGlest/megaglest-source/blob/develop/source/shared_lib/include/platform/sdl/platform_main.h
# Reference accessed: 2026-05-16
# Verified: shared_lib/include/platform/sdl/platform_main.h GAME_ARGS[] array
# Removed from prior file: --server (real is --starthost), --client= (real is
# --connect/--connecthost), --font-base-size= (real is --font-basesize, no
