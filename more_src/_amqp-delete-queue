#compdef amqp-delete-queue
# Documentation: https://manpages.debian.org/unstable/amqp-tools/amqp-delete-queue.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--usage[show usage]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-S --server)'{-S,--server}'+[broker host[:port]]:server:_hosts' \
  '--port=[broker port]:port:' \
  '(-u --url)'{-u,--url}'+[broker URL]:url:' \
  '--vhost=[virtual host]:vhost:' \
  '--username=[username]:user:' \
  '--password=[password]:pw:' \
  '--ssl[use TLS]' \
  '--cacert=[CA certificate]:file:_files' \
  '--cert=[client cert]:file:_files' \
  '--key=[client key]:file:_files' \
  '--verify[verify peer]' \
  '--heartbeat=[heartbeat seconds]:sec:' \
  '(-q --queue)'{-q,--queue}'+[queue name]:name:' \
  '(-i --if-unused)'{-i,--if-unused}'[only delete if unused]' \
  '(-e --if-empty)'{-e,--if-empty}'[only delete if empty]' && ret=0

return ret
