#compdef ctest-to
# Documentation: https://cmake-format.readthedocs.io/en/latest/ctest-to.html
# cmakelang utility to convert ctest output into JSON or XML (JUnit) format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--log-level=[set logging verbosity level]:level:(debug info warning error)' \
  '(--json --xml)--json[output results in JSON format]' \
  '(--json --xml)--xml[output results in XML format]' \
  '*:directory:_files -/' && ret=0

return ret
