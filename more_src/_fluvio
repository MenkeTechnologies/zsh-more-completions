#compdef fluvio

# Zsh completion for fluvio (distributed streaming platform)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'produce:write messages to a topic'
      'consume:read messages from a topic'
      'topic:manage topics'
      'partition:manage partitions'
      'profile:manage connection profiles'
      'cluster:manage Fluvio cluster'
      'install:install Fluvio plugins'
      'update:update Fluvio CLI'
      'version:show version'
      'completions:generate shell completions'
      'connector:manage connectors'
      'smartmodule:manage SmartModules'
      'table-format:manage table display formats'
      'hub:manage Fluvio Hub'
    )
    _describe -t commands 'fluvio command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (produce)
        _arguments \
          '(-f --file)'{-f,--file}'[file to produce]:file:_files' \
          '--key[message key]:key' \
          '--key-separator[key separator]:separator' \
          '--compression[compression]:type:(none gzip snappy lz4 zstd)' \
          '--raw[send raw data]' \
          '--delivery-semantic[delivery semantic]:semantic:(at-most-once at-least-once)' \
          '1:topic' && ret=0
        ;;
      (consume)
        _arguments \
          '(-B --beginning)'{-B,--beginning}'[start from beginning]' \
          '(-d --disable-continuous)'{-d,--disable-continuous}'[disable continuous mode]' \
          '--end-offset[end offset]:offset' \
          '(-o --offset)'{-o,--offset}'[start offset]:offset' \
          '(-p --partition)'{-p,--partition}'[partition]:partition' \
          '--key-value[print key with value]' \
          '--format[output format]:format' \
          '--output[output type]:type:(json text full raw table dynamic)' \
          '--smartmodule[apply SmartModule]:name' \
          '--filter[filter SmartModule]:name' \
          '--map[map SmartModule]:name' \
          '--aggregate[aggregate SmartModule]:name' \
          '1:topic' && ret=0
        ;;
      (topic)
        local -a subcmds=(
          'create:create a topic'
          'delete:delete a topic'
          'describe:describe a topic'
          'list:list topics'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
          (subargs)
            case ${words[1]} in
              (create)
                _arguments \
                  '--partitions[number of partitions]:count' \
                  '--replication[replication factor]:factor' \
                  '--retention-time[retention time]:duration' \
                  '--compression-type[compression]:type:(none gzip snappy lz4 zstd any)' \
                  '--dry-run[dry run]' \
                  '1:topic name' && ret=0
                ;;
              (delete)
                _arguments '1:topic name' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (cluster)
        local -a subcmds=(
          'start:start a cluster'
          'delete:delete a cluster'
          'check:run pre-flight checks'
          'status:show cluster status'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (profile)
        local -a subcmds=(
          'current:show current profile'
          'delete:delete a profile'
          'list:list profiles'
          'switch:switch to a profile'
          'sync:sync profiles from cluster'
          'export:export a profile'
          'add:add a profile'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (completions)
        _arguments '1:shell:(bash fish zsh powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
