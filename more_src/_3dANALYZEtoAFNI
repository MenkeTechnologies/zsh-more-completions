#compdef 3dANALYZEtoAFNI
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dANALYZEtoAFNI.html
# Convert ANALYZE-7.5 files to an AFNI dataset (deprecated)

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-OK[acknowledge program is deprecated]' \
  '-prefix[output dataset prefix]:prefix:' \
  '-view[set dataset view]:view:(orig acpc tlrc)' \
  '-TR[create 3D+time dataset with this TR]:tr:' \
  '-fbuc[make multi-volume data a functional bucket]' \
  '-abuc[make multi-volume data an anatomical bucket]' \
  '-geomparent[use geometry from another dataset .HEAD]:dataset:_files' \
  '-orient[3D volume orientation code]:orient:' \
  '-zorigin[center of first slice (mm)]:dz:' \
  '*:ANALYZE file:_files' && ret=0

return ret
