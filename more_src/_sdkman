#compdef sdk

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'install:install a SDK version'
      'uninstall:uninstall a SDK version'
      'list:list available SDK versions'
      'use:use a specific SDK version in current shell'
      'config:edit SDKMAN configuration'
      'default:set a default SDK version'
      'home:show SDK installation folder'
      'env:manage project-specific SDK versions'
      'current:show current SDK version'
      'upgrade:upgrade installed SDK to latest'
      'version:show SDKMAN version'
      'broadcast:show broadcast messages'
      'help:show help'
      'offline:manage offline mode'
      'selfupdate:update SDKMAN itself'
      'update:refresh candidate list'
      'flush:clear local caches'
    )
    _describe -t commands 'sdk command' commands && ret=0
    ;;
  args)
    local -a candidates=(java groovy scala kotlin gradle maven ant sbt spark spring)
    case $line[1] in
      install|uninstall|list|use|default|home|current|upgrade)
        _arguments '1:candidate:($candidates)' '2:version' && ret=0
        ;;
      env)
        _arguments '1:action:(init install clear)' && ret=0
        ;;
      offline)
        _arguments '1:mode:(enable disable)' && ret=0
        ;;
      flush)
        _arguments '1:target:(archives temp broadcast)' && ret=0
        ;;
    esac
    ;;
esac

return ret
