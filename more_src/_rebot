#compdef rebot

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d+[output directory]:directory:_directories' \
  '--outputdir=[output directory]:directory:_directories' \
  '-o+[output file]:output file:_files -g "*.xml"' \
  '--output=[output file]:output file:_files -g "*.xml"' \
  '-l+[log file]:log file:_files -g "*.html"' \
  '--log=[log file]:log file:_files -g "*.html"' \
  '-r+[report file]:report file:_files -g "*.html"' \
  '--report=[report file]:report file:_files -g "*.html"' \
  '-x+[xunit file]:xunit file:_files -g "*.xml"' \
  '--xunit=[xunit file]:xunit file:_files -g "*.xml"' \
  '-T[add timestamp to output files]' \
  '--timestampoutputs[add timestamp to output files]' \
  '--merge[merge outputs]' \
  '-N+[set suite name]:name' \
  '--name=[set suite name]:name' \
  '-D+[set suite documentation]:documentation' \
  '--doc=[set suite documentation]:documentation' \
  '-M+[set metadata]:name\:value' \
  '--metadata=[set metadata]:name\:value' \
  '-G+[set tag]:tag' \
  '--settag=[set tag]:tag' \
  '-s+[select suite]:suite' \
  '--suite=[select suite]:suite' \
  '-t+[select test]:test' \
  '--test=[select test]:test' \
  '-i+[include by tag]:tag' \
  '--include=[include by tag]:tag' \
  '-e+[exclude by tag]:tag' \
  '--exclude=[exclude by tag]:tag' \
  '-L+[log level]:level:(TRACE DEBUG INFO WARN ERROR NONE)' \
  '--loglevel=[log level]:level:(TRACE DEBUG INFO WARN ERROR NONE)' \
  '--removekeywords=[remove keywords]:mode:(ALL PASSED NAME\:* TAG\:* FOR WHILE)' \
  '--flattenkeywords=[flatten keywords]:mode:(FOR WHILE ITERATION NAME\:* TAG\:*)' \
  '--starttime=[set start time]:time' \
  '--endtime=[set end time]:time' \
  '--nostatusrc[do not return failing status code]' \
  '--processemptysuite[process empty suites]' \
  '-C[console colors]:mode:(auto on off ansi)' \
  '--consolecolors=[console colors]:mode:(auto on off ansi)' \
  '*:output files:_files -g "*.xml"' && ret=0

return ret
