#compdef getcap
# Documentation: man getcap(8)
# Source: kernel.org libcap progs/getcap.c — display file capabilities (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-l[(deprecated) show -h]' \
    '-r[recursive]' \
    '-v[verbose]' \
    '-n[show namespace root id]' \
    '*:file:_files' \
    && ret=0

return ret
