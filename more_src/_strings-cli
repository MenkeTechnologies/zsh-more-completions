#compdef strings-cli
# _strings-cli — GNU binutils strings print strings of printable characters in files CLI alias (GNU team, C); custom argparse
# upstream: https://sourceware.org/binutils/

_strings-cli() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-a[scan whole file]' \
        '--all[scan whole file]' \
        '-d[show only initialized data]' \
        '--data[show only initialized data]' \
        '-f[show file name]' \
        '--print-file-name[show file name]' \
        '-n+[min len]:n:' \
        '--bytes=+[min len]:n:' \
        '-o[show offset]' \
        '-t+[radix]:r:(d o x)' \
        '--radix=+[radix]:r:(d o x)' \
        '-T+[bfd target]:str:' \
        '--target=+[bfd target]:str:' \
        '-e+[encoding]:e:(s S b l B L)' \
        '--encoding=+[encoding]:e:(s S b l B L)' \
        '-w[include whitespace]' \
        '--include-all-whitespace[include whitespace]' \
        '-U+[unicode display]:u:(default invalid locale hex escape highlight)' \
        '--unicode=+[unicode display]:u:(default invalid locale hex escape highlight)' \
        '-s[show file separator]' \
        '--output-separator=+[separator]:str:' \
        '*:files:_files'
}

_strings-cli "$@"
