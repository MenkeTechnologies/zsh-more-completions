#compdef genext2fs
# Documentation: https://manpages.ubuntu.com/manpages/questing/man8/genext2fs.8.html
# Generate an ext2 filesystem image as a normal user

local ret=1

_arguments -s -S \
  '(-x --starting-image)'{-x,--starting-image}'[use this image as a starting point]:image:_files' \
  '(-d --root)'{-d,--root}'[add directory and contents at a path]:directory:_files -/' \
  '(-D --devtable)'{-D,--devtable}'[use spec-file to add inodes]:spec-file:_files' \
  '(-a --tarball)'{-a,--tarball}'[add tarball contents at a path]:file:_files' \
  '(-b --size-in-blocks)'{-b,--size-in-blocks}'[size of image in blocks]:blocks:' \
  '(-B --block-size)'{-B,--block-size}'[filesystem block size in bytes]:bytes:' \
  '(-N --number-of-inodes)'{-N,--number-of-inodes}'[maximum number of inodes]:inodes:' \
  '(-L --volume-label)'{-L,--volume-label}'[set volume label]:name:' \
  '(-i --bytes-per-inode)'{-i,--bytes-per-inode}'[bytes per inode ratio]:ratio:' \
  '(-m --reserved-percentage)'{-m,--reserved-percentage}'[reserved blocks percentage]:percent:' \
  '(-o --creator-os)'{-o,--creator-os}'[creator OS field value]:name:' \
  '(-g --block-map)'{-g,--block-map}'[generate block map file for path]:path:_files' \
  '(-e --fill-value)'{-e,--fill-value}'[fill unallocated blocks with value]:value:' \
  '(-z --allow-holes)'{-z,--allow-holes}'[make files with holes]' \
  '(-f --faketime)'{-f,--faketime}'[use timestamp 0 for creation]' \
  '(-q --squash)'{-q,--squash}'[squash permissions and owners]' \
  '(-U --squash-uids)'{-U,--squash-uids}'[squash ownership of -d inodes]' \
  '(-P --squash-perms)'{-P,--squash-perms}'[squash permissions of -d inodes]' \
  '(-v --verbose)'{-v,--verbose}'[print resulting filesystem structure]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:image file:_files' && ret=0

return ret
