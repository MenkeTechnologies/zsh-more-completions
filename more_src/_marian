#compdef marian
# Documentation: https://marian-nmt.github.io/docs/cmd/marian/
# Marian neural machine translation training

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message and exit]' \
  '--version[print version number and exit]' \
  '(-c --config)'{-c,--config}'=[configuration file(s)]:file:_files' \
  '(-t --train-sets)'{-t,--train-sets}'=[paths to training corpora: source target]:files:_files' \
  '(-v --vocabs)'{-v,--vocabs}'=[paths to vocabulary files]:files:_files' \
  '(-m --model)'{-m,--model}'=[path prefix for model to be saved/resumed]:file:_files' \
  '--type=[model type]:type:(amun nematus s2s multi-s2s transformer)' \
  '--dim-emb=[size of embedding vector]:n' \
  '--dim-rnn=[size of rnn hidden state]:n' \
  '(-d --devices)'{-d,--devices}'=[GPU ID(s) to use for training]:ids' \
  '--mini-batch=[size of mini-batch used during update]:n' \
  '(-o --optimizer)'{-o,--optimizer}'=[optimization algorithm]:opt:(sgd adagrad adam)' \
  '(-l --learn-rate)'{-l,--learn-rate}'=[learning rate]:lr' \
  '(-a --after)'{-a,--after}'=[finish after this many training units]:n' \
  '--save-freq=[save model file every arg updates]:n' \
  '--disp-freq=[display information every arg updates]:n' \
  '--valid-sets=[paths to validation corpora: source target]:files:_files' \
  '--valid-freq=[validation frequency during training]:n' \
  '--valid-metrics=[metrics for evaluation]:metrics' \
  '--early-stopping=[stop if first validation metric does not improve]:n' \
  '(-b --beam-size)'{-b,--beam-size}'=[beam size used during search with validating translator]:n' \
  '--transformer-heads=[number of heads in multi-head attention]:n' \
  '--transformer-dim-ffn=[feed-forward network size for transformer]:n' \
  '--enc-depth=[number of encoder layers]:n' \
  '--dec-depth=[number of decoder layers]:n' \
  '--label-smoothing=[regularization epsilon value]:eps' \
  '--clip-norm=[clip gradient norm]:val' \
  '--dropout-rnn=[dropout rate for RNN layers]:rate' \
  '--transformer-dropout=[dropout between transformer layers]:rate' \
  '--max-length=[maximum sentence length in training pairs]:n' \
  '--seed=[seed for all random number generators]:seed' \
  '*:file:_files' && ret=0

return ret
