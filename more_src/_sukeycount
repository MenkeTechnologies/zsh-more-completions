#compdef sukeycount
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/sukeycount.c
# SUKEYCOUNT - write a count of a selected key

local ret=1

_arguments -s -S \
  'key=[one key word]:k:' \
  'verbose=[=0 quiet]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
