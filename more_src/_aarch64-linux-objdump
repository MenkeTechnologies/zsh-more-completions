#compdef aarch64-linux-objdump aarch64-linux-gnu-objdump
# _aarch64-linux-objdump — GNU binutils aarch64-linux-objdump CLI cross-arch ELF object dumper disassembling AArch64 A64 instructions printing section headers symbol tables relocations source-mixed listings dwarf .eh_frame for ARMv8 Linux kernel modules user-space binaries SVE SVE2 BTI PAC printing (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_aarch64-linux-objdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a[archive headers]' \
        '--archive-headers[archive headers]' \
        '-f[file headers]' \
        '--file-headers[file headers]' \
        '-p[private headers]' \
        '--private-headers[private headers]' \
        '-h[section headers]' \
        '--section-headers[section headers]' \
        '--headers[section headers]' \
        '-x[all headers]' \
        '--all-headers[all headers]' \
        '-d[disassemble]' \
        '--disassemble[disassemble]' \
        '-D[disassemble all]' \
        '--disassemble-all[disassemble all]' \
        '-S[source-mixed]' \
        '--source[source-mixed]' \
        '-l[line numbers]' \
        '--line-numbers[line numbers]' \
        '-C[demangle]' \
        '--demangle[demangle]' \
        '-r[relocations]' \
        '--reloc[relocations]' \
        '-R[dynamic relocations]' \
        '--dynamic-reloc[dynamic relocations]' \
        '-s[section contents]' \
        '--full-contents[section contents]' \
        '-t[symbol table]' \
        '--syms[symbol table]' \
        '-T[dynamic symbol table]' \
        '--dynamic-syms[dynamic symbol table]' \
        '-g[debugging info]' \
        '--debugging[debugging info]' \
        '-W[dwarf]' \
        '--dwarf[dwarf]' \
        '--dwarf=+[type]:t:(info abbrev decodedline rawline loc Ranges pubnames frames frames-interp str gdb_index addr cu_index links follow-links)' \
        '-j+[section]:str:' \
        '--section=+[section]:str:' \
        '-b+[bfd]:str:' \
        '--target=+[bfd]:str:' \
        '-m+[arch]:a:(aarch64)' \
        '--architecture=+[arch]:a:(aarch64)' \
        '-M+[disassembler options]:str:' \
        '--disassembler-options=+[opts]:str:' \
        '--prefix=+[path]:dir:_files -/' \
        '--prefix-strip=+[N]:n:' \
        '--start-address=+[addr]:str:' \
        '--stop-address=+[addr]:str:' \
        '*:file:_files'
}

_aarch64-linux-objdump "$@"
