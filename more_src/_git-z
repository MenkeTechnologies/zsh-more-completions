#compdef git-z
# Documentation: https://github.com/ejpcmac/git-z
# Source: https://github.com/ejpcmac/git-z/blob/master/src/command.rs
# Reference accessed: 2026-06-01
# Git extension; invoked as `git z <subcommand>` or `git-z <subcommand>`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gz_cmds
_gz_cmds=(
    'init:initialise the git-z.toml configuration'
    'commit:run the Conventional Commits wizard'
    'update:update the configuration to the latest schema'
    'help:show help'
)

_arguments -C \
    '*-v[increase verbosity (repeatable)]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'git-z command' _gz_cmds && ret=0
        ;;
    args)
        case $line[1] in
            commit)
                _arguments -s -S \
                    '--topic=[topic to use instead of branch name]:topic:_default' \
                    '(--print-only)--command=[custom commit command instead of `git commit -em`]:cmd:_default' \
                    '(--command)--print-only[print the commit message; do not call git commit]' \
                    '(-n --no-verify)'{-n,--no-verify}'[skip pre-commit hook (unstable)]' \
                    '*: :_default' \
                    && ret=0
                ;;
            init|update)
                ret=0
                ;;
        esac
        ;;
esac

return ret
