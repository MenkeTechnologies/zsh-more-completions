#compdef ctest-cli
# _ctest-cli — Kitware ctest CMake test runner CLI alias (Kitware team, C++); custom argparse
# upstream: https://gitlab.kitware.com/cmake/cmake

_ctest-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-C+[build configuration]:c:(Debug Release RelWithDebInfo MinSizeRel)' \
        '--build-config=+[build configuration]:c:(Debug Release RelWithDebInfo MinSizeRel)' \
        '-V[verbose]' \
        '--verbose[verbose]' \
        '-VV[extra verbose]' \
        '--extra-verbose[extra verbose]' \
        '--debug[debug]' \
        '--output-on-failure[output on failure]' \
        '--stop-on-failure[stop on failure]' \
        '--test-output-size-passed=+[bytes]:n:' \
        '--test-output-size-failed=+[bytes]:n:' \
        '--test-output-truncation=+[mode]:m:(head middle tail)' \
        '-F[fail without running tests]' \
        '--no-tests=+[mode]:m:(error ignore)' \
        '-N[show test summary only]' \
        '--show-only=+[format]:f:(human json-v1)' \
        '-L+[label]:str:' \
        '--label-regex=+[regex]:str:' \
        '-R+[regex]:str:' \
        '--tests-regex=+[regex]:str:' \
        '-E+[exclude regex]:str:' \
        '--exclude-regex=+[exclude regex]:str:' \
        '-LE+[exclude label regex]:str:' \
        '--label-exclude=+[exclude label regex]:str:' \
        '-FA+[fixture add regex]:str:' \
        '--fixture-exclude-any=+[fixture regex]:str:' \
        '-FS+[fixture setup regex]:str:' \
        '--fixture-exclude-setup=+[fixture regex]:str:' \
        '-FC+[fixture cleanup regex]:str:' \
        '--fixture-exclude-cleanup=+[fixture regex]:str:' \
        '-D+[dashboard target]:str:' \
        '--dashboard=+[dashboard target]:str:' \
        '-M+[model]:m:(Experimental Nightly Continuous)' \
        '--model=+[model]:m:(Experimental Nightly Continuous)' \
        '-T+[stage]:s:(Start Update Configure Build Test Coverage MemCheck Submit Notes ExtraFiles Upload)' \
        '--test-action=+[stage]:s:(Start Update Configure Build Test Coverage MemCheck Submit Notes ExtraFiles Upload)' \
        '-S+[script]:file:_files' \
        '--script=+[script]:file:_files' \
        '-SP+[parallel script]:file:_files' \
        '--script-new-process=+[parallel script]:file:_files' \
        '-I+[range]:str:' \
        '--tests-information=+[range]:str:' \
        '-U[union of tests]' \
        '--union[union of tests]' \
        '-Q[quiet]' \
        '--quiet[quiet]' \
        '-O+[output log]:file:_files' \
        '--output-log=+[output log]:file:_files' \
        '--output-junit=+[file]:file:_files' \
        '--no-compress-output[no compress output]' \
        '--test-load=+[load]:str:' \
        '--test-dir=+[dir]:dir:_files -/' \
        '--build-and-test=+[src bld]:str:' \
        '--build-generator=+[generator]:str:' \
        '--build-generator-platform=+[platform]:str:' \
        '--build-generator-toolset=+[toolset]:str:' \
        '--build-makeprogram=+[program]:file:_files' \
        '--build-options=+[options]:str:' \
        '--build-project=+[project]:str:' \
        '--build-noclean[no clean]' \
        '--build-nocmake[no cmake]' \
        '--build-target=+[target]:str:' \
        '--build-two-config[two config]' \
        '--build-exe-dir=+[dir]:dir:_files -/' \
        '--build-config-sample=+[sample]:file:_files' \
        '--test-command=+[command]:str:' \
        '--test-timeout=+[seconds]:n:' \
        '--timeout=+[seconds]:n:' \
        '-j+[parallel]:n:' \
        '--parallel=+[parallel]:n:' \
        '--schedule-random[random schedule]' \
        '--repeat=+[count]:str:' \
        '--rerun-failed[rerun failed tests]' \
        '--max-width=+[width]:n:' \
        '--interactive-debug-mode=+[bool]:b:(0 1)' \
        '--resource-spec-file=+[file]:file:_files' \
        '--http-header=+[header]:str:' \
        '--submit-index=+[id]:str:' \
        '*:arg:'
}

_ctest-cli "$@"
