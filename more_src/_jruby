#compdef jruby
# Documentation: https://github.com/jruby/jruby/blob/master/core/src/main/java/org/jruby/util/cli/ArgumentProcessor.java
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (ruby-level options) and
# https://github.com/jruby/jruby/blob/master/bin/jruby.sh (launcher options).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(- *)--copyright[show copyright]' \
  '-0[stdin record separator (octal)]' \
  '-a[autosplit mode with -n or -p]' \
  '-c[check syntax only]' \
  '-C+[change to directory before executing]:dir:_files -/' \
  '-d[debug mode]' \
  '-E+[external:internal encoding]:enc:' \
  '-e+[execute one line of script]:expr:' \
  '-F+[autosplit field pattern]:pattern:' \
  '-G+[set Gemfile path]:file:_files' \
  '-i+[edit ARGV files in place (backup ext)]:ext:' \
  '-I+[add directory to $LOAD_PATH]:dir:_files -/' \
  '-l[enable line ending processing]' \
  '-n[wrap script in while gets loop]' \
  '-p[wrap with -n and print $_]' \
  '-r+[require library before executing]:lib:' \
  '-s[parse switches after script name as global vars]' \
  '-S[look up script using PATH]' \
  '-U[set internal encoding to UTF-8]' \
  '-v[verbose mode, print version]' \
  '-w[enable warnings]' \
  '-W+[warning level (0 silence, 1 medium, 2 verbose)]:lvl:(0 1 2)' \
  '-x-[strip text before #!ruby line; optional dir]::dir:_files -/' \
  '-X+[set extended option (e.g. -X+O); -X- to disable]:opt:' \
  '-J+[pass argument to the JVM]:jvm option:' \
  '-y[enable parser debug logging]' \
  '--encoding=[set external/internal encoding]:enc:' \
  '--profile[run with instrumented (flat) profiling]' \
  '--profile.api[support Ruby profiling API]' \
  '--profile.flat[flat profile (default)]' \
  '--profile.graph[graph profile]' \
  '--profile.html[HTML graph profile]' \
  '--profile.json[JSON graph profile]' \
  '--profile.out=[save profile to file]:file:_files' \
  '--profile.service=[use named profiling service]:class:' \
  '--bytecode[print generated bytecode to stdout]' \
  '--dev[development mode for faster startup]' \
  '--server[run in JVM server mode]' \
  '--client[run in JVM client mode]' \
  '--dump=[dump AST/parse and exit]:mode:(parsetree parsetree_with_locals heredoc_lex)' \
  '--debug[set runtime build mode to fully interpreted]' \
  '--jdb[run under JDB debugger]' \
  '--properties[list all JRuby properties]' \
  '--manage[enable JMX management beans]' \
  '--headless[set java.awt.headless=true]' \
  '--sample[run with sampling profiler (-Xprof)]' \
  '(--ng --ng-server)--ng[use Nailgun client]' \
  '(--ng --ng-server)--ng-server[start a Nailgun server]' \
  '--environment[print the java command line that would run]' \
  '*:script:_files -g "*.rb"' && ret=0

return ret
