#compdef mstprivhost mlxprivhost

# mstprivhost (a.k.a. mlxprivhost): manage privileged-host capabilities (Mellanox SmartNIC)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'r:restrict the host'
  'restrict:restrict the host'
  'p:un-restrict (privileged)'
  'privilege:un-restrict (privileged)'
  'q:query current state'
  'query:query current state'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-d[device]:dev:' \
  '--dev=[device]:dev:' \
  '--disable_port_owner[disable port owner]' \
  '--disable_rshim[disable rshim]' \
  '--disable_tracer[disable tracer]' \
  '--disable_counter_rd[disable counter read]' \
  '--disable_port_rst[disable port reset]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mstprivhost command' commands && ret=0 ;;
esac
return ret
