#compdef libinput-test
# Documentation: https://man.archlinux.org/man/libinput-test.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# libinput-test is normally disabled at build time. The man page documents
# only --help; the real test suite is invoked via libinput-test-suite.
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*:device:_files -g "/dev/input/event*"' && ret=0

return ret
