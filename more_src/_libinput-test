#compdef libinput-test
# Documentation: https://man.archlinux.org/search?q=libinput-test
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--grab[grab device exclusively]' \
  '--quiet[suppress event printing]' \
  '*:device:_files -g "/dev/input/event*"' && ret=0

return ret
