#compdef suaddhead
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/suaddhead.c
# SUADDHEAD - put headers on bare traces and set tracl and ns fields

local ret=1

_arguments -s -S \
  'ns=[number of samples per trace]:n:' \
  'head=[file to read headers in]:f:_files' \
  'ftn=[Fortran flag (0 = C, 1 = Fortran)]:f:(0 1)' \
  'tsort=[trace sorting code]:t:(1 2 3 4)' \
  'ntrpr=[number of data traces per record]:n:' \
  '*:SU file:_files' && ret=0

return ret
