#compdef repren

local -a arguments

arguments=(
  '--from=[pattern to search for]:pattern:'
  '--to=[replacement pattern]:pattern:'
  '(-p --patterns)'{-p,--patterns}'=[file with pattern pairs]:file:_files'
  '--full[do full renames (paths + contents)]'
  '--renames[rename files/directories only]'
  '--literal[treat patterns as literal strings]'
  '--preserve-case[preserve case when replacing]'
  '(-i --insensitive)'{-i,--insensitive}'[case-insensitive matching]'
  '--word-breaks[only match whole words]'
  '(-n --dry-run)'{-n,--dry-run}'[dry run - show changes without applying]'
  '--at-once[read entire file into memory]'
  '--exclude=[exclude paths matching pattern]:pattern:'
  '*:path:_files'
)

_arguments -s -S $arguments
