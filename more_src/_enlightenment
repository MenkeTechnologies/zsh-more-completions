#compdef enlightenment
# Documentation: https://man.archlinux.org/search?q=enlightenment
# Reference accessed: 2026-05-16

# Enlightenment window manager / desktop
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-version[show version]' \
  '-good[try to recover gracefully on crash]' \
  '-evil[do not try to recover gracefully on crash]' \
  '-psychotic[abort on errors]' \
  '-locked[start in locked state]' \
  '-display[X display]:display:' \
  '-fake-xinerama-screen=[fake xinerama screen]:WxH+X+Y@Z:' \
  '-profile[profile name]:profile:' \
  '-i-really-know-what-i-am-doing-and-accept-full-responsibility-for-it[force]' \
  '*::enlightenment args:_files' && ret=0
return ret
