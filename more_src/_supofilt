#compdef supofilt
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/multicomponent/supofilt.c
# POlarization FILTer for three-component SU data

local ret=1

_arguments -s -S \
  'dfile=[file with the 3 components of polarization direction]:file:_files' \
  'wfile=[file name of weighting polarization parameter]:file:_files' \
  'dt=[time sampling interval in seconds]:dt' \
  'smooth=[1 to smooth filter operators]:smooth:(0 1)' \
  'sl=[smoothing window length in seconds]:sl' \
  'wpow=[raise weighting function to power wpow]:wpow' \
  'dpow=[raise directivity functions to power dpow]:dpow' \
  'verbose=[1 to echo additional information]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
