#compdef anvil

# Zsh completion for anvil - Foundry's local Ethereum node

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --accounts)'{-a,--accounts}'[number of dev accounts to generate]:num:' \
  '--auto-impersonate[enable autoImpersonate]' \
  '(-b --block-time)'{-b,--block-time}'[block time in seconds]:seconds:' \
  '--balance[balance of every dev account in ether]:amount:' \
  '--base-fee[the base fee in a block]:fee:' \
  '--block-base-fee-per-gas[block base fee per gas]:fee:' \
  '--chain-id[the chain ID]:id:' \
  '--code-size-limit[EIP-170 code size limit override]:bytes:' \
  '--compute-units-per-second[QPS limit for forked node]:cups:' \
  '--config-out[write transactions output to file]:file:_files' \
  '--cups[QPS limit for forked node]:cups:' \
  '--derivation-path[BIP44 derivation path]:path:' \
  '--disable-block-gas-limit[disable block gas limit checks]' \
  '--disable-code-size-limit[disable code size limit checks]' \
  '--disable-console-log[disable console.log calls in solidity]' \
  '--disable-default-create2-deployer[disable default CREATE2 deployer]' \
  '--dump-state[dump state on shutdown]:file:_files' \
  '--enable-cors[enable CORS]' \
  '(-f --fork-url)'{-f,--fork-url}'[fork from this RPC URL]:url:' \
  '--fork-block-number[fork from a specific block]:number:' \
  '--fork-chain-id[fork chain id]:id:' \
  '--fork-retry-backoff[backoff in ms for fork retries]:ms:' \
  '--fork-transaction-hash[fork from a specific transaction]:hash:' \
  '--gas-limit[block gas limit]:limit:' \
  '--gas-price[gas price for transactions]:price:' \
  '--hardfork[EVM hardfork]:hardfork:(frontier homestead tangerineWhistle spuriousDragon byzantium constantinople petersburg istanbul muirGlacier berlin london arrowGlacier grayGlacier paris shanghai cancun)' \
  '--host[host to listen on]:host:' \
  '--init[init genesis from file]:file:_files' \
  '--ipc[IPC path]:path:' \
  '--load-state[load state from file]:file:_files' \
  '(-m --mnemonic)'{-m,--mnemonic}'[BIP39 mnemonic phrase]:mnemonic:' \
  '--mnemonic-random[generate a random mnemonic]' \
  '--mnemonic-seed-unsafe[generate mnemonic from seed]:seed:' \
  '--no-cors[disable CORS]' \
  '--no-mining[disable auto mining]' \
  '--no-storage-caching[disable storage caching for fork]' \
  '--order[transaction order]:order:(fees fifo)' \
  '(-p --port)'{-p,--port}'[port to listen on]:port:' \
  '--prune-history[prune historic state]' \
  '--retries[number of retries for fork]:num:' \
  '(-s --silent)'{-s,--silent}'[silence start-up logging]' \
  '--state[load and dump state]:file:_files' \
  '--state-interval[interval in seconds at which state is dumped]:seconds:' \
  '--steps-tracing[enable steps tracing]' \
  '--timeout[fork request timeout in ms]:ms:' \
  '--timestamp[the timestamp of the genesis block]:timestamp:' \
  '--transaction-block-keeper[number of blocks to keep transactions in memory]:num:'
