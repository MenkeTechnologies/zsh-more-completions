#compdef rebar3 rebar

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'alias:create custom command aliases'
  'as:run a task with a specific profile'
  'clean:remove compiled beam files'
  'compile:compile project'
  'completion:emit shell completion'
  'cover:perform coverage analysis'
  'ct:run Common Test suites'
  'deps:list dependencies'
  'dialyzer:run Dialyzer'
  'do:run multiple tasks in sequence'
  'edoc:generate EDoc documentation'
  'escriptize:create an executable escript'
  'eunit:run EUnit tests'
  'get-deps:fetch dependencies'
  'help:show help'
  'new:create a new project from template'
  'path:print code path of project'
  'pkgs:list packages from configured registries'
  'release:build OTP release'
  'relup:create a release upgrade'
  'report:create a crash report'
  'shell:run an Erlang shell with project loaded'
  'tar:tar a release'
  'tree:print dependency tree'
  'unlock:unlock dependencies in rebar.lock'
  'update:update package index'
  'upgrade:upgrade dependencies'
  'version:show version'
  'xref:run cross-reference analysis'
  'experimental:experimental commands'
  'local:local rebar3 install/upgrade'
  'plugins:plugin management'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rebar3 subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (as)
        _values 'profile' 'default' 'test' 'prod' && ret=0
        ;;
      (new)
        _values 'template' \
          'app' 'lib' 'release' 'umbrella' 'escript' 'plugin' 'cmake' && ret=0
        ;;
      (experimental)
        _values 'experimental action' 'manifest' 'vendor' && ret=0
        ;;
      (local)
        _values 'local action' 'install' 'upgrade' && ret=0
        ;;
      (plugins)
        _values 'plugins action' 'list' 'upgrade' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' && ret=0
        ;;
    esac
    ;;
esac

return ret
