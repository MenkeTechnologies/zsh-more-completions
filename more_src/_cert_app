#compdef cert_app
# Documentation: https://github.com/Mbed-TLS/mbedtls/blob/development/programs/x509/cert_app.c
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above (Mbed TLS X.509 sample program).

# cert_app: Mbed TLS X.509 certificate read & verify sample
local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'mode=:operating mode (file or ssl)'
  'filename=:certificate file (default cert.crt)'
  'ca_file=:trusted CA file'
  'crl_file=:CRL file'
  'ca_path=:trusted CA directory'
  'server_name=:server name (default localhost)'
  'server_port=:server port (default 4433)'
  'debug_level=:debug level (default 0)'
  'permissive=:permissive parsing (0 or 1)'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    if compset -P 'mode='; then
      _values mode file ssl && ret=0
    elif compset -P '(filename|ca_file|crl_file)='; then
      _files && ret=0
    elif compset -P 'ca_path='; then
      _files -/ && ret=0
    elif compset -P 'permissive='; then
      _values flag 0 1 && ret=0
    else
      _describe -t params 'param' params -S '' && ret=0
    fi
    ;;
esac

return ret
