#compdef checkMesh
# Documentation: https://www.openfoam.com/documentation/user-guide/4-mesh-generation-and-conversion/4.3-mesh-generation
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/mesh/manipulation/checkMesh/checkMesh.C — CFD mesh quality checker.
# Reference accessed: 2026-06-10
#
# Common argList options shared with all OpenFOAM utilities:
# -case, -parallel, -roots, -hostRoots, -noFunctionObjects, -fileHandler,
# -libs, -help, -doc, -srcDoc.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show application documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[case directory]:dir:_directories' \
    '-parallel[run in parallel]' \
    '-roots+[slave root directories]:dirs:_default' \
    '-hostRoots+[per-host slave root directories]:dirs:_default' \
    '-noFunctionObjects[do not execute functionObjects]' \
    '-fileHandler+[override fileHandler]:handler:_default' \
    '-libs+[pre-load libraries]:libs:_default' \
    '-region+[mesh region]:region:_default' \
    '-allRegions[run for all regions]' \
    '-noTopology[skip mesh topology checks]' \
    '-allGeometry[include bounding box checks]' \
    '-allTopology[include extra topology checks]' \
    '-meshQuality[read mesh quality criteria from system/meshQualityDict]' \
    '-writeSurfaces[reconstruct + write problem face/cell sets]' \
    '-writeSets[reconstruct + write problem point sets]' \
    '-surfaceFormat+[surface format for face/cell sets (default vtk)]:format:(vtk obj stl raw nas)' \
    '-setFormat+[set format for point sets (default vtk)]:format:(vtk raw csv gnuplot)' \
    '-nonOrthThreshold+[non-orthogonality threshold (deg, default 70)]:deg:_default' \
    '-skewThreshold+[skewness threshold (default 4)]:value:_default' \
    && ret=0

return ret
