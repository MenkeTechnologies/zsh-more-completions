#compdef livy-server livy
# Documentation: https://man.archlinux.org/search?q=livy-server
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'start:start the Livy server'
  'stop:stop the Livy server'
  'status:show server status'
)

_arguments -C \
  '1: :->action' && ret=0

case $state in
  (action)
    _describe -t actions 'livy-server action' actions && ret=0
    ;;
esac

return ret
