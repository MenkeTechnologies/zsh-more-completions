#compdef promtail

# Zsh completion for promtail - Loki log collection agent

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-config.file)-config.file=[path to config file]:file:_files' \
  '--config.file=[path to config file]:file:_files' \
  '--config.file-path=[path to config file directory]:directory:_directories' \
  '--config.expand-env[expand environment variables in config file]' \
  '--server.http-listen-address=[HTTP server listen address]:address:' \
  '--server.http-listen-port=[HTTP server listen port]:port:' \
  '--server.grpc-listen-address=[gRPC server listen address]:address:' \
  '--server.grpc-listen-port=[gRPC server listen port]:port:' \
  '--client.url=[URL of Loki server]:url:' \
  '--client.external-labels=[external labels for log entries]:labels:' \
  '--client.batch-wait=[maximum wait time before sending a batch]:duration:' \
  '--client.batch-size-bytes=[maximum batch size in bytes]:bytes:' \
  '--client.timeout=[maximum time to wait for server response]:duration:' \
  '--positions.file=[path to positions file]:file:_files' \
  '--target.sync-period=[period to resync directories being watched]:duration:' \
  '--dry-run[log line entries without sending them to Loki]' \
  '--inspect[inspect log pipeline]' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '--stdin[read logs from stdin]' && ret=0

return ret
