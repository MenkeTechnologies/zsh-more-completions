#compdef mineru-api
# Documentation: https://opendatalab.github.io/MinerU/usage/cli_tools/
# Start a FastAPI server for MinerU PDF parsing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--host=[host to bind]:host:' \
  '--port=[port to bind]:port:' \
  '--reload[enable auto-reload]' \
  '--enable-vlm-preload=[preload VLM model]:bool:(true false)' && ret=0

return ret
