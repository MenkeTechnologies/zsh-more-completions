#compdef weston-launch
# Documentation: (deprecated/removed upstream; historical manpage)
# Reference accessed: 2026-05-16
# Verified: weston-launch was deprecated in favor of systemd-logind/seatd.
# Historical flag set from old Debian buster manpage (which now returns 404).
# Tool kept per "do not delete files" directive with conservative historical flags.

# weston-launch: deprecated Weston session launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-u --user)'{-u,--user=}'[user to switch to]:user:_users' \
  '(-t --tty)'{-t,--tty=}'[tty to use]:tty:' \
  '*:Weston args (after --):_files' && ret=0
return ret
