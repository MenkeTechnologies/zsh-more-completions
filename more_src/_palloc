#compdef palloc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-n+,--np=}'[number of processes]:n:' \
  '--host=[host list]:hosts:' \
  '--hostfile=[host file]:file:_files' \
  '*--mca=[MCA parameter]:param:' \
  {-q,--quiet}'[quiet]' \
  {-v,--verbose}'[verbose]' \
  '*::command:_normal' && ret=0

return ret
