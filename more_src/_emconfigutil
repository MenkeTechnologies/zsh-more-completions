#compdef emconfigutil
# Documentation: https://docs.amd.com/r/en-US/ug1393-vitis-application-acceleration/emconfigutil-Utility
# AMD Vitis emulation config generator: emit emconfig.json for sw/hw emulation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--platform=[target acceleration platform]:platform:_files -g "*.xpfm"' \
  '--nd=[number of devices to emulate]:count:' \
  '*:file:_files' && ret=0

return ret
