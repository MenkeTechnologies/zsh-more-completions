#compdef wayvnc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-C --config)'{-C,--config}'=[config file path]:config file:_files' \
  '(-g --gpu)'{-g,--gpu}'[enable GPU acceleration]' \
  '(-o --output)'{-o,--output}'=[output/display to capture]:output' \
  '(-k --keyboard)'{-k,--keyboard}'=[keyboard layout]:layout' \
  '(-s --seat)'{-s,--seat}'=[seat to use]:seat' \
  '(-S --socket)'{-S,--socket}'=[wayland socket path]:socket:_files' \
  '(-r --render-cursor)'{-r,--render-cursor}'[render cursor in stream]' \
  '(-f --max-fps)'{-f,--max-fps}'=[maximum frames per second]:fps' \
  '(-p --show-performance)'{-p,--show-performance}'[show performance counters]' \
  '(-u --unix-socket)'{-u,--unix-socket}'[use Unix socket instead of TCP]' \
  '(-d --disable-input)'{-d,--disable-input}'[disable all input]' \
  '(-e --exec)'{-e,--exec}'=[command to run on client connect]:command' \
  '(-L --log-level)'{-L,--log-level}'=[log level]:level:(quiet error warning info debug trace)' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:address' \
  '2:port' && ret=0

return ret
