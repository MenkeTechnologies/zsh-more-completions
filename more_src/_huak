#compdef huak
# Documentation: https://man.archlinux.org/search?q=huak
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'activate:activate the project virtual environment'
  'add:add dependencies to the project'
  'build:build tarball and wheel for the project'
  'clean:remove tarball and wheel from the built project'
  'completion:generate a shell completion script'
  'fix:auto-fix fixable lint conflicts'
  'fmt:format the project Python code'
  'init:initialize the current directory as a project'
  'install:install a Python package'
  'lint:lint the project Python code'
  'new:create a new project at a given path'
  'publish:build and upload to a registry'
  'python:manage Python installations'
  'remove:remove dependencies from the project'
  'run:run a command with huak'
  'test:test the project'
  'toolchain:manage toolchains'
  'update:update project dependencies'
  'version:show project version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--no-color[disable colored output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'huak command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '--group=[dependency group]:group:' \
          '*::package:' && ret=0 ;;
      (remove)
        _arguments \
          '--group=[dependency group]:group:' \
          '*::package:' && ret=0 ;;
      (new)
        _arguments \
          '--app[create a new application project]' \
          '--lib[create a new library project]' \
          '--no-vcs[skip VCS init]' \
          '*::path:_files -/' && ret=0 ;;
      (init)
        _arguments \
          '--app[initialize as application]' \
          '--lib[initialize as library]' \
          '--no-vcs[skip VCS init]' && ret=0 ;;
      (install)
        _arguments \
          '--group=[dependency group]:group:' \
          '*::package:' && ret=0 ;;
      (run)
        _arguments \
          '*--with=[extra dependencies for the run]:dep:' \
          '*::cmd:_command_names' && ret=0 ;;
      (test)
        _arguments \
          '--trailing-args=[extra args]:args:' && ret=0 ;;
      (publish)
        _arguments \
          '--repository=[publish target]:repo:(pypi testpypi)' \
          '--trailing-args=[extra args]:args:' && ret=0 ;;
      (python)
        _arguments '*::sub:(install list use uninstall)' && ret=0 ;;
      (toolchain)
        _arguments '*::sub:(add remove use list info update)' && ret=0 ;;
      (completion)
        _arguments \
          '(-i --install)'{-i,--install}'[install completion]' \
          '(-u --uninstall)'{-u,--uninstall}'[uninstall completion]' \
          '(-s --shell)'{-s+,--shell=}'[shell name]:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
    esac ;;
esac

return ret
