#compdef coga
# _coga — coga CLI for cookie-based session anomaly detection of HTTP request collections analysing Set-Cookie patterns secure/HttpOnly/SameSite missing flags Path Domain scope SameSite Lax/Strict compliance (coga team, Go); flag
# upstream: https://github.com/coga-sec/coga

_coga() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[input file]:file:_files' \
        '--input=+[input file]:file:_files' \
        '-o+[output file]:file:_files -g "*.json *.csv *.txt *.html"' \
        '--output=+[output file]:file:_files -g "*.json *.csv *.txt *.html"' \
        '-f+[format]:f:(text json csv html)' \
        '--format=+[format]:f:(text json csv html)' \
        '-x+[proxy]:str:' \
        '--proxy=+[proxy]:str:' \
        '-H+[header]:str:' \
        '--header=+[header]:str:' \
        '-t+[N threads]:n:' \
        '--threads=+[N threads]:n:' \
        '--severity=+[s]:s:(info low medium high critical)' \
        '--insecure[insecure TLS]' \
        '--follow-redirects[follow redirects]' \
        '--check-secure[check Secure flag]' \
        '--check-httponly[check HttpOnly flag]' \
        '--check-samesite[check SameSite flag]' \
        '--check-path[check Path scope]' \
        '--check-domain[check Domain scope]' \
        '--check-prefix[check __Host- __Secure- prefix]' \
        '*:URL or file:_files'
}

_coga "$@"
