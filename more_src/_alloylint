#compdef alloylint
# _alloylint — Alloy-repo custom go-analysis linter (multichecker bundling findcomponents + syntaxtags)
# upstream: https://github.com/grafana/alloy
# Source: internal/cmd/alloylint/main.go on tip — uses golang.org/x/tools/go/analysis/multichecker.

_alloylint() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-V[print version and exit]' \
        '-flags[show flags as JSON]' \
        '-c=[display offending line with n lines of context]:n:' \
        '-cpuprofile=[write CPU profile to file]:file:_files' \
        '-debug=[debug flags (any of fpstv)]:flags:' \
        '-fix[apply all suggested fixes]' \
        '-json[emit JSON output]' \
        '-memprofile=[write memory profile to file]:file:_files' \
        '-source[no parallelism, treat unconfigured analyzers as errors]' \
        '-tags=[list of build tags]:tags:' \
        '-trace=[write trace log to file]:file:_files' \
        '*:package:_files'
}

_alloylint "$@"
