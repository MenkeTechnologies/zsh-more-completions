#compdef hgTrackDb
# UCSC kent: create trackDb table from text files

local ret=1

_arguments -s -S \
  '-strict[include only existing tables; complain about missing HTML files]' \
  '-raName=[alternate filename for .ra files]:name' \
  '-release=[filter entries by release tag]:tag:(alpha beta public)' \
  '-settings[output track names, types, and settings to stderr]' \
  '-gbdbList=[file confirming bigDataUrl file existence]:file:_files' \
  '-addVersion[add cartVersion pseudo-table]' \
  '-noHtmlCheck[disable HTML file validation even with strict mode]' \
  '1:org dir:_files -/' \
  '2:database:' \
  '3:trackDb table:' \
  '4:trackDb.sql:_files -g "*.sql"' \
  '5:hgRoot:_files -/' && ret=0

return ret
