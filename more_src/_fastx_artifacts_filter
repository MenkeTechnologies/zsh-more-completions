#compdef fastx_artifacts_filter
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastx_artifacts_filter.1.en.html
# FASTX-Toolkit: remove sequencing artifacts from FASTA/Q reads

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose: report number of processed reads]' \
  '-z[compress output with GZIP]' \
  '-i+[FASTA/Q input file (default STDIN)]:input file:_files' \
  '-o+[FASTA/Q output file (default STDOUT)]:output file:_files' && ret=0

return ret
