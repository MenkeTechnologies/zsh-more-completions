#compdef slate slate-docs
# _slate-docs — Tripit Slate single-page API documentation generator CLI rendering three-column API references from Markdown source with side navigation curl examples and language tabs (slatedocs team, Ruby); Thor-style argparse
# upstream: https://github.com/slatedocs/slate

_slate-docs() {
    local -a sub=(
        'init:initialize new Slate project'
        'build:build static docs site'
        'serve:run middleman dev server'
        'deploy:deploy to GitHub Pages'
        'clean:clean build dir'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'slate-docs subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--template=+[t]:t:(default minimal extended)' \
                    '*:project dir:_files -/' ;;
                build) _arguments \
                    '--output=+[dir]:dir:_files -/' \
                    '--clean[clean output]' \
                    '--environment=+[env]:e:(development production staging)' \
                    '--build-dir=+[dir]:dir:_files -/' ;;
                serve) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' \
                    '--bind-address=+[addr]:str:' \
                    '--environment=+[env]:e:(development production)' ;;
                deploy) _arguments \
                    '--branch=+[branch]:str:' \
                    '--remote=+[remote]:str:' \
                    '--message=+[msg]:str:' ;;
            esac
            ;;
    esac
}

_slate-docs "$@"
