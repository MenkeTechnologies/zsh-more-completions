#compdef shx

# Zsh completion for shx - portable Unix shell commands for Node.js

_arguments -s -S \
  '(- *)--help[display help]' \
  '(- *)--version[display version]' \
  '1:command:(cat chmod cp dirs echo exec find grep head ln ls mkdir mv pwd rm sed set sort tail tempdir test touch uniq which)' \
  '*:args:_files'
