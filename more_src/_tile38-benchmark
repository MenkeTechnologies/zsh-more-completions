#compdef tile38-benchmark

# tile38-benchmark: benchmark for Tile38
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '-h[host]:host:_hosts' \
  '-p[port]:port:' \
  '-a[password]:pass:' \
  '-c[clients]:n:' \
  '-n[total requests]:n:' \
  '-P[pipeline]:n:' \
  '-q[quiet]' \
  '--csv[csv output]' \
  '-t[tests]:tests:' \
  '*::tile38-benchmark args:_files' && ret=0
return ret
