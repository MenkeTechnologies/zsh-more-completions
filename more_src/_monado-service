#compdef monado-service monado-cli
# Documentation: https://gitlab.freedesktop.org/monado/monado
# Reference accessed: 2026-05-27
# Verified: upstream Debian man pages (monado-service.1, monado-cli.1) for 25.0.0+dfsg-2
# Note: monado-service takes no arguments (man page: "It takes no arguments,
# and detects whether it was started by socket activation automatically.").
# monado-cli exposes the subcommands 'test' and 'probe' only.

local curcontext="$curcontext" state line ret=1

case ${service} in
  monado-cli)
    local -a _monado_cli_subcommands
    _monado_cli_subcommands=(
      'test:verbosely list found devices, including un-recognized devices, for prober testing'
      'probe:create the prober, probe, and immediately shut down'
    )

    _arguments -C \
      '1: :->cmd' \
      '*:: :->args' && ret=0

    case $state in
      cmd)
        _describe -t commands 'monado-cli subcommand' _monado_cli_subcommands && ret=0
        ;;
      args)
        _message 'no further arguments' && ret=0
        ;;
    esac
    ;;
  monado-service|*)
    _message 'monado-service takes no arguments' && ret=0
    ;;
esac

return ret
