#compdef eqy
# Equivalence checking with Yosys

local ret=1

_arguments -s -S \
  '(-c --continue)'{-c,--continue}'[re-run using existing workdir]' \
  '(-f --force)'{-f,--force}'[remove workdir if it already exists]' \
  '(-b --backup)'{-b,--backup}'[backup workdir if it already exists]' \
  '(-t --tmp)'{-t,--tmp}'[run in temporary workdir]' \
  '-d+[set workdir name]:dirname:_files -/' \
  '(-m --setup)'{-m,--setup}'[generate partitions and makefiles then exit]' \
  '(-k --keep-going)'{-k,--keep-going}'[continue when some make targets fail]' \
  '(-j --jobs)'{-j+,--jobs=}'[allow N make jobs simultaneously]:N' \
  '(-P --purge)'{-P+,--purge=}'[purge partition/strategy pairs]:pattern' \
  '-p+[run yosys command on partition]:command' \
  '(-g --debug)'{-g,--debug}'[enable debug mode]' \
  '--init-config-file[create default config file]' \
  '--yosys=[path to yosys executable]:path:_files' \
  '--abc=[path to abc executable]:path:_files' \
  '--smtbmc=[path to smtbmc executable]:path:_files' \
  '--suprove=[path to suprove executable]:path:_files' \
  '--aigbmc=[path to aigbmc executable]:path:_files' \
  '--avy=[path to avy executable]:path:_files' \
  '--btormc=[path to btormc executable]:path:_files' \
  '--pono=[path to pono executable]:path:_files' \
  '--version[display version information]' \
  '*:config file:_files -g "*.eqy"' && ret=0

return ret
