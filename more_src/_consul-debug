#compdef consul-debug
# _consul-debug — HashiCorp Consul debug bundle helper (HashiCorp, Go); wraps `consul debug`
# upstream: https://github.com/hashicorp/consul

_consul-debug() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-archive[create archive]' \
        '-capture=+[targets]:targets:' \
        '-duration=+[duration]:dur:' \
        '-interval=+[interval]:dur:' \
        '-output=+[output dir]:dir:_files -/' \
        '-since=+[since]:dur:' \
        '-http-addr=+[http addr]:addr:' \
        '-token=+[token]:str:' \
        '-token-file=+[token file]:file:_files' \
        '-ca-file=+[ca file]:file:_files' \
        '-ca-path=+[ca path]:dir:_files -/' \
        '-client-cert=+[client cert]:file:_files' \
        '-client-key=+[client key]:file:_files' \
        '-tls-server-name=+[tls server name]:str:' \
        '*:arg:'
}

_consul-debug "$@"
