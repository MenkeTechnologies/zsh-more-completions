#compdef @grayplot
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@grayplot.html
# Create grayscale grayplots from AFNI residuals datasets

local ret=1

_arguments -s -S \
  '(-peelorder -ijkorder -ALLorder)-pvorder[order voxels by similarity within each partition]' \
  '(-pvorder -ijkorder -ALLorder)-peelorder[order voxels by distance from partition boundary]' \
  '(-pvorder -peelorder -ALLorder)-ijkorder[order voxels by 3D dataset indices (default)]' \
  '(-pvorder -peelorder -ijkorder)-ALLorder[generate grayplots using all ordering methods]' \
  '*:dataset:_files' && ret=0

return ret
