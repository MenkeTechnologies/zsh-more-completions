#compdef cowpoke
# Documentation: https://manpages.debian.org/cowpoke
# Source: debian/devscripts scripts/cowpoke.sh — remote cowbuilder Debian package build (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '--arch=-[target architecture(s)]:arch:_default' \
    '--dist=-[target distribution(s)]:dist:_default' \
    '--buildd=-[remote build host]:host:_hosts' \
    '--buildd-user=-[remote build user]:user:_users' \
    '--create[create remote cowbuilder root if missing]' \
    '(--no-return)--return=-[path to copy build results to]:path:_files -/' \
    '(--return)--no-return[do not copy results back]' \
    '--dpkg-opts=-[dpkg-buildpackage options]:opts:_default' \
    '--create-opts=-[cowbuilder --create options]:opts:_default' \
    '--update-opts=-[cowbuilder --update options]:opts:_default' \
    '--build-opts=-[cowbuilder --build options]:opts:_default' \
    '--sign=-[signing key id]:keyid:_default' \
    '--upload=-[dput queue]:queue:_default' \
    '*:dsc file(s):_files -g "*.dsc"' \
    && ret=0

return ret
