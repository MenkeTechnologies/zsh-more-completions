#compdef faust2plot
# Documentation: https://faustdoc.grame.fr/manual/tools/
# Reference accessed: 2026-06-21
# Verified: flags parsed by the faust2plot script in grame-cncm/faust tools/faust2appls.

local ret=1

_arguments -s -S \
  '(-help -h)'{-help,-h}'[show help]' \
  '-arch32[compile 32-bit architecture]' \
  '-arch64[compile 64-bit architecture]' \
  '-double[use double precision floats]' \
  '-dyn[dynamic compilation via LLVM]' \
  '*:dsp file:_files -g "*.dsp"' && ret=0

return ret
