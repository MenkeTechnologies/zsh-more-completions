#compdef plasma-discover
# _plasma-discover — KDE plasma-discover (KDE software center frontend over PackageKit/Flatpak/Snap/AppStream backends; --feedback opens to feedback page, --backends restricts active backends, --listbackends prints them, search URL forms drive UI navigation)
# upstream: https://invent.kde.org/plasma/discover
# Flags from discover discover/main.cpp on tip.

_plasma-discover() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--listbackends[list installed backends]' \
        '*--backends+[restrict active backends]:backend:(packagekit flatpak snap appstream rpm-ostree fwupd kns)' \
        '--application+[open application by id]:id:' \
        '--feedback[open feedback page]' \
        '--mime+[search by MIME type]:mime:' \
        '--category+[open category]:category:' \
        '--search+[search text]:query:' \
        '--local-filename+[install local file]:file:_files' \
        '--mode+[mode]:mode:(browse installed updates settings sources)'
}

_plasma-discover "$@"
