#compdef fssconfig
# Documentation: man fssconfig(8)
# Source: netbsd/src usr.sbin/fssconfig — file system snapshot device configuration (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-u -l)-c[configure the snapshot device (default)]' \
    '(-c -l)-u[unconfigure the device]' \
    '(-c -u)-l[list snapshot devices and status]' \
    '-v[verbose output]' \
    '-x[unlink backup after configuration]' \
    '1::snapshot device:_default' \
    '2::mount point:_files -/' \
    '3::backup file or directory:_files' \
    '4::cluster size (bytes):_default' \
    '5::backup file length:_default' \
    && ret=0

return ret
