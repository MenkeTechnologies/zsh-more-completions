#compdef kubectl-slice

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-f+[input file]:file:_files' \
  '--input-file=[input file]:file:_files' \
  '-o+[output directory]:directory:_directories' \
  '--output-dir=[output directory]:directory:_directories' \
  '-t+[template for output filenames]:template:' \
  '--template=[template for output filenames]:template:' \
  '--include-kind=[include resource kinds]:kind:' \
  '--exclude-kind=[exclude resource kinds]:kind:' \
  '--include-name=[include resource names]:name:' \
  '--exclude-name=[exclude resource names]:name:' \
  '-d[dry run]' \
  '--dry-run[dry run]' \
  '-r[recurse into subdirectories]' \
  '--recurse[recurse into subdirectories]' \
  '-s[read from stdin]' \
  '--stdin[read from stdin]' \
  '--prune[remove extra files from output directory]' \
  '--sort-by-kind[sort output by kind]' && ret=0

return ret
