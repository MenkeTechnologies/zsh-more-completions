#compdef svix

_svix() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--server-url=[Svix server URL]:url:' \
        '--auth-token=[authentication token]:token:' \
        '--color=[color output]:when:(auto always never)' \
        '--json[output as JSON]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_svix_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                login)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' && ret=0 ;;
                listen)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' && ret=0 ;;
                application)
                    _arguments -C \
                        '1: :_svix_application_commands' \
                        '*::arg:->app_args' && ret=0
                    case $state in
                        app_args)
                            case $words[1] in
                                list)
                                    _arguments \
                                        '--limit=[number of items]:limit:' \
                                        '--iterator=[pagination iterator]:iterator:' && ret=0 ;;
                                create)
                                    _arguments \
                                        '--name=[application name]:name:' \
                                        '--uid=[optional UID]:uid:' \
                                        '--rate-limit=[rate limit]:limit:' && ret=0 ;;
                                get|update|delete)
                                    _arguments \
                                        '1:app-id:' && ret=0 ;;
                            esac ;;
                    esac ;;
                endpoint)
                    _arguments -C \
                        '1: :_svix_endpoint_commands' \
                        '*::arg:->ep_args' && ret=0
                    case $state in
                        ep_args)
                            case $words[1] in
                                list)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '--limit=[number of items]:limit:' \
                                        '--iterator=[pagination iterator]:iterator:' && ret=0 ;;
                                create)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '--url=[endpoint URL]:url:' \
                                        '--description=[description]:desc:' && ret=0 ;;
                                get|update|delete)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '1:endpoint-id:' && ret=0 ;;
                                recover)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '1:endpoint-id:' && ret=0 ;;
                                replay-missing)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '1:endpoint-id:' && ret=0 ;;
                            esac ;;
                    esac ;;
                message)
                    _arguments -C \
                        '1: :_svix_message_commands' \
                        '*::arg:->msg_args' && ret=0
                    case $state in
                        msg_args)
                            case $words[1] in
                                list)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '--limit=[number of items]:limit:' \
                                        '--iterator=[pagination iterator]:iterator:' && ret=0 ;;
                                create)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '--event-type=[event type]:event-type:' \
                                        '--payload=[JSON payload]:payload:' && ret=0 ;;
                                get)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '1:message-id:' && ret=0 ;;
                            esac ;;
                    esac ;;
                event-type)
                    _arguments -C \
                        '1: :_svix_event_type_commands' \
                        '*::arg:->et_args' && ret=0
                    case $state in
                        et_args)
                            case $words[1] in
                                list)
                                    _arguments \
                                        '--limit=[number of items]:limit:' \
                                        '--iterator=[pagination iterator]:iterator:' && ret=0 ;;
                                create)
                                    _arguments \
                                        '--name=[event type name]:name:' \
                                        '--description=[description]:desc:' && ret=0 ;;
                                get|update|delete)
                                    _arguments \
                                        '1:event-type-name:' && ret=0 ;;
                            esac ;;
                    esac ;;
                message-attempt)
                    _arguments -C \
                        '1: :_svix_message_attempt_commands' \
                        '*::arg:->ma_args' && ret=0
                    case $state in
                        ma_args)
                            case $words[1] in
                                list|list-by-endpoint|list-by-msg)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '--limit=[number of items]:limit:' \
                                        '--iterator=[pagination iterator]:iterator:' && ret=0 ;;
                                get)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '1:attempt-id:' && ret=0 ;;
                                resend)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '1:attempt-id:' && ret=0 ;;
                            esac ;;
                    esac ;;
                integration)
                    _arguments -C \
                        '1: :_svix_integration_commands' \
                        '*::arg:->int_args' && ret=0
                    case $state in
                        int_args)
                            case $words[1] in
                                list)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '--limit=[number of items]:limit:' && ret=0 ;;
                                create)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '--name=[integration name]:name:' && ret=0 ;;
                                get|update|delete|get-key|rotate-key)
                                    _arguments \
                                        '--app-id=[application ID]:app-id:' \
                                        '1:integration-id:' && ret=0 ;;
                            esac ;;
                    esac ;;
                operational-webhook-endpoint)
                    _arguments -C \
                        '1: :_svix_op_webhook_commands' \
                        '*::arg:->ow_args' && ret=0
                    case $state in
                        ow_args)
                            case $words[1] in
                                list)
                                    _arguments \
                                        '--limit=[number of items]:limit:' \
                                        '--iterator=[pagination iterator]:iterator:' && ret=0 ;;
                                create)
                                    _arguments \
                                        '--url=[endpoint URL]:url:' \
                                        '--description=[description]:desc:' && ret=0 ;;
                                get|update|delete)
                                    _arguments \
                                        '1:endpoint-id:' && ret=0 ;;
                            esac ;;
                    esac ;;
            esac ;;
    esac

    return ret
}

(( $+functions[_svix_commands] )) ||
_svix_commands() {
    local -a commands=(
        'login:authenticate with Svix'
        'listen:listen for webhooks'
        'application:manage applications'
        'endpoint:manage endpoints'
        'message:manage messages'
        'event-type:manage event types'
        'message-attempt:manage message attempts'
        'integration:manage integrations'
        'operational-webhook-endpoint:manage operational webhook endpoints'
    )
    _describe -t commands 'svix command' commands
}

(( $+functions[_svix_application_commands] )) ||
_svix_application_commands() {
    local -a commands=(
        'list:list applications'
        'create:create an application'
        'get:get an application'
        'update:update an application'
        'delete:delete an application'
    )
    _describe -t commands 'application command' commands
