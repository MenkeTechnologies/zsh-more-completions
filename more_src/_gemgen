#compdef gemgen
# Documentation: https://man.archlinux.org/search?q=gemgen
# Reference accessed: 2026-05-16

# Zsh completion for gemgen Markdown→Gemtext (~kota/gemgen)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'[output .gmi]:file:_files' \
  '*:Markdown:_files -g "*.md"' && ret=0

return ret
