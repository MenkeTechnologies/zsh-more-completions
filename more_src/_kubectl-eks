#compdef kubectl-eks
# Documentation: https://surajincloud.github.io/kubectl-eks/usage/
# kubectl-eks - kubectl plugin for Amazon EKS

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--cluster=[name of the EKS cluster]:cluster' \
  '--region=[AWS region]:region' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace' \
  '--out[write kubeconfig to file]' \
  '*:command:(kubeconfig addons irsa nodes nodegroups ssm fargate suggest-ami)' && ret=0

return ret
