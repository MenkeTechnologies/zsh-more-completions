#compdef cabal-bounds
# Documentation: https://hackage.haskell.org/package/cabal-bounds
# Manage the dependency version bounds in a .cabal file

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--upper[only update upper bounds]' \
  '--lower[only update lower bounds]' \
  '--haskell-platform=[update using a specific Haskell Platform release version]:version' \
  '--fromfile=[update using library versions from a file]:file:_files' \
  '--lowercomp=[version component for lower bound]:component:(major1 major2 minor)' \
  '--uppercomp=[version component for upper bound]:component:(major1 major2 minor)' \
  '--library[restrict to the library section]' \
  '*--executable=[target a specific executable]:name' \
  '*--testsuite=[target a specific test suite]:name' \
  '*--benchmark=[target a specific benchmark]:name' \
  '*--only=[modify only the specified dependency]:name' \
  '*--ignore=[exclude the specified dependency]:name' \
  '--missing[update only dependencies without existing bounds]' \
  '--output=[output file for the dump command]:file:_files' \
  '1:command:((
    drop\:"drop the bounds of the dependencies"
    update\:"update the bounds by the library versions of the current cabal build"
    dump\:"dump the libraries and their lower bound versions into a file"
    libs\:"print the library names and versions used by the cabal build"
    format\:"reformat the cabal file without modifying dependencies"
  ))' \
  '*::arg:_files' && ret=0

return ret
