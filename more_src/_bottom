#compdef btm bottom

# Zsh completion for bottom/btm (system monitor)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--autohide_time[auto-hide time scale in graphs]' \
  '(-b --basic)'{-b,--basic}'[enable basic mode (no graphs)]' \
  '(-C --config)'{-C,--config}'[path to config file]:config file:_files' \
  '(-t --default_time_value)'{-t,--default_time_value}'[default time value in ms]:time (ms)' \
  '--default_widget_count[set default widget count]:count' \
  '--default_widget_type[set default widget type]:widget:(cpu mem net proc disk temp battery)' \
  '--disable_click[disable mouse click]' \
  '(-m --dot_marker)'{-m,--dot_marker}'[use dot markers instead of braille]' \
  '(-e --expanded)'{-e,--expanded}'[expand default widget on startup]' \
  '--hide_avg_cpu[hide average CPU from showing]' \
  '--hide_table_gap[hide spacing between table headers and entries]' \
  '--hide_time[hide time scale from graphs]' \
  '(-l --left_legend)'{-l,--left_legend}'[put CPU legend on left side]' \
  '--mem_as_value[show memory as values instead of percentages]' \
  '--network_use_binary_prefix[use binary prefix for network data]' \
  '--network_use_bytes[use bytes instead of bits for network data]' \
  '--network_use_log[use logarithmic scale for network graph]' \
  '--process_memory_as_value[show process memory as values]' \
  '(-g --group_processes)'{-g,--group_processes}'[group processes with same name by default]' \
  '(-n --unnormalized_cpu)'{-n,--unnormalized_cpu}'[show non-normalized CPU usage]' \
  '(-R --rate)'{-R,--rate}'[set refresh rate in ms]:rate (ms)' \
  '(-r --regex)'{-r,--regex}'[enable regex by default in search]' \
  '(-d --time_delta)'{-d,--time_delta}'[time delta for zoom in ms]:delta (ms)' \
  '(-S --case_sensitive)'{-S,--case_sensitive}'[enable case-sensitive search by default]' \
  '(-W --whole_word)'{-W,--whole_word}'[enable whole-word search by default]' \
  '--tree[show processes as tree by default]' \
  '--battery[show battery widget]' \
  '--enable_gpu[enable GPU monitoring]' \
  '--retention[data retention time]:time' \
  '(-c --color)'{-c,--color}'[color scheme]:color:(default default-light gruvbox gruvbox-light nord nord-light)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
