#compdef haktldextract
# _haktldextract — hakluke haktldextract CLI minimal TLD top-level-domain extraction utility written in Go reading URLs hostnames on stdin emitting registered-domain TLD subdomain per-line using public-suffix-list authoritative parsing for bug-bounty recon enumeration normalization pipelines (hakluke team, Go); pflag
# upstream: https://github.com/hakluke/haktldextract

_haktldextract() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d[only registered domain]' \
        '--domain[only registered domain]' \
        '-s[only subdomain]' \
        '--subdomain[only subdomain]' \
        '-t[only TLD]' \
        '--tld[only TLD]' \
        '-r[only root domain]' \
        '--root[only root domain]' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '*:input file:_files'
}

_haktldextract "$@"
