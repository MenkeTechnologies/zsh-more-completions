#compdef squawk

# Zsh completion for squawk (sbdchd/squawk); global flags from crates/squawk/src/main.rs,
# usage notes at https://squawkhq.com/docs/cli

local ret=1 i w subcmd=''
local -a g

g=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '*--exclude-path=[paths to skip (repeatable)]:path:_files'
  '(-e --exclude)'{-e+,--exclude=}'[comma-separated rules to disable]:rules:'
  '(-i --include)'{-i+,--include=}'[comma-separated opt-in rules to enable]:rules:'
  '--pg-version=[assume this Postgres version]:version:'
  '--debug=[emit lexer, parser, or AST traces]:format:(lex parse ast)'
  '--reporter=[diagnostic renderer]:reporter:(tty gcc json gitlab)'
  '--stdin-filepath=[virtual path when reading SQL from stdin]:path:'
  '--verbose[verbose logging to stderr]'
  '(-c --config)'{-c+,--config=}'[squawk config toml]:config:_files'
  '--assume-in-transaction[model SQL as running inside a migration transaction block]'
  '--no-assume-in-transaction[undo assume-in-transaction from config or previous flags]'
  '--no-error-on-unmatched-pattern[success when path globs match nothing]'
)

for i in {2..$#words}; do
  w=$words[i]
  if [[ $w == server ]]; then
    subcmd=server
    break
  fi
  if [[ $w == upload-to-github ]]; then
    subcmd=upload-to-github
    break
  fi
  [[ $w == -- ]] && break
done

_squawk_more_positional() {
  if (( CURRENT == 2 )); then
    _alternative \
      'squawk-subcommands:subcommand:(server upload-to-github)' \
      'sql-paths:path:_files'
  else
    _files
  fi
}

if [[ $subcmd == server ]]; then
  _arguments -s -S "$g[@]" && ret=0
elif [[ $subcmd == upload-to-github ]]; then
  _arguments -s -S "$g[@]" \
    '--fail-on-violations[exit with failure when violations are present]' \
    '--github-private-key=[GitHub App PEM path]:PEM:_files' \
    '--github-private-key-base64=[base64-encoded PEM]:string:' \
    '--github-api-url=[GitHub or GHES API root]:url:' \
    '--github-token=[override token]:token:' \
    '--github-app-id=[numeric GitHub App id]:id:' \
    '--github-install-id=[App installation id for the repo]:id:' \
    '--github-repo-owner=[repository owner login]:owner:' \
    '--github-repo-name=[repository name]:repo:' \
    '--github-pr-number=[pull request number]:pr:' \
    '*:paths to search:_files' && ret=0
else
  _arguments -s -S "$g[@]" '*:SQL path or subcommand:_squawk_more_positional' && ret=0
fi

return ret
