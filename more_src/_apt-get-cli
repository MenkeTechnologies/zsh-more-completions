#compdef apt-get-cli
# _apt-get-cli — Debian APT apt-get classic frontend CLI alias (Debian project, C++); custom argparse
# upstream: https://salsa.debian.org/apt-team/apt

_apt-get-cli() {
    local -a sub=(
        'update:update package lists'
        'upgrade:upgrade installed packages'
        'install:install packages'
        'reinstall:reinstall packages'
        'remove:remove packages'
        'purge:remove and purge configuration'
        'autoremove:remove no longer needed deps'
        'source:fetch source packages'
        'build-dep:install build dependencies'
        'check:check broken dependencies'
        'dist-upgrade:distribution upgrade'
        'full-upgrade:full upgrade'
        'dselect-upgrade:legacy dselect-style upgrade'
        'clean:clean apt cache'
        'autoclean:autoclean apt cache'
        'download:download package without install'
        'changelog:show changelog'
        'indextargets:show index targets'
        'satisfy:satisfy dep strings'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--simulate[simulate]' \
        '-s[simulate]' \
        '--dry-run[dry run]' \
        '--just-print[just print]' \
        '--recon[recon]' \
        '--no-act[no act]' \
        '--show-upgraded[show upgraded]' \
        '-u[show upgraded]' \
        '--allow-downgrades[allow downgrades]' \
        '--allow-remove-essential[allow remove essential]' \
        '--allow-change-held-packages[allow change held]' \
        '--no-install-recommends[no install recommends]' \
        '--install-recommends[install recommends]' \
        '--no-install-suggests[no install suggests]' \
        '--install-suggests[install suggests]' \
        '--download-only[download only]' \
        '-d[download only]' \
        '--no-download[no download]' \
        '--force-yes[force yes]' \
        '--assume-yes[assume yes]' \
        '-y[assume yes]' \
        '--assume-no[assume no]' \
        '--fix-broken[fix broken]' \
        '-f[fix broken]' \
        '--fix-missing[fix missing]' \
        '-m[fix missing]' \
        '--ignore-missing[ignore missing]' \
        '--no-upgrade[no upgrade]' \
        '--only-upgrade[only upgrade]' \
        '--print-uris[print URIs]' \
        '--reinstall[reinstall]' \
        '--list-cleanup[list cleanup]' \
        '--no-list-cleanup[no list cleanup]' \
        '--auto-remove[auto remove]' \
        '--purge[purge]' \
        '--allow-unauthenticated[allow unauthenticated]' \
        '--target-release=+[target release]:str:' \
        '-t+[target release]:str:' \
        '--option=+[apt option]:str:' \
        '-o+[apt option]:str:' \
        '--config-file=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--show-progress[show progress]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'apt-get subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|purge|reinstall|source|build-dep|download|changelog|satisfy) _arguments '*:package:' ;;
            esac
            ;;
    esac
}

_apt-get-cli "$@"
