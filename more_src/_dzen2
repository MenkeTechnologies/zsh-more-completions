#compdef dzen2

_arguments -s -S \
  '(- *)'-v'[show version]' \
  '-fg[set foreground color]:color' \
  '-bg[set background color]:color' \
  '-fn[set font]:font' \
  '-ta[set title alignment]:alignment:(l c r)' \
  '-tw[set title width]:width' \
  '-sa[set slave alignment]:alignment:(l c r)' \
  '-l[set number of lines in slave window]:lines' \
  '-e[set events and actions]:event string' \
  '-m[enable menu mode]' \
  '-u[update contents]' \
  '-p[persist for seconds or indefinitely]:seconds' \
  '-x[set x position]:x position' \
  '-y[set y position]:y position' \
  '-w[set width]:width' \
  '-h[set line height]:height' \
  '-xs[set xinerama screen]:screen number' \
  '-dock[set _NET_WM_WINDOW_TYPE_DOCK]'
