#compdef polar polar-migrate

# Zsh completion for Polar CLI
# https://polar.sh

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:Authenticate with Polar'
  'logout:Remove local credentials'
  'listen:Forward webhooks to local server'
  'init:Initialize a new Polar project'
  'help:Display help'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'polar command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (listen)
        _arguments -s -S \
          '--forward-to=[forward webhooks to URL]:url:_urls' && ret=0
        ;;
    esac
    ;;
esac

return ret
