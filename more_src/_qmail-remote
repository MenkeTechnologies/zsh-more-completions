#compdef qmail-remote
# _qmail-remote — qmail's remote-delivery agent (SMTPs message read from stdin to a remote MX; spawned by qmail-rspawn — does not follow getopt conventions; respects $QMAILREMOTE override)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-remote.8 on tip; positional args only.

_qmail-remote() {
    _arguments \
        '1:host:_hosts' \
        '2:sender:_email_addresses' \
        '*:recipient:_email_addresses'
}

_qmail-remote "$@"
