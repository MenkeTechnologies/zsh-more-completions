#compdef ysql_dumpall
# Documentation: https://docs.yugabyte.com/preview/admin/ysql-dumpall/
# YugabyteDB YSQL cluster-wide (all databases) dump utility

local ret=1

_arguments -s -S \
  '(-a --data-only)'{-a,--data-only}'[dump only the data, not the schema]' \
  '(-c --clean)'{-c,--clean}'[clean (drop) databases before recreating]' \
  '(-E --encoding)'{-E,--encoding=}'[dump the data in given character set encoding]:encoding' \
  '(-f --file)'{-f,--file=}'[output file]:file:_files' \
  '(-g --globals-only)'{-g,--globals-only}'[dump only global objects, no databases]' \
  '(-o --oids)'{-o,--oids}'[include OIDs in the dump]' \
  '(-O --no-owner)'{-O,--no-owner}'[skip restoration of object ownership]' \
  '(-r --roles-only)'{-r,--roles-only}'[dump only roles, no databases or tablespaces]' \
  '(-s --schema-only)'{-s,--schema-only}'[dump only the schema, no data]' \
  '(-S --superuser)'{-S,--superuser=}'[superuser name to use in the dump]:username' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '(-V --version)'{-V,--version}'[output version information and exit]' \
  '(-x --no-privileges)'{-x,--no-privileges}'[do not dump privileges (grant/revoke)]' \
  '--column-inserts[dump data as INSERT commands with column names]' \
  '--disable-dollar-quoting[disable dollar quoting, use SQL standard quoting]' \
  '--disable-triggers[disable triggers during data-only restore]' \
  '--if-exists[use IF EXISTS when dropping objects]' \
  '--inserts[dump data as INSERT commands rather than COPY]' \
  '--load-via-partition-root[load partitions via the root table]' \
  '--lock-wait-timeout=[fail after waiting TIMEOUT for a table lock]:timeout' \
  '--no-comments[do not dump comments]' \
  '--no-publications[do not dump publications]' \
  '--no-role-passwords[do not dump passwords for roles]' \
  '--no-security-labels[do not dump security label assignments]' \
  '--no-subscriptions[do not dump subscriptions]' \
  '--no-sync[do not wait for changes to be written safely to disk]' \
  '--no-unlogged-table-data[do not dump unlogged table data]' \
  '--quote-all-identifiers[quote all identifiers, even if not key words]' \
  '--use-set-session-authorization[use SET SESSION AUTHORIZATION instead of ALTER OWNER]' \
  '(-d --dbname)'{-d,--dbname=}'[connect using given connection string]:dbname' \
  '(-h --host)'{-h,--host=}'[database server host or socket directory]:host:_hosts' \
  '(-l --database)'{-l,--database=}'[alternative default database]:dbname' \
  '(-p --port)'{-p,--port=}'[database server port number]:port' \
  '(-U --username)'{-U,--username=}'[connect as specified database user]:username' \
  '(-w --no-password)'{-w,--no-password}'[never prompt for password]' \
  '(-W --password)'{-W,--password}'[force password prompt]' \
  '--role=[do SET ROLE before dump]:rolename' \
  '(- *)'{-\?,--help}'[show help and exit]' && ret=0

return ret
