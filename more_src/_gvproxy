#compdef gvproxy
# Documentation: https://github.com/containers/gvisor-tap-vsock/blob/main/README.md
# gvproxy - userspace network stack proxy for gvisor-tap-vsock

local ret=1

_arguments -s -S \
  '-debug[enable debug mode]' \
  '*-listen=[listening address (unix:// tcp:// vsock://)]:addr:' \
  '-listen-qemu=[QEMU-specific listening address]:addr:' \
  '-listen-bess=[BESS socket transport listening address]:addr:' \
  '-listen-vfkit=[vfkit listening address]:addr:' \
  '-services=[expose HTTP API without the /connect endpoint]:addr:' \
  '-notification=[unix socket for hypervisor and network event notifications]:socket:' \
  '(-h -help --help)'{-h,-help,--help}'[show help]' && ret=0

return ret
