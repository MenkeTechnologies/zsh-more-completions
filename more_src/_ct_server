#compdef ct_server
# _ct_server — Google Certificate Transparency log frontend (Trillian CTFE)
# upstream: https://github.com/google/certificate-transparency-go
# Flags from trillian/ctfe/ct_server/main.go on tip.

_ct_server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-http_endpoint=[HTTP bind host\:port]:host\:port:' \
        '-http_idle_timeout=[HTTP idle connection timeout]:dur:' \
        '-tls_certificate=[TLS server cert file]:file:_files' \
        '-tls_key=[TLS server key file]:file:_files' \
        '-metrics_endpoint=[metrics bind host\:port (empty=via http_endpoint)]:host\:port:' \
        '-log_rpc_server=[Trillian backend host\:port or etcd service name]:spec:' \
        '-rpc_deadline=[backend RPC deadline]:dur:' \
        '-get_sth_interval=[internal get-sth interval (0=disable)]:dur:' \
        '-log_config=[log config file (text proto)]:file:_files' \
        '-max_get_entries=[max entries per get-entries request (0=default 1000)]:n:' \
        '-etcd_servers=[comma-separated etcd servers]:csv:' \
        '-etcd_http_service=[etcd HTTP service name]:name:' \
        '-etcd_metrics_service=[etcd metrics HTTP service name]:name:' \
        '-mask_internal_errors=[mask internal errors from clients]:bool:(true false)' \
        '-tracing=[enable OpenCensus Stackdriver tracing]:bool:(true false)' \
        '-tracing_project_id=[GCP project ID for tracing]:id:' \
        '-tracing_percent=[%% of requests to trace]:n:' \
        '-quota_remote=[enable per-source-IP quota]:bool:(true false)' \
        '-quota_intermediate=[enable per-intermediate-cert quota]:bool:(true false)' \
        '-non_fresh_submission_age=[max age for fresh submissions]:dur:'
}

_ct_server "$@"
