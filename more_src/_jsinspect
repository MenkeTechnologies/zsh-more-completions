#compdef jsinspect
# Documentation: https://github.com/danielstjules/jsinspect
# jsinspect - detect copy-pasted and structurally similar code

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[output usage information]' \
  '(-V --version)'{-V,--version}'[output the version number]' \
  '(-t --threshold)'{-t,--threshold}'=[number of nodes (default 30)]:nodes' \
  '(-m --min-instances)'{-m,--min-instances}'=[min instances for a match (default 2)]:instances' \
  '(-c --config)'{-c,--config}'=[path to config file (default .jsinspectrc)]:config:_files' \
  '(-r --reporter)'{-r,--reporter}'=[specify the reporter to use]:reporter:(default json pmd)' \
  '(-I --no-identifiers)'{-I,--no-identifiers}'[do not match identifiers]' \
  '(-L --no-literals)'{-L,--no-literals}'[do not match literals]' \
  '(-C --no-color)'{-C,--no-color}'[disable colors]' \
  '--ignore=[ignore paths matching a regex]:pattern' \
  '--truncate=[length to truncate lines (default 100, off 0)]:length' \
  '--debug[print debug information]' \
  '*:path:_files' && ret=0

return ret
