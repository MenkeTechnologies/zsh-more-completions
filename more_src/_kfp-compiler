#compdef kfp-compiler
# _kfp-compiler — Kubeflow Pipelines v2 pipeline-spec → Argo Workflow compiler (kubeflow/pipelines)
# upstream: https://github.com/kubeflow/pipelines
# Flags from backend/src/v2/cmd/compiler/main.go on tip.

_kfp-compiler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--spec=[pipeline spec file path]:file:_files' \
        '--job=[pipeline job file path]:file:_files' \
        '--launcher=[v2 launcher image]:image:' \
        '--driver=[v2 driver image]:image:' \
        '--pipeline_root=[pipeline root storage prefix]:uri:' \
        '--cache_disabled=[disable caching globally]:bool:(true false)'
}

_kfp-compiler "$@"
