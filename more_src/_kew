#compdef kew
# Documentation: https://man.archlinux.org/search?q=kew
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'all:play all songs shuffled'
  'albums:play all albums in random order'
  'artists:play all artists shuffled'
  'random:play random track'
  'genres:browse genres'
  'list:show track list'
  'shuffle:shuffle current playlist'
  'songs:list songs'
  'help:show help'
)

_arguments -C \
  '(-h --help -?)'{-h,--help,-\?}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-e --exact)'{-e,--exact}'[exact match search]' \
  '(-q --quitonstop)'{-q,--quitonstop}'[exit on playlist end]' \
  '--nocover[disable album cover]' \
  '--noui[hide all UI]' \
  '--no-config[do not load config]' \
  '--gapless=[gapless playback]:bool:(true false)' \
  '--quitonstop[quit on stop]' \
  '--allow-notifications[enable system notifications]' \
  '--config-dir=[config dir]:dir:_files -/' \
  '--cache-dir=[cache dir]:dir:_files -/' \
  '--theme=[theme name]:theme:' \
  '*:music:_files -g "*.mp3 *.flac *.ogg *.opus *.aac *.m4a *.wav *.aiff *.webm"' && ret=0

case $state in
  (cmd) _describe -t cmds 'kew command' commands && ret=0 ;;
esac

return ret
