#compdef kew
# Documentation: https://github.com/ravachol/kew/blob/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
local -a commands

commands=(
  'all:play all songs in your library, shuffled'
  'albums:play all albums in random order'
  'artists:play all artists shuffled'
  'dir:specify a directory search'
  'song:specify a song search'
  'play:play specific paths'
  'list:load a playlist'
  'shuffle:shuffle the playlist'
)

_arguments -C \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-e --exact)'{-e,--exact}'[exact (case-insensitive) match]' \
  '(-q --quitonstop)'{-q,--quitonstop}'[exit after playlist ends]' \
  '--nocover[disable album cover]' \
  '--noui[completely hide the UI]' \
  '1:command:->cmd' \
  '*:music:_files -g "*.mp3 *.flac *.ogg *.opus *.aac *.m4a *.wav *.aiff *.webm"' && ret=0

case $state in
  (cmd) _describe -t cmds 'kew command' commands && ret=0 ;;
esac

return ret
