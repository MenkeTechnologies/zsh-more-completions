#compdef gospider

# Zsh completion for GoSpider web crawler

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-s+[site to crawl]:url' \
  '-S+[file containing list of sites]:file:_files' \
  '-p+[proxy URL]:proxy' \
  '-a+[user agent]:user agent' \
  '-d+[crawl depth]:depth' \
  '-c+[number of concurrent requests]:concurrency' \
  '-t+[request timeout in seconds]:seconds' \
  '-o+[output folder]:directory:_directories' \
  '--other-source[find URLs from other sources (Archive.org, CommonCrawl)]' \
  '--include-subs[include subdomains]' \
  '--include-other-source[include URLs from other sources in output]' \
  '-r[include robots.txt entries]' \
  '--sitemap[include sitemap.xml entries]' \
  '--json[output as JSON]' \
  '-q[quiet mode, suppress output]' \
  '--no-redirect[disable following redirects]' \
  '--cookie=[cookie to include in requests]:cookie' \
  '*--header=[custom header]:header' \
  '--burp=[import target from Burp Suite file]:file:_files' \
  '-l+[URL length limit]:length' \
  '-L+[maximum URL length]:length' \
  '*--blacklist=[blacklist URL regex]:regex' \
  '*--whitelist=[whitelist URL regex]:regex' \
  && ret=0

return ret
