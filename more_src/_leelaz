#compdef leelaz
# _leelaz — Leela Zero Go engine (leela-zero/leela-zero)
# upstream: https://github.com/leela-zero/leela-zero
# Flags from src/Leela.cpp (boost::program_options).

_leelaz() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-g --gtp)'{-g,--gtp}'[enable GTP mode]' \
        '(-t --threads)'{-t+,--threads=}'[number of threads (0 = auto)]:n:' \
        '(-p --playouts)'{-p+,--playouts=}'[limit number of playouts]:n:' \
        '(-v --visits)'{-v+,--visits=}'[limit number of visits]:n:' \
        '(-b --lagbuffer)'{-b+,--lagbuffer=}'[lag buffer (centiseconds)]:cs:' \
        '(-r --resignpct)'{-r+,--resignpct=}'[resign percentage]:pct:' \
        '(-w --weights)'{-w+,--weights=}'[neural network weights file]:file:_files' \
        '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
        '(-q --quiet)'{-q,--quiet}'[disable all diagnostic output]' \
        '--timemanage=[time management]:mode:(auto on off fast)' \
        '--noponder[disable thinking on opponent time]' \
        '--benchmark[test network and exit]' \
        '--cpu-only[CPU-only implementation]' \
        '*--gpu=[GPU device index (repeatable)]:n:' \
        '--full-tuner[try harder to tune OpenCL]' \
        '--tune-only[tune OpenCL then exit]' \
        '--batchsize=[OpenCL batch size]:n:' \
        '--precision=[neural net precision]:precision:(single half auto)' \
        '(-n --noise)'{-n,--noise}'[enable policy randomization]' \
        '(-s --seed)'{-s+,--seed=}'[random seed]:seed:' \
        '(-d --dumbpass)'{-d,--dumbpass}'[disable smart passing heuristics]' \
        '(-m --randomcnt)'{-m+,--randomcnt=}'[random move count]:n:' \
        '--randomvisits=[minimum visits for random move]:n:' \
        '--randomtemp=[random temperature]:t:' \
        '--puct=[PUCT exploration constant]:value:' \
        '--logpuct=[log PUCT constant]:value:' \
        '--logconst=[log constant]:value:' \
        '--softmax_temp=[softmax temperature]:value:' \
        '--fpu_reduction=[FPU reduction]:value:' \
        '--ci_alpha=[CI alpha for analysis]:value:' \
        '*:arguments:'
}

_leelaz "$@"
