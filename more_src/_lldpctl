#compdef lldpctl

# Zsh completion for lldpctl - LLDP daemon control

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --format)'{-f,--format}'[output format]:format:(plain keyvalue json json0 xml)' \
  '(-L --listen)'{-L,--listen}'[listen for LLDP events]' \
  '(-r --raw)'{-r,--raw}'[show raw TLVs]' \
  '(-u --socket)'{-u,--socket}'[set lldpd socket path]:socket:_files' \
  '(-N --neighbors)'{-N,--neighbors}'[show only neighbors information]' \
  '(-S --statistics)'{-S,--statistics}'[show statistics]' \
  '(-C --configuration)'{-C,--configuration}'[show configuration]' \
  '(-w --watch)'{-w,--watch}'[watch for changes]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:interface' && ret=0

return ret
