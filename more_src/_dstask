#compdef dstask

# Zsh completion for dstask - single binary task manager in Go

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add a new task'
  'next:show next tasks (default)'
  'show-next:show next tasks'
  'show-projects:show projects summary'
  'show-tags:show all tags'
  'show-active:show active tasks'
  'show-open:show open tasks'
  'show-paused:show paused tasks'
  'show-resolved:show resolved tasks'
  'show-unresolved:show unresolved tasks'
  'show-templates:show templates'
  'start:start a task'
  'stop:stop a task'
  'done:mark task done'
  'resolve:mark task done'
  'context:set or show current context'
  'undo:undo most recent action'
  'remove:remove a task'
  'rm:remove a task'
  'edit:edit task in $EDITOR'
  'modify:modify a task'
  'note:edit a task note'
  'n:edit a task note'
  'log:log an already completed task'
  'template:create a template'
  'open:open URL associated with task'
  'import-todoist:import from Todoist'
  'import-taskwarrior:import from Taskwarrior'
  'git:wrap git for the repository'
  'sync:pull and push via git'
  'export:export tasks as JSON'
  'gc:garbage collect resolved tasks'
  'version:show version info'
  'help:show help'
  'completion:generate shell completion'
)

_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'dstask command' commands && ret=0
    ;;
  args)
    case $words[1] in
      context)
        _message 'context expression (project: +tag -tag or "none")' && ret=0
        ;;
      template)
        _message 'template expression' && ret=0
        ;;
      *)
        _message 'task id or filter' && ret=0
        ;;
    esac
    ;;
esac

return ret
