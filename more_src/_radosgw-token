#compdef radosgw-token
# Documentation: https://docs.ceph.com/en/latest/man/8/radosgw-token/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# radosgw-token: create/verify temporary radosgw access tokens
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--access=[access key]:key:' \
  '--secret=[secret key]:key:' \
  '--ttype=[token type]:type:(s3 swift)' \
  '*::radosgw-token args:_files' && ret=0
return ret
