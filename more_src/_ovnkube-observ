#compdef ovnkube-observ
# _ovnkube-observ — OVN-K sFlow/Sample observability tool (ovn-kubernetes/ovn-kubernetes)
# upstream: https://github.com/ovn-kubernetes/ovn-kubernetes
# Flags from go-controller/cmd/ovnkube-observ/ovnkubeobserv.go on tip.

_ovnkube-observ() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-enable-enrichment=[enrich samples with NB DB data]:bool:(true false)' \
        '-log-cookie[print raw sample cookie + psample group_id]' \
        '-print-full-packet[print full packet rather than only src/dst IPs]' \
        '-add-ovs-collector[install OVS collector to enable sampling]' \
        '-output-file=[file to append samples to]:file:_files' \
        '-filter-src-ip=[only print samples from this source IP]:ip:' \
        '-filter-dst-ip=[only print samples to this destination IP]:ip:'
}

_ovnkube-observ "$@"
