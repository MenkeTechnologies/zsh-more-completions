#compdef sfheaderattr
# Documentation: https://raw.githubusercontent.com/ahay/src/master/system/seismic/Mheaderattr.c
# Madagascar: display header attributes (only nonzero values are reported)

local ret=1

_arguments -s \
  'segy=[if y input headers follow SEGY format]:segy:(y n)' \
  'desc=[if y provide descriptive text for each header key]:desc:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
