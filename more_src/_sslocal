#compdef sslocal

_arguments -s \
  '(-c --config)'{-c,--config}'=[config file]:file:_files -g "*.json"' \
  '(-b --local-addr)'{-b,--local-addr}'=[local listen address]:addr:' \
  '-u[UDP only]' \
  '-U[TCP and UDP]' \
  '--protocol=[protocol]:proto:(socks http tunnel redir tun)' \
  '--udp-bind-addr=[UDP bind address]:addr:' \
  '--udp-associate-addr=[UDP associate address]:addr:' \
  '(-s --server-addr)'{-s,--server-addr}'=[server address]:addr:' \
  '(-k --password)'{-k,--password}'=[password]:password:' \
  '(-m --encrypt-method)'{-m,--encrypt-method}'=[cipher]:cipher:' \
  '--timeout=[connection timeout]:s:' \
  '--plugin=[SIP003 plugin]:plugin:' \
  '--plugin-mode=[plugin mode]:mode:(tcp udp tcp_and_udp)' \
  '--plugin-opts=[plugin options]:opts:' \
  '--server-url=[ss:// URL]:url:' \
  '--acl=[ACL file]:file:_files' \
  '--dns=[DNS resolver]:dns:' \
  '--dns-cache-size=[DNS cache size]:n:' \
  '--tcp-no-delay[TCP no-delay]' \
  '--no-delay[TCP no-delay]' \
  '--tcp-fast-open[TCP fast open]' \
  '--fast-open[TCP fast open]' \
  '--tcp-keep-alive=[TCP keepalive seconds]:s:' \
  '--tcp-multipath[multipath TCP]' \
  '--mptcp[multipath TCP]' \
  '--udp-timeout=[UDP timeout]:s:' \
  '--udp-max-associations=[UDP max associations]:n:' \
  '--inbound-send-buffer-size=[inbound send buffer]:bytes:' \
  '--inbound-recv-buffer-size=[inbound recv buffer]:bytes:' \
  '--outbound-send-buffer-size=[outbound send buffer]:bytes:' \
  '--outbound-recv-buffer-size=[outbound recv buffer]:bytes:' \
  '--outbound-bind-addr=[outbound bind addr]:addr:' \
  '--bind-addr=[outbound bind addr]:addr:' \
  '--outbound-bind-interface=[outbound iface]:iface:_net_interfaces' \
  '-6[prefer IPv6]' \
  '*-v[verbose]' \
  '--log-without-time[no timestamps in log]' \
  '--log-config=[log config file]:file:_files' \
  '(-f --forward-addr)'{-f,--forward-addr}'=[tunnel forward address]:addr:' \
  '(-n --nofile)'{-n,--nofile}'=[nofile rlimit]:n:' \
  '--outbound-fwmark=[outbound fwmark]:n:' \
  '--outbound-user-cookie=[outbound user cookie]:n:' \
  '--tcp-redir=[TCP redir type]:type:' \
  '--udp-redir=[UDP redir type]:type:' \
  '--vpn[VPN mode (Android)]' \
  '--stat-path=[stat unix socket]:file:_files' \
  '--stat-addr=[stat addr]:addr:' \
  '--local-dns-addr=[local DNS addr]:addr:' \
  '--remote-dns-addr=[remote DNS addr]:addr:' \
  '--dns-addr=[DNS addr]:addr:' \
  '--tun-interface-name=[TUN iface name]:name:' \
  '--tun-interface-address=[TUN iface address]:net:' \
  '--tun-interface-destination=[TUN iface destination]:net:' \
  '--tun-device-fd-from-path=[TUN fd path]:file:_files' \
  '--fake-dns-record-expire-duration=[fake DNS expire]:duration:' \
  '--fake-dns-ipv4-network=[fake DNS IPv4 network]:net:' \
  '--fake-dns-ipv6-network=[fake DNS IPv6 network]:net:' \
  '--fake-dns-database-path=[fake DNS db]:file:_files' \
  '(-d --daemonize)'{-d,--daemonize}'[daemonize]' \
  '--daemonize-pid=[pid file]:file:_files' \
  '--single-threaded[single threaded runtime]' \
  '--worker-threads=[worker threads]:n:' \
  '(-a --user)'{-a,--user}'=[run as user]:user:_users' \
  '--online-config-url=[online config URL]:url:' \
  '--online-config-update-interval=[online config interval s]:s:' \
  '*--online-config-allowed-plugin=[allowed online plugin]:plugin:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
