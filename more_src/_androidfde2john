#compdef androidfde2john axcrypt2john dashlane2john ecryptfs2john filezilla2john ikescan2john lotus2john pfx2john sap2john sipdump2john vmx2john
# Documentation: https://github.com/openwall/john (bleeding-jumbo branch)
#                — sources read directly from run/*.py and run/*.pl
# Reference accessed: 2026-05-30
# John the Ripper *2john helpers, round 2. Extends the round-144 _unshadow
# multi-stem with 11 more hash extractors covering Android FDE, AxCrypt,
# Dashlane, eCryptfs, FileZilla Server, ike-scan PSK output, Lotus Notes,
# PKCS#12, SAP CODVN hashes, SIPdump, and VMware encrypted vmx files.
# Per-stem surfaces transcribed from upstream source rather than from
# Debian dyn-redirect manpages (which 404).

local curcontext="$curcontext" state line ret=1

case $service in

  androidfde2john)
    # run/androidfde2john.py — exactly 2 positionals.
    # Note: only old Android <= 4.3 disk images, AES-256/CBC-ESSIV-SHA-256.
    _arguments -s -S \
      '1:data partition or image:_files' \
      '2:footer partition or image:_files' \
      && ret=0
    ;;

  axcrypt2john)
    # run/axcrypt2john.py — 1 required .axx + 1 optional KEY-FILE.
    _arguments -s -S \
      '1:AxCrypt encrypted file or self-decrypting binary:_files -g "*.(axx|exe)"' \
      '2:optional keyfile:_files' \
      && ret=0
    ;;

  dashlane2john)
    # run/dashlane2john.py — 1+ .aes / .dash files.
    _arguments -s -S \
      '*:Dashlane database file:_files -g "*.(aes|dash)"' \
      && ret=0
    ;;

  ecryptfs2john)
    # run/ecryptfs2john.py — 1 required wrapped-passphrase + 1 optional .ecryptfsrc.
    _arguments -s -S \
      '1:wrapped-passphrase file:_files' \
      '2:optional .ecryptfsrc config file:_files' \
      && ret=0
    ;;

  filezilla2john)
    # run/filezilla2john.py — 1+ FileZilla Server.xml configuration files.
    _arguments -s -S \
      '*:FileZilla Server.xml file:_files -g "*.xml"' \
      && ret=0
    ;;

  ikescan2john)
    # run/ikescan2john.py — 1 required psk-parameters file + 1 optional norteluser string.
    # With 1 arg: outputs $ike$*0*<data>. With 2 args: outputs $ike$*1*<user>*<data>.
    _arguments -s -S \
      '1:psk-parameters file from ike-scan:_files' \
      '2:optional Nortel username:' \
      && ret=0
    ;;

  lotus2john)
    # run/lotus2john.py — 1+ Lotus Notes ID files.
    _arguments -s -S \
      '*:Lotus Notes ID file:_files -g "*.id"' \
      && ret=0
    ;;

  pfx2john)
    # run/pfx2john.py — 1+ PKCS#12 (.pfx) files. Depends on asn1crypto.
    _arguments -s -S \
      '*:PKCS#12 file:_files -g "*.(pfx|p12)"' \
      && ret=0
    ;;

  sap2john)
    # run/sap2john.pl — 1 input file (or -) + optional 6-letter CODVN selector.
    # Default selector is BFH. Allowed letters: A B D E F H.
    _arguments -s -S \
      "1:SAP hash input file or - for stdin:_files" \
      '2:CODVN selector (subset of ABDEFH, default BFH):' \
      && ret=0
    ;;

  sipdump2john)
    # run/sipdump2john.py — 1+ sipdump files.
    _arguments -s -S \
      '*:sipdump file:_files' \
      && ret=0
    ;;

  vmx2john)
    # run/vmx2john.py — 1+ VMware .vmx config files.
    _arguments -s -S \
      '*:VMware vmx file:_files -g "*.vmx"' \
      && ret=0
    ;;

esac

return ret
