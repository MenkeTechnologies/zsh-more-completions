#compdef eexpmap
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/eexpmap/node5.html
# XMM-Newton SAS: create EPIC exposure maps

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--imageset=[name of EPIC FITS image]:file:_files' \
  '--attitudeset=[name of attitude file]:file:_files' \
  '--eventset=[event file (bad pixel/exposure extensions)]:file:_files' \
  '--expimageset=[name(s) of output exposure image(s)]:file:_files' \
  '--withdetcoords=[output exposure map in detector coordinates]:flag:(yes no)' \
  '--withvignetting=[include vignetting effects]:flag:(yes no)' \
  '--usefastpixelization=[speed up computation (less accurate borders)]:flag:(yes no)' \
  '--attrebin=[positional accuracy of attitude rebinning (arcsec)]:arcsec:' \
  '--pimin=[lower PI energy boundaries]:ev:' \
  '--pimax=[upper PI energy boundaries]:ev:' \
  '--usedlimap=[use discarded line maps from epexposure]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
