#compdef autopano

# autopano: command-line panorama control-point detection (Hugin)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-i[input pto]:file:_files -g "*.pto"' \
  '-o[output pto]:file:_files -g "*.pto"' \
  '-d[downsample factor]:n:' \
  '-r[match ratio (0..1)]:val:' \
  '-c[max number of control points per pair]:n:' \
  '-s[size scale]:val:' \
  '--ransac=[RANSAC iterations]:n:' \
  '--projection=[projection model]:proj:(0 1 2 3)' \
  '*:image files:_files -g "*.(jpg|jpeg|tiff|tif|png)"' && ret=0
return ret
