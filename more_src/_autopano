#compdef autopano
# Documentation: https://man.archlinux.org/search?q=autopano
# Reference accessed: 2026-05-16

# autopano (panomatic-style): find control points across overlapping photos
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-o[output file (.pto)]:file:_files -g "*.pto"' \
  '-n[match radius around each feature]:n:' \
  '-c[max control points per image pair]:n:' \
  '-r[ransac threshold]:n:' \
  '-s[downsample factor]:n:' \
  '-f[forced overlap pairs file]:file:_files' \
  '*:input images:_files -g "*.(jpg|jpeg|tif|tiff|png|cr2|nef|arw|raf|orf|dng)"' && ret=0
return ret
