#compdef restic-cli
# Documentation: https://man.archlinux.org/search?q=restic-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'backup:create new backup'
  'cache:cache management'
  'cat:print internal objects'
  'check:check repository integrity'
  'copy:copy snapshots between repos'
  'diff:diff two snapshots'
  'dump:dump file from snapshot to stdout'
  'features:show feature flags'
  'find:find file in snapshots'
  'forget:remove snapshots from repo'
  'generate:generate man/auto-completion'
  'help:show help'
  'init:initialize repository'
  'key:manage repo keys'
  'list:list objects in repo'
  'ls:list files in snapshot'
  'migrate:apply migrations'
  'mount:mount repo as FUSE'
  'options:show all options'
  'prune:remove unused data'
  'rebuild-index:rebuild repo index'
  'recover:recover lost snapshots'
  'repair:repair commands'
  'restore:extract files from snapshot'
  'rewrite:rewrite snapshots'
  'self-update:update restic itself'
  'snapshots:list snapshots'
  'stats:show snapshot statistics'
  'tag:modify snapshot tags'
  'unlock:remove locks'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--cacert=[file]:file:_files' \
  '*--cache-dir=[dir]:dir:_files -/' \
  '*--cleanup-cache[clean unused cache]' \
  '*--compression=[level]:l:(auto off max)' \
  '*--http-user-agent=[ua]:ua:' \
  '*--insecure-no-password[disable password]' \
  '*--insecure-tls[insecure TLS]' \
  '*--json[JSON output]' \
  '*--key-hint=[key id]:k:' \
  '*--limit-download=[KiB/s]:n:' \
  '*--limit-upload=[KiB/s]:n:' \
  '*--no-cache[no cache]' \
  '*--no-extra-verify[no extra verify]' \
  '*--no-lock[no lock]' \
  '*-o+[k=v option]:v:' \
  '*--option=[k=v option]:v:' \
  '*--pack-size=[MiB]:n:' \
  '*--password-command=[cmd]:c:' \
  '*-p+[password file]:file:_files' \
  '*--password-file=[file]:file:_files' \
  '*-q[quiet]' \
  '*--quiet[quiet]' \
  '*-r+[repo]:repo:' \
  '*--repo=[repo]:repo:' \
  '*--repository-file=[file]:file:_files' \
  '*--retry-lock=[duration]:t:' \
  '*--tls-client-cert=[file]:file:_files' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'restic command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (backup)
        _arguments \
          '(-e --exclude)*'{-e+,--exclude=}'[pattern]:p:' \
          '(--exclude-caches)--exclude-caches[exclude CACHEDIR.TAG]' \
          '(--exclude-cloud-files)--exclude-cloud-files[exclude cloud files]' \
          '(--exclude-file)*--exclude-file=[file]:file:_files' \
          '(--exclude-if-present)*--exclude-if-present=[name]:n:' \
          '(--exclude-larger-than)--exclude-larger-than=[size]:s:' \
          '(--files-from)*--files-from=[file]:file:_files' \
          '(--files-from-raw)*--files-from-raw=[file]:file:_files' \
          '(--files-from-verbatim)*--files-from-verbatim=[file]:file:_files' \
          '(--force -f)'{-f,--force}'[force re-read]' \
          '(--group-by -g)'{-g+,--group-by=}'[criteria]:g:(host paths tags)' \
          '(-H --host)'{-H+,--host=}'[host name]:h:_hosts' \
          '(--iexclude)*--iexclude=[pattern (case insensitive)]:p:' \
          '(--iexclude-file)*--iexclude-file=[file]:file:_files' \
          '(--ignore-ctime)--ignore-ctime[no ctime check]' \
          '(--ignore-inode)--ignore-inode[no inode check]' \
          '(--no-scan)--no-scan[no scan]' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '(--one-file-system -x)'{-x,--one-file-system}'[one fs]' \
          '(--parent)--parent=[snapshot id]:id:' \
          '(--read-concurrency)--read-concurrency=[n]:n:' \
          '(--skip-if-unchanged)--skip-if-unchanged[skip unchanged]' \
          '(--stdin)--stdin[read from stdin]' \
          '(--stdin-filename)--stdin-filename=[name]:n:' \
          '(--stdin-from-command)--stdin-from-command[read stdin from cmd]' \
          '(--tag)*--tag=[tag]:t:' \
          '(--time)--time=[ts]:t:' \
          '(--with-atime)--with-atime[backup atime]' \
          '*: :_files' && ret=0 ;;
      (restore)
        _arguments \
          '(-e --exclude)*'{-e+,--exclude=}'[pattern]:p:' \
          '(-i --include)*'{-i+,--include=}'[pattern]:p:' \
          '(--iexclude)*--iexclude=[pattern]:p:' \
          '(--iinclude)*--iinclude=[pattern]:p:' \
          '(-H --host)*'{-H+,--host=}'[host]:h:_hosts' \
          '(--path)*--path=[path]:p:' \
          '(--tag)*--tag=[tag]:t:' \
          '(-t --target)'{-t+,--target=}'[output dir]:dir:_files -/' \
          '(--verify)--verify[verify after restore]' \
          '(--include-file)*--include-file=[file]:file:_files' \
          '(--exclude-file)*--exclude-file=[file]:file:_files' \
          '(--overwrite)--overwrite=[when]:w:(always if-changed if-newer never)' \
          '(--delete)--delete[delete extras]' \
          '(--sparse)--sparse[restore sparse]' \
          '*: :' && ret=0 ;;
      (snapshots)
        _arguments \
          '(-c --compact)'{-c,--compact}'[compact]' \
          '(-g --group-by)'{-g+,--group-by=}'[group]:g:(host paths tags)' \
          '(-H --host)*'{-H+,--host=}'[host]:h:_hosts' \
          '(--latest)--latest=[n]:n:' \
          '(--path)*--path=[path]:p:' \
          '(--tag)*--tag=[tag]:t:' \
          '*: :' && ret=0 ;;
      (forget)
        _arguments \
          '(-l --keep-last)'{-l+,--keep-last=}'[n]:n:' \
          '(-H --keep-hourly)'{-H+,--keep-hourly=}'[n]:n:' \
          '(-d --keep-daily)'{-d+,--keep-daily=}'[n]:n:' \
          '(-w --keep-weekly)'{-w+,--keep-weekly=}'[n]:n:' \
          '(-m --keep-monthly)'{-m+,--keep-monthly=}'[n]:n:' \
          '(-y --keep-yearly)'{-y+,--keep-yearly=}'[n]:n:' \
          '(--keep-tag)*--keep-tag=[tag]:t:' \
          '(--keep-within)--keep-within=[duration]:t:' \
          '(--keep-within-hourly)--keep-within-hourly=[duration]:t:' \
          '(--keep-within-daily)--keep-within-daily=[duration]:t:' \
          '(--keep-within-weekly)--keep-within-weekly=[duration]:t:' \
          '(--keep-within-monthly)--keep-within-monthly=[duration]:t:' \
          '(--keep-within-yearly)--keep-within-yearly=[duration]:t:' \
          '(--prune)--prune[prune after forget]' \
          '(--max-repack-size)--max-repack-size=[size]:s:' \
          '(--max-unused)--max-unused=[size]:s:' \
          '(--repack-cacheable-only)--repack-cacheable-only[only cacheable]' \
          '(--repack-small)--repack-small[repack small]' \
          '(--repack-uncompressed)--repack-uncompressed[repack uncompressed]' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '(--tag)*--tag=[tag]:t:' \
          '(--host)*--host=[host]:h:_hosts' \
          '(--path)*--path=[path]:p:' \
          '(--unsafe-allow-remove-all)--unsafe-allow-remove-all[allow remove all]' \
          '*: :' && ret=0 ;;
      (mount)
        _arguments \
          '(--allow-other)--allow-other[allow other users]' \
          '(--no-default-permissions)--no-default-permissions[no default perms]' \
          '(--owner-root)--owner-root[mount as root]' \
          '(--path-template)--path-template=[template]:t:' \
          '(--snapshot-template)--snapshot-template=[template]:t:' \
          '(--tag)*--tag=[tag]:t:' \
          '(--host)*--host=[host]:h:_hosts' \
          '(--path)*--path=[path]:p:' \
          '*: :_files -/' && ret=0 ;;
      (key)
        _arguments \
          '1:subcommand:(add list passwd remove)' \
          '*: :' && ret=0 ;;
      (list)
        _arguments '1:type:(blobs packs index snapshots keys locks)' '*: :' && ret=0 ;;
      (cat)
        _arguments '1:type:(masterkey config index snapshot blob lock pack key)' '*: :' && ret=0 ;;
      (find)
        _arguments \
          '(-i --ignore-case)'{-i,--ignore-case}'[case insensitive]' \
          '(-l --long)'{-l,--long}'[long format]' \
          '(--blob)--blob[search blobs]' \
          '(--tree)--tree[search trees]' \
          '(--pack)--pack[search packs]' \
          '*: :' && ret=0 ;;
      (rewrite)
        _arguments \
          '(--exclude -e)*'{-e+,--exclude=}'[pattern]:p:' \
          '(--forget)--forget[remove original]' \
          '(--snapshot-summary)--snapshot-summary[snapshot summary]' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '(--host)*--host=[host]:h:_hosts' \
          '(--tag)*--tag=[tag]:t:' \
          '(--path)*--path=[path]:p:' \
          '*: :' && ret=0 ;;
      (generate)
        _arguments \
          '(--bash-completion)--bash-completion=[file]:file:_files' \
          '(--zsh-completion)--zsh-completion=[file]:file:_files' \
          '(--fish-completion)--fish-completion=[file]:file:_files' \
          '(--powershell-completion)--powershell-completion=[file]:file:_files' \
          '(--man)--man=[dir]:dir:_files -/' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
