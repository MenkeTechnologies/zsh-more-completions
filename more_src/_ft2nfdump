#compdef ft2nfdump
# Documentation: https://raw.githubusercontent.com/phaag/nfdump/master/man/ft2nfdump.1
# Reference accessed: 2026-05-30
# ft2nfdump — convert flow-tools (ft) files to nfdump binary format.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[print help]' \
  '(- *)-V[print version and exit]' \
  '-r+[input flow-tools file]:file:_files' \
  '-w+[output nfdump file]:file:_files' \
  '-z+[output compression]:codec:(lzo bz2 lz4 zstd)' \
  '-E[show flow records on screen as conversion happens]' \
  '-c+[stop after N flow records]:N:' \
  && ret=0

return ret
