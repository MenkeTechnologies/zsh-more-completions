#compdef adcli
# Documentation: https://www.freedesktop.org/software/realmd/adcli/adcli.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create-msa:create managed service account'
  'create-user:create user account'
  'create-group:create group'
  'create-contact:create contact'
  'delete-user:delete user account'
  'delete-group:delete group'
  'delete-computer:delete computer account'
  'discover:discover info about Active Directory'
  'info:show domain or controller info'
  'join:join computer to domain'
  'preset-computer:precreate computer account(s)'
  'reset-computer:reset computer account password'
  'show-computer:show computer account info'
  'testjoin:verify current credentials'
  'update:update computer account password'
  'passwd-user:change user password'
  'add-member:add user/computer to group'
  'remove-member:remove user/computer from group'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-D --domain)'{-D+,--domain=}'[Active Directory domain]:domain:' \
  '(-R --domain-realm)'{-R+,--domain-realm=}'[Kerberos realm]:realm:' \
  '(-S --domain-controller)'{-S+,--domain-controller=}'[domain controller]:dc:' \
  '(-O --domain-ou)'{-O+,--domain-ou=}'[OU to place account]:ou:' \
  '(-N --computer-name)'{-N+,--computer-name=}'[short computer name]:name:' \
  '(-H --host-fqdn)'{-H+,--host-fqdn=}'[host FQDN]:fqdn:' \
  '(-U --login-user)'{-U+,--login-user=}'[admin user]:user:' \
  '(-W --login-ccache)'{-W+,--login-ccache=}'[Kerberos credential cache]:file:_files' \
  '--login-type=[login type]:type:(computer user)' \
  '--no-password[do not prompt for password]' \
  '--stdin-password[read password from stdin]' \
  '--prompt-password[always prompt for password]' \
  '(-K --host-keytab)'{-K+,--host-keytab=}'[host keytab path]:file:_files' \
  '--show-details[show detailed info]' \
  '--show-password[show machine password after join]' \
  '--add-service-principal=[service principal to add]:spn:' \
  '--add-samba-data[add samba data]' \
  '--samba-data-tool=[net binary path]:cmd:_command_names' \
  '--description=[computer description]:text:' \
  '--service-name=[service name]:svc:' \
  '--upn=[user principal name]:upn:' \
  '--use-ldaps[use LDAPS]' \
  '--no-tls[disable TLS]' \
  '--unix-home=[unix home dir]:dir:' \
  '--unix-shell=[unix shell]:sh:' \
  '--unix-uid=[unix UID]:uid:' \
  '--unix-gid=[unix GID]:gid:' \
  '--display-name=[display name]:name:' \
  '--mail=[email address]:mail:' \
  '--ou=[organisational unit]:ou:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'adcli command' commands && ret=0 ;;
esac

return ret
