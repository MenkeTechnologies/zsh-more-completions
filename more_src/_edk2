#compdef edk2
# Documentation: https://github.com/tianocore/edk2
# Reference accessed: 2026-05-17
# Verified: upstream repository at the URL above; edk2 itself is a project umbrella
# (no single `edk2` binary upstream — see edk2-build / edk2-tools for concrete tools).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*::edk2 args:_files' && ret=0
return ret
