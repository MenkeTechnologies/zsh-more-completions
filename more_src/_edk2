#compdef edk2
# Documentation: https://man.archlinux.org/search?q=edk2
# Reference accessed: 2026-05-16

# edk2: TianoCore EDK2 UEFI development kit dispatcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*::edk2 args:_files' && ret=0
return ret
