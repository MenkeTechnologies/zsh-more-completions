#compdef expand unexpand
# _expand — OpenBSD expand/unexpand (convert tabs <-> spaces in text streams; -t sets tab stop list (single number or comma list), -a (unexpand) compresses all leading runs of blanks, not just leading)
# upstream: https://github.com/openbsd/src (usr.bin/expand)
# Flags from usr.bin/expand/expand.1 on tip.

_expand() {
    _arguments \
        '-a[(unexpand) compress all runs of blanks]' \
        '-t+[tab stops (list or single int)]:tablist:' \
        '*:file:_files'
}

_expand "$@"
