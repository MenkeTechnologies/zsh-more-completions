#compdef btpd
# Documentation: https://github.com/btpd/btpd
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# BitTorrent Protocol Daemon (btpd/btpd)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-d+[btpd directory]:directory:_files -/' \
  '(-p --port)'{-p+,--port=}'[listen port]:port:' \
  '--bw-in=[limit incoming traffic kB/s]:kb/s:' \
  '--bw-out=[limit outgoing traffic kB/s]:kb/s:' \
  '--max-peers=[max peers]:n:' \
  '--max-uploads=[max simultaneous uploads]:n:' \
  '--ipcprot=[ipc protection mode]:mode:' \
  '--empty-start[start without active torrents]' \
  '--no-daemon[keep btpd in foreground]' \
  '--prealloc=[blocks to preallocate]:n:' \
  '--logfile=[log file]:file:_files'
