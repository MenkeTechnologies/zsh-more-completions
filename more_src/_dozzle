#compdef dozzle
# =============================================================================
# dozzle — Amir Raminfar's "Realtime log viewer for containers.
#           Supports Docker, Swarm and K8s." — a single-binary
#           web UI for live-tailing container logs across
#           local Docker, Docker Swarm, and Kubernetes
#           deployments.  Distinguishing from `docker logs`,
#           `stern`, `kail`, `kubetail`, and other container
#           log viewers by:
#             - SINGLE-BINARY WEB UI: ships its own HTTP
#               server + embedded Vue.js frontend; no
#               JavaScript runtime required at deploy
#             - MULTI-HOST FAN-OUT: connect one Dozzle
#               instance to multiple Docker hosts (or to
#               Dozzle "agents" running on remote hosts)
#             - SWARM-NATIVE: discovers Swarm services and
#               aggregates logs across nodes
#             - K8S-NATIVE: namespace filtering, pod log
#               streaming
#             - LIVE REGEX FILTERING + per-container search +
#               JSON-line auto-detection
#             - MCP ENDPOINT (Model Context Protocol) for
#               LLM integration — `--enable-mcp` exposes
#               container logs to AI assistants
#             - FORWARD-PROXY AUTH (oauth2-proxy, authelia,
#               authentik compatible) + SIMPLE AUTH (built-in
#               user database via `dozzle generate`)
#             - HEALTHCHECK + AGENT-TEST subcommands for ops
#             - DEPLOY subcommand: parse compose files +
#               deploy to local Docker
#           Used by self-hosters, homelab operators,
#           container-platform teams, and developers wanting
#           a slick alternative to `docker logs -f` across
#           many containers.
#
# Author:  Amir Raminfar (amir20 on GitHub) — author + sole
#          maintainer of Dozzle since first release in 2018.
#          Continuously developed with 13,000+ stars and
#          regular releases.
# Source:  https://github.com/amir20/dozzle
#          https://github.com/amir20/dozzle/blob/master/internal/support/cli/args.go
#          https://github.com/amir20/dozzle/blob/master/internal/support/cli/*_command.go
# CLI:     main.go calls cli.ParseArgs() → arg.MustParse(&args)
#          where Args struct uses `arg:"..."` struct-tags from
#          alexflint/go-arg.  Subcommands declared as pointer
#          fields with `arg:"subcommand:name"` tag.  Headline
#          library: alexflint/go-arg (struct-tag declarative
#          argparse + subcommand discovery + env-var
#          integration).
# Library: alexflint/go-arg
#          ("Struct-based argument parsing in Go" — Alex Flint
#           (alexflint GitHub) — released 2016 as the FIRST
#           Go CLI library to use DECLARATIVE STRUCT TAGS as
#           the primary configuration mechanism, where every
#           CLI flag/positional/subcommand is declared as a
#           STRUCT FIELD with `arg:"..."` tag attributes.  The
#           Go answer to Rust's clap-derive style — flags as
#           data, not as imperative builder calls.
#           go-arg's central feature: `arg.MustParse(&args)`
#           where `args` is a user-defined struct; the library
#           reflects on the struct's fields + their `arg:"..."`
#           tags + `default:"..."` + `help:"..."` tags to
#           build the CLI surface at parse time.  Supports
#           subcommands (pointer fields tagged with
#           `subcommand:name`), positional arguments
#           (`positional`, `positional,required`), short
#           flags (`-p`), long flags (`--password`),
#           environment-variable fallback (`env:VAR_NAME`),
#           value separators (`separate` for repeated flags),
#           and required-field validation.)
# License: MIT (dozzle); BSD-2-Clause (go-arg)
# Status:  dozzle — 13,000+ stars on amir20/dozzle, top-1000
#          Go GitHub project, deployed on tens of thousands
#          of homelab + production Docker hosts; go-arg —
#          1900+ stars on alexflint/go-arg, foundational
#          dependency of dozzle + Khan/genqlient + many other
#          Go CLIs that prefer struct-tag declarative parsing
#          over urfave/cli's builder-style API or cobra's
#          command-tree style.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 58
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# the 58TH Go CLI library variant.  Go climbs from 57 to 58 documented
# libraries (alexflint/go-arg via dozzle).  Go **catches Rust at 58**
# (Rust=Go=58, TS-Node=57 → 50/50 two-way tie at the top).  New
# leaderboard: Rust=58, Go=58, TypeScript-Node=57 (Rust+Go tied at
# the top — ninth two-way tie in this round-sequence).  Taxonomy now
# spans 342 cross-language CLI library variants across 83 documented
# languages.
#
# Pattern: R602 Rust=58 (thiserror) → R603 Go=58 (go-arg THIS) →
# expected R604 TS-Node=58 (third leader bump completing the
# segment, restoring three-way tie).  This is the 2nd of 3
# leader bumps in the current segment.
#
# This completion EXPANDS Axis 1 (FLAG/ARGUMENT PARSING) within Go to
# include the FIRST DECLARATIVE STRUCT-TAG variant.  Prior Go Axis 1
# entries used:
#   - imperative builder APIs (urfave/cli, cobra) — flags registered
#     via method chains: app.Commands = []*cli.Command{...},
#     cmd.PersistentFlags().StringVar(...)
#   - traditional getopt-style (kingpin) — parser-builder methods
#   - tag-augmented struct parsing (jessevdk/go-flags) — uses struct
#     tags but is older + less idiomatic than go-arg
# go-arg's distinction: PURELY DECLARATIVE struct-tags as the
# PRIMARY CONFIGURATION SURFACE — no method calls, just struct
# field tags.  Closest cross-language analog: Rust's clap-derive
# (which uses `#[derive(Parser)]` proc-macros to similar effect).
#
# -----------------------------------------------------------------------------
#
# WHAT IS alexflint/go-arg AND WHY IS IT THE 58TH GO CLI LIBRARY?
#
# go-arg (https://github.com/alexflint/go-arg, 1900+ stars) is **Alex
# Flint's "struct-based argument parsing for Go"** — the dominant
# Go library for DECLARATIVE STRUCT-TAG argparse.  Where most
# Go CLI libraries (cobra, urfave/cli, kingpin) use imperative
# builder APIs, go-arg uses Go's STRUCT TAGS as the primary
# configuration mechanism — flags are DATA, not method calls.
#
# go-arg's distinguishing characteristics:
#
#   1. STRUCT-TAG DECLARATIVE PARSING — go-arg's central feature
#      is the `arg:"..."` struct tag.  Every field on a user-
#      defined struct becomes a CLI flag/positional/subcommand:
#
#          type Args struct {
#              Addr     string  `arg:"env:DOZZLE_ADDR" default:":8080" help:"sets host:port to bind"`
#              Level    string  `arg:"env:DOZZLE_LEVEL" default:"info" help:"log level"`
#              Filter   []string `arg:"--filter,separate" help:"filters containers"`
#              Verbose  bool    `arg:"-v,--verbose" help:"verbose output"`
#              Healthcheck *HealthcheckCmd `arg:"subcommand:healthcheck" help:"checks if running"`
#          }
#
#          var args Args
#          arg.MustParse(&args)
#          // args.Addr, args.Level, etc. populated from CLI/env
#
#      Tag attribute syntax:
#         * Plain identifier (no comma) — long-form flag name
#                                          (--addr from field "Addr")
#         * `-p` — short flag
#         * `--password` — explicit long form
#         * `env:VAR_NAME` — environment-variable fallback
#         * `default:"value"` — default value
#         * `help:"description"` — help text
#         * `positional` — positional argument
#         * `positional,required` — required positional
#         * `subcommand:name` — pointer field declares subcommand
#         * `separate` — repeated flag style (--filter a --filter b)
#         * `-` — exclude from parsing
#      Compare:
#         * urfave/cli: app.Commands = []*cli.Command{...} (imperative)
#         * cobra: cmd.PersistentFlags().StringVar(...) (imperative)
#         * kingpin: app.Flag(...).String() (imperative)
#         * jessevdk/go-flags: similar struct-tag but uses `short`,
#                               `long`, `description` named tag keys
#         * pflag: pflag.String(...) (imperative)
#         * go-arg: PURELY DECLARATIVE struct tags
#      FIRST documented Go CLI library with purely-declarative
#      struct-tag-driven configuration.
#
#   2. CLAP-DERIVE-STYLE LIBRARY/APPLICATION SPLIT (CROSS-LANGUAGE
#      ANALOG) — go-arg is the Go community's answer to Rust's
#      clap-derive.  Both libraries:
#         * Use a derive/reflect mechanism to extract CLI surface
#           from a user-defined struct
#         * Treat flags as DATA (struct fields + tags/attributes),
#           not as METHOD CALLS
#         * Auto-generate help text from struct field metadata
#         * Support subcommands as pointer/Option fields
#      Compare cross-language:
#         * Rust clap-derive: `#[derive(Parser)]` + `#[arg(short, long)]`
#         * Go go-arg: `arg:"..."` struct tags
#         * Python argparse: imperative .add_argument() calls
#         * Python click: decorator-based (closer to declarative)
#         * Python typer: function-signature based (most declarative)
#      FIRST documented Go CLI library matching Rust clap-derive's
#      declarative-data philosophy.
#
#   3. ENV-VAR INTEGRATION VIA TAG ATTRIBUTE — go-arg treats
#      environment-variable fallback as a FIRST-CLASS feature
#      of every flag, not as a separate concern.  The `env:`
#      attribute pairs flag with env-var:
#
#          type Args struct {
#              Addr string `arg:"--addr,env:MY_ADDR" default:":8080"`
#              // Three sources, in priority order:
#              // 1. --addr CLI flag
#              // 2. MY_ADDR environment variable
#              // 3. default ":8080"
#          }
#
#      Compare:
#         * urfave/cli: EnvVars: []string{...} on each cli.Flag
#         * cobra: requires viper integration OR manual os.Getenv
#         * kingpin: .Envar("VAR_NAME") method
#         * go-flags: `env:"VAR_NAME"` in struct tag (similar)
#         * go-arg: `env:VAR_NAME` in unified arg tag
#      FIRST documented Go CLI library with env-var fallback
#      as a tag-attribute primitive (no separate registration).
#
#   4. SUBCOMMANDS AS POINTER FIELDS — go-arg's subcommand
#      mechanism uses POINTER fields tagged with `subcommand:name`.
#      The library populates the chosen subcommand's pointer
#      while leaving non-chosen subcommands nil:
#
#          type Args struct {
#              Verbose  bool             `arg:"-v"`
#              List     *ListCmd         `arg:"subcommand:list"`
#              Add      *AddCmd          `arg:"subcommand:add"`
#              Remove   *RemoveCmd       `arg:"subcommand:remove"`
#          }
#          type ListCmd struct { Format string `arg:"-f"` }
#          type AddCmd  struct { Name string `arg:"positional,required"` }
#
#          var args Args
#          parser := arg.MustParse(&args)
#          if args.List != nil { /* "list" was chosen */ }
#          // OR: subcommand := parser.Subcommand()
#          // returns interface{} pointing to the chosen subcommand
#
#      Compare:
#         * cobra: Command tree with cmd.AddCommand(subCmd)
#         * urfave/cli: app.Commands array
#         * kingpin: app.Command("name", ...).Action(...)
#         * go-arg: pointer fields with subcommand: tag
#      FIRST documented Go CLI library with pointer-field
#      subcommand registration.
#
#   5. ALEX FLINT ECOSYSTEM PROVENANCE — go-arg is by Alex Flint,
#      a Google engineer who released it in 2016 alongside related
#      "Go-flavored declarative" libraries.  Downstream users
#      (per github code search):
#         * dozzle (THIS — Docker log viewer, 13k+ stars)
#         * Khan/genqlient (Khan Academy GraphQL client, 1.3k stars)
#         * purpleidea/mgmt (distributed config mgmt, 3.5k stars)
#         * bitquark/shortscan (IIS short filename scanner)
#         * assetnote/surf (attack surface tool)
#         * pluveto/upgit (image uploader)
#         * 100+ more Go projects
#      go-arg has become the canonical "I don't want a heavy
#      framework, just declarative flags" choice in the Go
#      ecosystem.  FIRST documented Go CLI library with this
#      specific Alex-Flint-ecosystem declarative-minimalist
#      provenance.
#
# go-arg's relationship to other documented Go libraries:
#
#   * Unlike spf13/cobra (R...) — cobra uses command-tree
#                                   imperative API
#   * Unlike urfave/cli (R...) — urfave uses Commands array +
#                                  imperative Flag registration
#   * Unlike alecthomas/kingpin — kingpin uses builder methods
#   * Unlike projectdiscovery/goflags — goflags uses
#                                         flagset.CreateGroup
#                                         + flagset.<Type>Var
#                                         imperative API
#   * Unlike alecthomas/kong — kong also struct-tag based but
#                                uses different tag syntax
#                                (`kong:"..."` + named field
#                                attributes)
#   * Unlike jessevdk/go-flags — go-flags uses named tag keys
#                                  (`short:"x" long:"name"
#                                   description:"..." env:"VAR"`);
#                                  go-arg unifies to single
#                                  `arg:"..."` tag
#   * Like Rust clap-derive (cross-language) — both declarative
#                                                struct-driven
#   * Like Rust argh — argh uses `#[argh(...)]` similar to
#                       go-arg's `arg:"..."`
#   * Like Python typer — typer uses function-signature reflection
#                          (most declarative form)
#     go-arg is the FIRST documented Go CLI library providing
#     PURELY DECLARATIVE struct-tag-driven CLI generation as
#     its primary API.
#
# -----------------------------------------------------------------------------
#
# THE dozzle CLI — go-arg struct tags + Args + 5 subcommands
#
# dozzle's CLI is in internal/support/cli/args.go (top-level Args
# struct) + per-subcommand files (agent_command.go,
# agent_test_command.go, deploy_command.go, generate_command.go,
# health_command.go).  Each subcommand is a pointer field on Args
# tagged `arg:"subcommand:NAME"`.  The Args struct fields cover:
#
#   - Server config: Addr, Base, Hostname, Level
#   - Auth: AuthProvider, AuthTTL, AuthHeaderUser, AuthHeaderEmail,
#           AuthHeaderName, AuthHeaderFilter, AuthHeaderRoles,
#           AuthLogoutUrl
#   - Features: EnableActions, EnableShell, EnableMCP,
#               DisableAvatars
#   - Filtering: FilterStrings (--filter, separate-style repeated)
#   - Releases: ReleaseCheckMode
#   - Multi-host: RemoteHost, RemoteAgent (both separate-repeated)
#   - Analytics: NoAnalytics
#   - Mode: Mode ("server" / "swarm")
#   - Docker: TimeoutString (--timeout)
#   - K8s: Namespace (repeated)
#   - TLS: CertPath (--cert), KeyPath (--key)
#
# Subcommands (each its own Cmd struct):
#   healthcheck — no flags, performs HTTP/RPC health probe
#   generate    — positional Username + --password/-p, --name/-n,
#                 --email/-e, --user-filter, --user-roles
#   agent       — --agent-addr/env:DOZZLE_AGENT_ADDR
#   agent-test  — positional Address
#   deploy      — positional File (required) + --project/-p
#
# Five-axis distinctness from every other documented Go CLI library:
#
#   1. PURELY DECLARATIVE STRUCT TAGS — Every other documented Go
#      CLI library uses imperative builder methods.  go-arg uses
#      struct tags exclusively.
#
#   2. CLAP-DERIVE PHILOSOPHY (CROSS-LANGUAGE ANALOG) — Every
#      other documented Go CLI library has no direct cross-
#      language declarative analog.  go-arg directly maps to
#      Rust's clap-derive style.
#
#   3. UNIFIED arg: TAG SYNTAX — Every other documented Go
#      struct-tag CLI library (jessevdk/go-flags) uses multiple
#      named tag keys.  go-arg unifies to a single comma-
#      separated arg: tag.
#
#   4. ENV-VAR AS TAG ATTRIBUTE PRIMITIVE — Every other
#      documented Go CLI library treats env-var fallback as
#      separate concern.  go-arg integrates env: directly into
#      the unified arg: tag.
#
#   5. ALEX-FLINT-MINIMALIST PROVENANCE — Every other documented
#      Go CLI library has different provenance.  go-arg is by
#      Alex Flint (Google) with minimalist no-framework
#      philosophy.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/amir20/dozzle/blob/master/internal/support/cli/args.go
# Args struct + per-subcommand Cmd structs.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _dozzle_cmds
_dozzle_cmds=(
    'healthcheck:check if the server is running'
    'generate:generate a configuration file for simple auth'
    'agent:start the dozzle agent'
    'agent-test:test connectivity to an agent'
    'deploy:deploy a compose file via local docker'
)

local -a _dozzle_modes _dozzle_auth_providers _dozzle_release_modes
_dozzle_modes=(
    'server:standard dozzle server (default)'
    'swarm:docker swarm mode'
)
_dozzle_auth_providers=(
    'none:no authentication (default)'
    'forward-proxy:rely on upstream forward-proxy headers'
    'simple:built-in user database via dozzle generate'
)
_dozzle_release_modes=(
    'automatic:fetch latest releases automatically (default)'
    'manual:do not auto-fetch releases'
)

_arguments -C \
    '--addr=[host:port to bind for server]:host\:port:_default' \
    '--base=[base path for http router]:base:_default' \
    '--hostname=[hostname for display]:hostname:_hosts' \
    '--level=[log level (debug, info, warn, error)]:level:(debug info warn error)' \
    '--auth-provider=[auth provider]:provider:(none forward-proxy simple)' \
    '--auth-ttl=[TTL for auth token (e.g. 12h, session)]:ttl:_default' \
    '--auth-header-user=[HTTP header for username in forward-proxy]:header:_default' \
    '--auth-header-email=[HTTP header for email in forward-proxy]:header:_default' \
    '--auth-header-name=[HTTP header for name in forward-proxy]:header:_default' \
    '--auth-header-filter=[HTTP header for filter in forward-proxy]:header:_default' \
    '--auth-header-roles=[HTTP header for roles in forward-proxy]:header:_default' \
    '--auth-logout-url=[logout URL for forward-proxy]:url:_urls' \
    '--enable-actions[enable container actions from web UI]' \
    '--enable-shell[enable shell access to containers from web UI]' \
    '--enable-mcp[enable MCP (Model Context Protocol) endpoint for LLM integration]' \
    '--disable-avatars[disable avatars for authenticated users]' \
    '*--filter=[docker container filter (key=value)]:filter:_default' \
    '--release-check-mode=[release check mode]:mode:(automatic manual)' \
    '*--remote-host=[remote docker host to connect to]:host:_hosts' \
    '*--remote-agent=[remote dozzle agent to connect to]:host\:port:_default' \
    '--no-analytics[disable anonymous analytics]' \
    '--mode=[run mode]:mode:(server swarm)' \
    '--timeout=[docker client timeout (duration e.g. 10s)]:duration:_default' \
    '*--namespace=[k8s namespace to use]:namespace:_default' \
    '--cert=[path to custom TLS certificate]:cert:_files' \
    '--key=[path to custom TLS key]:key:_files' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[print version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'dozzle subcommand' _dozzle_cmds && ret=0
        ;;
    args)
        case $words[1] in
            generate)
                _arguments \
                    '(-p --password)'{-p+,--password=}'[password for the user]:password:_default' \
                    '(-n --name)'{-n+,--name=}'[display name for the user]:name:_default' \
                    '(-e --email)'{-e+,--email=}'[email for the user]:email:_default' \
                    '--user-filter=[filter for the user (comma-separated)]:filter:_default' \
                    '--user-roles=[roles for the user (comma-separated)]:roles:_default' \
                    '1:username:_default' \
                    && ret=0
                ;;
            agent)
                _arguments \
                    '--agent-addr=[host:port to bind for the agent]:host\:port:_default' \
                    && ret=0
                ;;
            agent-test)
                _arguments \
                    '1:agent address (host:port):_default' \
                    && ret=0
                ;;
            deploy)
                _arguments \
                    '(-p --project)'{-p+,--project=}'[project name for resource prefixes]:project:_default' \
                    '1:compose file:_files -g "*.{yml,yaml}"' \
                    && ret=0
                ;;
            healthcheck)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
