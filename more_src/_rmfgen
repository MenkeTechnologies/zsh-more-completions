#compdef rmfgen
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/rmfgen/node20.html
# XMM-Newton SAS: create an OGIP-compliant redistribution matrix file (RMF)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--spectrumset=[counts spectrum file associated with output RMF]:file:_files' \
  '--rmfset=[name of output response dataset]:file:_files' \
  '--threshold=[threshold level for grouping]:thresh:' \
  '--withenergybins=[use custom energy grid]:flag:(yes no)' \
  '--energymin=[lower energy boundary (keV)]:energy:' \
  '--energymax=[upper energy boundary (keV)]:energy:' \
  '--nenergybins=[number of bins in the energy grid]:bins:' \
  '--format=[format for MATRIX vector column]:format:(fixed variable)' \
  '--detmaptype=[origin of the detector map]:type:(dataset flat psf)' \
  '--detmaparray=[detector map dataset and array]:array:' \
  '--withdetbounds=[detector map bounds from parameters]:flag:(yes no)' \
  '--detxoffset=[half-width of detector map (DET coords)]:offset:' \
  '--detxbins=[number of bins along x-axis]:bins:' \
  '--detyoffset=[half-height of detector map (DET coords)]:offset:' \
  '--detybins=[number of bins along y-axis]:bins:' \
  '--correctforpileup=[apply pile-up correction to RMF]:flag:(yes no)' \
  '--raweventfile=[raw events file with energy and position]:file:_files' \
  '--acceptchanrange=[run on non-standard PI channel range]:flag:(yes no)' \
  '*:spectrum file:_files' && ret=0

return ret
