# Repository: HeLiBloks/zsh-completion-Collectable-Completions (_cscope-indexer)
#compdef cscope-indexer

_arguments -s  '-f[Specifies the cscope database file (default: cscope.out)]:cscope db file:_files'\
  '-i[Specifies the name of the file into which the list of files to index is placed (default: cscope.files)]:filename:'\
  '-l[Suppress generation/updating of cscope database file. Only a list of files is generated]'\
  '-r[Recurse into subdirectories to locate files to index. Without this option, onlycurrent directory is searched]'\
  '-v[Be verbose. Output simple progress messages]'\
  '*:filename:_files'
