#compdef setl
# =============================================================================
# setl — David Bacon's "GNU SETL" — the canonical modern
#        implementation of Jacob T. Schwartz's SETL (SET
#        Language), a 1969 high-level programming language
#        based on the mathematics of sets.  In SETL, SETS and
#        TUPLES are first-class data types; programs are
#        written using set theory operations (union,
#        intersection, comprehension, quantification) as
#        primary control structures.  GNU SETL is the
#        actively-maintained implementation by David Bacon
#        (NYU/Courant Institute) succeeding the original SETL,
#        SETL2 (Kirk Snyder), and SETLX (Tom Herrmann)
#        implementations.
#        Distinguishing from Python (set comprehensions
#        derivative), Mathematica (CAS), Maple (CAS), and
#        other mathematical languages by:
#          - SETS + TUPLES AS FIRST-CLASS PRIMITIVES — every
#            program operates on sets {a, b, c} and tuples
#            [1, 2, 3].  Sets are unordered, no duplicates;
#            tuples are ordered, may have duplicates.  These
#            data structures predate Python's set/tuple by
#            ~20 years.
#          - SET COMPREHENSIONS — `{f(x) : x in S | p(x)}`
#            syntax for sets:
#              squares := {x*x : x in {1..10}};
#              -- {1, 4, 9, 16, 25, 36, 49, 64, 81, 100}
#              primes := {n : n in {2..100} | not exists d in {2..n-1} | n mod d = 0};
#            Same for tuples: `[f(x) : x in T]`.  This syntax
#            directly inspired Python's list comprehensions
#            (Guido van Rossum cited ABC, which in turn was
#            inspired by SETL).
#          - QUANTIFIERS — `exists`, `forall` as first-class
#            operators:
#              if forall x in S | x > 0 then
#                print("All positive");
#              end if;
#              found := exists x in S | p(x);
#              -- Sets found to the first witness, or OM if none
#          - ATOMIC SETS via OP — set-builder + manipulation
#            operators:
#              union (+), intersection (*), difference (-)
#              member (in / notin), subset (subset), proper subset
#              cardinality (#), choice (arb)
#              powerset (pow), subsets of size k
#          - OM (UNDEFINED VALUE) — SETL has an explicit
#            undefined value `om` for missing map entries,
#            failed quantifier searches, etc.  Distinct from
#            Python's None / Java's null.
#          - DYNAMIC TYPING — values of any type can be put
#            in sets / tuples / maps; type checked at runtime
#          - MAPS as SETS OF PAIRS — `{[k1,v1], [k2,v2]}` IS
#            a map; `m(k1)` retrieves `v1`.  Maps are sets of
#            ordered pairs; can be operated on as sets.
#          - SIMULTANEOUS ASSIGNMENT — `x, y := y, x` swap
#            (predates Python's tuple unpacking by decades)
#          - VIRTUAL MACHINE BYTECODE — GNU SETL compiles to
#            VM bytecode (--compile produces VM output;
#            --translated reads VM input).  Distinct from
#            direct-execution interpreters.
#          - GNU CPP PREPROCESSOR — `--cpp` flag (or implicit
#            via -I/-D/-U or `#`-prefixed lines) routes source
#            through an adapted GNU CPP for C-style macros +
#            #include + #if directives.  Distinct from most
#            languages without preprocessing.
#          - SANDBOX MODE via --restricted (-r) — restricted-
#            rights execution for untrusted code.  Specific
#            permissions via --allow-open / --allow-fd-open /
#            --allow-mkstemp / --allow-filter / --allow-system.
#          - KEYWORD + IDENTIFIER CASING — historically SETL
#            was case-insensitive; GNU SETL supports
#            configurable case-sensitivity via
#            --keyword-case=any|upper|lower (default any) and
#            --identifier-case=any|upper|lower|mixed (default
#            any).
#          - FONT HINTS via --font-hints — emit prettyprinting
#            hints for source-code rendering (similar to
#            Emacs Lisp's auto-fill mode).
#          - MEMORY LIMIT via --maxmem=N (with k/m/g suffix)
#          - NUMERIC FILE DESCRIPTOR INPUT — `-3` syntax reads
#            from file descriptor 3 (for shell scripts)
#        Used by: NYU/Courant Institute computer-science
#        research labs studying high-level programming, formal
#        methods research (SETL was used to specify the Ada
#        compiler — historically influential), educational
#        contexts teaching set-theoretic computation, and as
#        a reference implementation of preprocessor + VM
#        bytecode compilation + sandboxed execution in C.
#
# Author:  GNU SETL by David Bacon (davidjbacon on GitHub) —
#          maintains GNU SETL since ~2007.  Original SETL by
#          Jacob T. Schwartz (1930-2009) + Robert B.K. Dewar
#          + others at NYU Courant Institute from 1969.
#          License: GPL-3.0.
# Source:  https://github.com/davidjbacon/SETL
#          https://setl.org/ (official site + docs)
#          https://setl.org/setl/doc/setl-user.html (user guide)
#          https://github.com/davidjbacon/SETL/blob/master/doc/setl.1
#          https://www.cs.nyu.edu/cs/faculty/schwartz/ (Schwartz)
# Manpage: setl(1) — "compile & run GNU SETL programs"
# Language: SETL (SET Language) — Jacob T. Schwartz's 1969
#           high-level set-theoretic language.  Distinct from:
#              * ABC (Lambert Meertens et al. — Python's
#                predecessor; inspired by SETL)
#              * Python (Guido van Rossum — set + list
#                comprehensions inherited from SETL via ABC)
#              * Mathematica (Wolfram CAS; symbolic math)
#              * Maple (computer algebra system)
#              * Sage (Python-based CAS)
#              * Coq / Lean / Agda (theorem provers; not
#                comprehension-based)
#              * Prolog (logic programming with unification;
#                different semantics)
#              * LISP family (lists vs sets; ordered vs unordered)
#           SETL distinguishes itself by:
#              1. SETS + TUPLES + MAPS as primitives
#              2. SET COMPREHENSIONS as primary control flow
#              3. QUANTIFIERS (exists, forall) as operators
#              4. OM undefined value
#              5. SIMULTANEOUS ASSIGNMENT (decades before Python)
#              6. PREPROCESSOR integration via GNU CPP
#              7. VM BYTECODE compilation
#              8. SANDBOX with fine-grained allow-list
#                 permissions
#              9. JACOB-SCHWARTZ / NYU COURANT INSTITUTE
#                 historical provenance (SETL was used to
#                 specify the first Ada compiler — historically
#                 significant)
#             10. INFLUENCED Python via ABC — Lambert Meertens'
#                 ABC language at CWI Amsterdam adopted SETL's
#                 comprehension syntax; Guido van Rossum
#                 (Python creator, formerly at CWI) inherited
#                 ABC's comprehensions into Python (where they
#                 became the well-known list / set / dict
#                 comprehensions).  Chain of influence:
#                   SETL (1969) → ABC (1975-1987) → Python (1989)
# License: GPL-3.0
# Status:  GNU SETL — 39+ stars on davidjbacon/SETL; active
#          maintenance since 2007; current version 3.5.8.
#          Used in academic research + historical-language
#          preservation.  setl.org is the canonical reference
#          site maintained by David Bacon.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 102ND LANGUAGE: SETL
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy expands its
# **102ND PROGRAMMING LANGUAGE**: SETL.  This expands the taxonomy from
# 101 to 102 documented programming languages.
#
# Pattern: R677 Rust=77 (image → Axis 22 OPENS) → R678 Go=77 (imaging)
# → R679 TS-Node=77 (sharp → Axis 22 1/1/1) → R680 102ND LANGUAGE
# (SETL via setl THIS).  This completes the 3-leader-bump + 1-new-
# language micro-cycle.
#
# WHY SETL IS A DISTINCTIVE 102ND LANGUAGE:
#
#   1. SET-THEORETIC PARADIGM — SETL is the canonical high-level
#      SET-THEORETIC programming language.  Operations on
#      sets, tuples, and maps are PRIMARY control structures,
#      not library additions.  Distinct from imperative
#      languages (control via statements), functional
#      (control via function application), and logic (control
#      via unification).  SETL's paradigm: control via set
#      operations + comprehensions + quantifiers.
#
#   2. ABC + PYTHON ANCESTOR — SETL's set comprehensions
#      directly inspired ABC (Lambert Meertens at CWI, 1975-
#      1987), which in turn was the design progenitor of
#      Python (Guido van Rossum, 1989; formerly at CWI).
#      Python's list comprehensions [x*x for x in range(10)],
#      set comprehensions {x*x for x in range(10)}, and dict
#      comprehensions {k: v*2 for k,v in d.items()} are
#      direct descendants of SETL's {f(x) : x in S | p(x)}
#      syntax.  Through Python's mainstream adoption, SETL's
#      mathematical-set-comprehension syntax has become the
#      lingua franca of modern programming.
#
#   3. JACOB SCHWARTZ NYU COURANT PROVENANCE — SETL was
#      designed by Jacob T. Schwartz (1930-2009), longtime
#      NYU Courant Institute of Mathematical Sciences
#      professor and ARPA program manager for the SETL
#      project.  Schwartz is recognized as a pioneer of
#      high-level programming language design and parallel-
#      processing algorithms.  His SETL textbooks
#      ("Programming with Sets: An Introduction to SETL", 1986
#      with Dewar/Dubinsky/Schonberg) are foundational
#      references.
#
#   4. ADA REFERENCE IMPLEMENTATION — SETL was used in 1980-
#      1983 to WRITE THE FIRST ADA COMPILER (NYU Ada/Ed
#      project, Honeywell sponsorship).  Ada/Ed was the first
#      validated Ada compiler.  Schwartz et al. used SETL's
#      high-level abstractions to define Ada semantics
#      executably, which then translated to a usable
#      compiler.  Historically significant achievement in
#      executable-specification methodology.
#
#   5. SIMULTANEOUS ASSIGNMENT — SETL supports `x, y := y, x`
#      simultaneous assignment + tuple destructuring decades
#      before Python adopted it.  In SETL, ANY tuple can be
#      destructured: `[a, b, c] := [1, 2, 3]`.  Python's
#      "a, b, c = 1, 2, 3" is direct descendant.
#
#   6. OM UNDEFINED VALUE — SETL has an explicit "undefined"
#      value `om` (omega) returned by failed quantifier
#      searches, missing map keys, etc.  Distinct from
#      Python's None / Java's null / C's NULL by being a
#      first-class value in the language semantics (not a
#      pointer convention).
#
#   7. QUANTIFIER EXPRESSIONS — `exists` and `forall` are
#      first-class operators with variable-binding scope:
#         if exists x in S | x < 0 then ...
#         if forall p, q in N | gcd(p, q) <= max(p, q) then ...
#      Distinct from imperative loops (Python's `any()` /
#      `all()` are library functions, not language operators).
#
#   8. VM BYTECODE compilation — GNU SETL compiles to its own
#      VM bytecode via setltran; setl runs the bytecode in
#      its VM.  --compile produces bytecode; --translated
#      reads bytecode input.  Distinct from direct
#      interpreters and direct native-code compilation.
#
#   9. GNU CPP PREPROCESSOR INTEGRATION — SETL source can use
#      C-style #include / #define / #ifdef / #if directives
#      via an adapted GNU CPP preprocessor (--cpp flag, or
#      automatically if a line starts with #).  Distinct from
#      most languages without source preprocessing.
#
#  10. SANDBOX with FINE-GRAINED ALLOW-LISTS — --restricted
#      mode with --allow-open=WHAT,HOW / --allow-fd-open /
#      --allow-mkstemp / --allow-filter / --allow-system
#      for capability-based restriction of untrusted SETL
#      programs.  Distinct from coarse-grained sandboxes;
#      pre-figures modern capability-based security designs
#      (Lua sandbox, Wasmer's WASI capabilities, etc.).
#
# Cross-language CLI library taxonomy after R680:
#   * 102 LANGUAGES DOCUMENTED (SETL is the 102nd)
#   * 410 total CLI library variants
#   * Rust=77 / Go=77 / TS-Node=77 (three-way tie at leaderboard top)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * Axes 7 + 8 + 11 + 12 + 15 + 16 + 17 + 18 + 19 + 20 + 21
#     + 22 at 1/1/1 three-language symmetric
#   * Fifteen axes at three-language symmetry
#
# SETL family in taxonomy:
#   * setl (THIS, R680) — SETL (GNU SETL by David Bacon)
#   (No other SETL implementation in taxonomy.)
#
# Set-theoretic / comprehension family in taxonomy:
#   * Python (in taxonomy via various Python tools) —
#     inherits comprehensions via ABC from SETL
#   * SETL (R680 THIS) — the original
#
# Languages documented prior to R680 (selected):
#   * R668 Frink (frink) — 99th
#   * R672 Cpp2 (cppfront) — 100th [MILESTONE]
#   * R676 Stan (stanc) — 101st [first post-100]
#   * R680 SETL (setl THIS) — 102nd
#
# -----------------------------------------------------------------------------
#
# THE setl CLI — manpage + user-guide sourced flags
#
# setl invokes the GNU SETL compile-and-run pipeline:
#   1. setlcpp (preprocessor) — if --cpp or implied by source
#   2. setltran (translator)  — emits VM bytecode
#   3. setl (interpreter)     — executes VM bytecode
#
# Flags (sourced from setl.org/setl/doc/setl-user.html
# --help output):
#
# Preprocessor:
#   --cpp                       force preprocessor use
#   --nocpp                     force NO preprocessor use
#   -I DIR                      include directory (implies --cpp)
#   -D NAME[=VALUE]             define macro (implies --cpp)
#   -U NAME                     undefine macro (implies --cpp)
#
# Compilation modes:
#   --compile, -c               emit VM code on stdout, don't run
#   --translated, -t            input is VM code (not source)
#   --font-hints                emit prettyprinting hints
#                                (implies --nocpp by default)
#
# Source-level options:
#   --keyword-case=any|upper|lower
#                               control keyword recognition
#                               (default any)
#   --identifier-case=any|upper|lower|mixed
#                               control identifier recognition
#                               (default any)
#
# Resource limits:
#   --maxmem=N                  memory limit (k/m/g suffix OK)
#
# Sandboxing:
#   --restricted, -r            restricted rights for untrusted code
#   --allow-open=WHAT,HOW ...   exemption for open() calls
#   --allow-fd-open=FD,HOW ...  exemption for open() over fd
#   --allow-mkstemp=TEMPLATE ... exemption for mkstemp() calls
#   --allow-filter=COMMAND ...  exemption for filter() calls
#   --allow-system=COMMAND ...  exemption for system() calls
#
# Tool overrides:
#   --setlcpp=COMMAND           specify preprocessor command
#   --setltran=COMMAND          specify translator command
#
# Diagnostics:
#   --help, -h                  show help
#   --version                   show version
#   --verbose, -v               verbose stderr output
#   --debug                     more verbose stderr output
#   --abort-on-error            core-dump on SETL-level error
#
# Input methods:
#   -FD                         input from numeric file descriptor
#   INPUT                       SETL source file (default stdin)
#
# Positional arguments:
#   [INPUT]                     SETL source file or VM code
#   [RUN-TIME ARGS]             arguments passed to running program
#
# File extensions (de facto):
#   .setl                       SETL source file
#   .stl                        SETL source (legacy)
#   (VM bytecode is binary, no standard extension)
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://setl.org/setl/doc/setl-user.html — the GNU SETL
# User Guide's "setl --help" section.  setl.org is the
# canonical reference documentation.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--cpp[force preprocessor use]' \
    '--nocpp[force NO preprocessor use]' \
    '*-I+[include directory (implies --cpp)]:directory:_files -/' \
    '*-D+[define macro (implies --cpp)]:name=value:_default' \
    '*-U+[undefine macro (implies --cpp)]:name:_default' \
    '(--compile -c)'{--compile,-c}'[emit VM code on stdout, do not run]' \
    '(--translated -t)'{--translated,-t}'[input is VM code (not source)]' \
    '--font-hints[emit prettyprinting hints]' \
    '--keyword-case=[control keyword recognition]:case:(any upper lower)' \
    '--identifier-case=[control identifier recognition]:case:(any upper lower mixed)' \
    '--maxmem=[memory limit (k/m/g suffix)]:limit:_default' \
    '(--restricted -r)'{--restricted,-r}'[restricted rights for untrusted code]' \
    '*--allow-open=[exemption for open() calls]:WHAT,HOW:_default' \
    '*--allow-fd-open=[exemption for open() over fd]:FD,HOW:_default' \
    '*--allow-mkstemp=[exemption for mkstemp() calls]:template:_default' \
    '*--allow-filter=[exemption for filter() calls]:command:_default' \
    '*--allow-system=[exemption for system() calls]:command:_default' \
    '--setlcpp=[specify preprocessor command]:command:_command_names' \
    '--setltran=[specify translator command]:command:_command_names' \
    '(- *)'{--help,-h}'[show help on stdout and exit]' \
    '(- *)--version[show version info and exit]' \
    '(-v --verbose)'{--verbose,-v}'[verbose stderr output]' \
    '--debug[more verbose stderr output]' \
    '--abort-on-error[core-dump on SETL-level error]' \
    '*:SETL source file or args:_files -g "*.(setl|stl)"' \
    && ret=0

return ret
