#compdef az-copy-image
# _az-copy-image — Confidential Containers helper that copies a PodVM image into an Azure compute gallery (per-region)
# upstream: https://github.com/confidential-containers/cloud-api-adaptor
# Flags from src/cloud-api-adaptor/cmd/az-copy-image/main.go on tip; AZURE_SUBSCRIPTION_ID / AZURE_RESOURCE_GROUP / AZURE_LOCATION env vars also bind.

_az-copy-image() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-subscription-id=[Azure subscription ID]:id:' \
        '-resource-group=[Azure resource group]:name:' \
        '-location=[Azure location]:loc:' \
        '-image-gallery=[image gallery name]:name:' \
        '-image-definition=[image definition name]:name:' \
        '-image-version=[image version (major.minor.patch)]:ver:' \
        '-community-image-id=[community gallery image version resource ID]:id:' \
        '-target-regions=[csv of target regions]:csv:'
}

_az-copy-image "$@"
