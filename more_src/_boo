#compdef boo
# _boo — boofuzz experimental CLI (jtpereyda/boofuzz)
# upstream: https://github.com/jtpereyda/boofuzz
# Subcommands from boofuzz/cli.py (click).

_boo() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                fuzz:'run a fuzz session (must be invoked from a fuzz script)'
                open:'open a boofuzz session database in the web UI'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                fuzz)
                    _arguments \
                        '--target=[target host:port]:host\:port:' \
                        '--test-case-index=[test case index]:idx:' \
                        '--test-case-name=[test case or node name]:name:' \
                        '--csv-out=[CSV output file]:file:_files -g "*.csv"' \
                        '--sleep-between-cases=[seconds to wait between cases]:s:' \
                        '--procmon-host=[process monitor host]:host:_hosts' \
                        '--procmon-port=[process monitor port]:port:' \
                        '--procmon-start=[process monitor start command]:cmd:' \
                        '--procmon-capture[capture target stdout/stderr on failure]' \
                        '--tui[enable TUI]' \
                        '--no-tui[disable TUI]' \
                        '--text-dump[full text dump of logs]' \
                        '--no-text-dump[no full text dump]' \
                        '--feature-check[feature check instead of fuzz test]' \
                        '--target-cmd=[target command and arguments]:cmd:' \
                        '--keep-web[keep web UI open after fuzz cases]' \
                        '--no-keep-web[close web UI when out of cases]' \
                        '--combinatorial[enable multiple-mutation fuzzing]' \
                        '--no-combinatorial[disable multiple-mutation fuzzing]' \
                        '--record-passes=[record this many cases before each failure]:n:' ;;
                open)
                    _arguments \
                        '--debug[print debug info to console]' \
                        '--ui-port=[web UI port]:port:' \
                        '--ui-addr=[web UI bind address]:addr:' \
                        '1:database file:_files' ;;
            esac
            ;;
    esac
}

_boo "$@"
