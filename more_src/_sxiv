#compdef sxiv
# Documentation: https://man.archlinux.org/man/sxiv.1.en
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

# Zsh completion for sxiv - Simple X Image Viewer.
# Notes: removed fabricated -O (only -o exists in upstream), -p means
# private mode upstream (not pixelize). Added -A FRAMERATE.

_arguments \
  '-A+[play animations at constant frame rate]:framerate:' \
  '-a[play animations of multi-frame images]' \
  '-b[do not show info bar]' \
  '-c[remove orphaned thumbnail cache files]' \
  '-e+[embed into window]:window ID:' \
  '-f[start in fullscreen mode]' \
  '-g+[set window position and size]:geometry:' \
  '-G+[set image gamma]:gamma:' \
  '-h[print usage information]' \
  '-i[read filenames from stdin]' \
  '-N+[set X window resource name]:name:' \
  '-n+[start at picture number]:number:' \
  '-o[print marked files to stdout on exit]' \
  '-p[private mode (no cache or temporary files)]' \
  '-q[quiet (suppress warnings)]' \
  '-r[search directories recursively for images]' \
  '-s+[scale mode]:mode:(d f w h)' \
  '-S+[slideshow mode delay]:seconds:' \
  '-t[start in thumbnail mode]' \
  '-v[print version]' \
  '-Z[equivalent to -z 100]' \
  '-z+[zoom percent]:zoom:' \
  '*:image file:_files -g "*.{jpg,jpeg,png,gif,bmp,tif,tiff,webp,svg,ico,xpm,xbm,ppm,pgm,pbm}"'
