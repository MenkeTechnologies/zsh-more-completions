#compdef sxiv

# Zsh completion for sxiv - Simple X Image Viewer

_arguments \
  '-a[play animations]' \
  '-b[do not show info bar]' \
  '-c[clean thumbnail cache]' \
  '-e[embed into window]:window ID:' \
  '-f[start in fullscreen mode]' \
  '-g[set window geometry]:geometry:' \
  '-G[set gamma]:gamma value:' \
  '-h[show help message]' \
  '-i[read file list from stdin]' \
  '-N[set window name]:name:' \
  '-n[start at image number]:number:' \
  '-o[print selected files to stdout on exit]' \
  '-O[print current file to stdout on exit]' \
  '-p[pixelize images]' \
  '-q[quiet mode]' \
  '-r[search directories recursively]' \
  '-s[set scale mode]:mode:(d f w h)' \
  '-S[set slideshow delay in seconds]:seconds:' \
  '-t[start in thumbnail mode]' \
  '-v[show version]' \
  '-Z[zoom to fit window]' \
  '-z[set zoom level]:zoom level:' \
  '*:image file:_files -g "*.{jpg,jpeg,png,gif,bmp,tif,tiff,webp,svg,ico,xpm,xbm,ppm,pgm,pbm}"'
