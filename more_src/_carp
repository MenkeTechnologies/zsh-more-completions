# Reference accessed: 2026-05-30 via gh api.
#
# carp is the **statically-typed Lisp** that compiles
# to C, designed for performance-critical applications.
# Inspired by Clojure but with ownership tracking (like
# Rust).  Pivots from Crystal (R269 shards) into the
# **Haskell language tooling cluster**.  Major addition:
# documents a NEW LANGUAGE in the corpus's cross-language
# CLI taxonomy.
#
# Critical extraction note: carp uses **Haskell's
# `Options.Applicative`** library — corpus's **first
# documented Haskell CLI** AND first **applicative-
# functor-style** CLI library.  Extends the **cross-
# language CLI taxonomy** to TWELVE library variants
# (R269 added Crystal; R270 adds Haskell): (a) Rust
# clap derive (R247-R262, R268), (b) Rust clap builder
# (R259), (c) Rust clap v3 (R261), (d) Go cobra
# (multiple), (e) Go pflag (multiple), (f) Go flaggy
# (R263), (g) Go stdlib flag (R264, R265), (h) Python
# Click (R266), (i) Python argparse (R267), (j) Python
# Typer (R268), (k) Crystal OptionParser (R269), (l)
# **Haskell optparse-applicative** (R270 — NEW).
# `optparse-applicative` is **the** standard Haskell
# CLI library — used by Cabal, Stack, GHC, Pandoc, etc.
# Documents the **applicative-functor CLI pattern**:
# the CLI definition is composed via `<$>` (fmap) and
# `<*>` (apply) operators to combine independent flag
# parsers into a single Parser for the full options
# record.  Distinct from clap derive's struct-attribute
# (declarative), Click's decorator-stack (decorator-
# based), and argparse's imperative `add_argument`
# (procedural).
#
# Critical extraction note: carp uses **applicative-
# functor composition** at parseFull (Main.hs:175-182):
# ```
#   parseFull :: Parser FullOptions
#   parseFull =
#     FullOptions
#       <$> parseExecMode
#       <*> parseOther
#       <*> many (strOption ...)
#       <*> many (strOption ...)
#       <*> parseFiles
# ```
# Documents the **Haskell applicative-style CLI
# composition**:
#   - `FullOptions <$> parser1` lifts the constructor
#     into the Parser context (Functor's fmap)
#   - `<*> parser2 <*> parser3 ...` applies each
#     subsequent parser, accumulating arguments
#     (Applicative's apply)
#   - The order of `<*>` matches the order of fields
#     in the record constructor
# Each sub-parser (parseExecMode, parseOther, etc.) is
# INDEPENDENT and composable.  Distinct from monadic
# composition (>>=) — applicative composition allows
# the CLI grammar to be statically analyzed (for help
# generation, parsing, etc.) because each parser
# doesn't depend on the result of previous parsers.
# Documents the **Functor / Applicative typeclass
# pattern** — fundamental to Haskell idiomatic code.
#
# Critical extraction note: carp uses **`<>` Semigroup
# operator for combining option attributes** at every
# option declaration (e.g. `long "no-core" <> help
# "Don't load Core.carp"`).  `<>` is Haskell's
# Semigroup/Monoid append; in optparse-applicative,
# option attributes (long / short / metavar / help /
# value / etc.) form a Monoid where they combine into
# a single Mod-context.  Documents the **`<>` attribute
# combinator** pattern — terse but powerful.  Distinct
# from clap derive's keyword-argument attributes
# (`long = "..."`, `short = 'X'`) and from Click's
# decorator kwargs (`"--name", help="..."`).  Haskell
# uses the Monoid abstraction to compose declarative
# metadata.
#
# Critical extraction note: carp uses **`<|>` Alternative
# typeclass for mutually-exclusive modes** at
# parseExecMode (Main.hs:207-212):
# ```
#   flag' Check (long "check" <> help "...")
#     <|> flag' Build (short 'b' <> help "...")
#     <|> flag' BuildAndRun (short 'x' <> help "...")
#     <|> Install <$> strOption (short 'i' <> help "...")
#     <|> pure Repl
# ```
# `<|>` chains options together; only ONE will match
# at parse time.  Plus `pure Repl` at the end provides
# the DEFAULT — if none of the explicit flags are
# given, ExecutionMode defaults to `Repl`.  Documents
# the **Alternative-functor mutex pattern** — distinct
# from R249 cairo-profiler's `conflicts_with =
# "list_samples"` (clap declarative mutex) and R250
# sozo's `#[group(multiple = false)]` (clap group).
# In Haskell, `<|>` is the natural way to express "one
# of these alternatives".  Plus `pure X` provides a
# default fallback — corpus's **first documented
# Alternative-with-default pattern**.
#
# Critical extraction note: carp uses **`flag'` (with
# apostrophe) vs `flag` distinction** at Main.hs:208-211
# — `flag' Check ...` parses the flag and PRODUCES
# Check value if the flag is present; FAILS to parse
# if absent (unlike `flag` which provides a default).
# Used in combination with `<|>` for mutex modes.
# Documents the **`flag'` vs `flag` distinction** in
# optparse-applicative:
#   - `flag default active mod` — provides both
#     default-when-absent and active-when-present;
#     never fails to parse
#   - `flag' active mod` — provides ONLY active-when-
#     present; fails if absent (used in mutex with
#     `<|>` so failure means "try the next alternative")
# Corpus's first documented this distinction.
#
# Critical extraction note: carp uses **`many (argument
# str ...)`** at Main.hs:215 — `many` from Alternative
# typeclass means "zero or more"; `argument str` is a
# positional argument with string parser.  Plus `many
# (strOption ...)` at Main.hs:180-181 for `--eval-
# preload` and `--eval-postload` (repeatable string
# options).  Documents the **`many` for repeatable
# args** pattern in optparse-applicative.  Distinct
# from clap derive's `Vec<T>` field (auto-detected) and
# from Click's `multiple=True` (explicit attribute).
# Plus `optional (strOption ...)` at Main.hs:203 wraps
# in `Maybe`.  Documents **3 Haskell repeat/optional
# modifiers**: (a) `many` (zero or more), (b) `some`
# (one or more; not used in carp), (c) `optional`
# (zero or one, wrapped in Maybe).
#
# Critical extraction note: carp uses **runtime env-var
# check** at Main.hs:98-106 — reads `CARP_DIR` from
# `SystemEnvironment.getEnvironment` AFTER CLI parsing.
# If unset AND `--no-core` is not given, emits an error
# and exits.  Documents the **runtime env-var check
# pattern** in Haskell — distinct from R252 saya's
# Rust clap auto-bind via `#[clap(long, env)]` and from
# R266 uvicorn's Click `auto_envvar_prefix`.  Haskell's
# `optparse-applicative` does NOT have built-in env-
# var-fallback support; the application handles env
# var reading manually.

local curcontext="$curcontext" state line

# Mutually-exclusive execution modes from parseExecMode
# at Main.hs:206-212 (combined via `<|>`).
local -a exec_modes=(
  '--check[check project (no build)]'
  '-b[build project (alternative; mutex with --check / -x / -i / default REPL)]'
  '-x[build and run project (alternative; mutex)]'
  '-i+[install built product; takes THING]:thing:'
)

# Other options (parseOther) — independent switches.
local -a other_options=(
  '--no-core[do not load Core.carp]'
  '--no-profile[do not load profile.carp]'
  '--log-memory[log memory allocations]'
  '--optimize[optimized build]'
  '--generate-only[stop after generating C code]'
  '--prompt=[set REPL prompt]:prompt:'
  '--line-directives[emit #line directives mapping C output to Carp source]'
)

# Eval pre/post-loads (parseFull) — repeatable strings.
local -a eval_loads=(
  '*--eval-preload=[eval CODE after loading config and before FILES (repeatable; Haskell `many`)]:code:'
  '*--eval-postload=[eval CODE after loading FILES (repeatable; Haskell `many`)]:code:'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help (added by `<**> helper`)]' \
  $exec_modes \
  $other_options \
  $eval_loads \
  '*:Carp source file:_files -g "*.carp"'
