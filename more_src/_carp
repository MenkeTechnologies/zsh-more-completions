#compdef carp
# Documentation: source-direct extraction from upstream
# carp-lang/Carp app/Main.hs (**Haskell language**;
# uses `Options.Applicative` library; corpus's first
# documented Haskell CLI + first **applicative-functor-
# style** CLI library):
#   app/Main.hs line 10 (`import Options.Applicative`)
#   app/Main.hs line 87 (`execParser $ Options.Applicative
#     .info (parseFull <**> helper) fullDesc` — top-level
#     parser setup with auto `--help` support)
#   app/Main.hs lines 166-173 (FullOptions record with
#     5 fields: optExecMode / optOthers / optPreload /
#     optPostload / optFiles)
#   app/Main.hs lines 175-182 (parseFull Parser composed
#     via applicative-style `<$>` and `<*>`)
#   app/Main.hs lines 184-204 (parseOther: 6 `switch`
#     boolean flags + 1 `optional (strOption ...)`)
#   app/Main.hs lines 206-212 (parseExecMode: 4 mutually-
#     exclusive modes via `<|>` Alternative + default
