#compdef kphotoalbum-cli
# Documentation: https://man.archlinux.org/search?q=kphotoalbum-cli
# Reference accessed: 2026-05-16

# KPhotoAlbum CLI: KDE photo album indexer / browser
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '-c[KPhotoAlbum index file]:file:_files -g "*.xml"' \
  '--config=[KPhotoAlbum index file]:file:_files -g "*.xml"' \
  '--demo[demo mode]' \
  '--import[import file]:file:_files -g "*.kim"' \
  '--export[export file]:file:_files' \
  '--export-in-2-hands[export to two locations]' \
  '*:album xml:_files -g "*.xml"' && ret=0
return ret
