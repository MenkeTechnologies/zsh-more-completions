#compdef kphotoalbum-cli

# KPhotoAlbum CLI helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--help-all[show all help (Qt/KDE included)]' \
  '--version[show version]' \
  '--db=[database file]:file:_files -g "*.xml"' \
  '--config=[config file]:file:_files' \
  '*:image directory:_files -/' && ret=0
return ret
