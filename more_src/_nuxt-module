#compdef nuxt-module
# Documentation: https://github.com/nuxt/module-builder
# Build a Nuxt module (legacy module-builder bin)

local ret=1

_arguments -C -s -S \
  '--cwd=[specify the working directory]:directory:_files -/' \
  '--outDir=[build directory]:directory:_files -/' \
  '--sourcemap[generate sourcemaps]' \
  '--stub[stub dist instead of building it (development)]' \
  '1:command:(build prepare)' \
  '*::rootDir:_files -/' && ret=0

return ret
