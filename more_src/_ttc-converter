local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 9 flags decoded source-direct from `descs : List
# $ OptDescr Option` at CommandLine.idr:80-89.
# Multi-char-list short for help: `-?` and `-h`
# both work (Idris 2 List Char syntax).
_arguments -s -S \
  '(-? -h --help)'{-?,-h,--help}'[show help]' \
  '(-i --input)'{-i+,--input=}'[input file name]:input file:_files' \
  '(-o --output)'{-o+,--output=}'[output file name]:output file:_files' \
  '(--ttc --ttm)--ttc[force TTC format]' \
  '(--ttc --ttm)--ttm[force TTM format]' \
  '--erase-fc[do not write FC (FileContext) in JSON]' \
  '--erase-mn[do not write MN (machine name) indexes in JSON]' \
  '--erase-bf[do not write buffer data in JSON]' \
  '--jq[use jq to format JSON output]' \
  '1:input file:_files -g "*.tt(c|m)"' && ret=0

return ret
