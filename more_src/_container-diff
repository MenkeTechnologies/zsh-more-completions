#compdef container-diff

# Zsh completion for container-diff - diff container images

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'analyze:analyze an image'
  'diff:diff two images'
  'version:print version information'
)

local -a analyzers=(
  'apt:Debian package analysis'
  'file:file system analysis'
  'history:image history analysis'
  'metadata:image metadata analysis'
  'node:Node.js package analysis'
  'pip:Python package analysis'
  'rpm:RPM package analysis'
  'size:image size analysis'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'container-diff subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (analyze)
        _arguments \
          '(-t --type)'{-t,--type}'[type of analysis]:analyzer:((${(j: :)analyzers}))' \
          '(-j --json)'{-j,--json}'[output in JSON format]' \
          '-w[output in HTML format]:file:_files -g "*.html"' \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--no-cache[do not use image cache]' \
          '--order[sort output]' \
          '--save[save image tarballs]' \
          '1:image:' && ret=0
        ;;
      (diff)
        _arguments \
          '(-t --type)'{-t,--type}'[type of analysis]:analyzer:((${(j: :)analyzers}))' \
          '(-j --json)'{-j,--json}'[output in JSON format]' \
          '-w[output in HTML format]:file:_files -g "*.html"' \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--no-cache[do not use image cache]' \
          '--order[sort output]' \
          '--save[save image tarballs]' \
          '1:image1:' \
          '2:image2:' && ret=0
        ;;
    esac
    ;;
esac

return ret
