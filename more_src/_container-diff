#compdef container-diff
# Documentation: https://github.com/GoogleContainerTools/container-diff
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for container-diff - diff container images

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'analyze:analyze an image'
  'diff:diff two images'
  'version:print version information'
)

local -a analyzers=(
  'apt:Debian package analysis'
  'file:file system analysis'
  'history:image history analysis'
  'metadata:image metadata analysis'
  'node:Node.js package analysis'
  'pip:Python package analysis'
  'rpm:RPM package analysis'
  'size:image size analysis'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'container-diff subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (analyze)
        _arguments \
          '*'{-t,--type}'=[type of analysis (repeatable)]:analyzer:((${(j: :)analyzers}))' \
          '(-j --json)'{-j,--json}'[output in JSON format]' \
          '(-o --order)'{-o,--order}'[sort files/packages by size descending]' \
          '(-q --quiet)'{-q,--quiet}'[suppress stderr output]' \
          '--format=[Go template for output]:template:' \
          '--filename=[file path for file-level diff]:path:' \
          '1:image:' && ret=0
        ;;
      (diff)
        _arguments \
          '*'{-t,--type}'=[type of analysis (repeatable)]:analyzer:((${(j: :)analyzers}))' \
          '(-j --json)'{-j,--json}'[output in JSON format]' \
          '(-o --order)'{-o,--order}'[sort files/packages by size descending]' \
          '(-q --quiet)'{-q,--quiet}'[suppress stderr output]' \
          '--format=[Go template for output]:template:' \
          '--filename=[file path for file-level diff]:path:' \
          '1:image1:' \
          '2:image2:' && ret=0
        ;;
    esac
    ;;
esac

return ret
