#compdef amk_grf
# Documentation: https://www.unix.com/man-page/debian/1/amk_grf
# Scotch: build a decomposition-defined target architecture from a source graph

local ret=1

_arguments -s \
  '-b-[apply bipartitioning strategy to compute the recursive bipartition]:strat' \
  '-h[display help]' \
  '-l-[only keep vertices whose indices are listed in file]:lfile:_files' \
  '-V[display version and copyright]' \
  '*:file:_files' && ret=0

return ret
