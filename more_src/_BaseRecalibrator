#compdef BaseRecalibrator
# Documentation: https://gatk.broadinstitute.org/hc/en-us/articles/360036898312-BaseRecalibrator
# GATK4: generate a recalibration table for base quality score recalibration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-I --input)'{-I,--input}'[input BAM/CRAM file]:file:_files -g "*.(bam|cram|sam)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-O --output)'{-O,--output}'[output recalibration table file]:file:_files' \
  '*--known-sites[database of known polymorphic sites]:file:_files -g "*.(vcf|vcf.gz)"' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to operate on]:intervals:_files' \
  '*:options:_files' && ret=0

return ret
