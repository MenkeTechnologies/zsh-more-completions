#compdef gosec

_gosec() {
  _arguments \
    '(-h --help)'{-h,--help}'[Show help]' \
    '-fmt[Output format]:format:(json yaml csv junit-xml html sonarqube golint sarif text)' \
    '-out[Output file]:file:_files' \
    '-conf[Configuration file]:file:_files -g "*.json"' \
    '-severity[Filter by severity]:severity:(low medium high)' \
    '-confidence[Filter by confidence]:confidence:(low medium high)' \
    '-exclude[Exclude rules]:rules:' \
    '-include[Include rules]:rules:' \
    '-exclude-dir[Exclude directories]:directory:_directories' \
    '-exclude-generated[Exclude generated files]' \
    '-sort[Sort issues]' \
    '-nosec[Ignore nosec comments]' \
    '-nosec-tag[Alternate tag for nosec]:tag:' \
    '-tests[Include test files]' \
    '-tags[Build tags]:tags:' \
    '-color[Colorize output]' \
    '-no-fail[Do not fail on found issues]' \
    '-quiet[Only show output on error]' \
    '-verbose[Verbose output]:level:' \
    '-track-suppressions[Track suppressed issues]' \
    '-log[Log file]:file:_files' \
    '-stdout[Print to stdout]' \
    '-version[Print version]' \
    '*:package or directory:_files -/'
}

_gosec "$@"
