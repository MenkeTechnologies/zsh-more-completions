#compdef laminarc
# Documentation: https://github.com/ohwgiles/laminar/blob/master/UserManual.md
# laminarc - command-line client for the Laminar CI service

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'queue:add one or more jobs to the queue, returning immediately'
  'start:start one or more jobs, returning when they begin execution'
  'run:trigger one or more jobs and wait for completion'
  'set:set variables exported in subsequent scripts for the run'
  'show-jobs:show the known jobs on the server'
  'show-running:show the currently running jobs with their numbers'
  'show-queued:show the names of the jobs waiting in the queue'
  'abort:manually abort a running job by name and number'
)

_arguments -C \
  '--next[place the job at the front of the queue instead of the end]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'laminarc command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (queue|start|run)
        _arguments \
          '--next[place the job at the front of the queue]' \
          '*::job:' && ret=0 ;;
      (set)
        _arguments '*::KEY=VALUE:' && ret=0 ;;
      (abort)
        _arguments \
          '1:job:' \
          '2:run number:' && ret=0 ;;
    esac ;;
esac

return ret
