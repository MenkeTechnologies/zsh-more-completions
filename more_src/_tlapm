#compdef tlapm
# Documentation: https://github.com/tlaplus/tlapm/blob/main/src/tlapm_args.ml
# TLA+ Proof Manager (TLAPS) proof checker

local ret=1

_arguments -s -S \
  '(-h --help -help)'{-h,--help,-help}'[show this help message and exit]' \
  '--version[show version number and exit]' \
  '(-v --verbose)'{-v,--verbose}'[produce verbose messages]' \
  '--where[show location of standard library and exit]' \
  '--config[show configuration and exit]' \
  '--summary[show summary of theorems (implies -N and not -C)]' \
  '--strict[report incomplete proofs and failed obligations as errors]' \
  '--timing[show runtime statistics]' \
  '-I+[add dir to search path]:dir:_files -/' \
  '-k[keep going on backend failures]' \
  '-N[do not run any backend verifiers]' \
  '-C[check proofs in Isabelle/TLA+]' \
  '--threads=[set number of worker threads]:threads:' \
  '--method=[set default method (try --method help)]:method:' \
  '--solver=[set SMT solver]:solver:' \
  '--smt-logic=[set SMT logic]:logic:' \
  '--fast-isabelle[(Windows-only) launch Isabelle with fast shortcut]' \
  '--stretch=[multiply all timeouts by factor]:factor:' \
  '--noflatten[do not flatten obligations]' \
  '--nonormal[do not normalize obligations before printing]' \
  '--debug=[enable/disable debugging flags]:flags:' \
  '--toolbox[toolbox mode]' \
  '--toolbox-vsn=[Toolbox protocol version 1|2]:version:(1 2)' \
  '--line=[line to prove]:line:' \
  '--wait=[wait before printing obligations in progress]:time:' \
  '--stdin[read the tla file from stdin instead of file system]' \
  '--prefer-stdlib[prefer built-in standard modules]' \
  '--noproving[do not prove, report fingerprinted results only]' \
  '--printallobs[print obligations in all toolbox messages]' \
  '--safefp[check tlapm, zenon, Isabelle versions for fingerprints]' \
  '--nofp[do not use existing fingerprints, overwrite with new ones]' \
  '--nofpl=[disable fingerprint use between given lines]:lines:' \
  '--cleanfp[erase fingerprint file before starting]' \
  '--erasefp=[erase all results of backend from file]:arg:' \
  '--printfp=[print the fingerprints stored in file and quit]:file:_files' \
  '--usefp=[load fingerprints from file]:file:_files' \
  '--fpp[print fingerprints of obligations in toolbox messages]' \
  '--cache-dir=[save auxiliary and temporary files under directory]:dir:_files -/' \
  '*:tla file:_files -g "*.tla"' && ret=0

return ret
