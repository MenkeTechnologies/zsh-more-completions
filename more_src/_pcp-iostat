#compdef pcp-iostat
# Documentation: https://man7.org/linux/man-pages/man1/pcp-iostat.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-x+[extra columns]:cols:' \
  '-t+[delay sec]:sec:' \
  '-R[show only running devices]' \
  '-A+[archive]:file:_files' \
  '-G+[group by]:by:' \
  '-H+[host]:host:_hosts' \
  '-O+[origin]:time:' \
  '-Z+[timezone]:tz:' \
  '-V[show version]' \
  '*:interval count:' && ret=0

return ret
