#compdef pcp-iostat

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-x+[extra columns]:cols:' \
  '-t+[delay sec]:sec:' \
  '-R[show only running devices]' \
  '-A+[archive]:file:_files' \
  '-G+[group by]:by:' \
  '-H+[host]:host:_hosts' \
  '-O+[origin]:time:' \
  '-Z+[timezone]:tz:' \
  '-V[show version]' \
  '*:interval count:' && ret=0

return ret
