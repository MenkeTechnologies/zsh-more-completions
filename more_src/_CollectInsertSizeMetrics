#compdef CollectInsertSizeMetrics
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/analysis/CollectInsertSizeMetrics.java
# Picard: collect insert-size distribution metrics from a SAM/BAM/CRAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM file]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output metrics file]:file:_files' \
  '(-H --Histogram_FILE)'{-H,--Histogram_FILE}'=[insert-size histogram pdf output]:file:_files' \
  '--DEVIATIONS=[trim data to MEDIAN + DEVIATIONS*MAD]:n:' \
  '(-W --HISTOGRAM_WIDTH)'{-W,--HISTOGRAM_WIDTH}'=[explicit histogram width]:n:' \
  '(-MW --MIN_HISTOGRAM_WIDTH)'{-MW,--MIN_HISTOGRAM_WIDTH}'=[minimum histogram width]:n:' \
  '(-M --MINIMUM_PCT)'{-M,--MINIMUM_PCT}'=[discard categories below this read percentage]:pct:' \
  '(-LEVEL --METRIC_ACCUMULATION_LEVEL)'{-LEVEL,--METRIC_ACCUMULATION_LEVEL}'=[metric accumulation level]:lvl:(ALL_READS SAMPLE LIBRARY READ_GROUP)' \
  '--INCLUDE_DUPLICATES=[include duplicate reads in histogram]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
