#compdef arpwatch
# _arpwatch — LBNL arpwatch (background daemon that watches the local Ethernet for ARP traffic, learns (ip, mac) pairs, alerts on changes via mail; -d debug (foreground + stderr), -f data file, -i interface, -n net/mask filter, -p disable promiscuous mode, -m mail address, -N skip data file dump, -r read pcap, -s sender override, -u user; default data file is /var/lib/arpwatch/arp.dat)
# upstream: https://ee.lbl.gov/
# Flags from LBNL arpwatch arpwatch.c on tip.

_arpwatch() {
    _arguments \
        '-h[show help]' \
        '-d[debug]' \
        '-f+[data file]:file:_files' \
        '-i+[interface]:interface:_net_interfaces' \
        '*-n+[net/mask filter]:net:' \
        '-p[disable promisc]' \
        '-m+[mail address]:addr:' \
        '-N[no data file dump]' \
        '-r+[pcap]:file:_files -g "*.(pcap|pcapng)"' \
        '-s+[sender override]:addr:' \
        '-u+[run as user]:user:_users' \
        '-z+[mail subject prefix]:subject:' \
        '-Q[disable rsource gathering]'
}

_arpwatch "$@"
