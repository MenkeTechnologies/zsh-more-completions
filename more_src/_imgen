#compdef imgen
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imgen.html
# MIRIAD: all-purpose image creator/manipulator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image to modify]:in:_files' \
  'out=[output image]:out:_files' \
  'source=[source component text file]:source:_files' \
  'factor=[input image multiplier]:factor:' \
  'object=[object type to add]:object:(level noise point gaussian gauss3 disk j1x jet shell comet cluster source)' \
  'spar=[object parameters]:spar:' \
  'imsize=[output image dimensions]:imsize:' \
  'cell=[pixel increment in arcsec]:cell:' \
  'radec=[image center coordinates]:radec:' \
  'options=[totflux]:options:(totflux)' \
  'seed=[random number generator seed]:seed:' \
  '*:image:_files' && ret=0

return ret
