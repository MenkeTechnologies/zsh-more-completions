#compdef create-pnpm-cli
# Documentation: https://www.npmjs.com/package/create-pnpm-cli
# Reference accessed: 2026-05-24
# Verified: npm view create-pnpm-cli bin; npx create-pnpm-cli --help; npx create-pnpm-cli create --help output.

# Zsh completion for create-pnpm-cli - pnpm-based CLI project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-V --version)'{-V,--version}'[output version number]'   '(-h --help)'{-h,--help}'[display help for command]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' create 'help:display help for command' && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments -C           '(-h --help)'{-h,--help}'[display help for command]'           '[target path]:path:_directories' && ret=0
        ;;
      help)
        _arguments -C ':command:' && ret=0
        ;;
    esac
    ;;
esac

return ret
