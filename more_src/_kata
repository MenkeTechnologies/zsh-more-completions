'--at=[Project root (defaults to cwd)]:DIR:_default' \
'*--var=[\`--var name=value\` (repeatable). Highest precedence]:NAME=VAL:_default' \
'--ai=[AI backend for \`how = "ai"\` files (auto / claude / gemini / codex / off)]:AI:((auto\:"Pick the first installed CLI in the order claude > codex > gemini (default)"
claude\:""
gemini\:""
codex\:""
off\:"Skip every \`how = "ai"\` file. Equivalent to \`--no-ai\`"))' \
