'*-v[Increase log verbosity (-v, -vv, -vvv)]' \
'*--verbose[Increase log verbosity (-v, -vv, -vvv)]' \
'--no-color[Disable color output (also respected via NO_COLOR env)]' \
'--non-interactive[Refuse to prompt; missing values become errors]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_kata_commands" \
"*::: :->kata" \
&& ret=0
