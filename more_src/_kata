(( $+functions[_kata_commands] )) ||
_kata_commands() {
    local commands; commands=(
'init:Bootstrap a new project from a preset' \
'apply:Re-apply this project'\''s templates against the recorded state' \
'status:Show what would change if \`apply\` were to run. Without \`--all\`, walks the current PJ'\''s templates and emits a per-file plan. With \`--all\`, walks the global registry and reports per-PJ drift (recorded \`content_hash\` vs disk)' \
'add:Append a template to this project'\''s applied state and apply' \
'remove:Drop a template from this project'\''s applied state' \
'update:Refresh the cache slot for git-sourced templates and bump recorded revs in \`applied.toml\`. No-op for local templates' \
'list:List inventory. Without \`--all\`, prints what governs the current PJ. If invoked from a directory with no \`.kata/applied.toml\` (and \`--at\` isn'\''t given), pick from the global registry interactively. With \`--all\`, walks the registry and shows a one-row-per-PJ overview (preset / templates / last-applied / status)' \
'register:Add a project to the global registry (\`~/.config/kata/config.toml\`). Optional \`--name\` defaults to the upstream repo basename; \`--tag\` is a repeatable label for filtering with \`kata apply --all --tag <t>\` (and the equivalent \`update --all\` / \`status --all\`)' \
'unregister:Drop a project from the global registry. The PJ'\''s \`.kata/applied.toml\` is left alone — only the registry pointer goes away' \
'doctor:Diagnose environment (git, agent CLIs, config dirs)' \
'completion:Print shell completion script' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'kata commands' commands "$@"
}
