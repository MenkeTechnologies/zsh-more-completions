#compdef lasclip
# LAStools: clip points against polygons from a shapefile

local ret=1

_arguments -s -S \
  '-help[display help]' \
  '-version[report tool version]' \
  '-gui[start with GUI]' \
  '-v[verbose output with statistics]' \
  '-poly+[input shapefile with polygons]:file:_files -g "*.(shp|SHP)"' \
  '-interior[clip points inside polygons (default outside)]' \
  '-donuts[handle donut-shaped polygons]' \
  '-split[create one output file per polygon]' \
  '-classify+[set classification of points outside shape]:code' \
  '-classify_as+[classify clipped points with code]:code' \
  '-flag_as_withheld[flag points instead of removing]' \
  '*-ignore_class+[exclude classes from clipping]:code' \
  '-gdal[support GPKG, GML, GeoJSON, KML, GPX vector formats]' \
  '-many_polys+[wildcard for multiple shapefiles]:pattern' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-merged[merge multiple input files]' \
  '-odir+[output directory]:dir:_files -/' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-otxt[output as text]' \
  '-oparse+[define ASCII output format]:parse string' \
  '-cores+[process on N parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
