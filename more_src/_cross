#compdef cross

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--verbose[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:compile the current package'
      'check:analyze the current package for errors'
      'test:run the tests'
      'run:run a binary or example'
      'bench:run benchmarks'
      'doc:build documentation'
      'clippy:run clippy lints'
      'fmt:format source code'
      'rustc:compile with custom flags'
      'rustdoc:build documentation with custom flags'
      'clean:remove generated artifacts'
    )
    _describe -t commands 'cross command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build|check|test|run|bench|doc|clippy|rustc|rustdoc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--target=[target triple]:target:(
            aarch64-linux-android aarch64-unknown-linux-gnu aarch64-unknown-linux-musl
            arm-unknown-linux-gnueabi arm-unknown-linux-gnueabihf armv7-unknown-linux-gnueabihf
            i686-unknown-linux-gnu i686-unknown-linux-musl
            mips-unknown-linux-gnu mipsel-unknown-linux-gnu
            powerpc-unknown-linux-gnu powerpc64le-unknown-linux-gnu
            riscv64gc-unknown-linux-gnu
            s390x-unknown-linux-gnu
            thumbv7neon-unknown-linux-gnueabihf
            x86_64-unknown-linux-gnu x86_64-unknown-linux-musl
            x86_64-pc-windows-gnu
            x86_64-unknown-freebsd x86_64-unknown-netbsd
            wasm32-unknown-emscripten
          )' \
          '-p+[package to build]:package:' \
          '--package=[package to build]:package:' \
          '--all[build all packages in workspace]' \
          '--workspace[build all packages in workspace]' \
          '--release[build in release mode]' \
          '--profile=[build profile]:profile:(dev release test bench)' \
          '-j+[number of parallel jobs]:jobs:' \
          '--jobs=[number of parallel jobs]:jobs:' \
          '--features=[features to activate]:features:' \
          '--all-features[activate all features]' \
          '--no-default-features[do not activate default features]' \
          '--lib[build only the library]' \
          '--bins[build all binaries]' \
          '--bin=[build specified binary]:binary:' \
          '--examples[build all examples]' \
          '--example=[build specified example]:example:' \
          '--tests[build all tests]' \
          '--test=[build specified test]:test:' \
          '--benches[build all benchmarks]' \
          '--bench=[build specified benchmark]:benchmark:' \
          '-v[verbose output]' \
          '--verbose[verbose output]' \
          '*:args:_files' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--target=[target triple]:target:' \
          '--release[clean release artifacts]' \
          '--profile=[clean profile]:profile:' && ret=0
        ;;
    esac
    ;;
esac

return ret
