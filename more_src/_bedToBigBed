#compdef bedToBigBed
# _bedToBigBed — UCSC Kent Lab bedToBigBed convert sorted BED to indexed bigBed binary format (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/bigBed.html

_bedToBigBed() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-blockSize=+[block size]:n:' \
        '-itemsPerSlot=+[items per slot]:n:' \
        '-as=+[autoSql definition file]:file:_files -g "*.as *.autosql"' \
        '-type=+[type]:t:(bed3 bed3+ bed4 bed4+ bed5 bed5+ bed6 bed6+ bed7 bed8 bed9 bed12 bed12+)' \
        '-unc[do not compress]' \
        '-tab[tab-separated input]' \
        '-extraIndex=+[fields csv]:str:' \
        '-sizesIs2Bit[sizes is 2bit]' \
        '-sizesIsChromAliasBb[sizes is chrom alias bb]' \
        '-allow1bpOverlap[allow 1 bp overlap]' \
        '-udcDir=+[UDC cache dir]:dir:_files -/' \
        '-maxAlloc=+[size]:n:' \
        '*:in_bed chrom_sizes out_bigbed:_files -g "*.bed *.chrom.sizes *.txt *.bb *.bigbed"'
}

_bedToBigBed "$@"
