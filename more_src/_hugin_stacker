#compdef hugin_stacker
# Documentation: https://man.archlinux.org/man/hugin_stacker.1.en
# hugin_stacker: stack a set of aligned images into one output image

local ret=1

_arguments -s -S \
  '--mode=[select stack mode (required)]:mode:' \
  '--output=[output filename (default final.tif)]:file:_files' \
  '--compression=[set compression of the output files]:compression:' \
  '--bigtiff[write output in BigTIFF format (TIFF only)]' \
  '--mask-input[enable masking of input images]' \
  '--mask-sigma=[sigma parameter for --mask-input (default 2)]:number:' \
  '--mask-suffix=[output a separate mask image per input with this suffix]:suffix:' \
  '--multi-layer-output[output a layered TIFF named via --output]' \
  '--winsor-trim=[Winsor mode trim parameter (default 0.2)]:number:' \
  '--max-sigma=[sigma mode parameter (default 2)]:number:' \
  '--max-iterations=[sigma mode iterations (default 5)]:number:' \
  '*:image:_files' && ret=0

return ret
