#compdef pypeit_sensfunc
# Documentation: https://pypeit.readthedocs.io/en/release/scripts.html
# Compute a sensitivity function from a reduced standard star spectrum

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '--extr=[override default extraction method]:method:(OPT BOX)' \
  '--algorithm=[override sensitivity function algorithm]:algorithm:(UVIS IR)' \
  '--multi=[detector numbers to splice together]:detectors' \
  '(-o --outfile)'{-o,--outfile}'[output file for sensitivity function]:file:_files' \
  '(-s --sens_file)'{-s,--sens_file}'[configuration file with parameters]:file:_files' \
  '(-f --use_flat)'{-f,--use_flat}'[use flatfield extraction for blaze function]' \
  '--debug[show debug plots]' \
  '--par_outfile=[save parameters to file]:file:_files' \
  '*:spec1d files:_files -g "*.fits"' && ret=0

return ret
