#compdef pagefind

# Zsh completion for pagefind - static search indexer

_arguments -s -S \
  '--site[path to the built static site]:directory:_files -/' \
  '--source[alias for --site]:directory:_files -/' \
  '--output-subdir[output subdirectory name]:directory name:' \
  '--output-path[explicit output path]:directory:_files -/' \
  '--root-selector[CSS selector for the root element]:selector:' \
  '--exclude-selectors[CSS selectors to exclude]:selectors:' \
  '--glob[glob pattern for files to include]:pattern:' \
  '--force-language[force a language for all pages]:language code:' \
  '--serve[serve the site after indexing]' \
  '--verbose[print verbose output]' \
  '--logfile[write logs to file]:file:_files' \
  '--keep-index-url[keep index.html in URLs]' \
  '--bundle-dir[directory for Pagefind bundle]:directory:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && return 0
