#compdef vmware-hgfsclient
# _vmware-hgfsclient — VMware open-vm-tools vmware-hgfsclient (list the shared folders the VMX has exported to the guest via the HGFS (host-guest filesystem) backdoor; takes no arguments — prints one share name per line; companion to vmhgfs-fuse for mounting them)
# upstream: https://github.com/vmware/open-vm-tools
# Behaviour from vmware/open-vm-tools open-vm-tools/hgfsclient/hgfsclient.c on tip.

_vmware-hgfsclient() {
    _arguments \
        '-h[show help]' \
        '--help[show help]'
}

_vmware-hgfsclient "$@"
