#compdef keda-operator
# _keda-operator — KEDA event-driven autoscaling operator
# upstream: https://github.com/kedacore/keda
# Flags from cmd/operator/main.go pflag bindings on tip.

_keda-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--enable-prometheus-metrics=[enable Prometheus metrics]:bool:(true false)' \
        '--enable-opentelemetry-metrics=[enable OpenTelemetry metrics]:bool:(true false)' \
        '--metrics-bind-address=[Prometheus metrics bind host\:port]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--metrics-service-bind-address=[gRPC Metrics Service bind host\:port]:host\:port:' \
        '--profiling-bind-address=[profiling bind host\:port]:host\:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-election-id=[leader-election lease ID]:id:' \
        '--kube-api-qps=[K8s API QPS]:f:' \
        '--kube-api-burst=[K8s API burst]:n:' \
        '--disable-compression=[disable client-go response compression]:bool:(true false)' \
        '--cert-secret-name=[webhook certificates Secret name]:name:' \
        '--cert-dir=[webhook certificates directory]:dir:_files -/' \
        '--operator-service-name=[Operator Service name]:name:' \
        '--metrics-server-service-name=[Metrics server Service name]:name:' \
        '--webhooks-service-name=[Webhook Service name]:name:' \
        '--k8s-cluster-name=[Kubernetes cluster name]:name:' \
        '--k8s-cluster-domain=[Kubernetes cluster DNS domain]:domain:' \
        '--enable-cert-rotation=[auto-rotate TLS certs/keys]:bool:(true false)' \
        '--validating-webhook-name=[ValidatingWebhookConfiguration name]:name:' \
        '--zap-devel[enable development zap logging]' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_keda-operator "$@"
