#compdef acdvalid
# Documentation: https://man.archlinux.org/search?q=acdvalid
# Reference accessed: 2026-05-16

# EMBOSS acdvalid: validate an ACD application definition
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-program=[ACD program to validate]:program:' \
  '-outfile=[validation report file]:file:_files' \
  '*::program name:' && ret=0
return ret
