#compdef gucci
# Documentation: https://github.com/noqcks/gucci
# gucci - a simple CLI templating tool written in golang (go text/template renderer)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print the version]' \
  '*'{-f+,--vars-file=}'[load variables from a JSON or YAML file]:file:_files' \
  '*'{-s+,--set-var=}'[set an individual variable using dot-notation]:var\=value:' \
  '*'{-o+,--option=}'[configure golang template options (e.g. missingkey=error)]:option:' \
  '1:template:_files' && ret=0

return ret
