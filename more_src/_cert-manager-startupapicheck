#compdef cert-manager-startupapicheck startupapicheck
# _cert-manager-startupapicheck — cert-manager API readiness check (cert-manager/cert-manager)
# upstream: https://github.com/cert-manager/cert-manager
# Subcommands + flags from cmd/startupapicheck/pkg/check/{check,api/api}.go + factory/factory.go (k8s genericclioptions) on tip.

_cert-manager-startupapicheck() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                check:'check cert-manager components'
            )
            _describe -t commands 'startupapicheck command' cmds
            ;;
        args)
            case $words[1] in
                check)
                    local -a sub=(
                        api:'check that the cert-manager API is ready'
                    )
                    _describe -t subcommands 'startupapicheck check subcommand' sub
                    if [[ $words[2] == api ]]; then
                        _arguments \
                            '--wait=[wait until the cert-manager API is ready (0=poll once)]:dur:' \
                            '--interval=[poll interval while waiting]:dur:' \
                            '(-n --namespace)'{-n,--namespace=}'[namespace]:ns:' \
                            '--kubeconfig=[kubeconfig file]:file:_files' \
                            '--context=[kubeconfig context]:ctx:' \
                            '--cluster=[kubeconfig cluster]:cluster:' \
                            '--user=[kubeconfig user]:user:' \
                            '--server=[apiserver URL]:url:_urls' \
                            '--token=[bearer token]:token:' \
                            '--insecure-skip-tls-verify[skip TLS verification]' \
                            '--certificate-authority=[CA cert file]:file:_files' \
                            '--client-certificate=[client cert file]:file:_files' \
                            '--client-key=[client key file]:file:_files' \
                            '--as=[impersonate user]:user:' \
                            '*--as-group=[impersonated group]:group:' \
                            '--request-timeout=[per-request timeout]:dur:'
                    fi
                    ;;
            esac
            ;;
    esac
}

_cert-manager-startupapicheck "$@"
