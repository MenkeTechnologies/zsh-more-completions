#compdef dpic
# Documentation: https://manpages.debian.org/bookworm/dpic/dpic.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dpic pic-language diagram processor

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-h[show help and exit]' \
  '-d[PDF output with basic strings]' \
  '-e[pict2e output]' \
  '-f[PostScript output with psfrag formatting]' \
  '-g[TikZ-pgf output]' \
  '-m[mfpic output]' \
  '-p[PSTricks output]' \
  '-r[raw PostScript output (no automatic string formatting)]' \
  '-s[MetaPost output]' \
  '-t[eepicemu output]' \
  '-v[SVG output]' \
  '-x[xfig 3.2 output]' \
  '-z[safe mode (disable sh directive)]' \
  '*:input:_files' && ret=0

return ret
