#compdef dpic

# Zsh completion for dpic diagram utility

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-d[debug parser]' \
  '*-g+[graphical dialect]:dialect:(pgf tikz box mpost metapost xfig ps eps mf mp svg svgbitmaps pdf pdftex pdflatex postscript pstex closepic shapes allpic allgen)' \
  '-r[square corners for PDF arrows]' \
  '-v[print dpic version]' \
  '-z[disable shell `sh` directive]' \
  '*:input:_files' && ret=0

return ret
