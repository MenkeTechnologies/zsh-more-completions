#compdef nuget

# Zsh completion for nuget (.NET NuGet package manager)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-version[Print version]' \
  '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
  '-noninteractive[Do not prompt for user input]' \
  '-configfile=[NuGet config file]:file:_files' \
  '-forceenglishoutput[Force English output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'add:Add a package to a non-HTTP package source'
      'config:Get or set NuGet config values'
      'delete:Delete or unlist a package from a server'
      'help:Display help information'
      'init:Add packages from a folder to a hierarchical source'
      'install:Install a package using packages.config'
      'list:List packages from a source'
      'locals:Clear or list local NuGet resource folders'
      'pack:Create a NuGet package from a nuspec or project'
      'push:Push a package to a server'
      'restore:Restore NuGet packages'
      'search:Search for packages on a source'
      'setapikey:Save an API key for a source'
      'sign:Sign a NuGet package'
      'sources:Manage package sources'
      'spec:Generate a nuspec file for a new package'
      'trusted-signers:Manage trusted signers'
      'update:Update packages to latest available versions'
      'verify:Verify a signed NuGet package'
    )
    _describe -t commands 'nuget command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      install)
        _arguments -s -S \
          '-h[Print help]' \
          '-source=[Package source]:source' \
          '-outputdirectory=[Directory to install packages to]:dir:_directories' \
          '-version=[Version of the package to install]:version' \
          '-dependencyversion=[Dependency version resolution]:version:(Lowest HighestPatch HighestMinor Highest)' \
          '-framework=[Target framework]:framework' \
          '-excludeversion[Exclude version number from folder path]' \
          '-prerelease[Allow prerelease packages]' \
          '-requireconsent[Check if package restore is enabled]' \
          '-solutiondirectory=[Solution root]:dir:_directories' \
          '-directdownload[Download packages directly without populating caches]' \
          '-nocache[Prevent using cached packages]' \
          '-disableparallelprocessing[Disable parallel processing]' \
          '-packagessavemode=[Package save mode]:mode:(nuspec nupkg nuspec\;nupkg)' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '-noninteractive[Do not prompt for user input]' \
          '-configfile=[NuGet config file]:file:_files' \
          '1:package ID or packages.config:_files' && ret=0
        ;;
      restore)
        _arguments -s -S \
          '-h[Print help]' \
          '-source=[Package source]:source' \
          '-nocache[Prevent using cached packages]' \
          '-disableparallelprocessing[Disable parallel processing]' \
          '-requireconsent[Check if package restore is enabled]' \
          '-packagessavemode=[Package save mode]:mode:(nuspec nupkg nuspec\;nupkg)' \
          '-solutiondirectory=[Solution root]:dir:_directories' \
          '-msbuildpath=[Path to MSBuild]:dir:_directories' \
          '-msbuildversion=[MSBuild version]:version' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '-noninteractive[Do not prompt for user input]' \
          '-configfile=[NuGet config file]:file:_files' \
          '-recursive[Restore all projects in the solution]' \
          '-force[Force all dependencies to be resolved]' \
          '-fallbacksource=[Fallback package sources]:sources' \
          '1:solution or packages.config:_files' && ret=0
        ;;
      pack)
        _arguments -s -S \
          '-h[Print help]' \
          '-outputdirectory=[Output directory]:dir:_directories' \
          '-basepath=[Base path for files defined in nuspec]:dir:_directories' \
          '-version=[Override the version number]:version' \
          '-suffix=[Version suffix]:suffix' \
          '-exclude=[Patterns to exclude from the package]:pattern' \
          '-symbols[Create a symbol package]' \
          '-symbolpackageformat=[Symbol package format]:format:(snupkg symbols.nupkg)' \
          '-tool[Mark as a tool package]' \
          '-build[Build the project before creating the package]' \
          '-msbuildpath=[Path to MSBuild]:dir:_directories' \
          '-msbuildversion=[MSBuild version]:version' \
          '-nodefaultexcludes[Do not apply default exclusions]' \
          '-nopackageanalysis[Do not run package analysis]' \
          '-includereferenced[Include referenced projects in the package]' \
          '-excludeemptydirectories[Exclude empty directories from the package]' \
          '-properties=[Key=value pairs for token replacement]:properties' \
          '-minClientVersion=[Set the minClientVersion attribute]:version' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '-noninteractive[Do not prompt for user input]' \
          '-configfile=[NuGet config file]:file:_files' \
          '1:nuspec or project file:_files' && ret=0
        ;;
      push)
        _arguments -s -S \
          '-h[Print help]' \
          '-source=[Server URL]:source' \
          '-apikey=[API key for the server]:key' \
          '-symbolsource=[Symbol server URL]:source' \
          '-symbolapikey=[API key for the symbol server]:key' \
          '-timeout=[Timeout for pushing to a server]:seconds' \
          '-disablebuffering[Disable buffering for HTTP(S) push]' \
          '-nothreads[Disable multithreaded push]' \
          '-nosymbols[Do not push symbols]' \
          '-skipduplicate[Skip duplicate packages]' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '-noninteractive[Do not prompt for user input]' \
          '-configfile=[NuGet config file]:file:_files' \
          '1:package:_files' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '-h[Print help]' \
          '-source=[Server URL]:source' \
          '-apikey=[API key for the server]:key' \
          '-nosymbols[Do not delete symbols]' \
          '-noninteractive[Do not prompt for confirmation]' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '-configfile=[NuGet config file]:file:_files' \
          '1:package ID' \
          '2:package version' && ret=0
        ;;
      list)
        _arguments -s -S \
          '-h[Print help]' \
          '-source=[Package source]:source' \
          '-allversions[List all versions of a package]' \
          '-prerelease[Allow prerelease packages to be shown]' \
          '-includeDelisted[Include delisted packages]' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '-noninteractive[Do not prompt for user input]' \
          '-configfile=[NuGet config file]:file:_files' \
          '1::search filter' && ret=0
        ;;
      search)
        _arguments -s -S \
          '-h[Print help]' \
          '-source=[Package source]:source' \
          '-prerelease[Include prerelease packages]' \
          '-take=[Number of results to return]:count' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '-noninteractive[Do not prompt for user input]' \
          '-configfile=[NuGet config file]:file:_files' \
          '1:search terms' && ret=0
        ;;
      sources)
        local -a subcmds=(
          'list:List all sources'
          'add:Add a package source'
          'remove:Remove a package source'
          'enable:Enable a package source'
          'disable:Disable a package source'
          'update:Update a package source'
        )
        _describe -t subcmds 'sources subcommand' subcmds && ret=0
        ;;
      locals)
        _arguments -s -S \
          '-h[Print help]' \
          '-clear[Clear the selected cache location]' \
          '-list[List the selected cache location]' \
          '1:cache location:(all http-cache global-packages temp plugins-cache)' && ret=0
        ;;
      config)
        _arguments -s -S \
          '-h[Print help]' \
          '-set=[Set a config value]:key=value' \
          '-asPath[Return value as a path]' \
          '-configfile=[NuGet config file]:file:_files' \
          '1::config key' && ret=0
        ;;
      sign)
        _arguments -s -S \
          '-h[Print help]' \
          '-certificatepath=[Path to certificate]:file:_files' \
          '-certificatestoreLocation=[X.509 store location]:location:(CurrentUser LocalMachine)' \
          '-certificatestorename=[X.509 store name]:name' \
          '-certificatesubjectname=[Certificate subject name]:name' \
          '-certificatefingerprint=[Certificate fingerprint]:hash' \
          '-certificatepassword=[Certificate password]:password' \
          '-hashAlgorithm=[Hash algorithm]:algo:(SHA256 SHA384 SHA512)' \
          '-timestamper=[URL of RFC 3161 timestamp server]:url' \
          '-timestamphashAlgorithm=[Timestamp hash algorithm]:algo:(SHA256 SHA384 SHA512)' \
          '-overwrite[Overwrite existing signature]' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '-noninteractive[Do not prompt for user input]' \
          '-configfile=[NuGet config file]:file:_files' \
          '*:package:_files' && ret=0
        ;;
      spec)
        _arguments -s -S \
          '-h[Print help]' \
          '-assemblypath=[Assembly to generate spec for]:file:_files' \
          '-force[Overwrite existing nuspec file]' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '1::package ID' && ret=0
        ;;
      update)
        _arguments -s -S \
          '-h[Print help]' \
          '-source=[Package source]:source' \
          '-id=[Package ID to update]:id' \
          '-version=[Version to update to]:version' \
          '-dependencyversion=[Dependency version resolution]:version:(Lowest HighestPatch HighestMinor Highest)' \
          '-prerelease[Allow updating to prerelease]' \
          '-repositorypath=[Local folder for packages]:dir:_directories' \
          '-safe[Only update within same major and minor]' \
          '-self[Update NuGet.exe itself]' \
          '-msbuildpath=[Path to MSBuild]:dir:_directories' \
          '-msbuildversion=[MSBuild version]:version' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '-noninteractive[Do not prompt for user input]' \
          '-configfile=[NuGet config file]:file:_files' \
          '1:solution or packages.config:_files' && ret=0
        ;;
      verify)
        _arguments -s -S \
          '-h[Print help]' \
          '-all[Verify all signatures on the package]' \
          '-certificatefingerprint=[Certificate fingerprint(s)]:hash' \
          '-signatures[Verify only the primary signature]' \
          '-verbosity=[Display verbosity level]:level:(normal quiet detailed)' \
          '-noninteractive[Do not prompt for user input]' \
          '-configfile=[NuGet config file]:file:_files' \
          '*:package:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
