#compdef font2c
# Convert a PostScript Type 0 or Type 1 font to C source code for compiling into Ghostscript
# Documentation: https://web.mit.edu/ghostscript/www/Fonts.htm
# Reference accessed: 2026-06-21

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:font name:_files' \
  '2:output C file:_files -g "*.(c|C)"' \
  '3:short name (for compilers with identifier length limits):' && ret=0

return ret
