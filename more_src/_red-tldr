#
# WHAT IT IS
#   red-tldr is "a lightweight red team command lookup tool" —
#   a TL;DR-style cheat-sheet retriever for red-team operators
#   that bundles a curated YAML knowledge base, indexes it with
#   Bleve full-text search, and answers `red-tldr <keyword>` in
#   milliseconds.  The companion `update` rebuilds the local
#   Bleve index from the bundled YAMLs;  `upgrade` pulls the
#   latest knowledge base from GitHub;  `serve` exposes the
#   same search backend as a Model Context Protocol (MCP)
#   server for Claude Desktop / Cursor (stdio) or remote web
#   clients (Streamable HTTP).
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/root.go and cmd/
#                       serve.go — spf13/cobra v1.8.1)
#   red-tldr [GLOBAL OPTIONS] [<KEYWORD>]
#   red-tldr <SUBCOMMAND> [args...]
#
#   Global persistent options:
#     -f, --format <FORMAT>          Output format
#                                    (text | json | markdown)
#                                    [default: text]
#
#   Subcommands:
#     <KEYWORD>                      Search the indexed
#                                    knowledge base (root
#                                    command, max 1 positional)
#     update                         Rebuild the local Bleve
#                                    index from local YAML
#                                    sources
#     upgrade                        Download the latest
#                                    knowledge base from GitHub
#     serve                          Start as a server (MCP
#                                    mode for AI assistants)
#       --http                         Use Streamable HTTP
#                                      transport (default: stdio)
#       --addr <ADDR>                  HTTP listen address
#                                      [default: localhost:8080]
#       --endpoint <PATH>              HTTP endpoint path
#                                      [default: /mcp]
#
#   Standard cobra auto-flags:
#     -h, --help                     Show help
#     -v, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/blevesearch/bleve/v2
#   v2.4.4` declared in go.mod — `bleve` is THE canonical Go
#   full-text search engine maintained by Couchbase Labs
#   (blevesearch/bleve, 10K+ stars, used by Grafana, Gitea,
#   AlistGo, Keybase, LocalAI, git-bug, OpenCloud, and dozens
#   of other Go projects).  bleve is the Go counterpart of
#   Tantivy / Apache Lucene:  it exposes `bleve.Index` with
#   `bleve.NewIndex(path, mapping)` / `bleve.Open(path)`,
#   `bleve.NewIndexMapping()` with typed `DocumentMapping`,
#   `FieldMapping` (Text / Numeric / DateTime / Boolean /
#   GeoPoint), `bleve.NewQueryStringQuery`,
#   `bleve.NewMatchQuery`, `bleve.NewMatchPhraseQuery`,
#   `bleve.NewBooleanQuery`, `bleve.NewNumericRangeQuery`,
#   `bleve.NewDateRangeQuery`, `bleve.NewGeoBoundingBox
#   Query`, the `bleve.SearchRequest` with `TopHits` /
#   `Highlight` / `Facets` / `Sort` / `Explain` configuration,
#   custom tokenizers + analyzers
#   (`bleve.RegisterAnalyzer`), the typed `bleve.SearchResult`
#   / `DocumentMatch` payload, and the pluggable storage layer
#   (scorch — the default segment-based store — plus the
#   legacy bolt-/goleveldb-backed stores).  red-tldr's
#   `internal/search/engine.go` constructs a
#   `bleve.NewIndexMapping`, registers field mappings for the
#   YAML schema (title, command, description, tag), and
#   serves queries via `index.Search(bleve.NewSearchRequest(
#   bleve.NewQueryStringQuery(keyword)))`.  Verified via:
#     gh api repos/Rvn0xsy/red-tldr/contents/go.mod
#       → github.com/blevesearch/bleve/v2 v2.4.4
#       → github.com/spf13/cobra v1.8.1
#       → module red-tldr
#     gh api repos/Rvn0xsy/red-tldr/contents/cmd/root.go
#       → rootCmd.Use = "red-tldr [keyword]"
#       → rootCmd.AddCommand(updateCmd|upgradeCmd|serveCmd)
#       → PersistentFlags --format (default "text")
#     gh api repos/Rvn0xsy/red-tldr/contents/cmd/serve.go
#       → serveCmd.Flags --http, --addr, --endpoint
#   This entry is the Go=147 leader bump that continues Axis
#   92 (Tantivy / full-text search engine library) opened at
#   R957 with Rust=tantivy via Dicklesworthstone/xf.
#
#   No completion for `red-tldr` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_red-tldr() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-f --format)'{-f,--format}'=[output format]:format:(text json markdown)' \
        '1: :_red_tldr_commands_or_keyword' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                serve)
                    _arguments \
                        '--http[use Streamable HTTP transport instead of stdio]' \
                        '--addr=[HTTP listen address]:addr:' \
                        '--endpoint=[HTTP endpoint path]:path:' && ret=0 ;;
                update|upgrade)
                    _arguments && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_red_tldr_commands_or_keyword] )) ||
_red_tldr_commands_or_keyword() {
    local -a commands
    commands=(
        'update:rebuild local Bleve index from local YAML sources'
        'upgrade:download latest knowledge base from GitHub'
        'serve:start as MCP server (stdio or HTTP)'
    )
    _describe -t commands 'red-tldr command (or search keyword)' commands
}

_red-tldr "$@"
