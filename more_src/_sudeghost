#compdef sudeghost
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/sudeghost.c
# applies a DEGHOSTING filter in (t,x) or (tau,p) data

local ret=1

_arguments -s -S \
  'h=[h]:h:' \
  'v=[v]:v:' \
  'r=[r]:r:' \
  'lambert=[lambert]:lambert:' \
  'dt=[dt]:dt:' \
  'verbose=[verbose]:verbose:' \
  'deghost=[deghost]:deghost:' \
  'pnoise=[pnoise]:pnoise:' \
  'f2=[f2]:f2:' \
  'd2=[d2]:d2:' \
  'offset=[offset]:offset:' \
  'choose=[choose]:choose:' \
  'igopt=[igopt]:igopt:' \
  'interoff=[interoff]:interoff:' \
  'offref=[offref]:offref:' \
  'pmin=[pmin]:pmin:' \
  'pmax=[pmax]:pmax:' \
  'dp=[dp]:dp:' \
  'f1=[f1]:f1:' \
  'cdpkey=[cdpkey]:cdpkey:' \
  'anderson=[anderson]:anderson:' \
  '*:file:_files' && ret=0

return ret
