#compdef marian-vocab
# Documentation: https://marian-nmt.github.io/docs/cmd/marian-vocab/
# Marian vocabulary builder from stdin

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help message and exit]' \
  '--version[print the version number and exit]' \
  '(-m --max-size)'{-m,--max-size}'=[generate only the most common vocabulary items]:n' \
  '*:file:_files' && ret=0

return ret
