#compdef MapAlignerPoseClustering
# OpenMS TOPP: align maps using a pose clustering algorithm

local ret=1

_arguments -s -S \
  '*-in[input files to align]:input file:_files' \
  '*-out[aligned output files]:output file:_files' \
  '*-trafo_out[transformation output files (trafoXML)]:file:_files' \
  '-in_spectra_files[input spectra files (mzML) for transformation]:file:_files' \
  '-out_spectra_files[output spectra files]:file:_files' \
  '-reference:file[file to use as alignment reference]:file:_files' \
  '-reference:index[input file index to use as reference]:n:' \
  '-algorithm:max_num_peaks_considered[maximum peaks per map]:n:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
