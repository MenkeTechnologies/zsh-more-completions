#compdef pelican-themes

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-l --list)'{-l,--list}'[list installed themes]' \
  '*'{-i,--install=}'[install theme]:theme:_files -/' \
  '*'{-r,--remove=}'[remove theme]:theme:' \
  '*'{-s,--symlink=}'[install via symlink]:theme:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
