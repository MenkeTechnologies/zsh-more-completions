#compdef cabal-hoogle
# Documentation: https://github.com/kokobd/cabal-hoogle
# Generate and query a local hoogle database for a cabal project and its dependencies

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    generate\:"create a hoogle database for all local packages and their dependencies"
    run\:"run hoogle with the generated database (args after -- are passed to hoogle)"
  ))' \
  '*::arg:' && ret=0

return ret
