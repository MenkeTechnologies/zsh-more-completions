#compdef VariantsToTable
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/variantutils/VariantsToTable.java
# Extract fields from a VCF file to a tab-delimited table

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'[File to which the tab-delimited table is written]:value:_files' \
  '(--fields -F)'{--fields,-F}'[The name of a standard VCF field or an INFO field to include in the output table]:value:' \
  '(--genotype-fields -GF)'{--genotype-fields,-GF}'[The name of a genotype field to include in the output table]:value:' \
  '-ASF+[The name of an allele-specific INFO field to be split if present]:value:' \
  '-ASGF+[The name of an allele-specific FORMAT field to be split if present]:value:' \
  '(--show-filtered -raw)'{--show-filtered,-raw}'[Include filtered records in the output]' \
  '--moltenize[Produce molten output]' \
  '(--error-if-missing-data -EMD)'{--error-if-missing-data,-EMD}'[Fail on missing data]' \
  '*:argument:_files' && ret=0

return ret
