#compdef bach
# _bach — Bach Bash Automated Testing tool (Bach Linux); Bash test harness with mocking + parameterized tests
# upstream: https://github.com/bach-sh/bach

_bach() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --filter)'{-f,--filter}'+[filter regex]:regex:' \
        '*:test file:_files -g "*.bach"'
}

_bach "$@"
