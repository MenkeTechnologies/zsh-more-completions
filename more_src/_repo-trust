'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':repo:_default' \
&& ret=0
;;
(serve)
_arguments "${_arguments_options[@]}" : \
'--bind=[Bind address (\`host\:port\`). Default \`127.0.0.1\:8765\`]:BIND:_default' \
'--allow-scan[Allow \`POST /scans\` to trigger fresh scans from the web UI]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(cache)
