'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_repo-trust_commands" \
"*::: :->repo-trust" \
&& ret=0
    case $state in
    (repo-trust)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:repo-trust-command-$line[1]:"
        case $line[1] in
            (scan)
_arguments "${_arguments_options[@]}" : \
'--mode=[Execution mode]:MODE:((quick\:"< 5s, < 30 API calls, headline signals only"
standard\:"< 30s, < 200 API calls, all modules at default sampling"
deep\:"< 5min, < 2000 API calls, larger sampling and graph analysis"))' \
'*--modules=[Comma-separated list of modules to enable (default\: all)]:MODULES:_default' \
'*--skip-modules=[Comma-separated list of modules to skip]:SKIP_MODULES:_default' \
'--output=[Output directory for written report files]:OUTPUT:_files' \
'*--format=[Output formats to write (terminal is always shown unless --quiet)]:FORMAT:(terminal json md csv sarif)' \
'--weights=[Path to a TOML file with custom module weights]:WEIGHTS:_files' \
'--scoring-version=[Pin a specific scoring version. If unset, latest is used]:SCORING_VERSION:_default' \
'--token=[GitHub Personal Access Token. Prefer the \`GITHUB_TOKEN\` env var]:TOKEN:_default' \
'--seed=[RNG seed for sampling (deterministic output). Default derived from repo+scoring_version]:SEED:_default' \
'--refresh-module=[Invalidate cache for a specific module before scanning]:REFRESH_MODULE:_default' \
'--api-base-url=[Override the GitHub API base URL. Hidden — used by integration tests to point at a wiremock server]:API_BASE_URL:_default' \
'--snapshot-at=[Pin the scan'\''s \`snapshot_at\` to a fixed RFC 3339 / ISO 8601 instant. Hidden — used by snapshot tests so that evidence values derived from \`now - commit_date\` (e.g. \`days_since_last_commit\`) stay stable across CI runs on different days. Production scans always use the wall clock]:SNAPSHOT_AT:_default' \
'--refresh[Invalidate all cache entries for this repo before scanning]' \
'--debug[Verbose tracing logs (sets RUST_LOG=debug)]' \
'--quiet[Suppress progress output]' \
'--no-color[Disable terminal colors]' \
'--json[Shorthand for \`--format json --quiet\`]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':repo -- Repository identifier\: `owner/repo` or full GitHub URL:_default' \
&& ret=0
;;
(batch)
_arguments "${_arguments_options[@]}" : \
'--concurrency=[Maximum concurrent scans]:CONCURRENCY:_default' \
'--output=[Output directory for per-repo reports plus a combined CSV]:OUTPUT:_files' \
'*--format=[Output combined report format(s)]:FORMAT:(terminal json md csv sarif)' \
'--token=[GitHub PAT]:TOKEN:_default' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':file -- Path to a newline-separated file of `owner/repo` identifiers:_files' \
&& ret=0
;;
(explain)
