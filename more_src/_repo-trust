_repo-trust_commands() {
    local commands; commands=(
'scan:Scan a single repository and produce a Trust Report' \
'batch:Scan many repositories from a newline-separated file' \
'explain:Print the full evidence walkthrough for a previously scanned repo' \
'serve:Start the local web viewer at http\://localhost\:8765' \
'cache:Cache management subcommands' \
'config:Configuration subcommands' \
'completions:Generate shell completion scripts' \
'version:Print version and scoring-model information' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'repo-trust commands' commands "$@"
