#compdef composer-normalize
# _composer-normalize — normalize composer.json (ergebnis/composer-normalize)
# upstream: https://github.com/ergebnis/composer-normalize

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-q --quiet)'{-q,--quiet}'[do not output any message]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--diff[show diff of changes]' \
  '--dry-run[show what would be changed without modifying files]' \
  '--indent-size=[indent size]:size:' \
  '--indent-style=[indent style]:style:(space tab)' \
  '--no-update-lock[do not update lock file]'
