#compdef bean-query

# completions for beancount bean-query SQL-like query tool

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  {-f+,--format=}'[output format]:format:(text csv htmldiv beancount)'
  {-o+,--output=}'[output file]:file:_files'
  '-v[verbose output]'
  '--verbose[verbose output]'
  '--no-errors[do not report errors]'
  '--numberify[convert currencies to numbers]'
  '1:beancount file:_files -g "*.beancount(-.)"'
  '2:query:'
)

_arguments -s -S $arguments
