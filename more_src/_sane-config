#compdef sane-config
# Documentation: https://manpages.org/sane-config
# Report installed libsane build/link flags for SANE frontends

local ret=1

_arguments -s -S \
  '--version[print the installed version of libsane]' \
  '--help[print a short usage message]:option:(--libs --ldflags --cflags --prefix --exec-prefix --version)' \
  '--libs[print additional libraries needed to link a SANE frontend]' \
  '--ldflags[print linker flags needed to link a SANE frontend]' \
  '--cflags[print compiler flags needed to compile a SANE frontend]' \
  '--prefix[print the prefix used during compilation of libsane]' \
  '--exec-prefix[print the exec-prefix used during compilation of libsane]' && ret=0

return ret
