#compdef kubectl-node_shell
# Documentation: https://github.com/kvaps/kubectl-node-shell
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-n --namespace)'{-n,--namespace}'=[Pod namespace]:namespace:' \
  '(-x)'-x'[X-mode: mount /host]' \
  '--kubeconfig=[path]:file:_files' \
  '--context=[kube context]:context:' \
  '*::node or command: _default'
