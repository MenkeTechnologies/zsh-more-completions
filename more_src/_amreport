#compdef amreport
# _amreport — Zmanda Amanda amreport CLI for generating human-readable mail-ready reports of Amanda backup run statistics tapes used disk-list dumps durations errors warnings emailing to admin (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amreport() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-i[do not send mail]' \
        '--no-mail[do not send mail]' \
        '-M+[mail address]:str:' \
        '--mailto=+[mail address]:str:' \
        '-l+[logfile]:file:_files' \
        '--logfile=+[logfile]:file:_files' \
        '-f+[output file]:file:_files' \
        '--print-file=+[output file]:file:_files' \
        '-p+[postscript file]:file:_files -g "*.ps"' \
        '--ps-file=+[postscript file]:file:_files -g "*.ps"' \
        '-x[xml output]' \
        '--xml[xml output]' \
        '-h+[html output]:file:_files -g "*.html"' \
        '--html=+[html output]:file:_files -g "*.html"' \
        '-t+[printer]:str:' \
        '--printer=+[printer]:str:' \
        '-o+[option]:str:' \
        '--from-amdump[from amdump]' \
        '--from-amflush[from amflush]' \
        '*:config:'
}

_amreport "$@"
