#compdef pacemaker pacemakerd
# Documentation: https://man.archlinux.org/search?q=pacemaker
# Reference accessed: 2026-05-16

# pacemakerd: master daemon for Pacemaker cluster resource manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)'{-\$,--version}'[show version]' \
  '-f[run in foreground]' \
  '--foreground[run in foreground]' \
  '-S[run in standalone mode]' \
  '--standalone[run in standalone mode]' \
  '-s[show pacemaker status]' \
  '--shutdown[ask pacemakerd to shut down]' \
  '-F[run as if no quorum is needed]' \
  '--features[show enabled features and exit]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '*::pacemakerd args:_files' && ret=0
return ret
