#compdef pacemaker pacemakerd
# Documentation: https://clusterlabs.org/projects/pacemaker/man/pacemakerd.8.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pacemakerd: master daemon for Pacemaker cluster resource manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--help-all[show all help options]' \
  '(- *)'{-\$,--version}'[show version]' \
  '--output-as=[set output format]:format:(text xml)' \
  '--output-to=[set output destination]:dest:_files' \
  '(-F --features)'{-F,--features}'[show enabled features and exit]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground (ignored)]' \
  '(-p --pid-file)'{-p+,--pid-file=}'[pid file location (ignored)]:file:_files' \
  '(-S --shutdown)'{-S,--shutdown}'[instruct pacemaker to shut down on this node]' \
  '(-s --standby)'{-s,--standby}'[start node in standby mode]' \
  '*'{-V,--verbose}'[increase verbosity]' \
  '*::pacemakerd args:_files' && ret=0
return ret
