#compdef spark-connect-shell

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show this help message and exit]' \
  '(- *)--version[print the version of current Spark]' \
  '-I+[preload file, enforcing line-by-line interpretation]:file:_files' \
  '--master=[master URL]:url:' \
  '--deploy-mode=[where the driver runs]:mode:(client cluster)' \
  '--class=[application main class]:class:' \
  '--name=[application name]:name:' \
  '--jars=[comma-separated list of jars]:jars:' \
  '--packages=[comma-separated list of maven coordinates]:packages:' \
  '--exclude-packages=[comma-separated list of groupId:artifactId to exclude]:packages:' \
  '--repositories=[comma-separated list of additional remote repositories]:repos:' \
  '--py-files=[comma-separated list of .zip, .egg, or .py files]:files:_files' \
  '--files=[comma-separated list of files for executor working dir]:files:_files' \
  '--archives=[comma-separated list of archives]:archives:_files' \
  {-c+,--conf=}'[arbitrary Spark configuration property (KEY=VALUE)]:conf:' \
  '--properties-file=[path to file with extra properties]:file:_files' \
  '--load-spark-defaults[load properties from conf/spark-defaults.conf]' \
  '--driver-memory=[memory for driver]:size:' \
  '--driver-java-options=[extra Java options for driver]:opts:' \
  '--driver-library-path=[extra library path entries for driver]:path:' \
  '--driver-class-path=[extra class path entries for driver]:path:' \
  '--executor-memory=[memory per executor]:size:' \
  '--proxy-user=[user to impersonate when submitting]:user:_users' \
  {-v,--verbose}'[print additional debug output]' \
  '--remote=[Spark Connect server URL]:url:' \
  '--driver-cores=[number of cores for driver in cluster mode]:n:' \
  '--supervise[restart the driver on failure]' \
  '--kill=[kill the driver specified]:submission-id:' \
  '--status=[request the status of the driver specified]:submission-id:' \
  '--total-executor-cores=[total cores for all executors]:n:' \
  '--executor-cores=[number of cores per executor]:n:' \
  '--num-executors=[number of executors to launch]:n:' \
  '--principal=[principal to login to KDC]:principal:' \
  '--keytab=[path to keytab file for principal]:file:_files' && ret=0

return ret
