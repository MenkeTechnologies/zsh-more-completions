#compdef kea-lfc
# Documentation: https://man.archlinux.org/search?q=kea-lfc
# Reference accessed: 2026-05-16

# kea-lfc: Kea lease file cleanup utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[show version]' \
  '-V[show extended version]' \
  '-W[show extended version with files]' \
  '-d[debug mode]' \
  '-4[DHCPv4]' \
  '-6[DHCPv6]' \
  '-p[PID file]:file:_files' \
  '-x[config file]:file:_files' \
  '-i[input file]:file:_files' \
  '-o[output file]:file:_files' \
  '-c[finish file]:file:_files' \
  '-f[copy file]:file:_files' \
  '*::kea-lfc args:_files' && ret=0
return ret
