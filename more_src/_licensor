#compdef licensor
# Documentation: https://man.archlinux.org/search?q=licensor
# Reference accessed: 2026-05-16

# raftario/licensor (clap); Homebrew: Formula/l/licensor.rb

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '(-t)'{-t+,--template=}'[license template id]:template:' \
  '(-y)'{-y+,--year=}'[copyright year]:year:' \
  '(-n)'{-n+,--name=}'[copyright holder name]:name:' \
  '::project path:_files -/' && ret=0
return ret
