#compdef vela

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:create scaffold for vela application'
  'up:deploy one application'
  'status:show status of vela application'
  'ls:list all vela applications'
  'delete:delete applications'
  'env:manage environments'
  'show:show reference doc for component/trait/policy/workflow'
  'addon:manage addons'
  'dry-run:render Kubernetes resources to stdout'
  'live-diff:compare application and revisions'
  'logs:tail logs for vela application'
  'port-forward:forward local ports'
  'exec:execute command inside container'
  'revision:manage application revisions'
  'debug:debug running application'
  'policy:view/test policy definitions'
  'workflow:operate the workflow during delivery'
  'adopt:adopt resources into applications'
  'uischema:manage UI schema for addons'
  'component:list/discover component types'
  'trait:list/discover trait types'
  'def:manage X-Definitions'
  'install:install KubeVela'
  'uninstall:uninstall KubeVela'
  'system:manage system'
  'version:print version'
)

_arguments -C \
  '(-V --verbosity)'{-V,--verbosity=}'[verbosity level]:level:' \
  '(-y --yes)'{-y,--yes}'[assume yes]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'vela subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (up)
        _arguments \
          '--debug[enable debug]' \
          '(-e --env)'{-e,--env=}'[environment]:env:' \
          '(-f --file)'{-f,--file=}'[application file]:file:_files -g "*.(yaml|yml|json)"' \
          '(-n --namespace)'{-n,--namespace=}'[namespace]:namespace:' \
          '(-v --publish-version)'{-v,--publish-version=}'[publish version]:version:' \
          '(-r --revision)'{-r,--revision=}'[revision]:revision:' \
          '(-s --shard-id)'{-s,--shard-id=}'[shard id]:shard:' \
          '--timeout=[timeout]:duration:' \
          '(-w --wait)'{-w,--wait}'[wait for completion]' && ret=0
        ;;
      (status)
        _arguments \
          '--cluster=[cluster]:cluster:' \
          '(-c --component)'{-c,--component=}'[component]:component:' \
          '(-d --detail)'{-d,--detail}'[show detail]' \
          '--detail-format=[detail format]:format:' \
          '(-p --endpoint)'{-p,--endpoint}'[show endpoint]' \
          '(-e --env)'{-e,--env=}'[environment]:env:' \
          '(-m --metrics)'{-m,--metrics}'[show metrics]' \
          '(-n --namespace)'{-n,--namespace=}'[namespace]:namespace:' \
          '(-o --output)'{-o,--output=}'[output format]:format:(table json yaml)' \
          '--pod=[pod name]:pod:' \
          '(-s --svc)'{-s,--svc}'[show service]' \
          '(-t --tree)'{-t,--tree}'[tree view]' && ret=0
        ;;
      (logs)
        _arguments \
          '--cluster=[cluster]:cluster:' \
          '(-c --component)'{-c,--component=}'[component]:component:' \
          '--container=[container]:container:' \
          '(-e --env)'{-e,--env=}'[environment]:env:' \
          '(-n --namespace)'{-n,--namespace=}'[namespace]:namespace:' \
          '(-o --output)'{-o,--output=}'[output format]:format:' \
          '(-p --pod)'{-p,--pod=}'[pod name]:pod:' && ret=0
        ;;
      (install)
        _arguments \
          '(-d --detail)'{-d,--detail}'[detailed output]' \
          '(-f --file)'{-f,--file=}'[file]:file:_files' \
          '(-n --namespace)'{-n,--namespace=}'[namespace]:namespace:' \
          '(-r --reuse)'{-r,--reuse}'[reuse existing values]' \
          '*--set=[set helm values]:value:' \
          '(-v --version)'{-v,--version=}'[version]:version:' && ret=0
        ;;
      (addon)
        _values 'addon action' \
          'disable' 'enable' 'init' 'list' 'package' 'push' 'registry' 'status' 'upgrade' && ret=0
        ;;
      (workflow)
        _values 'workflow action' \
          'debug' 'list' 'logs' 'restart' 'resume' 'rollback' 'suspend' 'terminate' && ret=0
        ;;
      (env)
        _values 'env action' 'delete' 'init' 'ls' 'set' && ret=0
        ;;
      (def)
        _values 'def action' \
          'apply' 'apply-module' 'del' 'edit' 'gen-api' 'gen-cue' 'gen-doc' 'gen-module' \
          'get' 'init' 'init-module' 'list' 'list-module' 'render' 'show' 'upgrade' \
          'validate-module' 'vet' && ret=0
        ;;
    esac
    ;;
esac

return ret
