#compdef rivercarro

# Zsh completion for rivercarro - layout generator for river

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-inner-gaps)'-inner-gaps'[set inner gaps]:pixels' \
  '(-outer-gaps)'-outer-gaps'[set outer gaps]:pixels' \
  '(-main-location)'-main-location'[main area location]:location:(left right top bottom monocle)' \
  '(-main-count)'-main-count'[number of main views]:count' \
  '(-main-ratio)'-main-ratio'[main area ratio]:ratio' \
  '(-no-smart-gaps)'-no-smart-gaps'[disable smart gaps]'
