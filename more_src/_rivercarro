# Zsh completion for rivercarro - layout generator for river

_arguments \
  '(- *)-help[display help message and exit]' \
  '-view-padding[set padding around views in pixels]:pixels' \
  '-outer-padding[set padding around edge of layout area in pixels]:pixels' \
  '-main-location[main area location]:location:(top right bottom left)' \
  '-main-count[number of views in main area]:count' \
  '-main-ratio[ratio of main to total layout area]:ratio' \
  '-no-smart-gaps[disable smart gaps]'
