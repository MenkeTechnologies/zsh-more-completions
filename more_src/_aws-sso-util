#compdef aws-sso-util
# Documentation: https://github.com/benkehoe/aws-sso-util
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'configure:configure AWS profiles for Identity Center'
  'login:authenticate to Identity Center'
  'logout:sign out of Identity Center'
  'roles:display available accounts and roles'
  'run-as:run a command as a specific account/role'
  'console:open AWS console in a browser for an account/role'
  'check:diagnose configuration and access issues'
  'credential-process:credential-process integration helper'
  'admin:admin commands (lookup/assignments/cfn)'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--sso-start-url=[Identity Center start URL]:url:' \
  '--sso-region=[Identity Center region]:region:' \
  '--profile=[AWS profile]:profile:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'aws-sso-util command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (configure)
        local -a cfg_subs=(
          'profile:configure a single AWS profile'
          'populate:generate profiles for all accounts/roles'
        )
        _describe -t cfgsub 'configure subcommand' cfg_subs && ret=0
        _arguments \
          '--region=[default region]:region:' \
          '*--account=[scope to account id]:id:' \
          '*--region-flag=[regions to include]:region:' \
          '--profile-name=[profile naming pattern]:pattern:' \
          '--existing-config-action=[action for existing config]:action:(keep overwrite discard)' \
          '--credential-process[use credential_process]' \
          '--non-interactive[non-interactive mode]' && ret=0 ;;
      (login)
        _arguments \
          '--force-refresh[force a fresh device login]' && ret=0 ;;
      (run-as)
        _arguments \
          '(-a --account)'{-a+,--account=}'[account id]:id:' \
          '(-r --role)'{-r+,--role=}'[role name]:role:' \
          '*::command:_command_names' && ret=0 ;;
      (console)
        _arguments \
          '(-a --account)'{-a+,--account=}'[account id]:id:' \
          '(-r --role)'{-r+,--role=}'[role name]:role:' \
          '--use-existing-credentials[use already-configured creds]' \
          '--browser=[browser to open]:browser:' && ret=0 ;;
      (admin)
        local -a admin_subs=(
          'lookup:lookup Identity Center identifiers'
          'assignments:list assignments'
          'cfn:generate CloudFormation templates'
        )
        _describe -t adm 'admin subcommand' admin_subs && ret=0
        _arguments \
          '*::file:_files' && ret=0 ;;
      (check)
        _arguments \
          '--verbose[verbose output]' && ret=0 ;;
      (credential-process)
        _arguments \
          '(-a --account-id)'{-a+,--account-id=}'[account id]:id:' \
          '(-r --role-name)'{-r+,--role-name=}'[role name]:role:' \
          '--region=[region]:region:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
