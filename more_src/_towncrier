#compdef towncrier
# Documentation: https://towncrier.readthedocs.io/en/stable/cli.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for towncrier - changelog fragment manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a news fragment'
  'build:build the combined news file from news fragments'
  'check:check if a feature branch adds at least one news fragment'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--dir=[execute command relative to PATH]:directory:_files -/' \
  '--config=[path to custom config file]:file:_files' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'towncrier command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (create)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --content)'{-c+,--content=}'[provide fragment content as string]:content' \
          '--edit[launch editor to write content]' \
          '--no-edit[do not launch editor]' \
          '--section=[section to use for the news fragment]:section' \
          '1:fragment name' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--draft[render fragments to stdout without writing files]' \
          '--yes[skip confirmation prompts]' \
          '--version=[version in rendered file]:version' \
          '--date=[date in ISO format for news file]:date' \
          '--name=[project name in output]:name' \
          '--keep[retain fragments after building]' && ret=0
        ;;
      (check)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--compare-with=[comparison branch instead of origin/main]:branch' \
          '--staged[include staged files in fragment detection]' && ret=0
        ;;
    esac
    ;;
esac

return ret
