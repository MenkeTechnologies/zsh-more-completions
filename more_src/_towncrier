#compdef towncrier

# Zsh completion for towncrier - changelog fragment manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a news fragment'
  'build:build the changelog'
  'check:check for news fragments'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'towncrier command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (create)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--dir=[base directory]:directory:_files -/' \
          '--config=[path to configuration file]:file:_files' \
          '-c[pass the content of the news fragment]:content' \
          '--content=[content of the news fragment]:content' \
          '--edit[open an editor to write the content]' \
          '1:fragment name' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--dir=[base directory]:directory:_files -/' \
          '--config=[path to configuration file]:file:_files' \
          '--draft[only render the changelog, do not write or delete]' \
          '--yes[do not ask for confirmation]' \
          '--version=[project version for changelog header]:version' \
          '--date=[date for changelog header]:date' \
          '--name=[project name for changelog header]:name' \
          '--keep[do not delete news fragments after build]' && ret=0
        ;;
      (check)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--dir=[base directory]:directory:_files -/' \
          '--config=[path to configuration file]:file:_files' \
          '--compare-with=[branch to compare with]:branch' \
          '--pyproject=[path to pyproject.toml]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
