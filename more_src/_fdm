#compdef fdm

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'fetch:fetch and deliver'
  'poll:poll accounts'
  'cache:manipulate cache'
)

_arguments -C \
  '*-a[account glob]:account:' \
  '*-D[macro NAME=VALUE]:macro:' \
  '-f[config file]:file:_files' \
  '-h[use $HOME]' \
  '-k[keep all mail]' \
  '-l[syslog]' \
  '-m[ignore lock]' \
  '-n[verify syntax]' \
  '-q[quiet]' \
  '-u[user]:user:_users' \
  '*-v[verbose]' \
  '*-x[exclude account]:account:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'fdm subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (cache) _arguments \
        '1:action:(add remove list dump clear)' \
        '*:path:_files' && ret=0 ;;
    esac ;;
esac

return ret
