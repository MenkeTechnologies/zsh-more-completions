#compdef isotest
# Documentation: https://github.com/bluez/bluez/blob/master/tools/isotest.c
# Source: BlueZ tools/isotest.c — LE Isochronous Channels (CIS/BIS) test harness.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --dump -c --reconnect -m --multiple -r --receive -s --send -n --silent)'{-d+,--dump=}'[dump (server) optional filename]:file:_files' \
    '(-d --dump -c --reconnect -m --multiple -r --receive -s --send -n --silent)'{-c,--reconnect}'[reconnect (client)]' \
    '(-d --dump -c --reconnect -m --multiple -r --receive -s --send -n --silent)'{-m,--multiple}'[multiple connects (client)]' \
    '(-d --dump -c --reconnect -m --multiple -r --receive -s --send -n --silent)'{-r+,--receive=}'[receive (server) optional filename]:file:_files' \
    '(-d --dump -c --reconnect -m --multiple -r --receive -s --send -n --silent)'{-s+,--send=}'[connect and send (client/broadcaster)]:files:' \
    '(-d --dump -c --reconnect -m --multiple -r --receive -s --send -n --silent)'{-n,--silent}'[connect and be silent (client)]' \
    '(-b --bytes)'{-b+,--bytes=}'[data size in bytes]:bytes:' \
    '(-i --device)'{-i+,--device=}'[device index or address]:device:' \
    '(-j --jitter)'{-j+,--jitter=}'[socket/jitter buffer bytes]:bytes:' \
    '(- *)'{-h,--help}'[show help]' \
    '(-q --quiet)'{-q,--quiet}'[disable packet logging]' \
    '(-t --timeout)'{-t+,--timeout=}'[send timeout (usec)]:usec:' \
    '(-C --continue)'{-C,--continue}'[repeat mode]' \
    '(-W --defer)'{-W+,--defer=}'[deferred setup seconds]:seconds:' \
    '(-M --mtu)'{-M+,--mtu=}'[max transmission unit]:mtu:' \
    '(-S --sca)'{-S+,--sca=}'[SCA or advertising interval]:val:' \
    '(-P --packing)'{-P+,--packing=}'[packing parameter]:val:' \
    '(-F --framing)'{-F+,--framing=}'[framing parameter]:val:' \
    '(-I --interval)'{-I+,--interval=}'[interval (usec)]:usec:' \
    '(-L --latency)'{-L+,--latency=}'[latency (ms)]:ms:' \
    '(-Y --phy)'{-Y+,--phy=}'[PHY value]:phy:' \
    '(-R --rtn)'{-R+,--rtn=}'[retransmission number]:n:' \
    '(-B --preset)'{-B+,--preset=}'[QoS preset configuration]:preset:' \
    '(-G --CIG)'{-G+,--CIG=}'[CIG/BIG identifier]:id:' \
    '(-T --CIS)'{-T+,--CIS=}'[CIS/BIS identifier]:id:' \
    '(-V --type)'{-V+,--type=}'[address type (use "help" for list)]:type:' \
    '(-N --nbis)'{-N+,--nbis=}'[number of BISes to create / sync to]:n:' \
    && ret=0

return ret
