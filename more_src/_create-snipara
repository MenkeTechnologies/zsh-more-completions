#compdef create-snipara
# Documentation: https://www.npmjs.com/package/create-snipara
# Reference accessed: 2026-05-24
# Verified: npm view create-snipara bin; npx create-snipara --help output.

# Zsh completion for create-snipara - Snipara MCP and companion workflow scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--api-key=[Snipara API key]:key:' \
  '--slug=[project slug]:slug:' \
  '--project-id=[Snipara project id]:id:' \
  '--client=[AI client target]:client:(claude-code cursor windsurf codex gemini chatgpt vscode continue claude-desktop other)' \
  '--advanced[show advanced profile, hooks, GitHub, and sandbox prompts]' \
  '--profile=[install profile]:profile:(hosted-only hosted-companion full-stack runtime-only)' \
  '--skip-companion[skip local companion CLI installation]' \
  '--skip-mcp[skip local snipara-mcp package installation]' \
  '--skip-runtime[skip snipara-sandbox installation]' \
  '--skip-hooks[skip hook generation]' \
  '--skip-test[skip hosted connection test]' \
  '--with-orchestrator[install optional snipara-orchestrator package]' \
  '--github[open GitHub repository automation setup]' \
  '--skip-github[skip GitHub automation prompt]' \
  '--github-path=[GitHub path filter for initial sync]:path:' \
  '--runtime-only[install only Snipara Sandbox]' \
  '(-y --yes)'{-y,--yes}'[accept defaults without prompting]' \
  '(-V --version)'{-V,--version}'[output version]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' init doctor repair upgrade print-config && ret=0
    ;;
  args)
    case $line[1] in
      doctor|repair|upgrade|print-config)
        _arguments -C \
          '--client=[AI client target]:client:(claude-code cursor codex gemini)' \
          '--json[JSON output]' && ret=0
        ;;
      init|*)
        _arguments -C \
          '--profile=[install profile]:profile:(hosted-only hosted-companion full-stack runtime-only)' \
          '--github[enable GitHub repository automation]' \
          '(-y --yes)'{-y,--yes}'[accept defaults]' \
          ':project directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
