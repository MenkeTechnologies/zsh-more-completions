#compdef pvbatch
# Documentation: https://docs.paraview.org/en/latest/UsersGuide/commandLineArguments.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ParaView pvbatch: batch script runner (Python)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(--help)--help[show help]' \
  '(--version)--version[show version]' \
  '--displays[display list for distributed rendering]:list:' \
  '--enable-bt[enable backtrace on signal]' \
  '--force-offscreen-rendering[force OS Mesa offscreen rendering]' \
  '--symmetric[symmetric (all-rank) batch execution]' \
  '--multi-clients[allow multiple connections]' \
  '--disable-registry[do not read registry settings]' \
  '--multi-servers[allow multiple servers]' \
  '--no-mpi[do not initialize MPI]' \
  '--ms[multi-servers]' \
  '--mr[multi-clients ready]' \
  '--script=[Python script]:file:_files -g "*.py"' \
  '*:script and args:_files -g "*.py"' && ret=0
return ret
