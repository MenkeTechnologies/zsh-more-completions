#compdef kernelstub
# _kernelstub — Pop_OS kernelstub (configure systemd-boot ESP layout for a current Linux kernel + initrd; -c (vmlinuz)/-i (initrd) override paths, --add-options/--remove-options/--get-options edit boot args, --esp-path picks ESP mountpoint, --kernel-path)
# upstream: https://github.com/pop-os/kernelstub
# Flags from kernelstub kernelstub/cli.py on tip.

_kernelstub() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--version[show version]' \
        '--dry-run[do not write changes]' \
        '--print-config[print config]' \
        '-c+[kernel image path]:file:_files' \
        '--kernel-path+[kernel image path]:file:_files' \
        '-i+[initrd path]:file:_files' \
        '--initrd-path+[initrd path]:file:_files' \
        '-a+[add kernel option]:option:' \
        '--add-options+[add kernel option]:option:' \
        '-d+[remove kernel option]:option:' \
        '--remove-options+[remove kernel option]:option:' \
        '-g[get kernel options]' \
        '--get-options[get kernel options]' \
        '-e+[ESP path]:dir:_files -/' \
        '--esp-path+[ESP path]:dir:_files -/' \
        '-l+[loader path]:dir:_files -/' \
        '--loader-path+[loader path]:dir:_files -/' \
        '-s+[stub name]:name:'
}

_kernelstub "$@"
