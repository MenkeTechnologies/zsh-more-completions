#compdef readlink-cli
# _readlink-cli — GNU coreutils readlink print resolved symbolic links CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_readlink-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-f[follow each component]' \
        '--canonicalize[follow each component]' \
        '-e[require components exist]' \
        '--canonicalize-existing[require components exist]' \
        '-m[no require components exist]' \
        '--canonicalize-missing[no require components exist]' \
        '-n[no trailing newline]' \
        '--no-newline[no trailing newline]' \
        '-q[suppress errors]' \
        '--quiet[suppress errors]' \
        '--silent[suppress errors]' \
        '-s[suppress errors]' \
        '-v[report errors]' \
        '--verbose[report errors]' \
        '-z[NUL terminator]' \
        '--zero[NUL terminator]' \
        '*:files:_files'
}

_readlink-cli "$@"
