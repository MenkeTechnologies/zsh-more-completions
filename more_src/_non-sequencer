#compdef non-sequencer
# Documentation: https://man.archlinux.org/search?q=non-sequencer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--nsm-url=+[NSM session url]:url:' \
  '*:project:_files' && ret=0

return ret
