#compdef pyznap

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'setup:create config dir and sample config'
  'snap:take and clean snapshots'
  'send:send snapshots to backup locations'
)

_arguments -C \
  '--config=[config file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pyznap subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (setup)
        _arguments '-p[setup path]:path:_files -/' && ret=0
        ;;
      (snap)
        _arguments \
          '--take[take snapshots only]' \
          '--clean[clean snapshots only]' \
          '--full[take and clean (default)]' && ret=0
        ;;
      (send)
        _arguments \
          '-s[source]:source:' \
          '-d[destination]:dest:' \
          '-c[compression]:type:(none lzop lz4 gzip pigz bzip2 xz)' \
          '-i[keyfile]:file:_files' \
          '-j[source key]:file:_files' \
          '-k[dest key]:file:_files' \
          '-e[exclude]:pattern:' \
          '-w[ZFS raw send]' \
          '-r[resumable]' \
          '--dest-auto-create[auto-create destination]' \
          '--retries=[retries]:n:' \
          '--retry-interval=[retry interval seconds]:secs:' && ret=0
        ;;
    esac
    ;;
esac

return ret
