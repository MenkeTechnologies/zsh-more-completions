#compdef ngs
# Documentation: https://github.com/ngs-lang/ngs/blob/master/doc/ngs.1.md
# ngs - Next Generation Shell: language and interactive shell

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-e -E -p -pi -pj -ppj -pl -pjl -pt)-e[evaluate the expression]:expression:' \
  '(-e -E -p -pi -pj -ppj -pl -pjl -pt)-E[evaluate expression without loading stdlib.ngs]:expression:' \
  '(-e -E -p -pi -pj -ppj -pl -pjl -pt)-p[print result in human readable NGS format]:expression:' \
  '(-e -E -p -pi -pj -ppj -pl -pjl -pt)-pi[print inspect() detailed info of result]:expression:' \
  '(-e -E -p -pi -pj -ppj -pl -pjl -pt)-pj[print result as JSON]:expression:' \
  '(-e -E -p -pi -pj -ppj -pl -pjl -pt)-ppj[print result as pretty JSON (requires jq)]:expression:' \
  '(-e -E -p -pi -pj -ppj -pl -pjl -pt)-pl[print elements of result one per line]:expression:' \
  '(-e -E -p -pi -pj -ppj -pl -pjl -pt)-pjl[print elements one per line as JSON]:expression:' \
  '(-e -E -p -pi -pj -ppj -pl -pjl -pt)-pt[print result as a table]:expression:' \
  '*:script:_files -g "*.ngs"' && ret=0

return ret
