#compdef addglyph
# _addglyph — Adobe afdko addGlyph CLI for inserting external glyph definitions into UFO and OTF source font with auto-generated glyph names and post-processing for cmap and feature updates (adobe-type-tools team, Python); argparse
# upstream: https://github.com/adobe-type-tools/afdko

_addglyph() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[input glyph file]:file:_files -g "*.glif *.svg *.ufo *.ai *.eps *.pdf"' \
        '--input=+[input glyph file]:file:_files -g "*.glif *.svg *.ufo *.ai *.eps *.pdf"' \
        '-n+[glyph name]:str:' \
        '--name=+[glyph name]:str:' \
        '-u+[unicode hex]:str:' \
        '--unicode=+[unicode hex]:str:' \
        '-f+[feature file]:file:_files -g "*.fea"' \
        '--feature-file=+[feature file]:file:_files -g "*.fea"' \
        '--update-cmap[update cmap]' \
        '--no-update-cmap[no update cmap]' \
        '--force[overwrite existing]' \
        '*:font UFO or OTF:_files -g "*.ufo *.otf"'
}

_addglyph "$@"
