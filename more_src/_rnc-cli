#compdef rnc-cli
# Documentation: https://www.npmjs.com/package/@react-native-community/cli
# Reference accessed: 2026-05-23
# Verified: npx @react-native-community/cli --help.

# Zsh completion for rnc-cli - React Native Community CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new React Native app'
  'doctor:diagnose and fix common issues'
  'help:display command help'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show version]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'rnc-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments           '--version[React Native version]'           '--template=[project template]:template:'           '--npm[use npm]'           '--yarn[use yarn]'           '--skip-install[skip dependency install]'           ':project name:' && ret=0 ;;
      (*)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
