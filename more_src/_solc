#compdef solc solcjs

# Zsh completion for solc - Solidity compiler

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(- *)--license[show license]' \
  '--base-path=[use the given path as the root of the source tree]:path:_directories' \
  '*--include-path=[extra source directories available for imports]:path:_directories' \
  '--allow-paths=[allow a given path for imports]:paths' \
  '(-o --output-dir)'{-o,--output-dir}'[output directory]:directory:_directories' \
  '--overwrite[overwrite existing files]' \
  '--abi[generate ABI specification]' \
  '--asm[generate EVM assembly]' \
  '--ast-compact-json[generate AST in compact JSON format]' \
  '--bin[generate binary of the contracts in hex]' \
  '--bin-runtime[generate binary of the runtime part of the contracts]' \
  '--combined-json=[output a single JSON document]:outputs:_values -s , "output type" abi asm ast bin bin-runtime devdoc function-debug function-debug-runtime generated-sources generated-sources-runtime hashes metadata opcodes srcmap srcmap-runtime storage-layout userdoc' \
  '--gas[print an estimate of contract gas usage]' \
  '--hashes[generate function signature hashes]' \
  '--metadata[generate metadata output]' \
  '--devdoc[generate developer documentation (natspec)]' \
  '--userdoc[generate user documentation (natspec)]' \
  '--storage-layout[generate storage layout]' \
  '--ir[generate Yul intermediate representation]' \
  '--ir-optimized[generate optimized Yul intermediate representation]' \
  '--opcodes[generate opcodes output]' \
  '--optimize[enable optimizer]' \
  '--optimize-runs=[set expected number of contract runs for optimizer]:runs' \
  '--via-ir[change compilation pipeline to go through Yul IR]' \
  '--yul[input is in Yul language]' \
  '--strict-assembly[input is in strict assembly]' \
  '--import-ast[import AST from JSON]' \
  '--lsp[start Language Server Protocol mode]' \
  '--standard-json[enable standard JSON input/output mode]' \
  '--link[enable linker mode]' \
  '--libraries=[direct string or file containing library addresses]:libraries' \
  '--evm-version=[set target EVM version]:version:(homestead tangerineWhistle spuriousDragon byzantium constantinople petersburg istanbul berlin london paris shanghai)' \
  '--metadata-hash=[choose hash method for metadata]:hash:(ipfs bzzr1 none)' \
  '--metadata-literal[store referenced sources as literal data in metadata]' \
  '--model-checker-engine=[set model checker engine]:engine:(all bmc chc eld)' \
  '--model-checker-timeout=[set model checker timeout in milliseconds]:timeout' \
  '--error-codes[output error codes]' \
  '--json-indent=[set JSON indentation level]:indent' \
  '--error-recovery[enable error recovery mode]' \
  '--no-color[disable colored output]' \
  '*:Solidity source files:_files -g "*.sol"'
