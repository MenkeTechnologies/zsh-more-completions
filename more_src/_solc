#compdef solc solcjs

# Zsh completion for solc - Solidity compiler

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(- *)--license[show license]' \
  '--base-path[set base path for imports]:path:_files -/' \
  '*--include-path[add include path for imports]:path:_files -/' \
  '--allow-paths[allow paths for imports]:paths' \
  '(-o --output-dir)'{-o,--output-dir}'[output directory]:directory:_files -/' \
  '--overwrite[overwrite existing files]' \
  '--abi[output ABI specification]' \
  '--asm[output EVM assembly]' \
  '--ast-compact-json[output AST as compact JSON]' \
  '--bin[output binary of contracts]' \
  '--bin-runtime[output runtime binary of contracts]' \
  '--combined-json[output combined JSON]:outputs:_values -s , "output" abi asm ast bin bin-runtime devdoc function-debug function-debug-runtime generated-sources generated-sources-runtime hashes metadata opcodes srcmap srcmap-runtime storage-layout userdoc' \
  '--gas[print gas estimates]' \
  '--hashes[output function signature hashes]' \
  '--metadata[output metadata]' \
  '--devdoc[output developer documentation]' \
  '--userdoc[output user documentation]' \
  '--storage-layout[output storage layout]' \
  '--ir[output intermediate representation]' \
  '--ir-optimized[output optimized intermediate representation]' \
  '--opcodes[output opcodes]' \
  '--optimize[enable optimizer]' \
  '--optimize-runs[set expected number of contract runs for optimizer]:runs' \
  '--via-ir[compile via IR pipeline]' \
  '--yul[input is Yul]' \
  '--strict-assembly[input is strict assembly]' \
  '--import-ast[import AST from JSON]' \
  '--lsp[run in Language Server Protocol mode]' \
  '--standard-json[read input from stdin in standard JSON format]' \
  '--link[perform linking]' \
  '*--libraries[link libraries]:libraries' \
  '--evm-version[set target EVM version]:version:(homestead tangerineWhistle spuriousDragon byzantium constantinople petersburg istanbul berlin london paris shanghai)' \
  '--metadata-hash[set metadata hash type]:hash:(ipfs bzzr1 none)' \
  '--metadata-literal[store referenced sources as literal data]' \
  '--model-checker-engine[set model checker engine]:engine:(all bmc chc eld)' \
  '--model-checker-timeout[set model checker timeout in ms]:timeout' \
  '--error-codes[output error codes]' \
  '--json-indent[set JSON indentation level]:indent' \
  '--error-recovery[enable error recovery mode]' \
  '--no-color[disable colored output]' \
  '*:solidity files:_files -g "*.sol"'
