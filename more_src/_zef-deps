#compdef zef-deps zef-deps-j zef-deps-js zef-deps-m
# Documentation: https://man.archlinux.org/search?q=zef-deps
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--png[output PNG dependency graph]' \
  '--json[output JSON]' \
  '*:Raku module:' && ret=0

return ret
