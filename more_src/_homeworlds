#compdef homeworlds-cli homeworlds-wx
# Documentation: https://man.archlinux.org/search?q=homeworlds-cli
# Reference accessed: 2026-05-16

# Zsh completion for Quux Homeworlds CLI and wx GUI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::args:{ _message "Homeworlds game arguments" }' && ret=0

return ret
