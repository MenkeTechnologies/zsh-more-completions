#compdef amp2response
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/amp2response.html
# Source: MRtrix3/mrtrix3 cmd/amp2response.cpp — estimate response function from amplitudes (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-isotropic[estimate an isotropic response function (lmax=0 for all shells)]' \
    '-noconstraint[disable non-negativity and monotonicity constraints]' \
    '-directions+[external directions text file]:file:_files' \
    '-lmax+[max harmonic degree(s); comma-separated per shell]:values:_default' \
    '1:amps (amplitudes image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:mask:_files -g "*.{nii,nii.gz,mif}"' \
    '3:directions (4D image of estimated fibre directions):_files -g "*.{nii,nii.gz,mif}"' \
    '4:response (output ZSH coefficients):_files -g "*.txt"' \
    && ret=0

return ret
