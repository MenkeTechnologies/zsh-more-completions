#compdef cdpr
# Documentation: https://man.archlinux.org/search?q=cdpr
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-d+[interface to listen on]:iface:_net_interfaces' \
  '-t+[timeout sec]:sec:' \
  '-v+[verbosity level]:lvl:(0 1 2 3)' && ret=0

return ret
