#compdef cdpr
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man8/cdpr.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-d+[device to listen on (eth0, hme0, etc.)]:iface:_net_interfaces' \
  '-t+[time in seconds to abort waiting for packets (default 300)]:sec:' \
  '-v[report all known TLVs (use -vv for unknown TLVs)]' \
  '-vv[report unknown TLVs as well]' && ret=0

return ret
