#compdef diesel

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'setup:create the database and run migrations'
  'database:manage the database'
  'migration:manage migrations'
  'print-schema:print the database schema'
  'completions:generate shell completions'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--database-url=[database URL]:URL' \
  '--config-file=[diesel.toml config file]:config file:_files -g "*.toml"' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'diesel command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      setup)
        _arguments -s -S \
          '--migration-dir=[migration directory]:directory:_directories' && ret=0
        ;;
      database)
        local -a db_cmds=(
          'setup:create and run migrations'
          'reset:drop, create, and run migrations'
          'drop:drop the database'
        )
        _arguments -s -S \
          '1:database command:->db_cmd' && ret=0
        case "$state" in
          db_cmd)
            _describe -t commands 'database subcommand' db_cmds && ret=0
            ;;
        esac
        ;;
      migration)
        local -a mig_cmds=(
          'generate:generate a new migration'
          'run:run pending migrations'
          'revert:revert the last migration'
          'redo:revert and re-run the last migration'
          'list:list all migrations'
          'pending:show pending migrations'
        )
        _arguments -s -S \
          '--migration-dir=[migration directory]:directory:_directories' \
          '1:migration command:->mig_cmd' \
          '*::args:->mig_args' && ret=0
        case "$state" in
          mig_cmd)
            _describe -t commands 'migration subcommand' mig_cmds && ret=0
            ;;
          mig_args)
            case "${words[1]}" in
              generate)
                _arguments -s -S \
                  '--diff-schema[generate based on schema diff]' \
                  '--version=[use specific version string]:version' \
                  '--format=[SQL file format]:format:(barrel)' \
                  '1:migration name:' && ret=0
                ;;
              run|revert|redo)
                _arguments -s -S \
                  '-n+[number of migrations]:count' \
                  '--all[apply to all migrations]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      print-schema)
        _arguments -s -S \
          '-s+[filter schema]:schema' \
          '--schema=[filter schema]:schema' \
          '-o=[table filter]:filter' \
          '--only-tables=[only include tables]:tables' \
          '--except-tables=[exclude tables]:tables' \
          '--with-docs[include doc comments]' \
          '--column-sorting=[column sort]:sort:(ordinal_position name)' \
          '--patch-file=[apply patch to schema]:file:_files' \
          '--import-types=[add import type]:type' && ret=0
        ;;
    esac
    ;;
esac

return ret
