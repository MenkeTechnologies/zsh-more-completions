#compdef chronic
# _chronic — moreutils chronic (run a command quietly: prints stdout+stderr only if the command exits non-zero; useful inside cron to suppress noise from successful runs; -v always prints, -e prints when stderr produced even on zero exit, -V verbose)
# upstream: https://salsa.debian.org/built-using-team/moreutils (joeyh)
# Flags from moreutils chronic.pl on tip.

_chronic() {
    _arguments \
        '-e[print output if stderr produced even on success]' \
        '-v[always print output]' \
        '-V[verbose chronic itself]' \
        '*:command:_command_names -e'
}

_chronic "$@"
