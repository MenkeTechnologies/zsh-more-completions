#compdef ddrescueview
# Documentation: https://man.archlinux.org/search?q=ddrescueview
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:mapfile:_files -g "*.{map,log,ddrescue}"' && ret=0

return ret
