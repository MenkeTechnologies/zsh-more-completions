#compdef obs-cli
# Documentation: https://github.com/muesli/obs-cli
# Reference accessed: 2026-05-19
# Verified: muesli/obs-cli README. Global flags: --host, --port,
# --password. Subcommands: stream, recording, scene,
# scenecollection, sceneitem, label, source, studiomode, profile,
# replaybuffer, virtualcam.
# Corrected from prior file: 'record' -> 'recording',
# 'replay' -> 'replaybuffer'; added scenecollection, sceneitem,
# label, profile, source subcommands.

# Zsh completion for obs-cli - OBS Studio command-line remote control

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'scene:manage scenes'
  'scenecollection:manage scene collections'
  'sceneitem:manage scene items'
  'source:manage sources'
  'stream:manage streaming'
  'recording:manage recording'
  'virtualcam:manage virtual camera'
  'replaybuffer:manage replay buffer'
  'studiomode:manage studio mode'
  'profile:manage profiles'
  'label:manage label sources'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--host=[websocket host]:host:' \
  '--port=[websocket port]:port:' \
  '--password=[websocket password]:password:' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'obs-cli command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      scene)
        local -a scene_cmds=(
          'list:list scenes'
          'get:get a scene'
          'current:show current scene'
          'preview:set preview scene'
          'switch:switch to scene'
        )
        _describe -t commands 'scene command' scene_cmds && ret=0
        ;;
      stream)
        local -a stream_cmds=(
          'start:start streaming'
          'stop:stop streaming'
          'toggle:toggle streaming'
          'status:get streaming status'
        )
        _describe -t commands 'stream command' stream_cmds && ret=0
        ;;
      recording)
        local -a rec_cmds=(
          'start:start recording'
          'stop:stop recording'
          'toggle:toggle recording'
          'pause:pause recording'
          'status:get recording status'
        )
        _describe -t commands 'recording command' rec_cmds && ret=0
        ;;
      virtualcam)
        local -a vc_cmds=(
          'start:start virtual camera'
          'stop:stop virtual camera'
          'toggle:toggle virtual camera'
          'status:get status'
        )
        _describe -t commands 'virtualcam command' vc_cmds && ret=0
        ;;
      replaybuffer)
        local -a rb_cmds=(
          'start:start replay buffer'
          'stop:stop replay buffer'
          'save:save replay buffer'
          'status:get status'
        )
        _describe -t commands 'replaybuffer command' rb_cmds && ret=0
        ;;
      studiomode)
        local -a sm_cmds=(
          'enable:enable studio mode'
          'disable:disable studio mode'
          'toggle:toggle studio mode'
          'status:get status'
          'transition:trigger transition'
        )
        _describe -t commands 'studiomode command' sm_cmds && ret=0
        ;;
      profile)
        local -a pf_cmds=(
          'list:list profiles'
          'get:get current profile'
          'set:set profile'
        )
        _describe -t commands 'profile command' pf_cmds && ret=0
        ;;
      scenecollection)
        local -a sc_cmds=(
          'list:list scene collections'
          'get:get current scene collection'
          'set:set scene collection'
        )
        _describe -t commands 'scenecollection command' sc_cmds && ret=0
        ;;
      sceneitem)
        local -a si_cmds=(
          'list:list scene items'
          'show:show item'
          'hide:hide item'
          'toggle:toggle visibility'
          'visible:query visibility'
          'center:center item'
        )
        _describe -t commands 'sceneitem command' si_cmds && ret=0
        ;;
      source)
        local -a sr_cmds=(
          'list:list sources'
          'toggle-mute:toggle source mute'
        )
        _describe -t commands 'source command' sr_cmds && ret=0
        ;;
      label)
        local -a lb_cmds=(
          'text:modify FreeType text'
          'countdown:trigger timed countdown'
        )
        _describe -t commands 'label command' lb_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
