#compdef desmume desmume-cli
# Documentation: https://github.com/TASEmulators/desmume/blob/master/desmume/src/commandline.cpp
# Reference accessed: 2026-05-16
# Verified: desmume/src/commandline.cpp:260 (shared getopt_long parser) + help
# string lines 49-130 + posix CLI extras in desmume/src/frontend/posix/cli/main.cpp:169.

# DeSmuME: Nintendo DS emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--num-cores=[override numcores detection]:n:' \
  '--spu-synch=[SPU sync mode]:mode:' \
  '--spu-method=[SPU sync method]:method:' \
  '--3d-render=[3D renderer]:renderer:(SW AUTOGL GL OLDGL)' \
  '--3d-texture-deposterize-enable[enable texture deposterize]' \
  '--3d-texture-upscale=[upscale factor]:n:(1 2 4)' \
  '--3d-texture-smoothing-enable[enable texture smoothing]' \
  '--scale=[window scale factor]:n:' \
  '--horizontal[touch screen on the right]' \
  '--nojoy[disable joystick]' \
  '--disable-sound[disable sound]' \
  '--disable-limiter[disable framerate limiter]' \
  '--rtc-day=[RTC day]:n:' \
  '--rtc-hour=[RTC hour]:n:' \
  '--frameskip=[frameskip]:n:' \
  '--jit-enable[enable JIT (if built)]' \
  '--jit-size=[JIT size (if built)]:n:' \
  '--advanced-timing[advanced bus timing]' \
  '--rigorous-timing[rigorous timing]' \
  '--gamehacks[enable game hacks]' \
  '--spu-advanced[advanced SPU emulation]' \
  '--backupmem-db[use backup memory DB]' \
  '--console-type=[DS console type]:type:(FAT LITE IQUE DEBUG DSI)' \
  '--bios-arm9=[ARM9 BIOS file]:file:_files -g "*.bin"' \
  '--bios-arm7=[ARM7 BIOS file]:file:_files -g "*.bin"' \
  '--firmware-path=[firmware file]:file:_files -g "*.bin"' \
  '--firmware-boot=[boot from firmware]:bool:(0 1)' \
  '--bios-swi[use BIOS SWI]' \
  '--lang=[firmware language 0..5]:n:(0 1 2 3 4 5)' \
  '--slot1=[Slot-1 mode]:type:(RETAIL RETAILAUTO R4 RETAILNAND RETAILMCDROM RETAILDEBUG)' \
  '--preload-rom[preload ROM]' \
  '--slot1-fat-dir=[Slot-1 FAT directory]:dir:_files -/' \
  '--slot1_no8000prot[disable slot1 0x8000 protection]' \
  '--cflash-image=[CompactFlash image]:file:_files' \
  '--cflash-path=[CompactFlash directory]:dir:_files -/' \
  '--gbaslot-rom=[GBA slot ROM]:file:_files -g "*.gba"' \
  '--start-paused[start paused]' \
  '--load-slot=[save slot to load]:n:' \
  '--play-movie=[play movie file]:file:_files -g "*.dsm"' \
  '--record-movie=[record movie file]:file:_files -g "*.dsm"' \
  '--scanline-filter-a=[scanline filter A]:n:' \
  '--scanline-filter-b=[scanline filter B]:n:' \
  '--scanline-filter-c=[scanline filter C]:n:' \
  '--scanline-filter-d=[scanline filter D]:n:' \
  '--arm9gdb=[ARM9 GDB stub port]:port:' \
  '--arm7gdb=[ARM7 GDB stub port]:port:' \
  '--auto-pause[CLI: auto-pause on focus loss]' \
  '--3d-engine=[CLI: 3D engine]:engine:' \
  '--save-type=[CLI: save type]:type:' \
  '--fwlang=[CLI: firmware language]:lang:' \
  '*:NDS ROM:_files -g "*.(nds|gba|zip|7z)"' && ret=0
return ret
