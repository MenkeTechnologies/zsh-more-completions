#compdef vgextend
# _vgextend — add physical volume(s) to a volume group (LVM2)
# upstream: https://gitlab.com/lvmteam/lvm2

_vgextend() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-A --autobackup)'{-A,--autobackup}'+[autobackup]:bool:(y n)' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-y --yes)'{-y,--yes}'[no prompts]' \
        '(-t --test)'{-t,--test}'[dry run]' \
        '(-Z --zero)'{-Z,--zero}'+[zero first sector]:bool:(y n)' \
        '--restoremissing[restore missing pv]' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '--dataalignment+[data alignment]:size:' \
        '--dataalignmentoffset+[data alignment offset]:size:' \
        '--metadatasize+[metadata size]:size:' \
        '--metadatatype+[metadata type]:type:(lvm1 lvm2)' \
        '--metadataignore+[ignore metadata]:bool:(y n)' \
        '--pvmetadatacopies+[metadata copies]:n:' \
        '1:vg:' \
        '*:pv device:_files'
}

_vgextend "$@"
