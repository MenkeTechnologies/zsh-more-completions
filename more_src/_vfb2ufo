#compdef vfb2ufo vfblib vfblib2ufo vfb2json
# _vfb2ufo — Lukas Schneider LucasFonts vfbLib vfb2ufo CLI for converting legacy FontLab .vfb binary font sources to UFO and JSON formats for migration to modern font editors (LucasFonts team, Python); argparse
# upstream: https://github.com/LucasFonts/vfbLib

_vfb2ufo() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '-f+[format]:f:(ufo3 ufo2 json plist xml)' \
        '--format=+[format]:f:(ufo3 ufo2 json plist xml)' \
        '--no-glyphs[no glyphs]' \
        '--no-info[no fontinfo]' \
        '--no-features[no features]' \
        '--no-kerning[no kerning]' \
        '--no-groups[no groups]' \
        '--no-lib[no lib]' \
        '--include-features-import[include features import]' \
        '--scale=+[F]:f:' \
        '--minimize[minimize]' \
        '--keep-aliases[keep aliases]' \
        '--no-decompose[no decompose]' \
        '--force[overwrite]' \
        '*:VFB file:_files -g "*.vfb"'
}

_vfb2ufo "$@"
