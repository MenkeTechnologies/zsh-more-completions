#compdef aread8 AreaD8
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/D8ContributingArea.html
# TauDEM: compute D8 contributing area

local ret=1

_arguments -s -S \
  '-p[input D8 flow directions grid]:pfile:_files' \
  '-ad8[output contributing area grid]:ad8file:_files' \
  '-o[input outlets file (OGR readable dataset)]:outletfile:_files' \
  '-wg[input weight grid]:wgfile:_files' \
  '-nc[disable edge contamination checking]' \
  '(-lyrno)-lyrname[OGR layer name for outlets]:layer name:' \
  '(-lyrname)-lyrno[OGR layer number for outlets]:layer number:' \
  '*:file:_files' && ret=0

return ret
