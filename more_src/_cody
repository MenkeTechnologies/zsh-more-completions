#compdef cody

# Zsh completion for Sourcegraph Cody CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--access-token=[Sourcegraph access token]:token' \
  '--endpoint=[Sourcegraph instance URL]:url' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'auth:manage authentication'
      'chat:start a chat session'
      'completions:get code completions'
    )
    _describe -t commands 'cody command' commands && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->auth_cmds' \
          '*::arg:->auth_args' && ret=0
        case $state in
          auth_cmds)
            local -a auth_commands=(
              'login:authenticate with Sourcegraph'
              'logout:remove authentication'
              'status:show authentication status'
              'accounts:list authenticated accounts'
            )
            _describe -t commands 'auth subcommand' auth_commands && ret=0
            ;;
          auth_args)
            case $line[1] in
              login)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--access-token=[access token]:token' \
                  '--endpoint=[Sourcegraph URL]:url' \
                  '--web[authenticate via web browser]' && ret=0
                ;;
              logout|status|accounts)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      chat)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--access-token=[access token]:token' \
          '--endpoint=[Sourcegraph URL]:url' \
          '--model=[model to use]:model' \
          '--context-repo=[repository for context]:repo' \
          '--context-file=[file for context]:file:_files' \
          '-m=[message to send]:message' \
          '--message=[message to send]:message' \
          '--stdin[read message from stdin]' \
          '--show-context[show context used]' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--access-token=[access token]:token' \
          '--endpoint=[Sourcegraph URL]:url' \
          '--filename=[filename for context]:file:_files' \
          '--stdin[read from stdin]' && ret=0
        ;;
    esac
    ;;
esac

return ret
