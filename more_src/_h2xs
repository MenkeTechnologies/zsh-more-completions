#compdef h2xs
# Documentation: h2xs -h (Perl)
# Source: scaffold a Perl XS extension from a C header file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,-?,--help}'[show help]' \
    '(- *)--version[show version]' \
    {-A,--omit-autoload}'[omit autoloading (implies -c)]' \
    {-B,--beta-version}'[use beta $VERSION 0.00_01]' \
    {-C,--omit-changes}'[omit Changes file]' \
    '*'{-F+,--cpp-flags=}'[extra C preprocessor flags]:flags:' \
    {-M+,--func-mask=}'[mask to select functions/macros]:mask:' \
    {-O,--overwrite-ok}'[overwrite existing extension dir]' \
    {-P,--omit-pod}'[omit stub POD]' \
    {-X,--omit-XS}'[omit XS portion]' \
    {-a,--gen-accessors}'[generate accessors for struct/union]' \
    {-b+,--compat-version=}'[backwards-compatible perl version]:version:' \
    {-c,--omit-constant}'[omit constant() and autoload]' \
    {-d,--debugging}'[debugging messages]' \
    {-e+,--omit-enums=-}'[omit enum constants (optional regex)]::pattern:' \
    {-f,--force}'[force creation even without header]' \
    {-g,--global}'[code for safely storing static data]' \
    {-k,--omit-const-func}'[omit const attribute on args]' \
    {-m,--gen-tied-var}'[generate tied variables]' \
    {-n+,--name=}'[name of extension]:name:' \
    {-o+,--opaque-re=}'[opaque types regex]:regex:' \
    {-p+,--remove-prefix=}'[prefix to strip]:prefix:' \
    {-s+,--const-subs=}'[force constants as subs]:list:' \
    {-t+,--default-type=}'[default C type]:type:' \
    {-v+,--version=}'[module version]:version:' \
    {-x,--autogen-xsubs}'[autogenerate XSUBs from C decls]' \
    ':header file:_files -g "*.h"' \
    '*:extra library:_files' \
    && ret=0

return ret
