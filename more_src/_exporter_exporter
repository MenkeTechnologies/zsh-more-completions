#compdef exporter_exporter
# Documentation: https://github.com/QubitProducts/exporter_exporter
# Reverse proxy and gateway for multiple Prometheus exporters

local ret=1

_arguments -s -S \
  '-config.file=[main configuration file (YAML)]:file:_files' \
  '-config.dirs=[directory paths for modular configuration files]:dir:_files -/' \
  '-web.listen-address=[HTTP listening address]:addr' \
  '-web.telemetry-path=[endpoint for exporter_exporter own metrics]:path' \
  '-web.proxy-path=[proxy endpoint path]:path' \
  '-web.tls.listen-address=[HTTPS listening address]:addr' \
  '-web.tls.cert=[path to the TLS certificate file]:file:_files' \
  '-web.tls.key=[path to the TLS private key file]:file:_files' \
  '-web.tls.ca=[path to the CA certificate for client authentication]:file:_files' \
  '-web.tls.verify[enable client certificate verification]' \
  '-verbose[enable verbose logging output]' && ret=0

return ret
