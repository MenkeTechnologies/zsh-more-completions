# Zsh completion for create-storybook - Storybook project installer

local curcontext="$curcontext" state line ret=1

_arguments -C   '--type=[project type]:type:(angular ember html nextjs nuxt preact qwik react react_native react_native_web react_native_and_rnw react_scripts react_project server solid svelte sveltekit vue3 web_components)'   '--features=[features to install]:feature:(docs test a11y)'   '--package-manager=[package manager]:manager:(npm pnpm yarn)'   ':project directory:_directories' && ret=0

return ret
