#compdef ntop
# _ntop — Luca Deri ntop (legacy multi-interface network-traffic analyzer with web UI; -i comma-separated interfaces, -P pidfile, -d daemonize, -W web port, -m local subnets, -F flow exporter target host:port, -E ttl, -O log directory, -e max embedded clients, --use-syslog, -u run-as user, -A admin password, -3 enable NetFlow probe, -V xtra verbose; superseded by ntopng)
# upstream: https://github.com/ntop/ntop (legacy)
# Flags from ntop src/main.c on tip.

_ntop() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-i+[interface(s)]:interfaces:_net_interfaces' \
        '-P+[pidfile]:file:_files' \
        '-d[daemonize]' \
        '-W+[web port]:port:' \
        '-w+[https port]:port:' \
        '-m+[local subnets]:subnets:' \
        '-F+[NetFlow exporter host:port]:exporter:' \
        '-E+[ttl]:ttl:' \
        '-O+[log directory]:dir:_files -/' \
        '-e+[max embedded clients]:n:' \
        '--use-syslog[log via syslog]' \
        '-u+[run as user]:user:_users' \
        '-A+[admin password]:password:' \
        '-3[enable NetFlow probe]' \
        '-l+[load plugin]:plugin:' \
        '-q+[capture queue size]:n:' \
        '-z+[sample rate]:rate:'
}

_ntop "$@"
