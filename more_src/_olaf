(( $+functions[_olaf_commands] )) ||
_olaf_commands() {
    local commands; commands=(
'index:Index the current project' \
'serve:Start the MCP stdio server' \
'status:Show index statistics' \
'init:Initialize Olaf in the current project' \
'observe:Handle Claude Code hook events' \
'sessions:Browse session observations' \
'restore:Manage file restore points' \
'workspace:Manage multi-repo workspace' \
'monitor:Live activity monitor — run in a separate terminal' \
'embed:Embed observations for semantic retrieval' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'olaf commands' commands "$@"
}
