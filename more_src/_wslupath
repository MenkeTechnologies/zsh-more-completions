#compdef wslupath
# wslupath — convert paths between WSL and Windows formats
# Part of wslu (https://github.com/wslutilities/wslu)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '-a[output absolute path]' \
  '-r[output relative path]' \
  '-w[output Windows path]' \
  '-l[output Linux path]' \
  '-d[output path to Windows Desktop directory]' \
  '-D[output path to Windows home directory]' \
  '-A[output path to AppData directory]' \
  '-T[output path to Windows temp directory]' \
  '-S[output path to Windows System32 directory]' \
  '-W[output path to Windows directory]' \
  '-s[output path to Windows startup directory]' \
  '*:path:_files'
