#compdef charles
# Documentation: https://man.archlinux.org/search?q=charles
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file]:config:_files' \
  '--headless[run in headless mode]' \
  '--port=[HTTP proxy port]:port' \
  '--socks-port=[SOCKS proxy port]:port' && return 0
