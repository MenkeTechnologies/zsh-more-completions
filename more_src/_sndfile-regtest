#compdef sndfile-regtest
# Documentation: https://github.com/libsndfile/libsndfile/blob/master/regtest/sndfile-regtest.c
# regression test utility for libsndfile using a checksum database

local ret=1

_arguments -s -S \
  '--create-db[create a new regression test database]' \
  '--list-all[list all entries in the database]' \
  '--check-all[check all files in the database against current libsndfile]' \
  '--del-entry[delete a specific entry from the database]:file:_files' \
  '--check-file[validate one or more audio files against database records]:*:file:_files' \
  '--add-file[add one or more audio files to the database]:*:file:_files' \
  '*:file:_files' && ret=0

return ret
