#compdef rgsfilter
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/rgsfilter/node6.html
# Filter the combined RGS event list by time intervals and event flags

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--mergedset=[input combined event list]:file:_files' \
  '--evlist=[output filtered event list]:file:_files' \
  '--auxgtitables=[auxiliary OGIP-compliant GTI tables for filtering]:files:_files' \
  '--rejflags=[rejection flags for which events to filter out]:flags' \
  '--withexpmaps=[generate exposure maps per node]:bool:(yes no)' \
  '--withcombmap=[output combined exposure map in separate dataset]:bool:(yes no)' \
  '--expimageset=[output dataset for the combined exposure map]:file:_files' \
  '--driftbinsize=[bin size in arcseconds for grouping frames by drift]:value' \
  '--spectrumbinning=[dispersion direction binning type]:binning:(lambda beta)' \
  '*:param=value:_default' && ret=0

return ret
