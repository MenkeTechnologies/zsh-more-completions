#compdef maxmind-cli maxmind mmcli
# _maxmind-cli — MaxMind maxmind-cli CLI client to the MaxMind GeoIP2 web service GeoLite2 download enrichment subscription account-key license-key authentication city country anonymous-IP ISP domain enterprise queries minFraud risk-score IP-enrichment for fraud detection (MaxMind team, Python); click
# upstream: https://www.maxmind.com/

_maxmind-cli() {
    local -a sub=(
        'city:GeoIP2 City lookup'
        'country:GeoIP2 Country lookup'
        'insights:GeoIP2 Insights lookup'
        'anonymous-ip:Anonymous IP lookup'
        'connection-type:Connection Type lookup'
        'domain:Domain lookup'
        'enterprise:Enterprise lookup'
        'isp:ISP lookup'
        'minfraud-score:minFraud score'
        'minfraud-insights:minFraud insights'
        'minfraud-factors:minFraud factors'
        'download:download GeoLite database'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--account-id=+[id]:str:' \
        '--license-key=+[key]:str:' \
        '--db-path=+[file]:file:_files -g "*.mmdb"' \
        '--mode=+[m]:m:(web db)' \
        '--locale=+[lang]:l:(en de es fr ja pt-BR ru zh-CN)' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'maxmind-cli subcommand' sub ;;
        args)
            case $words[1] in
                city|country|insights|anonymous-ip|connection-type|domain|enterprise|isp) _arguments '*:ip:' ;;
                download) _arguments '1:edition:(GeoLite2-ASN GeoLite2-City GeoLite2-Country GeoIP2-City GeoIP2-Country GeoIP2-Enterprise GeoIP2-ISP GeoIP2-Domain GeoIP2-Connection-Type GeoIP2-Anonymous-IP)' ;;
            esac
            ;;
    esac
}

_maxmind-cli "$@"
