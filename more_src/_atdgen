#compdef atdgen
# _atdgen — generate OCaml serialization code from ATD definitions (ahrefs/atd)
# upstream: https://github.com/ahrefs/atd
# Flags from atdgen/bin/ag_main.ml (Arg.parse spec).

_atdgen() {
    _arguments \
        '-help[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-t[output type defs and create_* functions]' \
        '-b[output biniou serialization code]' \
        '-j[output json serialization code]' \
        '-v[output validators]' \
        '-mel[output melange code]' \
        '-dep[print file dependencies produced by -t/-b/-j/-v]' \
        '-list[list files produced by -t/-b/-j/-v]' \
        '-o+[output file prefix]:prefix:_files' \
        '-j-defaults[serialize default values in JSON]' \
        '-j-strict-fields[reject unknown JSON fields]' \
        '-j-custom-fields=[function called on unknown JSON fields]:func:' \
        '-j-gen-modules[generate intf/impl modules for JSON]' \
        '-j-pp=[apply preprocessor to JSON input]:func:' \
        '-extend=[extend a module of type definitions]:module:' \
        '-open=[modules to open in generated code (comma separated)]:modules:' \
        '-nfd[no function definitions]' \
        '-ntd[no type definitions]' \
        '-pos-fname=[filename to use in error positions]:file:' \
        '-pos-lnum=[line number to use in error positions]:n:' \
        '-type-conv=[deprecated: type_conv preprocessor list]:list:' \
        '-deriving-conv=[deriving preprocessor list]:list:' \
        '-type-attr=[ppx attribute applied to type decls]:attr:' \
        '*:atd file:_files -g "*.atd"'
}

_atdgen "$@"
