#compdef datefudge
# Documentation: https://manpages.debian.org/bookworm/datefudge/datefudge.1.en.html
# datefudge: run a program with a faked system date

local ret=1

_arguments -s -S \
  '(-s --static)'{-s,--static}'[mark date as static so calls always return the date]' \
  '(-l --add-ld-preload)'{-l+,--add-ld-preload=}'[prepend a library to LD_PRELOAD]:library:_files' \
  '(-h --help)'{-h,--help}'[display usage information and exit]' \
  '(-v --version)'{-v,--version}'[show version details and exit]' \
  '1:date:' \
  '*:::command:_normal' && ret=0

return ret
