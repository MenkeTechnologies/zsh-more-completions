#compdef fitslist
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss57.html
# KAPPA FITSLIST - list the FITS extension of an NDF

local ret=1

_arguments -C \
  'IN=[input NDF whose FITS extension is listed]:NDF file:_files' \
  'ENCODING=[FITS keywords for WCS information]:encoding:(FITS-WCS FITS-IRAF)' \
  'FULLWCS=[include all coordinate Frames]:flag:(TRUE FALSE)' \
  'LOGFILE=[text file for the listing]:log file:_files' \
  '*:NDF file:_files' && ret=0

return ret
