#compdef sfsizes
# Documentation: https://github.com/ahay/src/blob/master/user/jennings/Msizes.c
# Madagascar: report the size of RSF (or Seismic Unix) datasets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'files=[if y, print size of each file; if n, print only total]:flag:(y n)' \
  'human=[if y, print human-readable file size; if n, print byte count]:flag:(y n)' \
  'su=[same for Seismic Unix files]:flag:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
