#compdef otx alienvault-otx otx-cli
# _alienvault-otx — AT&T Cybersecurity AlienVault otx CLI client to the Open Threat Exchange REST API querying pulses indicators IP domain URL filehash CVE NIDS Yara subscribed-pulses bulk-IOC-lookups community-curated open-source threat intelligence with public pulses subscriptions (AT&T Cybersecurity team, Python); custom argparse
# upstream: https://otx.alienvault.com/

_alienvault-otx() {
    local -a sub=(
        'pulse:pulse operations'
        'indicator:indicator operations'
        'subscribed:subscribed pulses'
        'user:user lookup'
        'cve:CVE lookup'
        'ip:IP lookup'
        'domain:domain lookup'
        'url:URL lookup'
        'file:file hash lookup'
        'nids:NIDS rule lookup'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-k+[api key]:str:' \
        '--api-key=+[key]:str:' \
        '--limit=+[N]:n:' \
        '--page=+[N]:n:' \
        '-f+[format]:f:(json yaml csv table stix2 misp openioc)' \
        '--format=+[format]:f:(json yaml csv table stix2 misp openioc)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'alienvault-otx subcommand' sub ;;
        args)
            case $words[1] in
                ip|domain|url|file|cve) _arguments '*:value:' ;;
                pulse) _arguments '1:op:(get create update delete subscribe unsubscribe)' '*:id:' ;;
            esac
            ;;
    esac
}

_alienvault-otx "$@"
