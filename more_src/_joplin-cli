#compdef joplin-cli
# _joplin-cli — Joplin open-source note-taking and to-do CLI alias (laurent22 team, TypeScript); commander
# upstream: https://github.com/laurent22/joplin

_joplin-cli() {
    local -a sub=(
        'apidoc:print api docs'
        'attach:attach file to note'
        'batch:batch run commands'
        'cat:print note content'
        'config:get/set config'
        'cp:copy notes'
        'done:mark todo as done'
        'dump:dump database'
        'e2ee:end-to-end encryption commands'
        'edit:edit note in editor'
        'env:show env info'
        'exit:exit cli'
        'export:export notes'
        'geoloc:show geolocation'
        'help:show help'
        'import:import notes'
        'init:init joplin'
        'ls:list notebooks/notes'
        'mkbook:create notebook'
        'mknote:create note'
        'mktodo:create todo'
        'mv:move notes'
        'ren:rename item'
        'rmbook:remove notebook'
        'rmnote:remove note'
        'search:search notes'
        'server:start clipper server'
        'set:set property on note'
        'status:show status'
        'sync:sync notes'
        'tag:tag operations'
        'todo:todo operations'
        'undone:mark todo as undone'
        'use:set current notebook'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--profile=+[profile dir]:dir:_files -/' \
        '--env=+[env]:str:' \
        '--log-level=+[log level]:l:(debug info warn error)' \
        '--stack-trace-enabled[enable stack traces]' \
        '--devplugin=+[dev plugin path]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'joplin subcommand' sub ;;
        args)
            case $words[1] in
                mkbook|mknote|mktodo|rmbook|rmnote|ren|cat|edit|use|done|undone) _arguments '*:notebook or note:' ;;
                tag) _arguments '1:cmd:(add remove list notetags tags)' '*:arg:' ;;
                todo) _arguments '1:cmd:(toggle clear)' '*:arg:' ;;
                config) _arguments \
                    '--export[export config]' \
                    '--verbose[verbose]' \
                    '*:key value:' ;;
                export|import) _arguments \
                    '1:path:_files' \
                    '--format=+[format]:f:(jex raw md html enex pdf)' \
                    '--note=+[note id or path]:str:' \
                    '--notebook=+[notebook id or path]:str:' ;;
                sync) _arguments \
                    '--target=+[target]:t:(memory filesystem onedrive nextcloud webdav dropbox amazon_s3 joplin_server joplin_cloud)' \
                    '--upgrade[upgrade sync target]' ;;
                e2ee) _arguments \
                    '1:cmd:(enable disable decrypt status target-status)' ;;
                server) _arguments \
                    '1:cmd:(start stop status)' \
                    '--background[run in background]' ;;
            esac
            ;;
    esac
}

_joplin-cli "$@"
