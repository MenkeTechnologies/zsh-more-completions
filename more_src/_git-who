#compdef git-who
# Documentation: https://man.archlinux.org/search?q=git-who
# Reference accessed: 2026-05-16

# https://github.com/lachlankrautz/git-who — clap v2 style

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --remote)'{-r+,--remote=}'[remote name]:remote:' && ret=0

return ret
