#compdef ros2

local curcontext="$curcontext" state line ret=1

_ros2_commands() {
  local -a commands=(
    'action:Various action related sub-commands'
    'bag:Various rosbag2 related sub-commands'
    'component:Various component related sub-commands'
    'daemon:Various daemon related sub-commands'
    'doctor:Check ROS setup and other potential issues'
    'interface:Show information about ROS interfaces'
    'launch:Run a launch file'
    'lifecycle:Various lifecycle related sub-commands'
    'multicast:Various multicast related sub-commands'
    'node:Various node related sub-commands'
    'param:Various param related sub-commands'
    'pkg:Various package related sub-commands'
    'run:Run a package specific executable'
    'security:Various security related sub-commands'
    'service:Various service related sub-commands'
    'topic:Various topic related sub-commands'
    'wtf:Use ros2 doctor instead'
  )
  _describe -t commands 'ros2 command' commands
}

_ros2_action_subcommands() {
  local -a subcmds=(
    'info:Print information about an action'
    'list:Output a list of action names'
    'send_goal:Send an action goal'
  )
  _describe -t commands 'action subcommand' subcmds
}

_ros2_bag_subcommands() {
  local -a subcmds=(
    'info:Print information about a bag'
    'play:Play back a bag file'
    'record:Record ROS data to a bag'
  )
  _describe -t commands 'bag subcommand' subcmds
}

_ros2_node_subcommands() {
  local -a subcmds=(
    'info:Output information about a node'
    'list:Output a list of available nodes'
  )
  _describe -t commands 'node subcommand' subcmds
}

_ros2_topic_subcommands() {
  local -a subcmds=(
    'bw:Display bandwidth used by topic'
    'delay:Display delay of topic from timestamp in header'
    'echo:Output messages from a topic'
    'find:Output a list of available topics of a given type'
    'hz:Print the average publishing rate to screen'
    'info:Print information about a topic'
    'list:Output a list of available topics'
    'pub:Publish a message to a topic'
    'type:Print a topic type'
  )
  _describe -t commands 'topic subcommand' subcmds
}

_ros2_service_subcommands() {
  local -a subcmds=(
    'call:Call a service'
    'find:Output a list of available services of a given type'
    'list:Output a list of available services'
    'type:Output a service type'
  )
  _describe -t commands 'service subcommand' subcmds
}

_ros2_param_subcommands() {
  local -a subcmds=(
    'delete:Delete parameter'
    'describe:Show descriptive information about declared parameters'
    'dump:Dump the parameters of a node to a yaml file'
    'get:Get parameter'
    'list:Output a list of available parameters'
    'set:Set parameter'
  )
  _describe -t commands 'param subcommand' subcmds
}

_ros2_pkg_subcommands() {
  local -a subcmds=(
    'create:Create a new ROS 2 package'
    'executables:Output a list of package specific executables'
    'list:Output a list of available packages'
    'prefix:Output the prefix path of a package'
    'xml:Output the XML of the package manifest'
  )
  _describe -t commands 'pkg subcommand' subcmds
}

_ros2_interface_subcommands() {
  local -a subcmds=(
    'list:List all interface types available'
    'package:Output a list of available interface types within one package'
    'packages:Output a list of packages that provide interfaces'
    'proto:Output an interface prototype'
    'show:Output the interface definition'
  )
  _describe -t commands 'interface subcommand' subcmds
}

_ros2_lifecycle_subcommands() {
  local -a subcmds=(
    'get:Get lifecycle state for one or more nodes'
    'list:Output a list of available transitions'
    'nodes:Output a list of nodes with lifecycle'
    'set:Trigger lifecycle state transition'
  )
  _describe -t commands 'lifecycle subcommand' subcmds
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '--use-python-default-buffering[Do not force line buffering in stdout]' \
  '1:command:_ros2_commands' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$words[1]" in
      action)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_ros2_action_subcommands' \
          '*:args' \
          && ret=0
        ;;
      bag)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_ros2_bag_subcommands' \
          '*:args' \
          && ret=0
        ;;
      component)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '*:args' \
          && ret=0
        ;;
      daemon)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:((start\:"Start the daemon" stop\:"Stop the daemon" status\:"Output the status of the daemon"))' \
          && ret=0
        ;;
      doctor|wtf)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--report[Print all reports]' \
          '--include-warnings[Include warnings]' \
          && ret=0
        ;;
      interface)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_ros2_interface_subcommands' \
          '*:args' \
          && ret=0
        ;;
      launch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--debug[Put the launch system in debug mode]' \
          '--print[Print the launch description and exit]' \
          '--show-args[Show arguments used by the launch file]' \
          '--show-all-subprocesses-output[Show output from all subprocesses]' \
          '*:launch file:_files' \
          && ret=0
        ;;
      lifecycle)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_ros2_lifecycle_subcommands' \
          '*:args' \
          && ret=0
        ;;
      multicast)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:((receive\:"Receive a single UDP multicast packet" send\:"Send a single UDP multicast packet"))' \
          && ret=0
        ;;
      node)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_ros2_node_subcommands' \
          '*:args' \
          && ret=0
        ;;
      param)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_ros2_param_subcommands' \
          '*:args' \
          && ret=0
        ;;
      pkg)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_ros2_pkg_subcommands' \
          '*:args' \
          && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--prefix[Prefix command]:prefix' \
          '1:package' \
          '2:executable' \
          '*:args' \
          && ret=0
        ;;
      security)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '*:args' \
          && ret=0
        ;;
      service)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_ros2_service_subcommands' \
          '*:args' \
          && ret=0
        ;;
      topic)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_ros2_topic_subcommands' \
          '*:args' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
