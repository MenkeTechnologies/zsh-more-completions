#compdef encore

# Zsh completion for Encore (backend development framework)

_encore() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'run:run your application'
    'test:test your application'
    'check:check your application for errors'
    'build:build your application'
    'daemon:manage the Encore daemon'
    'db:manage databases'
    'secret:manage secrets'
    'gen:generate code'
    'logs:view application logs'
    'app:manage Encore apps'
    'auth:manage authentication'
    'version:print Encore version'
    'vpn:manage VPN'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'encore command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        run)
          _arguments -s -S \
            '--port=[port to listen on]:port:' \
            '--listen=[address to listen on]:address:' \
            '--watch[watch for file changes]' \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            '--browser=[open in browser]:mode:(auto always never)' \
            && ret=0
          ;;
        test)
          _arguments -s -S \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            '-count=[run count]:count:' \
            '-run=[run only matching tests]:pattern:' \
            '-tags=[build tags]:tags:' \
            '*:packages:' \
            && ret=0
          ;;
        build)
          _arguments -s -S \
            '--output=[output file]:output file:_files' \
            && ret=0
          ;;
        db)
          _arguments -s -S \
            '1:subcommand:(shell reset proxy conn-uri)' \
            '--env=[environment]:environment:' \
            '2:database name:' \
            && ret=0
          ;;
        secret)
          _arguments -s -S \
            '1:subcommand:(set)' \
            '--type=[secret type]:type:(production development local)' \
            && ret=0
          ;;
        gen)
          _arguments -s -S \
            '1:subcommand:(client wrappers)' \
            '--output=[output directory]:directory:_files -/' \
            '--lang=[language]:language:(typescript javascript go)' \
            && ret=0
          ;;
        app)
          _arguments -s -S \
            '1:subcommand:(create link clone)' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_encore "$@"
