#compdef formatlist
# Documentation: https://bio-formats.readthedocs.io/en/stable/users/comlinetools/formatlist.html
# bio-formats: list supported file formats

local ret=1

_arguments -s \
  '(-txt -html -xml)-txt[print the list of formats as plain-text]' \
  '(-txt -html -xml)-html[print the list of formats as HTML]' \
  '(-txt -html -xml)-xml[print the list of formats as XML]' \
  '-help[display usage information]' && ret=0

return ret
