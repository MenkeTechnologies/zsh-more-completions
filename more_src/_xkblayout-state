#compdef xkblayout-state
# Documentation: https://github.com/nonpop/xkblayout-state
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Usage:
#   xkblayout-state print <format>
#   xkblayout-state set [+-]<number>

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:(print set)' \
  '*::arg:->args' && ret=0

return ret
