#compdef xkblayout-state
# Documentation: https://github.com/nonpop/xkblayout-state
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '1:command:(print set)' \
  '*:arg:' && ret=0

return ret
