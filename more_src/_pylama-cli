#compdef pylama
# Documentation: https://klen.github.io/pylama/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-o --options)'{-o+,--options=}'[options file]:file:_files' \
  '(-l --linters)'{-l+,--linters=}'[linters csv]:list:_values -s , linter eradicate mccabe mypy pycodestyle pydocstyle pyflakes pylint isort' \
  '(-i --ignore)'{-i+,--ignore=}'[ignore codes csv]:list:' \
  '(-s --select)'{-s+,--select=}'[select codes csv]:list:' \
  '--concurrent[async mode]' \
  '--async[async mode]' \
  '(-f --format)'{-f+,--format=}'[output format]:f:(pydocstyle pycodestyle pylint parsable json)' \
  '--from-stdin[read from stdin]' \
  '(-r --report)'{-r+,--report=}'[report file]:file:_files' \
  '(-m --max-line-length)'{-m+,--max-line-length=}'[max line]:n:' \
  '(-a --abspath)'{-a,--abspath}'[absolute paths]' \
  '*--skip=[skip files]:pattern:' \
  '--sort=[sort order, e.g. E,W,D]:order:' \
  '--max-complexity=[max complexity]:n:' \
  '--pydocstyle-convention=[doc convention]:c:(pep257 numpy google)' \
  '--pylint-confidence=[pylint confidence]:c:(HIGH INFERENCE INFERENCE_FAILURE UNDEFINED)' \
  '--hook[install Git/Mercurial hook]' \
  '*: :_files -g "*.py"' && ret=0

return ret
