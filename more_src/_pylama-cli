#compdef pylama

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-o --options)'{-o+,--options=}'[options file]:file:_files' \
  '(-l --linters)'{-l+,--linters=}'[linters csv]:list:(pycodestyle pydocstyle pyflakes mccabe pylint mypy ruff vulture isort radon eradicate)' \
  '(-i --ignore)'{-i+,--ignore=}'[ignore codes csv]:list:' \
  '(-s --select)'{-s+,--select=}'[select codes csv]:list:' \
  '*'{-c+,--concurrent=}'[concurrent]:b:(0 1)' \
  '(-A --async)'{-A,--async}'[async mode]' \
  '(-F --format)'{-F+,--format=}'[format]:f:(pep8 pylint parsable json emacs)' \
  '*'{-f+,--format=}'[output format]:f:(pep8 pylint parsable json emacs)' \
  '(--from-stdin)--from-stdin[read from stdin]' \
  '(-r --report)'{-r+,--report=}'[report file]:file:_files' \
  '(--max-line-length)--max-line-length=[max line]:n:' \
  '(--abspath)--abspath[absolute paths]' \
  '(--skip)*--skip=[skip files]:pattern:' \
  '(--sort)--sort=[sort order]:s:' \
  '(--ignore-patterns)--ignore-patterns=[ignore regex]:re:' \
  '(--max-complexity)--max-complexity=[max complexity]:n:' \
  '*: :_files -g "*.py"' && ret=0

return ret
