#compdef photoview
# _photoview — viktorstrate Photoview self-hosted high-performance photo gallery for personal libraries (photoview team, Go); standard flag package
# upstream: https://github.com/photoview/photoview

_photoview() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-api-listen-ip+[bind ip]:host:_hosts' \
        '-api-listen-port+[port]:port:_ports' \
        '-api-endpoint+[api url]:url:_urls' \
        '-public-endpoint+[public url]:url:_urls' \
        '-mysql-url+[mysql url]:str:' \
        '-postgres-url+[postgres url]:str:' \
        '-sqlite-path+[sqlite file]:file:_files' \
        '-database-driver+[driver]:d:(mysql postgres sqlite)' \
        '-photo-cache+[cache dir]:dir:_files -/' \
        '-media-cache+[cache dir]:dir:_files -/' \
        '-development-mode[development mode]' \
        '-debug[debug logs]' \
        '-disable-face-detection[no face detection]' \
        '-disable-video-encoding[no video encoding]' \
        '-disable-raw-processing[no raw processing]' \
        '-disable-image-decoding[no image decoding]' \
        '-face-recognition-models-path+[models dir]:dir:_files -/' \
        '-darktable-cli-path+[darktable-cli]:file:_command_names' \
        '-rawtherapee-cli-path+[rawtherapee-cli]:file:_command_names' \
        '-ffmpeg-path+[ffmpeg]:file:_command_names' \
        '-ffprobe-path+[ffprobe]:file:_command_names' \
        '-jwt-secret+[jwt secret]:str:' \
        '-scan-concurrent-workers+[N]:n:' \
        '-host-bypass[host bypass]'
}

_photoview "$@"
