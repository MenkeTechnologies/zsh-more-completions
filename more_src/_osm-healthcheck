#compdef osm-healthcheck
# _osm-healthcheck — Open Service Mesh sidecar health probe (reports Envoy admin readiness back to kubelet)
# upstream: https://github.com/openservicemesh/osm
# Flags from cmd/osm-healthcheck/osm-healthcheck.go on tip.

_osm-healthcheck() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --verbosity)'{-v,--verbosity}'=[log verbosity level]:level:(debug info warn error fatal)'
}

_osm-healthcheck "$@"
