#compdef bluemoon
# _bluemoon — BlueZ bluemoon (Intel/Bluemoon firmware loader: dumps boot params + firmware information, can upload firmware blob (--firmware), -i hciX target, --bddata writes BD_ADDR + DDC settings, --read-version, --read-boot-params, --reset)
# upstream: https://github.com/bluez/bluez (tools/bluemoon.c)
# Flags from bluez tools/bluemoon.c on tip.

_bluemoon() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-i+[hciX index]:device:' \
        '--firmware+[firmware blob]:file:_files' \
        '--bddata+[BD data file]:file:_files' \
        '--read-version[read controller version]' \
        '--read-boot-params[read boot params]' \
        '--reset[reset controller]' \
        '--reset-after[reset after operation]' \
        '--print-version[print version]' \
        '--quiet[quiet]'
}

_bluemoon "$@"
