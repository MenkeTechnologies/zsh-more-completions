#compdef jackmix
# Documentation: https://man.archlinux.org/search?q=jackmix
# Reference accessed: 2026-05-16

# JackMix: matrix-style audio mixer for JACK
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-i[number of input channels]:n:' \
  '-o[number of output channels]:n:' \
  '*:save file:_files -g "*.jackmix"' && ret=0
return ret
