#compdef backscale
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/backscale/node4.html
# XMM-Newton SAS: calculate and write the BACKSCAL keyword in EPIC spectra

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--spectrumset=[name of the input spectrum file]:file:_files' \
  '--badpixlocation=[file containing bad pixels]:file:_files' \
  '--withbadpixcorr=[factor in bad pixels and chip gaps]:flag:(yes no)' \
  '--useodfatt=[use ODF attitude file for position]:flag:(yes no)' \
  '--ignoreoutoffov=[exclude area outside field of view]:flag:(yes no)' \
  '--withbadpixres=[grid resolution specified on command line]:flag:(yes no)' \
  '--badpixelresolution=[grid resolution for area calculation]:res:' \
  '*:spectrum file:_files' && ret=0

return ret
