#compdef external-secrets-cli external-secrets esoctl
# _external-secrets-cli — External Secrets Operator external-secrets-cli esoctl CLI command-line frontend wrapping the External Secrets Operator Kubernetes-CRD controller synchronizing secrets from external API providers AWS Secrets Manager GCP Secret Manager Azure Key Vault Vault HashiCorp Doppler Akeyless 1Password GitLab Bitwarden Conjur (External Secrets team, Go); cobra
# upstream: https://external-secrets.io/

_external-secrets-cli() {
    local -a sub=(
        'install:install ESO into cluster'
        'uninstall:uninstall ESO'
        'apply:apply manifests'
        'validate:validate manifests'
        'render:render manifests'
        'create:scaffold new manifest'
        'list:list resources'
        'get:get a resource'
        'describe:describe a resource'
        'delete:delete a resource'
        'sync:trigger sync now'
        'wait:wait until ready'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '--store=+[type]:t:(aws gcp azure vault doppler akeyless 1password bitwarden ibm conjur gitlab kubernetes oracle alibaba senhasegura yandex passworddepot pulumi keepersecurity beyondtrust delinea infisical)' \
        '--kind=+[k]:k:(ExternalSecret SecretStore ClusterSecretStore PushSecret ClusterExternalSecret VaultDynamicSecret)' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'external-secrets-cli subcommand' sub ;;
        args)
            case $words[1] in
                apply|validate|render|create) _arguments '*:file:_files -g "*.yaml *.yml *.json"' ;;
                list|get|describe|delete|sync|wait) _arguments '*:resource name:' ;;
            esac
            ;;
    esac
}

_external-secrets-cli "$@"
