#compdef ppsspp ppsspp-sdl ppsspp-headless ppsspp-qt
# Documentation: https://man.archlinux.org/search?q=ppsspp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--fullscreen[fullscreen]' \
  '--windowed[windowed]' \
  '--pause-menu-exit[exit on pause menu]' \
  '--state+[load save state]:file:_files' \
  '--escape-exit[exit on Escape]' \
  '--touchscreen[touch mode]' \
  '--ignore-compat-settings[ignore compat]' \
  '--graphics+[graphics backend]:g:(directx9 directx11 opengl vulkan auto)' \
  '--debug[wait for debugger]' \
  '--language+[language]:l:' \
  '--config+[config file]:file:_files' \
  '*: :_files -g "*.iso *.cso *.pbp *.elf *.prx *.zip *.ppdmp"' && ret=0

return ret
