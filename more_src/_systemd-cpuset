#compdef systemd-cpuset
# _systemd-cpuset (systemd helper that exposes the active CPU affinity mask + isolated/nohz_full CPU sets to other systemd components at boot; takes no positional arguments — invoked once during early boot to populate /run/systemd/cpuset/)
# upstream: https://github.com/systemd/systemd (src/cpuset)
# Argument shape from systemd src/cpuset/cpuset.c on tip.

_systemd-cpuset() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-cpuset "$@"
