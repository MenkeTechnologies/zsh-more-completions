#compdef irevx
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Reverse an image left-to-right (in X)

local ret=1

_arguments -s -S \
  'IMAGE=[image to be reversed]:image:_files' \
  'OUTPUT=[resulting image]:output:_files' \
  '*:NDF data file:_files' && ret=0

return ret
