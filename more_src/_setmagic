#compdef setmagic
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss181.html
# KAPPA: replaces all occurrences of a given value in an NDF with the bad value

local ret=1

_arguments -s \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'REPVAL=[value to replace with the bad value]:value' \
  'COMP=[components to flag as bad]:comp:(Data Variance Error All)' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
