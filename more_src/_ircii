#compdef ircII irc
# Documentation: https://manpages.debian.org/trixie/ircii/ircII.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-a[add normal irc server list to command line server list]' \
  '-b[load .ircrc before connecting to a server]' \
  '-c+[automatically join channel]:channel:' \
  '-d[start in non-full-screen (direct) mode]' \
  '-D+[enable debugging of given level]:level:' \
  '-e+[set encryption/SSL level for protocol]:protocol level:' \
  '-F[do not use flow control]' \
  '-f[use flow control]' \
  '-H+[local address for DCC connections]:host:_hosts' \
  '-h+[use given host as the local address]:host:_hosts' \
  '-icb[use ICB connections by default]' \
  '-irc[use IRC connections by default]' \
  '-I+[set quick IRCRC file (used with -q)]:file:_files' \
  '-l+[use given ircrc instead of ~/.ircrc]:file:_files' \
  '-o+[set debug output file]:file:_files' \
  '-P+[set ICB port number]:port:' \
  '-p+[set IRC port number]:port:' \
  '-q[start up ircII quickly without loading full IRCRC]' \
  '-R+[default HTTP proxy host for server connections]:host:_hosts' \
  '-r[reverse default foreground and background colours]' \
  '-S[start the ircio process to connect to the server]' \
  '-s[do not start up the ircio process]' \
  '-T[use termcap ti and te sequences on startup/exit]' \
  '-t[do not use the termcap ti and te sequences]' \
  '-v[print version and release date]' \
  '1:nickname:' \
  '*:server[:port[:password[:nick]]]:_hosts' && ret=0

return ret
