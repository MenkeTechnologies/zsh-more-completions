#compdef ircII

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-a[append to log file]' \
  '-b[load .ircrc before init]' \
  '-c+[autojoin channel]:channel:' \
  '-d[direct mode]' \
  '-D+[debug level]:lvl:' \
  '-e+[client protocol level]:lvl:' \
  '-f[flow control]' \
  '-F[reverse flow control]' \
  '-h+[hostname[:port]]:host:_hosts' \
  '-H+[bind hostname[:port]]:host:_hosts' \
  '-I+[ircrc quick init file]:file:_files' \
  '-icb[use ICB protocol]' \
  '-irc[force IRC protocol]' \
  '-l+[startup ircrc file]:file:_files' \
  '-o+[output file]:file:_files' \
  '-p+[port number]:port:' \
  '-P+[port number]:port:' \
  '-q[do not load .ircrc]' \
  '-r[restricted mode]' \
  '-R+[proxy host[:port]]:host:_hosts' \
  '-s[do not display server list]' \
  '-S[silent mode]' \
  '-t[no tcl support]' \
  '-T[start a server in DCC]' \
  '-v[show version]' \
  '1:nickname:' \
  '*:server[:port[:password[:nick]]]:_hosts' && ret=0

return ret
