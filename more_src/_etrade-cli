#compdef etrade-cli etrade
# _etrade-cli — E-Trade Morgan Stanley etrade-cli CLI command-line frontend wrapping the E-Trade Morgan Stanley REST OAuth1 API managing accounts orders trades positions transactions balances market quote search lookups options-chain alerts notifications mutual-funds optionPosition fundamentals (E-Trade team, Go); cobra
# upstream: https://developer.etrade.com/

_etrade-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'order:order operations'
        'trade:trade operations'
        'position:position operations'
        'transaction:transaction operations'
        'balance:balance operations'
        'quote:quote operations'
        'market:market operations'
        'option:options chain'
        'alert:alert operations'
        'notification:notification operations'
        'mutual-fund:mutual fund operations'
        'fundamental:fundamentals'
        'search:symbol search'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--consumer-key=+[key]:str:' \
        '--consumer-secret=+[secret]:str:' \
        '--access-token=+[token]:str:' \
        '--access-token-secret=+[secret]:str:' \
        '--account-id-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--sandbox[use sandbox]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'etrade-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list get preview place cancel modify status)' \
                    '--symbol=+[ticker]:str:' \
                    '--order-action=+[a]:a:(BUY SELL BUY_TO_COVER SELL_SHORT BUY_OPEN BUY_CLOSE SELL_OPEN SELL_CLOSE)' \
                    '--price-type=+[t]:t:(MARKET LIMIT STOP STOP_LIMIT TRAILING_STOP_CONS TRAILING_STOP_PRCT)' \
                    '--quantity=+[N]:n:' \
                    '--limit-price=+[N]:str:' \
                    '--order-term=+[d]:d:(GOOD_FOR_DAY GOOD_TILL_CANCEL FILL_OR_KILL IMMEDIATE_OR_CANCEL)' \
                    '*:order id:' ;;
                account|trade|position|transaction|balance|alert|notification|mutual-fund|fundamental) _arguments '1:op:(list get create update delete)' '*:id:' ;;
                quote|market|option|search) _arguments '*:symbol:' ;;
            esac
            ;;
    esac
}

_etrade-cli "$@"
