#compdef chkchk
# Documentation: https://gaussian.com/chkchk/
# Display route, title, and structure info stored in a Gaussian checkpoint file

local ret=1

_arguments -s -S \
  '-m[memory to allocate (must precede other options)]:amount' \
  '-p[print coordinates, basis set, and MOs in input-card format]' \
  '*:checkpoint file:_files -g "*.chk"' && ret=0

return ret
