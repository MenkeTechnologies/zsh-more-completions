#compdef qmp-shell
# Documentation: https://qemu.readthedocs.io/projects/python-qemu-qmp/en/latest/qmp_shell.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-H --hmp)'{-H,--hmp}'[use HMP interface]' \
  '(-N --skip-negotiation)'{-N,--skip-negotiation}'[skip QMP capabilities negotiation]' \
  '(-v --verbose)'{-v,--verbose}'[echo commands sent and received]' \
  '(-p --pretty)'{-p,--pretty}'[pretty-print JSON]' \
  '(-l --logfile)'{-l,--logfile}'+[log file path]:file:_files' \
  '*:qmp_server (unix socket | host:port):_files' && ret=0

return ret
