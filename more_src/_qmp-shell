#compdef qmp-shell
# Documentation: https://qemu.readthedocs.io/projects/python-qemu-qmp/en/latest/qmp_shell.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-H[HMP shell]' \
  '-N[skip handshake]' \
  '-v[verbose]' \
  '-p[pretty print]' \
  '*:socket:_files' && ret=0

return ret
