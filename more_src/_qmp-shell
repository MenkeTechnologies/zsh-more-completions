#compdef qmp-shell
# Documentation: https://man.archlinux.org/search?q=qmp-shell
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-H[HMP shell]' \
  '-N[skip handshake]' \
  '-v[verbose]' \
  '-p[pretty print]' \
  '*:socket:_files' && ret=0

return ret
