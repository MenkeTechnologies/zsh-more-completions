#compdef coercer
# Documentation: https://man.archlinux.org/search?q=coercer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'scan:Scan for vulnerable methods'
      'coerce:Coerce authentication from target'
      'fuzz:Fuzz for new coercion methods'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    _arguments \
      '(-t --target)'{-t,--target}'=[target host]:host:_hosts' \
      '(-l --listener)'{-l,--listener}'=[listener host]:host:_hosts' \
      '(-u --username)'{-u,--username}'=[username]:username:' \
      '(-p --password)'{-p,--password}'=[password]:password:' \
      '(-d --domain)'{-d,--domain}'=[domain]:domain:' \
      '--hashes=[NTLM hashes (LM:NT)]:hashes:' \
      '--no-pass[do not prompt for password]' \
      '-k[use Kerberos authentication]' \
      '--dc-ip=[domain controller IP]:ip:_hosts' \
      '--target-ip=[target IP address]:ip:_hosts' \
      '--filter-pipe-name=[filter by pipe name]:pipe:' \
      '--filter-protocol-name=[filter by protocol]:protocol:' \
      '--filter-transport=[filter by transport]:transport:(ncacn_np ncacn_ip_tcp)' \
      '--webdav-host=[WebDAV host]:host:' \
      '--webdav-port=[WebDAV port]:port:' \
      '--http-port=[HTTP port]:port:' \
      '--always-continue[continue on error]' \
      '*:target:_hosts' && ret=0
    ;;
esac

return ret
