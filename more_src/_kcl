#compdef kcl

# Zsh completion for kcl (KCL configuration language)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'run:compile and run KCL program'
      'lint:lint KCL files'
      'fmt:format KCL files'
      'vet:validate data files using KCL schema'
      'doc:generate documentation'
      'test:run tests'
      'clean:clean output files'
      'import:import from other formats'
      'mod:module management'
      'server:start language server'
      'play:open playground'
      'help:show help for a subcommand'
    )
    _describe -t commands 'kcl subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      run)
        _arguments \
          '(-D --argument)'{-D,--argument}'[top-level argument key=value]:argument' \
          '(-O --overrides)'{-O,--overrides}'[override values]:overrides' \
          '(-S --setting)'{-S,--setting}'[setting file]:file:_files -g "*.yaml"' \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '(-d --disable-none)'{-d,--disable-none}'[disable None output]' \
          '--sort-keys[sort output keys]' \
          '(-n --output-type)'{-n,--output-type}'[output type]:type:(json yaml toml)' \
          '--strict-range-check[strict numeric range check]' \
          '*:KCL file:_files -g "*.k"' && ret=0
        ;;
      fmt|lint)
        _files -g '*.k' && ret=0
        ;;
      vet)
        _arguments \
          '*:file:_files' && ret=0
        ;;
      mod)
        local -a mod_subcmds=(
          'init:initialize a new module'
          'add:add a dependency'
          'update:update dependencies'
          'metadata:show module metadata'
        )
        _describe -t commands 'mod subcommand' mod_subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
