#compdef beamfit
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss10.html
# KAPPA: fit beam positions and shapes in a two-dimensional NDF

local ret=1

_arguments -s \
  'NDF=[NDF containing the data array]:NDF:_files' \
  'RESID=[map of residuals from the fit]:NDF:_files' \
  'LOGFILE=[text file for logging results]:file:_files' \
  'MODE=[method for obtaining initial coordinates]:mode:(Interface Cursor Catalogue File)' \
  'BEAMS=[number of beam positions to fit]:beams' \
  'POS=[primary beam position]:pos' \
  'REFPOS=[reference position for offsets]:refpos' \
  'COIN=[text file with coordinate guesses]:file:_files' \
  'INCAT=[catalogue with position list]:catalogue:_files' \
  'FIXPOS=[fix beam centre coordinates]:fixpos:(TRUE FALSE)' \
  'FIXSEP=[fix secondary-beam separations]:fixsep:(TRUE FALSE)' \
  'FIXAMP=[fix amplitude of first beam]:fixamp' \
  'FIXBACK=[fix background level]:fixback' \
  'FIXFWHM=[fix FWHM values]:fixfwhm' \
  'GAUSS=[constrain shape exponent to 2]:gauss:(TRUE FALSE)' \
  'CIRCULAR=[fit only circular beams]:circular:(TRUE FALSE)' \
  'FWHM=[initial FWHM values]:fwhm' \
  'AMPRATIO=[amplitude ratio of secondary beams]:ampratio' \
  'POLAR=[interpret coordinates as polar]:polar:(TRUE FALSE)' \
  'FITAREA=[size in pixels of fitting region]:fitarea' \
  'VARIANCE=[use variance for weighting]:variance:(TRUE FALSE)' \
  'DEVICE=[graphics device for cursor input]:device' \
  'DESCRIBE=[describe coordinate Frame]:describe:(TRUE FALSE)' \
  'MARK=[positions to mark on screen]:mark:(Initial Fit Ellipse None)' \
  'MARKER=[PGPLOT marker type]:marker' \
  'PLOTSTYLE=[styling attributes for markers]:plotstyle' \
  'TITLE=[title for the residual NDF]:title' \
  '*:NDF:_files' && ret=0

return ret
