;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_awww__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:awww-help-command-$line[1]:"
        case $line[1] in
            (clear)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(restore)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clear-cache)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(img)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(toggle)
