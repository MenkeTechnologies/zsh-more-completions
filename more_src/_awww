'--transition-type=[Sets the type of transition. Default is '\''simple'\'', that fades into the new image]:TRANSITION_TYPE:_default' \
'--transition-step=[How fast the transition approaches the new image]:TRANSITION_STEP:_default' \
'--transition-duration=[How long the transition takes to complete in seconds]:TRANSITION_DURATION:_default' \
'--transition-fps=[Frame rate for the transition effect]:TRANSITION_FPS:_default' \
'--transition-angle=[This is used for the '\''wipe'\'' and '\''wave'\'' transitions. It controls the angle of the wipe]:TRANSITION_ANGLE:_default' \
'--transition-pos=[This is only used for the '\''grow'\'','\''outer'\'' transitions. It controls the center of circle (default is '\''center'\'')]:TRANSITION_POS:_default' \
'--transition-bezier=[bezier curve to use for the transition https\://cubic-bezier.com is a good website to get these values from]:TRANSITION_BEZIER:_default' \
'--transition-wave=[currently only used for '\''wave'\'' transition to control the width and height of each wave]:TRANSITION_WAVE:_default' \
'-a[Set the image for all awww-daemon instances (all namespaces)]' \
'--all[Set the image for all awww-daemon instances (all namespaces)]' \
'--no-resize[Do not resize the image. Equivalent to \`--resize=no\`]' \
'--invert-y[inverts the y position sent in '\''transition_pos'\'' flag]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
