#compdef llvm-objcopy
# _llvm-objcopy — LLVM object file copier (LLVM project, C++); GNU objcopy-compatible binary rewriter
# upstream: https://github.com/llvm/llvm-project

_llvm-objcopy() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-I+[input format]:format:(binary ihex elf coff macho)' \
        '--input-target=+[input format]:format:(binary ihex elf coff macho)' \
        '-O+[output format]:format:(binary ihex elf coff macho)' \
        '--output-target=+[output format]:format:(binary ihex elf coff macho)' \
        '-F+[both target format]:format:' \
        '--target=+[both target format]:format:' \
        '-j+[only this section]:section:' \
        '--only-section=+[only this section]:section:' \
        '--add-section=+[name=file]:str:' \
        '--update-section=+[name=file]:str:' \
        '--dump-section=+[name=file]:str:' \
        '-R+[remove section]:section:' \
        '--remove-section=+[remove section]:section:' \
        '--keep-section=+[keep section]:section:' \
        '--only-keep-debug[only keep debug]' \
        '--decompress-debug-sections[decompress debug sections]' \
        '--compress-debug-sections=+[compress style]:style:(zlib zlib-gabi zstd)' \
        '-N+[strip symbol]:sym:' \
        '--strip-symbol=+[strip symbol]:sym:' \
        '-K+[keep symbol]:sym:' \
        '--keep-symbol=+[keep symbol]:sym:' \
        '-G+[keep only global symbol]:sym:' \
        '--keep-global-symbol=+[keep only global symbol]:sym:' \
        '-L+[localize symbol]:sym:' \
        '--localize-symbol=+[localize symbol]:sym:' \
        '-W+[weaken symbol]:sym:' \
        '--weaken-symbol=+[weaken symbol]:sym:' \
        '-w[wildcard matching]' \
        '--wildcard[wildcard matching]' \
        '--regex[regex matching]' \
        '-S[strip all]' \
        '--strip-all[strip all]' \
        '--strip-all-gnu[strip all GNU]' \
        '-x[discard all locals]' \
        '--discard-all[discard all locals]' \
        '-g[strip debug]' \
        '--strip-debug[strip debug]' \
        '--strip-dwo[strip dwo]' \
        '--strip-non-alloc[strip non-alloc]' \
        '--strip-sections[strip section headers]' \
        '--strip-unneeded[strip unneeded]' \
        '--rename-section=+[old=new]:str:' \
        '--rename-symbol=+[old=new]:str:' \
        '--redefine-sym=+[old=new]:str:' \
        '--redefine-syms=+[file]:file:_files' \
        '--add-symbol=+[name=value]:str:' \
        '--add-gnu-debuglink=+[debuglink file]:file:_files' \
        '--strip-section-headers[strip section headers]' \
        '-p[preserve dates]' \
        '--preserve-dates[preserve dates]' \
        '--split-dwo=+[split dwo file]:file:_files' \
        '*:file:_files'
}

_llvm-objcopy "$@"
