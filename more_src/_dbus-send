#compdef dbus-send
# Documentation: https://manpages.debian.org/dbus-send
# Source: freedesktop/dbus tools/dbus-send.c — send a D-Bus message (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '(--session --bus --peer)--system[connect to system bus]' \
    '(--system --bus --peer)--session[connect to session bus]' \
    '(--system --session --peer)--bus=-[bus address]:address:_default' \
    '(--system --session --bus)--peer=-[peer-to-peer address]:address:_default' \
    '--sender=-[sender name]:name:_default' \
    '--dest=-[destination bus name]:name:_default' \
    '--type=-[message type]:type:(method_call signal)' \
    '--print-reply=-[print reply]::format:(literal)' \
    '--reply-timeout=-[reply timeout in ms]:ms:_default' \
    '1:object path:_default' \
    '2:interface.method:_default' \
    '*:contents:_default' \
    && ret=0

return ret
