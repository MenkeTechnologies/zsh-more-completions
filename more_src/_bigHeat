#compdef bigHeat
# Documentation: https://github.com/ucscGenomeBrowser/kent/blob/master/src/utils/bigHeat
# duplicate BED features and color them by values in locationMatrix; creates bigBed files in outDir

local ret=1

_arguments -s -S \
  '--scale=[auto-scale values to 0-1.0: none or row]:mode:(none row)' \
  '--min=[minimum limit when transforming values to colors]:float:' \
  '--max=[maximum limit when transforming values to colors]:float:' \
  '--mult=[two comma-separated values multNeg,multPos]:mult:' \
  '--palRange=[two colon-separated floats 0-1.0 to use part of palette]:range:' \
  '--log[log all values in the matrix]' \
  '--order[reorder rows with the optimalLeaf algorithm]' \
  '*--del=[remove these samples (a regex)]:regex:' \
  '--cmap=[name of colormap (default viridis)]:colormap:' \
  '(-b --bbDir)'{-b,--bbDir}'=[prefix bigDataUrl filenames with this dir]:dir:_files -/' \
  '--bw=[also create a bigWig summarizing all values: sum or respFreq]:mode:(sum respFreq)' \
  '(-d --debug)'{-d,--debug}'[show debug messages]' \
  '*:locationBed locationMatrixFnames chromSizes outDir:_files' && ret=0

return ret
