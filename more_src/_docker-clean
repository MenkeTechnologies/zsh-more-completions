#compdef docker-clean
# Documentation: https://github.com/ZZROTDesign/docker-clean
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for docker-clean (ZZROTDesign/docker-clean)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-H --host)'{-H,--host}'[docker daemon socket or host:port]:host' \
  '(-n --dry-run)'{-n,--dry-run}'[print actions only]' \
  '(-l --log)'{-l,--log}'[verbose delete output]' \
  '(-s --stop)'{-s,--stop}'[stop running containers]' \
  '(-c --containers)'{-c,--containers}'[remove stopped containers]' \
  '(-i --images)'{-i,--images}'[remove untagged images]' \
  '(-m --volumes)'{-m,--volumes}'[remove dangling volumes]' \
  '(-net --networks)'{-net,--networks}'[remove empty networks]' \
  '(-r --restart)'{-r,--restart}'[restart docker machine/daemon]' \
  '(-d --created)'{-d,--created}'[do not remove created containers]' \
  '(-t --tagged)'{-t,--tagged}'[also remove tagged images]' \
  '(-a --all)'{-a,--all}'[aggressive clean + restart]' \
  '*:preset:(stop images run all)' && ret=0

return ret
