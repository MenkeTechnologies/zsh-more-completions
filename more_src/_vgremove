#compdef vgremove
# _vgremove — remove volume group (LVM2); destroy vg after removing or migrating its lvs
# upstream: https://gitlab.com/lvmteam/lvm2

_vgremove() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-y --yes)'{-y,--yes}'[no prompts]' \
        '(-A --autobackup)'{-A,--autobackup}'+[autobackup]:bool:(y n)' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '--profile+[config profile]:profile:' \
        '--select+[select clause]:str:' \
        '*:vg:'
}

_vgremove "$@"
