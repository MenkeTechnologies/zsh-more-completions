#compdef makesurface
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss110.html
# KAPPA: create a two-dimensional NDF from the coefficients of a surface fit

local ret=1

_arguments -s \
  'IN=[NDF with the SURFACEFIT extension]:NDF:_files' \
  'OUT=[output NDF with the generated surface]:NDF:_files' \
  'LIKE=[template NDF for shape and type]:NDF:_files' \
  'LBOUND=[lower bounds when LIKE not given]:lbound' \
  'UBOUND=[upper bounds when LIKE not given]:ubound' \
  'TYPE=[data type for the output NDF]:type:(DOUBLE REAL INTEGER WORD BYTE UBYTE)' \
  'XLIMIT=[x-axis coordinate range]:xlimit' \
  'YLIMIT=[y-axis coordinate range]:ylimit' \
  'TITLE=[title for the output NDF]:title' \
  'VARIANCE=[include variance from fit residuals]:variance:(TRUE FALSE)' \
  '*:NDF:_files' && ret=0

return ret
