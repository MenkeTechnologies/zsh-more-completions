#compdef pas2jni
# Documentation: https://www.mankier.com/1/pas2jni
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-o+[output directory]:dir:_files -/' \
  '-p+[Java package name]:package:' \
  '-u+[uses unit]:unit:' \
  '-c+[class name]:class:' \
  '-h[show help]' \
  '*:Pascal source file:_files -g "*.(pas|pp|inc)"' && ret=0

return ret
