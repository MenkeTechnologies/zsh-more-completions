#compdef pas2jni

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-o+[output directory]:dir:_files -/' \
  '-p+[Java package name]:package:' \
  '-u+[uses unit]:unit:' \
  '-c+[class name]:class:' \
  '-h[show help]' \
  '*:Pascal source file:_files -g "*.(pas|pp|inc)"' && ret=0

return ret
