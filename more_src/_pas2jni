#compdef pas2jni
# Documentation: pas2jni -? (in-binary usage)
# Reference accessed: 2026-05-20
# Verified: local invocation of pas2jni.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-U-[unit search path (semicolon delimited)]:path:_files -/' \
  '-L-[output library name]:name:' \
  '-P-[Java package name]:package:' \
  '-O-[output path for Pascal files]:path:_files -/' \
  '-J-[output path for Java files]:path:_files -/' \
  '-D-[path to ppudump program]:program:_files' \
  '-I-[include list (semicolon or @file)]:list:' \
  '-E-[exclude list (semicolon or @file)]:list:' \
  '-N[do not generate Java auto-loader code]' \
  '-?[show help]' \
  '*:unit:' && ret=0

return ret
