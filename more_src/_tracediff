#compdef tracediff
# Documentation: https://manpages.debian.org/testing/libtrace-tools/tracediff.1.en.html
# find and print differences between two libtrace traces

local ret=1

_arguments -s -S \
  '-m+[stop processing after displaying maxdiff differences]:maxdiff' \
  '*:uri:_files' && ret=0

return ret
