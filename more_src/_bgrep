#compdef bgrep
# Documentation: bgrep --help
# Source: tmbinc/bgrep bgrep.c (master) — binary grep for hex patterns (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[print N bytes after match]:bytes:_default' \
    '-B+[print N bytes before match]:bytes:_default' \
    '-C+[print N bytes before/after match]:bytes:_default' \
    '-f+[pattern from file]:file:_files' \
    '-m+[mask from file]:file:_files' \
    '-r[recurse into directories]' \
    '*::hex pattern or path:_files' \
    && ret=0

return ret
