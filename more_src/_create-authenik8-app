_create-authenik8-app() {
    _arguments \
        '(-h --help)'{-h,--help}'[Display help menu]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '--template[Specify template]:template:(express-auth+ express-base express-auth)' \
        '--install[Automatically run npm install]' \
        '--git[Initialize a new Git repository]' \
        '1:app-name:'
}

_create-authenik8-app "$@"
