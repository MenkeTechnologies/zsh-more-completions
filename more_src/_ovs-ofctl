#compdef ovs-ofctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'show:show switch information'
  'dump-tables:show table statistics'
  'dump-table-features:show table features'
  'dump-table-desc:show table description'
  'mod-table:modify a flow table'
  'dump-ports:show port statistics'
  'dump-ports-desc:show port descriptions'
  'mod-port:modify a port'
  'get-frags:get fragment handling mode'
  'set-frags:set fragment handling mode'
  'dump-ipfix-bridge:show IPFIX bridge config'
  'dump-ipfix-flow:show IPFIX flow config'
  'ct-flush-zone:flush conntrack zone'
  'ct-flush:flush conntrack'
  'add-flow:add a flow'
  'add-flows:add flows from file'
  'mod-flows:modify flows'
  'del-flows:delete flows'
  'replace-flows:replace flows from file'
  'dump-flows:dump flows'
  'dump-aggregate:dump aggregate flow stats'
  'diff-flows:diff flow tables'
  'packet-out:send a packet out'
  'add-group:add a group'
  'add-groups:add groups from file'
  'mod-group:modify a group'
  'del-groups:delete groups'
  'insert-buckets:insert buckets into a group'
  'remove-buckets:remove buckets from a group'
  'dump-groups:dump groups'
  'dump-group-features:dump group features'
  'dump-group-stats:dump group statistics'
  'add-meter:add a meter'
  'mod-meter:modify a meter'
  'del-meters:delete meters'
  'dump-meters:dump meter config'
  'meter-stats:dump meter statistics'
  'meter-features:dump meter features'
  'bundle:execute commands as a bundle'
  'add-tlv-map:add tunnel TLV map'
  'del-tlv-map:delete tunnel TLV map'
  'dump-tlv-map:dump tunnel TLV map'
  'queue-stats:dump queue statistics'
  'queue-get-config:get queue config'
  'snoop:snoop OpenFlow channel'
  'monitor:monitor OpenFlow events'
  'probe:probe a switch'
  'ping:ping a switch'
  'benchmark:benchmark a switch'
  'ofp-parse:parse OpenFlow messages'
  'ofp-parse-pcap:parse OpenFlow from pcap'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-O --protocols)'{-O,--protocols=}'[OpenFlow protocols]:protocols:' \
  '(-F --flow-format)'{-F,--flow-format=}'[flow format]:format:' \
  '(-P --packet-in-format)'{-P,--packet-in-format=}'[packet-in format]:format:' \
  '--strict[strict matching]' \
  '--names[show port/group names]' \
  '--no-names[do not show names]' \
  '--stats[show stats]' \
  '--no-stats[hide stats]' \
  '--sort=[sort flows]:fields:' \
  '--rsort=[reverse sort flows]:fields:' \
  '--bundle[execute as a bundle]' \
  '--may-create[may create flows on mod]' \
  '--readd[re-add flows]' \
  '--read-only[connect read-only]' \
  '(-t --timeout)'{-t,--timeout=}'[timeout]:secs:' \
  '--xlock-timeout=[xlock timeout]:secs:' \
  '(-m --more)'{-m,--more}'[more verbose output]' \
  '--timestamp[print timestamps]' \
  '--color=[color output]:when:(auto always never)' \
  '--pidfile=[PID file]:file:_files' \
  '--overwrite-pidfile[overwrite existing PID file]' \
  '--detach[run as daemon]' \
  '--monitor[monitor for crashes]' \
  '--no-chdir[do not chdir]' \
  '--user=[run as user]:user:_users' \
  '--unixctl=[unixctl socket]:socket:_files' \
  '(-p --private-key)'{-p,--private-key=}'[private key file]:file:_files' \
  '(-c --certificate)'{-c,--certificate=}'[certificate file]:file:_files' \
  '(-C --ca-cert)'{-C,--ca-cert=}'[CA cert file]:file:_files' \
  '--ssl-server-name=[SSL server name]:name:' \
  '(-v --verbose)'{-v,--verbose=}'[verbosity spec]:spec:' \
  '--log-file=[log file]:file:_files' \
  '--syslog-target=[syslog target]:target:' \
  '--syslog-method=[syslog method]:method:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ovs-ofctl subcommand' subcommands && ret=0
    ;;
esac

return ret
