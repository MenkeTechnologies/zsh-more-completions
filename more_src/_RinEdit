#compdef RinEdit
# Documentation: https://github.com/SGL-UT/GPSTk/blob/main/core/apps/Rinextools/RinEdit.cpp
# GPSTk RINEX observation file editor

local ret=1

_arguments -s \
  '--IF[input RINEX observation file name]:file:_files' \
  '--ID[path of input RINEX observation files]:dir:_files -/' \
  '--OF[output RINEX obs files]:file:_files' \
  '--OD[path of output RINEX observation files]:dir:_files -/' \
  '(-f --file)'{-f,--file}'[name of file containing more options]:file:_files' \
  '(-l --log)'{-l,--log}'[output log file name]:file:_files' \
  '--ver2[write out RINEX version 2]' \
  '--TB[start time: reject data before this time]:time' \
  '--TE[stop time: reject data after this time]:time' \
  '--TT[tolerance in comparing times]:tol' \
  '--TN[decimate data to specified interval]:interval' \
  '*--HDc[add COMMENT to the output header]:comment' \
  '--HDdc[delete all comments from input header]' \
  '--HDda[delete all auxiliary header data]' \
  '--verbose[print extra output information]' \
  '--debug[print debug output]' \
  '--help[print this syntax page and quit]' && ret=0

return ret
