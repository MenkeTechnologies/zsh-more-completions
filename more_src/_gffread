#compdef gffread
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/gffread.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for gffread (gpertea/gffread — see `gffread -h`)

local ret=1

_arguments -s -S \
  '(-g)-g+[genomic FASTA or directory]:path:_files' \
  '(-s)-s+[seq info .fsize file]:file:_files' \
  '(-o)-o+[output file]:file:_files' \
  '(-t)-t+[track name]:name' \
  '(-r)-r+[only transcripts overlapping range]:range' \
  '-R[with -r require full containment]' \
  '--jmatch+[junction match interval]:range' \
  '--no-pseudo[discard pseudogenes]' \
  '-w+[write exon sequences FASTA]:file:_files' \
  '-x+[write CDS FASTA]:file:_files' \
  '-y+[write translated CDS FASTA]:file:_files' \
  '--ids[keep only IDs listed in file]:file:_files' \
  '--nids[discard IDs listed in file]:file:_files' \
  '--attrs[attribute filter list]:list' \
  '(-i)-i+[max intron length]:len' \
  '--stream[streaming mode]' \
  '--bed[emit BED]' \
  '--gtf[emit GTF]' \
  '--tlf[emit TLF]' \
  '--table+[attribute table columns]:attrs' \
  '(-h --help)'{-h,--help}'[usage]' \
  '*:input GFF/GTF/BED:_files' && ret=0

return ret
