#compdef xen-watchdogd
# Documentation: https://man.archlinux.org/search?q=xen-watchdogd
# Reference accessed: 2026-05-16

# xen-watchdogd: feed Xen hypervisor watchdog from dom0
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-F[foreground]' \
  '-t[timeout sec]:s:' \
  '-s[refresh interval sec]:s:' \
  '*::xen-watchdogd args:_files' && ret=0
return ret
