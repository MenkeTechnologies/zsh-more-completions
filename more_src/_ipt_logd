#compdef ipt_logd
# _ipt_logd — netfilter ipt_logd (legacy distro-shipped userspace daemon that reads /var/log/kern.log for iptables LOG matches and writes a normalised /var/log/iptables file; -c config file, -f foreground, -p pidfile, -l log file, -v verbose, -V version; modern setups prefer ulogd2 or journalctl)
# upstream: distro-shipped (Debian ipt_logd)
# Flags inferred from Debian ipt_logd source on tip.

_ipt_logd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-f[foreground]' \
        '-p+[pidfile]:file:_files' \
        '-l+[log file]:file:_files' \
        '-v[verbose]'
}

_ipt_logd "$@"
