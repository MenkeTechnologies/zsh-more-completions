#compdef mockery

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[path to config file]:config file:_files' \
  '--name=[name of interface to mock]:interface name:' \
  '--all[generate mocks for all interfaces]' \
  '--recursive[search packages recursively]' \
  '--dir=[directory to search for interfaces]:directory:_directories' \
  '--output=[output directory]:directory:_directories' \
  '--outpkg=[output package name]:package name:' \
  '--packageprefix=[prefix for output package names]:prefix:' \
  '--filename=[output file name]:filename:' \
  '--structname=[name of generated mock struct]:struct name:' \
  '--inpackage[generate mock in same package]' \
  '--inpackage-suffix[use suffix for inpackage mock files]' \
  '--testonly[generate mock in _test file]' \
  '--case=[filename case]:case:(underscore camel snake)' \
  '--print[print mock to stdout]' \
  '--exported[generate exported mock]' \
  '--with-expecter[generate expecter methods]' \
  '--unroll-variadic[unroll variadic arguments]' \
  '--dry-run[show what would be generated]' \
  '--disable-version-string[disable version string in generated file]' \
  '--boilerplate-file=[copyright boilerplate file]:file:_files' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--tags=[build tags]:tags:' \
  '--srcpkg=[source package]:package:' \
  '--pkgname=[package name for mock]:package name:' \
  '*:packages:' && ret=0

return ret
