#compdef panaroo
# panaroo — pan-genome pipeline with error correction for bacterial genomes

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)--version[show version and exit]' \
  '(-i --input)'{-i,--input}'[input GFF3 files]:*:GFF files:_files' \
  '(-o --out_dir)'{-o,--out_dir}'[output directory]:output dir:_files -/' \
  '--clean-mode[cleaning stringency mode]:mode:(strict moderate sensitive)' \
  '(-a --alignment)'{-a,--alignment}'[output alignments of core genes]:alignment:(core pan)' \
  '--aligner[alignment tool to use]:aligner:(mafft prank clustal)' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads' \
  '--core_threshold[core gene sample threshold]:threshold' \
  '--threshold[sequence identity threshold]:threshold' \
  '--family_threshold[protein family sequence identity threshold]:threshold' \
  '--len_dif_percent[length difference cutoff]:percent' \
  '--merge_paralogs[merge paralogs into single entries]' \
  '--remove-invalid-genes[remove invalid gene annotations]' \
  '--verbose[verbose output]' \
  '--no_clean_edges[do not clean graph edges]' \
  '--min_trailing_support[minimum trailing support for graph cleaning]:support' \
  '--trailing_recursive[number of recursive trailing rounds]:rounds' \
  '--edge_support_threshold[minimum edge support threshold]:threshold' \
  '--refind_prop_match[proportion of length for re-finding genes]:proportion' \
  '--search_radius[search radius for re-finding genes]:radius' \
  && ret=0

return ret
