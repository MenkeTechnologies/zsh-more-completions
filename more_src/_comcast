#compdef comcast

# Zsh completion for comcast - network chaos and traffic shaping tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[display version]' \
  '(- *)--help[display help]' \
  '--device=[network device]:network interface:_net_interfaces' \
  '--default-bw=[default bandwidth in kbit/s]:bandwidth (kbit/s)' \
  '--latency=[latency to add in ms]:latency (ms)' \
  '--target-bw=[target bandwidth in kbit/s]:bandwidth (kbit/s)' \
  '--packet-loss=[packet loss percentage]:percentage' \
  '--target-addr=[target IP address or CIDR]:address' \
  '--target-port=[target port number]:port' \
  '--target-proto=[target protocol]:protocol:(tcp udp icmp)' \
  '--dry-run[display commands without executing]' \
  '--stop[stop traffic shaping]' \
  && ret=0

return ret
