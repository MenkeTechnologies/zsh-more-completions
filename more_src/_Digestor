#compdef Digestor
# OpenMS TOPP: digest a protein database in silico

local ret=1

_arguments -s -S \
  '-in[input FASTA file]:input file:_files' \
  '-out[output file (idXML or FASTA)]:output file:_files' \
  '-out_type[output format]:type:' \
  '-missed_cleavages[number of allowed missed cleavages]:n:' \
  '-min_length[minimum peptide length]:n:' \
  '-max_length[maximum peptide length]:n:' \
  '-enzyme[digestion enzyme type]:enzyme:' \
  '-FASTA:ID[peptide identifier source]:source:' \
  '-FASTA:description[retain FASTA header descriptions]:mode:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
