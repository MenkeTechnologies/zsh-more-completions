#compdef whizard-config
# Documentation: https://gitlab.tp.nt.uni-siegen.de/whizard/public/-/blob/master/scripts/whizard-config.in
# whizard-config - report build-time WHIZARD configuration

local ret=1

_arguments -s -S \
  '--prefix[WHIZARD installation prefix]' \
  '--libdir[directory containing the WHIZARD libraries]' \
  '--datadir[WHIZARD data directory]' \
  '--version[WHIZARD version]' \
  '--fc[FORTRAN 2003 compiler]' \
  '--fcflags[FORTRAN 2003 compiler flags]' \
  '--fcmodext[FORTRAN 2003 module file extension]' && ret=0

return ret
