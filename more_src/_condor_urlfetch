#compdef condor_urlfetch
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_urlfetch.html
# fetch configuration from a URL and cache it for daemons

local ret=1

_arguments -s -S \
  '-MASTER[the URL query always occurs for the master daemon]' \
  '-STARTD[query the URL only if the cache file does not exist]' \
  '-SCHEDD[query the URL only if the cache file does not exist]' \
  '*:url and cache file:_files' && ret=0

return ret
