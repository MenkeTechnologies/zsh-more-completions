#compdef ovn-kube-util
# _ovn-kube-util — OVN-Kubernetes node-side helper CLI (ovn-kubernetes/ovn-kubernetes)
# upstream: https://github.com/ovn-kubernetes/ovn-kubernetes
# Subcommands from go-controller/cmd/ovn-kube-util/ovn-kube-util.go + app/*.go (urfave/cli) on tip.

_ovn-kube-util() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--loglevel=[klog verbosity]:n:(0 1 2 3 4 5)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                nics-to-bridge:'create an OVS bridge for each listed NIC interface'
                bridges-to-nic:'delete an OVS bridge and move IP/routes back to the underlying NIC'
                readiness-probe:'run an OVN/OVS readiness probe'
                ovs-exporter:'run the OVS Prometheus exporter'
            )
            _describe -t commands 'ovn-kube-util command' cmds
            ;;
    esac
}

_ovn-kube-util "$@"
