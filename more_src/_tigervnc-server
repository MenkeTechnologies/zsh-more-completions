#compdef tigervncserver vncserver-tigervnc
# Documentation: https://manpages.debian.org/unstable/tigervnc-standalone-server/tigervncserver.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-kill[kill running VNC server]' \
  '-list[list running VNC servers]' \
  '-version[display version]' \
  '-rfbport=[TCP port to listen on]:port:' \
  '-rfbunixpath=[path for Unix domain socket]:path:_files' \
  '-rfbunixmode=[Unix socket mode (default 0600)]:mode:' \
  '-localhost=[restrict listening to localhost]:flag:(yes no)' \
  '-SecurityTypes=[security schemes]:types:' \
  '-RequireUsername=[require username for auth]:flag:(yes no)' \
  '-PasswordFile=[password file]:file:_files' \
  '-rfbauth=[password file (alias)]:file:_files' \
  '-PlainUsers=[allowed users]:users:' \
  '-PAMService=[PAM service name]:service:' \
  '-pam_service=[PAM service name (alias)]:service:' \
  '-X509Cert=[X509 cert PEM]:file:_files' \
  '-X509Key=[X509 private key PEM]:file:_files' \
  '-RSAKey=[RSA key PEM for RSA-AES]:file:_files' \
  '-fg[run as foreground process]' \
  '-useold[reuse existing server if available]' \
  '-verbose[debug output]' \
  '-dry-run[check whether requested action would be possible]' \
  '-geometry=[desktop size WIDTHxHEIGHT (default 1920x1200)]:geom:' \
  '-wmDecoration=[window decoration WIDTHxHEIGHT adjustment]:geom:' \
  '-xdisplaydefaults[derive geometry from running X session]' \
  '-xstartup=[custom startup script]:file:_files' \
  '-noxstartup[skip startup script]' \
  '-desktop=[desktop display name]:name:' \
  '-depth=[pixel depth bits]:n:(16 24 32)' \
  '-pixelformat=[pixel format BGRnnn or RGBnnn]:fmt:' \
  '-autokill=[auto-terminate server on session exit]:flag:(yes no)' \
  '-fp=[font path]:path:' \
  '-pidfile=[pid file for Xtigervnc server]:file:_files' \
  '-clean[remove logfile when used with -kill]' \
  '-cleanstale[clean up stale entries when used with -list]' \
  '*::display:' && ret=0

return ret
