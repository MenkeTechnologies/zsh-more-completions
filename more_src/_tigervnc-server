#compdef tigervnc-server vncserver-tigervnc
# Documentation: https://manpages.debian.org/unstable/tigervnc-standalone-server/tigervncserver.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start vnc server'
  'stop:stop vnc server'
  'restart:restart server'
  'status:show status'
  'list:list sessions'
  'kill:kill session'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-geometry+[geometry]:geom:' \
  '-depth+[color depth]:n:(8 16 24 32)' \
  '-pixelformat+[pixel format]:fmt:' \
  '-name+[desktop name]:name:' \
  '-localhost[localhost only]' \
  '-SecurityTypes+[security types]:types:' \
  '-PasswordFile+[password file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tigervnc-server command' commands && ret=0 ;;
esac

return ret
