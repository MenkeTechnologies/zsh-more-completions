#compdef cfssl-certinfo

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-cert[certificate file to examine]:file:_files -g "*.pem(|.crt|.cer)"' \
  '-domain[fetch and show cert for domain]:domain:' \
  '-csr[CSR file to examine]:file:_files -g "*.csr(|.pem)"' \
  && ret=0

return ret
