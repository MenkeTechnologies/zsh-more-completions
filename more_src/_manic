#compdef manic
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss111.html
# KAPPA: changes the dimensionality of all or part of an NDF

local ret=1

_arguments -s \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'AXES=[output pixel axes mapping]:axes' \
  'ESTIMATOR=[method for combining collapsed axes]:est:(Mean Median)' \
  'LBOUND=[lower pixel bounds for new axes]:bounds' \
  'UBOUND=[upper pixel bounds for new axes]:bounds' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
