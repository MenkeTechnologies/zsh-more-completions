#compdef fricas

# FriCAS: general-purpose computer algebra system (fork of Axiom)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-h[show help]' \
  '-version[show version]' \
  '-eval[evaluate FriCAS expression]:expr:' \
  '-execute[execute named file]:file:_files' \
  '-noclef[do not use Clef line editing]' \
  '-noht[do not start Hyperdoc viewer]' \
  '-iw[command-line editor wrapper]:wrap:' \
  '-ihere[run in current terminal]' \
  '-rm[stay in batch mode and exit on done]' \
  '-replay[load and replay command history file]:file:_files' \
  '-system[FriCAS system commands]:cmd:' \
  '-grx[run with graphics]:mode:(NIY off)' \
  '-clef[use Clef line editor]' \
  '*:FriCAS input script:_files -g "*.input"' && ret=0
return ret
