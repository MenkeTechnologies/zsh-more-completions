#compdef sanic

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--factory[treat target as a factory function]' \
  '(-s --simple)'{-s,--simple}'[simple server (single file)]' \
  '--repl[start REPL after running]' \
  '--no-repl[disable REPL]' \
  '(-H --host)'{-H,--host=}'[bind host]:host:_hosts' \
  '(-p --port)'{-p,--port=}'[bind port]:port:' \
  '(-u --unix)'{-u,--unix=}'[bind unix socket]:socket:_files' \
  '--http=[HTTP version]:version:(1 3)' \
  '-1[force HTTP/1]' \
  '-3[force HTTP/3]' \
  '--cert=[TLS cert]:file:_files' \
  '--key=[TLS key]:file:_files' \
  '--tls=[TLS dir or cert/key pair]:tls:' \
  '--tls-strict-host[strict host TLS]' \
  '--debug[debug mode]' \
  '(-r --reload --auto-reload)'{-r,--reload,--auto-reload}'[auto reload]' \
  '*'{-R,--reload-dir=}'[reload watch directory]:dir:_files -/' \
  '(-d --dev)'{-d,--dev}'[dev mode]' \
  '--auto-tls[auto TLS]' \
  '(-w --workers)'{-w,--workers=}'[number of workers]:n:' \
  '--fast[max workers]' \
  '--single-process[single process]' \
  '--access-logs[enable access logs]' \
  '--no-access-logs[disable access logs]' \
  '--coffee[coffee mode]' \
  '--no-coffee[no coffee mode]' \
  '--motd[show MOTD]' \
  '--no-motd[hide MOTD]' \
  '(-v --verbosity)'{-v,--verbosity=}'[verbosity level]:level:' \
  '--noisy-exceptions[verbose exceptions]' \
  '--no-noisy-exceptions[quiet exceptions]' \
  '(-D --daemon)'{-D,--daemon}'[run as daemon]' \
  '--pidfile=[PID file]:file:_files' \
  '--logfile=[log file]:file:_files' \
  '--user=[run as user]:user:_users' \
  '--group=[run as group]:group:_groups' \
  '*:target:'
