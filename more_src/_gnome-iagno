#compdef gnome-iagno iagno
# Documentation: https://man.archlinux.org/search?q=gnome-iagno
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--display=+[X display]:disp:' && ret=0

return ret
