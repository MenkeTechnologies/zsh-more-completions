#compdef aplay arecord
# Documentation: https://manpages.debian.org/aplay.1
# Source: alsa-utils — sound file player/recorder (argv[0]-dispatched: aplay/arecord).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show syntax]' \
    '(- *)--version[print version]' \
    '(- *)'{-l,--list-devices}'[list all soundcards and digital-audio devices]' \
    '(- *)'{-L,--list-pcms}'[list all PCMs defined]' \
    '(-D --device)'{-D+,--device=}'[select PCM by name]:name:' \
    '(-q --quiet)'{-q,--quiet}'[quiet (suppress messages)]' \
    '(-t --file-type)'{-t+,--file-type=}'[file type]:type:(voc wav raw au)' \
    '(-c --channels)'{-c+,--channels=}'[number of channels]:n:' \
    '(-f --format)'{-f+,--format=}'[sample format]:fmt:(S8 U8 S16_LE S16_BE U16_LE U16_BE S24_LE S24_BE U24_LE U24_BE S32_LE S32_BE U32_LE U32_BE FLOAT_LE FLOAT_BE FLOAT64_LE FLOAT64_BE IEC958_SUBFRAME_LE IEC958_SUBFRAME_BE MU_LAW A_LAW IMA_ADPCM MPEG GSM SPECIAL S24_3LE S24_3BE U24_3LE U24_3BE S20_3LE S20_3BE U20_3LE U20_3BE S18_3LE S18_3BE U18_3LE U18_3BE)' \
    '(-r --rate)'{-r+,--rate=}'[sample rate (Hz)]:hz:(8000 16000 22050 32000 44100 48000 88200 96000 176400 192000)' \
    '(-d --duration)'{-d+,--duration=}'[interrupt after N seconds]:seconds:' \
    '(-s --samples)'{-s+,--samples=}'[interrupt after N PCM frames]:frames:' \
    '(-M --mmap)'{-M,--mmap}'[mmap I/O mode]' \
    '(-N --nonblock)'{-N,--nonblock}'[non-blocking open]' \
    '(-F --period-time)'{-F+,--period-time=}'[period time in usec]:usec:' \
    '(-B --buffer-time)'{-B+,--buffer-time=}'[buffer duration in usec]:usec:' \
    '--period-size=[period size in frames]:frames:' \
    '--buffer-size=[buffer duration in frames]:frames:' \
    '(-A --avail-min)'{-A+,--avail-min=}'[min available space for wakeup (usec)]:usec:' \
    '(-R --start-delay)'{-R+,--start-delay=}'[automatic PCM start delay (usec)]:usec:' \
    '(-T --stop-delay)'{-T+,--stop-delay=}'[automatic PCM stop delay from xrun (usec)]:usec:' \
    '(-v --verbose)'{-v,--verbose}'[show PCM structure and setup]' \
    '(-V --vumeter)'{-V+,--vumeter=}'[VU-meter type]:type:(stereo mono)' \
    '(-I --separate-channels)'{-I,--separate-channels}'[one file per channel]' \
    '(-P -C)-P[playback (default if invoked as aplay)]' \
    '(-P -C)-C[record (default if invoked as arecord)]' \
    '(-i --interactive)'{-i,--interactive}'[interactive operation via stdin]' \
    '(-m --chmap)'{-m+,--chmap=}'[channel map override "ch1,ch2,..."]:map:' \
    '--disable-resample[disable automatic rate resample]' \
    '--disable-channels[disable automatic channel conversions]' \
    '--disable-format[disable automatic format conversions]' \
    '--disable-softvol[disable software volume (softvol)]' \
    '--test-position[test ring buffer position]' \
    '--test-coef=[ring-buffer position test coefficient (default 8)]:coef:' \
    '--test-nowait[do not wait for ring buffer (consumes CPU)]' \
    '--max-file-time=[close and open new file after N seconds]:seconds:' \
    '--process-id-file=[write PID for signal-based control]:file:_files' \
    '--use-strftime[interpret %-codes in filename via strftime]' \
    '--dump-hw-params[dump preconfigured hw_params to stderr]' \
    '--fatal-errors[disable recovery attempts on errors]' \
    '*:audio file:_files' \
    && ret=0

return ret
