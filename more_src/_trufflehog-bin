#compdef trufflehog
# _trufflehog-bin — Truffle Security trufflehog secret scanner (Truffle Security Co, Go); scan repos/files/CI for leaked secrets
# upstream: https://github.com/trufflesecurity/trufflehog

_trufflehog-bin() {
    local -a sub=(
        'git:scan a git repo'
        'github:scan github repos'
        'gitlab:scan gitlab projects'
        'filesystem:scan local filesystem'
        's3:scan s3 buckets'
        'gcs:scan GCS buckets'
        'azure:scan Azure blob containers'
        'docker:scan docker images'
        'syslog:scan syslog'
        'stdin:scan stdin'
        'circleci:scan circleci builds'
        'travisci:scan travis builds'
        'postman:scan postman'
        'elasticsearch:scan elasticsearch'
        'jenkins:scan jenkins'
        'workspace:scan a workspace'
        'huggingface:scan huggingface repos'
        'completion:print shell completion'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '--trace[trace log]' \
        '--profile[enable profiling]' \
        '--json[json output]' \
        '--json-legacy[legacy json output]' \
        '--github-actions[github actions output]' \
        '--concurrency+[parallel jobs]:n:' \
        '--no-verification[do not verify findings]' \
        '--only-verified[only verified findings]' \
        '--allow-verification-overlap[allow verification overlap]' \
        '--filter-unverified[filter unverified]' \
        '--config+[config file]:file:_files' \
        '--print-avg-detector-time[print avg detector time]' \
        '--no-update[skip update check]' \
        '--fail[exit non-zero if secrets found]' \
        '--verifier+[explicit verifier list]:list:' \
        '--exclude-detectors+[exclude detectors]:list:' \
        '--include-detectors+[include detectors]:list:' \
        '--print-buffer-utilization[print buffer utilization]' \
        '--max-archive-depth+[max archive depth]:n:' \
        '--archive-depth+[archive depth]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'trufflehog subcommand' sub ;;
        args)
            case $words[1] in
                git) _arguments \
                    '--branch+[branch]:branch:' \
                    '--bare[bare repo]' \
                    '--include-paths+[include paths]:file:_files' \
                    '--exclude-paths+[exclude paths]:file:_files' \
                    '--since-commit+[since commit]:commit:' \
                    '--max-depth+[max commit depth]:n:' \
                    '*:repo:_files -/' ;;
                github) _arguments \
                    '--token+[github token]:str:' \
                    '--org+[org]:str:' \
                    '--repo+[repo URL]:url:_urls' \
                    '--include-paths+[include paths]:file:_files' \
                    '--exclude-paths+[exclude paths]:file:_files' \
                    '--include-forks[include forks]' \
                    '--include-members[include org members]' \
                    '--issue-comments[scan issue comments]' \
                    '--pr-comments[scan pr comments]' \
                    '--gist-comments[scan gist comments]' ;;
                filesystem|s3|gcs|azure|docker) _arguments '*:target:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_trufflehog-bin "$@"
