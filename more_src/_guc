#
#  cargs distinctive features:
#    - LIGHTWEIGHT CROSS-PLATFORM — works on Linux, Windows, macOS,
#      FreeBSD, OpenBSD, NetBSD with consistent API (vs POSIX
#      getopt's Unix-only and GNU argp's glibc-only limitations)
#    - SINGLE HEADER + SINGLE C FILE — `cargs.h` + `cargs.c` for
#      easy embedding (no dependency on glibc or external libraries)
#    - DECLARATIVE `struct cag_option` ARRAY — each option is a struct
#      literal with `.identifier`/`.access_letters`/`.access_name`/
#      `.value_name`/`.description` fields
#    - `.identifier = 'X'` — UNIQUE INTEGER ID (typically char literal
#      for ASCII short flags; integer constants for long-only options)
#    - `.access_letters = "X"` — STRING of valid short letters (vs
#      getopt's single char) — `"abc"` means `-a`/`-b`/`-c` all map
#      to this option
#    - `.access_name = "long-name"` — LONG NAME without leading `--`
#      (cargs adds `--` at parse time); set to NULL for short-only
#    - `.value_name = "<arg>"` — PLACEHOLDER NAME for help text
#      (e.g. "<file>", "<int>"); set to NULL for boolean flag
#    - `.description = "help text"` — per-option help
#    - `cag_option_context` — PARSER STATE struct (caller-allocated)
#    - `cag_option_init(&ctx, options, count, argc, argv)` — INITIALIZE
#      the parser context with options array + argc/argv
#    - `cag_option_fetch(&ctx)` — FETCH NEXT option (returns true if
#      option fetched, false at end); typical pattern is `while
#      (cag_option_fetch(&ctx)) { switch (...) }`
#    - `cag_option_get_identifier(&ctx)` — GET current option's
#      `.identifier` field
#    - `cag_option_get_value(&ctx)` — GET current option's value
#      (NULL if no value)
#    - `cag_option_get_index(&ctx)` — GET current arg index (useful
#      after parsing for accessing positional args via
#      `argv[param_index]`)
#    - `cag_option_print(options, count, file)` — PRINT formatted help
#      text to a FILE* (typically stdout)
#    - `cag_option_print_error(&ctx, file)` — PRINT formatted error
#      for unrecognized options (typically stderr)
#    - `CAG_ARRAY_SIZE(arr)` MACRO — compile-time array size (avoids
#      `sizeof(arr)/sizeof(arr[0])` ceremony)
#    - SHORT OPTION CLUSTERING — `-abc` is equivalent to `-a -b -c`
#      (POSIX getopt convention)
#    - `--` SEPARATOR — args after `--` treated as positional (POSIX)
#    - NO automatic --help (caller writes `case 'h': cag_option_print(...);`
#      pattern)
#    - NO automatic --version (caller handles)
#    - NO subcommand support natively (caller hand-rolls subcommand
#      dispatch)
#    - PROCESS EXIT model — caller controls via `return EXIT_FAILURE`
#      / `exit(N)`; cargs itself never halts
#  Distinct from R272 C POSIX getopt (UNIX-ONLY char-by-char `getopt(argc,
#  argv, "ho:v")` with single-letter opts; `getopt_long(argc, argv,
#  shortopts, longopts, &index)` with `struct option longopts[]`; NO
#  Windows support without ports), R382 GNU argp (GLIBC-ONLY higher-
#  level parser with `struct argp_option` array + parser callback +
#  special keys like ARGP_KEY_ARG/_END for lifecycle hooks; needs
#  `argp-standalone` package on macOS/BSD), R270 Haskell optparse-
#  applicative (different language), R277 Java picocli (annotations
#  + auto-color help), R275 Rust clap-derive (struct + macros), R373
#  Haskell base stdlib System.Console.GetOpt (CLOSEST conceptual
#  analog — list-of-records with short chars + long names + arg
#  descriptor + help, but Haskell pure-functional vs cargs's C
#  imperative iteration).  cargs's approach: LIGHTWEIGHT CROSS-
#  PLATFORM (Linux/Windows/macOS/BSD) + SINGLE HEADER + SINGLE C FILE
#  embedding + DECLARATIVE `struct cag_option` ARRAY with `.identifier`/
#  `.access_letters`/`.access_name`/`.value_name`/`.description`
#  fields + `cag_option_context` PARSER STATE + `cag_option_init`/
#  `cag_option_fetch`/`cag_option_get_identifier`/`cag_option_get_value`/
#  `cag_option_get_index`/`cag_option_print`/`cag_option_print_error`
#  API + SHORT OPTION CLUSTERING + `--` SEPARATOR + NO automatic
#  --help/--version/subcommands (caller-driven) — corpus's **first
#  documented lightweight-cross-platform-single-file-embed C CLI
#  library**.  Brings cross-language CLI library taxonomy variant
#  count to 133; C ecosystem now has 3 documented CLI libraries.
#
#  Surface (verbatim from `src/guc/main.c` `cmd_options[]` array):
#
#  Options:
#    -m, --emit-mtlx                Emit MaterialX materials in addition
#                                   to UsdPreviewSurfaces
#    -u, --mtlx-as-usdshade         Convert and inline MaterialX materials
#                                   into the USD layer using UsdMtlx
#    -v, --default-material-variant <index>
#                                   Index of the material variant that
#                                   is selected by default
#    -s, --skip-validation          Skip glTF validation for reduced
#                                   processing time
#    -l, --licenses                 Print license of guc and third-party
#                                   libraries
#    -h, --help                     Show the command help
#
#  Positional:
#    GLTF_PATH                      Input glTF/GLB file path (REQUIRED)
#    USD_PATH                       Output USD file path (REQUIRED)
#    --                             Separator for cases where positionals
#                                   could be confused with flags
#
#  Examples:
#    guc model.gltf model.usd                   # Basic conversion
#    guc -m model.gltf model.usd                # Emit MaterialX
#    guc -u model.gltf model.usd                # Inline MaterialX via UsdMtlx
#    guc -s -v 2 model.gltf model.usd           # Skip validation +
#                                               # use variant 2
#    guc --licenses                             # Print licenses
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also cargs users):
#    - voxelpic (microsoft/voxelpic 0 stars — Microsoft point cloud
#      library; uses cargs but library not user-facing binary)
#    - hydrausb3-isp (hydrausb3/wch-ch56x-isp 18 stars — WCH MCU
#      flasher, smaller community)
#    - fennix (enderice2/Fennix 3 stars — hobby OS from scratch, niche)
#    - lvterm (AirDeeEx/lvterm 0 stars — terminal emulator, early-stage)
#    - cimplecrypt / outfittable / redit / speedo / git-note / gci-
#      encoder / xml_code_generator (smaller community C CLI tools)
#    - likle/cargs (the library itself — flagship use is the demo,
#      not a user-facing binary)
# ============================================================================

_guc() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-m --emit-mtlx)'{-m,--emit-mtlx}'[emit MaterialX materials in addition to UsdPreviewSurfaces]' \
    '(-u --mtlx-as-usdshade)'{-u,--mtlx-as-usdshade}'[inline MaterialX materials into USD via UsdMtlx]' \
    '(-v --default-material-variant)'{-v,--default-material-variant}'=[default material variant index]:index' \
    '(-s --skip-validation)'{-s,--skip-validation}'[skip glTF validation]' \
    '(-l --licenses)'{-l,--licenses}'[print license of guc and third-party libraries]' \
    '(-h --help)'{-h,--help}'[show command help]' \
    '1:input glTF/GLB file:_files -g "*.(glb|gltf)"' \
    '2:output USD file:_files -g "*.(usd|usda|usdc|usdz)"'
}

_guc "$@"
