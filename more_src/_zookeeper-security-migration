#compdef zookeeper-security-migration zookeeper-security-migration.sh
# _zookeeper-security-migration — Apache ZooKeeper zookeeper-security-migration helper CLI for switching znode ACLs between SASL secure and world-readable insecure mode used during Kafka SASL/SCRAM-Kerberos rollouts (apache team, Bash); JCommander
# upstream: https://kafka.apache.org/

_zookeeper-security-migration() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--zookeeper.acl=+[mode]:m:(secure unsecure)' \
        '--zookeeper.connect=+[host:port]:str:' \
        '--zookeeper.connection.timeout.ms=+[ms]:n:' \
        '--zookeeper.session.timeout.ms=+[ms]:n:' \
        '--zk-tls-config-file=+[file]:file:_files -g "*.properties *.conf"' \
        '*:additional arguments:'
}

_zookeeper-security-migration "$@"
