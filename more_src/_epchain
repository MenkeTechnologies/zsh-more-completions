#compdef epchain
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/epchain/node11.html
# XMM-Newton SAS: generate the EPIC-PN event list product

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--odf=[input ODF directory name]:dir:_files -/' \
  '--odfaccess=[how to access the ODF data]:mode:' \
  '--schedule=[exposure schedule flag]:flag:' \
  '--datamode=[data modes to process]:mode:(IMAGING TIMING BURST ALL)' \
  '--exposure=[exposure number to process]:exp:' \
  '--ccds=[list of CCDs to process]:ccds:' \
  '--keepintermediate=[intermediate files to preserve]:flag:' \
  '--withdefaultcal=[apply mode-dependent calibration]:flag:(yes no)' \
  '--usecanonicalnames=[auto-create output filenames]:flag:(yes no)' \
  '--outset=[output events file name]:file:_files' \
  '--withradmon=[access EPIC Radiation Monitor files]:flag:(yes no)' \
  '--runradmonfix=[execute radmonfix tool]:flag:(yes no)' \
  '--runatthkgen=[run attitude HK generation]:flag:(yes no)' \
  '--timestep=[duration of attitude quality steps]:step:' \
  '--runattcalc=[calculate attitude information]:flag:(yes no)' \
  '--runepframes=[process EPIC frames]:flag:(yes no)' \
  '--withsrccoords=[use user-supplied source coordinates]:flag:(yes no)' \
  '--srcra=[source right ascension (J2000)]:ra:' \
  '--srcdec=[source declination (J2000)]:dec:' \
  '--srcposition=[source position in RAWY pixels]:pos:' \
  '--runbadpixfind=[identify bad pixels]:flag:(yes no)' \
  '--runbadpix=[apply bad pixel corrections]:flag:(yes no)' \
  '--badpixset=[path to bad pixel file]:file:_files' \
  '--runepreject=[run rejection filtering]:flag:(yes no)' \
  '--runepevents=[process events]:flag:(yes no)' \
  '--runepnoise=[identify noisy frames]:flag:(yes no)' \
  '--runepxrlcorr=[apply X-ray loading correction]:flag:(yes no)' \
  '--withpatternoffset=[apply pattern energy offsets]:flag:(yes no)' \
  '--withtempcorrection=[apply temperature-gain corrections]:flag:(yes no)' \
  '--withctilongterm=[apply long-term CTI corrections]:flag:(yes no)' \
  '--screen=[reject flagged events]:flag:(yes no)' \
  '--runscreen=[perform event screening]:flag:(yes no)' \
  '--screenlowthresh=[low-energy rejection threshold]:thresh:' \
  '--runevselect=[apply final GTI screening]:flag:(yes no)' \
  '--runevlistcomb=[combine event lists]:flag:(yes no)' \
  '--runbackground=[generate background lightcurve]:flag:(yes no)' \
  '--withmask=[use masks for lightcurve]:flag:(yes no)' \
  '--maskset=[point source mask file path]:file:_files' \
  '--rateset=[background lightcurve output file]:file:_files' \
  '--timebinsize=[time bin for background data]:size:' \
  '*:event file:_files' && ret=0

return ret
