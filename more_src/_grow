#compdef grow
# Documentation: https://github.com/grow/grow/blob/master/grow/commands/subcommands/build.py
# Grow declarative website generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--out-dir=[output directory]:dir:_files -/' \
  '--clear-cache[clear the cache before building]' \
  '--file=[pod path to build]:file:_files' \
  '--locate-untranslated[show untranslated strings]' \
  '--locale=[locale to build]:locale:' \
  '--deployment=[named deployment]:deployment:' \
  '--preprocess[run preprocessors]' \
  '--threaded[build using threads]' \
  '--shards=[number of shards]:n:' \
  '--shard=[shard to build]:n:' \
  '--host=[development server host]:host:' \
  '--port=[development server port]:port:' \
  '--https[serve over https]' \
  '--browser[open a browser]' \
  '--ui[enable the grow ui]' \
  '1:command:(build run deploy stage install preprocess inspect convert translations)' \
  '*::arg:_files' && ret=0

return ret
