#compdef appium

# Zsh completion for appium - Appium mobile testing framework

_arguments -s -S \
  '(-a --address)'{-a,--address}'=[IP address to listen on]:host:_hosts' \
  '(-p --port)'{-p,--port}'=[port to listen on]:port:' \
  '(-pa --base-path)'{-pa,--base-path}'=[base path for routes]:path:' \
  '(-g --log)'{-g,--log}'=[log file path]:log file:_files' \
  '--log-level=[log level]:level:(info info\:debug info\:info info\:warn info\:error warn warn\:debug warn\:info warn\:warn warn\:error error error\:debug error\:info error\:warn error\:error debug)' \
  '--log-timestamp[show timestamps in console output]' \
  '--local-timezone[use local timezone for timestamps]' \
  '--log-no-colors[do not use colors in console output]' \
  '--tmp=[temporary directory]:directory:_files -/' \
  '--trace-dir=[directory for trace data]:directory:_files -/' \
  '--debug-log-spacing[add extra spacing in logs for readability]' \
  '--long-stacktrace[show long stack traces]' \
  '--webhook=[webhook URL for log notifications]:url:_urls' \
  '--session-override[enable session override]' \
  '--config=[configuration file]:config file:_files' \
  '--use-plugins=[comma-separated list of plugins to activate]:plugins:' \
  '--use-drivers=[comma-separated list of drivers to activate]:drivers:' \
  '--allow-cors[enable CORS]' \
  '*--allow-insecure=[enable insecure feature]:feature:' \
  '*--deny-insecure=[disable insecure feature]:feature:' \
  '--relaxed-security[disable all security checks]' \
  '--strict-caps[require all capabilities to be recognized]' \
  '--default-capabilities=[default desired capabilities as JSON]:capabilities:' \
  '--keep-alive-timeout=[keep-alive timeout in seconds]:seconds:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]'
