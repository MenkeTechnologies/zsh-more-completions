#compdef caffeinate
# Documentation: https://www.unix.com/man-page/osx/8/caffeinate/
# Source: Apple macOS — create power-management assertions (keep system / display awake).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[prevent the display from sleeping]' \
    '-i[prevent system from idle sleeping]' \
    '-m[prevent disk from idle sleeping]' \
    '-s[prevent system from sleeping (AC power only)]' \
    '-u[declare user active (wake display and prevent idle display sleep)]' \
    '-t[assertion timeout in seconds]:seconds:' \
    '-w[wait for given PID to exit]:pid:_pids' \
    '*:command and args:_command_names -e' \
    && ret=0

return ret
