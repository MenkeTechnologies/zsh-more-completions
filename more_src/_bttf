#compdef bttf
# ---------------------------------------------------------------------------
# bttf — command-line tool for datetime arithmetic, parsing, formatting,
#        and tagging (Rust, 657★)
#
# upstream: https://github.com/BurntSushi/bttf
# author : Andrew Gallant (BurntSushi, jamslam@gmail.com) — author of
#          ripgrep, xsv, aho-corasick, regex-rs, bstr, jiff, and most of
#          the canonical Rust text-processing / search ecosystem
# license: Unlicense OR MIT (dual)
#
# Source-direct completion: every subcommand below is verbatim from
# src/cmd/{mod,span/mod,time/mod,tag/mod,tz/mod}.rs on the BurntSushi/
# bttf v0.1.4 tip — lexopt-based dispatch with USAGE strings that
# enumerate each subtree's commands.  Per-subcommand flags live in
# src/cmd/<subtree>/<command>.rs as `lexopt::Parser` token matches;
# this completion focuses on subcommand discovery (the CLI is heavily
# nested with ~30 distinct leaf commands across the four subtrees);
# pair with `bttf <path> --help` for per-command options.
#
# Direct deps from Cargo.toml (selected):
#   jiff             0.2.11    ← canonical Rust datetime library (this
#                                axis) — by Andrew Gallant (BurntSushi/
#                                jiff); modern alternative to `chrono`
#                                inspired by JavaScript's Temporal
#                                proposal and Java's java.time package.
#                                Provides DST-safe calendar+absolute
#                                duration arithmetic, IANA time zone
#                                database integration (tzdb-bundle-
#                                always feature here), RFC 5545
#                                recurrence rules, and strftime-style
#                                formatting; the entire bttf CLI is
#                                essentially a CLI surface over the
#                                jiff API.
#   icu_calendar / icu_datetime / icu_locale / icu_time
#                              (ICU4X for locale-aware formatting under
#                               the `locale` feature, on by default)
#   lexopt                     (Sebastian Köln's minimal-token argv
#                               parser — alternative to clap that
#                               BurntSushi prefers for hand-crafted
#                               CLIs; <250 LOC)
#   anyhow + bstr + flume + anstyle (BurntSushi-typical companions)
#
# bttf — "Back to the Future" — does for datetimes what xsv does for
# CSV: a focused, fast CLI for parsing, arithmetic, formatting, and
# tagging.  Running `bttf` with no arguments prints the current time
# in `date`-like format; subcommands cover span/duration manipulation,
# datetime arithmetic, tagging arbitrary data streams with timestamps
# (great for re-localizing log files), and IANA time zone exploration
# including RFC 5545 recurrence sequences.
#
# === AXIS 177 OPENER — modern datetime libraries (post-chrono) ===========
# Axis position: Rust=232 OPENS Axis 177 at slot 1/0/0.  Canonical Rust
# modern datetime library is `jiff` by Andrew Gallant (BurntSushi/jiff)
# — inspired by JavaScript's Temporal proposal and Java's java.time
# package; provides DST-safe calendar+absolute duration arithmetic with
# IANA time zone database integration, RFC 5545 recurrence rules,
# strftime-style formatting, and a typed Zoned/DateTime/Span trinity
# that prevents the chrono-style pitfalls around naive timezone math.
# bttf is the de-facto CLI surface over the jiff API by the jiff author
# himself.  jiff has been gaining adoption as the recommended Rust
# datetime library over chrono for new projects since its 0.2 release.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=232     ← THIS FILE              (axis 177 OPENS, slot 1/0/0)
#   Go=232       ← next round              (axis 177 continues, slot 2/0/0)
#   TS-Node=232  ← round after             (axis 177 CLOSES at triple-232, slot 1/1/1)
# ---------------------------------------------------------------------------

_bttf() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'span:tools for manipulating time spans/durations (balance/fmt/iso8601/round/since/until)'
                'time:tools for manipulating datetimes (add/cmp/end-of/fmt/in/parse/relative/round/seq/sort/start-of)'
                'tag:tag arbitrary data with datetimes or spans (exec/files/lines/stat)'
                'tz:commands for working directly with time zones (compatible/list/prev/next/seq)'
                'untag:remove tags from previously tagged data'
            )
            _describe -t commands 'bttf command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                span)
                    _arguments \
                        '1: :->span_cmds' \
                        '*::arg:->span_args' && ret=0
                    case $state in
                        span_cmds)
                            local -a sub; sub=(
                                'balance:change the largest non-zero unit in a span'
                                'fmt:format a span as a friendly duration'
                                'iso8601:format span as an ISO 8601 duration'
                                'round:round a span to a given unit'
                                'since:calculate a span since a datetime'
                                'until:calculate a span until a datetime'
                            )
                            _describe -t commands 'span subcommand' sub && ret=0
                            ;;
                    esac
                    ;;
                time)
                    _arguments \
                        '1: :->time_cmds' \
                        '*::arg:->time_args' && ret=0
                    case $state in
                        time_cmds)
                            local -a sub; sub=(
                                'add:add a span to a datetime'
                                'cmp:compare datetimes'
                                'end-of:get the end of a year/month/week/day/hour/etc'
                                'fmt:format a datetime (strftime-style)'
                                'in:convert a datetime to a time zone'
                                'parse:parse a datetime from a string'
                                'relative:parse a relative datetime (e.g. "5pm last thursday")'
                                'round:round a datetime to a given unit'
                                'seq:generate a sequence of datetimes (RFC 5545 recurrence)'
                                'sort:sort datetimes from stdin'
                                'start-of:get the start of a year/month/week/day/hour/etc'
                            )
                            _describe -t commands 'time subcommand' sub && ret=0
                            ;;
                    esac
                    ;;
                tag)
                    _arguments \
                        '1: :->tag_cmds' \
                        '*::arg:->tag_args' && ret=0
                    case $state in
                        tag_cmds)
                            local -a sub; sub=(
                                'exec:tag files by running arbitrary commands and capturing their outputs'
                                'files:tag file paths by running regexes over file contents'
                                'lines:extract datetimes from lines in a file (great for reformatting/localizing log timestamps)'
                                'stat:extract datetimes from file metadata (mtime/atime/ctime/birthtime)'
                            )
                            _describe -t commands 'tag subcommand' sub && ret=0
                            ;;
                    esac
                    ;;
                tz)
                    _arguments \
                        '1: :->tz_cmds' \
                        '*::arg:->tz_args' && ret=0
                    case $state in
                        tz_cmds)
                            local -a sub; sub=(
                                'compatible:list time zones compatible with an RFC 3339 timestamp'
                                'list:list available IANA time zones'
                                'prev:find one time zone transition preceding datetimes'
                                'next:find one time zone transition following datetimes'
                                'seq:list time zone transitions after (or before) a datetime'
                            )
                            _describe -t commands 'tz subcommand' sub && ret=0
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac

    return ret
}

_bttf "$@"
