#compdef cd-hit-lap
# Documentation: https://github.com/weizhongli/cdhit/blob/master/cd-hit-auxtools/cdhit-lap.cxx
# CD-HIT-LAP - extract overlapping read pairs using tail-head matching

local ret=1

_arguments -s \
  '-i[input file]:input:_files' \
  '-o[output file]:output:_files' \
  '-m[minimum length of overlapping part (default 20)]:length' \
  '-p[minimum percentage of overlapping part (default 0, any percentage)]:percent' \
  '-d[description length (default 0)]:length' \
  '-s[random number seed for shuffling (default 0, no shuffling)]:seed' \
  '-stdout[standard output type (default log)]:type:(log rep clstr)' \
  '*:file:_files' && ret=0

return ret
