#compdef MaxQuantCmd MaxQuantCmd.exe MaxQuantCmd.dll
# Documentation: https://lgatto.github.io/maxquant-linux/
# MaxQuant: command-line driver for the MaxQuant proteomics pipeline

local ret=1

_arguments -s -S \
  '--create[create a template mqpar.xml parameter file]:template mqpar.xml:_files' \
  '--dryrun[list all processing steps and their job ids]' \
  '--partial-processing=[start processing from the given job id]:job id:' \
  '--partial-processing-end=[stop processing at the given job id]:job id:' \
  '--changeFolder[change fasta/raw/library folders in an mqpar file]:new mqpar.xml:_files' \
  '--help[show help]' \
  '*:mqpar.xml:_files' && ret=0

return ret
