#compdef tuckr
# Documentation: https://github.com/RaphGL/Tuckr
# Source: RaphGL/Tuckr — GNU Stow-style dotfile manager in Rust.
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _tuckr_cmds
_tuckr_cmds=(
    'status:check dotfiles symlinking status'
    's:alias for status'
    'add:deploy dotfiles for specified groups'
    'a:alias for add'
    'rm:remove dotfiles for specified groups'
    'set:setup groups and execute their hooks'
    'unset:remove groups and run cleanup hooks'
    'encrypt:encrypt files and move them to dotfiles/Secrets'
    'e:alias for encrypt'
    'decrypt:decrypt files'
    'd:alias for decrypt'
    'push:copy files into groups'
    'pop:remove groups from dotfiles/Configs'
    'ls:list dotfiles hooks, secrets, profiles'
    'init:initialize dotfile directory'
    'groupis:return the group files belong to'
    'help:show help'
)

_arguments -C \
    '(-p --profile)'{-p+,--profile=}'[dotfile profile to use]:profile:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'tuckr command' _tuckr_cmds && ret=0
        ;;
    args)
        _arguments -s -S '*:groups or files:_default' && ret=0
        ;;
esac

return ret
