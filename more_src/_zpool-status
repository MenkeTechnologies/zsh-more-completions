#compdef zpool-status
# _zpool-status — OpenZFS zpool status (per-pool health summary including vdev tree, resilver/scrub progress, errors; -v verbose error list, -x problems only, -e errors only, -P full pathnames, -L resolve symlinks, -g show GUIDs, -t periodic refresh; positional pool optionally filters)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_status) on tip.

_zpool-status() {
    _arguments \
        '-v[verbose error list]' \
        '-x[problems only]' \
        '-e[errors only]' \
        '-P[full pathnames]' \
        '-L[resolve symlinks]' \
        '-g[show GUIDs]' \
        '-D[dedup table summary]' \
        '-T+[timestamp format]:format:(u d)' \
        '-c+[cmds to run for stats]:cmds:' \
        '-i[show initialize state]' \
        '*:pool:'
}

_zpool-status "$@"
