#compdef torch-model-archiver
# Documentation: https://man.archlinux.org/search?q=torch-model-archiver
# Reference accessed: 2026-05-16

# torch-model-archiver: package PyTorch models into .mar for TorchServe
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--model-name=[model name]:name:' \
  '--serialized-file=[serialized .pth file]:file:_files -g "*.pth"' \
  '--model-file=[model definition .py]:file:_files -g "*.py"' \
  '--handler=[handler file or built-in]:handler:' \
  '--extra-files=[extra files (comma list)]:files:' \
  '--runtime=[runtime]:runtime:(python python3 lsp pytorch)' \
  '--export-path=[export path]:dir:_files -/' \
  '--archive-format=[archive format]:fmt:(default tgz no-archive)' \
  '-f[overwrite existing archive]' \
  '--force[overwrite existing archive]' \
  '-r[requirements.txt]:file:_files' \
  '--requirements-file=[requirements.txt]:file:_files' \
  '*::torch-model-archiver args:_files' && ret=0
return ret
