#compdef frida-pull
# Documentation: https://github.com/frida/frida-tools/blob/main/frida_tools/pull.py
# Pull files from a device

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[output version information and exit]' \
  '(-D --device)'{-D,--device}'=[connect to device with the given ID]:device ID' \
  '(-U --usb)'{-U,--usb}'[connect to USB device]' \
  '(-R --remote)'{-R,--remote}'[connect to remote frida-server]' \
  '(-H --host)'{-H,--host}'=[connect to remote frida-server on HOST]:host' \
  '--certificate=[speak TLS with HOST, expecting CERTIFICATE]:certificate:_files' \
  '--origin=[connect to remote server with Origin header set to ORIGIN]:origin' \
  '--token=[authenticate with HOST using TOKEN]:token' \
  '*:remote files to pull:_files' && ret=0

return ret
