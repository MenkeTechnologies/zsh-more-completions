#compdef koordlet
# _koordlet — Koordinator per-node QoS/SLO daemon (koordinator-sh/koordinator)
# upstream: https://github.com/koordinator-sh/koordinator
# Flags from cmd/koordlet/options/options.go on tip.

_koordlet() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--addr=[koordlet HTTP server host\:port]:host\:port:' \
        '--enable-pprof[enable pprof endpoints]' \
        '--pprof-addr=[pprof bind host\:port]:host\:port:' \
        '--kube-api-qps=[QPS to kube-apiserver]:f:' \
        '--kube-api-burst=[burst to kube-apiserver]:n:' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_koordlet "$@"
