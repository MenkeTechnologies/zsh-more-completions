#compdef anyproxy
# Documentation: https://github.com/alibaba/anyproxy/blob/master/docs-src/en/README.md
# Fully configurable HTTP/HTTPS proxy in NodeJS

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--port=[proxy server port (default 8001)]:port' \
  '--web=[web interface port]:port' \
  '--rule=[load a rule module (file, URL or npm package)]:rule' \
  '--intercept[enable HTTPS interception for all traffic]' \
  '--ws-intercept[enable WebSocket interception and recording]' \
  '(-i --ignore-unauthorized-ssl)'{-i,--ignore-unauthorized-ssl}'[ignore certificate errors in requests]' \
  '--throttle=[bandwidth throttling in kb/s]:kbps' \
  '--silent[suppress console output]' \
  '*:rule file:_files' && ret=0

return ret
