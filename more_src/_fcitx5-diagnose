#compdef fcitx5-diagnose
# Documentation: https://github.com/fcitx/fcitx5/blob/master/data/fcitx5-diagnose.sh
# Reference accessed: 2026-05-16
# Verified: data/fcitx5-diagnose.sh bash script. Only --color and optional
# positional output-file. No -h/--help/--version.
# Removed from prior file: -h/--help/-V/--version (none exist in source).

# fcitx5-diagnose: fcitx5 diagnostics shell script
local curcontext="$curcontext" ret=1
_arguments -C \
  '--color=-[output color mode]:mode:(never false auto true)' \
  '*:output file:_files' && ret=0
return ret
