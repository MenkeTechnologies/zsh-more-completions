#compdef amdvbflash atiflash
# Documentation: https://github.com/stylesuxx/amdvbflash
# Reference accessed: 2026-05-17
# Verified: AMD/ATI VBIOS flash utility — single-dash flags only,
# never --long. Real flags: -i [Num], -ai [Num], -p, -pa, -s,
# -biosfileinfo, -cf, -cb, -st, -atmel, -keepisrsn, -keepprodsn,
# -log, -logappend, -f, -fp, -fs, -passkept.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -isi, -pcimap, -info (correct is -biosfileinfo).

# amdvbflash / atiflash: AMD video BIOS flash utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-i[list adapters]' \
  '-s[save current VBIOS]:adapter file:' \
  '-p[program VBIOS]:adapter file:' \
  '-cf[verify checksum]:file:_files' \
  '-cb[check BIOS]:file:_files' \
  '-pa[program all]:file:_files' \
  '-info[show info]:file:_files' \
  '-fp[force program (ignore checks)]:file:_files' \
  '-f[force]' \
  '-biosfileinfo[show BIOS file info]:file:_files' \
  '-st[force ST M25Pxx algorithm]' \
  '-atmel[force AT25Fxxx algorithm]' \
  '-keepisrsn[preserve ISR serial]' \
  '-keepprodsn[preserve product serial]' \
  '-passkept[keep all serials]' \
  '-log[overwrite atiflash.log]' \
  '-logappend[append to atiflash.log]' \
  '-fs[force save]' \
  '-ai[advanced info]:adapter:' \
  '*::amdvbflash args:_files' && ret=0
return ret
