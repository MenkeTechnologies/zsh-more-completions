#compdef atiflash

# atiflash: legacy ATI video BIOS flash utility (same interface as amdvbflash)
local curcontext="$curcontext" ret=1
_arguments -C \
  '/?[show help]' \
  '-help[show help]' \
  '-i[show adapter info]' \
  '-ai[show ASIC info]' \
  '-p[program BIOS]:adapter file:_files' \
  '-s[save BIOS]:adapter file:_files' \
  '-v[verify BIOS]:adapter file:_files' \
  '-cf[force flash]' \
  '-pa[program all adapters]:file:_files' \
  '-sa[save all adapters]' \
  '-ce[clear errors]' \
  '*::atiflash args:_files' && ret=0
return ret
