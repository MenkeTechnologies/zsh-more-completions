#compdef scons-time
# Documentation: https://man.archlinux.org/man/scons-time.1.en
# generate and display SCons build timing and profile information

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help for the specified subcommand]' \
  '(-p --prefix)'{-p,--prefix=}'[prefix string for log files to extract from]:prefix:' \
  '(-f --file)'{-f,--file=}'[read configuration information from a file]:file:_files' \
  '(-C --chdir)'{-C,--chdir=}'[change to directory before looking for files]:dir:_files -/' \
  '(-t --tail)'{-t,--tail=}'[only extract from the last NUMBER files]:number:' \
  '--fmt=[report output in the specified format]:format:(ascii gnuplot)' \
  '--format=[report output in the specified format]:format:(ascii gnuplot)' \
  '--title=[set a title for the generated output]:title:' \
  '1:command:((
    run\:"generate profile and log file output"
    func\:"display timing information for a Python function"
    mem\:"display how much memory SCons uses"
    obj\:"display how many objects of a named type are created"
    time\:"display SCons execution times"
    help\:"print help text for other subcommands"
  ))' \
  '*::arg:->args' && ret=0

return ret
