#compdef otbcli_ReadImageInfo
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ReadImageInfo.html
# Orfeo ToolBox: get information about the geometry and metadata of an image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image to analyse]:image:_files' \
  '-imagemetadata[output the image metadata]' \
  '-outgeom[extract image metadata into a geom file]:file:_files' \
  '-indexx[X start index]:value:' \
  '-indexy[Y start index]:value:' \
  '-sizex[X size in pixels]:value:' \
  '-sizey[Y size in pixels]:value:' \
  '-spacingx[pixel size along X]:value:' \
  '-spacingy[pixel size along Y]:value:' \
  '-originx[origin along X]:value:' \
  '-originy[origin along Y]:value:' \
  '-numberbands[number of bands]:value:' \
  '-datatype[data type]:value:' \
  '-sensor[sensor identifier]:value:' \
  '-id[image identifier]:value:' \
  '-time[acquisition time]:value:' \
  '-projectionref[projection coordinate system]:value:' \
  '-metadata[image metadata]:value:' \
  '-rgb.r[red band number]:value:' \
  '-rgb.g[green band number]:value:' \
  '-rgb.b[blue band number]:value:' \
  '*::arg:_files' && ret=0

return ret
