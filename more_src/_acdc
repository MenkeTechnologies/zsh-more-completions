#compdef acdc
# Documentation: https://man.archlinux.org/search?q=acdc
# Reference accessed: 2026-05-16

# EMBOSS acdc: test an ACD application command-line parser
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-program=[ACD application name]:program:' \
  '-acdtrace[trace ACD processing in detail]' \
  '-acdverbose[verbose ACD trace]' \
  '-acdpretty[output formatted ACD]' \
  '-acdtable[output ACD as a table]' \
  '*::ACD program args:' && ret=0
return ret
