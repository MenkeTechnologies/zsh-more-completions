#compdef IntervalListToBed
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/util/IntervalListToBed.java
# Picard: convert a Picard interval list to a BED file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input IntervalList file]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output BED file]:file:_files' \
  '--SCORE=[score (0-1000) to output for each interval]:n:' \
  '--SORT=[sort interval list before output]:b:(true false)' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
