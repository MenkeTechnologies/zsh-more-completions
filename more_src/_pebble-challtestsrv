#compdef pebble-challtestsrv
# _pebble-challtestsrv — ACME challenge test server with HTTP management (letsencrypt/pebble)
# upstream: https://github.com/letsencrypt/pebble
# Flags from cmd/pebble-challtestsrv/main.go (flag).

_pebble-challtestsrv() {
    _arguments \
        '-http01=[bind addresses/ports for HTTP-01]:addrs:' \
        '-https01=[bind addresses/ports for HTTPS HTTP-01]:addrs:' \
        '-doh=[bind addresses/ports for DoH queries]:addrs:' \
        '-doh-cert=[DoH server certificate]:file:_files -g "*.(pem|crt)"' \
        '-doh-cert-key=[DoH server private key]:file:_files -g "*.(pem|key)"' \
        '-dnsserver=[bind addresses/ports for DNS]:addrs:' \
        '-tlsalpn01=[bind addresses/ports for TLS-ALPN-01]:addrs:' \
        '-management=[management HTTP bind address]:addr:' \
        '-defaultIPv4=[default IPv4 for A responses]:addr:' \
        '-defaultIPv6=[default IPv6 for AAAA responses]:addr:'
}

_pebble-challtestsrv "$@"
