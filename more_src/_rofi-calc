#compdef rofi-calc
# Documentation: https://github.com/svenstaro/rofi-calc
# Reference accessed: 2026-05-17
# Verified: svenstaro/rofi-calc README options table. rofi-calc is a
# rofi plugin, not a standalone binary; flags here are the plugin's
# rofi-config knobs (typically: rofi -modi calc -show calc <opts>).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --help/--version (the plugin itself has no -h/-V).

local ret=1
_arguments -s -S \
  '-calc-command[shell cmd run on selection]:cmd:' \
  '-no-bold[disable bold result]' \
  '-no-history[disable history]' \
  '-no-persist-history[disable persistent history]' \
  '-no-unicode[disable qalc unicode]' \
  '-terse[reduce output to result only]' \
  '-automatic-save-to-history[auto-save on exit]' \
  '-calc-command-history[add command output to history]' \
  '-qalc-binary[path to qalc]:file:_files' \
  '-hint-result[customize result hint]:text:' \
  '-hint-welcome[customize welcome text]:text:' \
  '-calc-error-color[color for errors]:color:' \
  '-reuse-result[reuse previous result as input]' && ret=0
return ret
