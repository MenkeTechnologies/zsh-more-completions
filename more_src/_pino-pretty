local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --colorize)'{-c,--colorize}'[colorize output (auto-detected from TTY)]' \
  '-C[force colorize output (even when not a TTY)]' \
  '(-f --crlf)'{-f,--crlf}'[use CRLF line endings]' \
  '(-e --errorProps)'{-e+,--errorProps=}'[error properties to show]:props:' \
  '(-l --levelFirst)'{-l,--levelFirst}'[show level as first output field]' \
  '(-L --minimumLevel)'{-L+,--minimumLevel=}'[minimum log level to display]:level:(trace debug info warn error fatal silent)' \
  '(-x --customLevels)'{-x+,--customLevels=}'[custom level mapping]:map:' \
  '(-X --customColors)'{-X+,--customColors=}'[custom level colors]:map:' \
  '(-U --useOnlyCustomProps)'{-U,--useOnlyCustomProps}'[only use custom-defined levels]' \
  '(-k --errorLikeObjectKeys)'{-k+,--errorLikeObjectKeys=}'[keys for error-like objects (default err,error)]:keys:' \
  '(-m --messageKey)'{-m+,--messageKey=}'[message key name (default msg)]:key:' \
  '--levelKey=[level key name (default level)]:key:' \
  '(-b --levelLabel)'{-b+,--levelLabel=}'[label for level output]:label:' \
  '(-o --messageFormat)'{-o+,--messageFormat=}'[custom message format template]:fmt:' \
  '(-a --timestampKey)'{-a+,--timestampKey=}'[timestamp key name (default time)]:key:' \
  '(-t --translateTime)'{-t+,--translateTime=}'[translate timestamp to human-readable]:format:' \
  '(-i --ignore)'{-i+,--ignore=}'[keys to ignore (comma-separated)]:keys:' \
  '(-I --include)'{-I+,--include=}'[keys to include (comma-separated)]:keys:' \
  '(-H --hideObject)'{-H,--hideObject}'[hide object from output]' \
  '(-S --singleLine)'{-S,--singleLine}'[show log object on single line]' \
  '--config=[config file path]:file:_files' && ret=0

return ret
