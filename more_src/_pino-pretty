#compdef pino-pretty

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c[colorize output]' \
  '--colorize[colorize output]' \
  '-C[force colorize output]' \
  '--crlf[use CRLF line endings]' \
  '-e+[error-like object keys]:keys' \
  '--errorLikeObjectKeys=[error-like object keys]:keys' \
  '-f+[format string]:format' \
  '-l[include level label]' \
  '--levelFirst[show level as first output field]' \
  '-k+[keys to include]:keys' \
  '--errorProps=[error properties to show]:properties' \
  '-L+[level key name]:key' \
  '--levelKey=[level key name]:key' \
  '-i+[keys to ignore]:keys' \
  '--ignore=[keys to ignore]:keys' \
  '-H[hide object from output]' \
  '--hideObject[hide object from output]' \
  '-m+[message key name]:key' \
  '--messageKey=[message key name]:key' \
  '-o+[message format]:format' \
  '--messageFormat=[message format]:format' \
  '-a+[timestamp key name]:key' \
  '--timestampKey=[timestamp key name]:key' \
  '-t[translate timestamp to human-readable]' \
  '--translateTime[translate timestamp to human-readable]' \
  '-s+[single line output]' \
  '--singleLine[single line output]' \
  '--config=[config file]:file:_files' && ret=0

return ret
