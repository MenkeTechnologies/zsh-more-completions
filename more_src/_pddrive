#compdef pddrive
# Documentation: https://github.com/xiaoyeli/superlu_dist/blob/master/EXAMPLE/pddrive.c
# SuperLU_DIST double-precision distributed driver example

local ret=1

_arguments -s -S \
  '-h[print help and exit]' \
  '-r[number of process rows]:nprow' \
  '-c[number of process columns]:npcol' \
  '-p[row permutation strategy]:rowperm' \
  '-q[column permutation strategy]:colperm' \
  '-s[parallel symbolic factorization flag]:parsymb' \
  '-l[lookahead level]:num' \
  '-i[iterative refinement setting]:ir' \
  '-b[use batch mode flag]:batch' \
  '*:matrix file:_files' && ret=0

return ret
