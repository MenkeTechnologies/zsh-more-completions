#compdef bsub
# Documentation: https://www.ibm.com/docs/en/spectrum-lsf/10.1.0?topic=reference-bsub
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bsub: submit a batch job to LSF
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-J[job name]:name:' \
  '-q[queue]:queue:' \
  '-n[processors]:n:' \
  '-R[resource req]:req:' \
  '-app[application profile]:app:' \
  '-P[project]:project:' \
  '-G[user group]:group:_groups' \
  '-u[mail user]:user:_users' \
  '-N[email on completion]' \
  '-B[email on begin]' \
  '-M[memory limit MB]:mb:' \
  '-c[CPU limit (min)]:n:' \
  '-W[wall clock limit]:HH\:MM:' \
  '-W_e[walltime exit]:hh\:mm:' \
  '-i[stdin]:file:_files' \
  '-o[stdout]:file:_files' \
  '-e[stderr]:file:_files' \
  '-oo[overwrite stdout]:file:_files' \
  '-eo[overwrite stderr]:file:_files' \
  '-cwd[working dir]:dir:_files -/' \
  '-x[exclusive host use]' \
  '-Ip[interactive pseudo-terminal]' \
  '-I[interactive]' \
  '-K[wait for job]' \
  '-r[rerun on failure]' \
  '-rn[never rerun]' \
  '-w[dependency]:expr:' \
  '-pack[job pack id]:n:' \
  '-extsched[extended scheduling]:opts:' \
  '-jsdl[JSDL XML file]:file:_files -g "*.xml"' \
  '-XF[X11 forwarding]' \
  '*:command:_command_names' && ret=0
return ret
