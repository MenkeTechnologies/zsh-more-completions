#compdef generate-keys
# _generate-keys — Dendrite TLS / signing key generator (element-hq/dendrite)
# upstream: https://github.com/element-hq/dendrite
# Flags from cmd/generate-keys/main.go.

_generate-keys() {
    _arguments \
        '-tls-cert=[X509 TLS certificate file to generate]:file:_files -g "*.{crt,pem}"' \
        '-tls-key=[RSA private key file to generate]:file:_files -g "*.{key,pem}"' \
        '-private-key=[Ed25519 private key to generate]:file:_files -g "*.key"' \
        '-tls-authority-cert=[optional CA cert for derived TLS certs]:file:_files' \
        '-tls-authority-key=[optional CA key for derived TLS certs]:file:_files' \
        '-server=[server name to embed in TLS cert]:name:' \
        '-keysize=[TLS RSA key size (default 4096)]:bits:(2048 3072 4096 8192)'
}

_generate-keys "$@"
