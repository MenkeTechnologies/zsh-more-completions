#compdef imglob
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/utilities/fslutils.html
# FSL: expand a list of image basenames to existing image files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-extension[return image with full extension]' \
  '-extensions[return image list with full extensions]' \
  '*:image:_files' && ret=0

return ret
