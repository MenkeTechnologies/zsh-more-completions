#compdef azion
# Documentation: https://github.com/aziontech/azion
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# aziontech/azion-cli — messages/root messages + pkg/cmd/root/root.go (persistent flags)

local curcontext="$curcontext" state line ret=1

local -a root_flags=(
  '(-t)'{-t+,--token=}'[personal token]:token:'
  '(-c)'{-c+,--config=}'[config dir for this invocation]:dir:_files -/'
  '(-d)'{-d,--debug}'[debug logs]'
  '(-s)'{-s,--silent}'[silence logs]'
  '(-l)'{-l+,--log-level=}'[log level]:level:(debug info error)'
  '(-y)'{-y,--yes}'[answer yes to prompts]'
  '--out=[export output path]:file:_files'
  '--format=[JSON payload for --format]:json:'
  '--no-color[disable color]'
  '--timeout=[HTTP timeout seconds]:seconds:'
)

local -a cmds=(
  init logs deploy build dev link unlink completion describe login logout
  create list delete update version whoami purge reset sync rollback
  profiles config clone warmup
)

_arguments -s -S \
  $root_flags \
  '(-h)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    _describe -t commands 'azion command' $cmds && ret=0
    ;;
  (rest)
    _arguments -s -S $root_flags '*:subcommand args:_default' && ret=0
    ;;
esac

return ret
