#compdef sixpack
# Documentation: https://man.archlinux.org/search?q=sixpack
# Reference accessed: 2026-05-16

# EMBOSS sixpack: translate a nucleotide sequence in all six reading
# frames (3 forward, 3 reverse) with ORF detection and pretty output.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s)]:DNA USA:_files' \
  '-table=[genetic code (NCBI table)]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '-firstorf[treat first codon as start of ORF (no requirement for M)]' \
  '-lastorf[treat last codon as end of ORF (no requirement for stop)]' \
  '-mstart[require M start codon for ORFs]' \
  '-reverse[also display reverse-strand frame translations]' \
  '-orfminsize=[minimum ORF length to report]:length:' \
  '-uppercase=[uppercase regions as "start-end[,start-end]"]:regions:' \
  '-highlight=[highlight regions as "start-end[,start-end]"]:regions:' \
  '-number[print residue position numbers]' \
  '-width=[characters per line of output]:cols:' \
  '-length=[print sequence length]:cols:' \
  '-margin=[output margin width]:cols:' \
  '-name[print sequence name in output]' \
  '-description[print sequence description in output]' \
  '-offset=[start numbering from N]:offset:' \
  '-html[output HTML formatted result]' \
  '-outseq=[output sequence file (translated)]:file:_files' \
  '-outfile=[report output file]:file:_files' \
  '*:DNA USA:_files' && ret=0

return ret
