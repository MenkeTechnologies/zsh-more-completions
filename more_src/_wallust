#compdef wallust
# Documentation: https://man.archlinux.org/search?q=wallust
# Reference accessed: 2026-05-16

# Zsh completion for wallust (codeberg.org/explosion-mental/wallust). Globals from src/args/mod.rs.

local -a sub
sub=(
  'run:generate palette from an image'
  'cs:apply colorscheme from disk'
  'migrate:migrate old config to v4'
  'cache:cache maintenance'
  'debug:print environment info'
  'pywal:pywal compatibility mode'
  'pick:rank themes for an image'
  'theme:apply built-in theme'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress status output]' \
  '(-I --ignore-sequence)'{-I,--ignore-sequence=}'[skip terminal color indices]:indices:' \
  '(--skip-sequences)'--skip-sequences'[skip setting terminal sequences]' \
  '(-T --skip-templates)'{-T,--skip-templates}'[skip template rendering]' \
  '(--update-current)'--update-current'[only update active TTY]' \
  '(-C --config-file)'{-C,--config-file=}'[wallust.toml path]:file:_files' \
  '(-d --config-dir)'{-d,--config-dir=}'[config directory]:dir:_directories' \
  '--templates-dir=[template directory]:dir:_directories' \
  '(-N --no-config)'{-N,--no-config}'[ignore config files]' \
  '--no-hooks[disable hook scripts]' \
  '--no-templated-hooks[disable templated hooks]' \
  '1: :{_describe '\''wallust command'\'' sub}' \
  '*::arguments:_default'
