#compdef sleek

local -a arguments

arguments=(
  '(-i --indent)'{-i,--indent}'=[indentation type]:type:(tab spaces)'
  '(-n --indent-spaces)'{-n,--indent-spaces}'=[number of spaces for indent]:spaces:'
  '(-U --uppercase)'{-U,--uppercase}'[uppercase keywords]'
  '(-L --lowercase)'{-L,--lowercase}'[lowercase keywords]'
  '(-t --trailing-comma)'{-t,--trailing-comma}'[add trailing commas]'
  '--check[check formatting without changes]'
  '(-h --help)'{-h,--help}'[show help]'
  '(-v --version)'{-v,--version}'[show version]'
  '*:SQL file:_files -g "*.sql"'
)

_arguments -s -S $arguments
