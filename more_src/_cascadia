#compdef cascadia

# suntong/cascadia v1.5.0 — go-css wrapper; Homebrew: Formula/c/cascadia.rb

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[help]' \
  '(-i)'{-i+,--in=}'[html/xml input file or stdin marker]:file:_files' \
  '(-o)'{-o+,--out=}'[output file or stdout]:file:_files' \
  '(-c)'{-c+,--css=}'[CSS selectors]:selector:' \
  '(-t)'{-t,--text}'[text output for non-block selection]' \
  '(-R)'{-R,--Raw}'[raw text, no trim]' \
  '(-p)'{-p+,--piece=}'[sub-selectors within --css]:piece spec:' \
  '(-d)'{-d+,--delimiter=}'[delimiter for piece CSV]:delimiter:' \
  '(-w)'{-w,--wrap-html}'[wrap with html shell]' \
  '(-y)'{-y+,--style=}'[CSS for wrapped document head]:style:' \
  '(-b)'{-b+,--base=}'[base href in wrapped html]:url:' \
  '(-q)'{-q,--quiet}'[quiet]' && ret=0
return ret
