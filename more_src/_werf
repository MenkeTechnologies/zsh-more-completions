#compdef werf

_werf_commands() {
    local -a commands
    commands=(
        'converge:Build and push images, then deploy application'
        'plan:Plan converge'
        'dismiss:Delete application from Kubernetes'
        'bundle:Work with bundles'
        'build:Build images'
        'export:Export images'
        'run:Run specified image command in a container'
        'kube-run:Run container in Kubernetes'
        'compose:Work with docker-compose'
        'slugify:Print slugified string'
        'render:Render Helm chart templates'
        'lint:Lint the Helm chart'
        'cleanup:Safely clean up unused images'
        'purge:Purge project images from container registry'
        'cr:Interact with container registries'
        'helm:Manage Helm charts and releases'
        'config:Work with werf configuration'
        'managed-images:Manage managed images'
        'host:Work with the host system'
        'kubectl:Run kubectl'
        'version:Print version'
        'completion:Generate shell completion'
    )
    _describe -t commands 'werf command' commands
}

_werf() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '--dir[Use custom working directory]:dir:_directories' \
        '--tmp-dir[Use custom tmp directory]:dir:_directories' \
        '--home-dir[Use custom home directory]:dir:_directories' \
        '--config[Use custom configuration file]:file:_files' \
        '--config-templates-dir[Custom configuration templates directory]:dir:_directories' \
        '--env[Use specified environment]:env:' \
        '--dev[Enable developer mode]' \
        '--log-color-mode[Set log color mode]:mode:(auto on off)' \
        '--log-debug[Enable debug log]' \
        '--log-pretty[Enable pretty logging]' \
        '--log-quiet[Disable informational output]' \
        '--log-terminal-width[Set log terminal width]:width:' \
        '--log-verbose[Enable verbose log]' \
        '--loose-giterminism[Loose giterminism restrictions]' \
        '1:command:_werf_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                converge)
                    _arguments \
                        '--repo[Container registry repo]:repo:' \
                        '--namespace[Kubernetes namespace]:namespace:' \
                        '--release[Helm release name]:release:' \
                        '--set[Set Helm values]:values:' \
                        '--values[Helm values files]:file:_files' \
                        '--secret-values[Secret values files]:file:_files' \
                        '--timeout[Timeout in seconds]:timeout:' \
                        '--auto-rollback[Auto rollback on failure]' \
                        '--atomic[Atomic deploy]' \
                        '--kube-config[Kubernetes config file]:file:_files' \
                        '--kube-context[Kubernetes context]:context:'
                    ;;
                build)
                    _arguments \
                        '--repo[Container registry repo]:repo:' \
                        '--introspect-before-error[Introspect image before error]' \
                        '--introspect-error[Introspect image on error]' \
                        '--platform[Target platform]:platform:' \
                        '--parallel[Build images in parallel]' \
                        '--report-path[Report file path]:file:_files' \
                        '--report-format[Report format]:format:(json envfile)'
                    ;;
                cleanup)
                    _arguments \
                        '--repo[Container registry repo]:repo:' \
                        '--dry-run[Only show what would be cleaned up]' \
                        '--scan-context-namespace-only[Only scan current namespace]' \
                        '--kube-config[Kubernetes config file]:file:_files' \
                        '--kube-context[Kubernetes context]:context:'
                    ;;
                dismiss)
                    _arguments \
                        '--namespace[Kubernetes namespace]:namespace:' \
                        '--release[Helm release name]:release:' \
                        '--with-hooks[Delete Helm hooks]' \
                        '--with-namespace[Delete namespace]'
                    ;;
                render|lint)
                    _arguments \
                        '--repo[Container registry repo]:repo:' \
                        '--namespace[Kubernetes namespace]:namespace:' \
                        '--release[Helm release name]:release:' \
                        '--set[Set Helm values]:values:' \
                        '--values[Helm values files]:file:_files'
                    ;;
                bundle)
                    _arguments \
                        '1:action:(publish apply render)' \
                        '--repo[Container registry repo]:repo:' \
                        '--tag[Bundle tag]:tag:'
                    ;;
                helm)
                    _arguments \
                        '1:action:(get-release get-namespace create-secret-key secret generate-secret-key encrypt decrypt)' \
                        '--namespace[Kubernetes namespace]:namespace:'
                    ;;
                completion)
                    _arguments \
                        '1:shell:(bash zsh fish powershell)'
                    ;;
                cr)
                    _arguments \
                        '1:action:(login logout)' \
                        '--repo[Container registry repo]:repo:'
                    ;;
            esac
            ;;
    esac
}

_werf "$@"
