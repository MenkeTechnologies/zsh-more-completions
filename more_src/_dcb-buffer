#compdef dcb-buffer
# Documentation: https://man.archlinux.org/man/dcb-buffer.8.en
# dcb buffer - manage port buffer configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'dcb buffer command' \
      'show[display buffer configuration]' 'set[modify buffer settings]' \
      'dev[network device]' 'prio-buffer[priority to buffer mapping]' \
      'buffer-size[buffer sizes in bytes]' 'total-size[total port buffer memory]' && ret=0
    ;;
esac

return ret
