#compdef pageant

_arguments -s \
  '-X[lifetime tied to X display]' \
  '-T[lifetime tied to controlling terminal]' \
  '--exec+[run cmd as subprocess]:cmd:' \
  '--permanent[run permanently]' \
  '--debug[foreground; log to stdout]' \
  '*-a+[add private key]:file:_files' \
  '-l[list fingerprints]' \
  '--public+[print public key (RFC 4716)]:keyid:' \
  '(-L --public-openssh)'{-L,--public-openssh=}'[print OpenSSH public key]:keyid:' \
  '*-d+[delete key]:keyid:' \
  '-D[delete all keys]' \
  '*-r+[re-encrypt key]:keyid:' \
  '-R[re-encrypt all keys]' \
  '--test-sign+[sign stdin]:keyid:' \
  '--test-sign-with-flags=+[sign with flags]:flags keyid:' \
  '--askpass+[act as ssh-askpass]:prompt:' \
  '-v[verbose]' \
  '-s[POSIX shell output]' \
  '-c[C shell output]' \
  '--symlink+[symlink agent socket]:path:_files' \
  '--encrypted[keep keys encrypted]' \
  '--no-decrypt[do not decrypt keys]' \
  '(-E --fptype)'{-E,--fptype=}'[fingerprint format]:format:(sha256 md5)' \
  '--gui-prompt[force GUI prompt]' \
  '--tty-prompt[force TTY prompt]' \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:key file:_files'
