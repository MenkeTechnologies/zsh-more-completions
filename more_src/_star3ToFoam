#compdef star3ToFoam
# Converts a STAR-CD (v3) PROSTAR mesh to OpenFOAM format

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-scale+[geometry scaling factor - default is 1]:factor:' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' \
  ':pro-STAR prefix:_files' && ret=0

return ret
