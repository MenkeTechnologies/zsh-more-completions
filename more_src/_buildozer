#compdef buildozer

_buildozer_commands() {
  local -a cmds=(
    'add:Add value to a list attribute'
    'comment:Add a comment to a rule'
    'copy:Copy an attribute from one rule to another'
    'copy_no_overwrite:Copy unless attribute already set'
    'delete:Delete a rule'
    'fix:Fix a file'
    'move:Move a file'
    'new:Create a new rule'
    'new_load:Add a new load statement'
    'print:Print the value of an attribute'
    'print_comment:Print comments on a rule'
    'remove:Remove a value from a list attribute'
    'remove_comment:Remove a comment from a rule'
    'rename:Rename a rule'
    'replace:Replace a value in a list attribute'
    'set:Set the value of an attribute'
    'set_if_absent:Set value only if attribute is not set'
    'substitute:Substitute a regex in an attribute value'
  )
  _describe -t commands 'buildozer command' cmds
}

_buildozer() {
  _arguments \
    '(- *)'{-h,-help}'[Show help message]' \
    '(- *)'{-v,-version}'[Show version]' \
    '-f[Path to a file containing commands]:file:_files' \
    '-k[Keep going on errors]' \
    '-r[Process files recursively]' \
    '-shorten_labels[Shorten labels when possible]' \
    '-stdout[Write changed BUILD to stdout]' \
    '-buildifier[Path to buildifier binary]:path:_files' \
    '-tables[Path to JSON table file]:file:_files -g "*.json"' \
    '-add-tables[Path to additional JSON table file]:file:_files -g "*.json"' \
    '-types[Comma-separated rule types to match]:types:' \
    '-edit-variables[Edit variables instead of rules]' \
    '*:command or target:'
}

_buildozer "$@"
