#compdef buildozer
# Documentation: https://github.com/bazelbuild/buildtools/blob/master/buildozer/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bazelbuild/buildtools buildozer (NOT kivy/buildozer Android packager).

_buildozer_commands() {
  local -a cmds=(
    'add:add value to a list attribute'
    'comment:add a comment to a rule or attribute'
    'copy:copy an attribute from one rule to another'
    'copy_no_overwrite:copy unless attribute already set'
    'delete:delete a rule'
    'dict_add:add key=value pair to a dict attribute'
    'dict_set:set key=value pair in a dict attribute'
    'dict_remove:remove key from a dict attribute'
    'fix:apply automated fixes'
    'format:enforce consistent formatting'
    'move:move attribute between rules'
    'new:create a new rule'
    'new_load:add a new load statement'
    'replace_load:replace a load statement'
    'substitute_load:substitute load contents'
    'print:print the value of an attribute'
    'print_comment:print comments on a rule'
    'remove:remove a value from a list attribute'
    'remove_comment:remove a comment from a rule'
    'rename:rename a rule'
    'replace:replace a value in a list attribute'
    'set:set the value of an attribute'
    'set_if_absent:set value only if attribute is not set'
    'set kind:change rule type'
    'substitute:substitute a regex in an attribute value'
  )
  _describe -t commands 'buildozer command' cmds
}

_buildozer() {
  _arguments \
    '(- *)'{-h,-help}'[show help]' \
    '(- *)'{-v,-version}'[show version]' \
    '-f[read commands from file]:file:_files' \
    '-k[apply all commands even if there are failures]' \
    '-quiet[suppress informational messages]' \
    '-shorten_labels[convert added labels to short form]' \
    '-stdout[write changed BUILD to stdout]' \
    '-buildifier[path to buildifier binary]:path:_files' \
    '-tables[path to JSON table file]:file:_files -g "*.json"' \
    '-add-tables[path to additional JSON table file]:file:_files -g "*.json"' \
    '-types[filter targets by type (comma-separated)]:types:' \
    '-edit-variables[edit variables instead of rules]' \
    '-eol-comments[put new comments on their own line]:bool:(true false)' \
    '*:command or target:'
}

_buildozer "$@"
