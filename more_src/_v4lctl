#compdef v4lctl
# Documentation: https://man.archlinux.org/search?q=v4lctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list capabilities'
  'show:show current state'
  'help:show help'
  'attr:set attribute'
  'setattr:set attribute'
  'setnorm:set norm'
  'setinput:set input'
  'setfreqtab:set frequency table'
  'setchannel:set channel'
  'setstation:set station'
  'setfreq:set frequency'
  'getfreq:get frequency'
  'snap:take snapshot'
  'scan:scan for stations'
  'mute:toggle audio mute'
  'volume:set volume'
  'color:set color'
  'hue:set hue'
  'bright:set brightness'
  'contrast:set contrast'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-c+[video device]:device:_files -g "/dev/video*"' \
  '-d+[video device]:device:_files -g "/dev/video*"' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'v4lctl command' commands && ret=0 ;;
esac

return ret
