#compdef trivy2
# _trivy2 — Aqua Security AquaSecurity trivy2 CLI command-line frontend wrapping the Trivy comprehensive and versatile security scanner open-source written in Go capable of scanning container images filesystems Git repositories Virtual machine images Kubernetes AWS cloud security accounts for vulnerabilities misconfigurations secrets sensitive data licenses SBOM-software-bill-of-materials k8s rootfs sbom config repo image VM convert plugin clean module server module-add module-uninstall scan-update SARIF JSON template (Aqua Security AquaSecurity team Teppei Fukuda Knqyf263, Go); cobra
# upstream: https://trivy.dev/

_trivy2() {
    local -a sub=(
        'image:scan container image'
        'filesystem:scan filesystem'
        'fs:scan filesystem'
        'rootfs:scan rootfs'
        'repository:scan a repo'
        'repo:scan a repo'
        'config:scan IaC config'
        'sbom:scan SBOM'
        'k8s:scan Kubernetes'
        'kubernetes:scan Kubernetes'
        'vm:scan VM image'
        'aws:scan AWS account'
        'convert:convert report'
        'clean:clean cache'
        'server:run as server'
        'module:module operations'
        'plugin:plugin operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '-c+[config file]:file:_files -g "trivy.yaml *.yaml *.yml"' \
        '--config=+[file]:file:_files -g "trivy.yaml *.yaml *.yml"' \
        '-d[show all errors]' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--cache-backend=+[b]:b:(fs redis)' \
        '--cache-ttl=+[d]:str:' \
        '--redis-cache-ttl=+[d]:str:' \
        '--redis-key=+[key]:str:' \
        '--db-repository=+[url]:str:' \
        '--java-db-repository=+[url]:str:' \
        '--policy-bundle-repository=+[url]:str:' \
        '--no-progress[no progress]' \
        '--server=+[url]:str:' \
        '--token=+[token]:str:' \
        '--token-header=+[name]:str:' \
        '--custom-headers=+[k=v]:str:' \
        '--insecure[skip TLS verify]' \
        '--registry-token=+[token]:str:' \
        '--username=+[user]:_users' \
        '--password=+[password]:str:' \
        '--password-stdin[read password from stdin]' \
        '--platform=+[os/arch]:str:' \
        '--no-color[no color]' \
        '--quiet-progress[quiet progress]' \
        '-f+[format]:f:(table json template sarif cyclonedx spdx spdx-json github cosign-vuln)' \
        '--format=+[fmt]:f:(table json template sarif cyclonedx spdx spdx-json github cosign-vuln)' \
        '-o+[output]:file:_files' \
        '--output=+[file]:file:_files' \
        '--output-plugin-arg=+[args]:str:' \
        '-t+[template]:str:' \
        '--template=+[t]:str:' \
        '-s+[severity]:s:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '*-s+[severity]:s:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '--severity=+[s]:s:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '--exit-code=+[code]:n:' \
        '--exit-on-eol=+[code]:n:' \
        '--scanners=+[s]:s:(vuln misconfig secret license)' \
        '*--scanners=+[s]:s:(vuln misconfig secret license)' \
        '--vuln-type=+[t]:t:(os library)' \
        '--ignore-unfixed[ignore unfixed]' \
        '--ignore-policy=+[file]:file:_files' \
        '--ignorefile=+[file]:file:_files -g ".trivyignore"' \
        '--list-all-pkgs[list all packages]' \
        '--report=+[r]:r:(all summary)' \
        '--show-suppressed[show suppressed]' \
        '--skip-update[skip update DB]' \
        '--download-db-only[download DB only]' \
        '--skip-files=+[files]:str:' \
        '--skip-dirs=+[dirs]:str:' \
        '--detection-priority=+[p]:p:(precise comprehensive)' \
        '--enable-modules=+[mods]:str:' \
        '--module-dir=+[dir]:dir:_files -/' \
        '--include-non-failures[include non-failures]' \
        '--include-deprecated-checks[include deprecated]' \
        '--check-namespaces=+[ns]:str:' \
        '--policy=+[paths]:str:' \
        '--data=+[paths]:str:' \
        '*--data=+[path]:str:' \
        '--secret-config=+[file]:file:_files -g "trivy-secret.yaml *.yaml"' \
        '--license-full[license full]' \
        '--license-confidence-level=+[N]:str:' \
        '--ignored-licenses=+[licenses]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'trivy subcommand' sub ;;
        args)
            case $words[1] in
                image) _arguments '*:image:' ;;
                filesystem|fs|rootfs|repository|repo|config|sbom|vm|convert) _arguments '*:path:_files' ;;
                k8s|kubernetes) _arguments '*:resource:' ;;
                aws) _arguments '*:arn:' ;;
                module) _arguments '1:op:(install uninstall)' '*:name:' ;;
                plugin) _arguments '1:op:(install uninstall list run update upgrade info search)' '*:name:' ;;
            esac
            ;;
    esac
}

_trivy2 "$@"
