#compdef prisma

# Zsh completion for prisma (Prisma ORM CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Set up Prisma for your app'
      'generate:Generate artifacts (e.g. Prisma Client)'
      'db:Manage your database schema and lifecycle'
      'migrate:Migrate your database'
      'studio:Browse your data with Prisma Studio'
      'validate:Validate your Prisma schema'
      'format:Format your Prisma schema'
      'version:Print current version of Prisma components'
      'debug:Display debug information'
    )
    _describe -t commands 'prisma command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '--datasource-provider=[Define the datasource provider]:provider:(postgresql mysql sqlite sqlserver mongodb cockroachdb)' \
          '--generator-provider=[Define the generator provider]:provider' \
          '--preview-feature=[Define a preview feature]:feature' \
          '--output=[Define the output directory]:dir:_directories' \
          '--url=[Define a custom datasource url]:url' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '--schema=[Custom path to your Prisma schema]:file:_files' \
          '--data-proxy[Generate for Prisma Data Proxy]' \
          '--accelerate[Generate for Prisma Accelerate]' \
          '--no-engine[Generate without a query engine]' \
          '--no-hints[Hides the update hints]' \
          '--watch[Watch the Prisma schema and rerun after a change]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      db)
        local -a subcmds=(
          'pull:Pull the schema from an existing database'
          'push:Push the Prisma schema state to the database'
          'seed:Seed your database'
          'execute:Execute native SQL commands against your database'
        )
        _describe -t subcmds 'db subcommand' subcmds && ret=0
        ;;
      migrate)
        local -a subcmds=(
          'dev:Create a migration from schema changes, apply it, and generate artifacts'
          'deploy:Apply pending migrations to the database in production/staging'
          'reset:Reset your database and apply all migrations'
          'resolve:Resolve issues with database migrations in deployment databases'
          'status:Check the status of migrations in the production/staging database'
          'diff:Compare database schemas and generate SQL migration'
        )
        _describe -t subcmds 'migrate subcommand' subcmds && ret=0
        ;;
      studio)
        _arguments -s -S \
          '--schema=[Custom path to your Prisma schema]:file:_files' \
          '-p+[Port to start Studio on]:port' \
          '--port=[Port to start Studio on]:port' \
          '-b+[Browser to open Studio in]:browser' \
          '--browser=[Browser to open Studio in]:browser' \
          '-n[Do not open a browser window]' \
          '--hostname=[Hostname to bind the Express server to]:hostname' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '--schema=[Custom path to your Prisma schema]:file:_files' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      format)
        _arguments -s -S \
          '--schema=[Custom path to your Prisma schema]:file:_files' \
          '--check[Check if schema is formatted without writing changes]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
