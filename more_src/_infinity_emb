#compdef infinity_emb
# Documentation: https://michaelfeil.eu/infinity/latest/cli_v2/
# Infinity embedding/reranking inference server CLI

local ret=1
local -a state line
local curcontext="$curcontext"

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'v2:start the infinity embedding server'
      'v1:start the legacy v1 server'
      'help:show help'
    )
    _describe -t commands 'infinity_emb command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      v2|v1)
        _arguments -s -S \
          '*--model-id=[HuggingFace model repo id]:model id:' \
          '*--served-model-name=[nickname for the model in the API]:name:' \
          '*--revision=[HuggingFace model repo revision]:revision:' \
          '--trust-remote-code=[trust remote modeling code]:bool:(true false)' \
          '*--batch-size=[max batch size for inference]:size:' \
          '*--engine=[inference backend]:engine:(torch ctranslate2 optimum neuron debugengine)' \
          '*--dtype=[dtype for the model weights]:dtype:(auto float32 float16 bfloat16 int8 fp8)' \
          '*--embedding-dtype=[output dtype with optional quantization]:dtype:(float32 int8 uint8 binary ubinary)' \
          '*--device=[computing device]:device:(cpu cuda mps tensorrt auto)' \
          '*--device-id=[device placement specification]:id:' \
          '*--compile=[enable torch.compile]:bool:(true false)' \
          '*--bettertransformer=[enable flash-attention via BetterTransformer]:bool:(true false)' \
          '*--pooling-method=[override pooling method]:method:(mean cls auto)' \
          '--host=[server host]:host:' \
          '--port=[server port]:port:' \
          '--url-prefix=[route prefix for proxy setups]:prefix:' \
          '--log-level=[console logging level]:level:(critical error warning info debug trace)' \
          '--api-key=[authentication header credential]:key:' \
          '*--model-warmup=[warm up model after startup]:bool:(true false)' \
          '*--vector-disk-cache=[enable SQLite vector caching]:bool:(true false)' \
          '*--lengths-via-tokenize=[use tokenizer counts vs input length]:bool:(true false)' \
          '--preload-only=[download models then exit]:bool:(true false)' \
          '--permissive-cors=[allow permissive CORS]:bool:(true false)' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
