#compdef chkproc
# Documentation: https://github.com/Magentron/chkrootkit/blob/master/chkproc.c
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above (chkrootkit chkproc.c argv parsing).

# chkproc - check for hidden /proc entries (LKM trojan detection helper used by chkrootkit)
local curcontext="$curcontext" state line ret=1

_arguments -s \
  '*-v[verbose (repeat for more verbosity)]' \
  '-p+[procps version (0-3)]:version:(0 1 2 3)' \
  '-\?[show usage]' && ret=0

return ret
