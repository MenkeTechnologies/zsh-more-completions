#compdef rsnapshot

# Zsh completion for rsnapshot - filesystem snapshot utility

_arguments \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-t --test)'{-t,--test}'[show what would be done (dry run)]' \
  '(-c --configtest)'{-c,--configtest}'[verify config file and exit]' \
  '(-D --debug)'{-D,--debug}'[maximum verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '-V[same as --verbose]' \
  '1:action:(configtest hourly daily weekly monthly alpha beta gamma delta sync diff)'
