#compdef obsutil
# Documentation: https://support.huaweicloud.com/intl/en-us/utiltg-obs/obs_11_0001.html
# obsutil - Huawei Cloud OBS (Object Storage Service) command line tool

local ret=1

_arguments -C -s \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '1:command:(config ls mb rm cp sync mv abort restore cat chattri mkdir sign hash archive clear stat du share-cp share-crt share-ls version)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $line[1] in
      cp|sync|mv)
        _arguments -s \
          '-r[recursively operate on all objects]' \
          '-f[force operation without interactive confirmation]' \
          '-u[only copy objects whose source is newer than destination]' \
          '-flat[do not create root folder in destination]' \
          '-crr[client-side cross-region replication]' \
          '-vlength[verify object length after transfer]' \
          '-vmd5[verify object md5 after transfer]' \
          '-j[maximum number of concurrent jobs]:jobs' \
          '-p[maximum number of concurrent tasks for multipart]:tasks' \
          '-threshold[threshold to enable multipart upload]:bytes' \
          '-acl[access control policy]:acl' \
          '-sc[storage class]:class' \
          '-meta[customized metadata]:meta' \
          '-ps[part size for multipart]:bytes' \
          '-include[include objects matching pattern]:pattern' \
          '-exclude[exclude objects matching pattern]:pattern' \
          '-timeRange[transfer objects within time range]:range' \
          '-dryRun[conduct a dry run]' \
          '-o[output result file directory]:dir:_files -/' \
          '-config[user-defined config file]:config:_files' \
          '-e[endpoint]:endpoint' \
          '-i[access key id]:ak' \
          '-k[secret access key]:sk' \
          '-t[security token]:token' \
          '*:file:_files' && ret=0
        ;;
      rm)
        _arguments -s \
          '-r[recursively delete]' \
          '-f[force delete without confirmation]' \
          '-j[maximum number of concurrent jobs]:jobs' \
          '-o[output result file directory]:dir:_files -/' \
          '-config[user-defined config file]:config:_files' \
          '*:object:_files' && ret=0
        ;;
      config)
        _arguments -s \
          '-interactive[interactive configuration]' \
          '-e[endpoint]:endpoint' \
          '-i[access key id]:ak' \
          '-k[secret access key]:sk' \
          '-t[security token]:token' \
          '-config[user-defined config file]:config:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
