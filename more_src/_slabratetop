#compdef slabratetop slabratetop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/slabratetop.py argparse)
# Reference accessed: 2026-05-29
# slabratetop — top-like display of kernel SLAB/SLUB allocation rate per cache (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-C --noclear)'{-C,--noclear}'[do not clear the screen]' \
  '(-r --maxrows)'{-r,--maxrows=}'[maximum rows to print (default 20)]:N:' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:interval (seconds, default 1):' \
  '2:count (number of outputs, default unlimited):' \
  && ret=0

return ret
