#compdef safecopy
# _safecopy-bin — Safecopy data recovery (Corkscrew); resilient bulk-copy with low-level retry for unreliable media
# upstream: https://github.com/Cyclic3/safecopy

_safecopy-bin() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f[fast mode]' \
        '-F[no fast mode]' \
        '-b[badblocks output]' \
        '-i+[chunk size]:bytes:' \
        '-s+[start offset]:bytes:' \
        '-l+[length]:bytes:' \
        '-R+[hard reset script]:cmd:' \
        '-r+[soft reset script]:cmd:' \
        '-X+[expert option]:flag:' \
        '-Z+[badblocks output file]:file:_files' \
        '-S+[skip bytes after error]:bytes:' \
        '-T+[stage]:n:' \
        '-c+[total retries]:n:' \
        '-q[quiet]' \
        '-V[verbose]' \
        '1:source:_files' \
        '2:dest:_files'
}

_safecopy-bin "$@"
