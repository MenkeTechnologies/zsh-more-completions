#compdef hgLoadGap
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: load gap table from an AGP-style file containing only gaps

local ret=1

_arguments -s -S \
  '-chrom=[just do a single chromosome, do not delete old tables]:chr' \
  '-unsplit[expect dir to be a .gap file and make an unsplit gap table]' \
  '-noLoad[do not load the database table (for testing)]' \
  '1:database:' \
  '2:dir or gap file:_files' && ret=0

return ret
