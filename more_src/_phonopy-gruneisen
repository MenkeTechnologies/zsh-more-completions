#compdef phonopy-gruneisen
# Documentation: https://phonopy.github.io/phonopy/gruneisen.html
# Mode Gruneisen parameter analysis from phonopy results

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--band=[band paths in reduced coordinates]:band' \
  '--band_points=[number of sampling points in a band path segment]:points' \
  '(-c --cell)'{-c,--cell}'=[read unit cell]:file:_files' \
  '--color=[color scheme]:scheme' \
  '--cutoff=[plot above this cutoff frequency for mesh sampling]:cutoff' \
  '--dim=[same behavior as DIM tag]:dim' \
  '--factor=[conversion factor to favorite frequency unit]:factor' \
  '--hdf5[use hdf5 to read force constants and store results]' \
  '(--gc --gamma_center)'{--gc,--gamma_center}'[set mesh as Gamma center]' \
  '--marker=[marker for plot]:marker' \
  '--markersize=[markersize for plot in points]:size' \
  '--mass=[same as MASS tag]:mass' \
  '(--mp --mesh)'{--mp,--mesh}'=[sampling mesh]:mesh' \
  '--nac[non-analytical term correction]' \
  '--nomeshsym[symmetry not imposed for mesh sampling]' \
  '(-o --output)'{-o,--output}'=[output filename of PDF plot]:file:_files' \
  '(-p --plot)'{-p,--plot}'[plot data]' \
  '(--pa --primitive-axis --primitive-axes)'{--pa,--primitive-axis,--primitive-axes}'=[same as PRIMITIVE_AXES tag]:axes' \
  '--q_cutoff=[treat acoustic modes inside cutoff wave vector]:qcutoff' \
  '--readfc[read FORCE_CONSTANTS]' \
  '(-s --save)'{-s,--save}'[save plot data in pdf]' \
  '--delta-strain=[delta strain instead of delta-V/V]:strain' \
  '(-t --title)'{-t,--title}'=[title of plot]:title' \
  '--tmax=[maximum calculated temperature]:tmax' \
  '--tmin=[minimum calculated temperature]:tmin' \
  '--tolerance=[symmetry tolerance to search]:tol' \
  '--tstep=[calculated temperature step]:tstep' \
  '*:dir:_files -/' && ret=0

return ret
