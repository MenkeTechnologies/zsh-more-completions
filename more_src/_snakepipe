#compdef snakepipe
# Documentation: https://github.com/topheman/snake-pipe-rust
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_snake_sub() {
  local -a c=(
    gamestate render throttle 'render-browser' 'stream-sse' 'socket-play' 'socket-watch' 'tcp-play' 'tcp-watch' pipeline 'generate-completions'
  )
  _describe -t commands 'snakepipe command' c
}

_arguments -C \
  '1: :_snake_sub' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      gamestate)
        _arguments -s -S \
          '--frame-duration=[tick duration ms]:ms:' \
          '--width=[board width]:w:' \
          '--height=[board height]:h:' \
          '--snake-length=[starting snake length]:n:' \
          '--fit-terminal[resize board to terminal]' && ret=0
        ;;
      throttle)
        _arguments -s -S \
          '--frame-duration=[throttle interval ms]:ms:' \
          '--loop-infinite[loop stdin when EOF]' && ret=0
        ;;
      render-browser)
        _arguments -s -S '--port=[HTTP server port]:port:' && ret=0
        ;;
      stream-sse)
        _arguments -s -S '--address=[render-browser SSE URL]:url:' && ret=0
        ;;
      socket-play|socket-watch)
        _arguments -s -S '--path=[unix socket path]:path:_files' && ret=0
        ;;
      tcp-play|tcp-watch)
        _arguments -s -S '--port=[tcp port]:port:' '--host=[bind host]:host:' && ret=0
        ;;
      pipeline)
        _arguments -s -S '--list[list bundled pipelines]' '*::pipeline_sub:_default' && ret=0
        ;;
      generate-completions)
        _arguments -s -S '--shell=[target shell]:shell:(bash fish zsh)' && ret=0
        ;;
      render) _message -e 'reads gamestate JSON from stdin' && ret=0 ;;
    esac
    ;;
esac
return ret
