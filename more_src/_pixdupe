#compdef pixdupe
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss157.html
# KAPPA: expands an NDF by pixel duplication

local ret=1

_arguments -s \
  'IN=[input NDF to be expanded]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'EXPAND=[linear expansion factors per axis]:factors' \
  'MASK=[NDF holding a duplication mask]:ndf:_files -g "*.sdf"' \
  'IMASK=[indices of mask elements set to 1]:indices' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
