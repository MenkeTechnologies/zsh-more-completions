#compdef vscode-json-language-server vscode-json-languageserver
# Documentation: https://man.archlinux.org/search?q=vscode-json-language-server
# Reference accessed: 2026-05-16

# Zsh completion for vscode-json-language-server (JSON Language Server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--stdio[use stdio transport]' \
  '--node-ipc[use node IPC transport]' \
  '--socket=[use socket transport on port]:port:' && ret=0

return ret
