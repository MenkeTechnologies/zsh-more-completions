#compdef megamgr
# Documentation: https://man.archlinux.org/search?q=megamgr
# Reference accessed: 2026-05-16

# megamgr: legacy LSI MegaRAID manager (text/curses tool)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-A[adapter number]:n:' \
  '*::megamgr args:_files' && ret=0
return ret
