#compdef gpcopy
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/gpcopy.html
# MIRIAD gpcopy - copy calibration tables between datasets

local ret=1

_arguments -s -S \
  'vis=[input dataset with calibration corrections]:vis:_files' \
  'out=[output dataset for calibration tables]:out:_files' \
  'mode=[create/copy/apply/merge]:mode:(create copy apply merge)' \
  'options=[nopol,nocal,nopass,relax]:options' \
  '*:dataset:_files' && ret=0

return ret
