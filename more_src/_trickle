#compdef trickle
# Documentation: https://manpages.debian.org/bookworm/trickle/trickle.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for trickle - lightweight userspace bandwidth shaper
# trickle only supports short flags; no long forms exist.

_arguments -s -S \
  '-d[set maximum download bandwidth (KB/s)]:download limit (KB/s)' \
  '-u[set maximum upload bandwidth (KB/s)]:upload limit (KB/s)' \
  '-w[set peak detection window size (KB)]:window size (KB)' \
  '-t[set smoothing time (seconds)]:seconds' \
  '-l[set smoothing length (KB)]:length (KB)' \
  '-n[path to trickled socket (default /tmp/.trickled.sock)]:socket path:_files' \
  '-P[alternative .so library file]:library path:_files' \
  '-s[run in standalone mode without trickled]' \
  '*-v[increase verbosity level]' \
  '(- *)-V[show version]' \
  '(- *)-h[show help]' \
  '*::command:_normal'
