#compdef trickle

# Zsh completion for trickle - lightweight userspace bandwidth shaper

_arguments -s -S \
  '-d[set maximum download bandwidth (KB/s)]:rate (KB/s):' \
  '-u[set maximum upload bandwidth (KB/s)]:rate (KB/s):' \
  '-w[peak detection window size]:size:' \
  '-t[smoothing time (seconds)]:seconds:' \
  '-l[smoothing length (KB)]:length (KB):' \
  '-n[path to trickled socket]:socket:_files' \
  '-s[standalone mode, do not use trickled]' \
  '-v[increase verbosity]' \
  '(- *)-V[show version]' \
  '(- *)-h[show help]' \
  '(-):command:_command_names -e' \
  '*::arguments:_normal'
