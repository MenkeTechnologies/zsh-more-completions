#compdef wiki-tui
# Documentation: https://man.archlinux.org/search?q=wiki-tui
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-l+[set language]:language' \
  '--language=[set language]:language' \
  '-s+[search for a specific article]:query' \
  '--search=[search for a specific article]:query' \
  '-a+[open a specific article]:article' \
  '--article=[open a specific article]:article' \
  '--log[enable logging]' \
  '--level=[set log level]:level:(trace debug info warn error)' && ret=0

return ret
