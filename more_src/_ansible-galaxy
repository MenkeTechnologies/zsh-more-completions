#compdef ansible-galaxy
# _ansible-galaxy — Ansible galaxy CLI (manage roles + collections from Ansible Galaxy / Automation Hub / git URLs; subcommands: collection {install|build|publish|init|verify|download|list}, role {install|build|init|list|remove|search|info|import|delete|setup})
# upstream: https://github.com/ansible/ansible (lib/ansible/cli/galaxy.py)
# Subcommands from ansible cli/galaxy.py on tip.

_ansible-galaxy() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--version[show version]' \
        '-h[show help]' \
        '*-v[verbose]' \
        '1: :->kind' \
        '2: :->cmd' \
        '*::arg:->args'
    case $state in
        kind) _describe -t commands 'galaxy kind' '(collection role)' ;;
        cmd)
            case $line[1] in
                collection) _describe -t commands 'collection subcommand' '(init build install publish list verify download cache)' ;;
                role) _describe -t commands 'role subcommand' '(init build install list info search remove import delete setup)' ;;
            esac
            ;;
        args)
            _arguments \
                '-p+[install path]:dir:_files -/' \
                '-r+[requirements file]:file:_files -g "*.(yml|yaml)"' \
                '--force[force overwrite]' \
                '--no-deps[skip deps]' \
                '-s+[server URL]:url:' \
                '--api-key+[Galaxy API key]:key:' \
                '*:name:'
            ;;
    esac
}

_ansible-galaxy "$@"
