#compdef rnaduplex

# ViennaRNA RNAduplex: predict hybrid duplex between two RNAs (no intramolecular)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-T --temp)'{-T,--temp=}'[temperature in C]:temp:' \
  '(-e --energyCutoff)'{-e,--energyCutoff=}'[suboptimal energy range]:val:' \
  '(-s --sorted)'{-s,--sorted}'[sort suboptimals by energy]' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '--noLP[no lonely pairs]' \
  '--noGU[no GU pairs]' \
  '--noClosingGU[no GU at helix ends]' \
  '--paramFile=[parameter file]:file:_files' \
  '*:two RNA sequence files:_files -g "*.(fa|fasta|seq)"' && ret=0
return ret
