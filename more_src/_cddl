#compdef cddl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'validate:validate data against a CDDL spec'
  'generate:generate random data from a CDDL spec'
)

_arguments -s -S \
  '1:cddl spec file:_files -g "*.cddl"' \
  '2:command:->command' \
  '*::args:->args' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'cddl command' commands && ret=0
    ;;
  (args)
    case $line[2] in
      (validate)
        _arguments \
          '1:instance file:_files -g "*.{cbor,json}"' \
          && ret=0
        ;;
      (generate)
        _arguments \
          '1:number of instances:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
