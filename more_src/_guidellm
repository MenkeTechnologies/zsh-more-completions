#compdef guidellm
# Documentation: https://github.com/vllm-project/guidellm/blob/main/docs/getting-started/benchmark.md
# GuideLLM LLM deployment benchmarking and evaluation CLI

local ret=1
local -a state line
local curcontext="$curcontext"

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'benchmark:run a benchmark against an OpenAI-compatible server'
      'preprocess:preprocess datasets for benchmarking'
      'config:show GuideLLM configuration'
    )
    _describe -t commands 'guidellm command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      benchmark)
        _arguments -s -S \
          '--target=[URL of the OpenAI-compatible server]:url:' \
          '--model=[model name to benchmark]:model:' \
          '--data=[data configuration for benchmarking]:data:' \
          '--profile=[type of benchmark profile to run]:profile:(synchronous concurrent throughput constant poisson sweep)' \
          '--rate=[request rate or number of benchmarks for sweep]:rate:' \
          '--random-seed=[random seed for reproducibility]:seed:' \
          '--max-seconds=[duration for each benchmark in seconds]:sec:' \
          '--max-requests=[max number of requests for each benchmark]:num:' \
          '--data-samples=[max number of dataset rows to load]:num:' \
          '--output-dir=[directory to save output files]:dir:_files -/' \
          '*--outputs=[output formats to generate]:format:(console json yaml csv html)' \
          '--rampup=[rate rampup duration]:dur:' \
          '--strategy-type=[strategy type for sweep]:type:' \
          '--backend-kwargs=[backend config parameters JSON]:kwargs:' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
