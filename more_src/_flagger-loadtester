#compdef flagger-loadtester
# _flagger-loadtester — Flagger canary load-test webhook server
# upstream: https://github.com/fluxcd/flagger
# Flags from cmd/loadtester/main.go on tip.

_flagger-loadtester() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[log level]:level:(debug info warning error)' \
        '--port=[port to listen on]:port:' \
        '--timeout=[load test exec timeout]:dur:' \
        '--namespace-regexp=[restrict to canaries in matching namespaces]:regex:' \
        '--zap-replace-globals=[replace global zap logger level]:bool:(true false)' \
        '--zap-encoding=[zap logger encoding]:fmt:(json console)'
}

_flagger-loadtester "$@"
