#compdef cyme

# Zsh completion for cyme (USB device lister, modern lsusb alternative)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-l --lsusb)'{-l,--lsusb}'[lsusb compatible output]' \
  '(-t --tree)'{-t,--tree}'[tree-style output]' \
  '(-d --device)'{-d,--device}'=[show specific device]:vendor\:product' \
  '(-s --show)'{-s,--show}'=[bus and device number]:bus\:devnum' \
  '(-D --device-file)'{-D,--device-file}'=[device file]:device:_files -W /dev' \
  '--json[JSON output]' \
  '--force-libusb[force libusb backend]' \
  '(-b --bus)'{-b,--bus}'=[show only devices on bus]:bus number' \
  '--filter-name=[filter by device name]:name' \
  '--filter-serial=[filter by serial number]:serial' \
  '--filter-class=[filter by device class]:class' \
  '--no-padding[disable padding in output]' \
  '--headings[show column headings]' \
  '--no-headings[hide column headings]' \
  '--color=[color mode]:mode:(auto always never)' \
  '--encoding=[string encoding]:encoding:(utf8 ascii latin1)' \
  '--sort-devices=[sort order for devices]:order:(no bus-number name)' \
  '--sort-buses=[sort order for buses]:order:(no bus-number)' \
  '--group-devices=[grouping]:group:(no bus)' \
  '--from-json=[read from JSON file]:json file:_files -g "*.json"' \
  '--mask-serials[mask serial numbers]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
