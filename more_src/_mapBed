#compdef mapBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/map.html
# apply a function to B features overlapping A (bedtools map)

local ret=1

_arguments -s -S \
  '-a[input file A]:file:_files' \
  '-b[input file B]:file:_files' \
  '-c[column from B to map onto intervals in A]:columns' \
  '-o[operation to apply (sum/count/mean/median...)]:operation' \
  '-f[minimum overlap as fraction of A]:fraction' \
  '-F[minimum overlap as fraction of B]:fraction' \
  '-r[require reciprocal overlap]' \
  '-e[satisfy minimum fraction for A OR B]' \
  '-s[force strandedness (same strand)]' \
  '-S[require opposite strandedness]' \
  '-null[value to print when no overlaps are found]:value' \
  '-split[treat split BAM/BED12 entries as distinct intervals]' \
  '-g[genome file defining chromosome order]:file:_files' \
  '-header[print the header from the A file before results]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
