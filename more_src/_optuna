#compdef optuna

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create-study:initialize a new study'
  'delete-study:remove a study'
  'study:study operations'
  'study-names:list study names'
  'studies:overview of studies'
  'trials:list trials'
  'best-trial:show best trial'
  'best-trials:Pareto-front trials'
  'storage:storage operations'
  'ask:create trial and suggest parameters'
  'tell:finalize a trial'
)

_arguments -C \
  '--storage=[storage URL]:url:' \
  '--storage-class=[storage class hint]:class:' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--log-file=[log file]:file:_files' \
  '--debug[show tracebacks]' \
  '(- *)--version[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'optuna subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create-study)
        _arguments \
          '--study-name=[study name]:name:' \
          '--direction=[optimization direction]:dir:(minimize maximize)' \
          '*--directions=[multi-objective directions]:dirs:' \
          '--skip-if-exists[skip if study exists]' && ret=0
        ;;
      (delete-study)
        _arguments '--study-name=[study name]:name:' && ret=0
        ;;
      (study)
        _values 'study action' 'set-user-attr' && ret=0
        ;;
      (storage)
        _values 'storage action' 'upgrade' && ret=0
        ;;
      (study-names|studies|trials|best-trial|best-trials)
        _arguments \
          '--study-name=[study name]:name:' \
          '(-f --format)'{-f,--format=}'[output format]:fmt:(value json table yaml)' \
          '--flatten[flatten output]' && ret=0
        ;;
      (ask)
        _arguments \
          '--study-name=[study name]:name:' \
          '--sampler=[sampler]:sampler:' \
          '--sampler-kwargs=[sampler kwargs JSON]:json:' \
          '--search-space=[search space JSON]:json:' \
          '(-f --format)'{-f,--format=}'[output format]:fmt:(value json table yaml)' \
          '--flatten[flatten output]' && ret=0
        ;;
      (tell)
        _arguments \
          '--study-name=[study name]:name:' \
          '--trial-number=[trial number]:n:' \
          '*--values=[values]:val:' \
          '--state=[trial state]:state:(complete pruned fail)' \
          '--skip-if-finished[skip if already finished]' && ret=0
        ;;
    esac
    ;;
esac

return ret
