#compdef sdkmanager
# Documentation: https://developer.android.com/tools/sdkmanager
# Source: Android SDK — install / list / update SDK packages.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--sdk_root=[SDK path (overrides tool-relative default)]:path:_directories' \
    '--channel=[channel filter]:channel:(0 1 2 3)' \
    '--include_obsolete[include obsolete packages (with --list or --update)]' \
    '--no_https[force HTTP instead of HTTPS]' \
    '--newer[with --list, show only new or updatable packages]' \
    '--verbose[verbose output]' \
    '--proxy=[proxy type]:proxy:(http socks)' \
    '--proxy_host=[proxy IP/DNS]:host:_hosts' \
    '--proxy_port=[proxy port]:port:' \
    '(--install --uninstall --update --licenses --list)--list[list installed and available packages]' \
    '(--install --uninstall --update --licenses --list)--install[install packages]' \
    '(--install --uninstall --update --licenses --list)--uninstall[uninstall packages]' \
    '(--install --uninstall --update --licenses --list)--update[update all installed packages]' \
    '(--install --uninstall --update --licenses --list)--licenses[accept licenses for installed packages]' \
    '--package_file=[text file with one SDK package path per line]:file:_files' \
    '*:package:' \
    && ret=0

return ret
