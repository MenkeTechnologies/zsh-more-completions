#compdef q2galaxy
# Documentation: https://github.com/qiime2/q2galaxy
# Generate Galaxy tool descriptions automatically from QIIME 2 actions

local ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    template\:generate Galaxy tool descriptions
    run\:internal use by Galaxy tool XML files
    version\:display version information
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      template)
        _arguments -s -S \
          '--distro=[distribution name]:distro:' \
          '--metapackage=[metapackage name]:metapackage:' \
          '1:subcommand:((
            all\:create tools for entire QIIME 2 environment
            builtins\:generate builtin tools only
            plugin\:create tools for a specific plugin
            tests\:generate test tools
            tool_conf\:generate tool_conf XML
          ))' \
          '*:output:_files -/' && ret=0
        ;;
      run)
        _arguments -s -S \
          '1:plugin:' \
          '2:action:' \
          '3:inputs:_files' && ret=0
        ;;
      version)
        _arguments -s -S '1:plugin:' && ret=0
        ;;
    esac
    ;;
esac

return ret
