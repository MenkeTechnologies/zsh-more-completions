#compdef ConvertHeaderlessHadoopBamShardToBam
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/ConvertHeaderlessHadoopBamShardToBam.java
# GATK: convert a headerless Hadoop BAM shard into a readable BAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--bam-shard=[headerless Hadoop BAM shard to convert]:bam:_files -g "*.bam"' \
  '--bam-with-header=[well-formed BAM whose header to use]:bam:_files -g "*.bam"' \
  {-O,--output=}'[location to write the converted BAM shard]:bam:_files -g "*.bam"' \
  '*:argument:_files' && ret=0

return ret
