#compdef nk
# Documentation: https://github.com/nats-io/nkeys/tree/master/nk
# nk - generate, sign and verify NKeys for NATS

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-gen[create an NKey seed of a given type]:type:(User Account Server Cluster Operator)' \
  '-sign[sign the contents of a file (requires -inkey)]:file:_files' \
  '-verify[verify a file against a signature]:file:_files' \
  '-sigfile[signature file used with -verify]:file:_files' \
  '-inkey[input key file for signing or verification]:keyfile:_files' \
  '-pubin[public key input file for verification]:keyfile:_files' \
  '-pubout[output the public key derived from a seed]' \
  '-e[entropy source for key generation]:source:_files' \
  '*:file:_files' && ret=0

return ret
