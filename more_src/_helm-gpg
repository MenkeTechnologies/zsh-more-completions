#compdef helm-gpg
# Documentation: https://github.com/technosophos/helm-gpg
# helm gpg: sign and verify Helm charts with GnuPG

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --local-user)'{-u,--local-user}'=[GPG key identifier to use for signing]:key:' \
  '1:command:(sign verify help)' \
  '*::file:_files' && ret=0

return ret
