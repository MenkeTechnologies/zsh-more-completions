#compdef aureport
# _aureport — Linux audit aureport (report on audit log file events; -au authentication, -av avc, -c crypto, -cr crypto, -cuid, -e events, -f files, -h hosts, -i interpret, -k keys, -l logins, -m mac, -n anomaly, -p process, -r response, -s syscalls, -t time, -tm tty mismatch, -u users, -v version, -w weekly, -x executable, --start time, --end time, -if input file, -nv no verify, --successful, --failed)
# upstream: https://github.com/linux-audit/audit-userspace
# Flags from linux-audit/audit-userspace src/aureport.c on tip.

_aureport() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-au[authentication]' \
        '-av[avc]' \
        '-c[crypto]' \
        '-cr[crypto]' \
        '-cuid[changed uids]' \
        '-e[events]' \
        '-f[files]' \
        '-i[interpret]' \
        '-k[keys]' \
        '-l[logins]' \
        '-m[mac]' \
        '-n[anomaly]' \
        '-p[process]' \
        '-r[response]' \
        '-s[syscalls]' \
        '-t[time]' \
        '-tm[tty mismatch]' \
        '-u[users]' \
        '-w[weekly]' \
        '-x[executable]' \
        '-if+[input file]:file:_files' \
        '-nv[no verify]' \
        '--successful[only successful]' \
        '--failed[only failed]' \
        '--start+[start time]:time:' \
        '--end+[end time]:time:' \
        '--summary[summary]' \
        '--tty[tty]' \
        '--anomaly[anomaly]' \
        '--integrity[integrity]'
}

_aureport "$@"
