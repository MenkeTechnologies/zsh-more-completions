#compdef yash-cli yash2
# _yash-cli — WATANABE Yuki Yash yash-cli CLI command-line frontend wrapping the Yash Yet Another Shell open-source POSIX-compliant command line shell focused on POSIX compatibility with many extensions written in C originally WATANABE Yuki now Yash team Yash is a POSIX-compliant command line shell focused on POSIX conformance Korn-Shell-Bash-like-syntax extensive-array-support job-control extended-pattern-matching command-line-editing command-line-completion direct-input-string interactive-mode emacs-mode vi-mode -c -i -l -s -m -o -e -f -n -u -v -x -X -T -- option allexport hashondefdef interactive login monitor noexec noglob nolog notify nounset posix pipefail trackall verbose xtrace (WATANABE Yuki Yash team, C); custom argparse
# upstream: https://yash.osdn.jp/

_yash-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[command]:str:' \
        '-i[interactive]' \
        '-l[login shell]' \
        '-s[stdin command]' \
        '-r[restricted shell]' \
        '-T+[profile]:file:_files' \
        '-X[no error exit]' \
        '-D[disabledialogfile]' \
        '--allexport[allexport]' \
        '--errexit[errexit]' \
        '--noclobber[noclobber]' \
        '--noexec[noexec]' \
        '--noglob[noglob]' \
        '--nounset[nounset]' \
        '--xtrace[xtrace]' \
        '--verbose[verbose]' \
        '--vi[vi mode]' \
        '--emacs[emacs mode]' \
        '--monitor[monitor]' \
        '--posix[POSIX mode]' \
        '--pipefail[pipefail]' \
        '--ignoreeof[ignore EOF]' \
        '--no-init-file[no init file]' \
        '--init-file=+[file]:file:_files' \
        '--profile=+[file]:file:_files' \
        '--noprofile[no profile]' \
        '--norcfile[no rcfile]' \
        '--rcfile=+[file]:file:_files' \
        '--brace-expand[brace expansion]' \
        '--curasycmd[curasycmd]' \
        '--curbg[curbg]' \
        '--cursorpos[cursor pos]' \
        '--dotglob[dot glob]' \
        '--emptylastarg[empty last arg]' \
        '--errreturn[err return]' \
        '--extendedglob[extended glob]' \
        '--forcefg[force foreground]' \
        '--forfor[for for]' \
        '--funcdyn[func dyn]' \
        '--globalvars[global vars]' \
        '--histfile=+[file]:file:_files' \
        '--histfilesize=+[N]:n:' \
        '--histsize=+[N]:n:' \
        '--histspace[histspace]' \
        '--le-promptsp[le prompt sp]' \
        '--linehist[line history]' \
        '--lineedit[line edit]' \
        '--markdirs[markdirs]' \
        '--printrcfileerrlines[print rcfile errlines]' \
        '--promptsubst[prompt subst]' \
        '--traceall[traceall]' \
        '*:yash file:_files -g "*.sh *.ya *.yash"'
}

_yash-cli "$@"
