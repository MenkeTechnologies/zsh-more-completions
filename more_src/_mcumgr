#compdef mcumgr
# _mcumgr — Apache Mynewt mcumgr CLI device management protocol client for embedded firmware over BLE serial UDP transports image upload list test confirm erase fs upload download stat log show reset config show set MCUmgr protocol (Apache Mynewt team, Go); cobra
# upstream: https://github.com/apache/mynewt-mcumgr-cli

_mcumgr() {
    local -a sub=(
        'conn:manage connection profiles'
        'config:read or write a config value on a device'
        'crash:trigger a crash'
        'datetime:get or set datetime'
        'echo:send echo'
        'fs:access device filesystem'
        'help:show help'
        'image:manage images on a device'
        'log:manage logs on a device'
        'mpstat:read memory pool stats'
        'reset:perform soft reset'
        'run:run tests'
        'shell:execute shell command'
        'stat:read stat'
        'taskstat:read task stats'
        'version:show client version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-c+[conn profile]:str:' \
        '--conn=+[conn profile]:str:' \
        '-l+[loglevel]:l:(panic fatal error warn info debug)' \
        '--loglevel=+[loglevel]:l:(panic fatal error warn info debug)' \
        '-t+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-r+[max retries]:n:' \
        '--tries=+[tries]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mcumgr subcommand' sub ;;
        args)
            case $words[1] in
                conn) _arguments \
                    '1:op:(add show delete edit)' \
                    '*:name:' ;;
                image) _arguments \
                    '1:op:(confirm erase list test upload)' \
                    '*:file:_files -g "*.img *.bin *.hex"' ;;
                fs) _arguments \
                    '1:op:(upload download)' \
                    '*:path:_files' ;;
                log) _arguments \
                    '1:op:(level_list list module_list show show_index clear)' ;;
                config) _arguments \
                    '*:name=value:' ;;
            esac
            ;;
    esac
}

_mcumgr "$@"
