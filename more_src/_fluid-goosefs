#compdef fluid-goosefs goosefsruntime-controller
# _fluid-goosefs — Fluid GooseFSRuntime controller (fluid-cloudnative/fluid)
# upstream: https://github.com/fluid-cloudnative/fluid
# Subcommands + flags from cmd/goosefs/app/goosefs.go on tip.

_fluid-goosefs() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start the GooseFSRuntime controller'
                version:'print version and exit'
            )
            _describe -t commands 'fluid-goosefs command' cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--metrics-addr=[metrics bind address]:host\:port:' \
                        '--enable-leader-election=[enable leader election]:bool:(true false)' \
                        '--leader-election-namespace=[leader-election namespace]:ns:' \
                        '--development=[enable development mode logging]:bool:(true false)' \
                        '--runtime-node-port-range=[allowed GooseFS node-port range]:range:' \
                        '--port-allocate-policy=[port allocation policy]:policy:(random bitmap)' \
                        '--pprof-addr=[pprof bind address]:host\:port:' \
                        '--runtime-workers=[max concurrent runtime reconciles]:n:' \
                        '--kube-api-qps=[Kubernetes client QPS]:f:' \
                        '--kube-api-burst=[Kubernetes client burst]:n:'
                    ;;
            esac
            ;;
    esac
}

_fluid-goosefs "$@"
