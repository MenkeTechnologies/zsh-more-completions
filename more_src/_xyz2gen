#compdef xyz2gen
# Documentation: https://github.com/dftbplus/dftbplus/blob/main/tools/dptools/src/dptools/scripts/xyz2gen.py
# DFTB+ dptools: convert an XYZ geometry file to DFTB+ gen format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --lattice-file)'{-l,--lattice-file}'+[read lattice vectors from an external file]:file:_files' \
  '(-o --output)'{-o,--output}'+[override the name of the output file]:file:_files' \
  '(-f --fractional)'{-f,--fractional}'[store coordinates in fractional format]' \
  '*:xyz input file:_files -g "*.xyz"' && ret=0

return ret
