#compdef ExtractSliceFromImage
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ExtractSliceFromImage.cxx — extract one slice from an image (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '2:inputImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outputSlice:_files' \
    '4:direction:(0 1 2)' \
    '5:slice_number:_default' \
    '6::KeepSliceInOriginalSpace (default 0):(0 1)' \
    && ret=0

return ret
