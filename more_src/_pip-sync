#compdef pip-sync
# Documentation: https://pip-tools.readthedocs.io/en/latest/cli/pip-sync.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '*'{-q,--quiet}'[decrease verbosity]' \
  '(-n --dry-run)'{-n,--dry-run}'[only show what would happen]' \
  '(-a --ask)'{-a,--ask}'[show what would happen then ask whether to continue]' \
  '--force[proceed despite any conflicts]' \
  '*'{-f,--find-links}'=[look for archives at URL or path]:url or path:_files' \
  '(-i --index-url)'{-i,--index-url}'=[base URL of the Python Package Index]:url:' \
  '*--extra-index-url=[extra index URLs]:url:' \
  '--no-index[ignore package index]' \
  '--pip-args=[arguments to pass directly to pip]:args:' \
  '--python-executable=[path to Python executable]:python:_files' \
  '--cert=[path to alternate CA bundle]:cert file:_files' \
  '--client-cert=[path to SSL client certificate]:cert file:_files' \
  '*--trusted-host=[mark host as trusted]:host:_hosts' \
  '--user[install to user site-packages]' \
  '--config=[read configuration from TOML file]:config file:_files' \
  '--no-config[skip loading configuration files]' \
  '*:requirements file:_files -g "*.txt"' && ret=0

return ret
