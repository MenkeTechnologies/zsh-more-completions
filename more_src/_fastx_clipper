#compdef fastx_clipper
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastx_clipper.1.en.html
# FASTX-Toolkit: remove adapter sequences from FASTA/Q reads

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-a+[adapter string (default CCTTAAGG)]:adapter' \
  '-l+[discard sequences shorter than N nucleotides]:length' \
  '-d+[keep the adapter and N bases after it]:bases' \
  '-c[discard non-clipped sequences]' \
  '-C[discard clipped sequences]' \
  '-k[report adapter-only sequences]' \
  '-n[keep sequences with unknown (N) nucleotides]' \
  '-M+[require minimum adapter alignment length of N]:length' \
  '-v[verbose: report number of sequences]' \
  '-z[compress output with GZIP]' \
  '-D[debug output]' \
  '-i+[FASTA/Q input file (default STDIN)]:input file:_files' \
  '-o+[FASTA/Q output file (default STDOUT)]:output file:_files' && ret=0

return ret
