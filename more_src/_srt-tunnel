#compdef srt-tunnel
# Documentation: https://github.com/Haivision/srt/blob/master/docs/apps/srt-tunnel.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed fabricated -g/-s (source URI)/-d (destination URI)/--help flags
# that are not documented in upstream srt-tunnel.md. Actual usage is:
# srt-tunnel [OPTIONS] <Listener URI> <Caller URI>. -s is skipflush, not source.

local -a arguments

arguments=(
    '(-ll -loglevel)'{-ll,-loglevel}'[logging level (default error)]:level:(fatal error note warning debug)'
    '(-lf -logfa)'{-lf,-logfa}'[logging Functional Area enabled]:area'
    '(-c -chunk)'{-c,-chunk}'[data size read per operation (default 4096)]:bytes'
    '(-v -verbose)'{-v,-verbose}'[display transmission details]'
    '(-s -skipflush)'{-s,-skipflush}'[exit without waiting for data completion]'
    '1:Listener URI'
    '2:Caller URI'
)

_arguments -s $arguments
