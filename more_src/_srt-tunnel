#compdef srt-tunnel

local -a arguments

arguments=(
    '-g[roles for gateway, roles separated by comma]:roles'
    '-ll[log level]:level:(fatal error note warning debug)'
    '-lf[log functional area]:area'
    '-s[source URI]:URI'
    '-d[destination URI]:URI'
    '-v[verbose output]'
    '-h[show help]'
    '--help[show help]'
)

_arguments -s -S $arguments
