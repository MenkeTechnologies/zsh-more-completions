#compdef catj
# catj — display JSON files in a cat-friendly flat format

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '-C[force colorized output]' \
  '-n[show null values]' \
  '-s[show string quotes]' \
  '*:JSON file:_files -g "*.json"'
