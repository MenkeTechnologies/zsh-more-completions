#compdef mxnet2ncnn
# Documentation: https://github.com/Tencent/ncnn/wiki/use-ncnn-with-pytorch-or-onnx
# Convert an MXNet model to ncnn param/bin

local ret=1

_arguments -s -S \
  '1:mxnet symbol json:_files -g "*.json"' \
  '2:mxnet params:_files -g "*.params"' \
  '3:output ncnn param:_files -g "*.param"' \
  '4:output ncnn bin:_files -g "*.bin"' && ret=0

return ret
