#compdef qbs-create-project
# _qbs-create-project — Qt Project qbs-create-project CLI tool generating a qbs project file tree from an existing directory recursively scanning C C++ Qt Quick QML source headers Java Android iOS xib storyboard assets producing main .qbs file with auto-discovered file groups (Qt Project team, C++); custom argparse
# upstream: https://doc.qt.io/qbs/qbs-create-project.html

_qbs-create-project() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--project-file=+[file]:file:_files -g "*.qbs"' \
        '--project-dir=+[dir]:dir:_files -/' \
        '--name=+[project name]:str:' \
        '--type=+[type]:t:(application library dynamiclibrary staticlibrary qt-application qt-quick-application qt-library plugin)' \
        '*:source dir:_files -/'
}

_qbs-create-project "$@"
