#compdef 3dmerge
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dmerge.html
# AFNI edit and/or merge 3D datasets (blur, cluster, threshold)

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-1thtoin[copy threshold data over intensity data]' \
  '-1noneg[zero out negative intensity voxels]' \
  '-1abs[take absolute values of intensities]' \
  '-1clip[clip intensities in range to zero]:val' \
  '-2clip[clip intensities in range v1..v2 to zero]:v1' \
  '-1thresh[use threshold data to censor intensities]:thr' \
  '-2thresh[zero voxels where threshold in t1..t2]:t1' \
  '-1blur_sigma[Gaussian blur with sigma in mm]:bmm' \
  '-1blur_rms[Gaussian blur with rms deviation in mm]:bmm' \
  '-1blur_fwhm[Gaussian blur with FWHM in mm]:bmm' \
  '-dxyz=1[use true 3D distance (1mm voxel dims)]' \
  '-1clust[form clusters with distance and min volume]:rmm' \
  '-1clust_mean[replace intensities with cluster average]:rmm' \
  '-1clust_max[replace with cluster maximum]:rmm' \
  '-1clust_amax[replace with cluster max absolute]:rmm' \
  '-1clust_smax[replace with cluster max signed]:rmm' \
  '-1clust_size[replace with cluster size]:rmm' \
  '-1clust_order[replace with cluster size index ranking]:rmm' \
  '-1clust_depth[replace with cluster depth]:rmm' \
  '-isovalue[cluster only contiguous same-value voxels]' \
  '-isomerge[cluster distinct values without contiguity]' \
  '-1erode[zero voxels unless pv% nearby are nonzero]:pv' \
  '-1dilate[restore eroded voxels near nonzero]' \
  '-1filter_mean[set voxels to average within radius]:rmm' \
  '-1filter_nzmean[average non-zero voxels within radius]:rmm' \
  '-1filter_max[set to maximum within radius]:rmm' \
  '-1filter_blur[Gaussian blur using filter expression]:fwhm' \
  '-1zvol[zero out entries in 3D volume range]:x1' \
  '-1mult[multiply intensities by factor]:factor' \
  '-1zscore[convert statistics to z-scores]' \
  '-1rank[return rank values at each voxel]' \
  '-1dindex[use sub-brick j as data source]:j' \
  '-1tindex[use sub-brick k as threshold source]:k' \
  '-gmean[average intensities (default)]' \
  '-gnzmean[average non-zero intensities]' \
  '-gmax[take maximum intensity]' \
  '-gamax[take maximum absolute intensity]' \
  '-gsmax[take maximum signed intensity]' \
  '-gcount[count nonzero hits per voxel]' \
  '-gorder[combine in input order, first nonzero wins]' \
  '-gfisher[merge correlations via Fisher transform]' \
  '-ghits[delete voxels with fewer than count nonzero]:count' \
  '-gclust[cluster merged results]:rmm' \
  '-nozero[do not write all-zero output datasets]' \
  '-datum[coerce output type]:type:(byte short float)' \
  '-thdatum[storage type for threshold data]:type:(byte short float)' \
  '-keepthr[copy unedited threshold data to output]' \
  '-doall[apply operations to all sub-bricks]' \
  '-nscale[do not scale output shorts to max range]' \
  '-quiet[reduce messages]' \
  '-session[output session directory]:dir:_files -/' \
  '-prefix[output dataset prefix]:prefix' \
  '*:dataset:_files' && ret=0

return ret
