#compdef lcmath
# Subtracts or adds two binned lightcurves

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[first input lightcurve (source+background)]:input file:_files' \
  'bgfile=[second input lightcurve (background)]:background file:_files' \
  'outfile=[output result lightcurve]:output file:_files' \
  'multi=[scaling factor for the first lightcurve]:factor:' \
  'multb=[scaling factor for the second lightcurve]:factor:' \
  'addsubr=[add input lightcurve instead of subtract]:flag:(yes no)' \
  'addi=[additive offset for first input lightcurve]:counts:' \
  'addb=[additive offset for second input lightcurve]:counts:' \
  'docor=[apply corrections to the result lightcurve]:flag:(yes no)' \
  'emin=[minimum energy channel to use]:channel:' \
  'emax=[maximum energy channel to use]:channel:' \
  'err_mode=[method to calculate errors (1-5)]:mode:(1 2 3 4 5)' \
  'tchat=[terminal chattiness level]:level:' \
  'lchat=[log file chattiness level]:level:' \
  '*:file:_files' && ret=0

return ret
