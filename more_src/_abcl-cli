#compdef abcl-cli abcl2
# _abcl-cli — Armed Bear Common Lisp ABCL abcl-cli CLI command-line frontend wrapping the Armed Bear Common Lisp ABCL JVM-based ANSI Common Lisp implementation that runs in a Java Virtual Machine open-source written in Java originally Peter Graves now ABCL team full ANSI Common Lisp implementation on the JVM Java interop CLOS conditions multithreading sockets MOP compile load eval REPL Java-Interop SBCL Quicklisp ASDF Slynk Swank --noinform --noinit --nosystem --batch --eval --load --no-debug --debug-on-error --core-file (Peter Graves ABCL team Mark Evenson Erik Hülsmann, Java); custom argparse
# upstream: https://abcl.org/

_abcl-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--noinform[no inform]' \
        '--noinit[no init]' \
        '--nosystem[no system]' \
        '--batch[batch mode]' \
        '--eval=+[expression]:str:' \
        '*--eval=+[expression]:str:' \
        '--load=+[file]:file:_files -g "*.lisp *.lsp *.cl *.abcl"' \
        '*--load=+[file]:file:_files -g "*.lisp *.lsp *.cl *.abcl"' \
        '--load-system-file=+[file]:file:_files' \
        '--end-toplevel-options[end toplevel options]' \
        '--end-runtime-options[end runtime options]' \
        '--debug[debug]' \
        '--no-debug[no debug]' \
        '--debug-on-error[debug on error]' \
        '--disable-debugger[disable debugger]' \
        '--max-heap=+[N]:str:' \
        '--initial-heap=+[N]:str:' \
        '--core-file=+[file]:file:_files' \
        '--describe-options[describe options]' \
        '--encoding=+[enc]:str:' \
        '--server[server]' \
        '--port=+[port]:n:' \
        '--persist[persist]' \
        '--no-server[no server]' \
        '--print=+[expr]:str:' \
        '*--print=+[expr]:str:' \
        '--no-print[no print]' \
        '*:lisp file:_files -g "*.lisp *.lsp *.cl *.fasl *.abcl"'
}

_abcl-cli "$@"
