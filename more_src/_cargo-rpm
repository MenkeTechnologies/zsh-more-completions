#compdef cargo-rpm
# Documentation: https://github.com/iqlusioninc/cargo-rpm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'init:initialize RPM packaging'
  'build:build the RPM'
  'config:show configuration'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cargo-rpm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '(--config-only)--config-only[only generate config]' \
          '(--editor)--editor[edit spec file]' \
          '(--force)--force[overwrite]' \
          '(--no-cargo-build)--no-cargo-build[skip cargo build]' \
          '*: :' && ret=0 ;;
      (build)
        _arguments \
          '(--no-cargo-build)--no-cargo-build[skip cargo build]' \
          '(--target)--target=[target triple]:t:' \
          '(--profile)--profile=[profile]:p:(release dev)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
