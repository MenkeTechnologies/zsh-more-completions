#compdef cargo-outdated
# Documentation: https://github.com/kbknapp/cargo-outdated
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_cargo-outdated() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s -S \
        {-a,--aggressive}'[Ignore version pinning and show latest versions]' \
        '--color=[Control color output]:color:(auto always never)' \
        {-d,--depth}'[How deep in the dependency chain to search]:depth:' \
        {-x,--exclude}'[Exclude specific dependencies from building]:crate:' \
        '--exit-code=[Exit code when outdated dependencies are found]:code:' \
        '--features=[Space-separated list of features to activate]:features:' \
        '--format=[Output format]:format:(list json)' \
        {-i,--ignore}'[Ignore specific dependencies]:crate:' \
        {-m,--manifest-path}'[Path to Cargo.toml]:path:_files -g "*.toml"' \
        {-p,--packages}'[Packages to inspect for updates]:package:' \
        {-q,--quiet}'[Suppress output]' \
        {-r,--root}'[Package to treat as root]:root:' \
        {-R,--root-deps-only}'[Only check root dependencies]' \
        '*'{-v,--verbose}'[Use verbose output]' \
        {-w,--workspace}'[Check entire workspace]' \
        {-h,--help}'[Print help information]' \
        {-V,--version}'[Print version information]' && ret=0

    return ret
}

_cargo-outdated "$@"
