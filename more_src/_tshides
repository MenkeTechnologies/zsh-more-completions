#compdef tshides
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tshides.cpp
# tshides - list HiDes modulator devices

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-a --adapter)'{-a,--adapter}'=[HiDes adapter number to list]:n:' \
  '(-c --count)'{-c,--count}'[only display the number of devices]' \
  '(-d --device)'{-d,--device}'=[HiDes device name to list]:name:' \
  '(-f --frequency)'{-f,--frequency}'=[carrier frequency in Hz with --gain-range]:hz:' \
  '(-g --gain-range)'{-g,--gain-range}'[display allowed range of output gain]' && ret=0

return ret
