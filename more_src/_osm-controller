#compdef osm-controller
# _osm-controller — Open Service Mesh control-plane controller (xDS server, mesh state reconciler)
# upstream: https://github.com/openservicemesh/osm
# Flags from cmd/osm-controller/osm-controller.go on tip.

_osm-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --verbosity)'{-v,--verbosity}'=[boot log verbosity level]:level:(debug info warn error fatal)' \
        '--mesh-name=[OSM mesh name]:name:' \
        '--osm-namespace=[OSM controller namespace]:ns:' \
        '--osm-service-account=[OSM controller service account]:name:' \
        '--validator-webhook-config=[ValidatingWebhookConfiguration name]:name:' \
        '--osm-config-name=[OSM MeshConfig name]:name:' \
        '--osm-version=[OSM version]:ver:' \
        '--certificate-manager=[certificate manager]:mgr:(tresor vault cert-manager)' \
        '--ca-bundle-secret-name=[Kubernetes Secret holding the OSM CA bundle]:name:' \
        '--trust-domain=[SPIFFE trust domain used in certificate CN]:domain:' \
        '--vault-protocol=[Hashi Vault protocol]:proto:(http https)' \
        '--vault-host=[Hashi Vault host]:host:' \
        '--vault-token=[Hashi Vault token]:token:' \
        '--vault-role=[Vault role dedicated to OSM]:role:' \
        '--vault-port=[Vault port]:port:' \
        '--vault-token-secret-name=[Secret holding the Vault token]:name:' \
        '--vault-token-secret-key=[Secret key holding the Vault token]:key:' \
        '--cert-manager-issuer-name=[cert-manager issuer name]:name:' \
        '--cert-manager-issuer-kind=[cert-manager issuer kind]:kind:(Issuer ClusterIssuer)' \
        '--cert-manager-issuer-group=[cert-manager issuer group]:group:' \
        '--enable-reconciler[enable reconciler for CRDs + admission webhooks]' \
        '--validate-traffic-target=[enable TrafficTarget validation]:bool:(true false)'
}

_osm-controller "$@"
