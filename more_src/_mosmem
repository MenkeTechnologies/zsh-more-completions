#compdef mosmem
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/mosmem.html
# MIRIAD mosmem - maximum entropy deconvolution of a mosaic

local ret=1

_arguments -s -S \
  'map=[input dirty image(s) (Jy/beam)]:map:_files' \
  'beam=[input dirty beam(s)]:beam:_files' \
  'model=[initial deconvolved image estimate (Jy/pixel)]:model:_files' \
  'default=[reference image solution tends toward]:default:_files' \
  'out=[output deconvolved map (Jy/pixel)]:out:_files' \
  'niters=[maximum iteration count]:niters' \
  'region=[deconvolution area]:region' \
  'measure=[entropy measure gull/cornwell]:measure:(gull cornwell)' \
  'tol=[solution tolerance]:tol' \
  'q=[points per beam estimate(s)]:q' \
  'rmsfac=[theoretical to true RMS scaling factor]:rmsfac' \
  'factor=[flux calibration multiplier for single-dish]:factor' \
  'flux=[integrated source flux estimate]:flux' \
  'options=[doflux,dofactor,verbose]:options' \
  '*:dataset:_files' && ret=0

return ret
