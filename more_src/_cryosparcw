#compdef cryosparcw
# Documentation: https://guide.cryosparc.com/llms-full.txt
# cryoSPARC GPU worker node management CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(connect gpulist update install)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $words[1] in
      connect|update) _arguments -s \
        '--worker=[worker hostname]:host:' \
        '--master=[master hostname]:host:' \
        '--port=[base port]:port:' \
        '--ssdpath=[SSD scratch path]:dir:_files -/' \
        '--update[update existing worker]' \
        '--sshstr=[custom ssh string]:str:' \
        '--nogpu[no GPU on this worker]' \
        '--gpus=[GPU indices]:gpus:' \
        '--nossd[no SSD on this worker]' \
        '--ssdquota=[SSD quota in MB]:mb:' \
        '--ssdreserve=[SSD reserve in MB]:mb:' \
        '--lane=[scheduler lane name]:lane:' \
        '--newlane[create new lane]' \
        '--cpus=[number of CPUs]:n:' && ret=0 ;;
      install) _arguments \
        '--license=[license ID]:license:' \
        '--yes[skip confirmations]' && ret=0 ;;
    esac
    ;;
esac

return ret
