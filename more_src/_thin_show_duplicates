#compdef thin_show_duplicates

# thin_show_duplicates: report duplicate blocks in thin pool metadata
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-essential output]' \
  '*:thin pool metadata file:_files' && ret=0
return ret
