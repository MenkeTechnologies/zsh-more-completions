#compdef thin_show_duplicates

# thin_show_duplicates: scan thin volumes for duplicate blocks (deduplication audit)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '--block-sectors=[block size in sectors]:n:' \
  '--input=[input device or metadata file]:file:_files' \
  '--metadata=[metadata file]:file:_files' \
  '--pool-file=[pool snapshot file]:file:_files' \
  '*::thin_show_duplicates args:_files' && ret=0
return ret
