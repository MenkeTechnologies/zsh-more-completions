#compdef lefthook
# Documentation: https://man.archlinux.org/search?q=lefthook
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add hook configuration'
  'install:install Git hooks'
  'uninstall:remove Git hooks'
  'run:run hooks group manually'
  'version:show version'
  'completion:generate shell completions'
  'help:show help'
  'dump:dump full configuration'
  'self-update:update lefthook itself'
  'validate:validate config'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.yml *.yaml"' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(--no-tty)--no-tty[disable TTY]' \
  '(-f --force)'{-f,--force}'[force]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'lefthook command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-n --no-auto-install)'{-n,--no-auto-install}'[no auto install]' \
          '(-a --all-files)'{-a,--all-files}'[all files]' \
          '(-A --files-from-stash)'{-A,--files-from-stash}'[files from stash]' \
          '(--commands)--commands=[commands csv]:list:' \
          '(--exclude-tags)--exclude-tags=[exclude tags csv]:list:' \
          '(--no-tty)--no-tty[no TTY]' \
          '(--force-stash)--force-stash[force stash]' \
          '(--files)*--files=[files csv]:list:' \
          '*: :' && ret=0 ;;
      (install|uninstall)
        _arguments \
          '(-f --force)'{-f,--force}'[force]' \
          '(--keep-config)--keep-config[keep config]' \
          '(--aggressive)--aggressive[aggressive]' \
          '*: :' && ret=0 ;;
      (add)
        _arguments \
          '(-c --create-dirs)'{-c,--create-dirs}'[create dirs]' \
          '(-f --force)'{-f,--force}'[force]' \
          '(-d --dirs)'{-d,--dirs}'[create scripts dir]' \
          '*: :' && ret=0 ;;
      (validate|dump|version|self-update)
        _arguments '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
