#compdef lefthook
# Documentation: https://github.com/evilmartians/lefthook/tree/master/cmd
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (urfave/cli command definitions).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install Git hooks based on lefthook.yml'
  'uninstall:remove Git hooks'
  'add:add a hook configuration'
  'run:run hook commands and scripts'
  'version:print lefthook version'
  'validate:validate configuration'
  'dump:dump resolved configuration'
  'check-install:verify installation status'
  'self-update:update lefthook itself'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'lefthook command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '(-f --force)'{-f,--force}'[overwrite .old files]' \
          '(-r --reset-hooks-path)'{-r,--reset-hooks-path}'[unset core.hooksPath]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0 ;;
      (uninstall)
        _arguments \
          '(-f --force)'{-f,--force}'[remove all Git hooks]' \
          '--remove-configs[remove lefthook configs]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0 ;;
      (add)
        _arguments \
          '(-f --force)'{-f,--force}'[force]' \
          '--dirs[create directories for scripts]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '*: :' && ret=0 ;;
      (run)
        _arguments \
          '(-f --force)'{-f,--force}'[bypass empty-changes skip]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '--colors=[color output]:colors:(on off auto)' \
          '*--job=[run only named jobs]:job:' \
          '*--tag=[run jobs matching tag]:tag:' \
          '*--command=[run only named commands]:command:' \
          '*--exclude=[exclude files from templates]:pattern:' \
          '*--file=[substitute file templates]:file:_files' \
          '--all-files[replace file templates with {all_files}]' \
          '--no-auto-install[disable auto install]' \
          '--no-stage-fixed[ignore stage_fixed setting]' \
          '--no-tty[simulate no TTY]' \
          '--skip-lfs[skip LFS hooks]' \
          '--fail-on-changes[exit 1 if files modified]' \
          '--fail-on-changes-diff[show diff on fail-on-changes]' \
          '--files-from-stdin[read files from stdin]' \
          '*: :' && ret=0 ;;
      (dump)
        _arguments \
          '(-f --format)'{-f+,--format=}'[output format]:format:(yaml toml json)' && ret=0 ;;
      (validate)
        _arguments '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0 ;;
      (version|check-install|self-update)
        _arguments '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
