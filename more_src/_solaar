#compdef solaar

# Zsh completion for solaar - Logitech Unifying device manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'show:show information about paired devices'
  'probe:probe a receiver for paired devices'
  'config:read/write device-specific settings'
  'pair:pair a new device'
  'unpair:unpair a device'
  'power-on:power on a device'
)

_arguments -s -S \
  '1:command:->command' \
  '(-d --debug)'{-d,--debug}'[print debug messages]' \
  '(-D --hidraw)'{-D,--hidraw}'[use specified HID device path]:device:_files' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'solaar command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (show)
        _arguments '1:device name or number' && ret=0
        ;;
      (config)
        _arguments \
          '1:device name or number' \
          '2:setting name' \
          '3:value' && ret=0
        ;;
      (pair)
        _arguments '1:receiver name or number' && ret=0
        ;;
      (unpair)
        _arguments '1:device name or number' && ret=0
        ;;
      (power-on)
        _arguments '1:device name or number' && ret=0
        ;;
    esac
    ;;
esac

return ret
