#compdef pithos
# Documentation: https://pithos.github.io/
# Reference accessed: 2026-05-16
# Verified: GTK Pandora client. GUI-only with minimal CLI surface.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# pithos: GTK Pandora Radio client (GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--test[enable test mode]' \
  '--verbose[verbose output]' \
  '--last-fm-handler[register as last.fm URL handler]' && ret=0
return ret
