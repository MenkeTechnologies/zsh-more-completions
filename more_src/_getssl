#compdef getssl

# Zsh completion for getssl - get SSL certificates via ACME

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --all)'{-a,--all}'[check and renew all certificates]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-c --create)'{-c,--create}'[create default config files]:domain' \
  '(-f --force)'{-f,--force}'[force renewal of certificate]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-r --revoke)'{-r,--revoke}'[revoke a certificate]:cert file:_files' \
  '(-u --upgrade)'{-u,--upgrade}'[upgrade getssl to latest version]' \
  '(-U --nocheck)'{-U,--nocheck}'[do not check for upgrades]' \
  '(-w --working-dir)'{-w,--working-dir}'[set working directory]:directory:_directories' \
  '--preferred-chain=[preferred certificate chain]:chain' \
  '--check-config[check configuration and exit]' \
  '*:domain' && ret=0

return ret
