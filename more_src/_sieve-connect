#compdef sieve-connect sieve-test

local curcontext="$curcontext" state line ret=1

case $service in
  (sieve-connect)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '(-s --server)'{-s+,--server=}'[server]:host:_hosts' \
      '(-p --port)'{-p+,--port=}'[port]:port:' \
      '(-u --user)'{-u+,--user=}'[username]:user:_users' \
      '(-a --authzid)'{-a+,--authzid=}'[authorization id]:user:' \
      '(-r --realm)'{-r+,--realm=}'[realm]:realm:' \
      '(-c --clientkey)'{-c+,--clientkey=}'[client key]:file:_files' \
      '(-C --clientcert)'{-C+,--clientcert=}'[client cert]:file:_files' \
      '(-e --execute)'{-e+,--execute=}'[execute commands]:cmds:' \
      '(-l --localsieve)'{-l+,--localsieve=}'[local sieve]:file:_files' \
      '(-r --remotesieve)'{-r+,--remotesieve=}'[remote sieve]:name:' \
      '--upload[upload script]' \
      '--download[download script]' \
      '--list[list scripts]' \
      '--delete[delete script]' \
      '--activate[activate script]' \
      '--deactivate[deactivate]' \
      '--exec[exec mode]' \
      '--debug[debug]' \
      '--debugsasl[debug SASL]' \
      '--noclearauth[no clear auth]' \
      '--nosslverify[no SSL verify]' \
      '--tls[force TLS]' \
      '--notls[no TLS]' \
      '--no-srv-lookup[no SRV lookup]' \
      '--ignoreserverversion[ignore server version]' \
      '*: :_files -g "*.sieve"' && ret=0 ;;
  (sieve-test)
    _arguments -C \
      '-h[help]' \
      '-D+[debug]:opt:' \
      '-T+[trace]:opt:' \
      '-x+[extensions]:list:' \
      '-l+[mailbox]:dir:_files -/' \
      '-r+[recipient]:addr:' \
      '-f+[envelope from]:addr:' \
      '-c+[client]:host:' \
      '-s+[script]:file:_files -g "*.sieve"' \
      '-X[explain]' \
      '-e[execute actions]' \
      '*: :_files' && ret=0 ;;
esac

return ret
