#compdef probtrackx2
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/diffusion/probtrackx.html
# probtrackx2 - probabilistic tractography with crossing fibres

local ret=1

_arguments -s -S \
  '(-s --samples)'{-s,--samples}'[basename for samples files (merged_*)]:basename:_files' \
  '(-m --mask)'{-m,--mask}'[brain mask in diffusion space]:file:_files' \
  '(-x --seed)'{-x,--seed}'[seed volume, surface, or ASCII mask list]:file:_files' \
  '(-o --out)'{-o,--out}'[output file basename]:basename:_files' \
  '--dir=[output directory]:dir:_files -/' \
  '--seedref=[reference vol for seed in single-voxel/surface mode]:file:_files' \
  '--simple[track from list of voxels (single seed mode)]' \
  '--waypoints=[waypoint masks, streamlines must pass through]:file:_files' \
  '--waycond=[waypoint condition (AND/OR)]:cond:(AND OR)' \
  '--wayorder[force waypoint crossing in listed order]' \
  '--avoid=[exclusion mask]:file:_files' \
  '--stop=[termination mask]:file:_files' \
  '--wtstop=[terminate after leaving the mask]:file:_files' \
  '--targetmasks=[file with target masks for classification]:file:_files' \
  '--network[activate network mode (ROI-by-ROI matrix)]' \
  '--omatrix1[output seed-to-seed connectivity matrix]' \
  '--omatrix2[output seed-to-lowres-mask matrix]' \
  '--omatrix3[output NxN connectivity matrix]' \
  '--os2t[output seed-to-target counts]' \
  '--opd[output path distribution]' \
  '--pd[correct path distribution for distance]' \
  '--xfm=[seed-to-diffusion transform]:file:_files' \
  '--invxfm=[diffusion-to-seed transform]:file:_files' \
  '--meshspace=[mesh space (caret/freesurfer/first/vox)]:space:(caret freesurfer first vox)' \
  '(-P --nsamples)'{-P,--nsamples}'[number of samples per seed (default 5000)]:n:' \
  '(-S --nsteps)'{-S,--nsteps}'[max number of steps per sample (default 2000)]:n:' \
  '--steplength=[step length in mm (default 0.5)]:len:' \
  '(-c --cthr)'{-c,--cthr}'[curvature threshold (default 0.2)]:thr:' \
  '--fibthresh=[volume fraction before subsidiary fibre (default 0.01)]:thr:' \
  '--distthresh=[discard streamlines shorter than this (mm)]:thr:' \
  '--sampvox=[sample within sphere of given radius around seed]:r:' \
  '(-l --loopcheck)'{-l,--loopcheck}'[perform loop checks on paths]' \
  '(-f --usef)'{-f,--usef}'[use anisotropy to constrain tracking]' \
  '--modeuler[use modified Euler streamlining]' \
  '--rseed=[random seed]:seed:' \
  '--randfib=[default/random fibre selection (0-3)]:mode:(0 1 2 3)' \
  '--forcedir[use the actual directory name given]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
