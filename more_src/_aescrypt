#compdef aescrypt
# _aescrypt — Packetizer AES Crypt (file-level AES-256 encryption/decryption with .aes container format; -e encrypt, -d decrypt, -p password inline, -k keyfile, -o output (- for stdin/stdout), one or more positional files)
# upstream: https://www.aescrypt.com/ (Packetizer)
# Flags from aescrypt aescrypt.c on tip.

_aescrypt() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '(-d)-e[encrypt]' \
        '(-e)-d[decrypt]' \
        '-p+[password (inline)]:password:' \
        '-k+[keyfile]:file:_files' \
        '-o+[output file (- for stdout)]:file:_files' \
        '*:file:_files'
}

_aescrypt "$@"
