#compdef genozip
# Documentation: https://genozip.com/genozip
# genozip - compressor for genomic files (FASTQ, BAM, VCF, FASTA)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'=[specify input data type]:type' \
  '(-f --force)'{-f,--force}'[force overwrite of output]' \
  '(-^ --replace)'{-^,--replace}'[replace source file with result]' \
  '(-D --subdirs)'{-D,--subdirs}'[include directory files recursively]' \
  '(-o --output)'{-o,--output}'=[output filename or directory]:file:_files' \
  '(-9 --optimize)'{-9,--optimize}'[optimize for better compression]' \
  '(-b --best)'{-b,--best}'[highest compression ratio]' \
  '(-F --fast)'{-F,--fast}'[faster compression lower ratio]' \
  '--low-memory[use less memory]' \
  '(-p --password)'{-p,--password}'=[256-bit AES encryption]:password' \
  '(-t --test)'{-t,--test}'[verify file integrity after compression]' \
  '(-X --no-test)'{-X,--no-test}'[disable testing]' \
  '(-m --md5)'{-m,--md5}'[use MD5 digest]' \
  '(-@ --threads)'{-@,--threads}'=[maximum thread count]:threads' \
  '(-B --vblock)'{-B,--vblock}'=[max data size per thread MB]:mb' \
  '(-e --reference)'{-e,--reference}'=[reference file]:file:_files' \
  '(-E --REFERENCE)'{-E,--REFERENCE}'=[include reference in compressed file]:file:_files' \
  '(-w --stats)'{-w,--stats}'[display compression statistics]' \
  '--make-reference[create reference from FASTA]' \
  '--tar=[compress into tar file]:file:_files' \
  '(-T --files-from)'{-T,--files-from}'=[file list from text file]:file:_files' \
  '--skip-index[skip compressing index files]' \
  '*:file:_files' && ret=0

return ret
