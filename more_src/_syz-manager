#compdef syz-manager
# _syz-manager — syzkaller kernel fuzzer manager (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from syz-manager/manager.go (flag).

_syz-manager() {
    _arguments \
        '-config=[configuration file]:file:_files -g "*.cfg"' \
        '-debug[dump all VM output to console]' \
        '-bench=[write execution statistics to this file periodically]:file:_files' \
        '-mode=[manager mode]:mode:(fuzzing smoke-test corpus-triage corpus-run run-tests iface-probe)' \
        '-tests=[prefix matching test file names (with -mode run-tests)]:prefix:'
}

_syz-manager "$@"
