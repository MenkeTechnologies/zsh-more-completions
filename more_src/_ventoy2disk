#compdef Ventoy2Disk.sh
# Documentation: https://man.archlinux.org/search?q=Ventoy2Disk.sh
# Reference accessed: 2026-05-16

# Zsh completion for Ventoy2Disk.sh - Ventoy installer script

_arguments -s -S \
  '-i[install Ventoy to sdX]' \
  '-I[force install Ventoy to sdX]' \
  '-u[update Ventoy in sdX]' \
  '-l[list Ventoy info in sdX]' \
  '-n[non-destructive reinstall]' \
  '-s[enable secure boot]' \
  '-g[use GPT partition style]' \
  '1:device:_files -g "/dev/sd*" -g "/dev/nvme*"'
