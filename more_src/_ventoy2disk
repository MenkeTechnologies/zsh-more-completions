#compdef ventoy2disk Ventoy2Disk.sh
# Documentation: https://www.ventoy.net/en/doc_start.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for Ventoy2Disk.sh - Ventoy installer script

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-i[install Ventoy to device]' \
  '-I[force install Ventoy to device]' \
  '-u[update Ventoy on device]' \
  '-l[list Ventoy info on device]' \
  '-n[non-destructive installation]' \
  '-s[enable secure boot support (default)]' \
  '-S[disable secure boot support]' \
  '-g[use GPT partition style]' \
  '-r[reserve space (MiB) at end of disk]:size:' \
  '-L[set partition label]:label:' \
  '1:device:_files -g "/dev/sd* /dev/nvme*"'
