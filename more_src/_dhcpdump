#compdef dhcpdump
# Documentation: https://man.archlinux.org/search?q=dhcpdump
# Reference accessed: 2026-05-16

# Zsh completion for dhcpdump
# Upstream: Monitor DHCP traffic for debugging purposes
# Conservative fallback — run `dhcpdump --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
