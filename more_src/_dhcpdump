#compdef dhcpdump
# Documentation: https://www.mankier.com/8/dhcpdump
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dhcpdump: monitor DHCP traffic. Per upstream manpage, only -i, -h, -H, -r
# are documented options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-i+[network interface to listen on]:interface:_net_interfaces' \
  '-h+[filter by client hardware address (regex)]:regex' \
  '-H[display full packet hex dump]' \
  '-r+[read DHCP packets from pcap file]:pcap file:_files' && ret=0

return ret
