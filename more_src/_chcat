#compdef chcat
# Documentation: man chcat(8)
# Source: SELinuxProject/selinux python/chcat/chcat (main) — change SELinux MCS category (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-d --delete)'{-d,--delete}'[delete categories]' \
    '(-l --login)'{-l,--login}'[apply to login users (sysadm)]' \
    '(-L --list)'{-L,--list}'[list available categories]' \
    '*:category or file:_files' \
    && ret=0

return ret
