#compdef create-tauri-app
# Documentation: https://www.npmjs.com/package/create-tauri-app
# Reference accessed: 2026-05-23
# Verified: npx create-tauri-app --help.

# Zsh completion for create-tauri-app - scaffold a new Tauri application

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --manager)'{-m,--manager=}'[package manager]:manager:(cargo pnpm yarn npm deno bun dotnet)' \
  '(-t --template)'{-t,--template=}'[UI template]:template:(vanilla vanilla-ts vue vue-ts svelte svelte-ts react react-ts solid solid-ts yew leptos sycamore angular preact preact-ts blazor dioxus)' \
  '--identifier=[unique application identifier]:id:' \
  '(-y --yes)'{-y,--yes}'[skip prompts and use defaults]' \
  '(-f --force)'{-f,--force}'[force create directory]' \
  ':project name:' && ret=0

return ret
