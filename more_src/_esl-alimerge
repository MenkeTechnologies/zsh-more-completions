#compdef esl-alimerge

# Easel esl-alimerge: merge multiple alignments into one
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-o[output file]:file:_files' \
  '--list[input is a file listing alignment files]:file:_files' \
  '--informat[input format]:fmt:(stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--outformat[output format]:fmt:(stockholm pfam a2m afa clustal phylip phylips)' \
  '--rfonly[merge using only RF-marked columns]' \
  '*:alignment files:_files' && ret=0
return ret
