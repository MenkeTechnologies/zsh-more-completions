#compdef exfatlabel
# Documentation: https://github.com/exfatprogs/exfatprogs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --volume-serial)'{-i,--volume-serial}'[switch to volume serial mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:device:_files -W /dev' \
  '2:label or serial:' && ret=0

return ret
