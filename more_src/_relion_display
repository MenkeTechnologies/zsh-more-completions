#compdef relion_display
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: display images, stacks, classes and pick particles in micrographs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input STAR file, image or stack]:file:_files' \
  '--gui[provide all other parameters through a GUI]' \
  '--display=[metadata label to display]:label' \
  '--text_label=[metadata label to display text]:label' \
  '--table=[name of the table to read from the input STAR file]:name' \
  '--scale=[relative scale]:value' \
  '--black=[pixel value for black]:value' \
  '--white=[pixel value for white]:value' \
  '--sigma_contrast=[set white/black this many stddev from mean]:value' \
  '--read_whole_stack[read entire stacks at once to speed up]' \
  '--show_fourier_amplitudes[show amplitudes of 2D Fourier transform]' \
  '--show_fourier_phase_angles[show phase angles of 2D Fourier transforms]' \
  '--colour_fire[black-grey-white-red colour scheme]' \
  '--colour_ice[blue-black-grey-white colour scheme]' \
  '--colour_rainbow[cyan-blue-black-red-yellow colour scheme]' \
  '--colour_bar[show colourbar image]' \
  '--ignore_optics[ignore optics groups in input STAR file]' \
  '--col=[number of columns]:value' \
  '--apply_orient[apply stored orientation angles and offsets]' \
  '--angpix=[pixel size (A) for lowpass filter and offsets]:value' \
  '--ori_scale=[relative scale for individual images in multiviewer]:value' \
  '--sort=[metadata label to sort images on]:label' \
  '--random_sort[use random order in the sorting]' \
  '--reverse[use reverse order in the sorting]' \
  '--class[analyse classes in optimiser.star or model.star]' \
  '--regroup=[number of groups to regroup saved particles into]:value' \
  '--allow_save[allow saving of selected particles or class averages]' \
  '--fn_imgs=[STAR file in which to save selected images]:file:_files' \
  '--fn_parts=[STAR file in which to save particles from classes]:file:_files' \
  '--max_nr_parts_per_class=[select max this many particles per class]:value' \
  '--recenter[recenter selected images to center-of-mass]' \
  '--max_nr_images=[only show this many images]:value' \
  '--pick[pick coordinates in input image]' \
  '--pick_start_end[pick start-end coordinates in input image]' \
  '--coords=[STAR file with picked particle coordinates]:file:_files' \
  '--coord_scale=[scale particle coordinates before display]:value' \
  '--particle_radius=[particle radius in pixels]:value' \
  '--topaz_denoise[use Topaz denoising before picking]' \
  '--lowpass=[lowpass filter (A) before displaying micrograph]:value' \
  '--highpass=[highpass filter (A) before displaying micrograph]:value' \
  '--minimum_pick_fom=[minimum rlnAutopickFigureOfMerit to display picks]:value' \
  '--color_star=[STAR file with a column for colouring particles]:file:_files' \
  '--color_label=[metadata label to colour particles on]:label' \
  '--blue=[value of the blue color]:value' \
  '--red=[value of the red color]:value' \
  '--verb=[verbosity]:value' \
  '*:file:_files' && ret=0

return ret
