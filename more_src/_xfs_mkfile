#compdef xfs_mkfile
# _xfs_mkfile — xfsprogs xfs_mkfile (allocate a regular file of a given size, optionally writing zeros (-n no-data fills with holes, -p preallocate via fallocate, -v verbose, -s prealloc and zero); size accepts k/m/g/t suffixes)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs io/mmap.c on tip.

_xfs_mkfile() {
    _arguments \
        '-V[show version]' \
        '-n[no data writes (sparse holes)]' \
        '-p[preallocate (fallocate)]' \
        '-s[preallocate + zero]' \
        '-v[verbose]' \
        '1:size (e.g. 100m):' \
        '*:file:_files'
}

_xfs_mkfile "$@"
