#compdef paket-bootstrapper paket.bootstrapper
# Documentation: https://github.com/fsprojects/Paket/blob/master/src/Paket.Bootstrapper/BootstrapperHelper.cs
# Reference accessed: 2026-05-27
# Verified: upstream HelpText constant in BootstrapperHelper.cs and the
# CommandArgs constants in ArgumentParser.cs (fsprojects/Paket).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[print help]' \
  '--prefer-nuget[prefer NuGet over GitHub as download source]' \
  '--force-nuget[only use NuGet as source]' \
  '--nuget-source=[NuGet source URL or filepath]:source:' \
  '--max-file-age=[skip checks when paket.exe is younger than this many minutes]:minutes:' \
  '--self[download and update paket.bootstrapper itself]' \
  '-f[do not use local cache; always download]' \
  '*-s[silent mode; errors only (repeat for no output)]' \
  '*-v[verbose; show more information on console]' \
  '--output-dir=[download paket to the specified directory]:dir:_files -/' \
  '--as-tool[install paket as a .NET SDK tool]' \
  '--config-file=[read settings from an alternate config file]:file:_files' \
  '--run[run the downloaded paket.exe with all following arguments]' \
  '*:version-or-prerelease:(prerelease)' && ret=0

return ret
