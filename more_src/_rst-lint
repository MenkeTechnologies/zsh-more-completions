#compdef rst-lint
# Documentation: https://github.com/twolfson/restructuredtext-lint
# rst-lint - lint reStructuredText files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version number and exit]' \
  '--format=[format of the output]:format:(text json)' \
  '--level=[minimum error level to report]:level:(debug info warning error severe)' \
  '--rst-prolog=[reStructuredText content to prepend to all files]:prolog:' \
  '*:path:_files' && ret=0

return ret
