#compdef backtranseq

# EMBOSS backtranseq: back-translate protein sequence to most likely DNA
# using codon-usage table for an organism
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-cfile=[codon usage table file]:file:_files' \
  '-outseq=[output DNA sequence]:file:_files' \
  '-osformat=[output format]:format:(fasta embl genbank gff swiss gcg pir nbrf raw msf ace text)' \
  '*:protein USA:_files' && ret=0
return ret
