#compdef deb-systemd-helper
# Documentation: https://man.archlinux.org/search?q=deb-systemd-helper
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'enable:enable units'
  'disable:disable units'
  'purge:purge state'
  'mask:mask units'
  'unmask:unmask units'
  'is-enabled:check if enabled'
  'was-enabled:check if was enabled'
  'debian-installed:check if installed'
  'update-state:update state'
  'reenable:re-enable units'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--quiet[quiet]' \
  '--no-reload-system[no system reload]' \
  '--user[user instance]' \
  '1: :->cmd' \
  '*::unit:->units' && ret=0

case $state in
  (cmd) _describe -t cmds 'deb-systemd-helper command' commands && ret=0 ;;
  (units) _arguments '*:unit:' && ret=0 ;;
esac

return ret
