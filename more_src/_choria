#compdef choria
# =============================================================================
# choria — choria-io/go-choria's "Choria
#   Orchestration System" — a Go-implemented
#   framework for building CONTROL PLANES,
#   ORCHESTRATION SYSTEMS, and PROGRAMMABLE
#   INFRASTRUCTURE on top of the NATS messaging
#   protocol.  Ships a daemon (server) + broker
#   + a fleet-management CLI tool (this one)
#   that speaks the Choria RPC protocol over
#   NATS subjects.  Built on direct
#   `nats-io/nats.go v1.52.0` for the messaging
#   transport + `nats-io/jsm.go v0.4.1` for
#   JetStream Manager + an EMBEDDED
#   `nats-io/nats-server/v2 v2.14.0` for the
#   built-in broker mode.  Go=103 leader bump
#   continuing Axis 48 (NATS Messaging Client)
#   at the Go pole, opened by R781 `_arkflow`
#   (Rust=103, async-nats 0.46).
#
# AXIS 48 — NATS MESSAGING CLIENT — GO POLE
# ==========================================
# `nats-io/nats.go` is the official, canonical
# pure-Go NATS client.  6,628 stars on GitHub,
# Apache-2.0.  Drop-in for Core NATS request/
# reply + pub/sub + queue groups + JetStream
# (via the sibling `jsm.go` package).
# Distinguishes from other corpus messaging
# Go clients:
#   - IBM/sarama  (Axis 47, Kafka)             — wire protocol re-impl in pure Go
#   - segmentio/kafka-go (alt Axis 47)         — pure Go, simpler API
#   - rabbitmq/amqp091-go                      — AMQP 0.9.1 client
#   - eclipse/paho.mqtt.golang                 — MQTT 3.1 / 5.0
#   - twmb/franz-go                            — newer Kafka client
#
# Other Axis 48 implementations across the
# corpus:
#   - Rust       : async-nats (R781, arkflow)
#                  — tokio-async, JetStream +
#                    KV + Object Store
#                    support
#   - Go         : nats-io/nats.go (THIS
#                  ROUND, choria) — pure-Go
#                  Core NATS + JetStream
#   - TS-Node    : nats.io/nats.js (R783 will
#                  close) — pure-JS Core NATS
#                  + separate @nats-io/
#                  jetstream package
#
# Distinguishing choria from other corpus NATS-
# adjacent or RPC-adjacent tools:
#   - PURPOSE: choria is an ORCHESTRATION /
#     CONTROL PLANE — its RPC layer rides on
#     NATS subjects and message brokers but the
#     user-visible model is "run fleet
#     commands against discovered nodes".  Not
#     a generic NATS CLI (use `_nats` for
#     that) and not a pure messaging library
#     wrapper
#   - DISCOVERY-BASED RPC — every Choria server
#     publishes a structured `inventory.json`
#     describing the facts (CPU arch, OS,
#     installed packages, custom data plugins)
#     of the node.  Operators run `choria req`
#     with discovery predicates like
#     `--filter os::operatingsystem=Linux
#     --filter package::nginx::enabled=true`
#     to fan out RPC calls to matching nodes
#   - ANSIBLE / SALT / MCOLLECTIVE LINEAGE —
#     descended from Puppet Labs's
#     MCollective (the now-archived
#     `meta-collective` Ruby project).  Choria
#     is the Go-rewrite of MCollective's
#     control plane.  Uses the same RPC
#     concept ("agents" expose typed actions)
#     with NATS as the transport (vs
#     MCollective's STOMP/AMQP)
#   - BROKER + SERVER + CLIENT IN ONE BINARY
#     — `choria broker run` starts the
#     embedded NATS-based broker.  `choria
#     server run` starts the agent host.
#     `choria req <agent> <action>` is the
#     RPC client invocation.  All three modes
#     live in the same `choria` binary
#   - JETSTREAM-BACKED KV STORE — `choria kv`
#     provides a CLI over the NATS JetStream
#     KV store, used internally by Choria for
#     leadership election + machine plugin
#     state but also exposed for general use
#   - JETSTREAM-BACKED GOVERNOR — `choria
#     governor` is a rate-limiter built on
#     JetStream consumer back-pressure.
#     Operators use it to throttle large RPC
#     fan-outs (e.g. "patch 10k nodes but
#     only 50 in parallel")
#   - LEADERSHIP ELECTION — `choria election`
#     uses NATS JetStream KV to implement
#     distributed leader election for
#     multi-node Scout / autonomous agent
#     deployments
#   - JWT-BASED AUTH — `choria jwt` issues +
#     verifies JSON Web Tokens for client /
#     server / provisioner identities.  No
#     mTLS-only mode required; works in
#     dynamic cloud environments
#   - SCOUT MONITORING PIPELINE — `choria
#     scout` integrates with Scout, the
#     Choria-native monitoring service that
#     runs checks across the discovered
#     inventory and emits Prometheus + alert
#     metrics
#   - APPBUILDER FRAMEWORK — `choria` itself
#     uses the `choria-io/appbuilder` Go
#     framework to provide auto-generated
#     command-driven CLIs from a YAML
#     spec.  The same framework powers other
#     Choria-IO tools (e.g. `aaasvc`)
#   - FISK ARG PARSER — uses
#     `choria-io/fisk`, a Choria-maintained
#     fork of Kingpin (alecthomas/kingpin
#     is deprecated).  Fisk adds cheat-sheet
#     help via `choria cheat` and structured
#     command groups
#
# TOP-LEVEL SUBCOMMAND SURFACE (extracted from
# `cmd/` directory contents):
#   * broker       — start the embedded NATS-
#                    backed Choria broker
#   * server       — start a Choria agent
#                    server (the node that
#                    accepts RPC calls)
#   * req          — issue an RPC request to
#                    matching agents (the
#                    primary client cmd)
#   * ping         — round-trip ping all
#                    discovered nodes
#   * discover     — list nodes matching a
#                    discovery filter
#   * inventory    — fetch + render the
#                    inventory of matching
#                    nodes
#   * facts        — fetch a specific fact
#                    from matching nodes
#   * kv           — NATS JetStream KV store
#                    operations
#                    (add/api/backup/create/
#                    del/get/history/keys/
#                    list/purge/put/restore/
#                    status/update/watch)
#   * jwt          — JWT identity issue +
#                    verify
#                    (check/client/keys/
#                    provisioner/server/view)
#   * executor     — interact with the
#                    Choria executor for
#                    background process
#                    supervision
#                    (info/signal/watch)
#   * election     — leader-election helpers
#                    (evict/file/info/run)
#   * governor     — JetStream rate-limiter
#                    operations
#                    (add/api/delete/evict/
#                    list/reset/run/view)
#   * machine      — autonomous-agent
#                    "machine" plugins
#                    (graph/plugins/run/
#                    validate/watch/plugins-
#                    {add/matcher/pack/rm/
#                    verify})
#   * scout        — Choria Scout monitoring
#                    integration
#                    (maintenance/resume/
#                    status/trigger/validate/
#                    watch)
#   * tool         — miscellaneous developer
#                    utilities (builder/config/
#                    event/inventory/protocol/
#                    provisioner/sha256/status/
#                    submit)
#   * plugin       — plugin-development
#                    helpers (doc/generate/
#                    generate-client/
#                    generate-ddl/schema)
#   * enroll       — fetch a client token for
#                    AAA-server-backed
#                    deployments
#   * login        — start an interactive
#                    AAA login session
#   * completion   — emit shell completion
#                    scripts
#                    (bash/zsh/fish)
#   * buildinfo    — print version + build
#                    metadata
#   * cheat        — render cheat-sheet
#                    style help
#   * help         — print general help
#
# CRITICAL DIRECT DEPENDENCIES (from go.mod):
#   - github.com/nats-io/nats.go v1.52.0
#                              — canonical
#                                pure-Go NATS
#                                client
#                                [AXIS 48
#                                LIBRARY]
#   - github.com/nats-io/jsm.go v0.4.1
#                              — JetStream
#                                Manager API
#   - github.com/nats-io/nats-server/v2 v2.14.0
#                              — EMBEDDED
#                                full NATS
#                                server (so
#                                `choria
#                                broker run`
#                                does not need
#                                an external
#                                nats-server
#                                process)
#   - github.com/nats-io/natscli v0.4.0
#                              — natscli
#                                library
#                                reuse for
#                                shared CLI
#                                helpers
#   - github.com/choria-io/fisk
#                              — fisk argument
#                                parser
#                                (Kingpin
#                                fork)
#   - github.com/choria-io/appbuilder
#                              — YAML-spec ->
#                                auto-generated
#                                CLI framework
#   - github.com/hashicorp/raft (indirect via
#                                jsm.go)
#                              — used by
#                                embedded
#                                broker for
#                                cluster
#                                state
#   - github.com/AlecAivazis/survey/v2
#                              — interactive
#                                prompts (used
#                                by `choria
#                                enroll` +
#                                `choria login`)
#   - github.com/awesome-gocui/gocui v1.1
#                              — TUI library
#                                (used by
#                                Scout +
#                                interactive
#                                inventory
#                                browsing)
#   - github.com/sirupsen/logrus
#                              — structured
#                                logging
#
# Go 1.25.0+ MSRV per go.mod `go 1.25.0`.
#
# UPSTREAM:
#   * Project home       : https://choria.io
#   * Source             : https://github.com/choria-io/go-choria
#   * Docs               : https://choria-io.github.io/go-choria/
#   * nats.go            : https://github.com/nats-io/nats.go
#   * License            : Apache-2.0
#   * Maintainer         : R.I. Pienaar
#
# INSTALL:
#   # From source
#   go install github.com/choria-io/go-choria@latest
#
#   # Pre-built binaries (Linux/macOS/Windows)
#   curl -sSL https://choria.io/install.sh | bash
#
#   # Docker
#   docker pull choria/choria:latest
#
# USAGE EXAMPLES:
#
#   # Print version + build metadata
#   choria buildinfo
#
#   # Cheat-sheet help
#   choria cheat
#
#   # Discover all Linux nodes
#   choria discover --filter os::operatingsystem=Linux
#
#   # Ping all discovered nodes
#   choria ping
#
#   # Fetch a fact from all nodes
#   choria facts os.lsb
#
#   # Full inventory of matching nodes
#   choria inventory --filter os::family=RedHat
#
#   # Run an RPC against the `puppet` agent
#   choria req puppet status --filter os::family=RedHat
#
#   # Run RPC with explicit batch size
#   choria req package install package=nginx \
#       --batch 50 --batch-sleep 5s
#
#   # JetStream KV: create + write + read
#   choria kv create my-config --replicas 3
#   choria kv put my-config db.host=db.local
#   choria kv get my-config db.host
#   choria kv watch my-config
#
#   # Issue a client JWT for a new operator
#   choria jwt client alice \
#       --token-file alice.jwt \
#       --validity 24h
#
#   # Start the embedded broker
#   choria broker run --config /etc/choria/broker.conf
#
#   # Start a Choria server (agent host)
#   choria server run --config /etc/choria/server.conf
#
#   # Choria Scout monitoring
#   choria scout status --filter scout=ssh
#
#   # Run a governor-throttled large fan-out
#   choria governor add deploys --limit 50
#   choria req puppet runonce \
#       --governor deploys
#
#   # Leader election lifecycle
#   choria election run my-app
#   choria election info my-app
#
#   # Emit zsh completion script
#   choria completion zsh > _choria
#
# OPTIONS (sourced directly from
# https://github.com/choria-io/go-choria/blob/main/cmd/cmd.go):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _choria_commands
_choria_commands=(
    'broker:Run the embedded Choria broker (NATS-backed)'
    'server:Run a Choria agent server'
    'req:Issue an RPC request to matching agents'
    'ping:Round-trip ping discovered nodes'
    'discover:List nodes matching a discovery filter'
    'inventory:Fetch + render the inventory of matching nodes'
    'facts:Fetch a specific fact from matching nodes'
    'kv:NATS JetStream KV store operations'
    'jwt:Issue + verify JWT identities'
    'executor:Interact with the Choria executor for background processes'
    'election:Leader-election helpers'
    'governor:JetStream rate-limiter operations'
    'machine:Autonomous-agent machine plugins'
    'scout:Choria Scout monitoring integration'
    'tool:Miscellaneous developer utilities'
    'plugin:Plugin-development helpers'
    'enroll:Fetch a client token for AAA-server-backed deployments'
    'login:Start an interactive AAA login session'
    'completion:Emit shell completion scripts (bash/zsh/fish)'
    'buildinfo:Print version + build metadata'
    'cheat:Render cheat-sheet style help'
    'help:Print general help'
)

local -a _choria_kv_actions
_choria_kv_actions=(
    'add:Create or update a value in a KV bucket'
    'api:Print the underlying NATS API call for a KV op'
    'backup:Backup a KV bucket to disk'
    'create:Create a new KV bucket'
    'del:Delete a key from a KV bucket'
    'get:Read a value from a KV bucket'
    'history:Print value history for a key'
    'keys:List keys in a KV bucket'
    'list:List KV buckets'
    'purge:Purge all keys from a KV bucket'
    'put:Write a value to a KV bucket'
    'restore:Restore a KV bucket from a backup'
    'status:Bucket status + metadata'
    'update:Atomically update a value (CAS)'
    'watch:Stream changes from a KV bucket'
)

local -a _choria_jwt_actions
_choria_jwt_actions=(
    'check:Verify a JWT signature'
    'client:Issue a client JWT'
    'keys:Generate signing keypairs'
    'provisioner:Issue a provisioner JWT'
    'server:Issue a server JWT'
    'view:Print JWT claims'
)

local -a _choria_election_actions
_choria_election_actions=(
    'evict:Force-evict the current leader'
    'file:Use a file-backed election (single-host fallback)'
    'info:Print the current election state'
    'run:Participate in an election'
)

local -a _choria_governor_actions
_choria_governor_actions=(
    'add:Create a new governor'
    'api:Print the underlying NATS API call for a governor op'
    'delete:Delete a governor'
    'evict:Evict a slot holder'
    'list:List configured governors'
    'reset:Reset a governor (clear all slots)'
    'run:Wrap a command in governor acquire/release'
    'view:Inspect governor state'
)

local -a _choria_scout_actions
_choria_scout_actions=(
    'maintenance:Place a check in maintenance mode'
    'resume:Resume a check from maintenance'
    'status:Print check status across discovered nodes'
    'trigger:Force-trigger a check'
    'validate:Validate a Scout check definition'
    'watch:Stream check status changes'
)

local -a _choria_completion_shells
_choria_completion_shells=(
    'bash:Bash completion script'
    'zsh:Zsh completion script'
    'fish:Fish completion script'
)

_arguments -C \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--debug[enable debug logging]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'choria command' _choria_commands && ret=0
        ;;
    args)
        case $line[1] in
            kv)
                _arguments -C \
                    '(-): :->kvaction' \
                    '(-)*:: :->kvargs' \
                    && ret=0
                case $state in
                    kvaction)
                        _describe -t actions 'choria kv action' _choria_kv_actions && ret=0 ;;
                esac
                ;;
            jwt)
                _arguments -C \
                    '(-): :->jwtaction' \
                    '(-)*:: :->jwtargs' \
                    && ret=0
                case $state in
                    jwtaction)
                        _describe -t actions 'choria jwt action' _choria_jwt_actions && ret=0 ;;
                esac
                ;;
            election)
                _arguments -C \
                    '(-): :->elaction' \
                    '(-)*:: :->elargs' \
                    && ret=0
                case $state in
                    elaction)
                        _describe -t actions 'choria election action' _choria_election_actions && ret=0 ;;
                esac
                ;;
            governor)
                _arguments -C \
                    '(-): :->goaction' \
                    '(-)*:: :->goargs' \
                    && ret=0
                case $state in
                    goaction)
                        _describe -t actions 'choria governor action' _choria_governor_actions && ret=0 ;;
                esac
                ;;
            scout)
                _arguments -C \
                    '(-): :->scaction' \
                    '(-)*:: :->scargs' \
                    && ret=0
                case $state in
                    scaction)
                        _describe -t actions 'choria scout action' _choria_scout_actions && ret=0 ;;
                esac
                ;;
            completion)
                _arguments -C \
                    '(-): :->shell' \
                    && ret=0
                case $state in
                    shell)
                        _describe -t shells 'shell' _choria_completion_shells && ret=0 ;;
                esac
                ;;
            broker)
                _arguments -C \
                    '1:subcommand:(run)' \
                    '--config=[path to broker.conf]:file:_files -g "*.(conf|cfg|yaml|yml)"' \
                    '--debug[enable debug logging]' \
                    && ret=0
                ;;
            server)
                _arguments -C \
                    '1:subcommand:(run)' \
                    '--config=[path to server.conf]:file:_files -g "*.(conf|cfg|yaml|yml)"' \
                    '--debug[enable debug logging]' \
                    && ret=0
                ;;
            req)
                _arguments -C \
                    '--config=[path to choria client config]:file:_files -g "*.(conf|cfg|yaml|yml)"' \
                    '*--filter=[discovery filter (repeatable, e.g. os::family=RedHat)]:filter: ' \
                    '*-W+[fact-based filter shortcut]:fact filter: ' \
                    '*-C+[class-based filter shortcut]:class filter: ' \
                    '*-A+[agent-based filter shortcut]:agent filter: ' \
                    '*-I+[identity-based filter shortcut]:identity filter: ' \
                    '--batch=[batch size for RPC fan-out]:n: ' \
                    '--batch-sleep=[sleep between batches]:duration: ' \
                    '--governor=[governor to throttle the call]:governor: ' \
                    '--timeout=[RPC timeout]:duration: ' \
                    '--json[emit JSON response objects]' \
                    '--debug[enable debug logging]' \
                    '*:agent action:_files' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
