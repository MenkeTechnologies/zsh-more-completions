#compdef winnowmap
# Documentation: https://github.com/marbl/Winnowmap
# Winnowmap: long-read mapping using weighted minimizers (minimap2 fork)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-W+[file of high-frequency k-mers to down-weight]:kmer file:_files' \
  '-k+[minimizer k-mer length]:k:' \
  '-w+[minimizer window size]:window:' \
  '-H[use homopolymer-compressed minimizers]' \
  '-I+[load at most NUM target bases into RAM for indexing]:size:' \
  '-d+[save minimizer index to file]:index file:_files' \
  '-x+[preset]:preset:(map-ont map-pb map-hifi asm5 asm10 asm20 ava-ont ava-pb splice sr)' \
  '-g+[stop chain enlongation if no minimizers within NUM-bp]:num:' \
  '-r+[bandwidth for chaining and base alignment]:num:' \
  '-n+[discard chains with < INT minimizers]:int:' \
  '-m+[discard chains with chaining score < INT]:int:' \
  '-p+[minimal secondary-to-primary score ratio]:float:' \
  '-N+[output at most INT secondary alignments]:int:' \
  '-A+[matching score]:int:' \
  '-B+[mismatching penalty]:int:' \
  '-O+[gap open penalty]:int:' \
  '-E+[gap extension penalty]:int:' \
  '-z+[truncate alignment on X-drop]:int:' \
  '-s+[minimal peak DP alignment score to output]:int:' \
  '-a[output in SAM format]' \
  '-o+[output alignments to file]:output:_files' \
  '-Q[ignore base quality]' \
  '-L[write long CIGAR strings to CG tag]' \
  '-R+[SAM read group line]:rg:' \
  '-c[generate CIGAR string]' \
  '--cs=[output cs tag for differences]:mode:(short long)' \
  '--MD[output MD tag]' \
  '-Y[use soft clipping for supplementary alignments]' \
  '-t+[number of threads]:threads:' \
  '-K+[number of bases in mini-batch]:size:' \
  '*:reference and reads:_files' && ret=0

return ret
