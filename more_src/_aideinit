#compdef aideinit
# Documentation: https://man.archlinux.org/search?q=aideinit
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-f[force update of database]' \
  '-y[no prompts, assume yes]' \
  '-c+[config file]:file:_files' \
  '-d+[database directory]:dir:_files -/' && ret=0

return ret
