#compdef aideinit
# Documentation: https://manpages.debian.org/testing/aide-common/aideinit.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-f[force update of database]' \
  '-y[no prompts, assume yes]' \
  '-c+[config file]:file:_files' \
  '-d+[database directory]:dir:_files -/' && ret=0

return ret
