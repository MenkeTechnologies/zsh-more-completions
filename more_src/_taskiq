#compdef taskiq

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'worker:run taskiq workers'
      'scheduler:run the scheduler'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (worker)
        _arguments \
          '(-w --workers)'{-w,--workers}'=[number of workers]:workers:' \
          '--max-async-tasks=[max concurrent async tasks]:count:' \
          '--no-parse[do not parse CLI for broker]' \
          '--fs-discover[discover tasks from filesystem]' \
          '--tasks-pattern=[task file glob pattern]:pattern:' \
          '--log-level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
          '(-r --reload)'{-r,--reload}'[auto-reload on file changes]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '--shutdown-timeout=[shutdown timeout in seconds]:seconds:' \
          '--no-gitignore[do not use .gitignore for discovery]' \
          '1:broker module path:' && ret=0
        ;;
      (scheduler)
        _arguments \
          '--log-level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
          '--fs-discover[discover tasks from filesystem]' \
          '--tasks-pattern=[task file glob pattern]:pattern:' \
          '(-r --reload)'{-r,--reload}'[auto-reload on file changes]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '1:scheduler module path:' && ret=0
        ;;
    esac
    ;;
esac

return ret
