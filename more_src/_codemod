#compdef codemod

# Zsh completion for codemod (large-scale code refactoring)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:Run a codemod or set of codemods'
      'learn:Learn a codemod from before/after examples'
      'list:List available codemods'
      'search:Search for codemods in the registry'
      'publish:Publish a codemod to the registry'
      'unpublish:Remove a codemod from the registry'
      'login:Login to the codemod registry'
      'logout:Logout from the codemod registry'
      'init:Initialize a new codemod project'
      'feedback:Send feedback about a codemod'
    )
    _describe -t commands 'codemod command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      run)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-t+[Target path to apply codemod]:path:_files' \
          '--target=[Target path to apply codemod]:path:_files' \
          '-s+[Source path of codemod]:path:_files' \
          '--source=[Source path of codemod]:path:_files' \
          '--dry[Dry run without making changes]' \
          '-n+[Codemod name from registry]:name' \
          '--name=[Codemod name from registry]:name' \
          '--no-cache[Disable caching]' \
          '--no-format[Skip formatting after transform]' \
          '--threads=[Number of worker threads]:count' \
          '--json[Output results as JSON]' \
          '*:files:_files' && ret=0
        ;;
      learn)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--before=[Path to before example]:file:_files' \
          '--after=[Path to after example]:file:_files' \
          '-o+[Output path for generated codemod]:file:_files' \
          '--output=[Output path for generated codemod]:file:_files' && ret=0
        ;;
      search)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:query' && ret=0
        ;;
      publish)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-s+[Source directory]:dir:_directories' \
          '--source=[Source directory]:dir:_directories' && ret=0
        ;;
      init)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--engine=[Codemod engine]:engine:(jscodeshift ts-morph ast-grep piranha filemod)' \
          '1:target-path:_directories' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
