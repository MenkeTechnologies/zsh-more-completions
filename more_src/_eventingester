#compdef eventingester armada-event-ingester
# _eventingester — Armada Event Ingester (consumes job events from Pulsar and persists them to the events Postgres store)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/eventingester/main.go on tip; everything else lives in the YAML config (./config/eventingester or --config).

_eventingester() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[application configuration file (repeatable; comma-separated paths also accepted)]:file:_files -g "*.yaml"'
}

_eventingester "$@"
