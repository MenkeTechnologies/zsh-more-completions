#compdef tempura
# _tempura — fast / flexible template fill tool (korosuke613/tempura)
# upstream: https://github.com/korosuke613/tempura
# Flags from cmd/root.go (cobra).

_tempura() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '(-i --input-filepath)'{-i+,--input-filepath=}'[input JSON/YAML/TOML file (default input.json)]:file:_files'
        '(-t --template-filepath)'{-t+,--template-filepath=}'[template file (default template.tmpl)]:file:_files'
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files'
        '--input-string=[input data as a raw string]:string:'
        '--template-string=[template as a raw string]:string:'
    )
    _arguments -s $args
}

_tempura "$@"
