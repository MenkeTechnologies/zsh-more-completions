#compdef verifier deps.dev-verifier scorecard-verifier
# _verifier — DepsDev / Scorecard verifier checks supply chain provenance and policies CLI alias (Google / OSSF, Go); spf13/cobra
# upstream: https://github.com/ossf/scorecard

_verifier() {
    local -a sub=(
        'verify:run verification'
        'check:check policy'
        'attest:produce attestation'
        'sign:sign artifact'
        'inspect:inspect artifact'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--policy=+[policy file]:file:_files' \
        '--policy-name=+[policy name]:str:' \
        '--certificate=+[certificate]:file:_files' \
        '--source-uri=+[source URI]:url:_urls' \
        '--source-branch=+[source branch]:str:' \
        '--source-tag=+[source tag]:str:' \
        '--source-versioned-tag=+[source versioned tag]:str:' \
        '--builder-id=+[builder id]:str:' \
        '--build-workflow-input=+[build workflow input key=value]:list:' \
        '--print-provenance[print provenance]' \
        '--format=+[format]:fmt:(json yaml text sarif)' \
        '-f+[format]:fmt:(json yaml text sarif)' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--rekor-url=+[rekor URL]:url:_urls' \
        '--fulcio-url=+[fulcio URL]:url:_urls' \
        '--bundle=+[bundle file]:file:_files' \
        '--provenance-path=+[provenance path]:file:_files' \
        '--artifact-path=+[artifact path]:file:_files' \
        '--no-bundle[no bundle]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'verifier subcommand' sub ;;
        args)
            case $words[1] in
                verify|check|inspect) _arguments \
                    '*:artifact:_files' ;;
                attest|sign) _arguments \
                    '--predicate=+[predicate]:file:_files' \
                    '--output=+[output]:file:_files' \
                    '*:artifact:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_verifier "$@"
