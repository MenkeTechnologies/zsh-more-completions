#compdef fftprof
# Documentation: https://docs.abinit.org/developers/testsuite_howto/
# fftprof - ABINIT FFT benchmarking tool (reads namelist config from stdin)

local ret=1

_arguments -s -S \
  '--abimem-level=-[set memory profiling level]:level:(0 1 2 3 4)' \
  '--abimem-limit-mb=-[log malloc/free only above limit in MB]:mb:' \
  '*:input file:_files' && ret=0

return ret
