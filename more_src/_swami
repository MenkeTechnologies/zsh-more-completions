#compdef swami swamiproject
# _swami — Josh Green Swami SoundFont editor and player using libInstPatch for SF2 SF3 DLS GIG instrument editing with FluidSynth audio (swami team, C/GTK); GOption
# upstream: https://github.com/swami/swami

_swami() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--help-all[show all help]' \
        '--help-gtk[GTK help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-N+[plugin path]:dir:_files -/' \
        '--plugin-path=+[plugin path]:dir:_files -/' \
        '-p+[preset]:str:' \
        '--preset=+[preset]:str:' \
        '-c+[config file]:file:_files' \
        '--config=+[config file]:file:_files' \
        '-l+[load file]:file:_files -g "*.sf2 *.sf3 *.dls *.gig *.swami"' \
        '--load=+[load file]:file:_files -g "*.sf2 *.sf3 *.dls *.gig *.swami"' \
        '-a+[audio driver]:d:(alsa pulseaudio jack coreaudio dsound wasapi waveout file)' \
        '--audio-driver=+[audio driver]:d:(alsa pulseaudio jack coreaudio dsound wasapi waveout file)' \
        '-D+[audio device]:str:' \
        '--audio-device=+[audio device]:str:' \
        '-r+[sample rate]:n:(22050 44100 48000 88200 96000)' \
        '--sample-rate=+[sample rate]:n:(22050 44100 48000 88200 96000)' \
        '-m+[midi driver]:d:(alsa_seq alsa_raw jack winmidi coremidi oss)' \
        '--midi-driver=+[midi driver]:d:(alsa_seq alsa_raw jack winmidi coremidi oss)' \
        '*:soundfont file:_files -g "*.sf2 *.sf3 *.dls *.gig *.swami *.iiwu"'
}

_swami "$@"
