#compdef mjml
# Documentation: https://man.archlinux.org/search?q=mjml
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --read)'{-r+,--read=}'[read MJML file]:file:_files -g "*.mjml"' \
  '(-w --watch)'{-w,--watch}'[watch and rebuild on change]' \
  '(-i --stdin)'{-i,--stdin}'[read MJML from stdin]' \
  '(-s --stdout)'{-s,--stdout}'[write to stdout]' \
  '(-o --output)'{-o+,--output=}'[output file or directory]:path:_files' \
  '(-l --validation-level)'{-l+,--validation-level=}'[validation level]:lvl:(strict soft skip)' \
  '--noStdoutFileComment[no file comment in stdout]' \
  '--config.beautify=[beautify HTML]:bool:(true false)' \
  '--config.minify=[minify HTML]:bool:(true false)' \
  '--config.minifyOptions=[minify options JSON]:json:' \
  '--config.fonts=[default fonts JSON]:json:' \
  '--config.keepComments=[keep comments]:bool:(true false)' \
  '--config.juicePreserveTags=[preserve tags JSON]:json:' \
  '--config.juiceOptions=[juice options JSON]:json:' \
  '--config.filePath=[file path]:path:_files' \
  '--config.mjmlConfigPath=[mjml config dir]:dir:_files -/' \
  '*:MJML file:_files -g "*.mjml"' && ret=0

return ret
