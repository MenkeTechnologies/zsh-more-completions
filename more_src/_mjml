#compdef mjml
# Documentation: https://github.com/mjmlio/mjml/blob/master/packages/mjml-cli/src/client.js
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '(- *)--version[show version]' \
  '*'{-r+,--read=}'[compile MJML file]:file:_files -g "*.mjml"' \
  '*'{-v+,--validate=}'[run validator on file]:file:_files -g "*.mjml"' \
  '*'{-w+,--watch=}'[watch and compile MJML file on change]:file:_files' \
  '(-i --stdin)'{-i,--stdin}'[read MJML from stdin]' \
  '(-s --stdout)'{-s,--stdout}'[write to stdout]' \
  '(-o --output)'{-o+,--output=}'[output file or directory]:path:_files' \
  '--noStdoutFileComment[no file comment in stdout]' \
  '--sanitizeStyles[sanitize template variables inside CSS]' \
  '--config.allowIncludes=[enable mj-include processing]:bool:(true false)' \
  '--config.allowMixedSyntax=[allow mixing block and CSS tokens]:bool:(true false)' \
  '--config.beautify=[beautify HTML]:bool:(true false)' \
  '--config.minify=[minify HTML]:bool:(true false)' \
  '--config.minifyOptions=[minify options JSON]:json' \
  '--config.fonts=[default fonts JSON]:json' \
  '--config.keepComments=[keep comments]:bool:(true false)' \
  '--config.juicePreserveTags=[preserve tags JSON]:json' \
  '--config.juiceOptions=[juice options JSON]:json' \
  '--config.filePath=[file path]:path:_files' \
  '--config.includePath=[include root directories allowlist]:path:_files -/' \
  '--config.mjmlConfigPath=[mjml config dir]:dir:_files -/' \
  '--config.sanitizeStyles=[sanitize CSS for templating syntax]:bool:(true false)' \
  '--config.stack=[print full error stack trace]:bool:(true false)' \
  '--config.templateSyntax=[templating delimiters]:syntax' \
  '--config.useMjmlConfigOptions=[use mjmlconfig options attribute]:bool:(true false)' \
  '--config.validationLevel=[validation level]:lvl:(strict soft skip)' \
  '*:MJML file:_files -g "*.mjml"' && ret=0

return ret
