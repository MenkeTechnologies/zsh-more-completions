#compdef landsatxplore
# Documentation: https://github.com/yannforget/landsatxplore
# search and download Landsat scenes from EarthExplorer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:command:->cmds' && ret=0

case $state in
  cmds)
    if (( CURRENT == 2 )); then
      _values 'landsatxplore command' \
        'search[search for Landsat scenes]' \
        'download[download one or several Landsat scenes]'
    else
      case $words[2] in
        search)
          _arguments -s \
            '(-u --username)'{-u,--username}'=[EarthExplorer username]:username:' \
            '(-p --password)'{-p,--password}'=[EarthExplorer password]:password:' \
            '(-d --dataset)'{-d,--dataset}'=[Landsat dataset]:dataset:' \
            '(-l --location)'{-l,--location}'=[point of interest (lat lon)]:location:' \
            '(-b --bbox)'{-b,--bbox}'=[bounding box (xmin ymin xmax ymax)]:bbox:' \
            '(-c --clouds)'{-c,--clouds}'=[max cloud cover (1-100)]:clouds:' \
            '(-s --start)'{-s,--start}'=[start date (YYYY-MM-DD)]:date:' \
            '(-e --end)'{-e,--end}'=[end date (YYYY-MM-DD)]:date:' \
            '(-o --output)'{-o,--output}'=[output format]:format:(entity_id display_id json csv)' \
            '(-m --limit)'{-m,--limit}'=[max number of results]:limit:' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        download)
          _arguments -s \
            '(-u --username)'{-u,--username}'=[EarthExplorer username]:username:' \
            '(-p --password)'{-p,--password}'=[EarthExplorer password]:password:' \
            '(-d --dataset)'{-d,--dataset}'=[Landsat dataset]:dataset:' \
            '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:scene id:'
          ;;
      esac
    fi
    ;;
esac

return ret
