#compdef statal
# statAl: alignment statistics tool (part of the trimAl suite)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show statAl version]' \
  {-i,-in}'[input alignment file]:file:_files' \
  '-compareset[file with several alignment paths to compare]:file:_files' \
  '-forceselect[force selection of a reference alignment]:file:_files' \
  '-matrix[input similarity matrix file]:file:_files' \
  '-sgc[print gap score per column]' \
  '-sgt[print gap scores distribution]' \
  '-ssc[print similarity score per column]' \
  '-sst[print similarity scores distribution]' \
  '-sfc[print sum-of-pairs score per column]' \
  '-sft[print sum-of-pairs scores distribution]' \
  '-sident[print sequence identity scores]' \
  '-scolidentt[print column identity descriptive statistics]' \
  '-w[half window size]:size:' \
  '-gw[gap window size]:size:' \
  '-sw[similarity window size]:size:' \
  '-cw[consistency window size]:size:' && ret=0

return ret
