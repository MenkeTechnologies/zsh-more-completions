#compdef scil_tractogram_assign_custom_color
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_tractogram_assign_custom_color.html
# Assign custom color to a tractogram

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--reference=[reference anatomy for file support]:nifti:_files -g "*.nii *.nii.gz"' \
  '--out_colorbar=[save colorbar image]:file:_files' \
  '--show_colorbar[display the colorbar (requires --out_colorbar)]' \
  '--horizontal_cbar[render colorbar horizontally]' \
  '--use_dps=[use data_per_streamline scalar]:dps_key' \
  '--use_dpp=[use data_per_point scalar]:dpp_key' \
  '--load_dps=[load data_per_streamline from file]:file:_files' \
  '--load_dpp=[load data_per_point from file]:file:_files' \
  '--from_anatomy=[use voxel data for coloring]:file:_files' \
  '--along_profile[color by point position along streamline length]' \
  '--local_orientation[color by local orientation]' \
  '--local_angle[color by angle between segments]' \
  '--ambiant_occlusion=[ambient occlusion impact factor]:factor' \
  '--colormap=[colormap or custom color combination]:colormap' \
  '--clip_outliers[remove first and last 5% quantile values]' \
  '--min_range=[minimum data value threshold]:min' \
  '--max_range=[maximum data value threshold]:max' \
  '--min_cmap=[colormap minimum value]:min' \
  '--max_cmap=[colormap maximum value]:max' \
  '--log[apply base-10 logarithm transformation]' \
  '--LUT=[lookup table for integer label substitution]:file:_files -g "*.npy *.txt"' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[force overwrite of output files]' \
  '1:in_tractogram:_files -g "*.trk *.tck"' \
  '2:out_tractogram:_files -g "*.trk *.tck"' && ret=0

return ret
