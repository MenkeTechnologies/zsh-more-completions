#compdef capinfos
# _capinfos-bin — Wireshark capture-file statistics tool; print metadata about pcap files
# upstream: https://gitlab.com/wireshark/wireshark

_capinfos-bin() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-t[show file type]' \
        '-E[show encapsulation]' \
        '-I[show interface count]' \
        '-F[show additional file info]' \
        '-c[show packet count]' \
        '-s[show file size]' \
        '-d[show data byte size]' \
        '-l[show packet sizes]' \
        '-u[show capture duration]' \
        '-a[show start time]' \
        '-e[show end time]' \
        '-o[show ordering]' \
        '-y[show data rates]' \
        '-i[show bit rates]' \
        '-z[show byte average]' \
        '-x[show byte rate]' \
        '-S[machine-readable formats]' \
        '-N[set name]' \
        '-A[show stats info]' \
        '-T[generate table report]' \
        '-r[do not generate header in table report]' \
        '-B[separate stats by header row in table report]' \
        '-m[separator char]:c:' \
        '-b[print with binary]' \
        '-q[print with quote]' \
        '-Q[print without trailing newline]' \
        '-M[print with mu prefix]' \
        '-k[show file comments]' \
        '-K[show packet comments]' \
        '-p[parse pcap header info]' \
        '-G[show all hashes]' \
        '-D[show data byte rate]' \
        '-H[show hash sha256]' \
        '*:file:_files'
}

_capinfos-bin "$@"
