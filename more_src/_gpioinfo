#compdef gpioinfo
# _gpioinfo — Bartosz Golaszewski libgpiod gpioinfo CLI for inspecting GPIO chips and their lines printing per-line name consumer direction active-state used kernel-claimed flags for diagnostics (linux team, C); getopt
# upstream: https://git.kernel.org/pub/scm/libs/libgpiod/libgpiod.git

_gpioinfo() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*:chips:'
}

_gpioinfo "$@"
