#compdef samtools-fqidx
# Documentation: http://www.htslib.org/doc/samtools-fqidx.html
# samtools fqidx: Index a FASTQ file for random access

local ret=1

_arguments -s -S \
  '(-o --output)'{-o,--output}'[Write FASTQ to file rather than to stdout. If FILE ends with .gz, .bgz]:FILE:_files' \
  '(-n --length)'{-n,--length}'[Length for FASTQ sequence line wrapping. If zero, this means do not li]:INT: ' \
  '(-c --continue)'{-c,--continue}'[Continue working if a non-existent region is requested.]' \
  '(-r --region-file)'{-r,--region-file}'[Read regions from a file. Format is chr\:from-to, one per line.]:FILE:_files' \
  '(-i --reverse-complement)'{-i,--reverse-complement}'[Output the sequence as the reverse complement. When this option is use]' \
  '(--mark-strand)'--mark-strand'[Append strand indicator to sequence name. TYPE can be one of\: rc Appen]:TYPE: ' \
  '(--fai-idx)'--fai-idx'[Read/Write to specified index file.]:FILE:_files' \
  '(--gzi-idx)'--gzi-idx'[Read/Write to specified compressed file index (used with .gz files).]:FILE:_files' \
  '(-h --help)'{-h,--help}'[Print help message and exit.]' \
  '(--output-fmt-option)'--output-fmt-option'[Set the output format options, level=0..9 for compression level 0 to 9]:OPTVAL: ' \
  '(--write-index)'--write-index'[Create index for the output sequence data along with the output, in sa]' \
  '(--threads)'--threads'[Set the number of extra threads for operations on compressed files.]:N: ' \
  '*:file:_files' && ret=0

return ret
