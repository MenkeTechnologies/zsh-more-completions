#compdef ahoy

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize .ahoy.yml'
)

_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-f --file)'{-f,--file}'=[ahoy file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--generate-bash-completion[generate completions]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'ahoy subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (init) _arguments '--force[force overwrite]' && ret=0 ;;
    esac ;;
esac

return ret
