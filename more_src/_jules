#compdef jules
# Documentation: https://jules.google/docs/cli/reference/
# Reference accessed: 2026-05-22
# Verified: @google/jules npm package command reference.

# Zsh completion for jules - Google Jules async coding agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--theme[UI theme]:theme:(dark light)' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'jules command' \
      'login[authenticate Google account]' \
      'logout[remove saved credentials]' \
      'new[create a Jules session]' \
      'remote[manage remote sessions]' \
      'version[show CLI version]' \
      'completion[generate shell completions]' \
      'help[show help]' && ret=0
    ;;
  args)
    case $line[1] in
      new)
        _arguments \
          '--repo[GitHub repository]:repo:' \
          '--parallel[parallel session count]:n:' \
          '1:task:' && ret=0
        ;;
      remote)
        case $line[2] in
          new)
            _arguments \
              '--repo[GitHub repository]:repo:' \
              '--session[session description]:text:' \
              '1:task:' && ret=0
            ;;
          list)
            _arguments \
              '--repo[list connected repositories]' \
              '--session[list active sessions]' && ret=0
            ;;
          pull)
            _arguments '--session[session ID]:id:' && ret=0
            ;;
          *)
            _values 'remote command' new list pull && ret=0
            ;;
        esac
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      login|logout|version|help)
        ret=0
        ;;
    esac
    ;;
esac

return ret
