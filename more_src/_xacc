#compdef xacc xacc-cli
# _xacc — ORNL eXtreme-scale ACCelerator XACC programming framework for hybrid quantum-classical computing with multiple backends (eclipse team, C++); custom argparse
# upstream: https://github.com/eclipse/xacc

_xacc() {
    local -a sub=(
        'install:install plugin'
        'uninstall:uninstall plugin'
        'list:list plugins'
        'config:configuration subcommands'
        'execute:execute a program'
        'compile:compile a program'
        'simulate:simulate a program'
        'analyze:analyze a program'
        'translate:translate between formats'
        'translate-to=:translate-to subcommands'
        'info:show installation info'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--accelerator=+[accelerator]:a:(qpp aer ibm rigetti ionq oqc honeywell quantinuum braket tnqvm dwave staq qasm qsim qibo)' \
        '-a+[accelerator]:a:(qpp aer ibm rigetti ionq oqc honeywell quantinuum braket tnqvm)' \
        '--shots=+[shots]:n:' \
        '-s+[shots]:n:' \
        '--qubits=+[N]:n:' \
        '--backend=+[backend name]:str:' \
        '-b+[backend name]:str:' \
        '--compiler=+[compiler]:c:(quil openqasm staq quil pyquil pulse xacc)' \
        '-c+[compiler]:c:(quil openqasm staq quil pyquil pulse xacc)' \
        '--source=+[source language]:l:(quil openqasm staq pulse xacc)' \
        '--target=+[target language]:l:(quil openqasm staq pulse xacc)' \
        '--algorithm=+[algorithm]:a:(vqe qaoa rbm ddcl qite qite-pauli vqe-energies ibm-vqe-energies)' \
        '--observable=+[observable]:str:' \
        '--optimizer=+[optimizer]:o:(nlopt mlpack scipy cma-es)' \
        '--max-iters=+[N]:n:' \
        '--plugin-dir=+[plugin dir]:dir:_files -/' \
        '--config-file=+[config file]:file:_files -g "*.cfg *.ini *.json"' \
        '--no-progress-bar[no progress bar]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xacc subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall) _arguments '*:plugin name:' ;;
                list) _arguments '1:list cmd:(plugins compilers accelerators algorithms observables optimizers irtransformations)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                execute|compile|simulate|analyze) _arguments \
                    '*:program:_files -g "*.quil *.qasm *.py *.staq *.xacc"' ;;
                translate|translate-to) _arguments \
                    '--from=+[source lang]:l:(quil openqasm staq pulse xacc)' \
                    '--to=+[target lang]:l:(quil openqasm staq pulse xacc)' \
                    '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_xacc "$@"
