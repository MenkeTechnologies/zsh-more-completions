#compdef qmail-tcpok
# _qmail-tcpok — qmail's IP timeout-cache reset (erases qmail-remote's current list of SMTP-connect-timeout IPs so it stops avoiding them; must run as root or user qmailr+group qmail)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-tcpok.8 on tip; no flags.

_qmail-tcpok() {
    _arguments '(- *)-h[show help]'
}

_qmail-tcpok "$@"
