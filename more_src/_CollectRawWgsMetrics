#compdef CollectRawWgsMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectRawWgsMetrics
# Picard: collect raw whole-genome sequencing coverage metrics (unfiltered)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output metrics file]:file:_files' \
  {-R=,--REFERENCE_SEQUENCE=}'[reference sequence FASTA]:fasta:_files -g "*.(fa|fasta)"' \
  {-MQ=,--MINIMUM_MAPPING_QUALITY=}'[minimum mapping quality to contribute coverage]:int:' \
  {-Q=,--MINIMUM_BASE_QUALITY=}'[minimum base quality to contribute coverage]:int:' \
  {-CAP=,--COVERAGE_CAP=}'[treat coverage above this value as if at this value]:int:' \
  '--LOCUS_ACCUMULATION_CAP=[ignore reads accumulating beyond this coverage]:int:' \
  '--STOP_AFTER=[stop after processing N loci]:int:' \
  '--INCLUDE_BQ_HISTOGRAM=[include a base-quality histogram in the output]:bool:(true false)' \
  '--COUNT_UNPAIRED=[count reads even if not part of a pair]:bool:(true false)' \
  '--SAMPLE_SIZE=[sample size for theoretical sensitivity]:int:' \
  '--INTERVALS=[optional interval list to restrict analysis to]:interval_list:_files -g "*.interval_list"' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
