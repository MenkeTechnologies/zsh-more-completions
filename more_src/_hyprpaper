#compdef hyprpaper

# Zsh completion for hyprpaper (Hyprland wallpaper utility)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  '--no-fractional[disable fractional scaling]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
