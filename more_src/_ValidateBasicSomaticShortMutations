#compdef ValidateBasicSomaticShortMutations
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/validation/basicshortmutpileup/ValidateBasicSomaticShortMutations.java
# GATK4: validate somatic short mutation calls against a validation BAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-I --input)'{-I,--input}'[input BAM/CRAM file]:file:_files -g "*.(bam|cram|sam)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '--discovery-sample-name=[sample name for discovery in VCF]:name:' \
  '(-O --output)'{-O,--output}'[output validation table (tsv)]:file:_files' \
  '--annotated-vcf=[optional output vcf with original variants annotated with validation info]:file:_files -g "*.(vcf|vcf.gz)"' \
  '--summary=[table of summary statistics]:file:_files' \
  '--min-power=[minimum power for an unvalidated variant to be a false positive]:val:' \
  '--max-validation-normal-count=[maximum read count in validation normal for a variant to validate]:n:' \
  '--val-case-sample-name=[validation case sample name in the bam]:name:' \
  '--val-control-sample-name=[validation control sample name in the bam]:name:' \
  '--min-base-quality-cutoff=[minimum base quality to count a read toward validation]:n:' \
  '*:options:_files' && ret=0

return ret
