#compdef emowse
# Documentation: https://man.archlinux.org/search?q=emowse
# Reference accessed: 2026-05-16

# EMBOSS emowse: identify protein from a list of peptide-mass fragments
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein database to search]:protein USA:_files' \
  '-infile=[input peptide mass list]:file:_files' \
  '-weight=[approximate parent molecular weight (Da)]:Da:' \
  '-pcrange=[tolerance for parent mass match (%)]:pct:' \
  '-aadata=[amino acid data file]:file:_files' \
  '-mwdata=[molecular weight data file]:file:_files' \
  '-frequencies=[fragment frequency file]:file:_files' \
  '-enzyme=[cleavage enzyme]:enzyme:(Trypsin LysC ArgC AspN V8-bicarb V8-phosph Chymotrypsin CNBr)' \
  '-mono[use monoisotopic masses]' \
  '-tolerance=[mass tolerance (Da)]:Da:' \
  '-partials=[partial digest allowed]:n:' \
  '-outfile=[output file]:file:_files' \
  '*:protein USA:_files' && ret=0
return ret
