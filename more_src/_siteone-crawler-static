#compdef siteone-crawler-static
# Documentation: https://crawler.siteone.io/configuration/command-line-options/
# Reference accessed: 2026-05-21
# Verified: same CLI as siteone-crawler (statically linked build).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--url=[target website or sitemap URL]:url:' \
  '--single-page[crawl only the given URL]' \
  '--max-depth=[max crawl depth]:n:' \
  '--device=[user agent device profile]:device:(desktop mobile tablet)' \
  '--user-agent=[custom User-Agent header]:ua:' \
  '--timeout=[request timeout in seconds]:s:' \
  '--workers=[concurrent worker count]:n:' \
  '--max-reqs-per-sec=[max requests per second]:n:' \
  '--memory-limit=[memory cap]:size:' \
  '--max-queue-length=[max queued URLs]:n:' \
  '--max-visited-urls=[max visited URLs]:n:' \
  '--max-url-length=[max URL length]:n:' \
  '--output=[console output format]:format:(text json)' \
  '--output-html-report=[save HTML audit report]:file:_files' \
  '--output-json-file=[save JSON output]:file:_files' \
  '--output-text-file=[save text output]:file:_files' \
  '--extra-columns=[extra XPath/regex extraction columns]:spec:' \
  '--timezone=[set timezone for timestamps]:tz:' \
  '--no-color[disable colorized output]' \
  '--force-color[force colorized output]' \
  '--disable-javascript[skip JavaScript assets]' \
  '--disable-styles[skip CSS assets]' \
  '--disable-fonts[skip font assets]' \
  '--disable-images[skip image assets]' \
  '--disable-files[skip file assets]' \
  '--disable-all-assets[skip all non-page resources]' \
  '*--include-regex=[only crawl URLs matching regex]:regex:' \
  '*--ignore-regex=[skip URLs matching regex]:regex:' \
  '*--allowed-domain-for-crawling=[additional allowed domain]:domain:' \
  '--remove-query-params[strip query params from URLs]' \
  '*--keep-query-param=[keep specified query param]:name:' \
  '*--resolve=[custom DNS resolution host:port:ip]:spec:' \
  '--proxy=[HTTP proxy]:host\:port:' \
  '--http-auth=[basic auth user:pass]:creds:' \
  '--accept-encoding=[Accept-Encoding header]:enc:' \
  '--http-cache-dir=[HTTP cache directory]:dir:_directories' \
  '--offline-export-dir=[offline export output directory]:dir:_directories' \
  '--markdown-export-dir=[markdown export directory]:dir:_directories' \
  '--sitemap-xml-file=[sitemap XML output]:file:_files' \
  '--sitemap-txt-file=[sitemap text output]:file:_files' \
  '--ci[CI mode (exit code 10 on quality fail)]' \
  '--ci-min-score=[minimum overall score]:n:' \
  '--ci-min-performance=[minimum performance score]:n:' \
  '--ci-min-security=[minimum security score]:n:' \
  '--ci-max-404=[max allowed 404s]:n:' \
  '--ci-max-5xx=[max allowed 5xx responses]:n:' \
  '--mail-to=[email recipients]:addr:' \
  '--mail-from=[email sender]:addr:' \
  '--mail-smtp-host=[SMTP host]:host:' \
  '--mail-smtp-port=[SMTP port]:port:' \
  '--upload[upload report]' \
  '--upload-to=[upload destination URL]:url:' \
  '--serve-markdown[serve markdown export via built-in HTTP server]' \
  '--serve-offline[serve offline export via built-in HTTP server]' \
  '--serve-port=[built-in server port]:port:' \
  '--serve-bind-address=[built-in server bind address]:addr:' \
  '*::args:_default' && return 0
