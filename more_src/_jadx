#compdef jadx
# Documentation: https://github.com/skylot/jadx/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (jadx --help options block).

# JADX: Dex to Java decompiler.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)--version[print jadx version]' \
  '(-d --output-dir)'{-d+,--output-dir=}'[output directory]:directory:_directories' \
  '(-ds --output-dir-src)'{-ds+,--output-dir-src=}'[output directory for sources]:directory:_directories' \
  '(-dr --output-dir-res)'{-dr+,--output-dir-res=}'[output directory for resources]:directory:_directories' \
  '(-r --no-res)'{-r,--no-res}'[do not decode resources]' \
  '(-s --no-src)'{-s,--no-src}'[do not decompile source code]' \
  '(-j --threads-count)'{-j+,--threads-count=}'[processing threads count]:threads:' \
  '--single-class=[decompile a single class (full name, raw or alias)]:class:' \
  '--single-class-output=[file or dir for single-class output]:path:_files' \
  '--output-format=[output format]:format:(java json)' \
  '(-e --export-gradle)'{-e,--export-gradle}'[save as gradle project]' \
  '--export-gradle-type=[gradle project template]:type:(auto android-app android-library simple-java)' \
  '(-m --decompilation-mode)'{-m+,--decompilation-mode=}'[code output mode]:mode:(auto restructure simple fallback)' \
  '--show-bad-code[show inconsistent code]' \
  '--no-xml-pretty-print[do not prettify XML]' \
  '--no-imports[always write entire package name]' \
  '--no-debug-info[disable debug info parsing]' \
  '--add-debug-lines[add comments with debug line numbers]' \
  '--no-inline-anonymous[disable anonymous classes inline]' \
  '--no-inline-methods[disable methods inline]' \
  '--no-move-inner-classes[disable move inner classes into parent]' \
  '--no-inline-kotlin-lambda[disable inline for Kotlin lambdas]' \
  '--no-finally[do not extract finally block]' \
  '--no-restore-switch-over-string[do not restore switch over string]' \
  '--no-replace-consts[do not replace constants with matching fields]' \
  '--escape-unicode[escape non latin characters in strings]' \
  '--respect-bytecode-access-modifiers[do not change original access modifiers]' \
  '--mappings-path=[deobfuscation mappings file or directory]:path:_files' \
  '--mappings-mode=[mappings file handling mode]:mode:(read read-and-autosave-every-change read-and-autosave-before-closing ignore)' \
  '--deobf[activate deobfuscation]' \
  '--deobf-min=[min length of name (default 3)]:length:' \
  '--deobf-max=[max length of name (default 64)]:length:' \
  '--deobf-whitelist=[classes/packages to exclude from deobfuscation]:list:' \
  '--deobf-cfg-file=[JADX auto-generated names mappings file]:file:_files' \
  '--deobf-cfg-file-mode=[mode for JADX names map file]:mode:(read read-or-save overwrite ignore)' \
  '--deobf-res-name-source=[name source for resources]:source:(auto resources code)' \
  '--use-source-name-as-class-name-alias=[use source name as class alias]:mode:(always if-better never)' \
  '--source-name-repeat-limit=[source name repeat limit (default 10)]:n:' \
  '--use-kotlin-methods-for-var-names=[use kotlin intrinsics to rename vars]:mode:(disable apply apply-and-hide)' \
  '--use-headers-for-detect-resource-extensions[use headers to detect resource extensions]' \
  '--rename-flags=[fix options]:flags:(case valid printable none all)' \
  '--integer-format=[integer display]:format:(auto decimal hexadecimal)' \
  '--type-update-limit=[type update limit per instruction (default 10)]:n:' \
  '--fs-case-sensitive[treat filesystem as case sensitive]' \
  '--cfg[save methods control flow graph to dot file]' \
  '--raw-cfg[save methods control flow graph (raw instructions)]' \
  '(-f --fallback)'{-f,--fallback}'[set decompilation mode to fallback (deprecated)]' \
  '--use-dx[use dx/d8 to convert java bytecode]' \
  '--comments-level=[code comments level]:level:(error warn info debug user-only none)' \
  '--log-level=[log level]:level:(quiet progress error warn info debug)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[turn off output]' \
  '--disable-plugins=[comma separated plugin ids to disable]:plugins:' \
  '--config=[load configuration from file]:config:' \
  '--save-config=[save current options into a config file and exit]:config:' \
  '--print-files[print files and directories used by jadx]' \
  '*:input file:_files -g "*.{apk,dex,jar,class,smali,zip,aar,arsc}"' && ret=0

return ret
