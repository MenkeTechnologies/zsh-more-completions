#compdef jadx

# Zsh completion for JADX - Android decompiler

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d+[output directory]:directory:_directories' \
  '--output-dir=[output directory]:directory:_directories' \
  '-ds+[output directory for sources]:directory:_directories' \
  '--output-dir-src=[output directory for sources]:directory:_directories' \
  '-dr+[output directory for resources]:directory:_directories' \
  '--output-dir-res=[output directory for resources]:directory:_directories' \
  '-r[do not decode resources]' \
  '--no-res[do not decode resources]' \
  '-s[do not decompile source code]' \
  '--no-src[do not decompile source code]' \
  '--single-class=[decompile single class]:class name' \
  '--single-class-output=[output for single class]:file:_files' \
  '-e[save as gradle project]' \
  '--export-gradle[save as gradle project]' \
  '-j+[threads count]:threads' \
  '--threads-count=[threads count]:threads' \
  '--show-bad-code[show inconsistent code]' \
  '--no-imports[disable use of imports]' \
  '--no-debug-info[disable debug info]' \
  '--add-debug-lines[add comments with original line numbers]' \
  '--no-inline-anonymous[disable anonymous class inline]' \
  '--no-inline-methods[disable methods inline]' \
  '--no-finally[do not extract finally]' \
  '--no-replace-consts[do not replace constant values]' \
  '--escape-unicode[escape non-Latin characters]' \
  '--respect-bytecode-access-modifiers[respect access modifiers from bytecode]' \
  '--deobf[activate deobfuscation]' \
  '--deobf-min=[min length of renamed identifiers]:length' \
  '--deobf-max=[max length of renamed identifiers]:length' \
  '--deobf-cfg-file=[deobfuscation config file]:file:_files' \
  '--deobf-cfg-file-mode=[mode for config file]:mode:(read write)' \
  '--deobf-use-source-name[use source file name as class alias]' \
  '--deobf-parse-kotlin-metadata[parse Kotlin metadata]' \
  '--rename-flags=[rename flags]:flags' \
  '--fs-case-sensitive[file system case sensitivity]' \
  '--cfg[save methods control flow graph]' \
  '--raw-cfg[save raw CFG]' \
  '-f[force overwrite]' \
  '--log-level=[log level]:level:(quiet progress error warn info debug)' \
  '-v[verbose logging]' \
  '--verbose[verbose logging]' \
  '-q[quiet logging]' \
  '--quiet[quiet logging]' \
  '*:input file:_files -g "*.{apk,dex,jar,class,smali,zip,aar,arsc}"' && ret=0

return ret
