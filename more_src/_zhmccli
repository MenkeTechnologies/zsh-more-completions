#compdef zhmccli

# zhmccli: IBM Z HMC command-line interface
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'cpc:manage CPCs'
  'partition:manage LPAR partitions'
  'image:manage CPC images'
  'lpar:manage LPARs (classic mode)'
  'storagegroup:manage storage groups (DPM)'
  'nic:manage NICs'
  'hba:manage HBAs'
  'virtualfunction:manage virtual functions'
  'vstorageresource:manage virtual storage'
  'console:manage HMC console'
  'user:manage HMC users'
  'userrole:manage HMC user roles'
  'usertype:show user types'
  'task:manage HMC tasks'
  'hmcgroup:manage HMC groups'
  'session:manage HMC sessions'
  'metrics:HMC metrics'
  'help:show command help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-H --host)'{-H,--host=}'[HMC hostname/IP]:host:' \
  '(-u --userid)'{-u,--userid=}'[HMC username]:user:' \
  '(-p --password)'{-p,--password=}'[HMC password]:password:' \
  '(-s --session-id)'{-s,--session-id=}'[reuse HMC session ID]:id:' \
  '(-l --logon-type)'{-l,--logon-type=}'[logon type]:type:(basic shared)' \
  '--ca-certs=[CA certificate file/dir]:file:_files' \
  '--no-verify[disable TLS verification]' \
  '(-o --output-format)'{-o,--output-format=}'[output format]:fmt:(table plain json yaml csv)' \
  '(-x --transpose)'{-x,--transpose}'[transpose table output]' \
  '--log=[logger spec]:val:' \
  '--log-dest=[log destination file]:file:_files' \
  '--syslog-facility=[syslog facility]:facility:' \
  '(-t --timestats)'{-t,--timestats}'[print HMC API time stats]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'zhmccli command' commands && ret=0 ;;
esac
return ret
