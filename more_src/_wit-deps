#compdef wit-deps
# Documentation: source-direct extraction from upstream
# bytecodealliance/wit-deps src/bin/wit-deps/main.rs clap-derive
# `Cli` struct + 3 `#[derive(Subcommand)]` enum variants
# (`Lock { check }` / `Update` / `Tar { package, output }`); the
# 3 root-level flags `-d`/`--deps`, `-m`/`--manifest`, `-l`/`--lock`
# have hardcoded `default_value = "wit/deps"` / `"wit/deps.toml"` /
# `"wit/deps.lock"` in the clap derive attributes.
# Reference accessed: 2026-05-30 via gh api.
# Bytecode Alliance wit-deps R135b — single-binary harvest of the
# WebAssembly WIT (Component-Model interface description) language
# dependency manager. WIT is the IDL used by WebAssembly Component
# Model; wit-deps is the equivalent of cargo/npm/go-mod for WIT
# packages. Sister tools to the wider WebAssembly toolchain in the
# corpus (wasm-tools/wit-bindgen/wasmtime/wasmer/etc).

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(-d --deps)'{-d+,--deps=}'[dependency output directory (default wit/deps)]:dir:_directories' \
  '(-m --manifest)'{-m+,--manifest=}'[dependency manifest path (default wit/deps.toml)]:file:_files' \
  '(-l --lock)'{-l+,--lock=}'[dependency lock path (default wit/deps.lock)]:file:_files' \
  '1:subcommand:(lock update tar)' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      lock)
        # Lock dependencies according to manifest. With --check,
        # exits non-zero if dependencies were not already in-sync
        # (CI-friendly drift detection).
        _arguments -s -S \
          '(-c --check)'{-c,--check}'[exit with error if dependencies were not already in-sync]' \
          && ret=0
        ;;
      update)
        # Update dependencies to the latest versions allowed by
        # the manifest. No flags.
        _arguments -s -S && ret=0
        ;;
      tar)
        # Write a deterministic tar of the `wit` subdirectory for
        # a package to stdout (or to a file with -o).
        _arguments -s -S \
          '(-o --output)'{-o+,--output=}'[output tar file path (default stdout)]:file:_files' \
          '1:package identifier:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
