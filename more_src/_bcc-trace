#compdef bcc-trace trace-bpfcc trace
# _bcc-trace — IO Visor BCC bcc-trace CLI eBPF-based generic tracing tool printing kprobes uprobes tracepoints user-statically-defined-trace USDT probes with custom format strings filter expressions struct field access pid command timestamp tid call stacks count-mode per-cpu-buffering output (IO Visor team, Python); argparse
# upstream: https://github.com/iovisor/bcc

_bcc-trace() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-b+[buffer pages]:n:' \
        '--buffer-pages=+[N]:n:' \
        '-p+[pid filter]:_pids' \
        '--pid=+[pid]:_pids' \
        '-L+[tid filter]:n:' \
        '--tid=+[tid]:n:' \
        '-v[print BPF program]' \
        '--ebpf[print BPF program]' \
        '-K[print kernel stack]' \
        '-U[print user stack]' \
        '-I+[include header]:file:_files' \
        '--include=+[header]:file:_files' \
        '-T[print timestamps]' \
        '-t[print delta time]' \
        '-C[print CPU id]' \
        '-c+[count]:n:' \
        '--max-events=+[N]:n:' \
        '-s+[symbol pid]:str:' \
        '--sym-file-list=+[list]:str:' \
        '-Z+[max str size]:n:' \
        '--string-size=+[N]:n:' \
        '-f+[fmt format]:str:' \
        '--cgroup-path=+[path]:dir:_files -/' \
        '--bpf-stats[print BPF stats]' \
        '-A[print address symbol]' \
        '-M[count mode]' \
        '*:probe spec:'
}

_bcc-trace "$@"
