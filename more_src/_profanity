#compdef profanity
# Documentation: https://manpages.debian.org/bookworm/profanity/profanity.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --account)'{-a,--account}'+[auto-connect to account on startup]:account:' \
  '(-c --config)'{-c,--config}'+[use alternate config file]:config file:_files' \
  '(-l --log)'{-l,--log}'+[set log level]:level:(DEBUG INFO WARN ERROR)' \
  '(-t --theme)'{-t,--theme}'+[load specified theme]:theme:' \
  '(-f --logfile)'{-f,--logfile}'+[log file]:file:_files' && ret=0

return ret
