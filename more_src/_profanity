#compdef profanity
# Documentation: https://man.archlinux.org/search?q=profanity
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --account)'{-a,--account}'+[auto-connect to account on startup]:account:' \
  '(-c --config)'{-c,--config}'+[use alternate config file]:config file:_files' \
  '(-l --log)'{-l,--log}'+[set log level]:level:(DEBUG INFO WARN ERROR)' \
  '(-t --theme)'{-t,--theme}'+[load specified theme]:theme:' \
  '*:JID to connect to:' && ret=0

return ret
