#compdef auggie
# Documentation: https://docs.augmentcode.com/cli/reference
# Reference accessed: 2026-05-22
# Verified: Augment Auggie CLI reference at the URL above.

# Zsh completion for auggie - Augment coding agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --print)'{-p,--print}'[run one instruction and exit]' \
  '--quiet[show only the final assistant message in print mode]' \
  '--compact[compact streaming output in print mode]' \
  '--show-credits[include credit usage summary in print mode]' \
  '--output-format[print mode output format]:format:(json)' \
  '(-a --ask)'{-a,--ask}'[ask mode - retrieval and non-editing tools only]' \
  '*--queue[queue instruction for sequential execution (requires --print)]' \
  '--mcp[run as MCP tool server]' \
  '--acp[run as ACP agent for compatible editors]' \
  '--instruction[initial instruction in interactive mode]:text:' \
  '--instruction-file[initial instruction from file]:file:_files' \
  '--image[attach image to initial prompt]:file:_files' \
  '--enhance-prompt[run prompt enhancer before sending (with --print)]' \
  '(-c --continue)'{-c,--continue}'[resume most recent conversation]' \
  '(-r --resume)'{-r,--resume}'[resume session by ID or interactively]' \
  '--dont-save-session[do not save conversation to local history]' \
  '--workspace-root[workspace root directory]:directory:_directories' \
  '--add-workspace[index additional workspace]:directory:_directories' \
  '--rules[additional rules file]:file:_files' \
  '--model[model name or short name]:model:' \
  '--persona[agent persona ID]:persona:' \
  '--augment-cache-dir[override Augment cache directory]:directory:_directories' \
  '--retry-timeout[rate-limit retry timeout in seconds]:seconds:' \
  '--max-turns[limit agentic turns in print mode]:count:' \
  '--allow-indexing[skip interactive indexing confirmation]' \
  '--wait-for-indexing[wait for full workspace indexing]' \
  '--no-update-terminal-title[disable automatic terminal title updates]' \
  '--mcp-config[MCP config JSON or file path]:path:_files' \
  '--enable-tool-search[expose find-tool/execute-tool instead of all MCP tools]' \
  '--mcp-auto-workspace[enable automatic workspace discovery in MCP mode]' \
  '(-w --workspace)'{-w,--workspace}'[workspace path for MCP mode]:directory:_directories' \
  '--permission[tool permission rule for this run]:rule:' \
  '--remove-tool[remove tool by name for this session]:tool:' \
  '--shell[override shell for process tools]:shell:' \
  '--startup-script[run before each shell command]:script:' \
  '--startup-script-file[startup script from file]:file:_files' \
  '--augment-session-json[session JSON or path for authentication]:session:' \
  '--github-api-token[path to GitHub API token file]:file:_files' \
  '--log-file[write logs to file (- for stderr)]:file:_files' \
  '--log-level[log level]:level:(error warn info debug)' \
  '--no-bell[disable terminal bell on task completion]' \
  '*--plugin-dir[load plugins from local marketplace directory]:directory:_directories' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'auggie command' \
      'login[login to Augment]' \
      'logout[remove locally stored token]' \
      'token[manage authentication tokens]' \
      'command[run custom slash commands]' \
      'session[manage saved sessions]' \
      'rules[list workspace rules and guidelines]' \
      'models[list available models]' \
      'tools[list and manage tools]' \
      'mcp[manage MCP server configurations]' \
      'plugin[manage plugins and marketplaces]' \
      'account[show account and billing information]' \
      'upgrade[upgrade Auggie to latest version]' && ret=0
    ;;
  args)
    case $line[1] in
      token)
        _values 'token action' print revoke && ret=0
        ;;
      command)
        _values 'command action' list help && ret=0
        ;;
      session)
        if (( CURRENT == 3 )); then
          _values 'session action' list continue resume delete share && ret=0
        elif [[ $line[2] == list ]]; then
          _arguments '--json[output sessions as JSON]' '--all[show sessions from all workspaces]' \
            '-n[limit number of sessions]:count:' && ret=0
        fi
        ;;
      tools)
        _values 'tools action' list remove add schemas && ret=0
        ;;
      mcp)
        _values 'mcp action' add add-json list remove && ret=0
        ;;
      plugin)
        _values 'plugin action' marketplace install list && ret=0
        ;;
      upgrade)
        _arguments '--skip-confirmation[skip upgrade confirmation]' && ret=0
        ;;
      models)
        _arguments '--json[output full model metadata as JSON]' \
          '--full-info[structured JSON with full model metadata]' && ret=0
        ;;
    esac
    ;;
esac

return ret
