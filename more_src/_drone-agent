#compdef drone-agent
# _drone-agent — Harness Drone drone-agent worker daemon executing CI jobs across containers and machines (drone team, Go); custom argparse via env or flags
# upstream: https://github.com/harness/drone

_drone-agent() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[debug logging]' \
        '--trace[trace logging]' \
        '--rpc-secret=+[rpc shared secret]:str:' \
        '--rpc-host=+[rpc host]:host:_hosts' \
        '--rpc-proto=+[rpc proto]:p:(http https grpc)' \
        '--rpc-port=+[rpc port]:port:_ports' \
        '--rpc-server=+[rpc server URL]:url:_urls' \
        '--runner-capacity=+[parallel jobs]:n:' \
        '--runner-name=+[runner name]:str:' \
        '--runner-os=+[os]:o:(linux windows darwin freebsd)' \
        '--runner-arch=+[arch]:a:(amd64 arm64 arm 386)' \
        '--runner-variant=+[variant]:str:' \
        '--runner-kernel=+[kernel]:str:' \
        '--runner-labels=+[k=v csv]:str:' \
        '--runner-environ=+[KEY=VAL csv]:str:' \
        '--runner-networks=+[networks csv]:str:' \
        '--runner-volumes=+[volumes csv]:str:' \
        '--runner-devices=+[devices csv]:str:' \
        '--runner-privileged-images=+[images csv]:str:' \
        '--runner-secrets=+[KEY=VAL csv]:str:' \
        '--runner-workspace=+[workspace]:dir:_files -/' \
        '--docker-host=+[docker socket]:str:' \
        '--docker-version=+[api version]:str:' \
        '--docker-cert-path=+[cert path]:dir:_files -/' \
        '--registry-config=+[docker config json]:file:_files' \
        '--metrics-port=+[port]:port:_ports' \
        '--healthz-port=+[port]:port:_ports' \
        '--logs-debug[debug logs]' \
        '--logs-trace[trace logs]' \
        '--logs-text[log as text]' \
        '--logs-pretty[pretty logs]' \
        '--logs-color[colored logs]'
}

_drone-agent "$@"
