#compdef wlogout

# Zsh completion for wlogout - Wayland logout menu

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l --layout)'{-l,--layout}'[layout file]:file:_files' \
  '(-C --css)'{-C,--css}'[CSS file]:file:_files -g "*.css"' \
  '(-b --buttons-per-row)'{-b,--buttons-per-row}'[buttons per row]:count' \
  '(-c --column-spacing)'{-c,--column-spacing}'[column spacing]:pixels' \
  '(-r --row-spacing)'{-r,--row-spacing}'[row spacing]:pixels' \
  '(-m --margin)'{-m,--margin}'[margin]:pixels' \
  '(-p --protocol)'{-p,--protocol}'[protocol]:protocol:(layer-shell)' \
  '-n[no reload of GTK theme]'
