#compdef shlock
# Documentation: https://man.archlinux.org/search?q=shlock
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-d[debug mode]' \
  '-u[expect uucp-style PID files]' \
  '-p+[PID]:pid:_pids' \
  '-f+[lock file]:file:_files' && ret=0

return ret
