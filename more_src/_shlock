#compdef shlock
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/shlock.1.html
# Reference accessed: 2026-05-21
# Verified: upstream Ubuntu manpage at the URL above.
# Removed unverified -d (debug). Added -b and -c per manpage.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-p+[PID to write into lock file]:pid:_pids' \
  '-f+[name of lock file]:file:_files' \
  '-b[binary int format for PID]' \
  '-u[UUCP-style binary PID (synonym for -b)]' \
  '-c[check only — do not create lock file]' && ret=0

return ret
