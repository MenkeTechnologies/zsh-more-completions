#compdef augment
# Documentation: https://docs.augmentcode.com/cli/reference
# Reference accessed: 2026-05-23
# Verified: npx @augmentcode/auggie --help (binary auggie; see _auggie).

# Zsh completion for augment - Augment CLI agent (package alias for auggie)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --print)'{-p,--print}'[one-shot print mode]' \
  '(-q --quiet)'{-q,--quiet}'[only final message in print mode]' \
  '(-a --ask)'{-a,--ask}'[ask mode - non-editing tools only]' \
  '(-i --instruction)'{-i+,--instruction=}'[instruction text]:text:' \
  '(-if --instruction-file)'{-if,--instruction-file=}'[instruction file]:file:_files' \
  '--image[attach image files]:file:_files' \
  '--file[attach PDF files]:file:_files' \
  '--enhance-prompt[enhance prompt before sending]' \
  '--output-format[print output format]:(text json)' \
  '*--queue[queue instruction (requires --print)]' \
  '(-c --continue)'{-c,--continue}'[continue most recent session]' \
  '(-r --resume)'{-r+,--resume=}'[resume session]:session:' \
  '--dont-save-session[do not save session]' \
  '(-m --model)'{-m+,--model=}'[model ID]:model:' \
  '--persona[agent persona]:persona:' \
  '(-w --workspace-root)'{-w+,--workspace-root=}'[workspace root]:directory:_directories' \
  '--add-workspace[additional workspace]:directory:_directories' \
  '--max-turns[max agentic turns in print mode]:count:' \
  '--mcp[run as MCP server]' \
  '--acp[ACP mode]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'augment command' \
      'login[login to Augment]' \
      'logout[logout]' \
      'token[manage tokens]' \
      'session[manage sessions]' \
      'models[list models]' \
      'mcp[manage MCP servers]' \
      'upgrade[upgrade CLI]' && ret=0
    ;;
esac

return ret
