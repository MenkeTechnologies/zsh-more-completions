#compdef gdcmviewer
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/gdcmviewer.1.html
# Simple DICOM viewer (VTK/GDCM wrapper)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '(-v --version)'{-v,--version}'[print version information and exit]' \
  '--force-rescale[force rescale (advanced users)]' \
  '--force-spacing[force spacing (advanced users)]' \
  '(-r --recursive)'{-r,--recursive}'[recursively descend directory]' \
  '(-V --verbose)'{-V,--verbose}'[verbose mode (warning+error)]' \
  '(-W --warning)'{-W,--warning}'[warning mode, print warning information]' \
  '(-E --error)'{-E,--error}'[error mode, print error information]' \
  '(-D --debug)'{-D,--debug}'[debug mode, print debug information]' \
  '*:DICOM input file:_files' && ret=0

return ret
