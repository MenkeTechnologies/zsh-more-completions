#compdef create-react-router
# Documentation: https://www.npmjs.com/package/create-react-router
# Reference accessed: 2026-05-23
# Verified: npx create-react-router --help.

# Zsh completion for create-react-router - scaffold a React Router project

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--no-color[disable ANSI colors]' \
  '--no-motion[disable console animations]' \
  '--template=[project template]:template:' \
  '--install[install dependencies after creation]' \
  '--no-install[skip installing dependencies]' \
  '--package-manager=[package manager]:manager:(npm yarn pnpm bun)' \
  '--show-install-output[show install process output]' \
  '--git-init[initialize a Git repository]' \
  '--no-git-init[skip Git initialization]' \
  '(-y --yes)'{-y,--yes}'[skip prompts and use defaults]' \
  '(-v --react-router-version)'{-v,--react-router-version=}'[React Router version]:version:' \
  ':project directory:_directories' && ret=0

return ret
