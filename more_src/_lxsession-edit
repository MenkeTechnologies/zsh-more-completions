#compdef lxsession-edit

# lxsession-edit: LXDE GUI for choosing default applications and autostart
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)--version[print version]' \
  '--session=[edit a specific session profile]:session name:' && ret=0

return ret
