#compdef vivid

# Zsh completion for vivid - LS_COLORS theme generator

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'generate:generate LS_COLORS string'
  'preview:preview color theme'
  'themes:list available themes'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color-mode[color mode]:mode:(8-bit 24-bit)' \
  '--database[path to filetypes database]:file:_files' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'vivid command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      generate|preview)
        local -a themes
        themes=(${(f)"$(vivid themes 2>/dev/null)"})
        _describe -t themes 'theme' themes && ret=0
        ;;
    esac
    ;;
esac

return ret
