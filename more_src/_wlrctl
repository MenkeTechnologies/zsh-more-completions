#compdef wlrctl
# Documentation: https://manpages.debian.org/trixie/wlrctl/wlrctl.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'toplevel:interact with toplevel windows'
  'output:interact with outputs'
  'pointer:simulate pointer events'
  'keyboard:simulate keyboard events'
  'window:alias for toplevel'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'wlrctl command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (toplevel|window)
        _arguments \
          '1:action:(minimize maximize fullscreen focus find wait waitfor)' \
          '*:matches:' && ret=0
        ;;
      (output)
        _arguments \
          '1:action:(list)' \
          '*:output:' && ret=0
        ;;
      (pointer)
        _arguments \
          '1:action:(click move scroll)' \
          '*:args:' && ret=0
        ;;
      (keyboard)
        _arguments \
          '1:action:(type)' \
          '*:text:' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
