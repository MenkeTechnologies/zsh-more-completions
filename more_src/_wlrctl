#compdef wlrctl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'toplevel:interact with toplevel windows'
  'output:interact with outputs'
  'pointer:simulate pointer events'
  'keyboard:simulate keyboard events'
  'window:alias for toplevel'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'wlrctl command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (toplevel|window)
        _arguments \
          '1:action:(focus close fullscreen maximize minimize)' \
          '*:app id or title:' && ret=0
        ;;
      (output)
        _arguments \
          '1:action:(toggle enable disable)' \
          '*:output name:' && ret=0
        ;;
      (pointer)
        _arguments \
          '1:action:(click move scroll)' \
          '*:coordinates:' && ret=0
        ;;
      (keyboard)
        _arguments \
          '1:action:(type)' \
          '*:text:' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
