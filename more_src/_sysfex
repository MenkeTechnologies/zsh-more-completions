#compdef sysfex
# Documentation: https://github.com/mehedirm6244/sysfex
# sysfex - another system information fetching tool written in C++

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help documentation]' \
  '(-b --about)'{-b,--about}'[display program information]' \
  '(-a --ascii)'{-a,--ascii}'[set the ASCII art display]:ascii:' \
  '(-C --config)'{-C,--config}'[specify a configuration file]:file:_files' \
  '(-i --info)'{-i,--info}'[initialize information settings]:info:' && ret=0

return ret
