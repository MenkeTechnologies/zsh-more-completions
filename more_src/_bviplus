#compdef bviplus

# bviplus: vi-like binary editor with multiple-file support
# Documentation: https://bviplus.sourceforge.net/
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-R[read-only]' \
  '-c[execute initial command]:cmd:' \
  '*:file:_files' && ret=0
return ret
