#compdef bviplus
# Documentation: https://bviplus.sourceforge.net/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bviplus — ncurses-based hex editor with vim-like interface and multi-file support.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-R[read-only mode]' \
  '-c+[execute initial command]:cmd:' \
  '*:file:_files' && ret=0
return ret
