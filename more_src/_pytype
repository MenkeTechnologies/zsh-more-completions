#compdef pytype
# Documentation: https://github.com/google/pytype/blob/main/pytype/config.py
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above; flag names match argparse
# definitions in config.py.

# Zsh completion for pytype - Google's static type checker for Python

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[show pytype version]'
  '(-C --check)'{-C,--check}'[skip type inference; check errors only]'
  '(-o --output)'{-o+,--output=}'[output file or directory]:file:_files'
  '(-d --disable)'{-d+,--disable=}'[comma-separated list of error codes to disable]:codes:'
  '--no-report-errors[do not report errors]'
  '(-V --python_version)'{-V+,--python_version=}'[python version of target code]:version:(3.8 3.9 3.10 3.11 3.12 3.13 3.14)'
  '--platform=[target platform]:platform:'
  '(-P --pythonpath)'{-P+,--pythonpath=}'[pythonpath for imports]:paths:'
  '(-M --module-name)'{-M+,--module-name=}'[name of analyzed module]:name:'
  '--nofail[never exit with a non-zero status]'
  '--return-success[always exit with a zero status]'
  '--output-errors-csv=[output errors to a csv file]:file:_files'
  '--touch=[touch this file when type-checking succeeds]:file:_files'
  '(-e --enable-only)'{-e+,--enable-only=}'[enable only specific error codes]:codes:'
  '--analyze-annotated[analyze fully-annotated code]'
  '(-Z --quick)'{-Z,--quick}'[run a faster, less precise analysis]'
  '--color=[when to use color]:when:(always auto never)'
  '--no-validate-version[disable Python version validation]'
  '--bind-decorated-methods[bind decorated methods]'
  '--none-is-not-bool[disable bool/None confusion]'
  '--no-return-any[disallow returning Any]'
  '--require-override-decorator[require @typing.override on overrides]'
  '--strict-none-binding[strict None binding checks]'
  '--use-fiddle-overlay[use Fiddle overlay]'
  '--use-functools-partial-overlay[use functools.partial overlay]'
  '--precise-return[infer precise return types]'
  '--protocols[support PEP 544 protocols]'
  '(-R --use-rewrite)'{-R,--use-rewrite}'[use rewrite mode]'
  '--strict-import[check that all imports resolve]'
  '--strict-parameter-checks[strict parameter checks]'
  '--strict-primitive-comparisons[strict primitive comparisons]'
  '--strict-undefined-checks[strict undefined checks]'
  '--generate-builtins=[generate builtins file]:file:_files'
  '--parse-pyi[parse pyi files]'
  '--pickle-output[pickle the output]'
  '--use-pickled-files[use pickled files]'
  '--precompiled-builtins=[precompiled builtins file]:file:_files'
  '--pickle-metadata=[pickle metadata]:value:'
  '--imports_info=[file listing imports]:file:_files'
  '--unused_imports_info_files=[unused imports info files]:file:_files'
  '--check_preconditions[check preconditions]'
  '--metrics=[output metrics to file]:file:_files'
  '--no-skip-calls[do not skip calls]'
  '(-T --no-typeshed)'{-T,--no-typeshed}'[do not use typeshed]'
  '--output-debug=[debug output file]:file:_files'
  '--profile=[output profile data]:file:_files'
  '(-v --verbosity)'{-v+,--verbosity=}'[logging verbosity]:level:(-1 0 1 2 3 4)'
  '(-S --timestamp-logs)'{-S,--timestamp-logs}'[add timestamps to logs]'
  '--debug-logs[emit debug logs]'
  '--exec-log=[exec log file]:file:_files'
  '--verify-pickle[verify pickled files]'
  '--memory-snapshots[take memory snapshots]'
  '--show-config[show configuration and exit]'
  '--timeout=[timeout in seconds]:seconds:'
  '--debug[debug mode]'
  '--debug-constant-folding[debug constant folding]'
  '*:python file:_files -g "*.py"'
)

_arguments -s -S $arguments
