#compdef pytype

# Zsh completion for pytype - Google's static type checker for Python

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-V --python-version)'{-V,--python-version}'[python version of target code]:version:(3.7 3.8 3.9 3.10 3.11 3.12)'
  '(-P --pythonpath)'{-P,--pythonpath}'[pythonpath for imports]:paths:'
  '(-o --output)'{-o,--output}'[output directory]:directory:_files -/'
  '(-d --disable)'{-d,--disable}'[comma-separated list of error codes to disable]:codes:'
  '--no-report-errors[do not report errors]'
  '-j[number of parallel jobs to run]:jobs:'
  '--jobs[number of parallel jobs]:jobs:'
  '-x[paths to exclude]:path:_files'
  '--exclude[paths to exclude]:path:_files'
  '--config[path to a pytype config file]:file:_files -g "*.(toml|cfg)"'
  '--generate-config[write a sample config to a file]:file:_files'
  '--keep-going[keep going past errors]'
  '--no-cache[do not use pytype cache]'
  '--strict-import[check that all imports resolve]'
  '--strict-none-binding[strict None binding checks]'
  '--strict-parameter-checks[strict parameter checks]'
  '--strict-primitive-comparisons[strict primitive comparisons]'
  '(-v --verbosity)'{-v,--verbosity}'[logging verbosity]:level:(0 1 2 3 4)'
  '--version[show pytype version]'
  '--no-cache-imports[do not cache import resolution]'
  '--precise-return[infer precise return types]'
  '--protocols[support PEP 544 protocols]'
  '--platform[target platform]:platform:(linux darwin win32)'
  '--check[check a file]'
  '--output-cfg[output control flow graph to file]:file:_files'
  '--output-typegraph[output type graph to file]:file:_files'
  '--show-config[show configuration and exit]'
  '--overriding-parameter-count-checks[parameter count overrides]'
  '*:python file:_files -g "*.py"'
)

_arguments -s -S $arguments
