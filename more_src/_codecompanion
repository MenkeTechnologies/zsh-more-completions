#compdef codecompanion

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'chat:open a chat session'
  'agent:run as an agent'
  'inline:run an inline transformation'
  'config:print/edit configuration'
  'cmds:list registered CodeCompanion commands'
  'workspace:manage CodeCompanion workspaces'
  'history:show conversation history'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--adapter=[LLM adapter]:adapter:(openai anthropic xai gemini ollama copilot azure_openai mistral)' \
  '--model=[model name]:model:' \
  '--config=[config file]:file:_files -g "*.{lua,toml,yaml,yml,json}"' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'codecompanion command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (chat|agent|inline)
        _arguments \
          '--mode=[mode]:mode:(buffer popup split)' \
          '*::prompt:' && ret=0 ;;
      (workspace)
        _arguments '*::sub:(list add remove use)' && ret=0 ;;
    esac ;;
esac

return ret
