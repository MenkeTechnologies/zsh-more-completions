#compdef mgc
# Documentation: https://docs.magalu.cloud/docs/devops-tools/cli-mgc/commands-reference/help/
# Magalu Cloud CLI (mgc) for managing Magalu Cloud services

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--api-key=[authenticate with the API using an API key]:api key' \
  '(-U --cli.retry-until)'{-U,--cli.retry-until}'=[retry the action until the given condition is met]:condition' \
  '(-t --cli.timeout)'{-t,--cli.timeout}'=[timeout for the action execution]:duration' \
  '--debug[display detailed log information at debug level]' \
  '--no-confirm[bypass confirmation prompts]' \
  '(-o --output)'{-o,--output}'=[change the output format]:format:(yaml json table)' \
  '(-r --raw)'{-r,--raw}'[output raw data without formatting or coloring]' \
  '*:command:((audit\:"Cloud Events API" block-storage\:"Block Storage API" container-registry\:"Container Registry API" dbaas\:"DBaaS API" iam\:"Magalu Cloud IAM" kubernetes\:"Kubernetes APIs" load-balancer\:"Load Balancer API" network\:"VPC API" object-storage\:"Object Storage operations" virtual-machine\:"Virtual Machine API" auth\:"login API keys and tenant changes" config\:"manage CLI configuration values" profile\:"manage account settings" workspace\:"manage isolated auth and config workspaces" completion\:"generate shell completion" help\:"help about any command"))' && ret=0

return ret
