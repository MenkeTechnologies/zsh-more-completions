#compdef seed
# _seed — Seed JavaScript binding for GNOME (libseed-gtk3); WebKit JSCore embedded in GNOME apps with GIRepository
# upstream: https://gitlab.gnome.org/Archive/seed

_seed() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-e+[expression]:expr:' \
        '*:script:_files -g "*.js"'
}

_seed "$@"
