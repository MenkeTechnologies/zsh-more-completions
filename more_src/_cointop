#compdef cointop

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config[config file path]:file:_files' \
  '--api[API to use]:api:(coingecko coinmarketcap)' \
  '--colorscheme[colorscheme to use]:scheme' \
  '--coin[show specified coin]:coin' \
  '--currency[set currency]:currency' \
  '--no-cache[disable cache]' \
  '--cache-dir[cache directory]:dir:_directories' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'holdings:view holdings'
      'clean:clean cache'
      'reset:reset config'
      'dominance:show dominance'
      'price:show price of a coin'
      'server:run price server'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case "$words[1]" in
      holdings)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--total[show total only]' && ret=0
        ;;
      price)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--coin[coin name]:coin' \
          '--currency[currency]:currency' && ret=0
        ;;
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--port[server port]:port' && ret=0
        ;;
    esac
    ;;
esac

return ret
