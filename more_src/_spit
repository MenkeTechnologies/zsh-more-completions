#compdef spit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--species=[type of LLM]:type:(ollama)' \
  '--url=[server URL]:url:' \
  {-m+,--model=}'[model name]:model:' \
  '--to=[target language]:lang:' \
  '--prompt=[prompt before input]:text:' \
  '--postprocess=[post-process command]:command:_command_names -e' && ret=0

return ret
