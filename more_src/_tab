#compdef tab

local curcontext="$curcontext" state line ret=1

_tab_commands() {
  local -a commands=(
    'list:list active tabs'
    'open:open a new tab'
    'close:close a tab'
    'disconnect:disconnect from a tab'
    'completion:generate shell completions'
  )
  _describe -t commands 'tab command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--log=[set log level]:level:(error warn info debug trace)' \
  '-w[use workspace from current directory]' \
  '--starship[use starship prompt]' \
  '1: :_tab_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      completion)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      *)
        _message 'no more arguments'
        ;;
    esac
    ;;
esac

return ret
