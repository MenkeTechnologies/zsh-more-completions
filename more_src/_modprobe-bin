#compdef modprobe
# _modprobe-bin — modprobe Linux kernel module loader (kmod, Lucas De Marchi); load/remove modules + handle dependencies
# upstream: https://github.com/kmod-project/kmod

_modprobe-bin() {
    _arguments \
        '(-a --all)'{-a,--all}'[process multiple modules]' \
        '(-b --use-blacklist)'{-b,--use-blacklist}'[apply blacklist]' \
        '(-C --config)'{-C,--config}'+[config file]:file:_files' \
        '(-c --showconfig)'{-c,--showconfig}'[show config]' \
        '(-d --dirname)'{-d,--dirname}'+[modules dir]:dir:_files -/' \
        '--first-time[fail if already loaded/removed]' \
        '--force-modversion[disable modversion check]' \
        '--force-vermagic[disable vermagic check]' \
        '--force[force load]' \
        '(-i --ignore-install)'{-i,--ignore-install}'[ignore install/remove rules]' \
        '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-R --resolve-alias)'{-R,--resolve-alias}'[print aliases]' \
        '(-r --remove)'{-r,--remove}'[remove module]' \
        '(-S --set-version)'{-S,--set-version}'+[kernel version]:ver:' \
        '--show-depends[print module dependencies]' \
        '--show-modversions[print module symbol versions]' \
        '(-s --syslog)'{-s,--syslog}'[log to syslog]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-w --wait)'{-w,--wait}'[wait until module idle]' \
        '*:module:'
}

_modprobe-bin "$@"
