#compdef aws-fsx-csi-driver
# _aws-fsx-csi-driver — AWS FSx Lustre/OpenZFS CSI driver
# upstream: https://github.com/kubernetes-sigs/aws-fsx-csi-driver
# Mode + flags from cmd/options.go + cmd/options/{server,controller,node}.go on tip; first positional arg = mode or "pre-stop-hook".

_aws-fsx-csi-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '1::cmd:(controller node all pre-stop-hook)' \
        '--mode=[driver mode]:mode:(controller node all)' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--http-endpoint=[TCP address for the metrics HTTP server]:addr:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--logging-format=[log format]:fmt:(text json)' \
        '--feature-gates=[csv of feature gates]:gates:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[DEPRECATED log to stderr]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_aws-fsx-csi-driver "$@"
