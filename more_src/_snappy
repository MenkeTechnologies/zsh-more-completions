#compdef snappy
# ============================================================================
# snappy - Snappy file compression CLI
#           (JavaScript -> Node, ISC)
#
# Author : Eugene Ware (kesla)
# Upstream: npm `snappy-cli` (binary: snappy)
#
# `snappy` is a stdio-capable CLI wrapper around the
# Node `snappy` package. It compresses or decompresses
# data using Google's Snappy algorithm (RFC-free; wire
# format defined by Google's snappy-format-description.
# txt + snappy_frame.h header). The CLI accepts data
# from stdin or a file + writes to stdout or a file,
# making it a drop-in replacement for `gzip` / `lz4` /
# `zstd` when the upstream compressor produces Snappy
# output.
#
# Usage:
#   snappy [input] [output]                  # compress
#                                             (default)
#   snappy c [input] [output]                # compress
#                                             (explicit)
#   snappy compress [input] [output]         # compress
#                                             (alias)
#   snappy d [input] [output]                # decompress
#   snappy decompress [input] [output]       # decompress
#                                             (alias)
#
# Commands:
#   c, compress      - compress input (default if no
#                       command given)
#   d, decompress    - decompress input
#
# Flags (yargs):
#   -i, --input <file>     - input file path
#                             (default: stdin)
#   -o, --output <file>    - output file path
#                             (default: stdout)
#   -k, --encoding <enc>   - input data encoding
#                             (default: utf8)
#       --version          - print version
#   -h, --help             - print help
#
# Operational examples:
#   cat data.json | snappy c > data.snappy
#   snappy d data.snappy data.json
#   snappy --input data.json --output data.snappy
#   echo "hello world" | snappy c -k utf8 \
#       | snappy d
#
# The snappy lane is built on `snappy ~6.3.5` (declared
# at upstream package.json HEAD as a direct dep,
# imported as `require('snappy')`). The `snappy` npm
# package has an interesting governance history:
#
#   1. kesla/node-snappy (Eugene Ware, 2014-2018):
#      original native Node binding to Google's
#      reference C++ Snappy library; npm-published
#      as `snappy` v1-v6
#   2. transition (2019): Eugene Ware handed the
#      package to LongYinan (Brooooooklyn / napi-rs
#      maintainer) who rewrote it as a napi-rs binding
#      to BurntSushi/rust-snappy
#   3. Brooooooklyn/snappy-rs (LongYinan, 2019-now):
#      maintained under the napi-rs umbrella as a
#      napi-rs binding; npm-published as `snappy` v7+
#
# This means the npm `snappy` package at pinned
# version `~6.3.5` (as snappy-cli uses) is the legacy
# kesla/node-snappy native binding, while `snappy` v7+
# is the current LongYinan napi-rs binding to
# BurntSushi/rust-snappy. Both versions produce wire-
# format-identical Snappy output + cross-decode
# correctly through any RFC-compliant implementation.
#
# The current canonical Node Snappy library is the
# napi-rs-binding-to-BurntSushi-rust-snappy variant,
# completing the Rust-roots-cycle for the Snappy axis.
# The Node ecosystem increasingly converges on
# napi-rs bindings to canonical Rust implementations
# for performance-sensitive primitives:
#   - @node-rs/argon2 (Axis 244) -> RustCrypto argon2
#   - @chainsafe/libp2p-quic (Axis 249) -> ChainSafe
#     quinn-rs fork
#   - SalvatorePreviti/roaring-node (Axis 250) ->
#     Daniel Lemire's CRoaring C library
#   - npm `snappy` v7+ (Axis 253, THIS AXIS) ->
#     BurntSushi/rust-snappy
#
# snappy-cli (THIS BINARY) uses the legacy v6 package
# but the wire-format output remains compatible with
# the v7 napi-rs binding + with golang/snappy + with
# BurntSushi/rust-snappy + with Google's reference
# C++ library.
#
# ----------------------------------------------------------------------------
# AXIS 253 :: Snappy compression (Google fast LZ77
#              variant, optimized for decompression
#              throughput)
# Round 1459 :: TS-Node slot 3 of 4 :: CLOSES Axis 253
#                                       (246th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : BurntSushi/rust-snappy      [R1457 _avml]
#   Go      : golang/snappy               [R1458 _ropee]
#             (extracted from
#              golang/leveldb in 2016)
#   TS/Node : @napi-rs/snappy             [R1459 THIS FILE]
#             (published as `snappy` v7+
#              on npm; napi-rs binding
#              to BurntSushi/rust-snappy)
#
# @napi-rs/snappy closes Axis 253 with the *napi-rs-
# binding-to-the-Rust-slot* pattern that completes
# the Rust-roots cycle. The three lanes form a clean
# convergence pattern:
#
#   - Rust (BurntSushi/rust-snappy): line-by-line
#     port of Google's reference C++ Snappy library;
#     part of Andrew Gallant's broader canonical-Rust
#     footprint (regex / ripgrep / fst / xsv /
#     rust-snappy / toml-test)
#   - Go (golang/snappy): Go core team port,
#     originally inside golang/leveldb (the Go LevelDB
#     port), extracted in 2016 + maintained
#     independently
#   - Node (@napi-rs/snappy): napi-rs binding to
#     BurntSushi/rust-snappy; legacy v6 uses kesla's
#     native binding to Google's reference C++; v7+
#     migrated to the Rust-routed napi-rs binding
#
# This Node-binds-to-Rust pattern at Snappy
# structurally mirrors the same patterns at Argon2
# (Axis 244), QUIC (Axis 249), Roaring (Axis 250),
# and others. The Node ecosystem's *napi-rs bindings
# to canonical Rust implementations* is the
# increasingly-standard approach for performance-
# sensitive Node primitives.
#
# Cross-language interop at the wire format level - a
# Snappy bitstream produced by BurntSushi/rust-snappy
# + golang/snappy + the legacy kesla/node-snappy v6 +
# the current @napi-rs/snappy v7+ decompresses
# byte-identically through any of the others. Google's
# canonical test corpus validates this cross-library
# byte-equivalence.
#
# Use-case spectrum across the three lanes:
#   - avml (Rust, BurntSushi/rust-snappy): Microsoft
#     Linux memory acquisition tool with optional
#     Snappy-compressed RAM snapshots
#   - ropee (Go, golang/snappy): Prometheus remote-
#     storage adapter for Splunk HEC using Snappy
#     decompression for the Prometheus wire format
#   - snappy (Node, @napi-rs/snappy): general-purpose
#     stdio CLI for Snappy compress/decompress
#     workflows
#
# Three lanes, three use-case shapes (forensic memory
# acquisition / metrics-pipeline adapter / general-
# purpose CLI), three implementation strategies
# (Gallant's safe-Rust port / Go core team extracted-
# from-leveldb port / napi-rs binding back to
# Gallant's Rust impl), all converging on Google's
# Snappy wire format.
#
# Axis 253 closes the round 1459 cycle - 246th axis
# closed total.
# ============================================================================

_snappy() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-i --input)'{-i,--input}'[input file path (default stdin)]:file:_files' \
        '(-o --output)'{-o,--output}'[output file path (default stdout)]:file:_files' \
        '(-k --encoding)'{-k,--encoding}'[input data encoding]:enc:(utf8 utf16le ascii base64 hex binary)' \
        '(- *)--version[print version]' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :_snappy_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                c|compress|d|decompress)
                    _arguments \
                        '(-i --input)'{-i,--input}'[input file path]:file:_files' \
                        '(-o --output)'{-o,--output}'[output file path]:file:_files' \
                        '(-k --encoding)'{-k,--encoding}'[input data encoding]:enc:(utf8 utf16le ascii base64 hex binary)' \
                        '(- *)'{-h,--help}'[print subcommand help]' \
                        '1:input file:_files' \
                        '2:output file:_files'
                    ;;
            esac
            ;;
    esac

    return ret
}

_snappy_cmds() {
    local -a cmds
    cmds=(
        'c:compress input (default)'
        'compress:compress input (alias)'
        'd:decompress input'
        'decompress:decompress input (alias)'
    )
    _describe -t commands 'snappy command' cmds
}

_snappy "$@"
