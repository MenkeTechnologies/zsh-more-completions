#compdef multibinit
# Documentation: https://docs.abinit.org/guide/multibinit/
# multibinit - ABINIT second-principles effective model builder and dynamics driver

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --version)'{-v,--version}'[show version number and exit]' \
  '(-b --build)'{-b,--build}'[show build parameters and exit]' \
  '(-d --dry-run)'{-d,--dry-run}'[validate input file and exit]' \
  '(-j --omp-num-threads)'{-j,--omp-num-threads}'+[set number of OpenMP threads]:n:' \
  '(-t --timelimit)'{-t,--timelimit}'+[set timelimit in Slurm notation]:time:' \
  '--F03[run F03 mode (Multibinit only)]' \
  '--ipi[activate socket-driven calculation using i-pi protocol]' \
  '--use-xgemm3m=-[use ZGEMM3M routines instead of ZGEMM]:yesno:(yes no)' \
  '--use-mpi-in-place=-[toggle MPI_IN_PLACE in xmpi_sum]:yesno:(yes no)' \
  '--fft-ialltoall=-[use non-blocking ialltoall in MPI-FFT]:yesno:(yes no)' \
  '--abimem-level=-[set memory profiling level]:level:(0 1 2 3 4)' \
  '--abimem-limit-mb=-[log malloc/free only if size > limit in MB]:mb:' \
  '--mem-per-cpu=-[set memory per CPU in Slurm syntax]:size:' \
  '--mem=-[set memory per node in Slurm syntax]:size:' \
  '--ntasks-per-node=-[set number of tasks per node]:n:' \
  '--log[enable log files and status files in parallel execution]' \
  '--netcdf-classic[use netcdf classic mode for new files]' \
  '--enforce-fortran-io[use Fortran-IO instead of MPI-IO on Fortran files]' \
  '--ieee-halt[halt the code on usual IEEE exceptions]' \
  '--ieee-signal[signal the occurrence of usual IEEE exceptions]' \
  '--gnu-mtrace[enable mtrace (requires GNU and clib)]' \
  '--verbose[verbose mode]' \
  '*:input file:_files' && ret=0

return ret
