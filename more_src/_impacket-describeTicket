#compdef impacket-describeTicket
# Documentation: https://github.com/fortra/impacket/blob/master/examples/describeTicket.py
# Ticket describer: parses ticket, decrypts the enc-part, and parses the PAC

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-debug[turn DEBUG output ON]' \
  '-ts[adds timestamp to every logging output]' \
  '(-p --password)'{-p,--password}'=[cleartext password of the service account]:password' \
  '(-hp --hex-password)'{-hp,--hex-password}'=[hex password of the service account]:hexpassword' \
  '(-u --user)'{-u,--user}'=[name of the service account]:user' \
  '(-d --domain)'{-d,--domain}'=[FQDN domain]:domain' \
  '(-s --salt)'{-s,--salt}'=[salt for keys calculation]:salt' \
  '--rc4=[RC4 key (i.e. NT hash)]:rc4' \
  '--aes=[AES128 or AES256 key]:hexkey' \
  '--asrep-key=[AS reply key for PAC credentials decryption]:hexkey' \
  '1:ticket:_files -g "*.ccache"' && ret=0

return ret
