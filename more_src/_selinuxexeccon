#compdef selinuxexeccon
# Documentation: https://man.archlinux.org/search?q=selinuxexeccon
# Reference accessed: 2026-05-16

# selinuxexeccon: print SELinux context an exec would transition to
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command path:_files' \
  '2:from context:' && ret=0
return ret
