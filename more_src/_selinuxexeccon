#compdef selinuxexeccon
# Documentation: https://man7.org/linux/man-pages/man8/selinuxexeccon.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# selinuxexeccon command [fromcon] - report SELinux context of an exec.
local curcontext="$curcontext" ret=1
_arguments -s -S \
  '1:command path:_files' \
  '2:from context:' && ret=0
return ret
