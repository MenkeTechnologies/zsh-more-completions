#compdef toipe

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-n+[number of words]:count:' \
  '--num-words=[number of words]:count:' \
  '-w+[word list]:word list:(os top200 top1000)' \
  '--word-list=[word list]:word list:(os top200 top1000)' \
  '-f+[custom word file]:word file:_files' \
  '--file=[custom word file]:word file:_files' && ret=0

return ret
