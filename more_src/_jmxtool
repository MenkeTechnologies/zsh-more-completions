#compdef jmxtool

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'diff:diff two JMX dump files'
  'dump:dump JMX MBeans of a Cassandra instance'
  'help:show help'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'jmxtool subcommand' subcommands && ret=0
    ;;
  (args)
    _files && ret=0
    ;;
esac

return ret
