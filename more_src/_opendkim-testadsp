#compdef opendkim-testadsp
# Documentation: https://man.archlinux.org/search?q=opendkim-testadsp
# Reference accessed: 2026-05-16

# opendkim-testadsp: probe ADSP record for a domain
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '*:domain:' && ret=0
return ret
