#compdef nerdctl-compose
# _nerdctl-compose — Docker Compose-compatible CLI for containerd (containerd/nerdctl)
# upstream: https://github.com/containerd/nerdctl
# Subcommands from cmd/nerdctl/compose/.

_nerdctl-compose() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '*'{-f+,--file=}'[compose file]:file:_files -g "(docker-compose.{yml,yaml}|compose.{yml,yaml})"' \
        '(-p --project-name)'{-p+,--project-name=}'[compose project name]:name:' \
        '--project-directory=[project base directory]:dir:_files -/' \
        '--env-file=[environment variable file]:file:_files' \
        '--profile=[profiles to enable]:profile:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'up:create and start containers'
                'down:stop and remove containers'
                'build:build / rebuild services'
                'config:render configuration to stdout'
                'cp:copy files between host and container'
                'create:create services'
                'exec:execute a command in a running container'
                'images:list images used by services'
                'kill:force-stop service containers'
                'logs:view output from containers'
                'pause:pause services'
                'port:print public port for a binding'
                'ps:list services'
                'pull:pull service images'
                'push:push service images'
                'restart:restart services'
                'rm:remove stopped service containers'
                'run:run a one-off command on a service'
                'start:start services'
                'stop:stop services'
                'top:display running processes'
                'unpause:unpause services'
                'version:show Compose version'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_nerdctl-compose "$@"
