#compdef ansible-runner-cli
# _ansible-runner-cli — Red Hat Ansible Runner interface to run Ansible CLI alias (ansible team, Python); argparse
# upstream: https://github.com/ansible/ansible-runner

_ansible-runner-cli() {
    local -a sub=(
        'run:run a job in foreground'
        'start:start a job in background'
        'stop:stop a running job'
        'is-alive:check if job is running'
        'transmit:transmit data over a socket'
        'worker:run a worker'
        'process:process a job'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--logfile=+[file]:file:_files' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ansible-runner subcommand' sub ;;
        args)
            case $words[1] in
                run|start) _arguments \
                    '1:private dir:_files -/' \
                    '-p+[playbook]:file:_files -g "*.{yml,yaml}"' \
                    '--playbook=+[playbook]:file:_files -g "*.{yml,yaml}"' \
                    '-m+[module]:str:' \
                    '--module=+[module]:str:' \
                    '--module-args=+[args]:str:' \
                    '-a+[args]:str:' \
                    '--role=+[role]:str:' \
                    '-r+[role]:str:' \
                    '--hosts=+[hosts]:str:' \
                    '--inventory=+[inventory]:file:_files' \
                    '-i+[inventory]:file:_files' \
                    '--roles-path=+[paths]:str:' \
                    '--role-vars=+[vars]:str:' \
                    '--limit=+[limit]:str:' \
                    '--tags=+[tags csv]:str:' \
                    '--skip-tags=+[skip tags csv]:str:' \
                    '--ident=+[ident]:str:' \
                    '--cmdline=+[cmdline]:str:' \
                    '--artifact-dir=+[dir]:dir:_files -/' \
                    '--cleanup-artifacts[cleanup artifacts]' \
                    '--keep-artifacts=+[count]:n:' \
                    '--forks=+[n]:n:' \
                    '--verbosity=+[level]:n:' \
                    '-v+[level]:n:' \
                    '--start-at-task=+[task]:str:' \
                    '--rotate-artifacts=+[n]:n:' \
                    '--list-tags[list tags]' \
                    '--list-tasks[list tasks]' \
                    '--list-hosts[list hosts]' \
                    '--check[check mode]' \
                    '--diff[diff mode]' \
                    '--syntax-check[syntax check]' \
                    '--quiet[quiet]' \
                    '--process-isolation[process isolation]' \
                    '--process-isolation-executable=+[exec]:str:' \
                    '--process-isolation-path=+[path]:dir:_files -/' \
                    '--container-image=+[image]:str:' \
                    '--container-volume-mount=+[mount]:str:' \
                    '--container-option=+[option]:str:' \
                    '--directory-isolation-base-path=+[path]:dir:_files -/' \
                    '--json[stream events as json]' \
                    '--omit-event-data[omit event data]' \
                    '--only-failed-event-data[only failed event data]' ;;
                stop|is-alive) _arguments '1:private dir:_files -/' ;;
            esac
            ;;
    esac
}

_ansible-runner-cli "$@"
