#compdef dmregrid2
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmregrid2.html
# Regrid a single image with rotation, shift, and scaling

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input image file]:infile:_files' \
  'outfile=[output image file]:outfile:_files' \
  'resolution=[points along each side of pixel]:resolution:' \
  'method=[sum or average pixel values]:method:(sum average)' \
  'theta=[rotation angle]:theta:' \
  'rotxcenter=[x-center of rotation]:rotxcenter:' \
  'rotycenter=[y-center of rotation]:rotycenter:' \
  'xoffset=[shift in X-direction]:xoffset:' \
  'yoffset=[shift in Y-direction]:yoffset:' \
  'xscale=[scaling in the X-direction]:xscale:' \
  'yscale=[scaling in the Y-direction]:yscale:' \
  'coord_sys=[coordinate system of parameters]:coord_sys:(logical physical)' \
  'lookupTab=[header merging rules]:lookupTab:_files' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'verbose=[verbosity level]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
