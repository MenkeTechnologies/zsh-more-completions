#compdef elink
# Documentation: https://www.ncbi.nlm.nih.gov/books/NBK179288/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# NCBI EDirect elink: link records between Entrez databases
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-db=[source database]:db:(pubmed protein nucleotide gene structure pmc taxonomy snp)' \
  '-target=[target database]:db:(pubmed protein nucleotide gene structure pmc taxonomy snp)' \
  '-id=[UID list]:ids:' \
  '-name=[name of link to follow]:linkname:' \
  '-cmd=[command]:cmd:(acheck llinks llinkslib lcheck ncheck neighbor neighbor_score neighbor_history prlinks)' \
  '-related[get related records in same db]' \
  '-cited[show citing publications]' \
  '-cites[follow reference lists of PubMed records]' \
  '-citedin[show records that cite this]' \
  '-log[enable logging]' \
  '-WebEnv=[reuse WebEnv]:env:' \
  '-query_key=[reuse query_key]:key:' \
  '-batch[batch mode]' \
  '-mindate=[minimum date]:date:' \
  '-maxdate=[maximum date]:date:' \
  '-datetype=[date type]:type:(PDAT EDAT MDAT)' \
  '*::ids:' && ret=0
return ret
