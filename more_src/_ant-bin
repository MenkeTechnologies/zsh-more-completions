#compdef ant
# _ant-bin — Apache Ant Java build tool (Apache, Java); classic XML-driven build system for Java projects
# upstream: https://github.com/apache/ant

_ant-bin() {
    _arguments \
        '-help[show help]' \
        '-h[show help]' \
        '-version[show version]' \
        '-diagnostics[print diagnostics]' \
        '-quiet[quiet]' \
        '-q[quiet]' \
        '-silent[silent]' \
        '-S[silent]' \
        '-verbose[verbose]' \
        '-v[verbose]' \
        '-debug[debug]' \
        '-d[debug]' \
        '-emacs[emacs-style output]' \
        '-e[emacs-style output]' \
        '-lib+[lib path]:dir:_files -/' \
        '-logfile+[log file]:file:_files' \
        '-l+[log file]:file:_files' \
        '-logger+[logger class]:class:' \
        '-listener+[listener class]:class:' \
        '-noinput[no input]' \
        '-buildfile+[build file]:file:_files -g "build.xml"' \
        '-file+[build file]:file:_files -g "build.xml"' \
        '-f+[build file]:file:_files -g "build.xml"' \
        '-D+[property]:KEY=VAL:' \
        '-keep-going[keep going]' \
        '-k[keep going]' \
        '-propertyfile+[property file]:file:_files' \
        '-inputhandler+[input handler]:class:' \
        '-find+[search build file]:file:_files' \
        '-s+[search build file]:file:_files' \
        '-nice+[priority]:n:' \
        '-nouserlib[no user lib]' \
        '-noclasspath[no classpath]' \
        '-autoproxy[auto proxy]' \
        '-main+[main class]:class:' \
        '*:target:'
}

_ant-bin "$@"
