#compdef ociowrite
# serialize a color transformation to a CTF or CLF XML file

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--colorspaces[source and destination color spaces for a ColorSpaceTransform]:src: :dst:' \
  '--file=[output filename (extension selects CTF or CLF)]:file:_files -g "*.(ctf|clf)"' && ret=0

return ret
