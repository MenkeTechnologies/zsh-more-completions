#compdef generate-peptides
# Documentation: https://crux.ms/commands/generate-peptides.html
# Crux generate-peptides: enumerate peptides from a protein database.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--min-mass=[minimum peptide mass (Da)]:mass' \
  '--max-mass=[maximum peptide mass (Da)]:mass' \
  '--min-length=[minimum peptide length]:n' \
  '--max-length=[maximum peptide length]:n' \
  '--isotopic-mass=[type of isotopic masses]:type:(average mono)' \
  '--clip-nterm-methionine=[include N-terminal Met variants]:bool:(T F)' \
  '--mod-precision=[precision for modifications in output]:n' \
  '--seed=[random number generator seed]:seed' \
  '--decoy-format=[decoy generation method]:fmt:(none shuffle peptide-reverse)' \
  '--keep-terminal-aminos=[terminal amino acids to preserve in decoys]:where:(N C NC none)' \
  '--enzyme=[enzyme for in silico digestion]:enzyme' \
  '--custom-enzyme=[custom digestion rules]:rule' \
  '--digestion=[digestion terminus requirements]:type:(full-digest partial-digest non-specific-digest)' \
  '--missed-cleavages=[maximum missed cleavages]:n' \
  '--decoy-prefix=[prefix for decoy protein names]:prefix' \
  '--fileroot=[prefix for output filenames]:prefix' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--overwrite=[overwrite existing files]:bool:(T F)' \
  '--parameter-file=[parameter file path]:file:_files' \
  '--verbosity=[verbosity level 0-60]:level' \
  '*:fasta:_files' && ret=0

return ret
