#compdef expo-cli2 expo2
# _expo-cli2 — Expo expo-cli2 CLI command-line frontend wrapping the Expo CLI command-line interface for the Expo open-source framework and platform for universal React applications React Native open-source written in TypeScript Node start install build prebuild export run-ios run-android publish login logout register whoami init export modules customize url config diagnostics doctor send credentials credentials-resolve EAS Continuous-Native-Generation OTA-updates Hermes-engine eas-build eas-submit eas-update eas-init eas-config-build-fingerprint-finger (Expo team Charlie Cheever James Ide, TypeScript); commander
# upstream: https://expo.dev/

_expo-cli2() {
    local -a sub=(
        'config:show project config'
        'customize:create local config files'
        'diagnostics:show env info'
        'doctor:diagnose project issues'
        'export:export the JS bundle'
        'help:show help'
        'init:scaffold a new app'
        'install:install dependencies'
        'login:authenticate'
        'logout:revoke session'
        'modules:Expo Modules ops'
        'prebuild:generate native projects'
        'publish:publish update'
        'register:register account'
        'run:run on a device'
        'send:send link via SMS'
        'start:start dev server'
        'whoami:show identity'
        'eas:EAS operations'
        'serve:serve exported bundle'
        'open:open in app'
        'logs:show device logs'
        'credentials:credentials ops'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--non-interactive[non interactive]' \
        '--offline[offline]' \
        '--host=+[h]:h:(lan localhost tunnel)' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--lan[LAN host]' \
        '--localhost[localhost]' \
        '--tunnel[tunnel]' \
        '--scheme=+[name]:str:' \
        '--ios[run iOS]' \
        '-i[run iOS]' \
        '--android[run Android]' \
        '-a[run Android]' \
        '--web[run web]' \
        '-w[run web]' \
        '--no-build-cache[no build cache]' \
        '--max-workers=+[N]:n:' \
        '--platform=+[p]:p:(ios android web all)' \
        '*--platform=+[p]:p:(ios android web)' \
        '--dev[dev mode]' \
        '--minify[minify]' \
        '--clear[clear cache]' \
        '-c[clear cache]' \
        '--reset-cache[reset cache]' \
        '--metro-port=+[port]:n:' \
        '--config=+[file]:file:_files -g "app.json app.config.* *.json *.ts *.js"' \
        '--public-url=+[url]:str:' \
        '--output-dir=+[dir]:dir:_files -/' \
        '--output-format=+[fmt]:f:(jsbundle json)' \
        '--source-maps[source maps]' \
        '--asset-url=+[url]:str:' \
        '--target=+[t]:t:(managed bare)' \
        '--template=+[name]:str:' \
        '-t+[template]:str:' \
        '--name=+[name]:str:' \
        '--slug=+[slug]:str:' \
        '--skip-dependency-update=+[deps]:str:' \
        '--no-install[no install]' \
        '--yes[yes]' \
        '-y[yes]' \
        '--check[check only]' \
        '--fix[fix issues]' \
        '--device=+[name]:str:' \
        '-d+[device]:str:' \
        '--simulator=+[name]:str:' \
        '--bundler[bundler]' \
        '--variant=+[name]:str:' \
        '--scheme-suffix=+[s]:str:' \
        '--configuration=+[c]:c:(Debug Release)' \
        '--archive=+[path]:_files' \
        '--binary=+[path]:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'expo subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments '1:platform:(ios android)' '*:arg:' ;;
                start) _arguments '*:dir:_files -/' ;;
                eas) _arguments '1:op:(build submit update channel branch project metadata config secret init credentials login logout whoami)' '*:arg:' ;;
                credentials) _arguments '1:op:(manager configure-build-credentials)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_expo-cli2 "$@"
