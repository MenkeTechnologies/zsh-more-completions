#compdef pvmove
# _pvmove — move physical extents off a PV (LVM2); migrate data between physical volumes online
# upstream: https://gitlab.com/lvmteam/lvm2

_pvmove() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-A --autobackup)'{-A,--autobackup}'+[autobackup]:bool:(y n)' \
        '(-b --background)'{-b,--background}'[background]' \
        '(-i --interval)'{-i,--interval}'+[progress interval]:sec:' \
        '(-n --name)'{-n,--name}'+[lv name to move]:lv:' \
        '--abort[abort move in progress]' \
        '--alloc+[allocation policy]:policy:(contiguous cling normal anywhere inherit)' \
        '--atomic[atomic move]' \
        '--noudevsync[do not sync udev]' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '1:source pv:_files' \
        '*:dest pv:_files'
}

_pvmove "$@"
