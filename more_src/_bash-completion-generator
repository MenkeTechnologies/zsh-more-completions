#compdef bash-completion-generator
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-o+[output file]:output:_files' \
  '--output=[output file]:output:_files' \
  '*::command:_command_names -e' && return 0
