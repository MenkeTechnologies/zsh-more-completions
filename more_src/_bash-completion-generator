#compdef bash-completion-generator
# Documentation: https://man.archlinux.org/search?q=bash-completion-generator
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-o+[output file]:output:_files' \
  '--output=[output file]:output:_files' \
  '*::command:_command_names -e' && return 0
