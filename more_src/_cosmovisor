#compdef cosmovisor
# Documentation: https://github.com/cosmos/cosmos-sdk/tree/main/tools/cosmovisor
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cosmovisor - process manager / upgrader for Cosmos SDK chains.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:create cosmovisor folder structure for executable'
  'add-upgrade:manually add an upgrade binary'
  'prepare-upgrade:retrieve, verify and install upgrade binary'
  'run:run the configured binary, passing through remaining args'
  'config:print the resolved cosmovisor environment'
  'version:print cosmovisor version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cosmovisor command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init|add-upgrade|prepare-upgrade) _arguments '*:executable:_files' && ret=0 ;;
    esac ;;
esac

return ret
