#compdef cosmovisor

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:create cosmovisor folder structure for executable'
  'add-upgrade:manually add an upgrade version'
  'prepare-upgrade:prepare upgrade folders'
  'show-upgrade-info:print info for current upgrade'
  'run:run app under cosmovisor management'
  'config:print resolved config'
  'version:show cosmovisor version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cosmovisor command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init|add-upgrade|prepare-upgrade) _arguments '*:executable:_files' && ret=0 ;;
    esac ;;
esac

return ret
