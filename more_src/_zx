#compdef zx

_zx() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments \
    '--quiet[Suppress script output]' \
    '--verbose[Enable verbose mode]' \
    '--shell[Shell to use]:shell:_command_names' \
    '--prefix[Command prefix]:prefix:' \
    '--postfix[Command postfix]:postfix:' \
    '--cwd[Working directory]:dir:_directories' \
    '--env[Set environment variable]:var:' \
    '--eval[Evaluate expression]:expr:' \
    '--ext[File extension override]:ext:(mjs mts js ts)' \
    '--install[Install dependencies]' \
    '--registry[npm registry URL]:url:' \
    '--version[Print version]' \
    '--help[Show help]' \
    '1:script:_files -g "*.mjs *.mts *.js *.ts *.md"'
}

_zx "$@"
