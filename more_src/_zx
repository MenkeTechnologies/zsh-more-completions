#compdef zx
# Documentation: https://google.github.io/zx/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Replaced bogus man.archlinux.org URL with the real google/zx CLI docs.

_zx() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments \
    '--quiet[Suppress any outputs]' \
    '--verbose[Enable verbose mode]' \
    '--shell=[Specify a custom shell binary path]:shell:_command_names' \
    '--prefix=[Attach a command to the beginning of every command]:prefix:' \
    '--postfix=[Attach a command to the end of every command]:postfix:' \
    '--cwd=[Set the current working directory]:dir:_directories' \
    '--env=[Specify an env file]:file:_files' \
    '--eval=[Evaluate the following argument as a script]:expr:' \
    '--ext=[Override the default script extension]:ext:(mjs mts js ts)' \
    '--install[Install missing dependencies automatically]' \
    '--registry=[Customize the npm registry]:url:' \
    '(-l --prefer-local)'{-l,--prefer-local}'[Prefer locally installed packages and binaries]' \
    '--repl[Starts zx in REPL mode]' \
    '(-v --version)'{-v,--version}'[Print the current zx version]' \
    '(-h --help)'{-h,--help}'[Print help notes]' \
    '1:script:_files -g "*.mjs *.mts *.js *.ts *.md"'
}

_zx "$@"
