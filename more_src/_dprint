#compdef dprint

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize configuration file'
      'fmt:format files'
      'check:check files are formatted'
      'config:manage configuration'
      'output-file-paths:output resolved file paths'
      'output-resolved-config:output resolved config'
      'output-format-times:output format times'
      'clear-cache:clear formatting cache'
      'upgrade:upgrade dprint'
      'completions:generate shell completions'
      'license:output license'
    )
    _describe -t commands 'dprint command' commands && ret=0
    ;;
  args)
    case $line[1] in
      fmt|check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[path to config file]:config file:_files' \
          '--config=[path to config file]:config file:_files' \
          '--excludes=[glob patterns to exclude]:pattern' \
          '--plugins=[URLs or file paths of plugins]:plugin' \
          '--incremental[only format changed files]' \
          '--diff[output diff]' \
          '*:files:_files' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(init add update)' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '1:shell:(bash fish zsh powershell)' && ret=0
        ;;
      clear-cache|upgrade|license)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
