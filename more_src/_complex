#compdef complex
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss28.html
# KAPPA: converts between representations of complex data in NDFs

local ret=1

_arguments -s \
  'IN1=[first input NDF]:ndf:_files -g "*.sdf"' \
  'IN2=[second input NDF]:ndf:_files -g "*.sdf"' \
  'OUT1=[first output NDF]:ndf:_files -g "*.sdf"' \
  'OUT2=[second output NDF]:ndf:_files -g "*.sdf"' \
  'INTYPE=[representation of the input data]:type' \
  'OUTTYPE=[representation of the output data]:type' \
  'TITLE1=[title for first output NDF]:title' \
  'TITLE2=[title for second output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
