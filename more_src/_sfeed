# _sfeed — suckless RSS / Atom parser (codemadness/sfeed)
# upstream: https://codemadness.org/sfeed.html
# Synopsis from sfeed.1 — `sfeed [baseurl]` reads RSS/Atom on stdin, writes TSV on stdout.

_sfeed() {
    _arguments -s -S \
        '(- *)1:base URL (optional):'
}

_sfeed "$@"
