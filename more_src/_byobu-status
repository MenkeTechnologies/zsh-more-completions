#compdef byobu-status
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/byobu-status.1.html
# byobu: print or toggle byobu status notifications

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--detail[show detailed status output]' \
  '1:position:(tmux_left tmux_right screen_upper_left screen_upper_right screen_lower_left screen_lower_right)' \
  '*:status item:_default' && ret=0

return ret
