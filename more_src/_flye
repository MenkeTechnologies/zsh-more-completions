#compdef flye
# Documentation: https://github.com/mikolmogorov/Flye/blob/flye/docs/USAGE.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Flye: assembler for long reads (Nanopore/PacBio)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--pacbio-raw[raw PacBio reads]:file:_files' \
  '--pacbio-corr[corrected PacBio reads]:file:_files' \
  '--pacbio-hifi[PacBio HiFi reads]:file:_files' \
  '--nano-raw[raw Nanopore reads]:file:_files' \
  '--nano-corr[corrected Nanopore reads]:file:_files' \
  '--nano-hq[high-quality Nanopore reads (Q20+)]:file:_files' \
  '--subassemblies[subassemblies to merge]:file:_files' \
  '(-o --out-dir)'{-o,--out-dir=}'[output directory]:dir:_files -/' \
  '(-g --genome-size)'{-g,--genome-size=}'[genome size (e.g. 3g, 200m)]:size:' \
  '(-t --threads)'{-t,--threads=}'[number of threads]:n:' \
  '(-i --iterations)'{-i,--iterations=}'[polishing iterations]:n:' \
  '(-m --min-overlap)'{-m,--min-overlap=}'[minimum overlap length]:n:' \
  '--asm-coverage=[reduce coverage for initial disjointig assembly]:cov:' \
  '--hifi-error=[expected HiFi read error rate]:rate:' \
  '--read-error=[expected read error rate]:rate:' \
  '--no-alt-contigs[do not output alternative contigs]' \
  '--scaffold[scaffold using long reads]' \
  '--resume[resume from last checkpoint]' \
  '--resume-from[resume from specific stage]:stage:(assembly consensus repeat trestle contigger polishing)' \
  '--stop-after[stop after specific stage]:stage:(assembly consensus repeat trestle contigger polishing)' \
  '--debug[debug mode]' \
  '--meta[metagenome mode]' \
  '--keep-haplotypes[keep alternative haplotypes]' \
  '--min-overlap=[minimum overlap (alternative to -m)]:n:' \
  '*:reads:_files' && ret=0
return ret
