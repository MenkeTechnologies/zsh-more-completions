#compdef ocspcheck

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-N[ignore nonces in OCSP response]' \
  '-v[verbose]' \
  '-C+[trusted CA bundle]:CA file:_files' \
  '-i+[input staple file]:staple file:_files' \
  '-o+[output staple file]:staple file:_files' \
  '*:certificate file:_files -g "*.(pem|crt|cer)"' && ret=0

return ret
