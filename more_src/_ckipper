#compdef ckipper ck
# Documentation: https://github.com/mswdev/Ckipper
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands
    commands=(
      'setup:Interactive wizard for configuring Ckipper'
      'run:Create-or-cd to a worktree, optionally Docker'
      'config:Manage settings (get/set/unset/list/edit)'
      'account:Manage multiple Claude accounts'
      'worktree:Manage git worktrees'
      'doctor:Diagnose registry, hooks, schema; optionally repair'
      'help:Show help'
    )
    _describe -t commands 'ckipper command' commands && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _values 'config subcommand' get set unset list edit && ret=0
        ;;
      account)
        _values 'account subcommand' add list default remove rename sync redeploy-hooks && ret=0
        ;;
      worktree)
        _values 'worktree subcommand' run list rm rebuild-image && ret=0
        ;;
      doctor)
        _arguments '--fix[attempt repair]' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
