#compdef xdg-user-dirs-update xdg-user-dir
# Documentation: https://www.freedesktop.org/wiki/Software/xdg-user-dirs/
# Reference accessed: 2026-05-21
# Verified: xdg-user-dirs-update accepts --help/--force/--dummy-output/--set;
# xdg-user-dir accepts only a NAME positional (no flags).
# Note: there is no `xdg-user-dirs` binary upstream; this compdef covers both
# real binaries shipped by the project.

local curcontext="$curcontext" state line ret=1
local -a names=(DESKTOP DOWNLOAD TEMPLATES PUBLICSHARE DOCUMENTS MUSIC PICTURES VIDEOS)

case $service in
  (xdg-user-dirs-update)
    _arguments -s -S \
      '(- *)--help[show help]' \
      '--force[update even if user disabled]' \
      '--dummy-output=[write dummy file marking last update]:path:_files' \
      '*--set[set directory mapping]:name:($names) :path:_files -/' && ret=0
    ;;
  (xdg-user-dir)
    _arguments -s -S \
      '1:name:($names)' && ret=0
    ;;
esac

return ret
