#compdef oct-harmonic-spectrum
# Documentation: https://www.octopus-code.org/documentation/main/manual/utilities/oct-harmonic-spectrum/
# Octopus: compute the harmonic spectrum from a time-dependent run

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help and exit]' \
  '(-v --version)'{-v,--version}'[print octopus version]' \
  '(-w --freq)'{-w,--freq}'=[specify the fundamental frequency]:freq' \
  '(-p --pol)'{-p,--pol}'=[specify the direction of the light polarization]:pol' \
  '(-m --mode)'{-m,--mode}'=[mode used to compute the harmonic spectrum]:mode' \
  '(-a --ar)'{-a,--ar}'[calculate the angle-resolved harmonic spectrum]' \
  '(-x --x)'{-x,--x}'=[x component of the polarization direction]:x' \
  '(-y --y)'{-y,--y}'=[y component of the polarization direction]:y' \
  '(-z --z)'{-z,--z}'=[z component of the polarization direction]:z' && ret=0

return ret
