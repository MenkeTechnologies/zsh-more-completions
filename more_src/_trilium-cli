#compdef trilium-cli
# _trilium-cli — Trilium personal hierarchical note app CLI alias (zadam team, JavaScript); custom argparse
# upstream: https://github.com/zadam/trilium

_trilium-cli() {
    local -a sub=(
        'login:save ETAPI token'
        'logout:clear token'
        'note:list:list child notes'
        'note:get:get note'
        'note:create:create note'
        'note:update:update note title or content'
        'note:delete:delete note'
        'note:export:export subtree'
        'note:import:import notes'
        'note:move:move note'
        'note:clone:clone note'
        'note:tree:print note tree'
        'note:search:search notes'
        'attribute:list:list attributes'
        'attribute:add:add attribute'
        'attribute:delete:delete attribute'
        'attachment:list:list attachments'
        'attachment:add:add attachment'
        'attachment:delete:delete attachment'
        'attachment:download:download attachment'
        'branch:list:list branches'
        'branch:create:create branch'
        'branch:delete:delete branch'
        'backup:create:create backup'
        'backup:restore:restore backup'
        'inbox:show today inbox'
        'app-info:show app info'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--url=+[trilium url]:url:_urls' \
        '--token=+[etapi token]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'trilium subcommand' sub ;;
        args)
            case $words[1] in
                note:create) _arguments \
                    '--parent=+[parent note id]:str:' \
                    '-p+[parent note id]:str:' \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--type=+[type]:t:(text code render mermaid book noteMap search shortcut webView relationMap canvas)' \
                    '--mime=+[mime type]:str:' \
                    '--content=+[content]:str:' \
                    '--content-file=+[content file]:file:_files' ;;
                note:export) _arguments \
                    '1:note id:' \
                    '2:output file:_files -g "*.{zip,html,md}"' \
                    '--format=+[format]:f:(markdown html zip)' ;;
                note:search) _arguments \
                    '1:query:' \
                    '--fast-search[fast search]' \
                    '--include-archived-notes[include archived]' \
                    '--ancestor-note-id=+[ancestor id]:str:' \
                    '--limit=+[limit]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_trilium-cli "$@"
