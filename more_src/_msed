#compdef msed
# Documentation: https://manpages.debian.org/testing/mblaze/msed.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. mblaze msed header editor.
# Syntax: msed script [msgs ...] - script contains a/c/d/s commands like
# /header/a/value/  /headers/c/value/  /headers/d  [/headers/]s/regex/repl/[flags]

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:script:' \
  '*:message:_files' && ret=0

return ret
