#compdef par2 par2create par2verify par2repair

# Zsh completion for par2 - PAR 2.0 parity file tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create recovery files (c)'
  'verify:verify files using recovery data (v)'
  'repair:repair files using recovery data (r)'
)

if [[ "$service" = "par2" ]]; then
  _arguments -s -S \
    '1:command:->command' \
    '*::args:->args' && ret=0
else
  state=args
fi

case "$state" in
  command)
    _describe -t commands 'par2 command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      '-b+[set block count]:block count:' \
      '-s+[set block size]:block size:' \
      '-r+[set redundancy level (percent)]:percent:' \
      '-c+[set recovery file count]:count:' \
      '-f+[set first recovery block number]:number:' \
      '-u[uniform recovery file sizes]' \
      '-l[limit size of recovery files]' \
      '-n+[set number of source files]:count:' \
      '-m+[set memory limit (MB)]:megabytes:' \
      '-t+[set number of threads]:threads:' \
      '-v[verbose output]' \
      '-vv[more verbose output]' \
      '-q[quiet mode]' \
      '-qq[very quiet mode]' \
      '-p[purge backup files after successful repair]' \
      '-N[do not recurse into subdirectories]' \
      '-B+[set base path]:path:_files -/' \
      '*:files:_files' && ret=0
    ;;
esac

return ret
