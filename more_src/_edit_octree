#compdef edit_octree
# Documentation: https://github.com/OctoMap/octomap/blob/devel/octomap/src/edit_octree.cpp
# Edit an OctoMap octree (offset, resolution, scale)

local ret=1

_arguments -s -S \
  '-o[output filename]:bt:_files -g "*.bt"' \
  '--offset[add translation offset to octree coordinates]:x y z' \
  '--res[set octree resolution to value]:m' \
  '--scale[multiply current octree resolution by factor]:factor' \
  '*:octree:_files -g "*.bt *.ot"' && ret=0

return ret
