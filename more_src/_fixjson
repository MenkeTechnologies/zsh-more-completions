#compdef fixjson
# Documentation: https://github.com/rhysd/fixjson
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-w --write)'{-w,--write}'[overwrite files with formatted output]' \
  '(-i --indent)'{-i+,--indent=}'[indent spaces (auto-detected if omitted)]:n:' \
  '--minify[minify JSON output]' \
  '--stdin-filename=[filename when reading from STDIN]:name:' \
  '*:file or glob:_files' && ret=0

return ret
