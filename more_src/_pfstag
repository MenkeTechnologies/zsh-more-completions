#compdef pfstag
# Documentation: https://resources.mpi-inf.mpg.de/pfstools/man1/pfstag.1.html
# set or remove tags to/from a pfs stream

local ret=1

_arguments -s \
  '(-s --set --add)'{-s+,--set=,--add=}'[add or change a tag ([channel:]name=value)]:tag' \
  '(-r --remove)'{-r+,--remove=}'[remove a tag ([channel:]name)]:tag' && ret=0

return ret
