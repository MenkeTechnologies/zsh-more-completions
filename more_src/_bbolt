#compdef bbolt
# Documentation: upstream cmd/bbolt/command/ files at github.com/etcd-io/bbolt
# Reference accessed: 2026-05-30
# etcd-io/bbolt R59 — CLI for the embedded Bolt key/value database
# (single-file ACID b+tree). Sister-tool to existing _etcdctl/_etcdutl
# coverage in the etcd family.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'bench:run a benchmark against a database file'
  'buckets:list buckets at the top level of a database file'
  'check:verify integrity (and traverse pages) of a database'
  'compact:rewrite a database into a new file, reclaiming space'
  'dump:dump raw page bytes (hex)'
  'get:retrieve a value for a given key in a bucket'
  'info:show metadata about a database file'
  'inspect:inspect db structure (buckets/keys hierarchical view)'
  'keys:list keys in a bucket'
  'page:show details of a single page'
  'page-item:show a single key/value item from a page'
  'pages:list summary of all pages'
  'stats:show stats for buckets'
  'surgery:repair a corrupted database (nested actions)'
  'version:show version'
)

local -a _surgery_subs
_surgery_subs=(
  'revert-meta-page:revert to the alternative meta page'
  'copy-page:copy a page from one DB to another'
  'clear-page:zero out a page'
  'clear-page-elements:clear elements within a page'
  'freelist:freelist surgery (abandon/rebuild)'
  'meta:meta-page surgery (validate/update)'
)

local -a _surgery_freelist
_surgery_freelist=(
  'abandon:abandon the freelist (rebuild on next open)'
  'rebuild:rebuild the freelist from scratch'
)

local -a _surgery_meta
_surgery_meta=(
  'validate:validate the meta pages'
  'update:update a meta-page field'
)

_arguments -C -s -S \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'bbolt subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      buckets|check|compact|dump|info|inspect|stats|version)
        _arguments '*:database file:_files -g "*.db"' && ret=0
        ;;
      keys)
        _arguments \
          '1:database file:_files -g "*.db"' \
          '2:bucket name:' && ret=0
        ;;
      get)
        _arguments \
          '1:database file:_files -g "*.db"' \
          '2:bucket name:' \
          '3:key:' && ret=0
        ;;
      page)
        _arguments \
          '1:database file:_files -g "*.db"' \
          '*:page id:' && ret=0
        ;;
      page-item)
        _arguments \
          '1:database file:_files -g "*.db"' \
          '2:page id:' \
          '3:item id:' && ret=0
        ;;
      pages)
        _arguments '1:database file:_files -g "*.db"' && ret=0
        ;;
      bench)
        _arguments \
          '-profile-mode=[profiling mode]:mode:(rw r w)' \
          '-write-mode=[write mode]:mode:(seq rnd seq-nest rnd-nest)' \
          '-read-mode=[read mode]:mode:(seq rnd)' \
          '-count=[number of records (default 1000)]:N:' \
          '-batch-size=[batch size]:N:' \
          '-key-size=[key size in bytes]:N:' \
          '-value-size=[value size in bytes]:N:' \
          '-cpuprofile=[CPU profile file]:file:_files' \
          '-memprofile=[memory profile file]:file:_files' \
          '-blockprofile=[block profile file]:file:_files' \
          '-stats-interval=[stats reporting interval]:duration:' \
          '-fill-percent=[fill percent (default 0.5)]:fraction:' \
          '-no-sync[disable fsync]' \
          '-work[print work info]' \
          '-path=[path to write profile files]:directory:_directories' \
          && ret=0
        ;;
      surgery)
        _arguments -C \
          '(-): :->surgcmd' \
          '(-)*:: :->surgcmd_args' && ret=0
        case $state in
          surgcmd)
            _describe -t commands 'bbolt surgery subcommand' _surgery_subs && ret=0
            ;;
          surgcmd_args)
            case $words[1] in
              freelist)
                _arguments '1:freelist action:(abandon rebuild)' && ret=0
                ;;
              meta)
                _arguments '1:meta action:(validate update)' && ret=0
                ;;
              revert-meta-page|copy-page|clear-page|clear-page-elements)
                _arguments \
                  '*:database file:_files -g "*.db"' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
