#compdef dvips
# Documentation: dvips --help
# Source: TeX dvips — convert DVI to PostScript.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a-[conserve memory not time]::suffix:(0)' \
    '(-A -B)-A[only odd (TeX) pages]' \
    '(-A -B)-B[only even (TeX) pages]' \
    '-b+[page copies]:n:' \
    '-bitmapfontenc+[bitmap font encoding]:mode:(on off strict)' \
    '-c+[uncollated copies]:n:' \
    '-C+[collated copies]:n:' \
    '-d+[debugging mask]:n:' \
    '-D+[resolution]:n:' \
    '-e+[maxdrift value]:n:' \
    '-E-[create EPSF]::suffix:(0)' \
    '-f-[run as filter]::suffix:(0)' \
    '-F-[send Ctrl-D at end]::suffix:(0)' \
    '-G-[shift low chars to higher pos]::suffix:(0)' \
    '*-h+[add header file]:file:_files' \
    '-i-[separate file per section]::suffix:(0)' \
    '-j-[download fonts partially]::suffix:(0)' \
    '-k-[print crop marks]::suffix:(0)' \
    '-K-[pull comments from inclusions]::suffix:(0)' \
    '-l+[last page]:n:' \
    '-L-[last special papersize wins]::suffix:(0)' \
    '-landscaperotate-[landscape rotated on portrait]::suffix:(0)' \
    '-m-[manual feed]::suffix:(0)' \
    '-M-[do not make fonts]::suffix:(0)' \
    '-mode+[Metafont device name]:device:' \
    '-n+[max pages]:n:' \
    '-N-[no structured comments]::suffix:(0)' \
    '-noomega[disable Omega extensions]' \
    '-noptex[disable pTeX extensions]' \
    '-o+[output file]:file:_files' \
    '-O+[paper offset (XxY)]:offset:' \
    '-p+[first page]:n:' \
    '-P+[load config.s]:configsuffix:' \
    '-pp+[page-range list]:ranges:' \
    '-q-[run quietly]::suffix:(0)' \
    '-r-[reverse page order]::suffix:(0)' \
    '-R-[run securely]::suffix:(0)' \
    '-s-[enclose output in save/restore]::suffix:(0)' \
    '-S+[max section size in pages]:n:' \
    '-t+[paper format]:format:(letter legal A4 ledger landscape unknown)' \
    '-T+[page size WxH]:WxH:' \
    '-title+[title in comment]:string:' \
    '-u+[PS mapfile]:file:_files' \
    '-U-[disable string param trick]::suffix:(0)' \
    '(- *)-v[print version]' \
    '-V-[send downloadable PS fonts as PK]::suffix:(0)' \
    '-x+[override DVI magnification]:n:' \
    '-X+[horizontal resolution]:n:' \
    '-y+[multiply by DVI magnification]:n:' \
    '-Y+[vertical resolution]:n:' \
    '-z-[hyper PS]::suffix:(0)' \
    '-Z-[compress bitmap fonts]::suffix:(0)' \
    '*:DVI file:_files -g "*.dvi"' \
    && ret=0

return ret
