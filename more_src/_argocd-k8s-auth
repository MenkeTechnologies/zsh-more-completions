#compdef argocd-k8s-auth
# _argocd-k8s-auth — generate Kubernetes auth tokens for Argo CD (argoproj/argo-cd)
# upstream: https://github.com/argoproj/argo-cd
# Subcommands from cmd/argocd-k8s-auth/commands/ (cobra).

_argocd-k8s-auth() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                aws:'generate AWS EKS auth token'
                gcp:'generate GCP GKE auth token'
                azure:'generate Azure AKS auth token'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                aws)
                    _arguments \
                        '--cluster-name=[AWS EKS cluster name]:name:' \
                        '--role-arn=[AWS Role ARN to assume]:arn:' \
                        '--profile=[AWS profile]:profile:' ;;
            esac
            ;;
    esac
}

_argocd-k8s-auth "$@"
