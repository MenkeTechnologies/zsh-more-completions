#compdef ovs-monitor-ipsec
# _ovs-monitor-ipsec — Open vSwitch ovs-monitor-ipsec (small daemon that monitors the local ovsdb's IPsec table and configures strongSwan (charon) or Libreswan (pluto) to bring up site-to-site or remote IKEv2 tunnels for OVS-managed bridges; --pidfile, --root-prefix path, --ike-daemon (libreswan|strongswan), --log-file, --verbose, --no-restart-ike, --no-cleanup-conf-on-exit, --restart, --version)
# upstream: https://github.com/openvswitch/ovs (ipsec)
# Flags from openvswitch/ovs ipsec/ovs-monitor-ipsec.in on tip.

_ovs-monitor-ipsec() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--pidfile+[pidfile]:file:_files' \
        '--root-prefix+[root prefix]:dir:_files -/' \
        '--ike-daemon=*[ike daemon]:daemon:(libreswan strongswan)' \
        '--log-file+[log file]:file:_files' \
        '--verbose+[module]:module:' \
        '--no-restart-ike[do not restart IKE daemon]' \
        '--no-cleanup-conf-on-exit[skip cleanup]' \
        '--restart[restart]'
}

_ovs-monitor-ipsec "$@"
