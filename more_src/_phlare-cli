#compdef phlare-cli profilecli
# _phlare-cli — Grafana Labs phlare-cli profilecli CLI command-line client to the Grafana Phlare Grafana Pyroscope continuous profiling REST API querying profile flame-graph series-listing tenant-stats backup-restore admin-block-list ingester-tools merge-mass-deletion for the continuous profiling backend (Grafana Labs team, Go); cobra
# upstream: https://grafana.com/oss/pyroscope/

_phlare-cli() {
    local -a sub=(
        'query:query profiles'
        'series:list series'
        'render:render profile to file'
        'merge:merge multiple profiles'
        'admin:admin operations'
        'tenant:tenant operations'
        'block:block operations'
        'upload:upload a profile'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[url]:str:' \
        '--url=+[url]:str:' \
        '-t+[tenant id]:str:' \
        '--tenant-id=+[id]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--tls-skip-verify[insecure TLS]' \
        '--tls-ca-file=+[file]:file:_files' \
        '--tls-cert-file=+[file]:file:_files' \
        '--tls-key-file=+[file]:file:_files' \
        '-q+[query]:str:' \
        '--query=+[query]:str:' \
        '--from=+[time]:str:' \
        '--to=+[time]:str:' \
        '--profile-type=+[type]:str:' \
        '--output=+[fmt]:f:(json text table dot svg flame-graph dot-graph)' \
        '--output-file=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'phlare-cli subcommand' sub ;;
        args)
            case $words[1] in
                query|series|render) _arguments '*:query:' ;;
                merge) _arguments '*:pprof files:_files -g "*.pprof"' ;;
                upload) _arguments '*:file:_files -g "*.pprof"' ;;
            esac
            ;;
    esac
}

_phlare-cli "$@"
