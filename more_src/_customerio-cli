#compdef customerio-cli customerio cio-cli
# _customerio-cli — Customer.io customerio-cli CLI command-line frontend wrapping the Customer.io customer engagement platform REST API managing customers events campaigns broadcasts newsletters segments transactional triggered messages workspace objects journey collections export-customer-API-track-app-API-token (Customer.io team, Go); cobra
# upstream: https://customer.io/

_customerio-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'customer:customer operations'
        'event:event operations'
        'page:page event'
        'identify:identify operations'
        'campaign:campaign operations'
        'broadcast:broadcast operations'
        'newsletter:newsletter operations'
        'segment:segment operations'
        'transactional:transactional message'
        'object:object operations'
        'collection:collection operations'
        'workspace:workspace operations'
        'export:export data'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--site-id=+[id]:str:' \
        '--api-key=+[key]:str:' \
        '--app-api-key=+[key]:str:' \
        '--track-api-key=+[key]:str:' \
        '--region=+[r]:r:(us eu)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'customerio-cli subcommand' sub ;;
        args)
            case $words[1] in
                customer|event|campaign|broadcast|newsletter|segment|transactional|object|collection|workspace) _arguments '1:op:(list get create update delete trigger send pause resume archive)' '*:id:' ;;
            esac
            ;;
    esac
}

_customerio-cli "$@"
