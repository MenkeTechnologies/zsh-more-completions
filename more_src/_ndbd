#compdef ndbd ndbmtd
# NDB Cluster data node daemon

local ret=1

_arguments -s -S \
  '(-? --help --usage)'{-\?,--help,--usage}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--initial[perform initial start, erasing recovery files]' \
  '--initial-start[perform partial initial start]' \
  '(-n --nostart)'{-n,--nostart}'[connect but do not start until commanded]' \
  '--nodaemon[run in foreground]' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '--foreground[run in foreground for debugging]' \
  '(-c --ndb-connectstring --ndb-mgmd-host)'{-c,--ndb-connectstring,--ndb-mgmd-host}'+[management server connection string]:string:' \
  '--ndb-nodeid=[set node ID]:id:' \
  '--bind-address=[bind to specific network interface]:host:_hosts' \
  '--connect-retries=[number of connection attempts]:num:' \
  '--connect-retry-delay=[seconds between connection attempts]:secs:' \
  '--nowait-nodes=[node IDs to skip waiting for]:list:' \
  '(-v --verbose)'{-v,--verbose}'[write extra debugging info to node log]' \
  '--logbuffer-size=[log buffer size]:bytes:' \
  '--core-file[write core file on error]' \
  '--defaults-file=[read options from specified file only]:file:_files' \
  '--defaults-extra-file=[read file after global files]:file:_files' \
  '--no-defaults[do not read any option files except login file]' && ret=0

return ret
