#compdef create-jmrsquared-website-template
# Documentation: https://www.npmjs.com/package/create-jmrsquared-website-template
# Reference accessed: 2026-05-24
# Verified: npm view create-jmrsquared-website-template bin; npm readme full-stack template flags.

# Zsh completion for create-jmrsquared-website-template - Vite site and monorepo scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--template=[scaffold mode]:template:(full)' \
  '--name=[npm-safe project name]:name:' \
  '--frontend=[frontend app]:frontend:(nextjs tanstack-start expo)' \
  '--db=[include database stack]:bool:(true false)' \
  '--cache=[include cache stack]:bool:(true false)' \
  '--mailer=[mailer backend]:mailer:(console mailpit)' \
  '--logger=[logging backend]:logger:(pino console)' \
  '--pkg-manager=[package manager]:manager:(pnpm npm yarn bun)' \
  '--provider=[AI provider CLI]:provider:(claude codex cursor cursor-provider)' \
  '--vsc[include VS Code/Cursor workspace config]' \
  '--warp[include Warp terminal config]' \
  '--skip-install[scaffold files without installing dependencies]' \
  ':project name:' && ret=0

return ret
