#compdef lsm
# Documentation: man lsm (macOS / Apple Latent Semantic Mapping tool)
# Reference accessed: 2026-05-19
# Verified: local `man lsm` on macOS 26.4 (Latent Semantic Mapping
# framework command-line tool, ships with macOS).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -v (verbose) flag (lsm uses subcommands and long
# --options, not a -v top-level flag for module-name arguments).

# lsm: Latent Semantic Mapping tool (macOS)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'create:create a new LSM map from input files'
  'update:add input files to an existing LSM map'
  'evaluate:classify input files into LSM map categories'
  'cluster:compute clusters for the map'
  'dump:dump map words and counts'
  'info:print map information and consistency checks'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'lsm command' commands && ret=0 ;;
  (args)
    _arguments \
      '--help[show help]' \
      '--force[overwrite existing file]' \
      '--dimensions=[dimensions for map]:dim:' \
      '--discard-counts[omit raw word counts in map]' \
      '--hash[write map in non-human-readable format]' \
      '--html[strip HTML codes from input]' \
      '--junk-mail[apply junk-mail heuristics]' \
      '--pairs[store word pairs]' \
      '--triplets[store word triplets and pairs]' \
      '--stop-words=[stop word file]:file:_files' \
      '--sweep-cutoff=[sweep threshold]:n:' \
      '--sweep-frequency=[sweep frequency in days]:days:' \
      '--text-delimiter=[text delimiter]:delim:(file line)' \
      '--weight=[scale input word counts]:weight:' \
      '--words[apply to words instead of categories]' \
      '--k-means=[k-means clusters]:n:' \
      '--agglomerative=[agglomerative clusters]:n:' \
      '--apply[apply clustering to map]' \
      '--each[apply per cluster]' \
      '*:file:_files' && ret=0
    ;;
esac
return ret
