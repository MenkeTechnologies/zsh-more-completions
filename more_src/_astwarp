#compdef astwarp
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astwarp.html
# astwarp — warp and align the pixel grid of an input image to WCS coordinates

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[only report errors, remain quiet about steps]' \
  '--cite[show BibTeX citation for this program]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and abort]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for this directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for this user]' \
  '--config[read configuration file immediately]:file:_files' \
  '--checkconfig[list all config files and variables read]' \
  '--lastconfig[do not parse any more configuration files]' \
  '--onlyversion[only run if program version matches]:version' \
  '--log[include information about outputs in a log file]' \
  '--minmapsize[minimum bytes to avoid automatic RAM usage]:size' \
  '--quietmmap[do not report memory-mapped file name and size]' \
  '--usage[give a short usage message]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[type of output]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--hstartwcs[header keyword number to start reading WCS]:number' \
  '--hendwcs[header keyword number to end reading WCS]:number' \
  '(-C --coveredfrac)'{-C,--coveredfrac}'[acceptable fraction of output pixel covered]:fraction' \
  '(-k --keepwcs)'{-k,--keepwcs}'[do not apply warp to input WCS]' \
  '--wcslinearmatrix[WCS linear matrix of output]:matrix:(pc cd)' \
  '--checkmaxfrac[moire pattern maximum fraction of input pixels on output]' \
  '--ctype[FITS standard CTYPE value]:ctype' \
  '(-c --center)'{-c,--center}'[center coordinate of output image RA,DEC]:center' \
  '--edgesampling[number of extra samplings on pixel sides]:number' \
  '(-G --gridfile)'{-G,--gridfile}'[file to use for output grid]:file:_files' \
  '(-H --gridhdu)'{-H,--gridhdu}'[HDU/extension to use for output grid]:HDU' \
  '--widthinpix[width is in pixels, not WCS coordinates]' \
  '(-w --width)'{-w,--width}'[output image size in both dimensions]:size' \
  '(-x --cdelt)'{-x,--cdelt}'[pixel scale of output in degrees/pixel]:scale' \
  '--centeroncorner[center coordinates on first pixel corner]' \
  '(-e --shear)'{-e,--shear}'[shear along given axis(es)]:shear' \
  '(-f --flip)'{-f,--flip}'[flip along given axis(es)]:axes' \
  '(-m --matrix)'{-m,--matrix}'[raw transformation matrix]:matrix' \
  '(-p --project)'{-p,--project}'[project along given axis(es)]:project' \
  '(-r --rotate)'{-r,--rotate}'[rotate by angle in degrees]:degrees' \
  '(-s --scale)'{-s,--scale}'[scale along given axis(es)]:scale' \
  '(-t --translate)'{-t,--translate}'[translate along given axis(es)]:translate' \
  '*:input:_files' && ret=0

return ret
