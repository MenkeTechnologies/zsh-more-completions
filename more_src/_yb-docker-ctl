#compdef yb-docker-ctl
# _yb-docker-ctl — Yugabyte yb-docker-ctl CLI command-line frontend wrapping the yb-docker-ctl YugabyteDB local Docker-based development cluster management providing create start stop destroy add-node remove-node status restart enable-services list-services for the yb-docker-ctl-managed cluster topology multi-node integration testing (Yugabyte team, Python); argparse
# upstream: https://docs.yugabyte.com/

_yb-docker-ctl() {
    local -a sub=(
        'create:create local cluster'
        'start:start the cluster'
        'stop:stop the cluster'
        'destroy:destroy the cluster'
        'restart:restart the cluster'
        'status:show cluster status'
        'add_node:add a node'
        'remove_node:remove a node'
        'enable_yedis:enable YEDIS service'
        'enable_ycql:enable YCQL service'
        'enable_ysql:enable YSQL service'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--rf=+[replication factor]:n:' \
        '--enable-cassandra-api[enable Cassandra API]' \
        '--enable-redis-api[enable Redis API]' \
        '--enable-postgres-api[enable Postgres API]' \
        '--num-nodes=+[N]:n:' \
        '--num-shards-per-tserver=+[N]:n:' \
        '--master-flags=+[flags]:str:' \
        '--tserver-flags=+[flags]:str:' \
        '--node-id=+[id]:n:' \
        '--remove-node-id=+[id]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yb-docker-ctl subcommand' sub ;;
    esac
}

_yb-docker-ctl "$@"
