#compdef jadx-cli
# _jadx-cli — Skylot jadx Dex to Java decompiler CLI alias (skylot team, Java); jcommander
# upstream: https://github.com/skylot/jadx

_jadx-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-d+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-ds+[output dir for sources]:dir:_files -/' \
        '--output-dir-src=+[output dir for sources]:dir:_files -/' \
        '-dr+[output dir for resources]:dir:_files -/' \
        '--output-dir-res=+[output dir for resources]:dir:_files -/' \
        '-r[no resources]' \
        '--no-res[no resources]' \
        '-s[no sources]' \
        '--no-src[no sources]' \
        '--single-class=+[class]:str:' \
        '--single-class-output=+[output file]:file:_files' \
        '--output-format=+[format]:f:(java json xml)' \
        '-e[enable deobfuscation]' \
        '--deobf[enable deobfuscation]' \
        '--deobf-min=+[min length]:n:' \
        '--deobf-max=+[max length]:n:' \
        '--deobf-rewrite-cfg[rewrite map.cfg]' \
        '--deobf-use-sourcename[use source filename]' \
        '--deobf-res-name-source=+[source]:s:(auto resource code)' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--show-bad-code[show bad code]' \
        '--no-imports[no imports]' \
        '--no-debug-info[no debug info]' \
        '--add-debug-lines[add debug lines]' \
        '--no-inline-anonymous[no inline anonymous]' \
        '--no-inline-methods[no inline methods]' \
        '--no-finally[no finally]' \
        '--no-replace-consts[no replace consts]' \
        '--escape-unicode[escape unicode]' \
        '--respect-bytecode-access-modifiers[respect bytecode access]' \
        '--mappings-path=+[file]:file:_files' \
        '--mappings-mode=+[mode]:m:(read read-and-autosave read-and-save ignore)' \
        '--decompilation-mode=+[mode]:m:(auto restructure simple fallback)' \
        '--no-decode-android-resources[no decode android resources]' \
        '--with-classes-paths=+[paths]:str:' \
        '--threads-count=+[n]:n:' \
        '-j+[threads]:n:' \
        '--export-as-gradle-project=+[type]:t:(library app)' \
        '--show-api-prefix=+[prefix]:str:' \
        '--use-dx[use dx]' \
        '--comments-level=+[level]:l:(error warn info debug)' \
        '--log-level=+[level]:l:(quiet progress error warn info debug)' \
        '*:input files:_files -g "*.{apk,dex,jar,class,aar,zip,xapk,arsc,aab}"'
}

_jadx-cli "$@"
