#compdef Relate relate
# Documentation: https://myersgroup.github.io/relate/getting_started.html
# Relate: estimate genome-wide genealogies (trees) for thousands of samples

local ret=1

_arguments -s -S \
  '--mode=[mode in which to run Relate]:mode' \
  '--haps=[filename of haps file]:file:_files' \
  '--sample=[filename of sample file]:file:_files' \
  '--map=[filename of genetic map]:file:_files' \
  '(-o --output)'{-o,--output}'=[output files prefix (no extension)]:prefix' \
  '(-m --mutation_rate)'{-m,--mutation_rate}'=[mutation rate per base per generation]:rate' \
  '(-N --effective_size)'{-N,--effective_size}'=[effective population size of haplotypes]:size' \
  '--memory=[approximate memory allowance in GB]:gb' \
  '--seed=[seed for random number generator]:int' \
  '--annot=[add columns to the .mut file]:file:_files' \
  '--dist=[distances (in BP) between SNPs]:file:_files' \
  '--coal=[variable coalescence rates through time (.coal file)]:file:_files' && ret=0

return ret
