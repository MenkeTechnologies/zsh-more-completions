#compdef swift-create-xcframework
# _swift-create-xcframework — Swift Package Manager → .xcframework builder; convert SPM library targets into prebuilt fat xcframeworks for iOS/macOS/tvOS/watchOS/visionOS
# upstream: https://github.com/unsignedapps/swift-create-xcframework

_swift-create-xcframework() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--package-path+[SPM package dir]:dir:_files -/' \
        '--output+[output dir]:dir:_files -/' \
        '--platform+[platform]:platforms:(iOS ios macOS macos macCatalyst maccatalyst tvOS tvos watchOS watchos visionOS visionos)' \
        '--configuration+[config]:cfg:(debug release)' \
        '--no-clean[skip clean]' \
        '--clean[clean build dir before]' \
        '--zip[zip the output xcframework]' \
        '--zip-version+[zip version suffix]:version:' \
        '--stack-evolution[enable library evolution]' \
        '--ios-deployment-target+[ios target]:ver:' \
        '--macos-deployment-target+[macos target]:ver:' \
        '--tvos-deployment-target+[tvos target]:ver:' \
        '--watchos-deployment-target+[watchos target]:ver:' \
        '--visionos-deployment-target+[visionos target]:ver:' \
        '--xc-setting+[xcconfig]:KEY=VAL:' \
        '*:product:'
}

_swift-create-xcframework "$@"
