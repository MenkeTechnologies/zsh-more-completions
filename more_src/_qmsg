#compdef qmsg
# Documentation: https://man.archlinux.org/search?q=qmsg
# Reference accessed: 2026-05-16

# qmsg: send a message to a PBS/TORQUE job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-E[stderr]' \
  '-O[stdout]' \
  '1:message:' \
  '*:jobid:' && ret=0
return ret
