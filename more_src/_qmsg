#compdef qmsg
# Documentation: https://www1.udel.edu/chem/grommet/help/pbs/qmsg.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# qmsg: send a message to a PBS/TORQUE job.
# Synopsis: qmsg [-E] [-O] message_string job_identifier ...

local ret=1
_arguments \
  '-E[write the message to the standard error of the job]' \
  '-O[write the message to the standard output of the job]' \
  '1:message_string:' \
  '*:job_identifier:' && ret=0
return ret
