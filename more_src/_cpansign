#compdef cpansign
# Documentation: cpansign POD
# Source: audreyt/module-signature script/cpansign (master) — CPAN SIGNATURE management (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'sign:create/overwrite SIGNATURE'
    'verify:verify existing SIGNATURE'
    'help:show help'
)

_arguments -s -C \
    '(-s --sign)'{-s,--sign}'[create SIGNATURE]' \
    '(-v --verify)'{-v,--verify}'[verify SIGNATURE]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '--skip[ignore files in MANIFEST.SKIP]' \
    '1::command or file:->arg' \
    && ret=0

case $state in
    arg) _alternative 'commands:command:(sign verify help)' 'files:file:_files -g "*.{par,SIGNATURE}"' && ret=0 ;;
esac

return ret
