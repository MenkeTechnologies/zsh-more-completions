#compdef wgsd-client
# Documentation: https://github.com/jwhited/wgsd
# wgsd-client - resolve WireGuard peer endpoints via DNS-SD (wgsd CoreDNS plugin)

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-device=[name of the WireGuard device]:device:' \
  '-dns=[address of the DNS server]:addr:' \
  '-zone=[DNS zone name]:zone:' && ret=0

return ret
