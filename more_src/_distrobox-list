#compdef distrobox-list
# Documentation: https://man.archlinux.org/search?q=distrobox-list
# Reference accessed: 2026-05-16

# Zsh completion for distrobox-list

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--no-color[disable color output]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' && ret=0

return ret
