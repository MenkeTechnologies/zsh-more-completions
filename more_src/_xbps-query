#compdef xbps-query

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --config)'{-C,--config}'[path to confdir]:directory:_directories' \
  '-c[path to cachedir]:directory:_directories' \
  '-D[enable debug messages]' \
  '-d[show dependencies]' \
  '-f[show package file list]' \
  '-H[show hold packages]' \
  '-L[list repositories]' \
  '-l[list all installed packages]' \
  '-M[ignore repos defined in confdir]' \
  '-m[list manual packages]' \
  '-O[list orphan packages]' \
  '-o[search for package owning file]:file:_files' \
  '-p[show package property]:property' \
  '(-R --repository)'{-R,--repository}'[query remote repositories]' \
  '-r[rootdir]:directory:_directories' \
  '-S[show package information]' \
  '-s[search for packages]:pattern' \
  '-v[verbose messages]' \
  '-X[show reverse dependencies]' \
  '-x[show dependencies]' \
  '*:package' && ret=0

return ret
