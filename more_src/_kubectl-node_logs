#compdef kubectl-node_logs
# Documentation: https://github.com/aravindhp/kubectl-node-logs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; flags cross-checked against
# aravindhp/kubectl-node-logs pkg/nodelogs/node_logs.go.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-Q --query)'{-Q+,--query=}'[log entries matching the specified file or service(s)]:query:' \
  '(-p --pattern)'{-p+,--pattern=}'[filter service log entries by regex pattern]:pattern:' \
  '--since-time=[return logs after a date (RFC3339)]:time:' \
  '--until-time=[return logs before a date (RFC3339)]:time:' \
  '--boot=[show messages from a specific boot (negative numbers)]:n:' \
  '--tail=[return up to this many lines from the end]:n:' \
  '--role=[label selector by node role]:role:' \
  '(-l --selector)'{-l+,--selector=}'[label selector to filter on]:selector:' \
  '--raw[perform no transformation of returned data]' \
  '--unify[interleave logs by sorting the output]' \
  '*:node: _default'
