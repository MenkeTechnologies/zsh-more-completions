#compdef unfurl-cli unfurl
# _unfurl-cli — TomNomNom Tom Hudson unfurl-cli CLI command-line frontend wrapping the unfurl pull out bits of URLs provided on stdin open-source written in Go domains apexes paths query keys values keypairs format json verbose unique no-empty all unfurl-mode (TomNomNom team, Go); flag
# upstream: https://github.com/tomnomnom/unfurl

_unfurl-cli() {
    local -a modes
    modes=(
        'keys:print keys for the query string'
        'values:print values for the query string'
        'keypairs:print key/value pairs from the query string'
        'domains:print only the domain'
        'paths:print only the path'
        'apexes:print apex domains'
        'format:print URLs by format string'
        'json:JSON output'
    )
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-u[unique]' \
        '--unique[unique]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:mode:->m' \
        '*:format-string:'

    case $state in
        m) _describe -t modes 'unfurl mode' modes ;;
    esac
}

_unfurl-cli "$@"
