#compdef makepasswd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--count=[number of passwords]:count:' \
  '--minchars=[minimum password length]:length:' \
  '--maxchars=[maximum password length]:length:' \
  '--chars=[characters to use]:characters:' \
  '--string=[use specific string]:string:' \
  '--crypt[show crypt(3) hash]' \
  '--crypt-md5[show MD5 hash]' \
  '--clearfrom=[read passwords from file]:file:_files' \
  '--cryptsalt=[crypt salt length]:length:' \
  '--rerandom=[re-randomize interval]:interval:' \
  '--randomseed=[random seed]:seed:' \
  '*:file:_files' && ret=0

return ret
