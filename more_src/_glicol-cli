#compdef glicol-cli
# Documentation: https://github.com/glicol/glicol-cli/blob/main/README.md
# Glicol live coding CLI: watch a .glicol file and render audio in real-time

local ret=1

_arguments -s -S \
  '(-b --bpm)'{-b,--bpm}'=[set beats per minute (default 120)]:bpm' \
  '(-d --device)'{-d,--device}'=[audio device to use (default default)]:device' \
  '(-H --headless)'{-H,--headless}'[disable the TUI]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '*:glicol file:_files -g "*.glicol"' && ret=0

return ret
