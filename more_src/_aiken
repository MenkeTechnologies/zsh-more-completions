#compdef aiken

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:create a new Aiken project'
  'fmt:format Aiken source files'
  'build:build an Aiken project'
  'check:type-check an Aiken project'
  'docs:generate documentation'
  'add:add a dependency'
  'blueprint:work with Plutus blueprints'
  'packages:manage packages'
  'tx:transaction tooling'
  'uplc:UPLC tools'
  'completion:generate shell completions'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'aiken command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (new)
        _arguments \
          '1:project path' && ret=0
        ;;
      (build)
        _arguments \
          '--trace-level=[trace level]:level:(silent compact verbose)' \
          '--filter-traces=[filter traces]:filter:(user-defined compiler-generated all)' \
          '--deny[treat warnings as errors]' \
          '--watch[watch for changes]' \
          '-w[watch for changes]' \
          '--keep-traces[keep traces in generated code]' \
          '--env=[target environment]:env' && ret=0
        ;;
      (check)
        _arguments \
          '--trace-level=[trace level]:level:(silent compact verbose)' \
          '--filter-traces=[filter traces]:filter:(user-defined compiler-generated all)' \
          '--deny[treat warnings as errors]' \
          '--watch[watch for changes]' \
          '-w[watch for changes]' \
          '--skip-tests[skip tests]' \
          '--match=[filter tests by name]:pattern' \
          '-m+[filter tests by name]:pattern' \
          '--exact-match[exact test name matching]' \
          '-e[exact test name matching]' && ret=0
        ;;
      (fmt)
        _arguments \
          '--check[check formatting without modifying]' \
          '--stdin[read from stdin]' \
          '*:files:_files -g "*.ak"' && ret=0
        ;;
      (docs)
        _arguments \
          '-d+[output directory]:directory:_directories' \
          '--destination=[output directory]:directory:_directories' && ret=0
        ;;
      (add)
        _arguments \
          '--version=[package version]:version' \
          '1:package (owner/repo)' && ret=0
        ;;
      (blueprint)
        local -a blueprint_cmds=(
          'address:compute a validator address'
          'hash:compute a validator hash'
          'policy:compute a minting policy ID'
          'convert:convert a blueprint'
          'apply:apply parameters to a validator'
        )
        _arguments '1:blueprint command:_describe -t blueprint-cmds "blueprint command" blueprint_cmds' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
