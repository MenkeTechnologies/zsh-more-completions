#compdef qacToWig
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert from compressed quality score format to wiggle format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-name=[restrict output to just this sequence name]:name:' \
  '-fixed[output single file with wig headers and fixed step]' \
  ':in qac:_files' \
  ':out file or dir:_files' && ret=0

return ret
