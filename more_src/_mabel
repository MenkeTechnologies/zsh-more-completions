#compdef mabel
# Documentation: https://github.com/mabel-dev/mabel
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for mabel — terminal BitTorrent client

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '*:torrent:_files -g "*.(torrent|magnet)"' && ret=0

return ret
