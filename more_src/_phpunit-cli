#compdef phpunit-cli
# _phpunit-cli — Sebastian Bergmann PHPUnit testing framework CLI alias (Sebastian Bergmann, PHP); custom argparse
# upstream: https://github.com/sebastianbergmann/phpunit

_phpunit-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--bootstrap=+[bootstrap file]:file:_files -g "*.php"' \
        '-c+[config file]:file:_files -g "*.xml *.xml.dist"' \
        '--configuration=+[config file]:file:_files -g "*.xml *.xml.dist"' \
        '--no-configuration[no configuration]' \
        '--no-coverage[no coverage]' \
        '--no-logging[no logging]' \
        '--no-extensions[no extensions]' \
        '--include-path=+[include path]:dir:_files -/' \
        '-d+[ini setting]:str:' \
        '--cache-result-file=+[cache result file]:file:_files' \
        '--coverage-clover=+[clover output]:file:_files' \
        '--coverage-cobertura=+[cobertura output]:file:_files' \
        '--coverage-crap4j=+[crap4j output]:file:_files' \
        '--coverage-html=+[html output]:dir:_files -/' \
        '--coverage-php=+[php output]:file:_files' \
        '--coverage-text=+[text output]:file:_files' \
        '--coverage-xml=+[xml output]:dir:_files -/' \
        '--coverage-cache=+[coverage cache]:dir:_files -/' \
        '--warm-coverage-cache[warm coverage cache]' \
        '--coverage-filter=+[coverage filter]:list:_files -/' \
        '--path-coverage[path coverage]' \
        '--disable-coverage-ignore[disable coverage ignore]' \
        '--no-coverage-filter[no coverage filter]' \
        '--debug[debug]' \
        '--log-junit=+[junit output]:file:_files' \
        '--log-teamcity=+[teamcity output]:file:_files' \
        '--testdox-html=+[testdox html]:file:_files' \
        '--testdox-text=+[testdox text]:file:_files' \
        '--testdox-xml=+[testdox xml]:file:_files' \
        '--reverse-list[reverse list]' \
        '--testdox[testdox format]' \
        '--testdox-exclude-group=+[testdox exclude group]:list:' \
        '--testdox-group=+[testdox group]:list:' \
        '--filter=+[filter]:str:' \
        '--testsuite=+[test suite]:str:' \
        '--exclude-testsuite=+[exclude test suite]:str:' \
        '--list-suites[list suites]' \
        '--group=+[group]:list:' \
        '--exclude-group=+[exclude group]:list:' \
        '--covers=+[covers]:str:' \
        '--uses=+[uses]:str:' \
        '--list-groups[list groups]' \
        '--list-tests[list tests]' \
        '--list-tests-xml=+[list tests xml]:file:_files' \
        '--test-suffix=+[test suffix]:str:' \
        '--colors=+[colors]:c:(always auto never)' \
        '--columns=+[columns]:n:' \
        '--no-progress[no progress]' \
        '--no-results[no results]' \
        '--no-output[no output]' \
        '--display-incomplete[display incomplete]' \
        '--display-skipped[display skipped]' \
        '--display-deprecations[display deprecations]' \
        '--display-errors[display errors]' \
        '--display-notices[display notices]' \
        '--display-warnings[display warnings]' \
        '--repeat=+[repeat]:n:' \
        '--strict-coverage[strict coverage]' \
        '--strict-global-state[strict global state]' \
        '--disallow-test-output[disallow test output]' \
        '--disallow-resource-usage[disallow resource usage]' \
        '--enforce-time-limit[enforce time limit]' \
        '--default-time-limit=+[default time limit]:n:' \
        '--disallow-todo-tests[disallow todo tests]' \
        '--process-isolation[process isolation]' \
        '--globals-backup[globals backup]' \
        '--static-backup[static backup]' \
        '--stop-on-defect[stop on defect]' \
        '--stop-on-error[stop on error]' \
        '--stop-on-failure[stop on failure]' \
        '--stop-on-warning[stop on warning]' \
        '--stop-on-incomplete[stop on incomplete]' \
        '--stop-on-risky[stop on risky]' \
        '--stop-on-skipped[stop on skipped]' \
        '--stop-on-deprecation[stop on deprecation]' \
        '--stop-on-notice[stop on notice]' \
        '--fail-on-incomplete[fail on incomplete]' \
        '--fail-on-risky[fail on risky]' \
        '--fail-on-skipped[fail on skipped]' \
        '--fail-on-warning[fail on warning]' \
        '--fail-on-deprecation[fail on deprecation]' \
        '--fail-on-notice[fail on notice]' \
        '--fail-on-empty-test-suite[fail on empty test suite]' \
        '*:test-path:_files -g "*Test.php"'
}

_phpunit-cli "$@"
