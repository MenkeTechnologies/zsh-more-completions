#compdef lasreturn
# Documentation: https://github.com/LAStools/LAStools
# LAStools: report on and repair return numbering in LAS/LAZ files

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print help output]' \
  '-version[report tool version]' \
  '-gui[start with files loaded into GUI]' \
  '-demo[run in demo mode]' \
  '-license[show license information]' \
  '(-v -verbose)'{-v,-verbose}'[verbose output]' \
  '-check_return_numbering[print histogram about missing/duplicate returns]' \
  '-classify_missing_as+[mark points with missing returns as class]:code' \
  '-classify_duplicate_as+[mark points with duplicate returns as class]:code' \
  '-classify_violation_as+[mark points with violating returns as class]:code' \
  '-compute_gap_to_next_return[add gap-to-next-return as extra bytes]' \
  '-flag_as_synthetic[mark remaining returns as synthetic]' \
  '-flag_as_withheld[mark remaining returns as withheld]' \
  '-histo+[compute histogram about return distance/angle]:attribute' \
  '-repair_number_of_returns[repair invalid number of return values]' \
  '-skip_incomplete[skip incomplete returns]' \
  '-error+[set quantization error (default 0.75)]:n' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-merged[merge input files]' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output file suffix]:suffix' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-cores+[process inputs on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
