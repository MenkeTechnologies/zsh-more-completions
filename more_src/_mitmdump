#compdef mitmdump

# Zsh completion for mitmdump - mitmproxy CLI dump mode

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --listen-port)'{-p,--listen-port}'[proxy listen port]:port' \
  '--listen-host=[proxy listen host]:host' \
  '(-s --scripts)'{-s,--scripts}'[run a script]:script file:_files -g "*.py"' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-n --no-server)'{-n,--no-server}'[do not start a proxy server]' \
  '(-r --rfile)'{-r,--rfile}'[read flows from file]:flow file:_files' \
  '(-w --wfile)'{-w,--wfile}'[write flows to file]:flow file:_files' \
  '(-a --afile)'{-a,--afile}'[append flows to file]:flow file:_files' \
  '--anticomp[try to convince servers to send uncompressed data]' \
  '--anticache[strip cache headers to prevent caching]' \
  '--flow-detail=[flow detail level]:level:(0 1 2 3 4)' \
  '--mode=[proxy mode]:mode:(regular transparent socks5)' \
  '(-k --ssl-insecure)'{-k,--ssl-insecure}'[do not verify upstream server SSL certificates]' \
  '--cert=[SSL certificate]:cert file:_files' \
  '*--certs=[SSL certificate specification]:certspec' \
  '--client-certs=[client certificate directory or file]:path:_files' \
  '*--set=[set an option value]:option' \
  '--rawtcp[enable raw TCP mode]' \
  '--rawudp[enable raw UDP mode]' \
  '--http2[enable HTTP/2]' \
  '--no-http2[disable HTTP/2]' \
  '*--ignore-hosts=[ignore host pattern]:pattern' \
  '*--allow-hosts=[allow host pattern]:pattern' \
  '*--tcp-hosts=[generic TCP SSL proxy hosts]:pattern' \
  '--upstream-auth=[upstream proxy auth]:user\:password' \
  '--upstream-cert[connect to upstream server to look up certificate]' \
  '*--map-remote=[map remote resources]:pattern' \
  '*--map-local=[map remote resources to local files]:pattern' \
  '*--modify-headers=[modify headers]:pattern' \
  '*--modify-body=[modify body]:pattern' \
  '--stickycookie=[set sticky cookie filter]:filter' \
  '--stickyauth=[set sticky auth filter]:filter' \
  '--view-filter=[limit display to matching flows]:filter' \
  '--intercept=[set intercept filter]:filter' \
  '--showhost[use Host header for URL display]' \
  '*:filter expression'
