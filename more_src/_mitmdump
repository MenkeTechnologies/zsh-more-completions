#compdef mitmdump
# Documentation: https://github.com/mitmproxy/mitmproxy/blob/main/mitmproxy/tools/cmdline.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mitmdump - mitmproxy CLI dump tool

_arguments -s -S \
  '--version[show version number and exit]' \
  '--options[show all options and their default values]' \
  '--commands[show all commands and their signatures]' \
  '*--set=[set an option]:option[=value]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[increase log verbosity]' \
  '*'{-m+,--mode=}'[proxy mode]:mode' \
  '--anticache[strip cache headers]' \
  '--no-anticache[do not strip cache headers]' \
  '--showhost[use Host header for URL display]' \
  '--no-showhost[do not use Host header for URL display]' \
  '--show-ignored-hosts[show ignored hosts]' \
  '--no-show-ignored-hosts[do not show ignored hosts]' \
  '(-r --rfile)'{-r+,--rfile=}'[read flows from file]:path:_files' \
  '*'{-s+,--scripts=}'[run script]:script:_files -g "*.py"' \
  '--stickycookie=[set sticky cookie filter]:filter' \
  '--stickyauth=[set sticky auth filter]:filter' \
  '(-w --save-stream-file)'{-w+,--save-stream-file=}'[stream flows to file]:path:_files' \
  '--anticomp[try to convince servers to send uncompressed data]' \
  '--no-anticomp[do not strip Accept-Encoding]' \
  '--listen-host=[address to bind proxy to]:host' \
  '(-p --listen-port)'{-p+,--listen-port=}'[proxy port]:port' \
  '(-n --server)--server[start proxy server]' \
  '(-n --server)-n[do not start proxy server]' \
  '--no-server[do not start proxy server]' \
  '*--ignore-hosts=[ignore host regex]:host' \
  '*--allow-hosts=[allow host regex]:host' \
  '*--tcp-hosts=[generic TCP SSL proxy host regex]:host' \
  '--upstream-auth=[upstream proxy auth]:user\:pass' \
  '--proxyauth=[require proxy auth]:spec' \
  '--store-streamed-bodies[store streamed bodies]' \
  '--no-store-streamed-bodies[do not store streamed bodies]' \
  '--rawtcp[enable raw TCP mode]' \
  '--no-rawtcp[disable raw TCP mode]' \
  '--http2[enable HTTP/2]' \
  '--no-http2[disable HTTP/2]' \
  '*--certs=[SSL certificate specification]:spec' \
  '--cert-passphrase=[certificate passphrase]:pass' \
  '(-k --ssl-insecure)'{-k,--ssl-insecure}'[do not verify upstream SSL certificates]' \
  '--no-ssl-insecure[verify upstream SSL certificates]' \
  '*'{-C+,--client-replay=}'[replay client requests from file]:path:_files' \
  '*'{-S+,--server-replay=}'[replay server responses from file]:path:_files' \
  '--server-replay-kill-extra[kill extra requests during replay]' \
  '--no-server-replay-kill-extra[do not kill extra requests during replay]' \
  '*--server-replay-extra=[extra response when no replay match]:behavior' \
  '--server-replay-reuse[reuse replayed responses]' \
  '--no-server-replay-reuse[do not reuse replayed responses]' \
  '--server-replay-refresh[refresh replayed responses]' \
  '--no-server-replay-refresh[do not refresh replayed responses]' \
  '*'{-M+,--map-remote=}'[map remote pattern]:pattern' \
  '*--map-local=[map local pattern]:pattern' \
  '*'{-B+,--modify-body=}'[modify response body]:pattern' \
  '*'{-H+,--modify-headers=}'[modify headers]:pattern' \
  '--flow-detail=[flow detail level]:level:(0 1 2 3 4)' \
  '*:filter expression'
