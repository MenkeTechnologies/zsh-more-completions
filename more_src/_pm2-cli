#compdef pm2-cli
# _pm2-cli — Unitech PM2 production process manager for Node.js CLI alias (Unitech team, JavaScript); commander
# upstream: https://github.com/Unitech/pm2

_pm2-cli() {
    local -a sub=(
        'start:start and daemonize app'
        'stop:stop app'
        'restart:restart app'
        'reload:zero-downtime reload'
        'delete:delete app from pm2'
        'kill:kill pm2 daemon'
        'list:list apps'
        'ls:list apps'
        'status:list apps'
        'show:show app info'
        'info:show app info'
        'describe:describe app'
        'logs:show logs'
        'monit:monitor processes'
        'flush:flush logs'
        'reloadLogs:reload logs'
        'save:save current process list'
        'resurrect:restart saved processes'
        'unstartup:disable startup'
        'startup:configure startup script'
        'cleardump:clear saved processes'
        'update:update pm2'
        'install:install pm2 module'
        'uninstall:uninstall pm2 module'
        'publish:publish module'
        'gen:gen ecosystem.config.js'
        'ecosystem:show ecosystem config'
        'init:scaffold ecosystem file'
        'attach:attach to process'
        'web:start web monitoring'
        'deploy:deploy app'
        'set:set config value'
        'get:get config value'
        'unset:unset config value'
        'multiset:set multiple values'
        'conf:show conf'
        'report:create diagnostic report'
        'reset:reset metrics'
        'env:show env'
        'sendSignal:send signal'
        'ping:ping pm2'
        'reset:reset metric'
        'profile:cpu:cpu profiling'
        'profile:mem:heap snapshot'
        'plus:link to pm2 plus'
        'unlink:unlink from pm2 plus'
        'link:link to pm2 plus'
        'serve:serve a static directory'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-v[show version]' \
        '--silent[do not log]' \
        '-s[do not log]' \
        '--no-daemon[run as foreground]' \
        '--no-autorestart[no auto restart]' \
        '--cron=+[cron pattern]:str:' \
        '--restart-delay=+[ms]:n:' \
        '--max-restarts=+[count]:n:' \
        '--exp-backoff-restart-delay=+[ms]:n:' \
        '--max-memory-restart=+[mb]:str:' \
        '--watch[enable watch]' \
        '--watch-delay=+[ms]:n:' \
        '--ignore-watch=+[patterns]:str:' \
        '--instance-var=+[var]:str:' \
        '--name=+[app name]:str:' \
        '-n+[app name]:str:' \
        '--namespace=+[namespace]:str:' \
        '--script=+[script]:file:_files' \
        '--cwd=+[dir]:dir:_files -/' \
        '--env=+[env]:str:' \
        '--time[time logs]' \
        '--log-date-format=+[format]:str:' \
        '--output=+[stdout file]:file:_files' \
        '-o+[stdout file]:file:_files' \
        '--error=+[stderr file]:file:_files' \
        '-e+[stderr file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--combine-logs[combine logs]' \
        '--merge-logs[merge logs]' \
        '--user=+[user]:_users' \
        '-u+[user]:_users' \
        '--exec-mode=+[mode]:m:(fork cluster)' \
        '-i+[instances]:n:' \
        '--instances=+[instances]:n:' \
        '--source-map-support[source map support]' \
        '--source-map=+[file]:file:_files' \
        '--no-source-map-support[no source map]' \
        '--node-args=+[args]:str:' \
        '--no-treekill[no tree kill]' \
        '--no-vizion[no vizion]' \
        '--no-pmx[no pmx]' \
        '--interpreter=+[interpreter]:str:' \
        '--interpreter-args=+[args]:str:' \
        '--pid=+[pid file]:file:_files' \
        '--force[force]' \
        '-f[force]' \
        '--lines=+[lines]:n:' \
        '--raw[raw logs]' \
        '--err[error logs only]' \
        '--out[stdout only]' \
        '--nostream[no stream]' \
        '--lines=+[n]:n:' \
        '--format[json output]' \
        '--auto-exit[auto exit]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pm2 subcommand' sub ;;
        args)
            case $words[1] in
                start|stop|restart|reload|delete|logs|describe|show|info|env|sendSignal|reset|profile:cpu|profile:mem|attach) _arguments \
                    '*:app:_files' ;;
                startup|unstartup) _arguments \
                    '1:platform:(systemd amazon centos darwin freebsd gentoo openrc rcd smf ubuntu upstart)' ;;
                serve) _arguments \
                    '1:directory:_files -/' \
                    '2:port:' ;;
                deploy) _arguments \
                    '1:env:' \
                    '*:command:' ;;
                init) ;;
            esac
            ;;
    esac
}

_pm2-cli "$@"
