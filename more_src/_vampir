#compdef vampir vampirserver vampirremote vng vng-server
# _vampir — TU Dresden ZIH Vampir performance trace visualization for parallel HPC applications (Vampir team, C++); custom argparse
# upstream: https://vampir.eu

_vampir() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.cfg *.ini *.conf"' \
        '--config=+[config file]:file:_files -g "*.cfg *.ini *.conf"' \
        '-l+[license file]:file:_files' \
        '--license=+[license file]:file:_files' \
        '-s+[server connection]:str:' \
        '--server=+[server connection]:str:' \
        '-p+[port]:port:_ports' \
        '--port=+[port]:port:_ports' \
        '--user=+[user]:user:_users' \
        '--password=+[password]:str:' \
        '--auto-connect[auto connect]' \
        '--unique[unique window]' \
        '--main-only[main only]' \
        '--debug[debug logging]' \
        '--workers=+[N]:n:' \
        '--ldap[LDAP auth]' \
        '--ldap-server=+[server]:host:_hosts' \
        '--no-license-check[no license check]' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--style=+[Qt style]:str:' \
        '--no-anti-alias[no anti alias]' \
        '*:trace file:_files -g "*.otf2 *.otf *.elg *.vam"'
}

_vampir "$@"
