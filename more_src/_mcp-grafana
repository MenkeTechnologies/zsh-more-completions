#compdef mcp-grafana
# Documentation: https://github.com/grafana/mcp-grafana
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Grafana MCP server

_arguments -s -S \
  '(-t --transport)'{-t,--transport}'=[transport type]:transport:(stdio sse streamable-http)' \
  '--address=[host:port for SSE/streamable-http server]:address' \
  '--base-path=[base path for SSE/streamable-http server]:path' \
  '--endpoint-path=[endpoint path for streamable-http server]:path' \
  '--debug[enable detailed HTTP request/response logging]' \
  '--log-level=[log verbosity]:level:(debug info warn error)' \
  '--metrics[expose Prometheus metrics at /metrics]' \
  '--metrics-address=[address for metrics server]:address' \
  '--slow-request-threshold=[log requests exceeding this duration]:duration' \
  '--slow-request-log-level=[log level for slow requests]:level:(info warn)' \
  '--enabled-tools=[comma-separated tool categories to enable]:categories' \
  '--session-idle-timeout-minutes=[session idle timeout in minutes]:minutes' \
  '--tls-cert-file=[client certificate path]:file:_files' \
  '--tls-key-file=[client private key path]:file:_files' \
  '--tls-ca-file=[CA certificate path]:file:_files' \
  '--tls-skip-verify[skip TLS verification (insecure)]' \
  '--server.tls-cert-file=[server HTTPS certificate]:file:_files' \
  '--server.tls-key-file=[server HTTPS private key]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::arguments:_default'
