#compdef 3dRank
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dRank.html
# AFNI replace voxel values by their rank over all input datasets

local ret=1

_arguments -s -S \
  '-help[print the help screen]' \
  '-prefix[output filename prefix]:prefix:' \
  '-input[input datasets]:dataset:_files' \
  '-ver[display author and version info]' \
  '*:dataset:_files' && ret=0

return ret
