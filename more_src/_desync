#compdef desync

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'cache:populate a chunk store cache from one or more remote stores'
  'cat:retrieve and concatenate chunks of an index file'
  'chop:split a blob into chunks and write them to a store'
  'chunk-server:run an HTTP chunk server'
  'config:show desync configuration'
  'extract:extract a blob from chunks in a store'
  'index-server:run an HTTP index server'
  'info:show information about an index file'
  'list-chunks:print the list of chunks in an index file'
  'make:create a chunked index file from a blob'
  'manifest:generate a deduplicating manifest'
  'mtree:generate an mtree-style manifest'
  'mount-index:mount an index file as a FUSE filesystem'
  'pull:pull chunks from a remote store'
  'prune:remove unused chunks from a chunk store'
  'tar:create a tar archive from chunks'
  'untar:extract chunks from a tar archive'
  'verify:verify the integrity of all chunks in a store'
  'verify-index:verify chunks referenced by an index'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'desync subcommand' subcommands && ret=0
    ;;
esac

return ret
