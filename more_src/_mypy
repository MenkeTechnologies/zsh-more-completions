#compdef mypy

# zsh completions for 'mypy'
local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)'{-V,--version}'[show version and exit]'
  '--config-file[use a specific config file]:config file:_files'
  '--warn-unused-configs[warn about unused \[mypy-...\] config sections]'
  '--no-implicit-optional[do not assume Optional for arguments with None default]'
  '--strict[enable all optional strictness checks]'
  '--ignore-missing-imports[silently ignore imports of missing modules]'
  '--follow-imports[how to treat imports]:strategy:(normal silent skip error)'
  '--python-version[type check for specific Python version]:version:'
  '--python-executable[Python executable to use for finding PEP 561 packages and stubs]:executable:_files -g "*"'
  '--platform[type check for specific platform]:platform:'
  '--disallow-untyped-defs[disallow defining functions without type annotations or with incomplete annotations]'
  '--disallow-any-unimported[disallow Any types resulting from unfollowed imports]'
  '--disallow-any-expr[disallow all expressions that have type Any]'
  '--disallow-any-decorated[disallow functions that have Any in their signature after decorator transformation]'
  '--disallow-any-explicit[disallow explicit Any in type positions]'
  '--disallow-any-generics[disallow usage of generic types that do not specify explicit type parameters]'
  '--disallow-subclassing-any[disallow subclassing values of type Any]'
  '--disallow-untyped-calls[disallow calling functions without type annotations from typed functions]'
  '--disallow-untyped-decorators[disallow decorating typed functions with untyped decorators]'
  '--disallow-incomplete-defs[disallow defining functions with incomplete type annotations]'
  '--check-untyped-defs[type check the interior of functions without type annotations]'
  '--warn-redundant-casts[warn about casting an expression to its inferred type]'
  '--warn-return-any[warn about returning values of type Any from non-Any typed functions]'
  '--warn-unreachable[warn about statements or expressions inferred to be unreachable]'
  '--no-warn-no-return[do not warn about functions that are missing return statements]'
  '--show-error-codes[show error codes in error messages]'
  '--show-error-context[precede errors with context information]'
  '--show-column-numbers[show column numbers in error messages]'
  '--show-absolute-path[show absolute paths in error messages]'
  '--no-color-output[do not colorize error messages]'
  '--no-error-summary[do not show error stats summary]'
  '--pretty[use visually nicer output in error messages]'
  '--txt-report[generate a text type-checking coverage report]:directory:_directories'
  '--html-report[generate an HTML type-checking coverage report]:directory:_directories'
  '--xml-report[generate an XML type-checking coverage report]:directory:_directories'
  '--junit-xml[write junit.xml to the given file]:file:_files'
  '--scripts-are-modules[script x becomes module x instead of __main__]'
  '--namespace-packages[support namespace packages (PEP 420)]'
  '--explicit-package-bases[use current directory and MYPYPATH to determine module names]'
  '--exclude[regular expression to match file names, directory names or paths to avoid checking]:pattern:'
  '--incremental[enable module cache (enabled by default)]'
  '--no-incremental[disable module cache]'
  '--cache-dir[store module cache info in the given folder]:directory:_directories'
  '--sqlite-cache[use a sqlite database to store the cache]'
  '--cache-fine-grained[include fine-grained dependency information in the cache]'
  '--skip-cache-mtime-checks[skip cache internal consistency checks based on mtime]'
  '--install-types[install detected missing library stub packages using pip]'
  '--non-interactive[install stubs without asking for confirmation and hide errors]'
  '--plugins[comma-separated list of mypy plugins]:plugins:'
  '--enable-error-code[enable specific error code]:error code:'
  '--disable-error-code[disable specific error code]:error code:'
  '*--shadow-file[when asked to type check path, use shadow path instead]:source file:_files:shadow file:_files'
  '--any-exprs-report[generate a report of Any expression usage]:directory:_directories'
  '--cobertura-xml-report[generate a Cobertura XML report]:directory:_directories'
  '--linecount-report[generate a line count report]:directory:_directories'
  '--linecoverage-report[generate a line coverage report]:directory:_directories'
  '--lineprecision-report[generate a line precision report]:directory:_directories'
  '--no-silence-site-packages[do not silence errors in installed PEP 561 packages]'
  '--no-site-packages[do not use typeshed or PEP 561 packages from site-packages]'
  '--fast-module-lookup[enable fast module lookup using search path ahead of time]'
  '--local-partial-types[treat local variables as having partial types initially]'
  '*:file or module:_files'
)

_arguments -s -S $arguments
