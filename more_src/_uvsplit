#compdef uvsplit
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvsplit.html
# MIRIAD uvsplit - split a uv dataset by source and frequency

local ret=1

_arguments -s -S \
  'vis=[input uv dataset name]:vis:_files' \
  'select=[uv selection commands]:select' \
  'maxwidth=[maximum bandwidth in GHz per output band]:maxwidth' \
  'options=[nocopy,mosaic,clobber,calcode,ifchain,nosource,nofreq,nowindow]:options' \
  '*:visibility data:_files' && ret=0

return ret
