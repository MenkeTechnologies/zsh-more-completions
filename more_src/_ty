#compdef ty

# Zsh completion for ty (Astral Python type checker)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:type-check Python files'
  'server:run the language server'
  'version:show the version'
  'help:show help for a command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ty command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (check)
        _arguments \
          '--project[project root directory]:dir:_files -/' \
          '--python-version[target Python version]:version:(3.7 3.8 3.9 3.10 3.11 3.12 3.13 3.14)' \
          '--python-platform[target platform]:platform:(linux darwin windows)' \
          '--config[path to configuration file]:file:_files -g "*.toml"' \
          '--extra-search-path[additional module search path]:dir:_files -/' \
          '--respect-ignore-files[respect .gitignore files]' \
          '--no-respect-ignore-files[ignore .gitignore files]' \
          '--error-on-warning[treat warnings as errors]' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[suppress output except errors]' \
          '--output-format[output format]:format:(text json concise full)' \
          '*:file or directory:_files' && ret=0
        ;;
      (server)
        _arguments \
          '--project[project root directory]:dir:_files -/' \
          '--python-version[target Python version]:version:(3.7 3.8 3.9 3.10 3.11 3.12 3.13 3.14)' \
          '--config[path to configuration file]:file:_files -g "*.toml"' && ret=0
        ;;
      (help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
