# =============================================================================
# pathbrute — HTTP URI path brute-forcing tool for web security assessments.
#             Tries common web paths (admin pages, backup directories,
#             config files, exposed source repos, debug endpoints) against
#             target hosts and reports which paths exist (and what
#             HTTP-status they return).  Used in AUTHORIZED penetration-
#             testing engagements to discover hidden web app surfaces.
#             Ships with multiple wordlist sources (msf, exploitdb,
#             RobotsDisallowed, SecLists) and CMS fingerprinting
#             (WordPress/Joomla/Drupal).
#
# Author:  Milo Tan (milo2012, Singapore-based offensive-security researcher)
# Source:  https://github.com/milo2012/pathbrute
# CLI:     pathBrute.go (uses mkideal/cli)
# Library: mkideal/cli
#          ("CLI - A package for building command line app with go")
# License: MIT
# Status:  Stable — 455+ stars, distributed alongside other Kali-Linux-style
#          offensive tools.  Sister tools include subjack (subdomain
#          takeover), takeover (similar), aquatone (visual recon).
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 30 LIBRARIES
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 30TH Go CLI library variant.  Go climbs from 29 to 30 documented libraries
# (mkideal/cli via pathbrute).  New leaderboard: Rust=30, Go=30 (TWO-WAY TIE),
# TypeScript-Node=29.  Both Rust AND Go now share the round-number milestone
# of 30 documented CLI library variants — the most for any single language
# in the taxonomy.  Taxonomy now spans 230 cross-language CLI library
# variants across 55 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS mkideal/cli AND WHY IS IT A DISTINCT 30TH GO CLI LIBRARY VARIANT?
#
# mkideal/cli (https://github.com/mkideal/cli, 724+ stars) is **Mkideal's
# (mkideal) struct-tag-driven Go CLI library**.  Created around 2015, it
# was one of the earlier struct-tag Go CLI libraries — predating both
# alecthomas/kong (R465) and alexflint/go-arg (R475) by several years.
#
# The library's defining feature is the COMMA-SEPARATED ALIAS SYNTAX in
# struct tags: `cli:"U,filename"` declares both `-U` and `--filename`
# as aliases for the same field.  This compact tag syntax is distinctive
# among Go CLI libraries — most use separate short/long fields.
#
# mkideal/cli is DISTINCT from every other Go CLI library documented in
# the corpus on SIX specific axes:
#
#   1. COMMA-SEPARATED ALIAS SYNTAX — `cli:"U,filename"` puts BOTH the
#      short and long flag names in a single tag value, comma-separated.
#      Compare:
#        flag stdlib:    flag.StringVar(&v, "filename", "", "")  (no alias)
#        cobra:          .Flags().StringVarP(&v, "filename", "U", "", "")
#                        (separate name/shorthand args)
#        urfave/cli:     cli.StringFlag{Name:"filename", Aliases:[]string{"U"}}
#        go-arg (R475):  `arg:"-U" help:"..."` (separate aliases not in tag)
#        kong (R465):    `short:"U"` (separate tag)
#        opts (R479):    `short:"U"` (separate tag)
#        flaggy:         AddStringFlag(&v, "U", "filename", "")
#                        (positional short/long args)
#        mkideal/cli:    `cli:"U,filename"` (comma-separated)
#      mkideal's comma syntax is the MOST COMPACT alias declaration in
#      any documented Go CLI library.
#
#   2. EMBEDDED cli.Helper FOR --help — mkideal/cli requires the user
#      struct to embed `cli.Helper`:
#         type argT struct {
#             cli.Helper
#             Filename string `cli:"U,filename" usage:"..."`
#             // ...
#         }
#      The embedded `cli.Helper` adds the `--help` / `-h` flag and the
#      built-in help-rendering plumbing.  Other Go CLI libraries either
#      auto-register --help (cobra, kong) or require explicit registration
#      (mitchellh/cli).  mkideal's approach is STRUCT-EMBEDDING based —
#      composition rather than configuration.
#
#   3. SEPARATE `usage` TAG — flag descriptions live in a `usage:"..."`
#      tag rather than embedded in the `cli:"..."` tag value.  Compare
#      Kong's combined `\`short:"U" help:"description"\``.  mkideal's
#      split tag separates concerns: `cli` is structural, `usage` is
#      documentation.
#
#   4. CONTEXT-OBJECT HANDLER — mkideal's `cli.Run()` signature:
#         cli.Run(new(argT), func(ctx *cli.Context) error { ... })
#      The handler receives a *cli.Context that exposes the parsed Argv
#      via type-asserted retrieval:
#         argv := ctx.Argv().(*argT)
#      This explicit type-assertion is similar to cobra's
#      `cmd.Flags().GetString("name")` but the assertion model lets
#      mkideal share Context infrastructure across subcommands without
#      type erasure.
#
#   5. cli.Tree FOR SUBCOMMANDS — subcommands are organized via:
#         cli.Root(rootCmd,
#             cli.Tree(buildCmd),
#             cli.Tree(testCmd),
#             cli.Tree(deployCmd))
#      The Tree structure makes nesting explicit and visually obvious.
#      Compare cobra's `AddCommand()` method chain — both work but
#      mkideal's nesting is more readable for deep trees.
#
#   6. dft TAG FOR DEFAULTS — defaults are declared in a `dft:"value"`
#      tag rather than as struct field initialization (opts R479) or
#      a separate `default:"..."` tag (kong R465, go-arg R475).
#      Example: `Threads int \`cli:"n,threads" dft:"2" usage:"..."\``
#      sets the default to 2.  `dft` is shorthand for "default" — the
#      kind of tag-vocabulary compression mkideal favors.
#
# THE mkideal/cli API SURFACE (verbatim from pathbrute usage)
#
#   import "github.com/mkideal/cli"
#
#   type argT struct {
#       cli.Helper
#       Filename string `cli:"U,filename" usage:"File containing list of websites"`
#       URLpath string `cli:"u,url" usage:"Url of website"`
#       PFilename string `cli:"P,Paths" usage:"File containing list of URI paths"`
#       Path string `cli:"p,path" usage:"URI path"`
#       Threads int `cli:"n,threads" usage:"No of concurrent threads (default: 2)"`
#       Statuscode int `cli:"c" usage:"Show only certain status code"`
#       Excludecode int `cli:"e" usage:"Exclude certain status code"`
#       Intellimode bool `cli:"i" usage:"Intelligent mode"`
#       Verbose bool `cli:"v,verbose" usage:"Verbose mode"`
#       Updatemode bool `cli:"update" usage:"Update wordlists from Github"`
#       // ... ~20 more flags
#   }
#
#   func main() {
#       cli.Run(new(argT), func(ctx *cli.Context) error {
#           argv := ctx.Argv().(*argT)
#           // use argv.Filename, argv.URLpath, etc.
#           return nil
#       })
#   }
#
# Tag vocabulary:
#   cli:"short,long"      — short and long aliases (comma-separated)
#   cli:"name"            — single name (long form derived from name)
#   usage:"..."           — help description
#   dft:"value"           — default value (string-encoded)
#   name:"foo"            — override field name (uncommon)
#   prompt:"Enter X:"     — interactive prompt if flag missing (rare)
#   parser:"json"         — JSON parsing for complex values (rare)
#   sep:","               — slice value separator
#
# CONTRAST WITH OTHER STRUCT-TAG-DRIVEN GO CLI LIBRARIES IN THE CORPUS
#
#   * jessevdk/go-flags          — POSIX getopt-style with `short:"x" long:"name"`
#                                   separate fields
#   * alecthomas/kong (R465)     — extensive tag vocabulary with auto-Run()
#                                   dispatch + custom validators
#   * alexflint/go-arg (R475)    — minimal tag, single MustParse(&cfg) call
#   * jpillora/opts (R479)       — struct-field-init defaults + 3-tag vocab
#   * mkideal/cli (THIS)         — comma-separated aliases in single tag,
#                                   embedded cli.Helper, dft tag for defaults,
#                                   cli.Tree subcommand nesting
#
# mkideal/cli is the FIRST documented Go CLI library with COMMA-SEPARATED
# ALIASES in a single struct tag.  This is a SUBTLE but DISTINCTIVE design
# choice that no other documented Go CLI library makes.  It also predates
# Kong (2018), go-arg (2016), opts (2017) — mkideal/cli's first commit was
# in 2015, making it one of the EARLIEST struct-tag Go CLI libraries.
#
# REAL-WORLD mkideal/cli USERS:
#
#   * rqlite/rqlite — distributed SQLite (17,556*; in corpus as _rqlite)
#   * milo2012/pathbrute — HTTP path brute-forcer (THIS, 455*)
#   * antony-jr/ham — Hetzner Android Make tool (17*)
#   * hellokaton/blade-cli — Blade MVC CLI
#   * suntong/web2image — webpage screenshot tool
#   * drharryhe/has — HAS service framework
#   * tympanix/artoodetoo — Star Wars-themed task runner
#   * GenaroNetwork/GenaroEden_Alpha — Genaro Network client
#   * neoxelox/clank — Clank Engine backend
#   * Many other Chinese-developer Go projects (mkideal is based in China
#     and the library has strong adoption in the Chinese Go community)
#
# -----------------------------------------------------------------------------
# PATHBRUTE'S CLI SURFACE (verbatim from pathBrute.go argT struct)
# -----------------------------------------------------------------------------
#
# USAGE:
#   pathbrute [OPTIONS]
#
# Target selection:
#   -u, --url <URL>          URL of website to test
#   -U, --filename <FILE>    File containing list of websites (one per line)
#
# Path source:
#   -p, --path <PATH>        Single URI path to test
#   -P, --Paths <FILE>       File containing list of URI paths
#   -s, --source <SOURCE>    Path source wordlist:
#                            default | msf | exploitdb | exploitdb-asp |
#                            exploitdb-aspx | exploitdb-cfm | exploitdb-cgi |
#                            exploitdb-jsp | exploitdb-perl | exploitdb-php |
#                            exploitdb-others | RobotsDisallowed | SecLists
#
# Response filtering:
#   -c <STATUS>              Show only certain status code (e.g., -c 200)
#   -e <STATUS>              Exclude certain status code (e.g., -e 404)
#
# Behavior:
#   -n, --threads <N>        Concurrent threads (default: 2)
#   -i                       Intelligent mode (adaptive path selection)
#   --cms                    Fingerprint CMS (WordPress/Joomla/Drupal)
#   -x                       Spread mode (test ONE URI path across ALL hosts
#                            instead of all paths against one host before
#                            moving on)
#   -r <NUM>                 Resume from path #NUM (out of total list)
#   --skip                   Skip sites with no useful results (OWA, VPN, etc)
#   --confirm                Confirm using more than 100 threads (with -n)
#
# Networking:
#   --pHost <IP>             IP of HTTP proxy
#   --pPort <PORT>           Port of HTTP proxy (default 8080)
#   --ua <UAGENT>            Custom User-Agent string
#   --timeout <SEC>          Per-request timeout
#
# Logging:
#   -v, --verbose            Verbose mode
#   -l, --log <FILE>         Output to log file
#
# Maintenance:
#   --update                 Update URI path wordlists from Github
#   -q, --query              Look up found URI paths against ExploitDB
#
# Help:
#   -h, --help               Print help (from embedded cli.Helper)
#
# =============================================================================

_pathbrute() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a path_sources

    path_sources=(
        'default:default path list'
        'msf:Metasploit-derived path list'
        'exploitdb:ExploitDB main paths'
        'exploitdb-asp:ExploitDB ASP paths'
        'exploitdb-aspx:ExploitDB ASPX paths'
        'exploitdb-cfm:ExploitDB CFM paths'
        'exploitdb-cgi:ExploitDB CGI paths'
        'exploitdb-jsp:ExploitDB JSP paths'
        'exploitdb-perl:ExploitDB Perl paths'
        'exploitdb-php:ExploitDB PHP paths'
        'exploitdb-others:ExploitDB miscellaneous paths'
        'RobotsDisallowed:RobotsDisallowed project paths'
        'SecLists:SecLists discovery paths'
    )

    _arguments -s \
        '(-u --url)'{-u,--url}'[URL of website]:url:_urls' \
        '(-U --filename)'{-U,--filename}'[file containing website list]:file:_files' \
        '(-p --path)'{-p,--path}'[single URI path to test]:path:' \
        '(-P --Paths)'{-P,--Paths}'[file containing URI path list]:path file:_files' \
        '(-s --source)'{-s,--source}'[path source wordlist]:source:->src' \
        '-c[show only certain HTTP status code]:status:' \
        '-e[exclude certain HTTP status code]:status:' \
        '(-n --threads)'{-n,--threads}'[concurrent threads (default 2)]:N:' \
        '-i[intelligent mode]' \
        '--cms[fingerprint CMS (WP/Joomla/Drupal)]' \
        '-x[spread mode (path across all hosts)]' \
        '-r[resume from path number]:N:' \
        '--skip[skip sites with no useful results]' \
        '--confirm[confirm using >100 threads]' \
        '--pHost[HTTP proxy host IP]:proxy host:_hosts' \
        '--pPort[HTTP proxy port (default 8080)]:proxy port:_ports' \
        '--ua[custom User-Agent string]:user agent:' \
        '--timeout[per-request timeout (seconds)]:seconds:' \
        '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
        '(-l --log)'{-l,--log}'[output to log file]:log file:_files' \
        '--update[update URI wordlists from GitHub]' \
        '(-q --query)'{-q,--query}'[lookup found paths against ExploitDB]' \
        '(-h --help)'{-h,--help}'[print help (from cli.Helper)]' \
        && ret=0

    case $state in
        (src)
            _describe -t sources 'path source wordlist' path_sources && ret=0
            ;;
    esac

    return ret
}

_pathbrute "$@"
