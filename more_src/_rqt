#compdef rqt
# Documentation: https://github.com/ros-visualization/rqt (rqt_gui/src/rqt_gui/main.py)
#                https://github.com/ros-visualization/qt_gui_core (qt_gui/src/qt_gui/main.py)
# Reference accessed: 2026-05-27
# Verified: rqt_gui inherits qt_gui.main.Main; the argparse declarations
# live in qt_gui_core's qt_gui/src/qt_gui/main.py `add_arguments` method.

_arguments \
  '(- *)'{-h,--help}'[show this help message and exit]' \
  '(-b --qt-binding)'{-b+,--qt-binding=}'[choose Qt bindings to use]:binding:(pyqt pyside)' \
  '--clear-config[clear the configuration (perspectives and plugin settings)]' \
  '(-f --freeze-layout)'{-f,--freeze-layout}'[freeze the GUI layout]' \
  '--force-discover[force a rediscover of plugins]' \
  '(-ht --hide-title)'{-ht,--hide-title}'[hide title label, icon, and help button]' \
  '(-l --lock-perspective)'{-l,--lock-perspective}'[lock the GUI to the active perspective]' \
  '(-p --perspective)'{-p+,--perspective=}'[start with this named perspective]:perspective:' \
  '--perspective-file=[start with a perspective loaded from a file]:file:_files' \
  '--reload-import[reload every imported module]' \
  '(-s --standalone)'{-s+,--standalone=}'[start only this plugin (implies -l)]:plugin:' \
  '(-t --on-top)'{-t,--on-top}'[set window mode to always on top]' \
  '(-v --verbose)'{-v,--verbose}'[output qDebug messages]' \
  '--list-perspectives[list available perspectives]' \
  '--list-plugins[list available plugins]' \
  '--command-pid=[pid of the GUI instance to operate on]:pid:' \
  '--command-start-plugin=[start plugin in a running GUI instance]:plugin:' \
  '--command-switch-perspective=[switch perspective on a running GUI instance]:perspective:' \
  '--embed-plugin=[embed a plugin into an already running GUI instance]:plugin:' \
  '--embed-plugin-serial=[serial number of plugin to be embedded]:serial:' \
  '--embed-plugin-address=[dbus server address of host GUI instance]:address:' \
  '*--args[arbitrary arguments passed to the plugin (must be last)]'
