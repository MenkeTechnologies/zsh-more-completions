#compdef butler
# Documentation: https://itch.io/docs/butler/
# Documentation: https://github.com/itchio/butler/blob/master/main.go
# Reference accessed: 2026-05-21
# Verified against butler main.go global flag list (itchio/butler)

# Zsh completion for butler (itch.io command-line tools)

local curcontext="$curcontext" state line ret=1

local -a _butler_subcommands
_butler_subcommands=(
  'login:authenticate with itch.io and save the API key'
  'logout:remove saved itch.io API key'
  'status:print the status of all channels of a project'
  'push:upload a build to itch.io'
  'fetch:download a build from itch.io'
  'file:print information about a file'
  'ls:list contents of an archive'
  'cp:copy or download a file'
  'sign:generate a signature file for a directory'
  'verify:verify a directory against a signature'
  'heal:repair a directory using a signature and source'
  'upgrade:upgrade butler to the latest version'
  'version:print version information'
  'mkdir:create directories'
  'untar:extract a tar archive'
  'unzip:extract a zip archive'
  'diff:generate a patch between two directories'
  'apply:apply a patch to a directory'
  'wipe:remove a directory entirely'
  'walk:print all paths in a directory'
  'which:print the path of the butler executable'
  'configure:detect launch candidates in a directory'
  'pipe:pipe data through butler'
  'service:run butler in background as a daemon'
  'script:run a series of butler commands'
)

_arguments -C \
  '(-j --json)'{-j,--json}'[enable machine-readable JSON-lines output]' \
  '--quiet[hide progress indicators and other extra info]' \
  '(-v --verbose)'{-v,--verbose}'[be very chatty about what is happening]' \
  '--timestamps[prefix all output by timestamps]' \
  '--noprogress[do not show progress bars]' \
  '--panic[panic on error]' \
  '--assume-yes[do not ask questions, just proceed]' \
  '(-i --identity)'{-i+,--identity=}'[path to your itch.io API token]:file:_files' \
  '(-a --address)'{-a+,--address=}'[itch.io server to talk to]:url:' \
  '--user-agent=[user-agent string for HTTP requests]:agent:' \
  '--dbpath=[SQLite database path]:file:_files' \
  '--butlerd-profile=[authenticate using butlerd profile credentials]:profile:' \
  '--compression=[compression algorithm for patches/signatures]:algorithm:(none brotli gzip)' \
  '(-q --quality)'{-q+,--quality=}'[quality level for compression]:level:' \
  '--cpuprofile=[write CPU profile to file]:file:_files' \
  '--memstats[print memory statistics]' \
  '--elevate[run butler as administrator]' \
  '--throttle=[bandwidth limit in Kbps]:kbps:' \
  '--context-timeout=[network timeout in seconds]:seconds:' \
  '--simulateOffline[simulate offline mode]' \
  '*--ignore=[glob patterns for files to ignore]:pattern:' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'butler subcommand' _butler_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      push)
        _arguments \
          '--userversion=[user-supplied version string]:version:' \
          '--userversion-file=[user-supplied version from file]:file:_files' \
          '--fix-permissions[fix permissions on uploaded files]' \
          '--dereference[dereference symlinks during push]' \
          '--if-changed[only push if the build has changed]' \
          '--auto-wipe[wipe build files after upload]' \
          '1:source:_files' \
          '2:target:' && ret=0
        ;;
      fetch)
        _arguments \
          '1:target:' \
          '2:directory:_files -/' && ret=0
        ;;
      *)
        _arguments '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
