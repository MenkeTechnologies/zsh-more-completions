#compdef pymol

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-c[command line only, no GUI]' \
  '-p[start in presentation mode]' \
  '-q[quiet launch, suppress startup messages]' \
  '-Q[very quiet]' \
  '-e[start in fullscreen mode]' \
  '-f[start in fullscreen mode (no menus)]' \
  '-i[start with internal GUI enabled]' \
  '-x[start with external GUI disabled]' \
  '-X[start with external GUI enabled]' \
  '-d+[execute command]:command:' \
  '-l+[run script]:script:_files -g "*.pml"' \
  '-r+[run Python script]:script:_files -g "*.py"' \
  '-s+[run script with arguments]:script:_files' \
  '-u+[run script and pass URL]:script:' \
  '-R[launch RPC server]' \
  '-G[launch GUI server]' \
  '-W+[window width]:width:' \
  '-H+[window height]:height:' \
  '-k[disable splash screen]' \
  '-K[use kiosk mode]' \
  '-o+[offset window position]:offset:' \
  '-M[use mono display mode]' \
  '-S[use stereo display mode]' \
  '-1[single window mode]' \
  '-2[two window mode]' \
  '-n[do not restore session]' \
  '-N[use GLUT windowing]' \
  '-t+[set number of threads]:threads:' \
  '-T+[title text]:title:' \
  '-A+[stereo angle]:angle:' \
  '-B+[set background color]:color:' \
  '-g+[set geometry]:geometry:' \
  '*:file:_files -g "*.(pdb|cif|mol|mol2|sdf|xyz|pml|py|pse|ccp4|mtz|map)"' && ret=0

return ret
