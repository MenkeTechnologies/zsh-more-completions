#compdef ht

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-b[print body only]' \
  '--body[print body only]' \
  '-H[print headers only]' \
  '--headers[print headers only]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-p+[output parts]:parts:(HhBb)' \
  '--print=[output parts]:parts:(HhBb)' \
  '-j[JSON mode]' \
  '--json[JSON mode]' \
  '-f[form mode]' \
  '--form[form mode]' \
  '-o+[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '-d[download mode]' \
  '--download[download mode]' \
  '-c[resume download]' \
  '--continue[resume download]' \
  '-F[follow redirects]' \
  '--follow[follow redirects]' \
  '--max-redirects=[max redirects]:count' \
  '-a+[credentials]:user\:pass' \
  '--auth=[credentials]:user\:pass' \
  '--auth-type=[auth type]:type:(basic digest)' \
  '--proxy=[proxy URL]:proxy' \
  '--verify=[SSL verification]:verify:(yes no)' \
  '--cert=[client certificate]:cert:_files' \
  '--cert-key=[client key]:key:_files' \
  '--timeout=[request timeout]:seconds' \
  '--style=[output style]:style:(monokai fruity native)' \
  '--pretty=[pretty print]:mode:(all colors format none)' \
  '1:method or URL:(GET POST PUT PATCH DELETE HEAD OPTIONS)' \
  '2:URL:' \
  '*:request items:' && return 0
