#compdef rack
# _rackspace-cli — Rackspace Cloud CLI (Rackspace, Go); manage Rackspace Cloud Servers/Files/Networks
# upstream: https://github.com/rackspace/rack

_rackspace-cli() {
    local -a sub=(
        'configure:configure profile'
        'autoscale:autoscale group commands'
        'block-storage:block storage'
        'compute:cloud servers'
        'configs:CLI configs'
        'files:cloud files'
        'help:show help'
        'images:images'
        'networks:networks'
        'orchestration:orchestration'
        'profile:profile commands'
        'queues:queues'
        'servers:cloud servers'
        'snapshots:snapshots'
        'version:show version'
        'volumes:volumes'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--region+[region]:region:(DFW HKG IAD LON ORD SYD)' \
        '--username+[username]:str:' \
        '--api-key+[API key]:str:' \
        '--auth-url+[auth URL]:url:_urls' \
        '--auth-tenant-id+[tenant id]:str:' \
        '--profile+[profile]:profile:' \
        '--no-cache[no cache]' \
        '--debug[debug]' \
        '--output+[output format]:fmt:(json table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rack subcommand' sub ;;
    esac
}

_rackspace-cli "$@"
