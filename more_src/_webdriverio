#compdef webdriverio wdio
# Documentation: https://man.archlinux.org/search?q=webdriverio
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:configuration helper / wizard'
  'install:add a reporter, service, runner, or framework'
  'run:run a WDIO configuration'
  'repl:open a WebDriver REPL'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wdio command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-c --config)'{-c+,--config=}'[wdio config file]:file:_files -g "wdio.{conf,config}.{js,ts,mjs,cjs}"' \
          '(-h --hostname)'{-h+,--hostname=}'[automation driver host]:host:_hosts' \
          '(-p --port)'{-p+,--port=}'[automation driver port]:port:' \
          '--path=[automation driver path]:path:' \
          '--protocol=[driver protocol]:protocol:(http https)' \
          '--bail=[stop after N failures]:n:' \
          '--baseUrl=[base URL]:url:' \
          '--watch[watch mode]' \
          '--user=[user (Sauce/BS)]:user:' \
          '--key=[key (Sauce/BS)]:key:' \
          '--mochaOpts.timeout=[mocha timeout (ms)]:n:' \
          '*--spec=[spec file]:file:_files -g "*.{js,ts}"' \
          '*--exclude=[file to exclude]:file:_files' \
          '*--suite=[suite to run]:suite:' \
          '--reporters=[comma-separated reporters]:reporters:' \
          '--logLevel=[log level]:level:(trace debug info warn error silent)' \
          '*::config:_files -g "wdio.conf.{js,ts}"' && ret=0 ;;
      (config)
        _arguments \
          '(-y --yes)'{-y,--yes}'[non-interactive defaults]' \
          '--yarn[use yarn instead of npm]' \
          '--npm-tag=[npm dist tag]:tag:' && ret=0 ;;
      (install)
        local -a install_types=(
          'service:install a WDIO service'
          'reporter:install a WDIO reporter'
          'framework:install a test framework'
          'runner:install a WDIO runner'
        )
        _describe -t itypes 'install type' install_types && ret=0
        _arguments \
          '--yarn[use yarn]' \
          '--npm-tag=[npm dist tag]:tag:' && ret=0 ;;
      (repl)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '*::browserName:(chrome firefox safari edge)' && ret=0 ;;
    esac ;;
esac

return ret
