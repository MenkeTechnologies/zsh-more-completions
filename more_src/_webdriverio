#compdef webdriverio wdio
# Documentation: https://webdriver.io/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream packages/wdio-cli/src/commands/run.ts option definitions.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:configuration helper / wizard'
  'install:add a reporter, service, runner, or framework'
  'run:run a WDIO configuration'
  'repl:open a WebDriver REPL'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wdio command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--watch[run in watch mode]' \
          '(-h --hostname)'{-h+,--hostname=}'[automation driver host]:host:_hosts' \
          '(-p --port)'{-p+,--port=}'[automation driver port]:port:' \
          '--path=[WebDriver endpoint path]:path:' \
          '(-u --user)'{-u+,--user=}'[user for cloud backends]:user:' \
          '(-k --key)'{-k+,--key=}'[access key]:key:' \
          '(-l --logLevel)'{-l+,--logLevel=}'[log level]:level:(trace debug info warn error silent)' \
          '--bail=[stop after N failures]:n:' \
          '--baseUrl=[base URL]:url:' \
          '(-w --waitforTimeout)'{-w+,--waitforTimeout=}'[waitForXXX timeout]:ms:' \
          '(-s --updateSnapshots)'{-s+,--updateSnapshots=}'[update snapshots]:mode:' \
          '(-f --framework)'{-f+,--framework=}'[test framework]:framework:(mocha jasmine cucumber)' \
          '*'{-r,--reporters=}'[output reporter]:reporter:' \
          '*--suite=[run specific suite]:suite:' \
          '*--spec=[run specific spec]:file:_files -g "*.{js,ts,mjs,cjs}"' \
          '*--exclude=[exclude spec file]:file:_files' \
          '--repeat=[repeat N times]:n:' \
          '--coverage[enable coverage for browser runner]' \
          '--shard=[execute specific shard (x/y)]:shard:' \
          '*::config:_files -g "wdio.conf.{js,ts,mjs,cjs}"' && ret=0 ;;
      (config)
        _arguments \
          '(-y --yes)'{-y,--yes}'[non-interactive defaults]' \
          '--npm-tag=[npm dist tag]:tag:' && ret=0 ;;
      (install)
        local -a install_types=(
          'service:install a WDIO service'
          'reporter:install a WDIO reporter'
          'framework:install a test framework'
          'runner:install a WDIO runner'
          'plugin:install a WDIO plugin'
        )
        _describe -t itypes 'install type' install_types && ret=0
        _arguments \
          '--npm-tag=[npm dist tag]:tag:' && ret=0 ;;
      (repl)
        _arguments \
          '*::browserName:(chrome firefox safari edge)' && ret=0 ;;
    esac ;;
esac

return ret
