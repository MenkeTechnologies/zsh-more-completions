#compdef labctl

# https://github.com/iximiuz/labctl — cobra (main.go cmd.AddCommand)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[version]' \
  '(-l --log-level)'{-l,--log-level}'=-[slog level]:level:(debug info warn error fatal)' \
  '--endpoint=-[override Labs API base URL]:url:' \
  '1:command:(api auth challenge content course cp expose ide kubeproxy playground portforward ssh sshproxy tutorial version)' \
  '*::arguments:_default'
