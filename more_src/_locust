#compdef locust

# Zsh completion for locust - Python load testing tool

_arguments -s -S \
  '(-H --host)'{-H,--host}'[Host to load test]:host URL:' \
  '(-f --locustfile)'{-f,--locustfile}'[Python module to import]:file:_files -g "*.py"' \
  '--headless[Disable the web interface]' \
  '(-u --users)'{-u,--users}'[Peak number of concurrent users]:users:' \
  '(-r --spawn-rate)'{-r,--spawn-rate}'[Rate to spawn users at]:rate:' \
  '(-t --run-time)'{-t,--run-time}'[Stop after the specified amount of time]:time:' \
  '--web-host[Host to bind the web interface to]:host:' \
  '(-P --web-port)'{-P,--web-port}'[Port on which to run web host]:port:' \
  '--csv[Store current request stats to files in CSV format]:prefix:' \
  '--csv-full-history[Store each stats entry in CSV format]' \
  '--html[Store HTML report]:file:_files -g "*.html"' \
  '--master[Set locust to run in distributed mode as master]' \
  '--master-bind-host[Host for master to bind to]:host:' \
  '--master-bind-port[Port for master to listen on]:port:' \
  '--worker[Set locust to run in distributed mode as worker]' \
  '--master-host[Host of the master node]:host:' \
  '--master-port[Port of the master node]:port:' \
  '--tags[List of tags to include in the test]:tags:' \
  '--exclude-tags[List of tags to exclude from the test]:tags:' \
  '(-L --loglevel)'{-L,--loglevel}'[Log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--logfile[Path to log file]:file:_files' \
  '--print-stats[Print stats in the console]' \
  '--only-summary[Only print the summary stats]' \
  '--reset-stats[Reset statistics once spawning has been completed]' \
  '--stop-timeout[Number of seconds to wait for a simulated user to complete]:seconds:' \
  '--step-load[Enable step load mode]' \
  '--step-users[Number of users to increase by step]:users:' \
  '--step-time[Step duration]:time:' \
  '(-a --autostart)'{-a,--autostart}'[Start the test immediately]' \
  '(-A --autoquit)'{-A,--autoquit}'[Quit N seconds after the test is finished]:seconds:' \
  '(- *)--help[Show help]' \
  '(- *)--version[Show version]'
