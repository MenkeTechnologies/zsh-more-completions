#compdef serverless sls
# _serverless-cli — Serverless Framework CLI (Serverless Inc, Node.js); deploy serverless apps to AWS/Azure/GCP/etc.
# upstream: https://github.com/serverless/serverless

_serverless-cli() {
    local -a sub=(
        'config:configure'
        'create:create new service'
        'dashboard:open dashboard'
        'deploy:deploy service'
        'deploy function:deploy single function'
        'deploy list:list deployments'
        'destroy:destroy service'
        'doctor:run doctor'
        'help:show help'
        'info:print service info'
        'install:install service from URL'
        'invoke:invoke a function'
        'invoke local:invoke locally'
        'login:login'
        'logout:logout'
        'logs:fetch logs'
        'metrics:fetch metrics'
        'package:package service'
        'plugin:plugin commands'
        'print:print effective config'
        'remove:remove service'
        'rollback:rollback deployment'
        'rollback function:rollback function'
        'slstats:opt in/out telemetry'
        'studio:open Studio'
        'test:run tests'
        'upgrade:upgrade serverless framework'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--verbose[verbose]' \
        '--debug+[debug]:str:' \
        '--region+[region]:region:' \
        '-r+[region]:region:' \
        '--stage+[stage]:stage:' \
        '-s+[stage]:stage:' \
        '--config+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--app+[app]:str:' \
        '--org+[org]:str:' \
        '--aws-profile+[AWS profile]:profile:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'serverless subcommand' sub ;;
        args)
            case $words[1] in
                deploy) _arguments \
                    '--function+[function]:fn:' \
                    '-f+[function]:fn:' \
                    '--force[force update]' \
                    '--package+[package]:dir:_files -/' \
                    '-p+[package]:dir:_files -/' \
                    '--region+[region]:region:' \
                    '--stage+[stage]:stage:' ;;
                invoke) _arguments \
                    '--function+[function]:fn:' \
                    '-f+[function]:fn:' \
                    '--data+[data]:str:' \
                    '-d+[data]:str:' \
                    '--path+[event path]:file:_files' \
                    '-p+[event path]:file:_files' \
                    '--type+[invocation type]:type:(RequestResponse Event DryRun)' \
                    '--log[log]' \
                    '-l[log]' ;;
                create) _arguments \
                    '--template+[template]:template:' \
                    '-t+[template]:template:' \
                    '--template-path+[template path]:dir:_files -/' \
                    '--template-url+[template URL]:url:_urls' \
                    '--path+[output path]:dir:_files -/' \
                    '-p+[output path]:dir:_files -/' \
                    '--name+[service name]:name:' \
                    '-n+[service name]:name:' ;;
                logs) _arguments \
                    '--function+[function]:fn:' \
                    '-f+[function]:fn:' \
                    '--tail[tail]' \
                    '-t[tail]' \
                    '--filter+[filter]:str:' \
                    '--startTime+[start time]:str:' ;;
                plugin) _arguments '1:plugin cmd:(install uninstall list search)' '*:plugin:' ;;
            esac
            ;;
    esac
}

_serverless-cli "$@"
