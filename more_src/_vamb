#compdef vamb
# Documentation: https://github.com/RasmussenLab/vamb
# Vamb - variational autoencoder metagenomic binning

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--fasta=[input contig fasta file]:file:_files' \
  '--composition=[npz of composition]:file:_files' \
  '--bamfiles=[bam files (deprecated)]:files:_files' \
  '--bamdir=[directory of bam files]:dir:_files -/' \
  '--abundance_tsv=[TSV of precomputed abundances]:file:_files' \
  '--abundance=[npz of abundances]:file:_files' \
  '--taxonomy=[taxonomy file]:file:_files' \
  '--markers=[marker npz file]:file:_files' \
  '--hmm_path=[hmm file of marker gene profiles]:file:_files' \
  '--outdir=[output directory to create]:dir:_files -/' \
  '--minfasta=[minimum bin size to output as fasta]:size' \
  '--compress[compress fasta output]' \
  '-o+[binsplit separator]:sep' \
  '-m+[ignore contigs shorter than this (default 2000)]:length' \
  '-p+[number of threads]:threads' \
  '--norefcheck[skip reference name hashing check]' \
  '--cuda[use GPU to train and cluster]' \
  '--seed=[random seed]:seed' \
  '-n+[number of hidden neurons]:n' \
  '-l+[latent dimensions]:l' \
  '-a+[alpha]:a' \
  '-b+[beta]:b' \
  '-d+[dropout]:d' \
  '-e+[number of epochs]:e' \
  '-t+[batch size]:t' \
  '-q+[batch steps]:q' \
  '-w+[window size]:w' \
  '-u+[minimum successes]:u' \
  '-c+[maximum clusters]:c' \
  '--no_predictor[do not complete taxonomy with Taxometer]' \
  '--latent_path=[latent space npz file]:file:_files' \
  '--clusters_path=[TSV file with clusters]:file:_files' \
  '--algorithm=[reclustering algorithm]:algo:(kmeans dbscan)' \
  '*::command:_default' && ret=0

return ret
