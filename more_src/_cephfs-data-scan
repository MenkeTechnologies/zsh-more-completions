#compdef cephfs-data-scan

# cephfs-data-scan: scan data pool to rebuild filesystem metadata
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--filesystem=[filesystem name]:name:' \
  '--rank=[MDS rank]:n:' \
  '--worker-n=[worker count]:n:' \
  '--worker-id=[worker id]:n:' \
  '--force-corrupt[allow corruption]' \
  '--force-init[allow init when exists]' \
  '*:cephfs-data-scan command:(init scan_extents scan_inodes scan_links scan_frags cleanup tmap_upgrade pg_files missing_objects)' && ret=0
return ret
