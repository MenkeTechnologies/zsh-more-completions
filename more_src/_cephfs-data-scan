#compdef cephfs-data-scan
# Documentation: https://docs.ceph.com/en/latest/cephfs/disaster-recovery-experts/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cephfs-data-scan: scan data pool to rebuild CephFS metadata
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--filesystem=[filesystem name]:fsname:' \
  '--alternate-pool=[recovery pool]:pool:' \
  '--worker_n=[this worker number]:n:' \
  '--worker_m=[total workers]:n:' \
  '--force-corrupt[allow operations on corrupt metadata]' \
  '--force-init[reinitialize when objects already exist]' \
  '*:cephfs-data-scan command:(init scan_extents scan_inodes scan_links scan_frags cleanup tmap_upgrade pg_files)' && ret=0
return ret
