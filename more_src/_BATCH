#compdef BATCH
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/utils/html/BATCH.html
# R CMD BATCH: run R non-interactively with input from a file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print short help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '--no-timing[do not report the timings]' \
  '*:file:_files' && ret=0

return ret
