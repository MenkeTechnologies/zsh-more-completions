#compdef cargo-run-bin
# Documentation: https://github.com/dustinblackman/cargo-run-bin
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# cargo-run-bin: build, cache and run binaries scoped in Cargo.toml metadata
# rather than installed globally. Usage: cargo bin <crate> [args...].

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--help[print help information]' \
  '--version[display installed version of cargo-run-bin]' \
  '--sync-aliases[generate cargo aliases for cargo-prefixed crates]' \
  '--install[install/build all configured binaries not yet cached]' \
  '--build[build all configured binaries not yet cached without running]' \
  '*::crate or args:_default' && ret=0

return ret
