#compdef arpspoof
# _arpspoof — dsniff arpspoof ARP cache poisoning tool (Dug Song, C); used in authorized network tests
# upstream: https://github.com/tecknicaltom/dsniff

_arpspoof() {
    _arguments \
        '-i+[interface]:iface:_net_interfaces' \
        '-c+[clean up mode]:mode:(own host both)' \
        '-t+[target host]:target:_hosts' \
        '-r[poison both directions]' \
        '*:host:_hosts'
}

_arpspoof "$@"
