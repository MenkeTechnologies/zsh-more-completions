#compdef dotenv-vault

# Zsh completion for dotenv-vault (Minebomber/dotenv-vault-rs, argh).

local -a subcmds
subcmds=(
  'run:load .env.vault and run a program'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1: :{_describe '\''subcommand'\'' subcmds}' \
  '*:: :->args'

[[ $state == args ]] || return 0

case $line[1] in
  run)
    _arguments -s -S \
      '--override[override existing environment variables]' \
      '--cwd=[working directory for child]:directory:_directories' \
      '2:program:_command_names' \
      '*::program argument:_normal'
    ;;
esac
