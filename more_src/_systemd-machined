#compdef systemd-machined
# _systemd-machined (systemd virtual-machine + container registry daemon; reads /var/lib/machines and registered images from machinectl(1) to expose them on the system bus; takes no positional arguments, only standard systemd unit flags - this stub completes the few flags the binary accepts directly)
# upstream: https://github.com/systemd/systemd (src/machine)
# Argument shape from systemd src/machine/machined.c on tip.

_systemd-machined() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-machined "$@"
