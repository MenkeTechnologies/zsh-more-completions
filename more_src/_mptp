#compdef mptp
# mPTP: single-locus species delimitation (PTP / mPTP models)

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version information]' \
  '--quiet[suppress stdout except warnings and errors]' \
  '--tree_file[input newick file with phylogenetic tree]:file:_files' \
  '--output_file[prefix for generating output files]:prefix:' \
  '--outgroup[root tree using comma-separated taxa list]:taxa:' \
  '--outgroup_crop[remove taxa specified with --outgroup]' \
  '--min_br[exclude branches smaller than the given value]:value:' \
  '--minbr_auto[auto-detect minimum branch length from FASTA]:file:_files' \
  '--precision[decimal precision for floating point output]:n:' \
  '--tree_show[display ASCII version of processed tree]' \
  '--ml[trigger ML estimation algorithm]' \
  '--single[use the PTP model]' \
  '--multi[use the mPTP model]' \
  '--pvalue[p-value for the likelihood ratio test (PTP only)]:p:' \
  '--mcmc[number of MCMC samples to generate]:n:' \
  '--mcmc_sample[sample every n-th MCMC step]:n:' \
  '--mcmc_log[log scores for each sample]' \
  '--mcmc_burnin[ignore samples before the specified step]:n:' \
  '--mcmc_runs[number of MCMC runs to perform]:n:' \
  '--mcmc_credible[probability for the credible interval]:p:' \
  '--mcmc_startnull[start from the null model]' \
  '--mcmc_startrandom[start from a random delimitation]' \
  '--seed[seed for the pseudo-random number generator]:seed:' \
  '--svg_width[total SVG width in pixels]:pixels:' \
  '--svg_fontsize[font size in SVG image]:size:' \
  '--svg_tipspacing[vertical space between taxa]:pixels:' \
  '--svg_legend_ratio[ratio of tree length used as legend]:ratio:' \
  '--svg_nolegend[hide legend]' \
  '--svg_marginleft[left margin in pixels]:pixels:' \
  '--svg_marginright[right margin in pixels]:pixels:' \
  '--svg_margintop[top margin in pixels]:pixels:' \
  '--svg_marginbottom[bottom margin in pixels]:pixels:' \
  '--svg_inner_radius[radius of inner nodes in pixels]:pixels:' && ret=0

return ret
