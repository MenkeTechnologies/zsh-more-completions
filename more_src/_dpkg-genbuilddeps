#compdef dpkg-genbuilddeps
# Documentation: https://manpages.debian.org/dpkg-genbuilddeps
# Source: debian/devscripts scripts/dpkg-genbuilddeps.sh — dpkg-depcheck wrapper to generate Build-Depends (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '*::dpkg-buildpackage args:_default' \
    && ret=0

return ret
