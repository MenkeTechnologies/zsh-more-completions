#compdef create-medusa-plugin
# Documentation: https://www.npmjs.com/package/create-medusa-plugin
# Reference accessed: 2026-05-24
# Verified: npm view create-medusa-plugin bin; npm readme Options table.

# Zsh completion for create-medusa-plugin - Medusa plugin monorepo scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-r --repo)'{-r,--repo=}'[root monorepo repository name]:name:' \
  '(-e --example)'{-e,--example=}'[example folder name for backend and storefront]:name:' \
  '--directory-path=[output directory for root repository]:directory:_directories' \
  '--plugin-repo-url=[Medusa plugin template repository URL]:url:' \
  '--example-repo-url=[example Medusa backend template repository URL]:url:' \
  '--no-storefront[exclude example storefront from scaffold]' \
  '--skip-example-db[skip creating Medusa example database]' \
  '--verbose[show verbose logs from underlying commands]' \
  ':plugin name:' && ret=0

return ret
