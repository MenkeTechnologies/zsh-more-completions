#compdef gok
# Documentation: https://github.com/gokrazy/tools
# Source: gokrazy/tools internal/gok/root.go — gokrazy build/deploy CLI (Go, spf13/cobra).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gok_cmds
_gok_cmds=(
    'new:create a new gokrazy instance'
    'edit:edit the gokrazy config'
    'add:add a Go package to the instance'
    'get:fetch a Go program for the instance'
    'update:update an existing gokrazy instance'
    'overwrite:overwrite the boot/root partitions'
    'push:push an image to a running instance'
    'run:build and run a Go program on the instance'
    'logs:tail logs of services on the instance'
    'ps:list services running on the instance'
    'vm:run an instance in a local VM'
    'sbom:produce a software bill of materials'
    'version:print version'
)

_arguments -C \
    '(-i --instance)'{-i+,--instance=}'[gokrazy instance name]:name:_default' \
    '--parent_dir=[parent dir for instances]:dir:_files -/' \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'gok command' _gok_cmds && ret=0
        ;;
esac

return ret
