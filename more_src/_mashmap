#compdef mashmap
# mashmap — fast approximate long read / genome mapper

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --ref)'{-r,--ref}'[reference genome FASTA/FASTQ]:file:_files -g "*.fa *.fasta *.fna *.fq *.fastq *.gz"' \
  '(-q --query)'{-q,--query}'[query sequences FASTA/FASTQ]:file:_files -g "*.fa *.fasta *.fna *.fq *.fastq *.gz"' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '--rl[file with list of reference files]:file:_files' \
  '--refList[file with list of reference files]:file:_files' \
  '--ql[file with list of query files]:file:_files' \
  '--queryList[file with list of query files]:file:_files' \
  '--pi[percent identity threshold (default 85)]:percent:' \
  '--perc_identity[percent identity threshold (default 85)]:percent:' \
  '(-s --segLength)'{-s,--segLength}'[minimum segment length (default 5000)]:length:' \
  '(-k --kmer)'{-k,--kmer}'[kmer size (default 16)]:size:' \
  '--noSplit[disable splitting of mappings]' \
  '(-f --filter_mode)'{-f,--filter_mode}'[filter mode]:mode:(map one-to-one none)' \
  '--dense[dense sketching for small genomes]' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads:' \
  '--lowerTriangular[only compute lower triangular for self-mapping]' \
  '--skipSelf[skip self mappings]' \
  '--targetList[file with list of target sequence names]:file:_files' \
  '*:input files:_files -g "*.fa *.fasta *.fna *.fq *.fastq *.gz"' \
  && ret=0

return ret
