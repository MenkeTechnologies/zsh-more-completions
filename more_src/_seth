#compdef seth

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--rpc-url[Ethereum RPC URL]:url:' \
  '--chain[chain name]:chain:(mainnet goerli sepolia)' \
  '--from[sender address]:address:' \
  '--keystore[keystore path]:file:_files' \
  '--password[keystore password]:password:' \
  '1:command:(call send balance nonce block tx receipt age basefee gas-price chain-id 4byte abi-encode abi-decode keccak namehash from-ascii to-ascii from-wei to-wei --to-hex --to-dec --to-fix --to-uint256 estimate run-tx)' \
  '*:args:' && ret=0

return ret
