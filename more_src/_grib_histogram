#compdef grib_histogram
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_histogram
# Source: ecmwf/eccodes tools/grib_histogram.cc — compute value histogram from GRIB files (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p+[keys to print]:keys:_default' \
    '-w+[where clause filter]:filter:_default' \
    '-S[strict, only messages matching all constraints]' \
    '(- *)-V[show version]' \
    '*:grib file:_files' \
    && ret=0

return ret
