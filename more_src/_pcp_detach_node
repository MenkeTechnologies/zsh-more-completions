#compdef pcp_detach_node
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/pcp_detach_node.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# pcp_detach_node: detach a node from Pgpool-II
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "(- *)-V[show version]" \
  "--version[show version]" \
  "-w[no password prompt]" \
  "--no-password[no password prompt]" \
  "-W[force password prompt]" \
  "--password[force password prompt]" \
  "-d[debug]" \
  "--debug[debug]" \
  "-v[verbose]" \
  "--verbose[verbose]" \
  "-U[username]:user:_users" \
  "--username=[username]:user:_users" \
  "-H[pgpool host]:host:_hosts" \
  "--host=[pgpool host]:host:_hosts" \
  "-p[pcp port]:port:" \
  "--port=[pcp port]:port:" \
  "-s[scope]:scope:" \
  "--scope=[scope]:scope:" \
  "-n[node id]:n:" "--node-id=[node id]:n:" "-g[detach gracefully]" "--gracefully[detach gracefully]" \
  '*::pcp_detach_node args:_files' && ret=0
return ret
