#compdef gdal_calc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*-A+[input file]:file:_files' \
  '*-B+[input file]:file:_files' \
  '*-C+[input file]:file:_files' \
  '*-D+[input file]:file:_files' \
  '--A_band=[band for input A]:n:' \
  '--B_band=[band for input B]:n:' \
  '--outfile=[output file]:file:_files' \
  '*--calc=[calculation expression]:expr:' \
  '--NoDataValue=[NoData value for output]:value:' \
  '--type=[output type]:type:(Byte Int8 UInt16 Int16 UInt32 Int32 Float32 Float64 CInt16 CInt32 CFloat32 CFloat64)' \
  '--format=[output format]:format:' \
  '*--creation-option=[creation option]:NAME=VALUE:' \
  '*--co=[creation option]:NAME=VALUE:' \
  '--allBands=[treat all bands of given input as separate bands]:input:(A B C D)' \
  '--overwrite[overwrite existing output]' \
  '--debug[turn on debug output]' \
  '--quiet[quiet mode]' \
  '--projectionCheck[check projections of inputs]' \
  '--color-table=[color table]:file:_files' \
  '--extent=[extent]:choice:(ignore fail union intersect)' \
  '--projwin=[projection window]:ulx uly lrx lry:' \
  '--user_namespace=[user namespace for calc]:dict:' \
  '--hideNoData[ignore NoData when computing]' && ret=0

return ret
