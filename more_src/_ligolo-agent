#compdef ligolo-agent ligolo-ng-agent
# Documentation: https://github.com/nicocha30/ligolo-ng/blob/master/cmd/agent/main.go
# Reference accessed: 2026-05-19
# Verified: upstream agent main.go at the URL above.

_arguments -s \
  '-ignore-cert[ignore TLS validation]' \
  '-accept-fingerprint=[SHA256 fingerprint]:hex:' \
  '-v[verbose]' \
  '-retry[retry on connect error]' \
  '-retry-delay=[retry delay]:seconds:' \
  '-reconnect[auto-reconnect]' \
  '-reconnect-delay=[reconnect delay]:seconds:' \
  '-reconnect-timeout=[reconnect timeout]:seconds:' \
  '-proxy=[proxy URL]:url:' \
  '-connect=[server host\:port]:host\:port:' \
  '-bind=[bind ip\:port]:ip\:port:' \
  '-ua=[User-Agent]:ua:' \
  '-version[show version]' \
  '(- *)'{-h,-help}'[show help]' \
  && return 0
