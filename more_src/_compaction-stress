#compdef compaction-stress

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'compact:compact data in directory'
  'help:display help information'
  'write:write data directly to disk'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'compaction-stress command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (compact|write)
        _files -/ && ret=0
        ;;
    esac
    ;;
esac

return ret
