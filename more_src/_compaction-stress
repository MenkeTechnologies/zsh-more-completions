#compdef compaction-stress
# Documentation: https://github.com/apache/cassandra/blob/trunk/tools/stress/src/org/apache/cassandra/stress/CompactionStress.java
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'compact:compact data in directory'
  'help:display help information'
  'write:write data directly to disk'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'compaction-stress command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (compact|write)
        _files -/ && ret=0
        ;;
    esac
    ;;
esac

return ret
