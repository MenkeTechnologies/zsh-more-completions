#compdef run-tutorial
# _run-tutorial — execute the LinkML tutorial markdown notebooks (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from src/linkml/utils/execute_tutorial.py (click).

_run-tutorial() {
    local -a args
    args=(
        '(-d --directory)'{-d+,--directory=}'[output directory for executed tutorial artifacts]:dir:_files -/'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '*:tutorial markdown input:_files -g "*.md"'
    )
    _arguments -s -S $args
}

_run-tutorial "$@"
