#compdef usdstitchclips
# Documentation: https://openusd.org/release/toolset.html
# Creates an aggregate representation of a prim across USD files using Value Clips

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --out)'{-o,--out}'[specify output file path]:output:_files' \
  '--clipPath[prim hierarchy to host Value Clip metadata]:primpath:' \
  '--templateMetadata[use template-based metadata for determining clip ranges]' \
  '--templatePath[regex-style template string for asset path naming]:template:' \
  '--startTimeCode[start time code of the clip range]:time:' \
  '--endTimeCode[end time code of the clip range]:time:' \
  '--stride[increment rate when seeking files]:stride:' \
  '--noComments[do not write comments to the output layer]' \
  '*:USD file:_files' && ret=0

return ret
