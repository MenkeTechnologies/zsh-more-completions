#compdef cognac
# =============================================================================
# cognac — cognate-lang/cognate's "CognaC"
#   (Cognate Compiler) — the original
#   reference COMPILER for the COGNATE
#   programming language.  Cognate is a STACK-
#   ORIENTED CONCATENATIVE language (like
#   Forth / Factor) with two distinctive
#   syntactic twists: (1) statements are
#   evaluated RIGHT TO LEFT (so they read
#   prefix-style like English sentences) and
#   (2) lowercase-initial words are IGNORED
#   by the parser, letting you embed English
#   commentary INSIDE statements as fluent
#   prose.  CognaC compiles `.cog` source
#   files to readable C, then invokes the
#   system C compiler to produce a small
#   native executable with generational
#   garbage collection.  Performs type
#   inference at compile time (for both
#   optimisation and error reporting).
#   133rd language entry in the corpus.
#
# 133RD LANGUAGE ENTRY — Cognate closes the
# 3+1 micro-cycle started after Axis 53
# (ClickHouse Client Library) closed at 1/1/1
# three-language symmetry in R803 (TS-Node=108
# `_hdx` on @clickhouse/client + R802 Go=108
# `_clickhouse_sinker` on ClickHouse/clickhouse-
# go/v2 + R801 Rust=108 `_dozer` on clickhouse-
# rs).
#
# Distinguishing Cognate from the 132 prior
# corpus languages — closest neighbours and
# their differences:
#   - FORTH FAMILY (`_gforth`, `_pforth`, `_8th`,
#     etc.): untyped, left-to-right evaluation,
#     interactive REPL.  Cognate is statically-
#     type-inferred, RIGHT-TO-LEFT, file-based
#   - FACTOR (`_factor`): dynamic + image-based.
#     Cognate is static + AOT-compiled
#   - JOY (Manfred von Thun): untyped left-to-
#     right.  Cognate evaluates rtl + infers
#     types
#   - MIRTH (R796, `_mirth`): statically typed
#     concatenative + self-hosting + C99
#     codegen.  Cognate is also statically typed
#     concatenative + C codegen BUT mirth is
#     left-to-right (like Forth ancestry) and
#     uses categorical effects.  Cognate is
#     right-to-left with READABILITY-FOCUSED
#     syntax (lowercase-ignore)
#   - MLATU (R784, `_mlatu`): DECLARATIVE term-
#     rewriting concatenative.  Cognate is
#     IMPERATIVE concatenative
#   - LAWVERE (R800, `_bill`): ARROW-COMPOSITION
#     concatenative (categorical foundations,
#     no stack).  Cognate IS stack-based
#   - REBOL / RED: also "near-English"-style
#     syntax via dialect dispatch.  Cognate
#     achieves it via lowercase-ignore + rtl
#     evaluation, no dialect machinery
#
# THE LOWERCASE-IGNORE RULE — Cognate's
# signature feature.  ANY word starting with a
# lowercase letter is COMPLETELY IGNORED by
# the parser.  Only Uppercase-initial words +
# punctuation contribute to evaluation.  This
# lets you write:
#
#     Print the sum of 1 and 2 ;
#
# where "the", "of", "and" are skipped, so the
# compiler sees only `Print Sum 1 2 ;` —
# evaluated right-to-left as Forth `1 2 Sum
# Print`.  This produces remarkably English-
# looking code that the parser tokens are still
# unambiguous because they Capitalise
#
# THE RIGHT-TO-LEFT RULE — Cognate's other
# distinctive choice.  Statements are evaluated
# right-to-left, so the leftmost word is the
# OUTERMOST call.  Programs read like prefix
# notation but compile like Forth.  Combined
# with lowercase-ignore, the surface syntax
# looks like English narration of the
# computation
#
# KEY COGNATE LANGUAGE FEATURES:
#   - POINT-FREE FUNCTIONS — no lambda syntax;
#     functions composed by juxtaposition
#   - OPERATION CHAINING — `Square Square
#     Square 2` cubes a square via three
#     Squares stacked
#   - MULTIPLE RETURN VALUES — words can leave
#     2+ items on the stack; consumers
#     destructure naturally
#   - COMBINATOR-ORIENTED PROGRAMMING — Map,
#     Filter, Fold, etc. are first-class
#     combinators in the prelude
#   - PREDICATE PATTERN MATCHING — `Define
#     Foo As Case When ... ; ...` matches by
#     dynamic predicate (not just type tag)
#   - STATIC TYPE INFERENCE — every stack-
#     effect is inferred by CognaC at compile
#     time.  Used for both optimisation (avoid
#     boxing) and compile-time error detection
#     (`stack underflow` detected without
#     execution)
#   - GENERATIONAL GARBAGE COLLECTION — the
#     emitted C uses CognaC's runtime which
#     includes a generational GC (young
#     gen + old gen + write barrier).
#     Closer to OCaml's GC than Forth's
#     manual stack discipline
#   - PRETTY ERROR MESSAGES + BACKTRACES —
#     `-debug` mode emits debug info into the
#     generated C, so segfaults / runtime
#     errors print a Cognate-level backtrace
#     rather than a C-level one
#   - C-CALL-LEVEL PERFORMANCE — upstream
#     claims small programs approach C speed
#     because the emitted C inlines aggressively
#     and the type inference erases dynamic
#     dispatch
#
# COGNATE IMPLEMENTATION ECOSYSTEM:
#   * CognaC (this binary)           original
#                                    compiler;
#                                    produces
#                                    optimised
#                                    native
#                                    executables
#                                    via C
#                                    codegen
#   * Cognate Playground             web
#                                    interpreter
#                                    (by
#                                    hedyhli) at
#                                    https://
#                                    cognate-
#                                    playground.
#                                    hedy.dev
#   * Cogni                          microcontroller-
#                                    optimised
#                                    interpreter
#                                    (by
#                                    dragoncoder047)
#                                    at github.
#                                    com/
#                                    dragoncoder047/
#                                    cogni
#
# CLI ARGUMENT PARSER — hand-rolled `argv`
# iteration (no getopt / argp / clap).  No
# subcommands.  Three boolean toggles + a
# single positional file argument.
#
# FILE EXTENSION: `*.cog`
#
# CRITICAL BUILD DEPENDENCIES:
#   - flex                     — lexer
#                                generator
#                                (compiles
#                                src/lexer.l)
#   - bison                    — parser
#                                generator
#                                (compiles
#                                src/parser.y)
#   - C compiler (GCC, Clang,  — produces the
#     or TCC supported)          final
#                                executable
#                                from the C
#                                output
#   - GNU make                 — build
#                                orchestration
#
# Pure C99 codegen output.  No external
# runtime dependencies in the emitted
# executable — the Cognate runtime is bundled
# into every output binary via
# `src/runtime_bytes.h` (xxd-embedded
# `runtime.h`).
#
# SUPPORTED PLATFORMS: Linux + macOS native;
# Windows via WSL.  Builds tested on Debian
# (GCC/Clang/TCC) + macOS (Clang) in CI.
#
# UPSTREAM:
#   * Source             : https://github.com/cognate-lang/cognate
#   * Site               : https://cognate-lang.github.io
#   * Tutorial           : https://cognate-lang.github.io/learn/
#   * Playground         : https://cognate-playground.hedy.dev
#   * Cogni μC port      : https://github.com/dragoncoder047/cogni
#   * License            : BSD-2-Clause
#   * Maintainer         : cognate-lang
#
# INSTALL:
#   # Build dependencies
#   sudo apt install make flex bison gcc   # Debian/Ubuntu
#   brew install flex bison                # macOS (system gcc/clang OK)
#
#   # Build CognaC
#   git clone https://github.com/cognate-lang/cognate
#   cd cognate
#   make
#
#   # Install (to ~/.local/bin by default;
#   # override with PREFIX=...)
#   make install
#
#   # Custom prefix
#   make PREFIX=/usr/local install
#
# USAGE EXAMPLES:
#
#   # Compile a Cognate file (emits a native
#   # executable next to the source)
#   cognac hello.cog
#   ./hello                          # run it
#
#   # Compile with debug info (pretty
#   # backtraces + assertion checks)
#   cognac -debug hello.cog
#   ./hello                          # crashes
#                                    # now print
#                                    # a Cognate-
#                                    # level
#                                    # backtrace
#
#   # GC stress-test mode (forces GC on every
#   # heap allocation; useful for finding
#   # write-barrier bugs in custom builtins)
#   cognac -GCTEST hello.cog
#
#   # Disable inlining (slower binary, easier
#   # to read the generated C; useful for
#   # debugging the compiler itself)
#   cognac -NOINLINE hello.cog
#
#   # Combine modes (debug + no-inline + GC
#   # stress)
#   cognac -debug -NOINLINE -GCTEST hello.cog
#
#   # Order doesn't matter — flags can come
#   # before or after the filename
#   cognac hello.cog -debug
#
#   # No subcommands / no -h flag — running
#   # `cognac` with no .cog file just prints
#   # a USAGE message and exits 1
#   cognac
#
# SAMPLE PROGRAM (verbatim from upstream
# examples/hello.cog or equivalent):
#
#   # hello.cog
#   #
#   # Lowercase words ("the", "to") are ignored.
#   # Statements are evaluated right-to-left,
#   # so this compiles to roughly:
#   #     "Hello, world!" Print ;
#   #
#   Print the message "Hello, world!" ;
#
#   # Fizzbuzz
#   Def Fizzbuzz As (
#       Range 1 to 100
#       Map (
#           Case ( divides 15 ) "Fizzbuzz"
#           Case ( divides  3 ) "Fizz"
#           Case ( divides  5 ) "Buzz"
#           ;
#           Show
#       )
#       For-each Print
#   ) ;
#
# OPTIONS (sourced directly from
# https://github.com/cognate-lang/cognate/blob/master/src/cognac.c main):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '-debug[enable debug mode (pretty error messages, runtime assertions, backtraces)]' \
    '-GCTEST[GC stress-test mode (forces garbage collection on every heap allocation)]' \
    '-NOINLINE[disable function inlining in the generated C (easier to read; slower binary)]' \
    '*:Cognate source file:_files -g "*.cog"' \
    && ret=0

return ret
