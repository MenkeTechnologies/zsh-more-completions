#compdef maxit
# Documentation: https://sw-tools.rcsb.org/apps/MAXIT/README-binary
# RCSB MAXIT macromolecular PDB / mmCIF format conversion and processing

local ret=1

_arguments -s -S \
  '-i+[input file]:file:_files' \
  '-o+[output format]:format:((1\:mmCIF 2\:PDB 8\:mmCIF-update))' \
  '-exchange_in[read input in exchange (PDBx/mmCIF) format]' \
  '-exchange_out[write output in exchange (PDBx/mmCIF) format]' && ret=0

return ret
