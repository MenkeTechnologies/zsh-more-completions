#compdef djlint

# Zsh completion for djlint - HTML template linter and formatter (Django, Jinja, Nunjucks, Handlebars, GoLang)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-e --extension)'{-e,--extension}'[file extension to check]:ext' \
  '(-i --ignore)'{-i,--ignore}'[ignored rules (comma separated)]:rules' \
  '--reformat[reformat file in place]' \
  '--check[check formatting without making changes]' \
  '--indent[number of spaces for indentation]:spaces' \
  '--quiet[be quiet]' \
  '--profile[template profile]:profile:(html django jinja nunjucks handlebars golang angular)' \
  '--require-pragma[only format files which contain djlint pragma]' \
  '--lint[lint only, no formatting]' \
  '--preserve-leading-space[preserve leading space]' \
  '--preserve-blank-lines[preserve blank lines]' \
  '--format-css[format embedded css]' \
  '--format-js[format embedded js]' \
  '--configuration[configuration file path]:file:_files' \
  '--statistics[print code statistics]' \
  '--include[regex of rules to include]:regex' \
  '--ignore-case[case insensitive matching]' \
  '--ignore-blocks[blocks to ignore]:blocks' \
  '--blank-line-after-tag[insert blank line after specific tags]:tags' \
  '--blank-line-before-tag[insert blank line before specific tags]:tags' \
  '--line-break-after-multiline-tag[line break after multiline tag]' \
  '--custom-blocks[custom blocks as csv]:blocks' \
  '--custom-html[custom html as csv]:html' \
  '--exclude[regex of files to exclude]:regex' \
  '--extend-exclude[extend the default exclude regex]:regex' \
  '--linter-output-format[linter output format]:format' \
  '--max-line-length[max line length]:length' \
  '--max-attribute-length[max attribute length]:length' \
  '--format-attribute-template-tags[format template tag attributes]' \
  '--per-file-ignores[per-file ignore rules]:rules' \
  '--indent-css[CSS indent size]:size' \
  '--indent-js[JS indent size]:size' \
  '--close-void-tags[add closing slash to void tags]' \
  '--no-line-after-yaml[no line break after YAML front matter]' \
  '--no-function-formatting[disable function formatting]' \
  '--no-set-formatting[disable set formatting]' \
  '*:file:_files' && ret=0

return ret
