#compdef otbcli_LSMSSegmentation
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_LSMSSegmentation.html
# Orfeo ToolBox: second step of Large-Scale Mean-Shift segmentation workflow

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[filtered image (fout of MeanShiftSmoothing)]:image:_files' \
  '-inpos[filtered position image (foutpos of MeanShiftSmoothing)]:image:_files' \
  '-out[output segmented label image]:output:_files' \
  '-spatialr[threshold on spatial distance for same segment]:value:' \
  '-ranger[threshold on spectral euclidean distance for same segment]:value:' \
  '-minsize[minimum segment size threshold]:value:' \
  '-tilesizex[size of tiles along X-axis]:value:' \
  '-tilesizey[size of tiles along Y-axis]:value:' \
  '-tmpdir[directory for temporary tile files]:dir:_files -/' \
  '-cleanup[remove all temporary files created]:bool:(true false)' \
  '*::arg:_files' && ret=0

return ret
