#compdef zot
# _zot — OCI-native container image registry (project-zot/zot)
# upstream: https://github.com/project-zot/zot
# Subcommands from pkg/cli/server/root.go (cobra).

_zot() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'serve:store and distribute OCI images'
                'scrub:verify manifest/blob integrity'
                'verify:validate the configuration file'
                'verify-feature:check if a feature is built into the binary'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                serve|scrub|verify) _arguments '1:config file:_files -g "*.(json|yml|yaml)"' ;;
            esac
            ;;
    esac
}

_zot "$@"
