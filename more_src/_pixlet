#compdef pixlet
# Documentation: https://man.archlinux.org/search?q=pixlet
# Reference accessed: 2026-05-16

# Tidbyt `pixlet` — https://github.com/tidbyt/pixlet — render/push apps.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'render:render.star to webp/gif'
  'serve:local dev server'
  'push:upload applet to device'
  'encrypt:encrypt secrets bundle'
  'decrypt:decrypt bundle'
  'lint:lint starlark'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'pixlet' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
