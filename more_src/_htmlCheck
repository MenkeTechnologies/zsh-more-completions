#compdef htmlCheck
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: do a little checking on an HTML page fetched over the web

local ret=1

_arguments -s -S \
  '-cookies=[two-column file with cookie names and values]:file:_files' \
  '-withSrc[include SRC= links in get and checkLinks commands]' \
  '1:command:(ok getAll getHeader getCookies getHtml getForms getVars getLinks getTags checkLinks checkLinks2 checkLocalLinks checkLocalLinks2 submit validate strictTagNestCheck)' \
  '2:url:_files' && ret=0

return ret
