#compdef segger-jrun JRun JRunPC
# _segger-jrun — SEGGER Microcontroller JRun CLI for the SEGGER J-Link execute load and run application image on target reset connect download semihosting capture RTT output stop on breakpoint event-driven exit (segger team, C++); custom argparse
# upstream: https://www.segger.com/downloads/jlink/

_segger-jrun() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-device=+[target device]:str:' \
        '-Device=+[target device]:str:' \
        '-if=+[interface]:i:(SWD JTAG)' \
        '-IF=+[interface]:i:(SWD JTAG)' \
        '-speed=+[Hz]:n:' \
        '-Speed=+[Hz]:n:' \
        '-RTTAddress=+[hex]:str:' \
        '-RTTSearchRanges=+[ranges]:str:' \
        '-RTTLogFile=+[file]:file:_files' \
        '-RTTTelnetPort=+[port]:n:' \
        '-AutoConnect=+[b]:b:(1 0)' \
        '-NoGui[no GUI]' \
        '-NoReset[no reset]' \
        '-Log=+[file]:file:_files' \
        '-Force[force]' \
        '-ExitOnError[exit on error]' \
        '-StopOnBreak[stop on break]' \
        '-RestoreRegs[restore registers]' \
        '-StartAddr=+[hex]:str:' \
        '-EndAddr=+[hex]:str:' \
        '*:ELF AXF HEX:_files -g "*.elf *.axf *.hex *.srec *.bin"'
}

_segger-jrun "$@"
