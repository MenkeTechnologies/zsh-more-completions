#compdef oksh
# _oksh — OpenBSD ksh portable build (Jasper Lievisse Adriaanse); BSD-derived public-domain ksh suitable for /bin/sh
# upstream: https://github.com/ibara/oksh

_oksh() {
    _arguments \
        '-c+[command]:code:' \
        '-i[interactive]' \
        '-l[login shell]' \
        '-s[read from stdin]' \
        '-r[restricted shell]' \
        '-T+[redirect to tty]:tty:' \
        '-o+[option]:option:(allexport bgnice braceexpand emacs gmacs ignoreeof markdirs monitor noclobber noexec noglob nolog notify nounset physical posix pipefail privileged restricted sh stdin trackall verbose vi xtrace)' \
        '+o+[unset option]:option:' \
        '-a[allexport]' \
        '-e[errexit]' \
        '-f[no glob]' \
        '-h[hashall]' \
        '-k[keywords]' \
        '-m[monitor]' \
        '-n[noexec]' \
        '-t[exit after one command]' \
        '-u[nounset]' \
        '-v[verbose]' \
        '-x[xtrace]' \
        '*:script:_files'
}

_oksh "$@"
