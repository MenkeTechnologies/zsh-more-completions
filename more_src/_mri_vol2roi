#compdef mri_vol2roi
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_vol2roi
# FreeSurfer: extract a region-of-interest average from a volume

local ret=1

_arguments -s -S \
  '--srcvol[input volume stem]:srcvolstem:_files' \
  '--srcreg[source registration file]:regfile:_files' \
  '--label[path to label file]:labelfile:_files' \
  '--labelreg[label registration file]:labelregfile:_files' \
  '--labeltal[use tal xfm for labelreg]' \
  '--talxfm[use talxfm instead of talairach.xfm]:xfmfile:_files' \
  '--labelfillthresh[voxel fill fraction threshold]:thresh' \
  '--mskvol[mask volume path]:maskstem:_files' \
  '--mskthresh[mask threshold (default 0.5)]:mskthresh' \
  '--msktail[mask tail]:tail:(abs pos neg)' \
  '--mskframe[0-based mask frame]:nthframe' \
  '--mskinvert[invert the mask]' \
  '--roiavgtxt[output text file for ROI average]:fname:_files' \
  '--roiavg[output bfloat stem for ROI average]:stem:_files' \
  '--finalmskvol[save final mask]:finalmaskstem:_files' \
  '--finalmskcrs[save col,row,slice as text]:fname:_files' \
  '*:argument:_files' && ret=0

return ret
