#compdef kjsembed kjscmd kjscmd5
# Documentation: https://linux.die.net/man/1/kjscmd
# Reference accessed: 2026-05-16
# Verified: kjscmd(1) and kjscmd5(1) manpages. NOTE: `kjsembed` is the
# library; the interpreter binary is `kjscmd` (KDE4) or `kjscmd5`
# (KF5). This completion accepts all three names via #compdef alias.
# Removed from prior file: bogus man.archlinux.org search URL.

# kjsembed/kjscmd: KJS embedded interpreter
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '(-e --exec)'{-e,--exec}'[execute script without GUI support]' \
  '(-i --interactive)'{-i,--interactive}'[start interactive interpreter]' \
  '(-n --no-kde)'{-n,--no-kde}'[start without KApplication support]' \
  '*:script:_files -g "*.(js|kjs)(-.)"' && ret=0
return ret
