#compdef kjsembed kjscmd kjscmd5
# Documentation: https://www.mankier.com/1/kjscmd
# Reference accessed: 2026-05-19
# Verified: upstream kjscmd(1)/kjscmd5(1) man pages at the URL above.
# kjsembed is the library; the interpreter binary is kjscmd (KDE4) or
# kjscmd5 (KF5). -n/--no-kde is documented for kjscmd (not kjscmd5).

# kjsembed/kjscmd: KJS embedded interpreter
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '(-e --exec)'{-e,--exec}'[execute script without GUI support]' \
  '(-i --interactive)'{-i,--interactive}'[start interactive interpreter]' \
  '(-n --no-kde)'{-n,--no-kde}'[start without KApplication support]' \
  '*:script:_files -g "*.(js|kjs)(-.)"' && ret=0
return ret
