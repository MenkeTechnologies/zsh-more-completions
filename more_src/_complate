#compdef complate
# Documentation: https://man.archlinux.org/search?q=complate
# Reference accessed: 2026-05-16

# https://github.com/replicadse/complate — Handlebars templating processor

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
