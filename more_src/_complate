#compdef complate
# Documentation: https://github.com/replicadse/complate
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# complate - general purpose text templating CLI (replicadse/complate).
# Upstream README documents a `render` subcommand but does not enumerate
# all flags; stub completion only.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'render:render a configured template'
      'help:show help for a subcommand'
    )
    _describe -t commands 'complate command' commands && ret=0
    ;;
  (args)
    _arguments '*:file:_files' && ret=0
    ;;
esac

return ret
