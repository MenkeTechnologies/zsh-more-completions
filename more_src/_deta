#compdef deta
# Documentation: https://man.archlinux.org/search?q=deta
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'new:create a new micro'
      'deploy:deploy a micro'
      'details:show micro details'
      'watch:watch for changes and deploy'
      'auth:manage authentication'
      'visor:manage visor'
      'cron:manage cron jobs'
      'run:run a micro'
      'update:update the CLI'
      'pull:pull latest deployed code'
      'clone:clone an existing micro'
      'version:show CLI version'
      'login:log in to Deta'
      'logout:log out of Deta'
      'open:open micro in browser'
      'release:create a release'
      'validate:validate configuration'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--name[micro name]:name' \
          '(--python --go)--node[create a Node.js micro]' \
          '(--node --go)--python[create a Python micro]' \
          '(--node --python)--go[create a Go micro]' \
          ':directory:_directories' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--name[micro name]:name' && ret=0
        ;;
      auth)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(enable disable create-api-key delete-api-key)' && ret=0
        ;;
      details|watch|visor|cron|run|pull|clone|open|release|validate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      login|logout|update|version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
