#compdef pyocd
# Documentation: https://man.archlinux.org/search?q=pyocd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'commander:interactive REPL command line tool'
  'cmd:alias for commander'
  'erase:erase target flash'
  'flash:flash file to target'
  'load:program file to flash or RAM'
  'gdbserver:start GDB remote server'
  'gdb:alias for gdbserver'
  'json:dump info as JSON'
  'list:list connected debug probes'
  'pack:manage CMSIS device packs'
  'reset:reset target'
  'rtt:RTT viewer'
  'server:start probe server'
  'help:show subcommand help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
  '-j+[parallel jobs]:n:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'pyocd subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (flash|load)
        _arguments \
          '(-e --erase)'{-e+,--erase=}'[erase mode]:mode:(auto chip sector)' \
          '(-a --base-address)'{-a+,--base-address=}'[base address]:addr:' \
          '--trust-crc[trust CRC]' \
          '--format=[file format]:fmt:(bin hex elf axf)' \
          '--skip=[skip bytes]:n:' \
          '-t+[target type]:target:' \
          '-u+[unique ID]:id:' \
          '-O+[option=value]:opt:' \
          '*:file:_files' && ret=0 ;;
      (erase)
        _arguments \
          '(-c --chip)'{-c,--chip}'[chip erase]' \
          '(-s --sector)'{-s,--sector}'[sector erase]' \
          '(-m --mass)'{-m,--mass}'[mass erase]' \
          '-t+[target]:target:' \
          '-u+[unique ID]:id:' && ret=0 ;;
      (gdbserver|gdb)
        _arguments \
          '(-p --port)'{-p+,--port=}'[gdb listen port]:port:' \
          '(-T --telnet-port)'{-T+,--telnet-port=}'[telnet console port]:port:' \
          '(-R --reset-on-connect)'{-R,--reset-on-connect}'[reset on connect]' \
          '(-S --no-step-into-interrupts)'{-S,--no-step-into-interrupts}'[disable interrupt step]' \
          '--persist[persist after disconnect]' \
          '-t+[target]:target:' \
          '-u+[unique ID]:id:' \
          '-O+[option=value]:opt:' && ret=0 ;;
      (list)
        _arguments \
          '(-p --probes)'{-p,--probes}'[list probes]' \
          '(-b --boards)'{-b,--boards}'[list supported boards]' \
          '(-t --targets)'{-t,--targets}'[list supported targets]' \
          '--name=[match by name]:name:' && ret=0 ;;
      (pack)
        _arguments \
          '(-c --clean)'{-c,--clean}'[clean cache]' \
          '(-u --update)'{-u,--update}'[update index]' \
          '(-s --show)'{-s,--show}'[show installed]' \
          '(-i --install)'{-i+,--install=}'[install pack]:pack:' \
          '(-f --find)'{-f+,--find=}'[find pack by part]:part:' && ret=0 ;;
      (reset)
        _arguments \
          '-m+[reset method]:method:(default hw sw sw_sysresetreq sw_vectreset)' \
          '-t+[target]:target:' \
          '-u+[unique ID]:id:' && ret=0 ;;
      (commander|cmd)
        _arguments \
          '(-c --command)'{-c+,--command=}'[run command then exit]:cmd:' \
          '(-N --no-init)'{-N,--no-init}'[skip target init]' \
          '-t+[target]:target:' \
          '-u+[unique ID]:id:' \
          '-O+[option=value]:opt:' && ret=0 ;;
    esac ;;
esac

return ret
