#compdef saucelabs sauce
# _saucelabs — Sauce Labs sauce CLI (Sauce Labs, JS); commander
# upstream: https://github.com/saucelabs/sauce-cypress-plugin

_saucelabs() {
    local -a sub=(
        'login:login to sauce labs'
        'logout:logout'
        'config:manage CLI config'
        'tunnel:manage sauce-connect tunnels'
        'job:manage jobs/tests'
        'storage:manage app storage'
        'usage:show usage stats'
        'team:manage teams'
        'user:manage users'
        'realdevice:manage real device pool'
        'asset:download job assets'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--username=+[Sauce Labs username]:str:_users' \
        '-u+[Sauce Labs username]:str:_users' \
        '--access-key=+[Sauce Labs access key]:str:' \
        '-k+[Sauce Labs access key]:str:' \
        '--region=+[region]:r:(us-west-1 eu-central-1 us-east-1 staging)' \
        '-r+[region]:r:(us-west-1 eu-central-1 us-east-1 staging)' \
        '--output=+[output format]:fmt:(table json yaml csv)' \
        '-o+[output format]:fmt:(table json yaml csv)' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sauce subcommand' sub ;;
        args)
            case $words[1] in
                tunnel) _arguments \
                    '1:cmd:(list start stop info)' \
                    '--name=+[tunnel name]:str:' \
                    '--region=+[region]:str:' ;;
                job) _arguments \
                    '1:cmd:(list get cancel retry delete results)' \
                    '--id=+[job id]:id:' \
                    '--status=+[status]:s:(passed failed errored queued in progress)' \
                    '--limit=+[limit]:n:' ;;
                storage) _arguments \
                    '1:cmd:(upload list get delete download describe)' \
                    '--file-id=+[file id]:id:' \
                    '--platform=+[platform]:p:(android ios)' \
                    '*:file:_files -g "*.(apk|ipa|app|zip)"' ;;
                realdevice) _arguments \
                    '1:cmd:(list status reserve release)' \
                    '--device-id=+[device id]:id:' ;;
                asset) _arguments \
                    '1:cmd:(download list)' \
                    '--job-id=+[job id]:id:' \
                    '--type=+[asset type]:t:(log video selenium screenshots)' \
                    '--output-dir=+[output dir]:dir:_files -/' ;;
                login) _arguments \
                    '--username=+[username]:str:_users' \
                    '--access-key=+[access key]:str:' ;;
                config) _arguments \
                    '1:cmd:(get set list reset)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_saucelabs "$@"
