#compdef cephcsi
# _cephcsi — Ceph CSI multi-mode driver (rbd / cephfs / nfs / nvmeof / liveness / controller)
# upstream: https://github.com/ceph/ceph-csi
# Flags from cmd/cephcsi.go on tip.

_cephcsi() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print cephcsi version information]' \
        '--type=[driver type]:type:(rbd cephfs nfs nvmeof liveness controller)' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--drivername=[name of the driver]:name:' \
        '--drivernamespace=[namespace in which driver is deployed]:ns:' \
        '--nodeid=[node id]:id:' \
        '--pluginpath=[plugin path]:dir:_files -/' \
        '--stagingpath=[staging path]:dir:_files -/' \
        '--clustername=[name of the cluster]:name:' \
        '--setmetadata=[set metadata on volumes]:bool:(true false)' \
        '--enable-fencing[enable fencing of nodes during non-graceful shutdowns]' \
        '--instanceid=[unique ID distinguishing this instance of Ceph-CSI]:id:' \
        '--pidlimit=[PID limit to configure through cgroups]:n:' \
        '--automaxprocs[set GOMAXPROCS from container CPU quota]' \
        '--controllerserver[start cephcsi controller server]' \
        '--nodeserver[start cephcsi node server]' \
        '--enable-read-affinity[enable read affinity]' \
        '--domainlabels=[csv of crush location labels]:csv:' \
        '--crush-location-labels=[csv of crush location labels]:csv:' \
        '--forcecephkernelclient[force the kernel client for cephfs mounts]' \
        '--kernelmountoptions=[mount options for kernel mounts]:opts:' \
        '--fusemountoptions=[mount options for ceph-fuse mounts]:opts:' \
        '--radosnamespacecephfs=[rados namespace for cephfs]:ns:' \
        '--metricsport=[liveness/profile metrics TCP port]:port:' \
        '--metricspath=[metrics path]:path:' \
        '--polltime=[poll interval]:duration:' \
        '--timeout=[probe timeout]:duration:' \
        '--logslowopinterval=[log slow op interval]:duration:' \
        '--rbdhardmaxclonedepth=[hard limit for RBD clone depth]:n:' \
        '--rbdsoftmaxclonedepth=[soft limit for RBD clone depth]:n:' \
        '--maxsnapshotsonimage=[max snapshots per RBD image]:n:' \
        '--minsnapshotsonimage=[min snapshots per RBD image]:n:' \
        '--skipforceflatten[skip image flattening if kernel maps rbd images]' \
        '--enableprofiling[enable go profiling]' \
        '--csi-addons-endpoint=[CSI-Addons endpoint]:uri:' \
        '--feature-gates=[csv of feature gates]:gates:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_cephcsi "$@"
