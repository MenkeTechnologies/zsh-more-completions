#compdef centipede
# _centipede — coverage-guided distributed fuzzing engine (google/fuzztest)
# upstream: https://github.com/google/fuzztest
# Flags from centipede/centipede_flags.inc (absl/flags).

_centipede() {
    _arguments \
        '--binary=[target binary]:file:_files' \
        '--workdir=[working directory]:dir:_files -/' \
        '--name=[experiment name]:name:' \
        '--test_name=[test name (for fuzztest binaries)]:name:' \
        '--num_runs=[number of fuzzing runs]:n:' \
        '--total_shards=[number of shards]:n:' \
        '--my_shard_index=[index of this shard]:n:' \
        '--first_shard_index=[first shard index]:n:' \
        '--j=[number of parallel jobs]:n:' \
        '--max_len=[maximum input length]:bytes:' \
        '--timeout=[timeout per input]:duration:' \
        '--timeout_per_input=[timeout per input]:duration:' \
        '--stop_after=[stop after duration]:duration:' \
        '--stop_at=[stop at absolute time]:time:' \
        '--mutate_batch_size=[mutate batch size]:n:' \
        '--ignore_timeout_reports[do not record timeouts as crashes]' \
        '--runner_cleanup_timeout=[runner cleanup timeout]:duration:' \
        '--persistent_mode[run target in persistent mode]' \
        '--corpus_weight_method=[corpus weight method]:method:(uniform inverse_size frequency)' \
        '--use_pc_features[use PC features]' \
        '--use_cmp_features[use compare features]' \
        '--use_auto_dictionary[enable auto-dictionary]' \
        '--use_dataflow_features[use dataflow features]' \
        '--use_pcpair_features[use PC-pair features]' \
        '--require_pc_table[require PC table in binary]' \
        '--require_seeds[require seeds in workdir]' \
        '--print_runner_log[print runner log]' \
        '--runner_dl_path_suffix=[runner DL path suffix]:suffix:' \
        '--exit_on_crash[exit immediately on crash]' \
        '--max_num_crash_reports=[max crash reports]:n:' \
        '--num_crash_reports=[max crash reports (alias)]:n:' \
        '--save_binary_info[save binary info]' \
        '--first_corpus_dir_output_only[only write to first corpus dir]' \
        '--load_shards_only[load shards then exit]' \
        '--list_crash_ids_file=[file to write crash ids]:file:_files' \
        '--crash_id=[replay this crash id]:id:' \
        '--replay_crash[replay a single crash]' \
        '--minimize_crash=[file to minimize]:file:_files' \
        '--minimize_crash_file_path=[file to minimize]:file:_files' \
        '*:input file:_files'
}

_centipede "$@"
