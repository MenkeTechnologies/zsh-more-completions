#compdef go-doc
# _go-doc — go doc wrapper completion; show documentation for packages/symbols
# upstream: https://pkg.go.dev/cmd/go

_go-doc() {
    _arguments \
        '-all[show all docs for package]' \
        '-c[case-sensitive]' \
        '-cmd[treat commands like packages]' \
        '-short[short summary]' \
        '-src[show source]' \
        '-u[show unexported symbols]' \
        '*:pkg or symbol:'
}

_go-doc "$@"
