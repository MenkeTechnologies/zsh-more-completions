#compdef foliate com.github.johnfactotum.Foliate
# Documentation: https://man.archlinux.org/search?q=foliate
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--gapplication-service[run as service]' \
  '--new-window[open new window]' \
  '*:ebook file:_files -g "*.epub *.mobi *.azw *.azw3 *.fb2 *.cbz *.cbr *.cbt *.cb7 *.txt *.htm *.html *.xhtml *.pdf"' && ret=0

return ret
