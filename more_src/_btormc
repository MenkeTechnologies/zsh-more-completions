#compdef btormc
# Documentation: https://github.com/Boolector/boolector
# btormc bounded model checker for BTOR2

local ret=1

_arguments -s -S \
  '--btor-stats[print boolector stats at each k]' \
  '(--bound-min --kmin)'{--bound-min,--kmin}'+[min bound for bmc]:kmin' \
  '(--bound-max --kmax)'{--bound-max,--kmax}'+[max bound for bmc, inclusive]:kmax' \
  '(--verbosity -v)'{--verbosity,-v}'+[set verbosity]:level' \
  '--stop-first[stop at first reached property]' \
  '--trace-gen=[enable/disable trace generation]:flag:(0 1)' \
  '--trace-gen-full[always print states in trace]' \
  '--kind[enable k-induction]' \
  '--simple-path[add simple path constraints]' \
  '*:btor2 file:_files' && ret=0

return ret
