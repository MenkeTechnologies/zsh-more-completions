#compdef neonctl

# Zsh completion for neonctl - Neon serverless Postgres CLI

local curcontext="$curcontext" state line ret=1

local -a neonctl_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-v --version)'{-v,--version}'[show version]'
  '--api-key=[Neon API key]:key: '
  '--project-id=[project ID]:project ID: '
  '--config-dir=[path to config directory]:directory:_directories'
  '(-o --output)'{-o,--output}'[output format]:format:(json yaml table)'
  '--color=[colorize output]:when:(auto always never)'
  '--analytics[enable analytics]'
  '--no-analytics[disable analytics]'
)

_arguments -C \
  $neonctl_global_flags \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'auth:manage authentication'
      'me:show current user info'
      'projects:manage projects'
      'branches:manage branches'
      'databases:manage databases'
      'roles:manage roles'
      'operations:manage operations'
      'connection-string:get connection string'
      'cs:get connection string (alias)'
      'set-context:set project context'
      'completion:generate shell completion'
    )
    _describe -t commands 'neonctl command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (projects)
        _arguments -C \
          $neonctl_global_flags \
          '1:subcommand:->subcmd' \
          '*::project arg:' && ret=0
        case $state in
          (subcmd)
            local -a subcmds=(
              'list:list projects'
              'create:create a project'
              'get:get project details'
              'update:update a project'
              'delete:delete a project'
            )
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (branches)
        _arguments -C \
          $neonctl_global_flags \
          '1:subcommand:->subcmd' \
          '*::branch arg:' && ret=0
        case $state in
          (subcmd)
            local -a subcmds=(
              'list:list branches'
              'create:create a branch'
              'get:get branch details'
              'delete:delete a branch'
              'rename:rename a branch'
              'set-default:set default branch'
              'set-primary:set primary branch'
              'add-compute:add compute to branch'
              'reset:reset a branch'
            )
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (databases)
        _arguments -C \
          $neonctl_global_flags \
          '1:subcommand:->subcmd' \
          '*::database arg:' && ret=0
        case $state in
          (subcmd)
            local -a subcmds=(
              'list:list databases'
              'create:create a database'
              'delete:delete a database'
            )
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (roles)
        _arguments -C \
          $neonctl_global_flags \
          '1:subcommand:->subcmd' \
          '*::role arg:' && ret=0
        case $state in
          (subcmd)
            local -a subcmds=(
              'list:list roles'
              'create:create a role'
              'delete:delete a role'
            )
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (operations)
        _arguments -C \
          $neonctl_global_flags \
          '1:subcommand:->subcmd' \
          '*::operation arg:' && ret=0
        case $state in
          (subcmd)
            local -a subcmds=(
              'list:list operations'
            )
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (connection-string|cs)
        _arguments \
          $neonctl_global_flags \
          '--project-id=[project ID]:project ID: ' \
          '--branch=[branch name or ID]:branch: ' \
          '--database-name=[database name]:name: ' \
          '--role-name=[role name]:name: ' \
          '--pooled[use pooled connection]' \
          '--prisma[format for Prisma]' \
          '--extended[show extended info]' && ret=0
        ;;
      (auth)
        local -a subcmds=(
          'login:log in to Neon'
          'logout:log out from Neon'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (set-context)
        _arguments \
          $neonctl_global_flags \
          '--project-id=[project ID]:project ID: ' && ret=0
        ;;
      (completion)
        _arguments \
          '1:shell:(bash zsh fish)' && ret=0
        ;;
      (me)
        _arguments $neonctl_global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
