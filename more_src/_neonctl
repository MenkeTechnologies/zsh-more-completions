#compdef neonctl

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--api-key+[Neon API key]:key:' \
  '--project-id+[project ID]:project ID:' \
  '--config-dir+[path to config directory]:directory:_files -/' \
  '--context-file+[path to context file]:file:_files' \
  '(-o --output)'{-o,--output}'[output format]:format:(json yaml table)' \
  '--color[colorize output]:when:(auto always never)' \
  '--no-color[disable color output]' \
  '--analytics[enable or disable analytics]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'auth:manage authentication'
      'projects:manage projects'
      'branches:manage branches'
      'databases:manage databases'
      'roles:manage roles'
      'operations:manage operations'
      'endpoints:manage compute endpoints'
      'connection-string:get connection string'
      'cs:get connection string (alias)'
      'set-context:set project context'
      'completion:generate shell completion'
      'me:show current user info'
      'help:show help for a command'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (projects)
        local -a subcmds=(
          'list:list projects'
          'create:create a project'
          'get:get project details'
          'update:update a project'
          'delete:delete a project'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (branches)
        local -a subcmds=(
          'list:list branches'
          'create:create a branch'
          'get:get branch details'
          'rename:rename a branch'
          'set-default:set default branch'
          'add-compute:add compute to branch'
          'delete:delete a branch'
          'reset:reset a branch'
          'restore:restore a branch'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (databases)
        local -a subcmds=(
          'list:list databases'
          'create:create a database'
          'delete:delete a database'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (roles)
        local -a subcmds=(
          'list:list roles'
          'create:create a role'
          'delete:delete a role'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (endpoints)
        local -a subcmds=(
          'list:list endpoints'
          'create:create an endpoint'
          'get:get endpoint details'
          'update:update an endpoint'
          'delete:delete an endpoint'
          'start:start an endpoint'
          'suspend:suspend an endpoint'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (auth)
        local -a subcmds=(
          'login:log in to Neon'
          'logout:log out from Neon'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (connection-string|cs)
        _arguments \
          '--branch-id+[branch ID]:branch ID:' \
          '--endpoint-id+[endpoint ID]:endpoint ID:' \
          '--database-name+[database name]:name:' \
          '--role-name+[role name]:name:' \
          '--pooled[use pooled connection]' \
          '--prisma[format for Prisma]' \
          '--extended[show extended info]' && ret=0
        ;;
    esac
    ;;
esac

return ret
