#compdef readpb
# Documentation: https://github.com/bayesiancook/pbmpi/blob/master/sources/RASCATGTRSBDPGammaPhyloProcess.cpp
# PhyloBayes readpb: post-analysis of a saved chain. Flags mirror ReadPB() argv parsing.

local ret=1

_arguments -s -S \
  '-x[burn-in, then read every and upto]:burnin:' \
  '-ppred[posterior predictive simulations]' \
  '-allppred[all posterior predictive tests]' \
  '-ppredprofile[posterior predictive profile test]' \
  '-ppredrate[posterior predictive rate test]' \
  '-ppredroot[posterior predictive root test]' \
  '-ss[site-specific stationary profiles]' \
  '-cv[cross-validation log likelihood]:testdata:_files' \
  '-jointcv[joint cross-validation]' \
  '-sitecv[site-wise cross-validation]' \
  '-sitelogl[site log likelihoods]' \
  '-sitecomp[site composition]' \
  '-siteprofilesuffstat[site profile sufficient statistics]' \
  '-siteconvprob[site convergence probabilities]' \
  '-map[maximum a posteriori substitution mapping]' \
  '-anc[ancestral state reconstruction]' \
  '-comp[compositional homogeneity test]' \
  '-div[diversity statistics]' \
  '-cutoff[posterior probability cutoff]:cutoff:' \
  '-posthyper[posterior hyperparameters]' \
  '-savetrees[save sampled trees]' \
  '-rr[relative exchange rates]' \
  '-r[reroot]' \
  '-v[verbose output]' \
  '-extract[extract subsample of points]' \
  '*:chain name:' && ret=0

return ret
