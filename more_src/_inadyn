#compdef inadyn

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-1 --once)'{-1,--once}'[run once and exit]' \
  '(-e --exec)'{-e,--exec=}'[command on IP change]:cmd:' \
  '(-f --config)'{-f,--config=}'[config file]:file:_files' \
  '(-F --foreground)'{-F,--foreground}'[run in foreground]' \
  '(-i --iface)'{-i,--iface=}'[interface to monitor]:iface:' \
  '(-j --jobs)'{-j,--jobs=}'[concurrent jobs]:n:' \
  '(-l --loglevel)'{-l,--loglevel=}'[log level]:level:(none err warn notice info debug)' \
  '(-L --list)'{-L,--list}'[list supported providers]' \
  '(-n --no-pidfile)'{-n,--no-pidfile}'[disable PID file]' \
  '(-p --pidfile)'{-p,--pidfile=}'[PID file]:file:_files' \
  '(-P --check-config)'{-P,--check-config}'[validate config and exit]' \
  '(-s --syslog)'{-s,--syslog}'[log to syslog]' \
  '(-t --startup-delay)'{-t,--startup-delay=}'[startup delay seconds]:secs:' \
  '(-u --user)'{-u,--user=}'[drop privileges to user[:group]]:user:_users' \
  '--force[force update bypassing cache]' \
  '--cache-dir=[cache directory]:dir:_files -/'
