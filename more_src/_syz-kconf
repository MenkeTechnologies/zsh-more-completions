#compdef syz-kconf
# _syz-kconf — generate syzkaller kernel config based on shared rules (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-kconf/kconf.go (flag).

_syz-kconf() {
    _arguments \
        '-sourcedir=[kernel sources directory]:dir:_files -/' \
        '-config=[kconf config file]:file:_files' \
        '-instance=[instance name to generate]:name:'
}

_syz-kconf "$@"
