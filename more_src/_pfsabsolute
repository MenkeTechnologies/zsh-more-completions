#compdef pfsabsolute
# Documentation: http://pfstools.sourceforge.net/man1/pfsabsolute.1.html
# pfstools: rescale relative luminance to absolute luminance level

local ret=1

_arguments -s -S \
  '--verbose[enable verbose output]' \
  '--help[show help]' \
  '1:dest Y (target luminance level)' \
  '2:src Y (source luminance, default 1)' && ret=0

return ret
