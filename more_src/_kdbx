autoload -U is-at-least

_kdbx() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_kdbx_commands" \
"*::: :->kdbx" \
&& ret=0
    case $state in
    (kdbx)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kdbx-command-$line[1]:"
        case $line[1] in
            (pwd)
_arguments "${_arguments_options[@]}" : \
'-t+[Timeout in seconds before clearing the clipboard. 0 means no clean-up]:TIMEOUT:_default' \
'--timeout=[Timeout in seconds before clearing the clipboard. 0 means no clean-up]:TIMEOUT:_default' \
'-d+[KDBX file path]:DATABASE:_files' \
'--database=[KDBX file path]:DATABASE:_files' \
'-k+[Path to the key file unlocking the database]:KEY_FILE:_files' \
'--key-file=[Path to the key file unlocking the database]:KEY_FILE:_files' \
'-G[Show entries without group(s)]' \
'--no-group[Show entries without group(s)]' \
'-n[Do not ask any interactive question]' \
'--no-interaction[Do not ask any interactive question]' \
'-v[Preview entry during picking]' \
'--preview[Preview entry during picking]' \
'-f[Use all available screen for picker]' \
'--full-screen[Use all available screen for picker]' \
'-p[Store password for the database in the OS'\''s keyring]' \
'--use-keyring[Store password for the database in the OS'\''s keyring]' \
'-P[Remove database'\''s password from OS'\''s keyring and exit]' \
'--remove-key[Remove database'\''s password from OS'\''s keyring and exit]' \
'-h[Print help]' \
'--help[Print help]' \
'::entry:_default' \
&& ret=0
;;
(totp)
_arguments "${_arguments_options[@]}" : \
'-d+[KDBX file path]:DATABASE:_files' \
'--database=[KDBX file path]:DATABASE:_files' \
'-k+[Path to the key file unlocking the database]:KEY_FILE:_files' \
'--key-file=[Path to the key file unlocking the database]:KEY_FILE:_files' \
'-G[Show entries without group(s)]' \
'--no-group[Show entries without group(s)]' \
'-n[Do not ask any interactive question]' \
'--no-interaction[Do not ask any interactive question]' \
'-v[Preview entry during picking]' \
'--preview[Preview entry during picking]' \
'--raw[Show the secret instead of code]' \
'-f[Use all available screen for picker]' \
'--full-screen[Use all available screen for picker]' \
'-p[Store password for the database in the OS'\''s keyring]' \
'--use-keyring[Store password for the database in the OS'\''s keyring]' \
'-P[Remove database'\''s password from OS'\''s keyring and exit]' \
'--remove-key[Remove database'\''s password from OS'\''s keyring and exit]' \
'-h[Print help]' \
'--help[Print help]' \
'::entry:_default' \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
'-d+[KDBX file path]:DATABASE:_files' \
'--database=[KDBX file path]:DATABASE:_files' \
'-k+[Path to the key file unlocking the database]:KEY_FILE:_files' \
'--key-file=[Path to the key file unlocking the database]:KEY_FILE:_files' \
'-G[Show entries without group(s)]' \
'--no-group[Show entries without group(s)]' \
'-n[Do not ask any interactive question]' \
'--no-interaction[Do not ask any interactive question]' \
'-v[Preview entry during picking]' \
'--preview[Preview entry during picking]' \
'-f[Use all available screen for picker]' \
'--full-screen[Use all available screen for picker]' \
'-p[Store password for the database in the OS'\''s keyring]' \
'--use-keyring[Store password for the database in the OS'\''s keyring]' \
'-P[Remove database'\''s password from OS'\''s keyring and exit]' \
'--remove-key[Remove database'\''s password from OS'\''s keyring and exit]' \
'--show-sensitive[Show sensitive fields]' \
'-h[Print help]' \
'--help[Print help]' \
'::entry:_default' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'-d+[KDBX file path]:DATABASE:_files' \
'--database=[KDBX file path]:DATABASE:_files' \
'-k+[Path to the key file unlocking the database]:KEY_FILE:_files' \
'--key-file=[Path to the key file unlocking the database]:KEY_FILE:_files' \
'-p[Store password for the database in the OS'\''s keyring]' \
'--use-keyring[Store password for the database in the OS'\''s keyring]' \
'-P[Remove database'\''s password from OS'\''s keyring and exit]' \
'--remove-key[Remove database'\''s password from OS'\''s keyring and exit]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'-d+[KDBX file path]:DATABASE:_files' \
'--database=[KDBX file path]:DATABASE:_files' \
'-k+[Path to the key file unlocking the database]:KEY_FILE:_files' \
'--key-file=[Path to the key file unlocking the database]:KEY_FILE:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-d+[KDBX file path]:DATABASE:_files' \
'--database=[KDBX file path]:DATABASE:_files' \
'-k+[Path to the key file unlocking the database]:KEY_FILE:_files' \
'--key-file=[Path to the key file unlocking the database]:KEY_FILE:_files' \
'-G[Show entries without group(s)]' \
'--no-group[Show entries without group(s)]' \
'-p[Store password for the database in the OS'\''s keyring]' \
'--use-keyring[Store password for the database in the OS'\''s keyring]' \
'-P[Remove database'\''s password from OS'\''s keyring and exit]' \
'--remove-key[Remove database'\''s password from OS'\''s keyring and exit]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-s+[]:SHELL:(bash elvish fish powershell zsh)' \
'--shell=[]:SHELL:(bash elvish fish powershell zsh)' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_kdbx__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kdbx-help-command-$line[1]:"
        case $line[1] in
            (pwd)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(totp)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_kdbx_commands] )) ||
_kdbx_commands() {
    local commands; commands=(
'pwd:Copy password and clear clipboard after specified amount of time' \
'totp:Copy totp' \
'show:Display entry'\''s info' \
'add:Add new entry' \
'init:Init new database' \
'list:List all entries' \
'completion:Outputs the completion file for given shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'kdbx commands' commands "$@"
}
