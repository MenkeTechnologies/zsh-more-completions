#compdef totalseg_combine_masks
# Documentation: https://github.com/wasserth/TotalSegmentator
# Combine TotalSegmentator output masks into one image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[input directory of masks]:input:_files -/' \
  '-o[output file]:output:_files' \
  '-m[mask type to combine]:mask:' \
  '*:arg:_files' && ret=0

return ret
