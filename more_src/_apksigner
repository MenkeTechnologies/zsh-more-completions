#compdef apksigner

# Zsh completion for apksigner (Android APK signing tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'sign:sign an APK'
      'verify:verify APK signatures'
      'rotate:rotate signing certificate'
      'lineage:manage signing certificate lineage'
      'version:show version'
      'help:show help'
    )
    _describe -t commands 'apksigner command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (sign)
        _arguments \
          '--ks[keystore file]:keystore:_files -g "*.{jks,keystore,p12,pfx}"' \
          '--ks-key-alias[key alias]:alias' \
          '--ks-pass[keystore password]:password spec' \
          '--key-pass[key password]:password spec' \
          '--ks-type[keystore type]:type:(jks pkcs12 bks)' \
          '--ks-provider-name[keystore provider name]:provider' \
          '--key[private key file]:key:_files -g "*.{pem,pk8,der}"' \
          '--cert[certificate file]:cert:_files -g "*.{pem,der,x509}"' \
          '--v1-signing-enabled[enable v1 signing]:enabled:(true false)' \
          '--v2-signing-enabled[enable v2 signing]:enabled:(true false)' \
          '--v3-signing-enabled[enable v3 signing]:enabled:(true false)' \
          '--v4-signing-enabled[enable v4 signing]:enabled:(true false)' \
          '--min-sdk-version[minimum SDK version]:version' \
          '--max-sdk-version[maximum SDK version]:version' \
          '--out[output file]:file:_files -g "*.apk"' \
          '--in[input file]:file:_files -g "*.apk"' \
          '*:APK file:_files -g "*.apk"' && ret=0
        ;;
      (verify)
        _arguments \
          '--min-sdk-version[minimum SDK version]:version' \
          '--max-sdk-version[maximum SDK version]:version' \
          '--print-certs[print certificate info]' \
          '-v[verbose output]' \
          '-Werr[treat warnings as errors]' \
          '--in[input file]:file:_files -g "*.apk"' \
          '*:APK file:_files -g "*.apk"' && ret=0
        ;;
      (rotate)
        _arguments \
          '--out[output lineage file]:file:_files' \
          '--old-signer-ks[old keystore]:keystore:_files' \
          '--old-signer-key-alias[old key alias]:alias' \
          '--old-signer-ks-pass[old keystore password]:password' \
          '--new-signer-ks[new keystore]:keystore:_files' \
          '--new-signer-key-alias[new key alias]:alias' \
          '--new-signer-ks-pass[new keystore password]:password' && ret=0
        ;;
    esac
    ;;
esac

return ret
