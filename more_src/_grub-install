#compdef grub-install grub2-install
# _grub-install — GRUB grub-install (install GRUB to a disk's boot sector / EFI partition; --target picks platform (i386-pc/x86_64-efi/...), --efi-directory points at ESP, --boot-directory boot dir, --bootloader-id efi entry id, --removable, --force, --recheck, --no-floppy)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-install.c on tip.

_grub-install() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--compress=*[compression]:method:(no xz gz lzo)' \
        '--target=*[target platform]:platform:(arm-coreboot arm-efi arm-uboot arm64-efi i386-coreboot i386-efi i386-ieee1275 i386-multiboot i386-pc i386-qemu i386-xen i386-xen_pvh ia64-efi mips-arc mips-qemu_mips mipsel-arc mipsel-fuloong mipsel-loongson mipsel-qemu_mips mipsel-yeeloong powerpc-ieee1275 riscv32-efi riscv64-efi sparc64-ieee1275 x86_64-efi x86_64-xen)' \
        '--directory=*[GRUB binary directory]:dir:_files -/' \
        '--locale-directory=*[locale dir]:dir:_files -/' \
        '--themes-directory=*[themes dir]:dir:_files -/' \
        '--fonts=*[fonts list]:fonts:' \
        '--install-modules=*[modules to install]:modules:' \
        '--modules=*[preloaded modules]:modules:' \
        '--themes=*[themes list]:themes:' \
        '--locales=*[locale list]:locales:' \
        '--pubkey=*[GPG pubkey file]:file:_files' \
        '--no-rs-codes[no Reed-Solomon codes]' \
        '--boot-directory=*[/boot directory]:dir:_files -/' \
        '--grub-setup=*[grub-setup binary]:file:_files' \
        '--grub-mkimage=*[grub-mkimage binary]:file:_files' \
        '--grub-mkrelpath=*[grub-mkrelpath binary]:file:_files' \
        '--grub-probe=*[grub-probe binary]:file:_files' \
        '--allow-floppy[treat as floppy]' \
        '--recheck[probe again instead of caching]' \
        '--force[install on inappropriate device]' \
        '--force-file-id[force file ID]' \
        '--disk-module=*[disk module]:module:(biosdisk ata native)' \
        '--no-nvram[do not update NVRAM (efi)]' \
        '--removable[install for removable media (efi)]' \
        '--bootloader-id=*[EFI bootloader name]:name:' \
        '--efi-directory=*[ESP mountpoint]:dir:_files -/' \
        '--debug-image=*[image to debug]:img:' \
        '*:device:_files -g "/dev/*"'
}

_grub-install "$@"
