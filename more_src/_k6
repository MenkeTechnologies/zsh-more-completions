#compdef k6
# Documentation: https://github.com/grafana/k6/blob/master/internal/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for k6 - a modern load testing tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'archive:create an archive'
  'cloud:run a test on Grafana Cloud k6'
  'deps:list dependencies of a test script'
  'inspect:inspect a script or archive'
  'new:create and initialize a new k6 script'
  'run:start a test'
  'stats:show test metrics'
  'version:show application version'
  'completion:generate shell autocompletion script'
  'help:help about any command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --address)'{-a,--address}'=[address for the REST API server]:address:' \
  '(-q --quiet)'{-q,--quiet}'[disable progress updates]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '(-c --config)'{-c,--config}'=[JSON config file]:file:_files' \
  '--log-format=[log output format]:format:' \
  '--log-output=[change the output for k6 logs]:output:' \
  '*--secret-source=[setup a secret source]:source:' \
  '--no-color[disable colored output]' \
  '1:command:->command' \
  '*:file:_files' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
esac

return ret
