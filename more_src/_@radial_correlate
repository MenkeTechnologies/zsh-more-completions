#compdef @radial_correlate
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@radial_correlate.html
# Check datasets for correlation artifact

local ret=1

_arguments -s -S \
  '-help[display help information]' \
  '-hist[show modification history]' \
  '-do_clean[remove non-correlation files at completion]:yn:(yes no)' \
  '-do_clust[perform clustering analysis]:yn:(yes no)' \
  '-do_corr[generate correlation volumes]:yn:(yes no)' \
  '-polort[polynomial degree for detrending (default 2)]:polort' \
  '-rdir[output directory for results]:dir:_files -/' \
  '-use_3dmerge[use 3dmerge instead of 3dLocalstat]:yn:(yes no)' \
  '-ver[display version number]' \
  '-verb[enable verbose output]' \
  '-cthresh[correlation threshold value (default 0.9)]:thresh' \
  '-corr_mask[mask time series before correlation blurring]:yn:(yes no)' \
  '-mask[brain mask dataset]:dset:_files' \
  '-frac_limit[min mask fraction for cluster survival (default 0.02)]:limit' \
  '-merge_frad[radius fraction for blurring kernel (default 0.0)]:frad' \
  '-nfirst[initial TRs to exclude (default 3)]:nfirst' \
  '-min_thr[min percentile threshold (default 0.45)]:thr' \
  '-percentile[percentile for correlation threshold (default 80)]:perc' \
  '-sphere_rad[spherical correlation radius in mm (default 20)]:rad' \
  '*:dataset:_files' && ret=0

return ret
