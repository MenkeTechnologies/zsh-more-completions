#compdef pyspur
# Documentation: https://github.com/pyspur-dev/pyspur
# Reference accessed: 2026-05-23
# Verified: pyspur/cli/main.py Typer commands (init, serve, version).

# Zsh completion for pyspur - PySpur visual AI agent workflow CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'pyspur command' \
      'version[show version]' \
      'init[initialize PySpur project]' \
      'serve[start PySpur server]' && ret=0
    ;;
esac

return ret
