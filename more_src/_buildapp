#compdef buildapp
# Documentation: https://www.xach.com/lisp/buildapp/
# buildapp - build executable images from SBCL and Common Lisp code

local ret=1

_arguments -s \
  '--help[show usage message]' \
  '--output=[name of the executable to create]:output file:_files' \
  '--entry=[function used as the executable toplevel function]:name:' \
  '--dispatched-entry=[entry function depending on the start file name]:dname:' \
  '*--load=[load FILE in the CL-USER package]:file:_files' \
  '*--load-system=[load an ASDF system identified by NAME]:name:' \
  '*--require=[use CL:REQUIRE to load NAME]:name:' \
  '*--eval=[evaluate CODE with CL:EVAL]:code:' \
  '*--load-path=[search DIRECTORY for files to load]:directory:_files -/' \
  '*--asdf-path=[search DIRECTORY for ASDF system files]:directory:_files -/' \
  '*--asdf-tree=[search DIRECTORY and subdirectories for ASDF system files]:directory:_files -/' \
  '*--manifest-file=[read ASDF system file pathnames from FILE]:file:_files' \
  '--compress-core[compress the core or executable]' \
  '--core-only[make a core file only, not an executable]' \
  '--dynamic-space-size=[pass --dynamic-space-size to SBCL when building]:megabytes:' \
  '--logfile=[log compilation and load output to FILE]:file:_files' \
  '--sbcl=[use PATH-TO-SBCL instead of the sbcl in PATH]:sbcl:_files' && ret=0

return ret
