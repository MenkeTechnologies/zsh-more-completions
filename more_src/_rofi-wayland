#compdef rofi-wayland

# Zsh completion for rofi-wayland - application launcher for Wayland

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)'{-v,-version}'[show version]' \
  '-show[show a specific mode]:mode:(run drun window ssh filebrowser keys combi)' \
  '-modi[enabled modes]:modes' \
  '-dmenu[start in dmenu mode]' \
  '-dump[dump settings]' \
  '-dump-config[dump current configuration]' \
  '-dump-theme[dump current theme]' \
  '-quiet[quiet mode]' \
  '-no-lazy-grab[disable lazy grab]' \
  '-no-config[disable config file loading]' \
  '-config[config file]:config file:_files' \
  '-theme[theme file]:theme:_files' \
  '-matching[matching algorithm]:method:(normal regex glob fuzzy prefix)' \
  '-tokenize[tokenize input]' \
  '-drun-categories[drun categories]:categories' \
  '-drun-match-fields[drun match fields]:fields' \
  '-drun-display-format[drun display format]:format' \
  '-drun-url-launcher[drun URL launcher]:launcher' \
  '-window-format[window format]:format' \
  '-window-command[window command]:command' \
  '-window-match-fields[window match fields]:fields' \
  '-terminal[terminal emulator]:terminal' \
  '-ssh-client[SSH client]:client' \
  '-ssh-command[SSH command]:command' \
  '-parse-hosts[parse /etc/hosts]' \
  '-parse-known-hosts[parse known_hosts]' \
  '-run-command[run command]:command' \
  '-run-list-command[run list command]:command' \
  '-run-shell-command[run shell command]:command' \
  '-display-drun[display name for drun mode]:name' \
  '-display-run[display name for run mode]:name' \
  '-display-ssh[display name for ssh mode]:name' \
  '-display-window[display name for window mode]:name' \
  '-display-keys[display name for keys mode]:name' \
  '-display-filebrowser[display name for filebrowser mode]:name' \
  '-display-combi[display name for combi mode]:name' \
  '-sidebar-mode[enable sidebar mode]' \
  '-hover-select[select entry on hover]' \
  '-eh[element height]:height' \
  '-auto-select[auto-select if only one match]' \
  '-m[monitor to display on]:monitor' \
  '-filter[set initial filter]:filter' \
  '-cache-dir[cache directory]:directory:_directories' \
  '-scroll-method[scroll method]:method:(0 1)' \
  '-normalize-match[normalize match strings]' \
  '-steal-focus[steal focus]' \
  '-icon-theme[icon theme]:theme' \
  '-application-fallback-icon[fallback icon]:icon' \
  '-font[font]:font' \
  '-fixed-num-lines[fixed number of lines]' \
  '-threads[number of threads]:threads' \
  '-click-to-exit[click outside to exit]' \
  '-no-click-to-exit[disable click outside to exit]' \
  '-kb-accept-entry[keybinding for accept entry]:keybinding' \
  '-kb-row-up[keybinding for row up]:keybinding' \
  '-kb-row-down[keybinding for row down]:keybinding'
