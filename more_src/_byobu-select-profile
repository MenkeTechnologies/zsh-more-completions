#compdef byobu-select-profile
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/byobu-select-profile.1.html
# byobu: select or generate a byobu color profile

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-l --list)'{-l,--list}'[list available profiles]' \
  '(-b --background)'{-b,--background}'[set the background color]:color:' \
  '(-f --foreground)'{-f,--foreground}'[set the foreground color]:color:' \
  '(-h --hostname)'{-h,--hostname}'[set colors based on a hash of the hostname]' \
  '(-i --ip)'{-i,--ip}'[set colors based on a hash of the ip]' \
  '(-r --random)'{-r,--random}'[set colors randomly]' && ret=0

return ret
