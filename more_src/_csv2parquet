#compdef csv2parquet

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --schema-file)'{-s+,--schema-file=}'[Avro/Parquet schema file]:file:_files -g "*.{avsc,json,parquet,schema}"' \
  '(-c --compression)'{-c+,--compression=}'[parquet compression]:codec:(uncompressed snappy gzip lz4 zstd brotli lzo)' \
  '(-d --delimiter)'{-d+,--delimiter=}'[CSV delimiter]:char:' \
  '(-n --no-header)'{-n,--no-header}'[CSV has no header row]' \
  '(-D --double-quote)'{-D,--double-quote}'[double quote escaping]' \
  '(-r --record-batch-size)'{-r+,--record-batch-size=}'[record batch size]:n:' \
  '(-m --max-read-records)'{-m+,--max-read-records=}'[max records to read for inference]:n:' \
  '--writer-version=[parquet writer version]:version:(1.0 2.0)' \
  '*:csv_file:_files -g "*.csv"' && ret=0

return ret
