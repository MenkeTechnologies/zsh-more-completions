#compdef csv2parquet
# Documentation: https://github.com/domoritz/csv2parquet
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (Rust Arrow-based csv2parquet).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --schema-file)'{-s+,--schema-file=}'[Arrow schema file in JSON format]:file:_files -g "*.{json,avsc,schema}"' \
  '(-c --compression)'{-c+,--compression=}'[parquet compression codec]:codec:(uncompressed snappy gzip lzo brotli lz4 zstd)' \
  '(-d --delimiter)'{-d+,--delimiter=}'[CSV column delimiter as byte char]:char:' \
  '--header=[CSV has headers]:bool:(true false)' \
  '(-e --encoding)'{-e+,--encoding=}'[column encoding]:encoding:' \
  '--max-read-records=[records to infer schema from]:n:' \
  '--write-batch-size=[write batch size]:n:' \
  '--max-row-group-size=[max row group size]:n:' \
  '(-p --print-schema)'{-p,--print-schema}'[print schema to stderr]' \
  '(-n --dry)'{-n,--dry}'[only print schema]' \
  '*:csv_file:_files -g "*.csv"' && ret=0

return ret
