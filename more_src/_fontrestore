#compdef fontrestore

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'sync:restore default fonts'
  'install:install missing default fonts'
  'check:check for missing default fonts'
)

_arguments -C \
  '1: :->subcommand' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'fontrestore subcommand' subcommands && ret=0
    ;;
esac

return ret
