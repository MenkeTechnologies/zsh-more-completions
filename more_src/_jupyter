#compdef jupyter
# Documentation: jupyter docs.jupyter.org
# Source: Jupyter — top-level launcher dispatching to jupyter-<name> subcommands.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_jupyter_subcmds() {
    local -a subs
    subs=( ${(@f)"$(jupyter --help 2>/dev/null | awk '/^[[:space:]]+[a-z][a-z0-9_-]+[[:space:]]+/ {print $1}')"} )
    if (( ${#subs} == 0 )); then
        subs=(
            'console:start a Jupyter terminal console'
            'kernel:start an IPython kernel'
            'kernelspec:manage kernelspecs'
            'lab:start JupyterLab server'
            'labextension:manage JupyterLab extensions'
            'migrate:migrate config from IPython/Jupyter'
            'nbclassic:start the Jupyter classic notebook'
            'nbconvert:convert notebooks between formats'
            'nbextension:manage Jupyter notebook extensions'
            'notebook:start a Jupyter notebook server'
            'qtconsole:start a Jupyter Qt console'
            'run:run a Jupyter notebook as a script'
            'server:start a Jupyter server'
            'serverextension:manage server extensions'
            'troubleshoot:print system info for bug reports'
            'trust:sign a notebook with user trust'
        )
    fi
    _describe -t jupyter-subcmds 'jupyter subcommand' subs
}

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--help-all[show all help]' \
    '(- *)--version[show version]' \
    '(- *)--paths[print Jupyter directories and search paths]' \
    '(- *)--config-dir[print config directory]' \
    '(- *)--data-dir[print data directory]' \
    '(- *)--runtime-dir[print runtime directory]' \
    '--json[print directories in JSON]' \
    '--debug[enable debug logging]' \
    '--generate-config[generate sample config file]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd) _jupyter_subcmds && ret=0 ;;
    args) _files && ret=0 ;;
esac

return ret
