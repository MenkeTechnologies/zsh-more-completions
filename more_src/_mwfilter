#compdef mwfilter
# Documentation: https://man.archlinux.org/search?q=mwfilter
# Reference accessed: 2026-05-16

# EMBOSS mwfilter: filter mass list against known contaminant masses
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-datafile=[contaminant mass data file]:file:_files' \
  '-infile=[mass list to filter]:file:_files' \
  '-tolerance=[ppm tolerance]:ppm:' \
  '-showdel[show deleted masses too]' \
  '-outfile=[output file]:file:_files' \
  '*:mass file:_files' && ret=0
return ret
