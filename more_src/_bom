#compdef bom
# Documentation: https://github.com/kubernetes-sigs/bom
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'generate:create SPDX manifests from sources'
  'document:work with SPDX documents (outline, query)'
  'completion:generate shell autocompletion'
  'help:show help for a command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--log-level=[log verbosity]:level:(panic fatal error warning info debug trace)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    _describe -t commands 'bom command' commands && ret=0
    ;;
esac

return ret

