#compdef lfm
# Last File Manager - terminal file manager

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-1 --one)'{-1,--one}'[start in one-pane mode]' \
  '(-2 --two)'{-2,--two}'[start in two-pane mode]' \
  '*:directory:_files -/' \
  && return 0
