#compdef git-branchless

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color=[when to colorize output]:when:(auto always never)' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'amend:amend the current commit'
      'bug-report:generate a bug report'
      'difftool:view changes with difftool'
      'gc:garbage collect unused objects'
      'hide:hide commits from the smartlog'
      'init:initialize branchless workflow'
      'move:move subtree of commits'
      'next:move to next commit'
      'prev:move to previous commit'
      'query:query the commit graph'
      'record:create a new commit interactively'
      'repair:repair broken branchless data'
      'restack:rebase commits to maintain stack'
      'reword:reword commit messages'
      'smartlog:display the commit graph'
      'submit:push commits to remote'
      'switch:switch to a commit or branch'
      'sync:sync with upstream'
      'test:run tests on commits'
      'undo:undo last operation'
      'unhide:unhide commits'
      'wrap:wrap a git command'
    )
    _describe 'command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      move)
        _arguments \
          '-s+[source commit]:commit' \
          '--source=[source commit]:commit' \
          '-d+[destination commit]:commit' \
          '--dest=[destination commit]:commit' \
          '-b+[base commit]:commit' \
          '--base=[base commit]:commit' \
          '--on-disk[perform on-disk rebase]' \
          '--in-memory[perform in-memory rebase]' \
          '-f[force move]' \
          '--force-rewrite[force rewrite commits]' \
          '--merge[use merge strategy]' \
          '--insert[insert rather than move]' \
          '-x+[exact commits to move]:commits' \
          '--exact=[exact commits to move]:commits' && ret=0
        ;;
      next|prev)
        _arguments \
          '-b[toward branch]' \
          '--branch[toward branch]' \
          '-o[oldest]' \
          '--oldest[oldest]' \
          '-n[newest]' \
          '--newest[newest]' \
          '--interactive[interactive selection]' \
          '1:offset' && ret=0
        ;;
      smartlog)
        _arguments \
          '--exact[show exact commits]' \
          '-r+[revset expression]:revset' \
          '--revset=[revset expression]:revset' && ret=0
        ;;
      switch)
        _arguments \
          '-f[force switch]' \
          '--force[force switch]' \
          '--merge[merge uncommitted changes]' \
          '--interactive[interactive selection]' \
          '1:target:' && ret=0
        ;;
      test)
        _arguments \
          '1:subcommand:(run fix show clean)' \
          '-c+[command to execute]:command' \
          '--command=[command to execute]:command' \
          '-x+[exec strategy]:strategy:(working-copy worktree)' \
          '--exec=[exec strategy]:strategy:(working-copy worktree)' \
          '*:revset' && ret=0
        ;;
      submit)
        _arguments \
          '--create[create new submissions]' \
          '--dry-run[dry run]' \
          '--forge=[forge]:forge:(github)' \
          '*:revset' && ret=0
        ;;
    esac
    ;;
esac

return ret
