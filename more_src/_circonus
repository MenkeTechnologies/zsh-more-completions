#compdef circonus circonusctl circonus-cli circonus-agent
# _circonus — Circonus circonusctl CLI for managing accounts brokers check bundles dashboards graphs RUM rules ruleset groups maintenance windows worksheets metrics API tokens against Circonus telemetry SaaS (circonus-labs team, Go); cobra
# upstream: https://github.com/circonus-labs/circonus-cli

_circonus() {
    local -a sub=(
        'account:account operations'
        'agent:agent operations'
        'broker:broker operations'
        'check:check operations'
        'check-bundle:check-bundle operations'
        'contact-group:contact group operations'
        'dashboard:dashboard operations'
        'graph:graph operations'
        'maintenance:maintenance window operations'
        'metric:metric operations'
        'metric-cluster:metric cluster operations'
        'rule:rule operations'
        'rule-set:rule-set operations'
        'rule-set-group:rule-set-group operations'
        'tag:tag operations'
        'token:token operations'
        'worksheet:worksheet operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--api-app=+[name]:str:' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.toml *.yaml *.yml *.json"' \
        '--config=+[config file]:file:_files -g "*.toml *.yaml *.yml *.json"' \
        '--debug[debug]' \
        '--format=+[fmt]:f:(table json yaml csv)' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'circonus subcommand' sub ;;
        args)
            case $words[1] in
                check|check-bundle|graph|dashboard|rule|rule-set|tag|token|worksheet) _arguments \
                    '1:action:(list show create update delete clone fetch)' \
                    '*:id:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_circonus "$@"
