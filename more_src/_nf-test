#compdef nf-test
# Documentation: https://www.nf-test.com/docs/cli/
# Simple test framework for Nextflow pipelines

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[show debug output]' \
  '--verbose[show verbose output]' \
  '--profile=[set the Nextflow profile]:profile' \
  '(-c --config)'{-c,--config}'=[path to the nf-test config file]:file:_files' \
  '--without-trace[disable Nextflow trace file]' \
  '--tap=[write a TAP report to file]:file:_files' \
  '--junitxml=[write a JUnit XML report to file]:file:_files' \
  '--csv=[write a CSV report to file]:file:_files' \
  '--update-snapshot[update test snapshots]' \
  '--ci[run in continuous integration mode]' \
  '--related-tests[find tests related to the given files]' \
  '--follow-dependencies[follow dependencies when finding related tests]' \
  '--filter=[filter tests by type]:type' \
  '--only-changed[run tests for changed files only]' \
  '--changed-since=[run tests changed since a git ref]:ref' \
  '--changed-until=[run tests changed until a git ref]:ref' \
  '--coverage[enable coverage reporting]' \
  '--dry-run[list tests without running them]' \
  '--graph[render a dependency graph]' \
  '--clean-snapshot[remove obsolete snapshots]' \
  '--shard=[run a shard of the tests]:shard' \
  '--shard-strategy=[set the test sharding strategy]:strategy' \
  '--lib=[add a directory to the library path]:dir:_files -/' \
  '--plugins=[set the plugins to load]:plugins' \
  '--tag=[run tests with the given tag]:tag' \
  '--smart-testing[enable smart testing]' \
  '--stop-on-first-failure[stop after the first test failure]' \
  '1:command:((
    init\:"initialize nf-test in the current directory"
    generate\:"generate test cases for scripts and pipelines"
    test\:"run tests"
    list\:"list available tests"
    coverage\:"show test coverage status"
    clean\:"clean the nf-test working directory"
    update-plugins\:"update nf-test plugins"
    version\:"show version"
  ))' \
  '*::arg:_files' && ret=0

return ret
