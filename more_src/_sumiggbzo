#compdef sumiggbzo
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/migration_inversion/sumiggbzo.c
# MIGration via Gaussian Beams of Zero-Offset SU data

local ret=1

_arguments -s -S \
  'vfile=[vfile]:vfile:' \
  'nz=[nz]:nz:' \
  'dt=[dt]:dt:' \
  'dx=[dx]:dx:' \
  'dz=[dz]:dz:' \
  'fmin=[fmin]:fmin:' \
  'fmax=[fmax]:fmax:' \
  'amin=[amin]:amin:' \
  'amax=[amax]:amax:' \
  'bwh=[bwh]:bwh:' \
  'verbose=[verbose]:verbose:' \
  '*:file:_files' && ret=0

return ret
