#compdef weechat weechat-curses weechat-headless

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-l --license)'{-l,--license}'[show license]' \
  '(-c --colors)'{-c,--colors}'[show terminal colors]' \
  '(-d --dir)'{-d+,--dir=}'[home dir]:dir:_files -/' \
  '(-t --temp-dir)'{-t,--temp-dir}'[use temp dir]' \
  '(-r --run-command)*'{-r+,--run-command=}'[command to run]:cmd:' \
  '(-s --no-script)'{-s,--no-script}'[do not load scripts]' \
  '(-a --no-connect)'{-a,--no-connect}'[do not auto-connect]' \
  '(-p --no-plugin)'{-p,--no-plugin}'[do not load plugins]' \
  '(-P --plugins)'{-P+,--plugins=}'[plugins to load csv]:list:' \
  '(--upgrade)--upgrade[upgrade]' \
  '(--daemon)--daemon[daemon mode]' \
  '(--stdout)--stdout[log to stdout]' \
  '(--no-gnutls)--no-gnutls[no gnutls init]' \
  '(--no-gcrypt)--no-gcrypt[no gcrypt init]' \
  '*:plugin args:' && ret=0

return ret
