#compdef abstouch
# Documentation: https://man.archlinux.org/search?q=abstouch
# Reference accessed: 2026-05-16
# Source: https://github.com/rszyma/abstouch-nux/blob/14d3709c2f7ebd1728a5e0686d74e07d2824f4b8/completions/_abstouch
# Repository: rszyma/abstouch-nux (completions/_abstouch)
#!/usr/bin/env zsh

_abstouch()
{
    _arguments -C \
        "1: :(help start stop setup calibrate config)" \
        "*::arg:->args"

    case $line[1] in
        start)
            _abstouch_start
        ;;
        calibrate)
            _abstouch_calibrate
        ;;
    esac
}

_abstouch_start()
{
    _arguments \
        '--foreground[Runs the client on foreground instead of background.]' \
        '--quiet[Disables the output with the client except errors.]'
}

_abstouch_calibrate()
{
    _arguments \
        '--no-visual[Disables the visualization while calibrating.]'
}

