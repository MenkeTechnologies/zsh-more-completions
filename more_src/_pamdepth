#compdef pamdepth
# Documentation: man pamdepth (Netpbm)
# Source: Netpbm pamdepth — change the depth (maxval / color resolution) in a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '1:newmaxval:' \
    '2:netpbm file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
