#compdef metacam
# Documentation: https://man.archlinux.org/search?q=metacam
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-c[comma separated values output]' \
  '*:file:_files -g "*.{jpg,jpeg,tiff,tif,raw}"' && ret=0

return ret
