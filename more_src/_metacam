#compdef metacam
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/metacam.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose -a --all)'{-v,--verbose}'[output unknown tags too]' \
  '(-v --verbose -a --all)'{-a,--all}'[output ALL tags (implies -v)]' \
  '(-x --xml)'{-x,--xml}'[output as XML]' \
  '*:file:_files -g "*.(jpg|jpeg|tif|tiff|raw|nef|cr2|orf)"' && ret=0

return ret
