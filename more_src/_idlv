#compdef idlv
# Documentation: https://github.com/DeMaCS-UNICAL/I-DLV/wiki
# idlv - I-DLV, the intelligent grounder of the DLV2 Answer Set Programming system

local ret=1

_arguments -s \
  '--help[print help guide]' \
  '--stdin[read input from standard input]' \
  '--silent[suppress startup banner and blank lines]' \
  '--no-facts[suppress printing of the EDB]' \
  '--output-format=-[set output format]:format:((0\:smodels 1\:plain-text 2\:query-text 3\:aspif))' \
  '--t[print grounding in textual mode]' \
  '--filter=-[filter listed predicates with arity (e.g. p1/2,p2/3)]:predicates' \
  '--print-rewriting[print the rewritten program]' \
  '--query[print query results]' \
  '--check-edb-duplication[remove duplicate facts from the EDB]' \
  '--choice-rewriting=-[set choice rule rewriting strategy]:strategy:(0 1 2)' \
  '--rewrite-arith-terms[enable arithmetic term rewriting]' \
  '--align-dictionaries[enable dictionary alignment mechanism]' \
  '--look-ahead[enable look-ahead mechanism]' \
  '--ordering=-[set body ordering criterion]:criterion:(0 1 2 3 4 5 6)' \
  '--no-isolated-filter[disable isolated variable filtering]' \
  '--no-projection=-[disable projection rewriting]:level:(0 1 2)' \
  '--indexing=-[set indexing terms for predicates]:indexing' \
  '--FC[enable cautious reasoning]' \
  '--FB[enable brave reasoning]' \
  '--no-magic-sets[disable magic sets rewriting]' \
  '--decomp=-[configure decomposition rewriting]:level:(0 1 2)' \
  '--decomp-algorithm=-[set decomposition algorithm]:algorithm:(0 1 2 3)' \
  '--decomp-threshold=-[set decomposition threshold]:threshold' \
  '--decomp-size-body-limit=-[set max body literals for fitness]:limit' \
  '--decomp-limit=-[set decomposition improvement limit]:limit' \
  '--decomp-iterations=-[set decomposition iterations]:iterations' \
  '--decomp-no-fitness[disable decomposition fitness mechanism]' \
  '--time[print grounding time per rule]' \
  '--gstats[display grounding statistics]' \
  '*:file:_files' && ret=0

return ret
