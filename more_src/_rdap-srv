_rdap-srv() {
    case "$service" in
        rdap-srv)              _rdap_srv_server     ;;
        rdap-srv-data)         _rdap_srv_data       ;;
        rdap-srv-store)        _rdap_srv_store      ;;
        rdap-srv-test-data)    _rdap_srv_test_data  ;;
    esac
}

# `rdap-srv` — env-only configuration (LISTEN_ADDR, LISTEN_PORT, ...)
_rdap_srv_server() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'

    _message 'rdap-srv reads configuration from environment variables only:
  LISTEN_ADDR             bind address          (default 127.0.0.1)
  LISTEN_PORT             bind port             (default 3000)
  AUTO_RELOAD             reload data on change (default true)
  BOOTSTRAP               start with bootstrap  (default false)
  UPDATE_ON_BOOTSTRAP                            (default false)
  JSCONTACT_CONVERSION    none|... contact format
  RDAP_SRV_LOG            log filter
  RDAP_SRV_DATA_DIR       data directory'
}

# `rdap-srv-data` — subcommand-driven RDAP JSON template builder
_rdap_srv_data() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '--data-dir=[directory where data will be written (env RDAP_SRV_DATA_DIR)]:dir:_files -/' \
        '(--template)--redirect=[output data as a redirect to the given URL]:url:' \
        '(--redirect)--template[output data as a template file]' \
        '*--check=[apply a check class (repeatable)]:class:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    local -a subcmds
    subcmds=(
        'domain:add a domain object'
        'entity:add an entity (registrar/registrant/contact)'
        'nameserver:add a nameserver object'
        'autnum:add an autonomous system number object'
        'network:add an IP network object'
        'help:help for a subcommand'
    )

    case $state in
        cmds)
            _describe -t commands 'rdap-srv-data command' subcmds && ret=0
            ;;
        args)
            _arguments \
                '(-B --base-url)'{-B,--base-url=}'[base URL of the server (env RDAP_BASE_URL)]:url:' \
                '*--status=[status of the object (e.g. active) - repeatable]:status:' \
                '--created=[created date+time (RFC3339)]:datetime:' \
                '--updated=[updated date+time (RFC3339)]:datetime:' \
                '*--notice=[server notice: [LINK] description - repeatable]:notice:' \
                '*--remark=[object remark: [LINK] description - repeatable]:remark:' \
                '--registrant=[registrant entity handle]:handle:' \
                '--administrative=[administrative entity handle]:handle:' \
                '--technical=[technical entity handle]:handle:' \
                '*:positional:' && ret=0
            ;;
    esac

    return ret
}

# `rdap-srv-store` — validate + move RDAP files into storage
_rdap_srv_store() {
    _arguments -s -S \
        '*--check=[apply a check class (repeatable)]:class:' \
        '(--reload)--update[update storage]' \
        '(--update)--reload[completely reload storage]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1:directory containing RDAP JSON files:_files -/'
}

# `rdap-srv-test-data` — generate RDAP test data templates
_rdap_srv_test_data() {
    _arguments -s -S \
        '--data-dir=[directory where data will be written (env RDAP_SRV_DATA_DIR)]:dir:_files -/' \
        '(-B --base-url)'{-B,--base-url=}'[base URL of the server (env RDAP_BASE_URL)]:url:' \
        '--entities=[number of test entities to create]:n:' \
        '--nameservers=[number of test nameservers to create]:n:' \
        '--domains=[number of test domains to create]:n:' \
        '--autnums=[number of test autonomous-system numbers to create]:n:' \
        '--v4s=[number of test IPv4 networks to create]:n:' \
        '--v6s=[number of test IPv6 networks to create]:n:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_rdap-srv "$@"
