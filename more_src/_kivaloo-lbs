#compdef kivaloo-lbs
# _kivaloo-lbs — kivaloo log-structured block storage daemon (Tarsnap/kivaloo)
# upstream: https://github.com/Tarsnap/kivaloo
# Flags from lbs/main.c (libcperciva GETOPT).

_kivaloo-lbs() {
    _arguments \
        '(- *)--version[print version]' \
        '-s+[LBS listen socket]:socket:' \
        '-d+[storage directory]:dir:_files -/' \
        '-b+[block size in bytes]:bytes:' \
        '-n+[number of reader threads]:n:' \
        '-p+[pidfile]:file:_files' \
        '-1[run one request at a time]' \
        '-L[lazy commit (do not fsync per write)]' \
        '-l+[simulated read latency (ns)]:ns:'
}

_kivaloo-lbs "$@"
