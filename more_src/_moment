#compdef moment
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/moment.html
# MIRIAD: compute the nth moment of an image spectral axis

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image]:in:_files' \
  'region=[bounding box region]:region:' \
  'out=[output image]:out:_files' \
  'mom=[moment type -3 to 2]:mom:(-3 -2 -1 0 1 2)' \
  'axis=[axis to compute moments along]:axis:' \
  'clip=[intensity range to exclude]:clip:' \
  'span=[channel distance from peak limit]:span:' \
  'rngmsk=[mask if centroid outside axis range]:rngmsk:' \
  'pkmask=[peak intensity mask threshold]:pkmask:' \
  '*:image:_files' && ret=0

return ret
