#compdef CNNScoreVariants
# Documentation: https://gatk.broadinstitute.org/hc/en-us/articles/360037593891-CNNScoreVariants
# Annotate a VCF with scores from a Convolutional Neural Network

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-O --output)'{-O,--output}'=[output VCF file]:output:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '(-V --variant)'{-V,--variant}'=[input VCF of variants]:vcf:_files' \
  '*'{-I,--input}'=[BAM/SAM/CRAM read file (for 2D models)]:bam:_files' \
  '(--architecture)--architecture=[neural net architecture config json]:json:_files' \
  '(--weights)--weights=[Keras model HD5 file with neural net weights]:hd5:_files' \
  '--tensor-type=[name of tensors to generate]:type:(reference read_tensor)' \
  '--window-size=[neural net input window size]:size:' \
  '--read-limit=[max reads to encode in a tensor (2D only)]:n:' \
  '--filter-symbolic-and-sv[filter symbolic and structural variants from input]' \
  '*--info-annotation-keys=[VCF info fields to send to python]:key:' \
  '--inference-batch-size=[size of batches for python inference]:n:' \
  '--transfer-batch-size=[size of data to queue for python streaming]:n:' \
  '--inter-op-threads=[inter-op parallelism threads for Tensorflow]:n:' \
  '--intra-op-threads=[intra-op parallelism threads for Tensorflow]:n:' \
  '--output-tensor-dir=[directory to save tensors for debugging]:dir:_files -/' \
  '--disable-avx-check[skip the AVX support check]' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf:_files' && ret=0

return ret
