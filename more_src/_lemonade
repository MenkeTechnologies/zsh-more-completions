#
# WHAT IS log15 AND WHY IS IT THE 62ND GO CLI LIBRARY?
#
# log15 (https://github.com/inconshreveable/log15, 1,100+ stars) is
# **Alan Shreve's "Structured logging for Go"** — the FIRST production-
# quality STRUCTURED logger for Go, released 2014, by the author of
# ngrok (the dominant secure-tunnel-as-a-service).  Where Go's
# stdlib `log` is text-only and zap/zerolog came later optimized for
# perf, log15 staked out the "structured key-value pairs as the
# canonical API" design philosophy in the Go ecosystem.
#
# log15's distinguishing characteristics:
#
#   1. KEY-VALUE PAIRS AS FIRST-CLASS API — log15's central feature
#      is that every log call takes a message + variadic key-value
#      pairs:
#
#          import log "github.com/inconshreveable/log15"
#
#          logger := log.New()
#          logger.Info("HTTP request",
#              "method", r.Method,
#              "path", r.URL.Path,
#              "user", currentUser.ID,
#              "duration_ms", elapsed.Milliseconds(),
#              "status", w.StatusCode,
#          )
#          // Default Terminal output:
#          // INFO[06-01|14:32:18] HTTP request method=GET path=/users user=u-42 duration_ms=37 status=200
#          //
#          // JSON output (with JsonHandler):
#          // {"t":"2026-06-01T14:32:18Z","lvl":"info","msg":"HTTP request",
#          //  "method":"GET","path":"/users","user":"u-42",
#          //  "duration_ms":37,"status":200}
#
#      Compare:
#         * Go stdlib log: log.Printf("...") — text only
#         * zap (R579): zap.String("key", val), zap.Int(...) typed
#                        fields
#         * zerolog (R583): log.Info().Str(...).Int(...).Msg("...")
#                            chained
#         * logrus (R587): log.WithFields(Fields{"k": v}).Info("...")
#         * slog (stdlib, R591): slog.Info("...", "k", v) variadic
#                                  (slog COPIED log15's design ~2021)
#         * hclog (R607): logger.Info("...", "k", v) variadic
#                          (similar to log15)
#         * log15: logger.Info("...", "k", v) variadic (THE
#                   ORIGINAL 2014 DESIGN)
#      FIRST documented Go Axis 9 logger with variadic key-value
#      pairs as the primary API — DESIGN INFLUENCED Go's stdlib
#      slog (released 7 years later).
#
#   2. HANDLER PIPELINE COMPOSITION — log15's Handler is a recursive
#      interface; every output destination is a Handler, and
#      Handlers compose by wrapping other Handlers:
#
#          import log "github.com/inconshreveable/log15"
#
#          // Compose a complex pipeline:
#          //   1. Filter messages below LvlError
#          //   2. Add file:line caller info to each
#          //   3. Wrap in mutex for thread-safety
#          //   4. Write to stdout as Logfmt-formatted text
#          handler := log.LvlFilterHandler(
#              log.LvlError,
#              log.CallerFileHandler(
#                  log.SyncHandler(
#                      log.StreamHandler(os.Stdout, log.LogfmtFormat()),
#                  ),
#              ),
#          )
#          logger := log.New()
#          logger.SetHandler(handler)
#
#      Built-in Handlers:
#         * StreamHandler(io.Writer, Format) — basic stream output
#         * FileHandler(path, Format) — file output
#         * NetHandler(network, addr, Format) — TCP/UDP output
#         * SyslogHandler(facility, Format) — syslog output
#         * BufferedHandler(buffer-size, Handler) — buffered wrap
#         * LvlFilterHandler(Lvl, Handler) — level-filter wrap
#         * MatchFilterHandler(key, val, Handler) — key=val filter
#         * SyncHandler(Handler) — mutex wrap
#         * CallerFileHandler(Handler) — adds file:line key
#         * CallerStackHandler(Format, Handler) — adds stack-trace
#         * DiscardHandler — /dev/null
#      Compare:
#         * zap: zapcore.Core with zapcore.NewMultiWriteSyncer
#         * zerolog: io.MultiWriter for fanout (limited)
#         * logrus: Hooks + Formatters (different concept)
#         * slog (stdlib): Handler interface (BORROWS log15's
#                            recursive composition idea)
#         * hclog: LoggerOptions config struct (no recursive
#                   composition)
#         * log15: HANDLER PIPELINE via recursive wrapping
#      FIRST documented Go Axis 9 logger with recursive Handler-
#      wrapping pipeline composition.
#
#   3. CONTEXT VIA logger.New("key", val) — log15's logger.New()
#      method returns a CHILD logger with ambient key-value context
#      that is merged into every log call:
#
#          logger := log.New("app", "lemonade", "version", "1.5.0")
#          // Every log from `logger` will include app=lemonade
#          // and version=1.5.0 automatically
#
#          // Per-request child:
#          reqLogger := logger.New("req-id", "abc-123",
#                                  "remote-ip", req.RemoteAddr)
#          // Every log from reqLogger includes app=, version=,
#          // req-id=, remote-ip= automatically
#
#          reqLogger.Info("processing request", "url", req.URL)
#          // → INFO[...] processing request app=lemonade version=1.5.0
#          //    req-id=abc-123 remote-ip=10.1.2.3 url=/api/copy
#
#      Compare:
#         * zap: logger.With(zap.String(...)) (similar concept)
#         * zerolog: log.With().Str(...).Logger() chained
#         * logrus: log.WithFields(...) (similar)
#         * slog (stdlib): slog.With(...) (BORROWS log15's idea)
#         * hclog: logger.Named("...") + With() (similar)
#         * log15: logger.New("k", v, "k2", v2) variadic context
#      FIRST documented Go Axis 9 logger with variadic-pairs
#      context inheritance via .New() — DESIGN COPIED INTO slog.
#
#   4. FORMAT-AGNOSTIC HANDLERS — log15's Handlers are independent
#      of the OUTPUT FORMAT.  The Format type is a separate
#      pluggable abstraction:
#
#          log15.LogfmtFormat()  // key=value pairs
#          log15.JsonFormat()    // JSON objects
#          log15.TerminalFormat() // colored human-readable
#
#          // Mix and match Handlers + Formats:
#          stdout := log.StreamHandler(os.Stdout, log.TerminalFormat())
#          file := log.FileHandler("app.log", log.JsonFormat())
#          syslog := log.SyslogHandler(syslog.LOG_LOCAL0, log.LogfmtFormat())
#
#          handler := log.MultiHandler(stdout, file, syslog)
#          // Same log calls fan out to ALL three with different formats
#
#      Compare:
#         * zap: zapcore.Encoder is bound to a single Core
#         * zerolog: format is config of the Writer (not pluggable)
#         * logrus: Formatter is set per Logger (not per output)
#         * slog (stdlib): Handler bundles format + output
#         * hclog: JSONFormat boolean toggle in LoggerOptions
#         * log15: HANDLER + FORMAT are orthogonal abstractions
#      FIRST documented Go Axis 9 logger with format and output
#      destination as fully orthogonal abstractions.
#
#   5. ALAN-SHREVE / NGROK / GO-ETHEREUM PROVENANCE — log15 is by
#      Alan Shreve, the creator of ngrok (the dominant secure-
#      tunnel SaaS).  log15 was extracted from ngrok's internal
#      logging and open-sourced in 2014.  Adopted by:
#         * jackc/pgx (the dominant Go PostgreSQL driver)
#         * ethereum/go-ethereum (Geth — Ethereum reference impl)
#         * caddyserver/caddy (Caddy web server — originally)
#         * drone/drone (Drone CI — originally; later migrated)
#         * go-kit/kit (Go microservice framework)
#         * jaegertracing/jaeger (originally)
#         * ipfs/go-ipfs (originally)
#         * lemonade-command/lemonade (THIS — 725 stars)
#         * flexera-public/wstunnel
#         * ncsa/ssh-auditor (security audit tool)
#         * GESkunkworks/gossamer (AWS MFA helper)
#         * 500+ more Go production services
#      log15 STRONGLY INFLUENCED Go's stdlib log/slog package
#      (released 2021) — slog's variadic-key-value API +
#      Handler-with-context-inheritance pattern are direct
#      descendants of log15's 2014 design.  FIRST documented Go
#      Axis 9 logger with this specific Alan-Shreve / ngrok-
#      origin / influence-on-stdlib-slog provenance.
#
# log15's relationship to other documented Go Axis 9 libraries:
#
#   * Unlike zap (R579) — zap optimizes for raw performance with
#                          typed-field allocators; log15 prioritizes
#                          API ergonomics with variadic key-value
#                          pairs
#   * Unlike zerolog (R583) — zerolog uses chained .With().Str()
#                              builder; log15 uses variadic pairs
#   * Unlike logrus (R587) — logrus uses WithFields(Fields{})
#                             map-based context; log15 uses
#                             variadic pairs
#   * Unlike slog (R591) — slog (stdlib, Go 1.21+) ADOPTED log15's
#                            variadic-key-value API + Handler
#                            inheritance pattern; slog is the
#                            "official stdlib version of log15"
#   * Unlike hclog (R607) — hclog adopted log15's variadic API
#                            but added go-plugin RPC integration +
#                            Named() prefix inheritance
#   * Closest cross-language analogs:
#         * Rust: tracing (R590) — span-based context (different
#                                    concept but similar role)
#         * Rust: slog (R586) — Rust's slog is literally the
#                                 Rust port of Go's log15 design
#         * Python: structlog — variadic-key-value structured
#                                 logging library
#         * JavaScript: bunyan — JSON-line structured logging
#     log15 is the FIRST documented Go logger establishing
#     VARIADIC KEY-VALUE pairs as the primary API + HANDLER
#     PIPELINE composition + FORMAT-AGNOSTIC outputs + influence
#     on Go's stdlib slog (released 7 years later).
#
# -----------------------------------------------------------------------------
#
# THE lemonade CLI — stdlib flag + log15 + conflag config + go-homedir
#
# lemonade's CLI is in main.go + lemon/flag.go.  Uses Go's stdlib
# `flag` package with custom argv[0]-detection for pbcopy/pbpaste/
# xdg-open aliases:
#
#     // From main.go:
#     import log "github.com/inconshreveable/log15"
#
#     var logLevelMap = map[int]log.Lvl{
#         0: log.LvlDebug,
#         1: log.LvlInfo,
#         2: log.LvlWarn,
#         3: log.LvlError,
#         4: log.LvlCrit,
#     }
#
#     func Do(c *lemon.CLI, args []string) int {
#         logger := log.New()
#         logger.SetHandler(log.LvlFilterHandler(log.LvlError,
#                                                  log.StdoutHandler))
#         // ... parse flags ...
#         logLevel := logLevelMap[c.LogLevel]
#         logger.SetHandler(log.LvlFilterHandler(logLevel,
#                                                  log.StdoutHandler))
#         // ... dispatch subcommand (open/copy/paste/server) ...
#     }
#
# Subcommands:
#   open <url>      Open URL in local browser
#   copy [text]     Copy text to local clipboard (reads stdin if no arg)
#   paste           Paste local clipboard to stdout
#   server          Run lemonade RPC server (default port 2489)
#
# argv[0] aliases (when symlinked):
#   xdg-open <url>  → equivalent to `lemonade open <url>`
#   pbcopy [text]   → equivalent to `lemonade copy`
#   pbpaste         → equivalent to `lemonade paste`
#
# Flags (all subcommands):
#   --port N                          TCP port (default 2489)
#   --allow CIDR                       Allowed client IPs (default
#                                       0.0.0.0/0,::/0)
#   --host HOST                        Server host (default localhost)
#   --help                             Show help
#   --trans-loopback                   Translate loopback URLs (default true)
#   --trans-localfile                  Translate local-file URLs (default true)
#   --line-ending {CR|CRLF}            Convert line endings
#   --no-fallback-messages             Suppress fallback messages
#   --rpc-timeout DURATION             RPC timeout (default 100ms)
#   --log-level N                      0=Debug, 1=Info, 2=Warn,
#                                       3=Error, 4=Crit
#
# Config file: ~/.config/lemonade.toml (loaded via monochromegane/
# conflag) — flag values can be set in the config file.
#
# Five-axis distinctness from every other Go Axis 9 logger:
#
#   1. VARIADIC KEY-VALUE PAIRS API — log15 ESTABLISHED this
#      pattern in 2014; stdlib slog adopted it in 2021.
#
#   2. HANDLER PIPELINE COMPOSITION — log15's Handler is a
#      recursive interface; pipeline built by wrapping.
#
#   3. logger.New("k", v) CONTEXT INHERITANCE — variadic-pairs
#      child loggers with merged ambient context.
#
#   4. FORMAT-AGNOSTIC HANDLERS — Format (Logfmt/JSON/Terminal)
#      and Handler (Stream/File/Net/Syslog) are orthogonal.
#
#   5. ALAN-SHREVE / NGROK PROVENANCE — extracted from ngrok's
#      internal logger; influenced Go stdlib slog design.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/lemonade-command/lemonade/blob/master/lemon/flag.go
# stdlib flag.FlagSet definitions + main.go logger setup.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _lemonade_cmds _lemonade_line_endings
_lemonade_cmds=(
    'open:open a URL in the local browser (via server)'
    'copy:copy text to the local clipboard (via server)'
    'paste:paste local clipboard contents to stdout (via server)'
    'server:run the lemonade RPC server (default port 2489)'
)
_lemonade_line_endings=(
    'CR:convert line endings to CR'
    'CRLF:convert line endings to CRLF'
)

_arguments -C \
    '--port=[TCP port number (default 2489)]:port:_default' \
    '--allow=[allow client IPs (CIDR list, default 0.0.0.0/0,::/0)]:cidr:_default' \
    '--host=[destination host name (default localhost)]:host:_hosts' \
    '--trans-loopback=[translate loopback address (default true)]:bool:(true false)' \
    '--trans-localfile=[translate local file (default true)]:bool:(true false)' \
    '--line-ending=[convert line endings (CR/CRLF)]:line ending:(CR CRLF)' \
    '--no-fallback-messages[do not show fallback messages]' \
    '--rpc-timeout=[RPC timeout duration (default 100ms)]:duration:_default' \
    '--log-level=[log level (0=Debug, 1=Info, 2=Warn, 3=Error, 4=Crit; default 1)]:level:(0 1 2 3 4)' \
    '(- *)--help[show help]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'lemonade subcommand' _lemonade_cmds && ret=0
        ;;
    args)
        case $words[1] in
            open)
                _arguments \
                    '1:URL:_urls' \
                    && ret=0
                ;;
            copy)
                _arguments \
                    '1:text or file:_files' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
