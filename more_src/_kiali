#compdef kiali
# Documentation: https://man.archlinux.org/search?q=kiali
# Reference accessed: 2026-05-16

# Kiali: Istio service mesh observability/UI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '--v=[log verbosity level]:n:' \
  '--logtostderr[log to stderr]' \
  '--alsologtostderr[also log to stderr]' \
  '--log_dir=[log dir]:dir:_files -/' \
  '*::kiali args:_files' && ret=0
return ret
