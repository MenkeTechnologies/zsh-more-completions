#compdef kiali
# Documentation: https://github.com/kiali/kiali/blob/master/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream source (cobra) at the URL above.

# Kiali: the console for Istio service mesh

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:Run Kiali locally'
  'gather:Run Kiali in gather mode to collect Prometheus queries'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'[path to the YAML configuration file]:file:_files' \
  '(-l --log-level)'{-l,--log-level}'[log level]:level:(trace debug info warn error fatal)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    _describe -t commands 'kiali command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      run)
        local -a run_cmds=(
          'offline:Start Kiali in offline mode with local data'
        )
        _arguments \
          '--context=[kubeconfig context for Kiali to use]:context:' \
          '--kubeconfig=[path to the kubeconfig file]:file:_files' \
          '*--remote-cluster-contexts=[remote cluster kubeconfig contexts]:contexts:' \
          '--no-browser[do not open the default browser after startup]' \
          '*--cluster-name-overrides=[cluster name overrides]:overrides:' \
          '1:subcommand:->sub' '*::args:->subargs' && ret=0
        [[ $state == sub ]] && _describe -t commands 'run subcommand' run_cmds && ret=0
        if [[ $state == subargs && ${words[1]} == offline ]]; then
          _arguments \
            '(-d --data-path)'{-d,--data-path}'[directory containing offline data files]:dir:_files -/' \
            '(-w --without-browser)'{-w,--without-browser}'[do not open the default browser after startup]' && ret=0
        fi
        ;;
      gather)
        _arguments \
          '--home-cluster-context=[home cluster context in gather mode]:context:' \
          '--kubeconfig=[path to the kubeconfig file]:file:_files' \
          '*--remote-cluster-contexts=[remote cluster kubeconfig contexts]:contexts:' \
          '--output-dir=[directory for gather mode output files]:dir:_files -/' \
          '*--cluster-name-overrides=[cluster name overrides]:overrides:' && ret=0
        ;;
    esac
    ;;
esac

return ret
