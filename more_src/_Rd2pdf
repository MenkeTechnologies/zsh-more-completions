#compdef Rd2pdf
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/tools/html/Rdutils.html
# R CMD Rd2pdf: generate PDF output from Rd sources

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print short help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '(-q --quiet)'{-q,--quiet}'[no output unless errors]' \
  '--no-clean[do not remove created temporary files]' \
  '--no-preview[do not preview generated PDF file]' \
  '--encoding=[use enc as the default input encoding]:encoding:' \
  '--outputEncoding=[use outenc as the default output encoding]:encoding:' \
  '--os=[use OS subdir NAME]:os:(unix windows)' \
  '--OS=[the same as --os]:os:(unix windows)' \
  '(-o --output)'{-o,--output=}'[write output to FILE]:file:_files' \
  '--force[overwrite output file if it exists]' \
  '--title=[use NAME as the title of the document]:title:' \
  '--no-index[do not index output]' \
  '--no-description[do not typeset the description of a package]' \
  '--internals[typeset internal documentation (usually skipped)]' \
  '--build-dir=[use DIR as the working directory]:dir:_files -/' \
  '--RdMacros=[packages from which to get Rd macros]:pkglist:' \
  '*:file:_files' && ret=0

return ret
