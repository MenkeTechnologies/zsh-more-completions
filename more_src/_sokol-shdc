#compdef sokol-shdc
# Documentation: https://github.com/floooh/sokol-tools/blob/master/docs/sokol-shdc.md
# sokol-shdc annotated-GLSL shader cross-compiler

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage information and exit]' \
  '(-i --input)'{-i,--input}'[path to the annotated GLSL source file]:input:_files' \
  '(-o --output)'{-o,--output}'[path for the generated output file]:output:_files' \
  '(-l --slang)'{-l,--slang}'[output shader languages, colon-separated]:slang:' \
  '(-f --format)'{-f,--format}'[output backend format]:format:(sokol sokol_impl sokol_zig sokol_nim sokol_odin sokol_rust sokol_d bare bare_yaml)' \
  '(-b --bytecode)'{-b,--bytecode}'[compile shaders to bytecode when possible]' \
  '(-e --errfmt)'{-e,--errfmt}'[error message format]:errfmt:(gcc msvc)' \
  '(-t --tmpdir)'{-t,--tmpdir}'[directory for intermediate files]:tmpdir:_files -/' \
  '--module[namespace prefix for generated identifiers]:module:' \
  '--ifdef[wrap backend-specific code in preprocessor conditionals]' \
  '--reflection[generate runtime inspection functions]' \
  '(-g --genver)'{-g,--genver}'[version number to embed in header]:genver:' \
  '--defines[colon-separated preprocessor definitions]:defines:' \
  '(-d --dump)'{-d,--dump}'[enable verbose debug output to stdout]' \
  '--save-intermediate-spirv[save intermediate SPIRV blob for inspection]' \
  '--no-log-cmdline[omit command-line logging from output]' \
  '--dependency-file[generate Clang/GCC style dependency file]:depfile:_files' \
  '*:file:_files' && ret=0

return ret
