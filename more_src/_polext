#compdef polext
# Documentation: https://starlink.eao.hawaii.edu/docs/sun223.htx/sun223ss6.html
# POLPACK: sets explicit values in the POLPACK extension.

local ret=1

_arguments -s -S \
  'IN=[input data files]:ndf:_files' \
  'NAMELIST=[output file listing processed files]:file:_files' \
  'IMGID=[image identifier strings]:id:' \
  'FILTER=[filter name identifier]:filter:' \
  'STOKES=[Stokes quantities in cube planes]:stokes:' \
  'RAY=[ray type for dual-beam]:ray:(O E)' \
  'WPLATE=[half-wave plate position in degrees]:deg:' \
  'ANGROT=[angle to reference direction in degrees]:deg:' \
  'ANLANG=[angle to analyser in degrees]:deg:' \
  'EPS=[analyser efficiency 0.0-1.0]:val:' \
  'T=[analyser transmission value]:val:' \
  'QUIET=[suppress screen output]:flag:(TRUE FALSE)' \
  '*:ndf:_files' && ret=0

return ret
