#compdef csi-driver-spiffe
# _csi-driver-spiffe — cert-manager SPIFFE CSI driver (per-pod SPIFFE SVIDs)
# upstream: https://github.com/cert-manager/csi-driver-spiffe
# Flags from internal/csi/app on tip.

_csi-driver-spiffe() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --log-level)'{-v,--log-level=}'[log verbosity (0-5)]:n:' \
        '--log-format=[log format]:fmt:(text json)' \
        '--node-id=[Kubernetes node ID]:id:' \
        '--endpoint=[CSI endpoint (unix sock or tcp host\:port)]:endpoint:' \
        '--driver-name=[CSI driver name]:name:' \
        '--data-root=[data directory]:dir:_files -/' \
        '--trust-domain=[SPIFFE trust domain]:domain:' \
        '--issuer-name=[cert-manager Issuer name]:name:' \
        '--issuer-kind=[cert-manager Issuer kind]:kind:(Issuer ClusterIssuer)' \
        '--issuer-group=[cert-manager Issuer API group]:group:' \
        '--certificate-request-duration=[CertificateRequest duration]:dur:' \
        '--certificate-file-name=[in-pod certificate file name]:name:' \
        '--key-file-name=[in-pod key file name]:name:' \
        '--ca-file-name=[in-pod CA bundle file name]:name:' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--kube-api-qps=[max QPS to K8s apiserver]:f:' \
        '--kube-api-burst=[max burst to K8s apiserver]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_csi-driver-spiffe "$@"
