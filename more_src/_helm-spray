#compdef helm-spray
# Documentation: https://github.com/ThalesGroup/helm-spray
# helm spray: deploy umbrella charts subchart-by-subchart

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[enable helm debug output]' \
  '--dry-run[simulate a spray operation]' \
  '(-x --exclude)'{-x,--exclude}'+[subchart to exclude (repeatable)]:subchart:' \
  '--force[force resource update through delete/recreate]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace to spray the chart into]:namespace:' \
  '--prefix-releases=[prefix release names with given string]:prefix:' \
  '--prefix-releases-with-namespace[prefix releases with namespace name]' \
  '--reset-values[reset values to chart defaults when upgrading]' \
  '--reuse-values[reuse last release values and merge overrides]' \
  '*--set=[set values on the command line]:value:' \
  '*--set-file=[set values from files]:file:_files' \
  '*--set-string=[set STRING values on the command line]:value:' \
  '(-t --target)'{-t,--target}'+[subchart to target (repeatable)]:subchart:' \
  '--timeout=[time in seconds for Kubernetes operations]:seconds:' \
  '(-f --values)'{-f,--values}'+[values in a YAML file or URL]:file:_files' \
  '--verbose[enable spray verbose output]' \
  '--version=[specify exact chart version to install]:version:' \
  '*:chart:_files' && ret=0

return ret
