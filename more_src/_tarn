#compdef tarn
# Documentation: https://man.archlinux.org/search?q=tarn
# Reference accessed: 2026-05-16
# Source: cargo binstall tarn@0.12.0
# Probed via: completions zsh
# Repository: https://github.com/NazarKalytiuk/tarn

autoload -U is-at-least

_tarn() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tarn_commands" \
"*::: :->tarn" \
&& ret=0
    case $state in
    (tarn)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tarn-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
'*--format=[Output format target(s)\: human, json, junit, tap, html, curl, curl-all, compact, llm, or FORMAT=PATH. When omitted, tarn picks \`human\` on a TTY and \`llm\` when stdout is piped (so an LLM never sees boxed headers by default)]:FORMAT:_default' \
'--json-mode=[JSON report mode\: verbose (default) or compact]:JSON_MODE:_default' \
'--tag=[Filter by tag (comma-separated, AND logic)]:TAG:_default' \
'*--select=[Select a single file, test, or step (repeatable). Form\: FILE\[\:\:TEST\[\:\:STEP\]\]. STEP may be a name or a 0-based index. Multiple --select flags union; combined with --tag they AND]:FILE[::TEST[::STEP]]:_default' \
'--test-filter=[Restrict the run to a single named test. Ergonomic shorthand for \`--select FILE\:\:TEST\`; internally composed against every file in the discovery set. Combine with \`--step-filter\` to narrow further]:NAME:_default' \
'--step-filter=[Restrict the run to a single step within the \`--test-filter\` test. Accepts a 0-based numeric index or an exact step name. When used without \`--test-filter\` it applies to the flat-steps form of the file. Internally composes into the selector grammar]:INDEX|NAME:_default' \
'*--var=[Override environment variables (key=value)]:KEY=VALUE:_default' \
'--env=[Environment name (loads tarn.env.{name}.yaml)]:ENV_NAME:_default' \
'--max-body=[Maximum response body size (bytes) embedded in the report when \`--verbose-responses\` or a per-step \`debug\: true\` causes the body to be recorded. Larger bodies are truncated with a \`"...<truncated\: N bytes>"\` marker]:BYTES:_default' \
'-j+[Number of parallel workers (default\: number of CPUs)]:JOBS:_default' \
'--jobs=[Number of parallel workers (default\: number of CPUs)]:JOBS:_default' \
'--cookie-jar=[Load and persist cookie jars to a JSON file]:COOKIE_JAR:_default' \
'--proxy=[Explicit proxy URL for HTTP/HTTPS requests]:PROXY:_default' \
'--no-proxy=[Hosts that should bypass the configured proxy]:NO_PROXY:_default' \
'--cacert=[Additional PEM CA bundle to trust]:CACERT:_default' \
'--cert=[Client certificate PEM file]:CERT:_default' \
'--key=[Client private key PEM file]:KEY:_default' \
'*--redact-header=[Additional header name to redact in reports (repeatable, case-insensitive). Merges with — never narrows — the built-in defaults and any \`redaction\:\` block from config or test files]:NAME:_default' \
'--report-json=[Override the path for the always-on JSON artifact. Defaults to \`<project-root>/.tarn/last-run.json\`. Every run overwrites the file so machines can always find the most recent result without rerunning in \`--format json\`]:PATH:_files' \
'--fixture-retention=[Override the rolling-history retention cap for per-step fixtures. Defaults to 5. Setting this to 1 keeps only the most recent fixture (plus the always-on \`latest-passed.json\`). Higher values trade disk for deeper history — helpful for debugging flaky steps]:N:_default' \
'-v[Print full request/response for every step]' \
'--verbose[Print full request/response for every step]' \
'--verbose-responses[Include response body, response headers, and captures in the report for every step (not just failed ones). Works with \`json\`, \`html\`, \`compact\`, and \`llm\` formats. Use \`--max-body\` to cap body size]' \
'--only-failed[Show only failed tests and steps in the output. \`--only-fails\` is accepted as an alias]' \
'--no-progress[Disable streaming progress output (print the final report in one batch)]' \
'(--no-progress)--ndjson[Stream NDJSON events to stdout for machine-readable progress. Mutually exclusive with any --format target that writes to stdout]' \
'--dry-run[Show interpolated requests without sending them]' \
'-w[Watch for changes and rerun on file save]' \
'--watch[Watch for changes and rerun on file save]' \
'--parallel[Run test files in parallel. Only safe when tests don'\''t share mutable state (DB rows, global counters, filesystem fixtures). Mark state-sharing files with \`serial_only\: true\` or bucket them with a shared \`group\:\` name; opt in via \`parallel_opt_in\: true\` in \`tarn.config.yaml\` to silence the startup warning once the suite has been audited]' \
'--no-parallel-warning[Suppress the \`--parallel\` isolation warning. Use in CI once the suite has been verified safe for concurrent execution. Prefer setting \`parallel_opt_in\: true\` in the project config; this flag is an escape hatch for one-off runs]' \
'--cookie-jar-per-test[Reset the default cookie jar between named tests in each file. Overrides the file'\''s declared \`cookies\:\` mode (except \`off\`)]' \
'--insecure[Disable TLS certificate and hostname verification]' \
'(--http2)--http1.1[Force HTTP/1.1]' \
'(--http1.1)--http2[Force HTTP/2]' \
'--no-default-excludes[Include normally-ignored directories (\`.git\`, \`.worktrees\`, \`node_modules\`, \`.venv\`/\`venv\`, \`dist\`, \`build\`, \`target\`, \`tmp\`, \`.tarn\`) during test discovery. Use with care — it commonly doubles the run by picking up stale worktree copies]' \
'--no-last-run-json[Skip writing the always-on JSON artifact. Use for transient runs where persisting the result on disk is undesirable]' \
'--no-fixtures[Skip writing per-step fixtures under \`.tarn/fixtures/\`. Fixtures are what \`tarn.getFixture\` / \`tarn.evaluateJsonpath\` / \`tarn.explainFailure\` in tarn-lsp consume, so disabling them means LLM clients cannot answer "what did this step last return?" until the next run without \`--no-fixtures\`]' \
'--agent[Emit a compact root-cause-first JSON payload (\`AgentReport\`) to stdout for automation / MCP clients, suppressing the normal stdout formatter. Composes with other \`--format\` targets that write to files; mutually exclusive with \`--ndjson\`, \`--watch\`, and any explicit \`--format\` target that writes a non-JSON payload to stdout. Stderr still carries the usual \`run id\:\` / \`run artifacts\:\` announcements so humans watching the run see progress (NAZ-412)]' \
'--allow-exec[Authorize \`command\:\` steps (NAZ-464) to spawn child processes. Without this flag (and without \`allow_exec\: true\` in \`tarn.config.yaml\`) every shell command is recorded as \`failure_category\: skipped_by_policy\` — the security default for freshly cloned repositories]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Test file or directory to run:_default' \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
