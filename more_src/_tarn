(( $+functions[_tarn_commands] )) ||
_tarn_commands() {
    local commands; commands=(
'run:Run test files' \
'validate:Validate test files without running' \
'lint:Lint test files for reliability smells and correctness errors (NAZ-406)' \
'fmt:Format Tarn test files into canonical YAML' \
'list:List all tests (dry run)' \
'env:List project-defined named environments' \
'import-hurl:Convert common-case .hurl files into Tarn YAML' \
'init:Initialize a new Tarn project' \
'bench:Benchmark a test step with concurrent requests' \
'update:Update tarn to the latest version' \
'completions:Generate shell completions' \
'summary:Re-render a prior JSON report in the LLM-friendly format. Accepts a file path or \`-\` to read from stdin. Primarily for \`tarn run --format json > run.json && tarn summary run.json\` workflows where a large report is streamed once and summarized lazily on demand' \
'failures:Group a prior run'\''s failures by root cause and suppress cascade noise' \
'rerun:Rerun the failing subset of a prior run (NAZ-403)' \
'inspect:Inspect a prior run'\''s report at run, file, test, or step level (NAZ-405)' \
'report:Concise re-render of a prior run'\''s persisted artifacts (NAZ-404)' \
