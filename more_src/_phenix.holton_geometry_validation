#compdef phenix.holton_geometry_validation
# Phenix: Holton geometry validation score for an atomic model

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'model=[input PDB model to evaluate]:file:_files -g "*.(pdb|cif)"' \
  'other_models=[PDB files to compare against the model]:file:_files -g "*.(pdb|cif)"' \
  'get_individual_residue_scores=[calculate per-residue scores]:bool:(True False)' \
  'keep_hydrogens=[retain input hydrogens]:bool:(True False)' \
  'ignore_cis_peptides=[skip cis peptide penalties]:bool:(True False)' \
  'ignore_h_except_in_nonbond=[exclude H except in nonbonded terms]:bool:(True False)' \
  'ignore_arg_h_nonbond=[exclude H atoms in arginine residues]:bool:(True False)' \
  'ignore_bond_lengths_with_h=[skip bonds containing hydrogen]:bool:(True False)' \
  'ignore_water_h_bonds=[exclude water hydrogen contacts]:bool:(True False)' \
  'remove_waters=[strip waters before analysis]:bool:(True False)' \
  'round_numbers=[round values before calculation]:bool:(True False)' \
  'omega_angle_sigma=[omega angle deviation tolerance]:sigma:' \
  'cbetadev_sigma=[CB position tolerance]:sigma:' \
  'include_random=[estimate expected value for random errors]:bool:(True False)' \
  'n_random=[number of sampling iterations]:n:' \
  'random_seed=[RNG seed value]:seed:' \
  '*:model file:_files -g "*.(pdb|cif)"' && ret=0

return ret
