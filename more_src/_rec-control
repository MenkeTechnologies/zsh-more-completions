#compdef rec-control
# _rec-control — PowerDNS rec_control control PowerDNS recursor CLI alias (PowerDNS team, C++); custom argparse
# upstream: https://github.com/PowerDNS/pdns

_rec-control() {
    local -a sub=(
        'add-dont-throttle-names:add names to dont-throttle list'
        'add-dont-throttle-netmasks:add netmasks to dont-throttle list'
        'add-nta:add negative trust anchor'
        'add-ta:add trust anchor'
        'check-config:check configuration'
        'clear-dont-throttle-names:clear dont-throttle names'
        'clear-dont-throttle-netmasks:clear dont-throttle netmasks'
        'clear-nta:clear NTA'
        'clear-ta:clear TA'
        'current-queries:show currently running queries'
        'dump-cache:dump cache to file'
        'dump-dot-probe-map:dump DoT probe map'
        'dump-edns:dump EDNS status'
        'dump-failedservers:dump failed servers'
        'dump-non-resolving:dump non-resolving'
        'dump-nsspeeds:dump NS speeds'
        'dump-rpz:dump RPZ'
        'dump-saved-parent-ns-sets:dump saved parent NS sets'
        'dump-throttlemap:dump throttle map'
        'get:get statistic'
        'get-all:get all statistics'
        'get-dont-throttle-names:get dont-throttle names'
        'get-dont-throttle-netmasks:get dont-throttle netmasks'
        'get-ntas:get NTAs'
        'get-parameter:get parameter value'
        'get-proxymapping-stats:get proxymapping stats'
        'get-qtypelist:get qtype list'
        'get-remotelogger-stats:get remotelogger stats'
        'get-tas:get TAs'
        'help:show help'
        'hash-password:hash a password'
        'list-dnssec-algos:list DNSSEC algos'
        'ping:ping server'
        'quit:quit server'
        'quit-nicely:quit nicely'
        'reload-acls:reload ACLs'
        'reload-lua-config:reload Lua config'
        'reload-lua-script:reload Lua script'
        'reload-zones:reload zones'
        'set-dnssec-log-bogus:enable/disable DNSSEC bogus log'
        'set-ecs-minimum-ttl-override:set ECS min TTL override'
        'set-event-trace-enabled:set event trace'
        'set-log-level:set log level'
        'set-max-cache-entries:set max cache entries'
        'set-max-packetcache-entries:set max packetcache entries'
        'set-minimum-ttl-override:set min TTL override'
        'set-yaml-setting:set YAML setting'
        'show-yaml:show YAML config'
        'top-bogus-remotes:show top bogus remotes'
        'top-largeanswer-remotes:show top large answer remotes'
        'top-noerror-remotes:show top noerror remotes'
        'top-nxdomain-remotes:show top NXDOMAIN remotes'
        'top-pub-queries:show top public queries'
        'top-queries:show top queries'
        'top-remotes:show top remotes'
        'top-servfail-queries:show top SERVFAIL queries'
        'top-servfail-remotes:show top SERVFAIL remotes'
        'top-timeouts:show top timeouts'
        'trace-regex:set trace regex'
        'unload-lua-script:unload Lua script'
        'version:show version'
        'wipe-cache:wipe cache entries'
        'wipe-cache-typed:wipe cache entries by type'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files' \
        '--socket-dir=+[socket dir]:dir:_files -/' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '--config-name=+[config name]:str:' \
        '--process=+[process]:n:' \
        '--timeout=+[seconds]:n:' \
        '--no-config[no config]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rec_control subcommand' sub ;;
    esac
}

_rec-control "$@"
