#compdef apparmor_parser
# _apparmor_parser — AppArmor apparmor_parser (compile + load AppArmor profiles into the kernel; -a add, -r replace, -R remove, -q quiet, -v verbose, -p preprocess only (print resulting profile), -N print profile name only, -d debug, -K do not cache, --cache-loc cache dir, --policy-features feature file, --base policy_dir, --print-cache-dir, --config-file; positional argument is a profile file or `stdin`)
# upstream: https://gitlab.com/apparmor/apparmor
# Flags from apparmor/apparmor parser/parser_main.c on tip.

_apparmor_parser() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-a[add profile]' \
        '-r[replace profile]' \
        '-R[remove profile]' \
        '-q[quiet]' \
        '-v[verbose]' \
        '-p[preprocess only]' \
        '-N[print profile name only]' \
        '-d[debug]' \
        '-K[no cache]' \
        '-T[skip read cache]' \
        '-B[skip write cache]' \
        '--cache-loc+[cache dir]:dir:_files -/' \
        '--policy-features+[features file]:file:_files' \
        '--base+[policy base dir]:dir:_files -/' \
        '--print-cache-dir[print cache dir]' \
        '--config-file+[config file]:file:_files' \
        '-O+[optimization flag]:flag:' \
        '-W[warnings]' \
        '-Z[debug optimization]' \
        '*:profile:_files'
}

_apparmor_parser "$@"
