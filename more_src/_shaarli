#compdef shaarli
# _shaarli — Shaarli community Shaarli minimalist personal bookmark database with single-PHP-file install (shaarli team, PHP); custom argparse
# upstream: https://github.com/shaarli/Shaarli

_shaarli() {
    local -a sub=(
        'install:install Shaarli'
        'version:show version'
        'check:check installation'
        'update:run database updates'
        'reset-password:reset admin password'
        'thumbnails:sync:sync thumbnails'
        'thumbnails:clear:clear thumbnails'
        'bookmarks:export:export bookmarks'
        'bookmarks:import:import bookmarks'
        'bookmarks:list:list bookmarks'
        'bookmarks:get:get bookmark by id'
        'bookmarks:delete:delete bookmark'
        'cache:clear:clear caches'
        'cache:warmup:warm up caches'
        'tags:list:list tags'
        'tags:rename:rename tag'
        'tags:delete:delete tag'
        'plugins:list:list plugins'
        'plugins:enable:enable plugin'
        'plugins:disable:disable plugin'
        'config:get:get config value'
        'config:set:set config value'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config-file=+[config file]:file:_files -g "*.json *.php"' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--no-interaction[no interactive prompts]' \
        '-n[no interactive prompts]' \
        '--quiet[no output]' \
        '-q[no output]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-vvv[debug verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shaarli subcommand' sub ;;
        args)
            case $words[1] in
                bookmarks:export|bookmarks:import) _arguments \
                    '--format=+[format]:f:(html json csv markdown)' \
                    '*:file:_files' ;;
                tags:rename) _arguments '1:tag:' '2:new name:' ;;
                config:set) _arguments '1:key:' '2:value:' ;;
            esac
            ;;
    esac
}

_shaarli "$@"
