#compdef laravel

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'new:create a new Laravel project'
  'list:list available commands'
  'help:show help for a command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-n --no-interaction)'{-n,--no-interaction}'[no interactive prompts]' \
  '--ansi[force ANSI output]' \
  '--no-ansi[disable ANSI output]' \
  '*-v[verbose (repeat for more)]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'laravel subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (new)
        _arguments \
          '--dev[install latest dev release]' \
          '--git[init git repo]' \
          '--branch=[default branch name]:branch:' \
          '--github=[create GitHub repo]:name:' \
          '--organization=[GitHub org]:org:' \
          '--database=[database driver]:driver:(mysql mariadb pgsql sqlite sqlsrv)' \
          '--react[React starter kit]' \
          '--vue[Vue starter kit]' \
          '--svelte[Svelte starter kit]' \
          '--livewire[Livewire starter kit]' \
          '--livewire-class-components[Livewire class components]' \
          '--workos[WorkOS auth]' \
          '--teams[Jetstream team support]' \
          '--no-authentication[skip authentication scaffolding]' \
          '--pest[use Pest testing]' \
          '--phpunit[use PHPUnit testing]' \
          '--npm[use npm]' \
          '--pnpm[use pnpm]' \
          '--bun[use bun]' \
          '--yarn[use yarn]' \
          '--boost[install Laravel Boost]' \
          '--no-boost[skip Laravel Boost]' \
          '--using=[community starter kit]:package:' \
          '(-f --force)'{-f,--force}'[overwrite existing directory]' \
          ':project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
