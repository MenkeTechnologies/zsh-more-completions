#compdef logss

# Zsh completion for logss (log stream viewer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --command)'{-c,--command=}'[command to run]:command:_command_names' \
  '(-r --render)'{-r,--render=}'[render mode]:mode:(raw smart)' \
  '(-t --trigger)'{-t,--trigger=}'[trigger regex pattern]:regex:' \
  '(-n --lines)'{-n,--lines=}'[number of lines to show]:lines:' \
  '(-C --containers)'{-C,--containers}'[show docker container names]' \
  '*:input file:_files' && ret=0

return ret
