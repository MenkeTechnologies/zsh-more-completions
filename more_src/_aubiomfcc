#compdef aubiomfcc

# aubiomfcc: extract MFCC (mel-frequency cepstral coefficients) from audio
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-i[input audio file]:file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3)"' \
  '--input=[input file]:file:_files' \
  '-n[number of MFCC coefficients]:n:' \
  '--mfcc-coeffs=[number of MFCC coefficients]:n:' \
  '-N[FFT size]:n:' \
  '--bufsize=[FFT size]:n:' \
  '-H[hop size]:n:' \
  '--hopsize=[hop size]:n:' \
  '-r[sample rate]:n:' \
  '--samplerate=[sample rate]:n:' \
  '-v[verbose output]' \
  '--verbose[verbose]' \
  '*:input audio file:_files' && ret=0
return ret
