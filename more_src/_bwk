#compdef bwk
# Documentation: https://github.com/onetrueawk/awk
# the one true awk (bwk awk)

local ret=1

_arguments -s \
  '-F+[set input field separator regular expression]:field separator' \
  '*-v+[assignment done before prog is executed]:assignment:_vars' \
  '*-f+[read program from file]:program file:_files' \
  '--csv[process input as comma-separated values]' \
  '-safe[disable file output, process creation, environment access]' \
  '-d-[enable debug mode with optional level]::level' \
  '(- *)-version[show version and exit]' \
  '(- *)--version[show version and exit]' \
  '1:program text' \
  '*::argument:_files' && ret=0

return ret
