#compdef afl-stats
# Documentation: https://github.com/rc0r/afl-utils
# Gather and post afl-fuzz statistics (afl-utils)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'=[afl-stats config file]:file:_files' \
  '(-d --database)'{-d,--database}'=[dump stats history into database]:db:_files' \
  '(-t --twitter)'{-t,--twitter}'[post stats to twitter]' \
  '(-q --quiet)'{-q,--quiet}'[suppress any output]' && ret=0

return ret
