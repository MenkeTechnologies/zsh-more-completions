#compdef seealso
# Documentation: https://man.archlinux.org/search?q=seealso
# Reference accessed: 2026-05-16

# EMBOSS seealso: list other applications in the same EMBOSS group(s)
# as the named program. Useful for discovering related tools.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-search=[program name(s) to find related applications for]:program:' \
  '-explode[expand each program into its underlying group set]' \
  '-showembassy=[restrict to applications in named EMBASSY package(s)]:packages:' \
  '-html[output an HTML formatted table]' \
  '-groups[show group names instead of programs]' \
  '-emboss[include EMBOSS-installed programs]' \
  '-embassy[include EMBASSY add-on packages]' \
  '-outfile=[output file]:file:_files' \
  '*:program name:' && ret=0

return ret
