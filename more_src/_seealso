#compdef seealso
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/seealso.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS seealso: list other applications in the same EMBOSS group(s)
# as the named program.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' \
  '-auto[no prompts]' \
  '-stdout[output to stdout]' \
  '-filter[stdin/stdout filter mode]' \
  '-options[prompts for optional qualifiers]' \
  '-debug[debug output]' \
  '-verbose[verbose output]' \
  '-warning[warnings]' \
  '-error[errors]' \
  '-fatal[fatal errors]' \
  '-die[errors on dying]' \
  '-version[version]' \
  '-search=[program name(s) to find related applications for]:program:' \
  '-explode[expand each program into its underlying group set]' \
  '-showembassy=[restrict to applications in named EMBASSY package(s)]:packages:' \
  '-html[output as HTML formatted table]' \
  '-groups[show group names instead of programs]' \
  '-emboss[include EMBOSS-installed programs]' \
  '-noemboss[exclude EMBOSS-installed programs]' \
  '-embassy[include EMBASSY add-on packages]' \
  '-noembassy[exclude EMBASSY add-on packages]' \
  '-colon[place colons between primary and secondary group levels]' \
  '-outfile=[output file]:file:_files' \
  '-odirectory=[output directory]:dir:_directories' && ret=0

return ret
