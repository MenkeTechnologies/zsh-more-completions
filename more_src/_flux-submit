#compdef flux-submit
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-submit.html
# submit a job to a Flux instance

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-N --nodes)'{-N,--nodes=}'[set number of nodes]:nodes' \
  '(-x --exclusive)'{-x,--exclusive}'[allocate nodes exclusively]' \
  '(-n --ntasks)'{-n,--ntasks=}'[set number of tasks to launch]:ntasks' \
  '(-c --cores-per-task)'{-c,--cores-per-task=}'[cores per task]:cores' \
  '(-g --gpus-per-task)'{-g,--gpus-per-task=}'[GPU devices per task]:gpus' \
  '--cores=[set total number of cores]:cores' \
  '--tasks-per-node=[set tasks per node]:n' \
  '--gpus-per-node=[GPUs per node]:n' \
  '--tasks-per-core=[force tasks per allocated core]:n' \
  '(-q --queue)'{-q,--queue=}'[submit to named queue]:queue' \
  '(-B --bank)'{-B,--bank=}'[set bank name]:bank' \
  '(-t --time-limit)'{-t,--time-limit=}'[set job time limit]:minutes|FSD' \
  '--job-name=[set alternate job name]:name' \
  '--flags=[set submission flags]:flags' \
  '--input=[redirect stdin from file or ranks]:input' \
  '--output=[stdout filename template]:template' \
  '--error=[stderr filename template]:template' \
  '(-u --unbuffered)'{-u,--unbuffered}'[disable I/O buffering]' \
  '(-l --label-io)'{-l,--label-io}'[prefix output lines with task rank]' \
  '*--requires=[resource matching constraint]:constraint' \
  '*--dependency=[job dependency URI]:uri' \
  '*--env=[control environment variable export]:rule' \
  '*--env-remove=[remove matching environment variables]:pattern' \
  '--env-file=[read environment rules from file]:file:_files' \
  '*--rlimit=[control resource limit propagation]:rule' \
  '--cwd=[set job working directory]:dir:_files -/' \
  '--urgency=[set job urgency]:n' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '*'{-o,--setopt=}'[set shell option]:key[=val]' \
  '*'{-S,--setattr=}'[set jobspec attribute]:key[=val]' \
  '*--add-file=[add file to job archive]:spec' \
  '--begin-time=[set begin-time dependency]:time' \
  '--signal=[send signal before time limit]:sig@time' \
  '--dry-run[emit jobspec without submitting]' \
  '--debug[enable job debug events]' \
  '--taskmap=[task-to-node mapping method]:scheme' \
  '--cc=[replicate job per idset value]:idset' \
  '--bcc=[replicate job per idset without FLUX_JOB_CC]:idset' \
  '--quiet[suppress jobid logging]' \
  '--log=[log output and stderr to file]:file:_files' \
  '--log-stderr=[separate stderr to file]:file:_files' \
  '--wait[wait for job completion before exiting]' \
  '--wait-event=[wait until job receives event]:event' \
  '--watch[display output from all jobs]' \
  '--progress[show progress bar]' \
  '--jps[display throughput stats with --progress]' \
  '*::command:_command_names -e' && ret=0

return ret
