#compdef massren

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config[show or set configuration]' \
  '--undo[undo last rename]' \
  '--dry-run[simulate rename without making changes]' \
  '--editor[set editor to use]:editor:_command_names' \
  '--verbose[enable verbose output]' \
  '*:file or directory:_files' && ret=0

return ret
