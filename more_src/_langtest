#compdef langtest
# Documentation: https://github.com/JohnSnowLabs/langtest
# Reference accessed: 2026-05-23
# Verified: langtest --help (Click CLI).

# Zsh completion for langtest - LangTest LLM and NLP evaluation CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'langtest command' \
      'benchmark[benchmark NLP and LLM models on datasets]' \
      'config[manage langtest configurations]' \
      'eval[initialize langtest leaderboard]' \
      'generate[generate testcases]' \
      'init[initialize new langtest project]' \
      'report[generate report]' \
      'run[run testcases]' \
      'show-leaderboard[show leaderboard]' && ret=0
    ;;
esac

return ret
