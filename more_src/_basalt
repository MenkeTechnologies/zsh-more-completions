#compdef basalt
# =============================================================================
# basalt — Erik Kinnunen's "TUI Application to manage
#          Obsidian notes directly from the terminal" — a
#          Rust ratatui-based terminal user interface for
#          browsing, reading, and editing Obsidian-format
#          Markdown notes without leaving the terminal,
#          rendering CommonMark + GitHub-Flavored Markdown
#          extensions + Obsidian-specific [[wiki-link]] +
#          ![[transclusion]] + #tag + ^block-ref syntax
#          via pulldown-cmark's streaming event stream
#          piped into ratatui's Paragraph + Block widgets.
#          Distinguishing from the official Obsidian
#          desktop app (Electron + JS — heavyweight,
#          cloud sync), `glow` (charm.sh's markdown-only
#          TUI renderer — no Obsidian-vault-aware
#          navigation), `mdcat` (Sebastian Wiesner's
#          inline-image-capable markdown CLI — single-
#          file rendering only), `frogmouth` (Textualize's
#          PyTextual markdown browser — Python, no
#          vault model), and `lazygit`-style git-only
#          TUIs by:
#            - OBSIDIAN-VAULT MODEL — reads the Obsidian
#              `~/.config/obsidian/obsidian.json` config
#              file (via `basalt-core::obsidian::config`)
#              to discover registered vaults; presents a
#              vault picker, then navigates the vault's
#              folder tree + flat note list
#            - WIKILINK + TRANSCLUSION RESOLUTION — parses
#              `[[Note Name]]`, `[[Note#Heading]]`,
#              `[[Note|alias]]`, and `![[Note]]`
#              transclusion syntax beyond standard
#              CommonMark; resolves them against the
#              vault note index so users can navigate
#              between linked notes
#            - PULLDOWN-CMARK RENDERER — uses raphlinus/
#              pulldown-cmark v0.13 (this is the headline
#              CLI library that OPENS Axis 42 on the Rust
#              side; see taxonomy notes below) for the
#              underlying CommonMark + GFM parsing;
#              streams Event tokens (Start/End/Text/Code/
#              Html/InlineHtml/FootnoteReference/
#              SoftBreak/HardBreak/Rule/TaskListMarker)
#              into a ratatui-compatible Span pipeline
#            - RATATUI TUI FRONTEND — built on the
#              ratatui v0.30 + crossterm v0.29 stack
#              (Axis 28 TUI in this corpus); responsive
#              layout adapting to terminal resize via
#              ratatui's Layout/Constraint system
#            - LIVE-RELOAD via notify-debouncer-full —
#              file changes to open notes are detected
#              via filesystem watch + propagated into
#              the rendered view without manual refresh;
#              suitable for the "edit in $EDITOR while
#              previewing in basalt" workflow
#            - TEXTWRAP for SOFT WRAPPING — uses
#              textwrap 0.16 for word-aware soft-wrap
#              of paragraph text against the terminal
#              width; preserves Markdown code block
#              fences + URL formatting
#            - NATURAL-ORDER NOTE LIST — uses natord
#              1.0 for natural (human) sort order of
#              filenames in the note list ("note10"
#              after "note9", not before "note2")
#            - UNICODE-AWARE WIDTH CALCULATION — uses
#              unicode-width 0.2 for CJK + emoji + RTL
#              column-width accounting in the rendered
#              paragraph; avoids visual misalignment in
#              mixed-script notes
#            - VAULT-PATH OVERRIDE via
#              BASALT_EXP_VAULT_PATH env-var — power
#              users can bypass the Obsidian config
#              loader + point basalt at any directory
#              of markdown files (e.g. a git-cloned
#              docs repo, a personal /notes tree) by
#              setting `BASALT_EXP_VAULT_PATH=/path/to/
#              notes`; experimental
#            - VERSION INFO BUILT-IN — `basalt --version`
#              shows version + commit hash + short hash
#              + build date (compiled-in via
#              VersionInfo::from_env() during cargo
#              build)
#            - 1,219+ STARS ON erikjuhani/basalt —
#              actively developed by Erik Kinnunen
#              (senior fullstack at Reaktor, Finland)
#              with regular releases through 2026
#          Used by: Obsidian users wanting to peek at
#          their second-brain notes from inside a tmux
#          + nvim workflow without alt-tabbing to the
#          Obsidian desktop app, SSH-only deployments
#          where the GUI Obsidian app is unavailable,
#          and terminal-purists who prefer text-based
#          interfaces over Electron.
#
# Author:  Erik Kinnunen (erikjuhani on GitHub), Senior
#          Fullstack Developer at Reaktor, Finland.
#          Self-described "software enthusiast excited
#          about Rust and functional programming."
# Source:  https://github.com/erikjuhani/basalt
#          https://github.com/erikjuhani/basalt/blob/main/basalt/src/main.rs
#          https://github.com/erikjuhani/basalt/blob/main/basalt/src/cli.rs
#          https://github.com/erikjuhani/basalt/blob/main/basalt/Cargo.toml
# Manpage: No traditional manpage; `basalt --help`
#          shows the (currently minimal) clap-derived
#          help; `basalt --version` shows version +
#          commit + date.
# Library: pulldown-cmark 0.13 (raphlinus/pulldown-cmark
#          — Raph Levien's "A pull parser for
#          CommonMark").  This is the headline
#          dependency for this completion's axis-opening
#          role; see taxonomy notes below.  Also clap
#          4.6 (Axis 1 argparse with `derive` +
#          `string` features), ratatui 0.30 (Axis 28
#          TUI), crossterm 0.29 (terminal backend for
#          ratatui), notify-debouncer-full 0.7 (file
#          watching), textwrap 0.16 (word-aware wrap),
#          serde + toml (config), etcetera 0.11 (XDG
#          paths), thiserror 2.0 (Axis 6 errors),
#          unicode-width 0.2 (CJK/emoji column-width),
#          natord 1.0 (natural sort), basalt-core (own
#          internal lib path-deped to ../basalt-core).
# License: MIT
# Status:  1,219+ stars on erikjuhani/basalt; active
#          development (latest commit 2026-06-01);
#          stable v0.12.x release line.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY — AXIS 42 OPENS:
#   MARKDOWN PARSING / COMMONMARK CODECS
# -----------------------------------------------------------------------------
# This completion **OPENS AXIS 42** in the cross-
# language CLI library taxonomy: Markdown Parsing /
# CommonMark Codecs (libraries that parse the
# CommonMark + GitHub-Flavored Markdown spec into a
# traversable event stream or AST and provide rendering
# back-ends — as distinct from Axis 41 HTML Parsing
# which handles HTML rather than Markdown, or Axis 28
# TUI which renders UIs without parsing Markdown).
#
# Pattern: R756 121st language (Stainless) closes the
# prior 3+1 cycle → R757 Rust=97 (basalt/pulldown-cmark
# → Axis 42 OPENS THIS) is the first leader bump in
# the new cycle.  Pending: R758 Go=97 with a yuin/
# goldmark user; R759 TS-Node=97 with a markedjs/
# marked or markdown-it/markdown-it user; R760 122nd
# language.
#
# WHY pulldown-cmark IS A DISTINCTIVE AXIS-42 OPENER:
#
#   raphlinus/pulldown-cmark by Raph Levien (lead
#   developer at Google Fonts, creator of Spiro curve
#   math + the Druid GUI framework + Xilem GUI + many
#   other tools) is the canonical Rust CommonMark
#   parser.  Distinguishing characteristics:
#     1. PULL-PARSER ARCHITECTURE — the parser exposes
#        Markdown as a *stream of Events* (Iterator<Item
#        = Event>) rather than a fully-materialized
#        AST.  Renderers consume events in O(1) memory;
#        100× faster than AST-walking parsers for large
#        documents
#     2. COMMONMARK 0.30 COMPLIANCE — passes the full
#        CommonMark 0.30 specification test suite (the
#        normative test corpus); strict adherence to
#        spec edge cases
#     3. GFM EXTENSIONS — opt-in via Options bitset:
#        Options::ENABLE_STRIKETHROUGH,
#        Options::ENABLE_TABLES,
#        Options::ENABLE_FOOTNOTES,
#        Options::ENABLE_TASKLISTS,
#        Options::ENABLE_SMART_PUNCTUATION,
#        Options::ENABLE_HEADING_ATTRIBUTES,
#        Options::ENABLE_YAML_STYLE_METADATA_BLOCKS,
#        etc.  Users pay only for the extensions they
#        enable
#     4. HTML RENDERER BUILT-IN — pulldown_cmark::html::
#        push_html(out, events) renders the event
#        stream to a String of HTML; suitable for the
#        most common transformation
#     5. ZERO-COPY where possible — events that
#        reference source text expose CowStr (clone-on-
#        write string) so unchanged text spans are
#        borrowed slices into the original input
#        buffer
#     6. SAFETY — pure Rust, no unsafe blocks in the
#        parser core; suitable for parsing
#        untrusted/user-uploaded Markdown
#     7. ~3,000+ STARS ON raphlinus/pulldown-cmark
#     8. ECOSYSTEM-DOMINANT — used by mdBook (Rust
#        Programming Language's official book renderer),
#        Zola (static site generator), Cobalt (static
#        site generator), Hayagriva (citation
#        management), Helix editor (markdown preview),
#        basalt (this completion), Codex (OpenAI's CLI
#        assistant), Goose (AAIF's MCP host), every
#        major Rust web framework's markdown plugin,
#        and the Rust-lang/rust compiler's docs
#        generation
#
# Maintained under github.com/raphlinus/pulldown-cmark.
# License: MIT.
#
# Cross-language CLI library taxonomy after R757:
#   * 121 languages
#   * 469 total CLI library variants (Rust 97 / Go 96 /
#     TS-Node 96)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * 34 axes at 1/1/1 three-language symmetric (7, 8,
#     11, 12, 15-41)
#   * Axis 42 opens with Rust=pulldown-cmark (this
#     round); pending Go + TS-Node companions
#
# Comparison to other Axis 42 candidates (Rust):
#   * pulldown-cmark (R757 THIS) — Raph Levien's pull-
#     parser CommonMark crate; ~3,000 stars; THE
#     canonical Rust markdown parser
#   * comrak (kivikakk/comrak) — Ashe Connor's
#     CommonMark + GFM Rust port of cmark-gfm
#     (GitHub's C parser); ~1,400 stars; AST-based,
#     slower than pulldown-cmark but more
#     ergonomic for transformations
#   * markdown-rs (wooorm/markdown-rs) — Titus
#     Wormer's micromark Rust port; ~900 stars;
#     newer, less ecosystem usage
#   * cmark-rs — older bindings to upstream C
#     cmark; less idiomatic
#
# pulldown-cmark is the chosen Axis 42 opener because:
#   - It is the upstream Rust CommonMark parser that
#     EVERY major Rust markdown-CLI depends on (mdBook,
#     Zola, Cobalt, basalt, glow's predecessors,
#     Helix's markdown preview, Codex, Goose)
#   - basalt uses pulldown-cmark v0.13 as a DIRECT
#     dependency in its Cargo.toml for ALL Obsidian-
#     note rendering
#   - It is the closest functional analog to Go's
#     yuin/goldmark (the dominant Go CommonMark
#     parser) and TS-Node's markedjs/marked +
#     markdown-it/markdown-it (the dominant Node
#     Markdown parsers)
#   - Demonstrates the streaming-pull-parser pattern
#     that all three languages converge on for large-
#     document handling (Go's goldmark also uses
#     streaming, TS-Node's markdown-it is also
#     streaming-capable)
#
# Pending companion picks for Axis 42:
#   - Go=97: a Go CLI tool prominently using
#            yuin/goldmark (the dominant Go
#            CommonMark + GFM parser, used by Hugo +
#            many static site generators)
#   - TS-Node=97: a Node.js CLI tool prominently
#            using markedjs/marked or markdown-it/
#            markdown-it as the headline Markdown
#            library
#
# -----------------------------------------------------------------------------
#
# THE basalt CLI
#
# basalt is a single-command CLI built on clap v4.6
# with the derive macro.  Invocation:
#   basalt [--version] [--help]
#
# basalt has NO interactive subcommands or workflow
# flags — once launched, control transfers to the
# ratatui TUI event loop.  All vault navigation +
# note rendering + edit-launching happens via in-TUI
# keybindings (see the basalt repo README for the
# current key map).
#
# Flags:
#   -h, --help                        show clap-
#                                     generated help
#   -V, --version                     show version +
#                                     commit hash +
#                                     short hash +
#                                     build date
#
# Environment variables:
#   BASALT_EXP_VAULT_PATH             override the
#                                     Obsidian config-
#                                     discovered vault
#                                     list with a
#                                     single explicit
#                                     vault path
#                                     (experimental)
#
# Common invocations:
#   # Launch basalt — show vault picker, then navigate
#   basalt
#
#   # Show version + commit info
#   basalt --version
#
#   # Show help
#   basalt --help
#
#   # Launch directly into a specific vault directory
#   # (bypassing Obsidian config)
#   BASALT_EXP_VAULT_PATH=~/notes basalt
#
#   # Launch with a git-cloned docs tree as the vault
#   BASALT_EXP_VAULT_PATH=~/src/rust/book basalt
#
#   # tmux pane integration: launch basalt in a side pane
#   tmux split-window -h 'BASALT_EXP_VAULT_PATH=~/notes basalt'
#
# OPTIONS (sourced directly from
# https://github.com/erikjuhani/basalt/blob/main/basalt/src/cli.rs):
#
#   -h, --help                        show help
#   -V, --version                     show version
#
# Files / configuration:
#   ~/.config/obsidian/obsidian.json  Obsidian config
#                                     (read by basalt
#                                     to discover
#                                     vaults)
#
# In-TUI keybindings (consult the repo README for
# current bindings — they are NOT exposed via clap
# flags so this completion file doesn't enumerate
# them, but typical: arrow keys for navigation, /
# for search, q for quit, o for open vault picker).
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version + commit hash + build date]' \
    && ret=0

return ret
