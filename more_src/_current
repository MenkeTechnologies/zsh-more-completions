#compdef current gmx-current
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-current.html
# gmx current: calculate dielectric constants and current autocorrelation function

local ret=1

_arguments -s \
  '-s[structure+mass(db) file]:file:_files' \
  '-n[index file]:file:_files' \
  '-f[trajectory file]:file:_files' \
  '-o[primary xvgr/xmgr output]:file:_files' \
  '-caf[current autocorrelation function]:file:_files' \
  '-dsp[displacement file]:file:_files' \
  '-md[dipole moment data file]:file:_files' \
  '-mj[mean jump file]:file:_files' \
  '-mc[moment correlation file]:file:_files' \
  '-b[beginning time for trajectory reading]:time:' \
  '-e[ending time for trajectory reading]:time:' \
  '-dt[frame sampling interval]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-sh[frame shift for averaging correlations]:int:' \
  '-nojump[remove periodic box jumps]' \
  '-eps[surrounding medium dielectric constant]:real:' \
  '-bfit[MSD fit start point]:real:' \
  '-efit[MSD fit end point]:real:' \
  '-bvit[current autocorrelation fit beginning]:real:' \
  '-evit[current autocorrelation fit ending]:real:' \
  '-temp[temperature for dielectric calculations]:real:' && ret=0

return ret
