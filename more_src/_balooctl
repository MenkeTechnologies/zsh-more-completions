#compdef balooctl
# _balooctl — KDE balooctl CLI controlling the Baloo file index daemon for KDE Plasma desktop searching status enable disable suspend resume purge config check show index size index path inclusion exclusion filters mime patterns for the Xapian-backed file content index (KDE team, C++); custom argparse
# upstream: https://invent.kde.org/frameworks/baloo

_balooctl() {
    local -a sub=(
        'status:show indexer status'
        'enable:enable indexer'
        'disable:disable indexer'
        'purge:purge all data and re-index'
        'suspend:suspend indexer'
        'resume:resume indexer'
        'check:check index integrity'
        'config:get/set baloo configuration'
        'index:index given file or directory'
        'monitor:monitor indexer in real-time'
        'failed:list files that failed to index'
        'clear:clear index for given files'
        'indexSize:show on-disk index size'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'balooctl subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments \
                    '1:op:(show set add remove)' \
                    '2:key:(contentIndexing onlyBasicIndexing exclude include excludeFolders includeFolders excludeFilters excludeMimetypes)' \
                    '*:value:' ;;
                index|clear) _arguments '*:path:_files' ;;
            esac
            ;;
    esac
}

_balooctl "$@"
