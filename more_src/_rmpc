#compdef rmpc

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'addrandom:add random songs'
  'config:print default config'
  'theme:print default theme'
  'lyricsindex:index lyrics directory'
  'update:scan music dir for updates'
  'rescan:rescan including unmodified files'
  'albumart:save current album art'
  'debuginfo:print runtime info'
  'version:show version'
  'queue:print current queue'
  'listall:list files from DB'
  'play:play song at position'
  'pause:pause playback'
  'unpause:unpause playback'
  'togglepause:toggle play/pause'
  'stop:stop playback'
  'next:play next song'
  'prev:play previous song'
  'volume:set volume'
  'repeat:set repeat mode'
  'random:set random mode'
  'single:set single mode'
  'consume:set consume mode'
  'togglerepeat:toggle repeat'
  'togglerandom:toggle random'
  'togglesingle:toggle single'
  'toggleconsume:toggle consume'
  'seek:seek current song'
  'clear:clear queue'
  'add:add song'
  'addyt:add YouTube song'
  'searchyt:search and add YouTube'
  'save:save queue as playlist'
  'load:load playlist'
  'outputs:list outputs'
  'toggleoutput:toggle output'
  'enableoutput:enable output'
  'disableoutput:disable output'
  'decoders:list decoders'
  'status:playback status'
  'song:current song info'
  'mount:mount storage'
  'unmount:unmount storage'
  'listmounts:list mounts'
  'listpartitions:list partitions'
  'sticker:song stickers'
  'remote:send command to running rmpc'
  'sendmessage:send message to channel'
  'help:show help'
)

_arguments -C \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-t --theme)'{-t,--theme=}'[theme file]:file:_files' \
  '--clean[skip user config]' \
  '(-a --address)'{-a,--address=}'[MPD address]:addr:' \
  '(-p --password)'{-p,--password=}'[MPD password]:pw:' \
  '--partition=[partition]:name:' \
  '--autocreate[auto-create partition]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rmpc subcommand' subcommands && ret=0
    ;;
esac

return ret
