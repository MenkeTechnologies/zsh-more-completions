#compdef condor_wait
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_wait.html
# wait for one or more jobs to finish from a job event log

local ret=1

_arguments -s -S \
  '(-help)-help[display usage information]' \
  '(-version)-version[display version information]' \
  '-debug[show extra debugging information]' \
  '-status[show job start and terminate information]' \
  '-echo[print the events out to stdout]' \
  '-wait[wait no more than the given number of seconds]:seconds' \
  '-num[wait for the given number of jobs to end]:number-of-jobs' \
  '-allevents[continue reading the log even after all jobs have ended]' \
  '1:log file:_files' \
  '*:job-ID' && ret=0

return ret
