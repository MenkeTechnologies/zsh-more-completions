#compdef sea-orm-cli sea-orm

local curcontext="$curcontext" state line ret=1

_sea_orm_commands() {
  local -a commands=(
    'generate:generate entity files from database'
    'migrate:run database migrations'
  )
  _describe -t commands 'sea-orm-cli command' commands
}

_sea_orm_generate_commands() {
  local -a commands=(
    'entity:generate entity files from database'
  )
  _describe -t commands 'generate subcommand' commands
}

_sea_orm_migrate_commands() {
  local -a commands=(
    'init:initialize migration directory'
    'generate:generate a new migration file'
    'up:apply pending migrations'
    'down:rollback applied migrations'
    'status:check migration status'
    'fresh:drop all tables and reapply all migrations'
    'refresh:rollback all migrations and reapply'
  )
  _describe -t commands 'migrate subcommand' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:_sea_orm_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      generate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:_sea_orm_generate_commands' \
          '*::arg:->generate_args' && ret=0
        case $state in
          generate_args)
            case $words[1] in
              entity)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[show help]' \
                  '(-u --database-url)'{-u,--database-url}'[database URL]:url' \
                  '(-s --database-schema)'{-s,--database-schema}'[database schema]:schema' \
                  '(-o --output-dir)'{-o,--output-dir}'[output directory]:dir:_files -/' \
                  '--with-serde[derive serde traits]:mode:(none serialize deserialize both)' \
                  '--expanded-format[generate entity in expanded format]' \
                  '--include-hidden-tables[include hidden tables]' \
                  '(-t --tables)'{-t,--tables}'[tables to generate]:tables' \
                  '--ignore-tables[tables to ignore]:tables' \
                  '--max-connections[max database connections]:count' \
                  '--model-extra-derives[extra derive macros for model]:derives' \
                  '--date-time-crate[date time crate]:crate:(chrono time)' \
                  '--lib[generate lib.rs instead of mod.rs]' \
                  '--serde-skip-deserializing-primary-key[skip deserializing primary key]' \
                  '--serde-skip-hidden-column[skip hidden columns in serde]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      migrate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:_sea_orm_migrate_commands' \
          '*::arg:->migrate_args' && ret=0
        case $state in
          migrate_args)
            _arguments -s -S \
              '(-h --help)'{-h,--help}'[show help]' \
              '(-u --database-url)'{-u,--database-url}'[database URL]:url' \
              '(-d --migration-dir)'{-d,--migration-dir}'[migration directory]:dir:_files -/' \
              '(-s --database-schema)'{-s,--database-schema}'[database schema]:schema' \
              '(-n --num)'{-n,--num}'[number of migrations]:count' && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
