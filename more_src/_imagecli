#compdef imagecli
# ============================================================================
# imagecli - command-line image processing
#             tool with pipeline DSL
#             (Rust, MIT)
#
# Author : Phil Ellison (theotherphil)
# Upstream: https://github.com/theotherphil/imagecli
#
# `imagecli` is a command-line image
# processing tool that applies sequences of
# image operations to one or more input
# files via a concise pipeline DSL inspired
# by ImageMagick's convert + GraphicsMagick.
# Built on the canonical Rust image-rs +
# imageproc ecosystem.
#
# Pipeline DSL examples:
#   - Resize + grayscale + save:
#       imagecli -i input.png -o output.png \
#         -p "resize 300 200 > gray"
#   - Blur + threshold:
#       imagecli -i input.png -o output.png \
#         -p "gaussian 2.0 > threshold 128"
#   - Multiple inputs + outputs:
#       imagecli -i 'photos/*.jpg' \
#         -o 'thumbs/' \
#         -p "resize-w 200"
#
# Distinguishing features vs alternatives
# (ImageMagick + GraphicsMagick + ffmpeg
# image filters):
#   - **Pure Rust** (single binary; no
#     ImageMagick dependency)
#   - **Pipeline DSL** (compact + readable
#     vs ImageMagick's complex argument
#     order)
#   - **Glob pattern input** (process
#     directories of images with one
#     command)
#   - **Memory safety** (no buffer
#     overflows + use-after-free + format
#     parsing CVE classes that have
#     historically affected ImageMagick)
#   - **image-rs ecosystem** (broad format
#     support + active maintenance)
#
# Supported operations (pipeline DSL):
#   - **Resize**: resize WIDTH HEIGHT +
#     resize-w WIDTH + resize-h HEIGHT
#   - **Crop**: crop X Y WIDTH HEIGHT
#   - **Rotate**: rotate90 + rotate180 +
#     rotate270 + rotate ANGLE
#   - **Flip**: flip-h + flip-v
#   - **Color**: gray + invert
#   - **Filters**: gaussian SIGMA + median
#     RADIUS + sharpen + blur
#   - **Edge detection**: canny + sobel
#   - **Threshold**: threshold VALUE +
#     adaptive-threshold + otsu
#   - **Morphology**: dilate + erode +
#     open + close
#   - **Drawing**: rect X Y W H COLOR +
#     line + circle
#   - **Annotate**: text "STRING" FONT
#     SIZE X Y COLOR
#   - **Composite**: overlay INPUT_INDEX X Y +
#     side-by-side
#   - **Histogram**: histogram (visualize
#     image histogram)
#   - **Color quantization**: median-cut
#     COLORS
#
# Use cases:
#   - Batch thumbnail generation
#   - Image preprocessing for ML pipelines
#     (grayscale + normalize + crop)
#   - Format conversion (PNG ↔ JPEG ↔
#     WebP + many others via image-rs
#     format detection)
#   - Quick image inspection workflows
#     (histogram + edge detection +
#     thresholding in one pipeline)
#   - CI/CD image asset processing (web
#     asset optimization)
#
# Usage:
#   imagecli [-v] -i <input>... -o <output>... -p <pipeline>
#   imagecli --generate-guide
#
# Flags (structopt):
#   -v, --verbose                  - enable
#                                     verbose
#                                     logging
#   -i, --input <file>             - input
#                                     files
#                                     or
#                                     glob
#                                     patterns
#                                     (repeatable)
#   -o, --output <file>            - output
#                                     files
#                                     (repeatable)
#   -p, --pipeline <string>        - image
#                                     processing
#                                     pipeline
#                                     (pipeline
#                                     DSL
#                                     operations
#                                     separated
#                                     by >)
#       --generate-guide           - regenerate
#                                     the user
#                                     guide
#                                     documentation
#                                     (developer
#                                     workflow)
#   -h, --help                     - show
#                                     help
#   -V, --version                  - show
#                                     version
#
# Example invocations:
#   # Resize a single image
#   imagecli -i in.png -o out.png \
#     -p "resize 800 600"
#
#   # Grayscale + Gaussian blur
#   imagecli -i in.png -o out.png \
#     -p "gray > gaussian 2.0"
#
#   # Batch thumbnail generation
#   imagecli -i 'photos/*.jpg' \
#     -o 'thumbs/' \
#     -p "resize-w 200"
#
#   # Edge detection pipeline
#   imagecli -i in.png -o edges.png \
#     -p "gray > gaussian 1.0 > canny 50 100"
#
#   # Threshold + invert
#   imagecli -i in.png -o out.png \
#     -p "gray > threshold 128 > invert"
#
#   # Multi-input composite
#   imagecli \
#     -i background.png \
#     -i overlay.png \
#     -o result.png \
#     -p "[1] overlay 0 100 200"
#
#   # Generate user guide (for
#   # contributors/maintainers)
#   imagecli --generate-guide
#
# The image-rs lane is built on `image =
# "0.22.2"` + `imageproc = "0.19.1"`
# (declared verbatim at upstream Cargo.toml
# HEAD as direct deps, imported by the
# entire src/ for image format I/O +
# pixel-level operations + filters + edge
# detection + morphology + drawing
# operations), the canonical Rust image
# processing ecosystem by Piston
# Developers + the image-rs maintainers -
# github.com/image-rs/image.
#
# image-rs/image is the de-facto canonical
# Rust image processing library:
#   - **Multi-format support** (PNG +
#     JPEG + GIF + WebP + BMP + TIFF +
#     TGA + ICO + PNM + HDR + DDS +
#     EXR + Farbfeld + AVIF + QOI +
#     ...)
#   - **Pure-Rust decoders** (no C-library
#     dependencies for most formats;
#     reduces attack surface vs
#     libpng/libjpeg/libwebp + their
#     historical CVE patterns)
#   - **Pluggable codec architecture**
#     (format support modules can be
#     compiled in/out via Cargo features
#     for binary size optimization)
#   - **Generic over pixel types** (Luma +
#     LumaA + Rgb + Rgba + arbitrary
#     channel layouts + 8/16/32-bit
#     depth)
#   - **6,200+ stars on github.com/
#     image-rs/image**
#   - **~10,000 reverse-deps on
#     crates.io (the canonical Rust
#     image processing ecosystem)**
#
# image-rs/image's distinguishing position
# vs Rust image processing alternatives:
#   - image-rs/image (PistonDevelopers +
#     image-rs maintainers): canonical;
#     multi-format; pure-Rust; THIS
#     AXIS
#   - imageproc (image-rs/imageproc):
#     companion crate by the same team
#     for higher-level operations
#     (filters + edge detection +
#     morphology + drawing + ...);
#     also used by imagecli
#   - rgb (kornelski/rust-rgb): pixel
#     primitive types; smaller scope
#   - libvips bindings: FFI to libvips
#     (high-performance C/C++ image
#     library); less idiomatic Rust
#   - resvg (linebender/resvg): SVG
#     rendering (smaller scope; not
#     raster processing)
#   - photon-rs (silvia-odwyer/photon):
#     WASM-friendly image processing
#     for browser deployment;
#     smaller scope
#
# The image-rs organization is a community
# Rust working group focused on the
# canonical image processing ecosystem.
# It originated from the PistonDevelopers
# game engine project's image needs but
# spun off into its own organization
# (image-rs) as adoption grew beyond the
# Piston ecosystem.
#
# Notable Pistion Developers core
# contributors who shaped image-rs:
#   - **Sven Nilsen (bvssvni)** - the
#     Piston project founder + early
#     image-rs contributor
#   - **HeroicKatora** - long-time
#     image-rs maintainer + format
#     decoder lead
#   - **fintelia** - image-rs maintainer
#     + format decoder contributor
#   - **theotherphil (Phil Ellison)** -
#     imageproc maintainer + author of
#     THIS AXIS CLI; long-time
#     image-rs contributor
#
# Phil Ellison (theotherphil) is the
# primary maintainer of imageproc + a
# major image-rs contributor. His role
# spans:
#   - **image-rs/imageproc** (canonical
#     Rust higher-level image processing
#     - filters + edge detection +
#     morphology + drawing; companion
#     to image-rs/image)
#   - **theotherphil/imagecli** (THIS
#     AXIS opener; the CLI consumer of
#     image + imageproc)
#   - **image-rs/image** (long-time
#     contributor)
#
# Ellison's role represents the
# *library-author + reference-CLI co-
# maintainership* pattern documented
# across many corpus axes (Hildebrand
# for CBOR; websockets org for ws +
# wscat; etc.).
#
# Multi-axis canonical-Rust author/org
# cohort extension (now spanning even
# more distinct authors):
#   - + Phil Ellison (theotherphil) +
#     PistonDevelopers + image-rs
#     organization (image-rs/image +
#     image-rs/imageproc + theotherphil
#     /imagecli; THIS AXIS; canonical
#     Rust image processing ecosystem
#     + reference CLI)
#
# Ellison + image-rs joining the
# canonical-Rust cohort at the *spec-
# implementer canonical organization*
# level continues the pattern of
# *coordinated multi-library single-
# organization* contributions documented
# across the corpus.
#
# imagecli uses image-rs/image for:
#   - Input format detection +
#     decoding (PNG + JPEG + WebP +
#     ... auto-detected from file
#     header)
#   - Output format encoding (target
#     format chosen from output
#     filename extension)
#   - Pixel buffer manipulation (the
#     pipeline DSL operations transform
#     ImageBuffer<P, Vec<u8>>
#     instances)
#
# imagecli uses image-rs/imageproc for:
#   - Filters (Gaussian + median +
#     sharpen + blur)
#   - Edge detection (Canny + Sobel)
#   - Morphology (dilate + erode +
#     open + close)
#   - Drawing operations (rectangles +
#     lines + circles + text)
#   - Threshold operations (Otsu +
#     adaptive)
#
# This is the canonical use case for
# image-rs in production Rust
# tooling: pipeline-style image
# manipulation where pure-Rust
# safety + cross-format support
# matter more than absolute peak
# performance (which would require
# specialized SIMD libraries like
# libvips).
#
# ----------------------------------------------------------------------------
# AXIS 289 :: Image processing libraries
#              (multi-format image I/O +
#              pixel-level manipulation +
#              filters + edge detection +
#              morphology + format
#              conversion)
# Round 1565 :: Rust slot 1 of 4 :: OPENS Axis 289
#
# Cross-language canonical library family
# for this axis (proposed):
#   Rust    : image-rs/image           - Piston
#                                          Developers +
#                                          image-rs
#                                          maintainers
#                                          (canonical
#                                          Rust image
#                                          ecosystem;
#                                          multi-
#                                          format)
#   Go      : disintegration/imaging   - Grigory
#                                          Dryapak
#                                          (canonical
#                                          Go
#                                          imaging
#                                          library;
#                                          high-
#                                          level
#                                          API)
#   TS/Node : lovell/sharp             - Lovell
#                                          Fuller
#                                          (canonical
#                                          Node
#                                          imaging
#                                          library;
#                                          libvips
#                                          bindings;
#                                          high
#                                          performance)
#
# Image processing is a *foundational
# building block* in production
# infrastructure:
#   - **Web frameworks** require thumbnail
#     generation
#   - **Mobile + desktop apps** require
#     image cropping + filtering
#   - **ML pipelines** require dataset
#     preprocessing (resize +
#     normalize + augment)
#   - **Content management** requires
#     format conversion + optimization
#   - **Print + publishing** requires
#     color space conversion + DPI
#     management
#
# Each canonical library provides:
#   - Multi-format I/O (PNG + JPEG +
#     WebP + AVIF + GIF + TIFF + ...)
#   - Pixel-level manipulation
#   - Common filters (blur + sharpen
#     + edge detection)
#   - Geometry operations (resize +
#     rotate + flip + crop)
#   - Color space conversion
#
# Use-case spectrum for this axis (so far):
#   - imagecli (Rust, image + imageproc):
#     command-line image processing tool
#     with pipeline DSL for batch
#     processing + thumbnail generation
#     + ML preprocessing
# ============================================================================

_imagecli() {
    _arguments \
        '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
        '*'{-i,--input}'=[input files or glob patterns]:file:_files -g "*.(png|jpg|jpeg|gif|webp|bmp|tiff|tga|ico|pnm|hdr|dds|exr|qoi|avif)"' \
        '*'{-o,--output}'=[output files]:file:_files' \
        '(-p --pipeline)'{-p+,--pipeline=}'[image processing pipeline DSL]:pipeline:' \
        '--generate-guide[regenerate the user guide documentation]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_imagecli "$@"
