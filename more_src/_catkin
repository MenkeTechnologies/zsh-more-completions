#compdef catkin
# Documentation: https://catkin-tools.readthedocs.io/en/latest/verbs/catkin_build.html
# command line tools for working with the catkin meta-buildsystem

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --workspace)'{-w,--workspace}'=[specify workspace path]:dir:_files -/' \
  '--profile=[select config profile]:profile:' \
  '(-n --dry-run)'{-n,--dry-run}'[list packages that would be built without building]' \
  '--this[build package in current working directory]' \
  '--no-deps[build only specified packages, excluding dependencies]' \
  '--unbuilt[build packages not yet constructed]' \
  '--start-with=[begin build from specified package onward]:package:' \
  '--start-with-this[start build with current package]' \
  '(-c --continue-on-failure)'{-c,--continue-on-failure}'[build packages with satisfied deps despite failures]' \
  '--get-env=[display build environment for package]:package:' \
  '--force-cmake[explicitly invoke cmake for each package]' \
  '--pre-clean[run make clean before building]' \
  '(-j --jobs)'{-j,--jobs}'=[maximum distributed build jobs]:jobs:' \
  '(-p --parallel-packages)'{-p,--parallel-packages}'=[maximum concurrent packages]:packages:' \
  '(-l --load-average)'{-l,--load-average}'=[maximum load threshold]:load:' \
  '--mem-limit=[restrict jobs based on available memory]:limit:' \
  '--cmake-args[pass arguments to CMake]:*::args:' \
  '--make-args[pass arguments to make]:*::args:' \
  '--catkin-make-args[arguments for catkin packages only]:*::args:' \
  '--save-config[persist configuration options]' \
  '(-v --verbose)'{-v,--verbose}'[display command output in ordered blocks]' \
  '(-i --interleave-output)'{-i,--interleave-output}'[show concurrent command output in real-time]' \
  '--no-status[suppress status line]' \
  '(-s --summarize --summary)'{-s,--summarize,--summary}'[display build summary]' \
  '--no-notify[suppress system notifications]' \
  '1:command:((
    build\:"build packages in a workspace"
    clean\:"clean products in a workspace"
    config\:"configure a workspace context"
    create\:"create catkin workspace components"
    init\:"initialize a workspace"
    list\:"list workspace packages"
    locate\:"get the location of workspace folders"
    profile\:"manage workspace build profiles"
    env\:"run a command with a modified environment"
    test\:"test packages in a workspace"
  ))' \
  '*::arg:->args' && ret=0

return ret
