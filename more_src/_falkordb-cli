#compdef falkordb-cli
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for FalkorDB CLI
# https://github.com/FalkorDB/FalkorDB

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--repo=[path to repository]:path:_files' \
  '--db=[database name]:db:' \
  '--host=[server host]:host:' \
  '--port=[server port]:port:' \
  '--query=[Cypher query]:query:' \
  '--version[show version]' \
  '--help[show help]' && ret=0

return ret
