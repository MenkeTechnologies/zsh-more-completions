#compdef helm-chartsnap
# Documentation: https://github.com/jlandowner/helm-chartsnap
# Helm plugin for snapshot testing of charts

local ret=1

_arguments -s -S \
  '(-c --chart)'{-c,--chart}'=[path to the chart directory]:dir:_files -/' \
  '*'{-f,--values}'=[path to a test values file or directory]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace' \
  '(-u --update-snapshot)'{-u,--update-snapshot}'[update snapshot mode]' \
  '--config-file=[config file name or path]:file:_files' \
  '(-N --ctx-lines)'{-N,--ctx-lines}'=[number of lines in diff output]:lines' \
  '--debug[debug mode]' \
  '--fail-helm-error[fail if helm template command failed]' \
  '--failfast[fail once any test case failed]' \
  '(-o --output-dir)'{-o,--output-dir}'=[directory where __snapshot__ is created]:dir:_files -/' \
  '--parallelism=[test concurrency]:n' \
  '--release-name=[release name]:name' \
  '--snapshot-version=[use specific snapshot format version]:version' \
  '(-v --version)'{-v,--version}'[version for chartsnap]' \
  '(-h --help)'{-h,--help}'[help for chartsnap]' \
  '*:arg:' && ret=0

return ret
