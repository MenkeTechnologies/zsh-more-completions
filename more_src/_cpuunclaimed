#compdef cpuunclaimed cpuunclaimed-bpfcc
# _cpuunclaimed — sample CPUs that have run-queue work but are idle (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/cpuunclaimed.py (argparse).

_cpuunclaimed() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-j --csv)'{-j,--csv}'[CSV output]'
        '(-J --fullcsv)'{-J,--fullcsv}'[full CSV (per-CPU rows)]'
        '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]'
        '1:interval (seconds):'
        '2:output count:'
    )
    _arguments $args
}

_cpuunclaimed "$@"
