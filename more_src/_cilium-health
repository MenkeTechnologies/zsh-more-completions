#compdef cilium-health
# Documentation: https://docs.cilium.io/en/stable/cmdref/cilium-health/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cilium-health: probe Cilium node-to-node connectivity
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'completion:generate autocompletion scripts'
  'get:get the local cilium agent status'
  'ping:verify cilium-health API endpoint is operational'
  'status:show node-to-node connectivity status'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-D,--debug}'[debug]' \
  {-H,--host=}'[host address (cilium-health server URI)]:addr:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'cilium-health command' commands && ret=0 ;;
esac
return ret
