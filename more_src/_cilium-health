#compdef cilium-health

# cilium-health: probe Cilium node-to-node connectivity
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'status:show connectivity status'
  'get:get node info'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-D[debug]' \
  '--debug[debug]' \
  '-H[host address]:addr:' \
  '--host=[host address]:addr:' \
  '--probe[probe (forced)]' \
  '--succinct[short output]' \
  '--verbose[verbose output]' \
  '--output=[output format]:fmt:(plain json yaml jsonpath)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'cilium-health command' commands && ret=0 ;;
esac
return ret
