#compdef mkbootimg
# Documentation: https://android.googlesource.com/platform/system/tools/mkbootimg (mkbootimg.py argparse)
# Reference accessed: 2026-05-29
# Android Boot Image creation tool.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kernel=[path to the kernel file]:file:_files' \
  '--ramdisk=[path to the ramdisk file]:file:_files' \
  '--second=[path to the second bootloader]:file:_files' \
  '--dtb=[path to the device tree blob]:file:_files' \
  '(--recovery_dtbo --recovery_acpio)--recovery_dtbo=[recovery DTBO file path]:file:_files' \
  '(--recovery_dtbo --recovery_acpio)--recovery_acpio=[recovery ACPIO file path]:file:_files' \
  '--cmdline=[kernel command line arguments]:cmdline:' \
  '--vendor_cmdline=[vendor boot kernel command line]:cmdline:' \
  '--base=[base memory address (default 0x10000000)]:addr:' \
  '--kernel_offset=[kernel offset (default 0x00008000)]:addr:' \
  '--ramdisk_offset=[ramdisk offset (default 0x01000000)]:addr:' \
  '--second_offset=[second bootloader offset (default 0x00f00000)]:addr:' \
  '--dtb_offset=[DTB offset (default 0x01f00000)]:addr:' \
  '--tags_offset=[tags offset (default 0x00000100)]:addr:' \
  '--board=[board name]:name:' \
  '--pagesize=[page size in bytes]:size:(2048 4096 8192 16384)' \
  '--header_version=[boot image header version]:version:(0 1 2 3 4)' \
  '--os_version=[operating system version]:version:' \
  '--os_patch_level=[OS patch level (YYYY-MM)]:date:' \
  '(-o --output)'{-o,--output=}'[output boot image file]:file:_files' \
  '--vendor_boot=[vendor boot output file]:file:_files' \
  '*--vendor_ramdisk=[vendor ramdisk file]:file:_files' \
  '--vendor_bootconfig=[vendor bootconfig file]:file:_files' \
  '--gki_signing_algorithm=[GKI signing algorithm (deprecated)]:algo:(SHA256_RSA2048 SHA256_RSA4096 SHA512_RSA2048 SHA512_RSA4096)' \
  '--gki_signing_key=[GKI RSA private key file (deprecated)]:file:_files' \
  '--gki_signing_avbtool_path=[path to avbtool (deprecated)]:file:_files' \
  '--gki_signing_signature_args=[additional avbtool hash arguments (deprecated)]:args:' \
  '--id[print the image ID to standard output]' && ret=0

return ret
