#compdef hardhat

# Zsh completion for hardhat - Ethereum development environment

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'accounts:print the list of accounts'
  'check:check whatever you need'
  'clean:clear the cache and delete all artifacts'
  'compile:compile the entire project, building all artifacts'
  'console:open a Hardhat console'
  'coverage:generate solidity coverage'
  'flatten:flattens and prints contracts and their dependencies'
  'help:print help message'
  'node:start a JSON-RPC server on top of Hardhat Network'
  'run:run a user-defined script after compiling the project'
  'test:run mocha tests'
  'typechain:generate TypeChain typings for compiled contracts'
  'verify:verify a contract on Etherscan'
  'init:initialize a new project'
)

_arguments -C \
  '--config[path to a Hardhat config file]:file:_files' \
  '(-h --help)--help[show help]' \
  '--max-memory[max memory in MB for Hardhat]:mb:' \
  '--network[network to connect to]:network:' \
  '--show-stack-traces[show stack traces on errors]' \
  '--tsconfig[path to tsconfig file]:file:_files' \
  '--typecheck[enable TypeScript type-checking]' \
  '--verbose[enable verbose logging]' \
  '--emoji[use emoji in messages]' \
  '--version[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'hardhat task' commands && ret=0
    ;;
  args)
    case $words[1] in
      compile)
        _arguments \
          '--force[force compilation]' \
          '--quiet[suppress output]' \
          '--no-typechain[skip TypeChain generation]' && ret=0
        ;;
      test)
        _arguments \
          '--bail[stop on first failing test]' \
          '--grep[only run tests matching the regexp]:pattern:' \
          '--no-compile[do not compile before running]' \
          '--parallel[run tests in parallel]' \
          '--reporter[mocha reporter]:reporter:' \
          '*:test files:_files' && ret=0
        ;;
      run)
        _arguments \
          '--no-compile[do not compile before running]' \
          '1:script:_files' && ret=0
        ;;
      node)
        _arguments \
          '--hostname[hostname to listen on]:host:' \
          '--port[port to listen on]:port:' \
          '--fork[URL of the JSON-RPC node to fork from]:url:' \
          '--fork-block-number[block number to fork from]:number:' \
          '--no-deploy[do not run deploy scripts]' && ret=0
        ;;
      verify)
        _arguments \
          '--contract[contract to verify]:contract:' \
          '--constructor-args[file with constructor arguments]:file:_files' \
          '--libraries[file with library addresses]:file:_files' \
          '--list-networks[list supported networks]' \
          '1:address:' '*:constructor args:' && ret=0
        ;;
      flatten)
        _arguments '*:file:_files' && ret=0
        ;;
      coverage)
        _arguments \
          '--matrix[matrix output]' \
          '--solcoverjs[solidity-coverage config file]:file:_files' \
          '--temp[temp build directory]:dir:_directories' \
          '--testfiles[test files glob pattern]:pattern:' && ret=0
        ;;
      clean)
        _arguments '--global[clear the global cache]' && ret=0
        ;;
    esac
    ;;
esac

return ret
