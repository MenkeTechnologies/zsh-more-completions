#compdef gdaltransform
# Documentation: https://gdal.org/programs/gdaltransform.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '-i[inverse transformation]' \
  '-s_srs+[source SRS]:srs:' \
  '-t_srs+[target SRS]:srs:' \
  '-s_coord_epoch+[source coordinate epoch]:epoch:' \
  '-t_coord_epoch+[target coordinate epoch]:epoch:' \
  '*-to+[transformer option]:NAME=VALUE:' \
  '-ct+[coordinate operation (proj string)]:proj string:' \
  '-tps[use thin plate spline transformation]' \
  '-rpc[use RPC-based transformation]' \
  '-geoloc[use geolocation array]' \
  '-order+[polynomial order]:order:(1 2 3)' \
  '-output_xy[only output X and Y]' \
  '-E[echo mode (prepend input to output)]' \
  '-field_sep+[field separator]:sep:' \
  '-ignore_extra_input[ignore non-numeric trailing content]' \
  '*-gcp+[ground control point]:pixel line easting northing elevation:' \
  '1::source dataset:_files' \
  '2::destination dataset:_files' && ret=0

return ret
