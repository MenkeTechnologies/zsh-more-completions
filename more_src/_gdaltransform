#compdef gdaltransform

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-i[inverse transformation]' \
  '-s_srs+[source SRS]:srs:' \
  '-t_srs+[target SRS]:srs:' \
  '-to+[transformation parameter]:NAME=VALUE:' \
  '-ct+[coordinate operation]:proj string:' \
  '-tps[force GCP-based polynomial fit (TPS)]' \
  '-rpc[force RPC transformation]' \
  '-geoloc[force use of geolocation array]' \
  '-order+[polynomial order]:order:(1 2 3)' \
  '-output_xy[only output X and Y]' \
  '-coord+[coordinates from CLI]:x y z:' \
  '-gcp+[ground control point]:pixel line easting northing elevation:' \
  '*:source dataset:_files' && ret=0

return ret
