#compdef bomber

# devops-kung-fu/bomber — cmd/root.go (persistent --debug --output) + cmd/scan.go.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'scan:scan SBOM file or directory for vulnerabilities'
)

_arguments -s -S -C \
  '(--debug)--debug[verbose logs]' \
  '--output=[report format]:fmt:(stdout json json-file html ai md)' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'bomber command' subcmds && ret=0
    ;;
  rest)
    _arguments -s -S \
      '--username=[provider username]:user' \
      '--token=[provider API token]:token' \
      '--openai-api-key=[OpenAI key for AI reports]' \
      '--provider=[vuln provider]:provider:(ossindex osv snyk github)' \
      '--ignore-file=[CVE ignore list file]:file:_files' \
      '--severity=[minimum severity for nonzero exit]:sev' \
      '--exitcode[exit code reflects highest severity]' \
      '--enrich=[extra enrichment fields]:enrich:()' \
      '*:sbom path:_files' && ret=0
    ;;
esac

return ret
