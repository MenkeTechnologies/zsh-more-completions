#compdef wizer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --allow-wasi)'{-a,--allow-wasi}'[allow WASI calls during initialization]' \
  '*--dir[grant access to a directory]:directory:_files -/' \
  '(-f --init-func)'{-f,--init-func}'[initialization function name]:function' \
  '*--func-rename[rename exported function]:old=new' \
  '--inherit-stdio[inherit stdio during initialization]' \
  '--inherit-env[inherit environment variables during initialization]' \
  '--wasm-bulk-memory[enable bulk memory proposal]:bool:(true false)' \
  '--wasm-multi-memory[enable multi-memory proposal]:bool:(true false)' \
  '--wasm-multi-value[enable multi-value proposal]:bool:(true false)' \
  '--wasm-simd[enable SIMD proposal]:bool:(true false)' \
  '--wasm-relaxed-simd[enable relaxed SIMD proposal]:bool:(true false)' \
  '--wasm-threads[enable threads proposal]:bool:(true false)' \
  '(-o --output)'{-o,--output}'[output file path]:file:_files -g "*.wasm"' \
  '*--mapdir[map a directory]:guest=host' \
  '1:input wasm file:_files -g "*.wasm"' && ret=0

return ret
