#compdef argocd-dex
# _argocd-dex — Argo CD bundled Dex IdP launcher and config generator (argoproj/argo-cd)
# upstream: https://github.com/argoproj/argo-cd
# Subcommands from cmd/argocd-dex/commands/argocd_dex.go (cobra).

_argocd-dex() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                rundex:'run the Dex OIDC server'
                gendexcfg:'generate the Dex configuration from Argo CD ConfigMap'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                rundex)
                    _arguments \
                        '--logformat=[log format]:format:(json text)' \
                        '--loglevel=[log level]:level:(debug info warn error)' \
                        '--disable-tls[disable TLS on the HTTP endpoint]' ;;
                gendexcfg)
                    _arguments \
                        '--logformat=[log format]:format:(json text)' \
                        '--loglevel=[log level]:level:(debug info warn error)' \
                        '(-o --out)'{-o+,--out=}'[output file (default stdout)]:file:_files' \
                        '--disable-tls[disable TLS on the HTTP endpoint]' ;;
            esac
            ;;
    esac
}

_argocd-dex "$@"
