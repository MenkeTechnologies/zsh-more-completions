#compdef ddgs
# Documentation: https://github.com/deedy5/ddgs
# Reference accessed: 2026-05-23
# Verified: ddgs --help (duckduckgo-search PyPI console script).

# Zsh completion for ddgs - DuckDuckGo Search CLI and MCP server

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'ddgs command' \
      'api[start or stop DDGS API server]' \
      'books[DDGS books metasearch]' \
      'extract[extract content from URL]' \
      'images[DDGS images metasearch]' \
      'mcp[start DDGS MCP server over stdio]' \
      'news[DDGS news metasearch]' \
      'text[DDGS text metasearch]' \
      'version[print version]' \
      'videos[DDGS videos metasearch]' && ret=0
    ;;
  args)
    case $line[1] in
      api)
        _values 'ddgs api command' 'start' 'stop' && ret=0
        ;;
    esac
    ;;
esac

return ret
