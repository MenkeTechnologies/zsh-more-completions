#compdef rbd-fuse
# Documentation: https://man.archlinux.org/search?q=rbd-fuse
# Reference accessed: 2026-05-16

# rbd-fuse: FUSE wrapper exposing RBD images as files
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '-c[ceph config file]:file:_files -g "*.conf"' \
  '-p[pool name]:name:' \
  '--pool=[pool name]:name:' \
  '-d[debug]' \
  '-f[foreground]' \
  '-s[single-threaded]' \
  '-o[FUSE mount options]:opts:' \
  '*:mountpoint:_files -/' && ret=0
return ret
