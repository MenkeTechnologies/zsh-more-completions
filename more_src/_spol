#compdef spol gmx-spol
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-spol.html
# gmx spol: analyze solvent dipole orientation and polarization around solutes

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-n[index file]:file:_files' \
  '-o[xvgr/xmgr file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-com[use the center of mass as the reference position]' \
  '-refat[the reference atom of the solvent molecule]:int:' \
  '-rmin[minimum distance (nm)]:real:' \
  '-rmax[maximum distance (nm)]:real:' \
  '-dip[the average dipole (D)]:real:' \
  '-bw[the bin width]:real:' && ret=0

return ret
