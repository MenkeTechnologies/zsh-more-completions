#compdef bluepill

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-privileged[non-privileged mode]' \
  '--logfile=[log file]:log file:_files' \
  '--base-dir=[base directory]:directory:_directories' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'load:load a config file'
      'status:show status of processes'
      'start:start a process or group'
      'stop:stop a process or group'
      'restart:restart a process or group'
      'unmonitor:unmonitor a process or group'
      'log:show log for a process'
      'quit:stop bluepill daemon'
    )
    _describe -t commands 'bluepill command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      load)
        _arguments '1:config file:_files -g "*.pill(-.)"' && ret=0
        ;;
      start|stop|restart|unmonitor|log)
        _arguments '1:process or group:' && ret=0
        ;;
    esac
    ;;
esac

return ret
