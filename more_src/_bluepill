#compdef bluepill
# Documentation: https://github.com/bluepill-rb/bluepill
# Reference accessed: 2026-05-16
# Verified: Ruby bluepill-rb upstream README + bin/bluepill source
# (Application#cli command list). Note: not LinkedIn's iOS test runner
# (also named bluepill) — that ships as `bp` and ships its own Xcode
# project; this completion targets the Ruby process monitor.
# Removed from prior file: bogus man.archlinux.org search URL.

# bluepill: Ruby process monitor (similar to monit)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'load:load a config file'
  'status:show status of processes'
  'start:start a process or group'
  'stop:stop a process or group'
  'restart:restart a process or group'
  'unmonitor:unmonitor a process or group'
  'log:show log for a process'
  'quit:stop the bluepill daemon'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-privileged[run in non-privileged mode]' \
  '--logfile=[path to log file]:file:_files' \
  '--base-dir=[base directory]:dir:_files -/' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands) _describe -t commands 'bluepill command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (load) _arguments '1:config file:_files -g "*.pill(-.)"' && ret=0 ;;
      (start|stop|restart|unmonitor|log) _arguments '1:process or group:' && ret=0 ;;
    esac
    ;;
esac
return ret
