#compdef distant

# Zsh completion for distant (chipsenkbeil/distant, clap 4). Command tree from
# src/options.rs on the master branch: flattened client verbs plus manager,
# server, and generate groups.

local curcontext="$curcontext" state line ret=1
local -a globals top fsops tunnelops

globals=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show build metadata]'
  '(-q --quiet)'{-q,--quiet}'[suppress informational stderr output]'
  '--config=[alternate config file]:config:_files'
  '--log-file=[log sink path]:log file:_files'
  '--log-level=[global log filter]:level:(off error warn info debug trace)'
)

top=(
  'api:JSON-lines RPC on stdin/stdout'
  'connect:open a destination URI through the manager'
  'copy:sync files between local paths and \`:\` remote paths'
  'fs:remote filesystem verbs'
  'tunnel:TCP forward and reverse tunnels'
  'launch:bootstrap a distant server via ssh/docker handlers'
  'shell:interactive PTY shell session'
  'spawn:run a non-interactive remote command'
  'system-info:dump remote networking facts'
  'version:query the remote server version'
  'ssh:SSH-first shortcut (requires the ssh feature in your build)'
  'status:summarize the manager and connections'
  'kill:stop a tracked connection'
  'select:set the active connection in the cache'
  'manager:control the local supervisor'
  'server:run the distant server (requires the host feature)'
  'generate:emit configs or shell integration snippets'
)

fsops=(
  'copy:duplicate a remote file or directory'
  'exists:test whether a remote path is present'
  'make-dir:create a remote directory'
  'metadata:inspect file metadata'
  'read:dump a file or directory listing'
  'remove:delete a remote file or tree'
  'rename:move a remote path'
  'search:search remote paths for patterns'
  'set-permissions:adjust POSIX permissions'
  'watch:subscribe to filesystem change events'
  'write:create or truncate a remote file from stdin'
)

tunnelops=(
  'open:local listener that forwards to a remote TCP port'
  'listen:remote listener that forwards back locally'
  'close:teardown an existing tunnel'
  'list:list active tunnels'
)

_arguments -C -s -S \
  "$globals[@]" \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'distant command' top && ret=0 ;;
  (args)
    case $line[1] in
      (fs)
        if (( CURRENT == 3 )); then
          _describe -t commands 'distant fs operation' fsops && ret=0
        else
          _default && ret=0
        fi ;;
      (tunnel)
        if (( CURRENT == 3 )); then
          _describe -t commands 'distant tunnel operation' tunnelops && ret=0
        else
          _default && ret=0
        fi ;;
      (manager)
        if (( CURRENT == 3 )); then
          local -a mops
          mops=(
            'listen:bind the supervisor socket or Windows pipe'
            'version:print manager build information'
          )
          _describe -t commands 'distant manager command' mops && ret=0
        else
          _default && ret=0
        fi ;;
      (server)
        if (( CURRENT == 3 )); then
          local -a sops
          sops=('listen:accept authenticated distant clients')
          _describe -t commands 'distant server command' sops && ret=0
        else
          _default && ret=0
        fi ;;
      (generate)
        if (( CURRENT == 3 )); then
          local -a gops
          gops=(
            'config:write a starter distant configuration file'
            'completion:print shell completion definitions'
          )
          _describe -t commands 'distant generate target' gops && ret=0
        elif [[ $line[2] == completion ]] && (( CURRENT == 4 )); then
          local -a shells
          shells=(
            'bash:bash completion script'
            'elvish:elvish completion script'
            'fish:fish completion script'
            'powershell:powershell completion script'
            'zsh:zsh completion script'
          )
          _describe -t shells 'shell' shells && ret=0
        else
          _default && ret=0
        fi ;;
      (*) _default && ret=0 ;;
    esac ;;
esac

return ret
