#compdef suttoz
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/stretching_moveout_resamp/suttoz.c
# Resample from time to depth

local ret=1

_arguments -s -S \
  'nz=[number of depth samples in output]:nz' \
  'dz=[depth sampling interval]:dz' \
  'fz=[first depth sample]:fz' \
  't=[times corresponding to interval velocities in v]:t' \
  'v=[interval velocities corresponding to times in t]:v' \
  'vfile=[binary file containing velocities v(t)]:vfile:_files' \
  'verbose=[>0 to print depth sampling information]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
