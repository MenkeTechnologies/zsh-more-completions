#compdef clipnotify-cli
# _clipnotify-cli — Christian Schwarzgruber clipnotify Notify when clipboard changes (cdown team, C); custom argparse
# upstream: https://github.com/cdown/clipnotify

_clipnotify-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-s+[selection]:s:(clipboard primary secondary)' \
        '--selection=+[selection]:s:(clipboard primary secondary)' \
        '-l[loop until killed]' \
        '--loop[loop until killed]' \
        '*:arg:'
}

_clipnotify-cli "$@"
