#compdef prepgen
# generate an Amber prep (residue template) file from an ac file

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-i[input file name (ac format)]:file:_files' \
  '-o[output file name]:file:_files' \
  '-f[output file format]:format:(car int)' \
  '-m[mainchain file name]:file:_files' \
  '-rn[residue name]:name:' \
  '-rf[residue file name]:file:_files' \
  '-inf[information file name]:file:_files' \
  '-p[PDB output file name]:file:_files -g "*.pdb"' \
  '-s[atom sequence order changeable]:choice:(yes no)' && ret=0

return ret
