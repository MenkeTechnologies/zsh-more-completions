#compdef rocprof-compute
# Documentation: https://rocm.docs.amd.com/projects/rocprofiler-compute/en/latest/how-to/use.html
# rocprof-compute - ROCm Compute Profiler (formerly Omniperf)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-v --version)'{-v,--version}'[print the version and exit]' \
  '(-V --verbose)'{-V,--verbose}'[increase output verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[reduce output verbosity and run quietly]' \
  '(-s --specs)'{-s,--specs}'[print system specs and exit]' \
  '--list-metrics=[list metrics by hardware block for a system architecture]:arch' \
  '1:mode:((
    profile\:"launch and profile the target application"
    analyze\:"analyze profiling data from a workload path"
    database\:"interact with the Grafana/ROCm Compute Profiler database"
  ))' \
  '*::args:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '(-n --name)'{-n,--name}'=[output workload directory name]:name' \
      '(-p --path)'{-p,--path}'=[path to profiling data]:dir:_files -/' \
      '(-k --kernel)'{-k,--kernel}'=[filter kernels by name]:kernel' \
      '(-d --dispatch)'{-d,--dispatch}'=[filter based on dispatch ID]:id' \
      '(-b --block)'{-b,--block}'=[collect metrics for the specified analysis blocks]:block' \
      '--list-available-metrics[list metrics for the current system architecture]' \
      '--roof-only[run standalone roofline analysis]' \
      '*::rest:_normal' && ret=0
    ;;
esac

return ret
