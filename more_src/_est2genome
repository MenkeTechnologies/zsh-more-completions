#compdef est2genome
# Documentation: https://man.archlinux.org/search?q=est2genome
# Reference accessed: 2026-05-16

# EMBOSS est2genome: align EST/cDNA to genome, finding splice sites
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-estsequence=[EST/cDNA sequence(s)]:DNA USA:_files' \
  '-genomesequence=[genomic DNA sequence]:DNA USA:_files' \
  '-match=[match score]:score:' \
  '-mismatch=[mismatch penalty]:score:' \
  '-gappenalty=[gap penalty]:score:' \
  '-intronpenalty=[intron penalty]:score:' \
  '-splicepenalty=[splice site penalty]:score:' \
  '-minscore=[minimum alignment score]:score:' \
  '-reverse[align reverse-strand]' \
  '-splice[use splice-site detection]' \
  '-mode=[alignment mode]:mode:(both forward reverse)' \
  '-best[only report best alignment]' \
  '-space=[memory limit (MB)]:mb:' \
  '-shuffle=[number of shuffles for significance]:n:' \
  '-seed=[random seed]:seed:' \
  '-align[output alignment]' \
  '-width=[output width in columns]:cols:' \
  '-outfile=[output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
