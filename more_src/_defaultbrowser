#compdef defaultbrowser
# Documentation: https://man.archlinux.org/search?q=defaultbrowser
# Reference accessed: 2026-05-16

# kerma/defaultbrowser src/main.m — optional browser key sets default HTTP handler; no flags; Homebrew: Formula/d/defaultbrowser.rb

local ret=1
_message -e browsers 'defaultbrowser: optional browser name (from listed handlers); empty lists handlers'
_arguments -s '*::browser key:_default' && ret=0
return ret
