#compdef sdcc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-m+[processor type]:processor:(mcs51 z80 z180 r2k r2ka r3ka sm83 tlcs90 ez80_z80 z80n ds390 ds400 pic14 pic16 hc08 s08 stm8 pdk13 pdk14 pdk15)' \
  '-p+[processor variant]:variant' \
  '-o+[output file]:output file:_files' \
  '-c[compile and assemble, do not link]' \
  '-E[preprocess only]' \
  '-S[compile only, do not assemble or link]' \
  '-D+[define macro]:macro[=value]' \
  '-I+[add include directory]:directory:_directories' \
  '-L+[add library search directory]:directory:_directories' \
  '-l+[link with library]:library name' \
  '-W+[pass option to preprocessor]:option' \
  '--std=[C standard]:standard:(c89 c99 c11 c17 c2x sdcc89 sdcc99 sdcc11 sdcc17 sdcc2x)' \
  '--opt-code-speed[optimize for code speed]' \
  '--opt-code-size[optimize for code size]' \
  '--model-small[use small memory model]' \
  '--model-medium[use medium memory model]' \
  '--model-large[use large memory model]' \
  '--model-huge[use huge memory model]' \
  '--xram-loc=[set external RAM start address]:address' \
  '--xram-size=[set external RAM size]:size' \
  '--iram-size=[set internal RAM size]:size' \
  '--code-loc=[set code start address]:address' \
  '--code-size=[set max code size]:size' \
  '--stack-loc=[set stack start address]:address' \
  '--stack-size=[set stack size]:size' \
  '--data-loc=[set data segment address]:address' \
  '--debug[enable debug output]' \
  '--cyclomatic[display cyclomatic complexity]' \
  '--no-xinit-opt[do not optimize initialization of external memory]' \
  '--no-c-code-in-asm[do not include C code in .asm file]' \
  '--no-peep[disable peephole optimization]' \
  '--no-peep-return[disable peephole for return instructions]' \
  '--peep-asm[enable peephole optimization on inline assembly]' \
  '--peep-file=[use peephole file]:file:_files' \
  '--fomit-frame-pointer[omit frame pointer]' \
  '--all-callee-saves[callee saves for all functions]' \
  '--nostdinc[do not search standard include directories]' \
  '--nostdlib[do not search standard library directories]' \
  '--verbose[show verbose compile info]' \
  '-V[execute verbosely, showing sub-commands]' \
  '*:source file:_files -g "*.(c|h|s|asm|S|rel|lib)"' && ret=0

return ret
