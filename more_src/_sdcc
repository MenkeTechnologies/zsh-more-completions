#compdef sdcc
# Documentation: https://sourceforge.net/p/sdcc/code/HEAD/tree/trunk/sdcc/src/SDCCmain.c
# Reference accessed: 2026-05-21
# Verified: SDCCmain.c optionsTable[] long flags, ports[] enabled target list,
# and parseCmdLine() --std value handling.
# Removed from prior file: c17 / c2x / sdcc17 / sdcc2x from --std list (real
# values are c89/c90/c95/c99/c11/c23/c2y/sdcc89/sdcc99/sdcc11/sdcc23/sdcc2y).
# Added missing -m targets: r4k, r5k, r6k, r800, tininative, pic14 (was "pic"),
# mos6502, mos65c02, f8, f8l.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-m+[processor type]:processor:(mcs51 z80 z180 r2k r2ka r3ka r4k r5k r6k sm83 tlcs90 ez80_z80 z80n r800 ds390 ds400 pic14 pic16 tininative hc08 s08 stm8 pdk13 pdk14 pdk15 mos6502 mos65c02 f8 f8l)' \
  '-p+[processor variant]:variant' \
  '-o+[output file]:output file:_files' \
  '-c[compile and assemble, do not link]' \
  '-E[preprocess only]' \
  '-S[compile only, do not assemble or link]' \
  '-D+[define macro]:macro[=value]' \
  '-I+[add include directory]:directory:_directories' \
  '-L+[add library search directory]:directory:_directories' \
  '-l+[link with library]:library name' \
  '-W+[pass option to preprocessor]:option' \
  '--std=[C standard]:standard:(c89 c90 c95 c99 c11 c23 c2y sdcc89 sdcc99 sdcc11 sdcc23 sdcc2y)' \
  '--opt-code-speed[optimize for code speed]' \
  '--opt-code-size[optimize for code size]' \
  '--model-small[use small memory model]' \
  '--model-medium[use medium memory model]' \
  '--model-large[use large memory model]' \
  '--model-huge[use huge memory model]' \
  '--xram-loc=[set external RAM start address]:address' \
  '--xram-size=[set external RAM size]:size' \
  '--iram-size=[set internal RAM size]:size' \
  '--code-loc=[set code start address]:address' \
  '--code-size=[set max code size]:size' \
  '--stack-loc=[set stack start address]:address' \
  '--stack-auto[stack automatic variables]' \
  '--data-loc=[set data segment address]:address' \
  '--idata-loc=[set idata segment address]:address' \
  '--xstack[use external stack]' \
  '--xstack-loc=[set xstack start address]:address' \
  '--xram-movc[use movc instead of movx for xram reads]' \
  '--debug[enable debug output]' \
  '--cyclomatic[display cyclomatic complexity]' \
  '--no-xinit-opt[do not optimize external memory initialization]' \
  '--no-c-code-in-asm[do not include C code in .asm file]' \
  '--no-peep[disable peephole optimization]' \
  '--no-peep-return[disable peephole for return instructions]' \
  '--peep-asm[enable peephole optimization on inline assembly]' \
  '--peep-file=[use peephole file]:file:_files' \
  '--fomit-frame-pointer[omit frame pointer]' \
  '--all-callee-saves[callee saves for all functions]' \
  '--nostdinc[do not search standard include directories]' \
  '--nostdlib[do not search standard library directories]' \
  '--nostdlibcall[disable optimization of standard library calls]' \
  '--norestartseqatomics[omit restartable sequence support routines for atomics]' \
  '--nogcse[disable global subexpression elimination]' \
  '--noinduction[disable loop induction optimization]' \
  '--noinvariant[disable loop invariant optimization]' \
  '--nolabelopt[disable label optimization]' \
  '--noloopreverse[disable loop reverse]' \
  '--nooverlay[disable overlaying leaf function auto variables]' \
  '--out-fmt-ihx[output Intel hex format (default)]' \
  '--out-fmt-s19[output Motorola S19 format]' \
  '--int-long-reent[use reentrant calls on int and long support functions]' \
  '--float-reent[use reentrant calls on float support functions]' \
  '--use-non-free[use non-free libraries (e.g. PIC)]' \
  '--use-stdout[use stdout for messages]' \
  '--vc[Visual C error format]' \
  '--Werror[treat warnings as errors]' \
  '--syntax-only[parse and verify syntax only]' \
  '--print-search-dirs[print library and include search paths]' \
  '--verbose[trace calls to preprocessor, assembler, and linker]' \
  '-V[execute verbosely, showing sub-commands]' \
  '*:source file:_files -g "*.(c|h|s|asm|S|rel|lib)"' && ret=0

return ret
