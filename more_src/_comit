#compdef comit
# Documentation: https://www.ccp4.ac.uk/html/comit.html
# CCP4 comit: calculate composite omit map

local ret=1

_arguments -s -S \
  '-pdbin[input PDB file]:file:_files' \
  '-mtzin[input MTZ file]:file:_files' \
  '-mtzout[output MTZ file]:file:_files' \
  '-mapout[output map file]:file:_files' \
  '-prefix[output filename prefix]:prefix:' \
  '-colin-fo[observed F and sigma column path]:colpath:' \
  '-colin-fc[map coefficient column path]:colpath:' \
  '-colout[output column path]:colpath:' \
  '-nomit[number of spheres/regions to omit]:n:' \
  '-pad-radius[padding radius (A)]:radius:' \
  '-verbose[verbosity level]:level:' \
  '-stdin[read keywords from standard input]' \
  '*:file:_files' && ret=0

return ret
