#compdef brittany
# Documentation: https://man.archlinux.org/search?q=brittany
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config-file[configuration file]:config file:_files' \
  '(-i --indent)'{-i,--indent}'[indentation amount]:spaces:' \
  '(-c --columns)'{-c,--columns}'[max column width]:columns:' \
  '--obfuscate[obfuscate output]' \
  '--write-mode[write mode]:mode:(inplace newfile stdout check)' \
  '--check[check mode, exit non-zero if changes needed]' \
  '--no-user-config[ignore user configuration]' \
  '--exact-print-only[only use exact printing]' \
  '*:file:_files' && ret=0

return ret
