#compdef certstrap

# Zsh completion for certstrap - certificate bootstrap tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)--version[display version]' \
  '--depot-path=[certificate depot path]:depot directory:_directories' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'init:Initialize a new certificate authority'
      'request-cert:Request a new certificate'
      'sign:Sign a certificate request'
      'revoke:Revoke a certificate'
      'verify:Verify a certificate'
      'version:Display version'
    )
    _describe -t commands 'certstrap commands' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      init)
        _arguments -s -S \
          '--common-name=[common name]:common name:' \
          '--organization=[organization]:organization:' \
          '--organizational-unit=[organizational unit]:unit:' \
          '--country=[country]:country:' \
          '--province=[province or state]:province:' \
          '--locality=[locality or city]:locality:' \
          '--key-bits=[RSA key size in bits]:bits:(2048 4096)' \
          '--curve=[elliptic curve]:curve:(P-256 P-384 P-521)' \
          '--expires=[certificate expiry duration]:duration:' \
          '--passphrase=[passphrase for private key]:passphrase:' \
          '--stdout[print certificate to stdout]' \
          '--depot-path=[certificate depot path]:depot directory:_directories' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      request-cert)
        _arguments -s -S \
          '--common-name=[common name]:common name:' \
          '--organization=[organization]:organization:' \
          '--organizational-unit=[organizational unit]:unit:' \
          '--country=[country]:country:' \
          '--province=[province or state]:province:' \
          '--locality=[locality or city]:locality:' \
          '--key-bits=[RSA key size in bits]:bits:(2048 4096)' \
          '--curve=[elliptic curve]:curve:(P-256 P-384 P-521)' \
          '*--domain=[subject alternative name domain]:domain:' \
          '*--ip=[subject alternative name IP]:ip address:' \
          '*--uri=[subject alternative name URI]:uri:' \
          '--passphrase=[passphrase for private key]:passphrase:' \
          '--stdout[print certificate request to stdout]' \
          '--depot-path=[certificate depot path]:depot directory:_directories' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      sign)
        _arguments -s -S \
          '--CA=[certificate authority name]:CA name:' \
          '--cert=[certificate request name]:certificate name:' \
          '--expires=[certificate expiry duration]:duration:' \
          '--passphrase=[passphrase for CA private key]:passphrase:' \
          '--intermediate[sign as intermediate CA]' \
          '--crl-url=[CRL distribution point URL]:url:' \
          '--stdout[print certificate to stdout]' \
          '--depot-path=[certificate depot path]:depot directory:_directories' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      revoke)
        _arguments -s -S \
          '--CA=[certificate authority name]:CA name:' \
          '--cert=[certificate name to revoke]:certificate name:' \
          '--passphrase=[passphrase for CA private key]:passphrase:' \
          '--stdout[print CRL to stdout]' \
          '--depot-path=[certificate depot path]:depot directory:_directories' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      verify)
        _arguments -s -S \
          '--CA=[certificate authority name]:CA name:' \
          '--cert=[certificate name to verify]:certificate name:' \
          '--depot-path=[certificate depot path]:depot directory:_directories' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
