#compdef git-hooks
# Documentation: https://github.com/git-hooks/git-hooks/wiki/Get-Started
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# git-hooks: a tool to manage project, user, and global Git hooks
# Fork lineage: git-hooks/git-hooks (originally icefox/git-hooks)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:enable git-hooks for the current repository'
  'uninstall:disable git-hooks for the current repository'
  'install-template:install git-hooks into a Git template'
  'uninstall-template:uninstall git-hooks from a Git template'
  'list:list hooks for all scopes'
  'run:run a hook by name'
  'update:update git-hooks to the latest release'
  'identity:show the configured identity'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'git-hooks command' commands && ret=0
    ;;
esac

return ret
