#compdef kubectl-event-summary
# Documentation: upstream pkg/cmd/flags.go at
# github.com/nareshku/kubectl-event-summary
# Reference accessed: 2026-05-30 via gh api inspection of every
# cmd.Flags() declaration.
# nareshku kubectl-event-summary R72 — kubectl plugin that provides
# a summarized view of Kubernetes events with filtering, grouping,
# and search. Single-command Cobra CLI with 9 flags + the standard
# genericclioptions.ConfigFlags set.

local -a _outputs _sort_keys _severities _group_keys
_outputs=( wide json yaml )
_sort_keys=( lastTimestamp count )
_severities=( all normal warning error )
_group_keys=( kind namespace reason type )

_arguments -s -S \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[summarize events across all namespaces]' \
  '--sort-by=[sort events by]:key:($_sort_keys)' \
  '(-o --output)'{-o,--output}'=[output format]:format:($_outputs)' \
  '--since=[show events from the last duration (e.g. 5m, 1h)]:duration:' \
  '--group-by=[group events by (comma-separated)]:keys:_values -s , key $_group_keys' \
  '--compact[show only group summaries]' \
  "--filter=[filter groups by prefix (e.g. 'kind=Pod')]:prefix:" \
  '--severity=[filter events by severity]:severity:($_severities)' \
  '--search=[search string (matches name, message, reason, namespace)]:query:' \
  '(-n --namespace)'{-n,--namespace}'=[the kubernetes namespace to use]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:kubeconfig:_files' \
  '--context=[the name of the kubeconfig context to use]:context:' \
  '--cluster=[the name of the kubeconfig cluster to use]:cluster:' \
  '--user=[the name of the kubeconfig user to use]:user:' \
  '--server=[the address and port of the Kubernetes API server]:url:' \
  '--insecure-skip-tls-verify[skip TLS certificate verification]' \
  '--request-timeout=[length of time to wait before giving up on a single request]:duration:' \
  '(- *)'{-h,--help}'[show help]'
