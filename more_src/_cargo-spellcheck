#compdef cargo-spellcheck

# Zsh completion for cargo-spellcheck (spellcheck Rust documentation)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-v[Increase verbosity]' \
  '--verbose[Increase verbosity]' \
  '-f[Fix mistakes interactively]' \
  '--fix[Fix mistakes interactively]' \
  '-r[Recursive into subdirectories]' \
  '--recursive[Recursive into subdirectories]' \
  '-m+[Manifest path]:file:_files' \
  '--manifest-path=[Manifest path]:file:_files' \
  '--cfg=[Config file path]:file:_files' \
  '-c+[Checker to use]:checker:(hunspell nlprule languagetool reflow)' \
  '--checkers=[Checker to use]:checker:(hunspell nlprule languagetool reflow)' \
  '--code=[Error code]:code' \
  '-n[Dry run, do not modify files]' \
  '--dry-run[Dry run, do not modify files]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:Check documentation for spelling errors (default)'
      'fix:Fix documentation spelling errors interactively'
      'reflow:Reflow documentation comments'
      'config:Print or create configuration'
      'completions:Generate shell completions'
      'list-files:List files that would be checked'
    )
    _describe -t commands 'cargo-spellcheck command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      config)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--stdout[Print config to stdout]' \
          '--overwrite[Overwrite existing config file]' \
          '--user[Apply to user config]' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(bash zsh fish elvish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:paths:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
