#compdef magma Magma
# Documentation: https://magma.maths.usyd.edu.au/magma/handbook/text/47
# magma - Magma computational algebra system

local ret=1

_arguments -s -S \
  '-b[suppress opening banner and total time message]' \
  '-d[dump licence for current magmapassfile, then exit]' \
  '-s[use given file as startup file]:file:_files' \
  '-n[cancel the startup file]' \
  '*:file:_files' && ret=0

return ret
