#compdef screengrab
# _screengrab — fastlane screengrab Android screenshot generator (fastlane, Ruby); commander
# upstream: https://github.com/fastlane/fastlane

_screengrab() {
    local -a sub=(
        'init:scaffold Screengrabfile'
        'run:capture screenshots'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--android-home=+[android home]:dir:_files -/' \
        '-n+[android home]:dir:_files -/' \
        '--build-tools-version=+[build tools version]:ver:' \
        '-i+[build tools version]:ver:' \
        '--locales=+[locales]:list:' \
        '-q+[locales]:list:' \
        '--clear-previous-screenshots=+[clear previous screenshots]:b:(true false)' \
        '-c+[clear previous screenshots]:b:(true false)' \
        '--output-directory=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--skip-open-summary=+[skip open summary]:b:(true false)' \
        '-w+[skip open summary]:b:(true false)' \
        '--app-package-name=+[app package name]:str:' \
        '-a+[app package name]:str:' \
        '--tests-package-name=+[tests package name]:str:' \
        '-p+[tests package name]:str:' \
        '--use-tests-in-packages=+[use tests in packages]:list:' \
        '-r+[use tests in packages]:list:' \
        '--use-tests-in-classes=+[use tests in classes]:list:' \
        '-y+[use tests in classes]:list:' \
        '--launch-arguments=+[launch arguments]:list:' \
        '-x+[launch arguments]:list:' \
        '--test-instrumentation-runner=+[test instrumentation runner]:str:' \
        '-d+[test instrumentation runner]:str:' \
        '--ending-locale=+[ending locale]:str:' \
        '--use-adb-root=+[use adb root]:b:(true false)' \
        '--app-apk-path=+[app apk path]:file:_files -g "*.apk"' \
        '-k+[app apk path]:file:_files -g "*.apk"' \
        '--tests-apk-path=+[tests apk path]:file:_files -g "*.apk"' \
        '-t+[tests apk path]:file:_files -g "*.apk"' \
        '--specific-device=+[device serial]:str:' \
        '-s+[device serial]:str:' \
        '--device-type=+[device type]:type:(phone sevenInch tenInch tv wear)' \
        '-e+[device type]:type:(phone sevenInch tenInch tv wear)' \
        '--exit-on-test-failure=+[exit on test failure]:b:(true false)' \
        '--reinstall-app=+[reinstall app]:b:(true false)' \
        '-z+[reinstall app]:b:(true false)' \
        '--use-timestamp-suffix=+[use timestamp suffix]:b:(true false)' \
        '--adb-host=+[adb host]:host:_hosts' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'screengrab subcommand' sub ;;
    esac
}

_screengrab "$@"
