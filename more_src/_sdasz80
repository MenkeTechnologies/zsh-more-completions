#compdef sdasz80

# sdasz80: SDCC Z80 assembler
# Documentation: https://sdcc.sourceforge.net/doc/sdccman.pdf
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-l[create listing]' \
  '-o[generate object]' \
  '-s[create symbol table]' \
  '-c[cycle counts in listing]' \
  '-x[hex octal binary listings]' \
  '-g[mark global all undef syms]' \
  '-a[all symbols global]' \
  '-w[wide listing]' \
  '-p[no list pagination]' \
  '-z[disable case sensitivity]' \
  '-I[include dir]:dir:_files -/' \
  '-D[define symbol]:symbol=value:' \
  '*:source file:_files -g "*.(asm|s)"' && ret=0
return ret
