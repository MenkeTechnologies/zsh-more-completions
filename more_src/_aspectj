#compdef aspectj ajc-compiler
# _aspectj — AspectJ AOP compiler entrypoint alias (Eclipse AspectJ, Java); custom argparse (ajc binary)
# upstream: https://github.com/eclipse-aspectj/aspectj

_aspectj() {
    _arguments \
        '-help[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-aspectpath+[aspect path]:list:_files' \
        '-classpath+[classpath]:list:_files' \
        '-cp+[classpath]:list:_files' \
        '-bootclasspath+[boot classpath]:list:_files' \
        '-d+[output dir]:dir:_files -/' \
        '-deprecation[deprecation warnings]' \
        '-encoding+[encoding]:enc:' \
        '-extdirs+[ext dirs]:dirs:_files -/' \
        '-g[debug info]' \
        '-g:none[no debug info]' \
        '-g:vars[vars info]' \
        '-g:lines[lines info]' \
        '-g:source[source info]' \
        '-inpath+[input path]:list:_files' \
        '-injars+[input jars]:list:_files' \
        '-noExit[no exit]' \
        '-noImportError[no import error]' \
        '-outjar+[output jar]:file:_files' \
        '-outxml[write META-INF/aop.xml]' \
        '-outxmlfile+[aop xml file]:file:_files' \
        '-preserveAllLocals[preserve all locals]' \
        '-proceedOnError[proceed on error]' \
        '-referenceInfo[reference info]' \
        '-repeat+[repeat]:n:' \
        '-source+[source level]:n:(1.5 1.6 1.7 1.8 11 17 21)' \
        '-sourceroots+[source roots]:list:_files -/' \
        '-target+[target]:n:(1.5 1.6 1.7 1.8 11 17 21)' \
        '-time[show time]' \
        '-verbose[verbose]' \
        '-warn:+[warnings]:str:' \
        '-Werror[warnings as errors]' \
        '-Xajruntimetarget:+[runtime target]:n:' \
        '-Xaspectj-bootstrap[aspectj bootstrap]' \
        '-Xfullgenerics[full generics]' \
        '-Xlint:+[lint]:str:(ignore warning error)' \
        '-Xreweavable[reweavable]' \
        '-XterminateAfterCompilation[terminate after compilation]' \
        '-X[show extra help]' \
        '*:file:_files -g "*.(java|aj|class|jar)"'
}

_aspectj "$@"
