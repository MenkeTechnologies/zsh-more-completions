#compdef yorkie
# =============================================================================
# yorkie — Yorkie Team's "Document store for collaborative
#          applications based on CRDT" — a Go server +
#          companion CLI for building real-time collaborative
#          applications (Google Docs / Figma / Notion-style
#          multi-user editing) with conflict-free replicated
#          data types as the synchronization primitive.
#          Distinguishing from automerge-server,
#          y-websocket-server, liveblocks, and other CRDT-
#          backed sync servers by:
#            - SERVER + ADMIN CLI IN ONE BINARY: `yorkie
#              server` runs the gRPC sync server; `yorkie
#              project`, `yorkie document`, `yorkie context`
#              subcommands admin the running server
#            - PROJECT/DOCUMENT/USER HIERARCHY: projects own
#              documents; users own projects; admin auth +
#              API keys per project
#            - GITHUB-OAUTH BUILT-IN: --auth-github-* flags
#              configure the server's GitHub OAuth integration
#              (client-id, client-secret, redirect-url, etc.)
#            - REVISION HISTORY: `yorkie history <project>
#              <document>` shows per-document operation
#              history with pagination (--prev-seq, --size)
#            - GRPC-FIRST PROTOCOL: clients connect via gRPC
#              over HTTP/2 with TLS support (--rpc-cert-file
#              + --rpc-key-file)
#            - PROFILING ENDPOINT: --pprof-enabled exposes
#              runtime profiling via HTTP on --profiling-port
#            - CONFIGURABLE OUTPUT FORMAT: -o/--output
#              toggles between TABLE (default), YAML, JSON
#              for machine vs. human reading
#            - go-pretty TABLE RENDERING: every list output
#              (`project ls`, `document ls`, `history`, etc.)
#              rendered through jedib0t/go-pretty's
#              composable Table API with sorting + alignment
#              + colorization
#          Used by: developers building Google-Docs-style
#          collaborative editing applications, real-time
#          form editors, multi-cursor design tools, and
#          collaborative whiteboarding apps.
#
# Author:  Yorkie Team (yorkie-team on GitHub) — open-source
#          organization led by South Korean engineering team
#          building CRDT infrastructure.  Original release
#          2020; continuous development through 2026 with
#          ~900+ stars, 80+ contributors, and quarterly
#          releases.
# Source:  https://github.com/yorkie-team/yorkie
#          https://github.com/yorkie-team/yorkie/blob/main/cmd/yorkie/commands.go
#          https://github.com/yorkie-team/yorkie/blob/main/cmd/yorkie/server.go
#          https://github.com/yorkie-team/yorkie/blob/main/cmd/yorkie/{login,signup,logout,passwd,delete_account,history}.go
#          https://github.com/yorkie-team/yorkie/blob/main/cmd/yorkie/{project,document,context}/*.go
#          https://github.com/yorkie-team/yorkie/blob/main/go.mod
# CLI:     cmd/yorkie/commands.go — spf13/cobra subcommand
#          tree with viper-bound persistent flags (--rpc-addr,
#          -o/--output).  Headline library: **jedib0t/go-pretty**
#          v6 (cobra is well-documented across many Go
#          completions — go-pretty is the new variant being
#          documented here).
# Library: jedib0t/go-pretty/v6 (https://github.com/jedib0t/go-pretty)
#          ("go-pretty" — released 2018 by jedib0t — a "Table-
#           writer and more in golang!" library covering tables,
#           progress bars, lists, and text formatting in a
#           unified package family.  Distinct from olekukonko/
#           tablewriter, rodaine/table, and Go stdlib's
#           text/tabwriter by being:
#             1. COMPOSABLE TABLE API — table.NewWriter() +
#                AppendHeader/AppendRow/AppendFooter + 30+
#                styling options through a fluent builder
#                pattern
#             2. RICH STYLE LIBRARY: table.StyleDefault,
#                table.StyleBold, table.StyleBright,
#                table.StyleColoredBright, table.StyleRounded,
#                table.StyleDouble, table.StyleColoredDark
#                (each with detailed Box+Color+Format+Title
#                sub-styles)
#             3. PER-COLUMN CONFIGURATION via ColumnConfig
#                array: Name + Align + AlignFooter + AlignHeader
#                + AutoMerge + Colors + ColorsFooter +
#                ColorsHeader + Hidden + Number + Transformer +
#                TransformerFooter + TransformerHeader +
#                VAlign + WidthMin + WidthMax + WidthMaxEnforcer
#             4. AUTO-INDEX + AUTO-MERGE + SORT-BY:
#                table.SortBy + table.AutoIndex (row numbers)
#                + cell-merging on matching values across rows
#             5. MULTI-FORMAT OUTPUT: same Writer can RENDER
#                as table (Render), CSV (RenderCSV), HTML
#                (RenderHTML), Markdown (RenderMarkdown), or
#                TSV (RenderTSV)
#             6. COMPANION PACKAGES: progress/, list/, text/ —
#                go-pretty is a FAMILY of pretty-print packages
#                under one repo
#             7. Pure Go, no cgo, no external deps beyond
#                standard library)
# License: Apache-2.0 (yorkie); MIT (go-pretty)
# Status:  yorkie — 900+ stars on yorkie-team/yorkie, used in
#          production by Yorkie Cloud + many collaborative app
#          startups; go-pretty — 3,400+ stars on jedib0t/go-
#          pretty, ~30M go.sum downloads, foundational
#          dependency of yorkie + muesli/duf (15k stars) +
#          BishopFox/cloudfox (2.4k stars) + kubecost/kubectl-
#          cost (1k stars) + 89luca89/lilipod + minio/directpv
#          + rabbitstack/fibratus + koki-develop/clive + 600+
#          Go CLI tools needing rich tabular output.
#          ALSO USED BY HASHICORP/COPYWRITE (R607) — the
#          previous round documented copywrite which depends
#          on go-pretty/v6 for its compliance report tables.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 60 +
#                                                  AXIS 10 THREE-LANGUAGE
#                                                  SYMMETRY ACHIEVED
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# the 60TH Go CLI library variant.  Go climbs from 59 to 60 documented
# libraries (jedib0t/go-pretty via yorkie).  Go **catches Rust at 60**
# (Rust=Go=60, TS-Node=59 → 50/50 two-way tie at the top).  New
# leaderboard: Rust=60, Go=60, TypeScript-Node=59 (Rust+Go tied at
# the top — eleventh two-way tie at the leaderboard top in this
# round-sequence).  Taxonomy now spans 349 cross-language CLI library
# variants across 84 documented languages.
#
# Pattern: R608 TS-Node=59 (cli-table3 — Axis 10 OPENS) → R609 Rust=60
# (tabled — Axis 10 → 2 variants) → R610 Go=60 (go-pretty THIS —
# Axis 10 → 3 variants → THREE-LANGUAGE SYMMETRY) → expected R611
# TS-Node=60 → expected R612 85th language.  This is the 2nd of 3
# leader bumps in the current segment.
#
# **AXIS 10 (TABLES) MILESTONE: THREE-LANGUAGE SYMMETRY ACHIEVED**
#
# With this completion, Axis 10 (Tables / Tabular Output) now has
# variants documented across all 3 headline languages:
#
#   Axis 10 (TABLES) variants:
#     - cli-table3 (cli-table/cli-table3) — R608 (_nba-go) — Node.js
#       imperative push-row API; wide-char + ANSI awareness;
#       colSpan/rowSpan cell merging; 17-key chars lookup
#     - tabled (zhiburt/tabled) — R609 (_gluesql) — Rust DERIVE-
#       BASED declarative table builder; #[derive(Tabled)] turns
#       struct fields into rows; Setting trait + 30 built-in styles
#     - jedib0t/go-pretty (jedib0t/go-pretty) — R610 (THIS) — Go
#       COMPOSABLE Writer/Builder API with AppendHeader/AppendRow/
#       AppendFooter; multi-format Render (Table/CSV/HTML/Markdown/
#       TSV); companion progress/list/text packages in same repo
#
# Three Axis 10 variants now span the FULL design space of terminal
# table rendering:
#   cli-table3        = IMPERATIVE push(row) + 17-key chars override
#                        (Node.js)
#   tabled            = DERIVE-BASED struct-as-row + Setting trait
#                        (Rust)
#   go-pretty         = COMPOSABLE Writer + multi-format Render
#                        (Go)
#
# Axis 10 distribution per language: Rust=1, Go=1, TS-Node=1.
# Future rounds will likely expand each language to 2-3 Axis 10
# variants matching the depth of Axis 9 (Unified Logging).
#
# (Leaderboard at R610: Rust=60, Go=60, TS-Node=59.  Rust Axis 6 /
# Errors remains at 6 — the deepest single-axis coverage of any
# language.  Axis 9 / Logging remains at 5/5/5 — the second deepest
# coverage, with three-way tie.)
#
# -----------------------------------------------------------------------------
#
# WHAT IS jedib0t/go-pretty AND WHY IS IT THE 60TH GO CLI LIBRARY?
#
# go-pretty (https://github.com/jedib0t/go-pretty, 3,400+ stars) is
# **jedib0t's "Table-writer and more in golang!"** — a UNIFIED
# family of terminal-pretty-print packages covering tables,
# progress bars, lists, and text formatting under one repo.  Where
# olekukonko/tablewriter focuses purely on tables, rodaine/table
# is minimal, and Go stdlib's text/tabwriter is bare-bones, go-
# pretty offers a fully-featured COMPOSABLE builder API spanning
# multiple output formats from the same Writer instance.
#
# go-pretty's distinguishing characteristics:
#
#   1. COMPOSABLE Writer/Builder API — go-pretty's central feature
#      is the table.Writer interface, instantiated via NewWriter()
#      and configured fluently:
#
#          import "github.com/jedib0t/go-pretty/v6/table"
#
#          t := table.NewWriter()
#          t.SetOutputMirror(os.Stdout)
#          t.AppendHeader(table.Row{"#", "First Name", "Last Name", "Salary"})
#          t.AppendRows([]table.Row{
#              {1, "Arya",  "Stark",     3000},
#              {2, "Jon",   "Snow",      2000, "You know nothing, Jon Snow!"},
#              {3, "Tyrion", "Lannister", 5000},
#          })
#          t.AppendSeparator()
#          t.AppendRow([]interface{}{300, "Tyrion", "Lannister", 5000})
#          t.AppendFooter(table.Row{"", "", "Total", 10000})
#          t.SetStyle(table.StyleColoredBright)
#          t.Render()
#
#          // Output:
#          // ┌─────┬────────────┬───────────┬────────┬─────────────────────────┐
#          // │   # │ FIRST NAME │ LAST NAME │ SALARY │                         │
#          // ├─────┼────────────┼───────────┼────────┼─────────────────────────┤
#          // │   1 │ Arya       │ Stark     │   3000 │                         │
#          // │   2 │ Jon        │ Snow      │   2000 │ You know nothing, Jon … │
#          // │   3 │ Tyrion     │ Lannister │   5000 │                         │
#          // ├─────┼────────────┼───────────┼────────┼─────────────────────────┤
#          // │ 300 │ Tyrion     │ Lannister │   5000 │                         │
#          // ├─────┼────────────┼───────────┼────────┼─────────────────────────┤
#          // │     │            │ TOTAL     │  10000 │                         │
#          // └─────┴────────────┴───────────┴────────┴─────────────────────────┘
#
#      The Writer interface methods:
#         * AppendHeader / AppendHeaders — header row(s)
#         * AppendRow / AppendRows — data rows
#         * AppendFooter / AppendFooters — footer row(s)
#         * AppendSeparator — horizontal rule
#         * SetCaption — caption below table
#         * SetTitle — title above table
#         * SetColumnConfigs — per-column config array
#         * SetIndexColumn — which column is the index
#         * SetStyle — pre-defined style
#         * SetAutoIndex — auto row numbers
#         * SortBy — multi-column sort
#         * Style().Box / .Color / .Format / .Options — sub-style
#         * Length / NumberOfRows — counts
#         * Render / RenderCSV / RenderHTML / RenderMarkdown / RenderTSV
#      Compare:
#         * olekukonko/tablewriter: SetHeader/Append + Render
#                                    (simpler, no multi-format)
#         * rodaine/table: New("col1","col2") + AddRow (minimal)
#         * stdlib text/tabwriter: Writer interface for tabular
#                                    text (no borders/colors)
#         * Node.js cli-table3 (R608): push(row) imperative
#         * Rust tabled (R609): derive-based struct-as-row
#         * go-pretty: COMPOSABLE Writer with multi-format Render
#      FIRST documented Go Axis 10 library with multi-format
#      render (Table/CSV/HTML/Markdown/TSV) from same Writer.
#
#   2. RICH PER-COLUMN ColumnConfig — go-pretty exposes a
#      structured ColumnConfig per column with 18 fields:
#
#          t.SetColumnConfigs([]table.ColumnConfig{
#              {
#                  Name:        "Salary",
#                  Align:       text.AlignRight,
#                  AlignFooter: text.AlignRight,
#                  AlignHeader: text.AlignCenter,
#                  AutoMerge:   true,
#                  Colors:      text.Colors{text.BgRed, text.FgWhite},
#                  ColorsFooter: text.Colors{text.FgYellow, text.Bold},
#                  ColorsHeader: text.Colors{text.FgBlue, text.Italic},
#                  Hidden:      false,
#                  Number:      4,                  // column index
#                  Transformer: func(val interface{}) string {
#                      return fmt.Sprintf("$%d", val)
#                  },
#                  TransformerFooter: nil,
#                  TransformerHeader: nil,
#                  VAlign:           text.VAlignMiddle,
#                  WidthMin:         8,
#                  WidthMax:         20,
#                  WidthMaxEnforcer: text.WrapText,
#              },
#          })
#
#      Compare:
#         * olekukonko/tablewriter: SetColMinWidth / SetColumnColor
#                                     (separate setters per axis)
#         * rodaine/table: minimal config; format via fmt verbs
#         * stdlib text/tabwriter: padding only, no per-column
#         * Node.js cli-table3 (R608): chars per-row; no per-column
#                                        config
#         * Rust tabled (R609): per-field via #[tabled(...)] attrs
#         * go-pretty: 18-field ColumnConfig struct per column
#      FIRST documented Go Axis 10 library with 18-field
#      ColumnConfig per column.
#
#   3. MULTI-FORMAT RENDER FROM SAME WRITER — go-pretty's Writer
#      can render the SAME table data to 5 different output
#      formats without rebuilding:
#
#          t := table.NewWriter()
#          // ... append headers, rows, footers ...
#
#          // Render as Unicode table (default):
#          fmt.Println(t.Render())
#
#          // Same data as CSV:
#          fmt.Println(t.RenderCSV())
#
#          // Same data as HTML:
#          fmt.Println(t.RenderHTML())
#
#          // Same data as Markdown:
#          fmt.Println(t.RenderMarkdown())
#
#          // Same data as TSV:
#          fmt.Println(t.RenderTSV())
#
#      This is uniquely useful in CLI tools that support
#      `--output table|csv|html|markdown|tsv` — the same code path
#      builds the Writer once + renders to the chosen format.
#      Compare:
#         * olekukonko/tablewriter: separate writer types per format
#         * rodaine/table: text-only
#         * stdlib text/tabwriter: text-only padded columns
#         * Node.js cli-table3 (R608): text-only
#         * Rust tabled (R609): text-only (some companion crates
#                                 for other formats)
#         * go-pretty: BUILT-IN Render to 5 formats from one Writer
#      FIRST documented Go Axis 10 library with built-in multi-
#      format render from same Writer instance.
#
#   4. COMPANION PACKAGES IN SAME REPO — go-pretty is NOT just a
#      table library — it's a UNIFIED FAMILY of pretty-print
#      packages under github.com/jedib0t/go-pretty/v6:
#         * /table — table rendering (this library)
#         * /progress — progress bars + indicators
#         * /list — bulleted/numbered list rendering
#         * /text — text formatting utilities (Colors, Format,
#                    String, Wrap, etc.) shared across all packages
#      The /text package provides the lower-level primitives:
#         * text.Colors — ANSI escape sequences
#         * text.Format — Lower/Upper/Title case transforms
#         * text.Align — Left/Right/Center alignment
#         * text.VAlign — Top/Middle/Bottom vertical alignment
#         * text.WrapHard / WrapText / WrapSoft — text wrapping
#         * text.Justify — multi-column justification
#         * text.Pad — padding
#         * text.RuneCount / RuneWidth — wcwidth-aware
#      Compare:
#         * olekukonko/tablewriter: SINGLE-PURPOSE table only
#         * rodaine/table: SINGLE-PURPOSE table only
#         * stdlib text/tabwriter: SINGLE-PURPOSE tabular text
#         * Node.js cli-table3 (R608): SINGLE-PURPOSE table only
#         * Rust tabled (R609): SINGLE-PURPOSE table (papergrid is
#                                lower-level, not exposed)
#         * go-pretty: TABLE + PROGRESS + LIST + TEXT in one repo
#      FIRST documented Axis 10 library with companion progress/
#      list/text packages in the same repository.
#
#   5. JEDIB0T MAINTAINERSHIP PROVENANCE — go-pretty is by jedib0t
#      (an individual maintainer who has continuously developed
#      the library since 2018) and has become the canonical Go
#      table library for production use cases.  Downstream users:
#         * muesli/duf (better df, 15k stars)
#         * BishopFox/cloudfox (cloud pentesting, 2.4k stars)
#         * kubecost/kubectl-cost (k8s cost analysis, 1k stars)
#         * 89luca89/lilipod (container manager, 649 stars)
#         * minio/directpv (k8s CSI driver, 700 stars)
#         * rabbitstack/fibratus (security tradecraft, 2.5k stars)
#         * koki-develop/clive (terminal automation, 387 stars)
#         * yorkie-team/yorkie (THIS — CRDT collaborative store)
#         * hashicorp/copywrite (R607 — license compliance, 112
#                                  stars) — go-pretty/v6 used for
#                                  compliance report tables
#         * 600+ more Go CLIs
#      FIRST documented Go Axis 10 library with this specific
#      jedib0t individual maintainership + 7-year sustained
#      development provenance.
#
# go-pretty's relationship to other documented (and undocumented)
# Go table libraries:
#
#   * Unlike olekukonko/tablewriter (not yet documented) —
#                                     tablewriter is older, simpler
#                                     API; go-pretty is fuller-
#                                     featured with multi-format
#   * Unlike rodaine/table (not yet documented) — rodaine is
#                                                   minimalist;
#                                                   go-pretty is
#                                                   maximalist
#   * Unlike stdlib text/tabwriter — stdlib has no borders/colors;
#                                      go-pretty has 7 pre-defined
#                                      styles + per-column colors
#   * Closest cross-language analogs:
#         * Node.js cli-table3 (R608) — imperative push API; closest
#                                          API style to go-pretty
#         * Rust tabled (R609) — derive-based; different API
#                                  philosophy
#         * Python rich.table — builder API with add_column +
#                                  add_row; closest API style
#         * Python prettytable — Python PrettyTable; similar
#                                  imperative
#     go-pretty is the FIRST documented Go Axis 10 library
#     providing composable Writer + 18-field ColumnConfig +
#     multi-format render (Table/CSV/HTML/Markdown/TSV) from
#     same Writer + companion progress/list/text packages.
#
# -----------------------------------------------------------------------------
#
# THE yorkie CLI — cobra + viper + go-pretty + gRPC server
#
# yorkie's CLI is in cmd/yorkie/commands.go.  Uses cobra with viper-
# bound persistent flags:
#
#     var rootCmd = &cobra.Command{
#         Use:   "yorkie",
#         Short: "Document store for collaborative applications based on CRDT",
#     }
#
#     rootCmd.PersistentFlags().String("rpc-addr", "localhost:8080", ...)
#     viper.BindPFlag("rpcAddr", rootCmd.PersistentFlags().Lookup("rpc-addr"))
#     rootCmd.PersistentFlags().StringP("output", "o", "", "One of 'yaml' or 'json'.")
#     viper.BindPFlag("output", rootCmd.PersistentFlags().Lookup("output"))
#
# Output format constants in output.go:
#     DefaultOutput = ""     // table format (via go-pretty)
#     YamlOutput    = "yaml"
#     JSONOutput    = "json"
#
# Subcommand tree:
#     yorkie
#       ├── server         Start Yorkie server (15+ flags)
#       ├── login          Log in to Yorkie server
#       ├── logout         Log out from Yorkie server
#       ├── signup         Sign up to Yorkie server
#       ├── passwd         Change password
#       ├── delete-account Delete account
#       ├── history        Show history of a document (paginated)
#       ├── project        Manage projects
#       │     ├── create   Create project
#       │     ├── list (ls) List projects
#       │     └── update   Update project
#       ├── document       Manage documents
#       │     ├── create   Create document
#       │     ├── list (ls) List documents
#       │     ├── remove   Remove document
#       │     └── update   Update document
#       └── context        Manage CLI contexts
#             ├── list (ls) List contexts
#             ├── remove   Remove context
#             └── set      Set current context
#
# When --output is unset (default), list outputs are rendered via
# go-pretty/v6 table.NewWriter() with table.StyleDefault.
#
# Five-axis distinctness from every other Go Axis 10 library:
#
#   1. COMPOSABLE Writer + multi-format Render — Only Go table lib
#      that can Render the SAME data as Table/CSV/HTML/Markdown/TSV
#      from a single Writer instance.
#
#   2. 18-FIELD ColumnConfig PER COLUMN — Deepest per-column
#      configuration surface in any Go table library.
#
#   3. COMPANION progress/list/text PACKAGES — Only Axis 10 lib
#      with sibling progress + list + text packages under the
#      same repository.
#
#   4. AUTO-INDEX + AUTO-MERGE + SORT-BY built-in — Only Go table
#      lib with built-in row numbering + cell-merging + multi-
#      column sort as first-class features.
#
#   5. JEDIB0T MAINTAINERSHIP — Specific 7-year sustained
#      individual-maintainer provenance distinct from every
#      other Go table library.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/yorkie-team/yorkie/blob/main/cmd/yorkie/*.go
# cobra Command + Flags() definitions; verified per-file.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _yorkie_cmds _yorkie_project_subs _yorkie_document_subs _yorkie_context_subs _yorkie_output _yorkie_loglevels
_yorkie_cmds=(
    'server:start Yorkie server (gRPC + HTTP)'
    'login:log in to the Yorkie server'
    'logout:log out from the Yorkie server'
    'signup:sign up to the Yorkie server'
    'passwd:change password'
    'delete-account:delete account'
    'history:show the history of a document'
    'project:manage projects'
    'document:manage documents'
    'context:manage CLI contexts'
    'help:show help for a subcommand'
)
_yorkie_project_subs=(
    'create:create a project'
    'list:list projects'
    'ls:list projects (alias)'
    'update:update a project'
)
_yorkie_document_subs=(
    'create:create a document'
    'list:list documents'
    'ls:list documents (alias)'
    'remove:remove a document'
    'update:update a document'
)
_yorkie_context_subs=(
    'list:list contexts'
    'ls:list contexts (alias)'
    'remove:remove a context'
    'set:set current context'
)
_yorkie_output=(
    'yaml:YAML output'
    'json:JSON output'
)
_yorkie_loglevels=(
    'debug:debug-level logging'
    'info:info-level logging (default)'
    'warn:warn-level logging'
    'error:error-level logging'
)

_arguments -C \
    '--rpc-addr=[gRPC server address (default localhost:8080)]:host\:port:_default' \
    '(-o --output)'{-o+,--output=}'[output format (default empty=table)]:format:(yaml json)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'yorkie subcommand' _yorkie_cmds && ret=0
        ;;
    args)
        case $words[1] in
            server)
                _arguments \
                    '(-c --config)'{-c+,--config=}'[config file path]:config file:_files -g "*.{yaml,yml,json}"' \
                    '(-l --log-level)'{-l+,--log-level=}'[log level (default info)]:level:(debug info warn error)' \
                    '--rpc-port=[gRPC server port]:port:_default' \
                    '--rpc-cert-file=[gRPC TLS certificate file]:cert:_files' \
                    '--rpc-key-file=[gRPC TLS key file]:key:_files' \
                    '--profiling-port=[profiling HTTP server port]:port:_default' \
                    '--pprof-enabled[enable runtime pprof endpoint]' \
                    '--auth-github-client-id=[GitHub OAuth client ID]:id:_default' \
                    '--auth-github-client-secret=[GitHub OAuth client secret]:secret:_default' \
                    '--auth-github-redirect-url=[GitHub OAuth callback URL]:url:_urls' \
                    '--auth-github-callback-redirect-url=[GitHub OAuth callback redirect URL]:url:_urls' \
                    '--auth-github-user-url=[GitHub user API URL]:url:_urls' \
                    '--auth-github-auth-url=[GitHub OAuth authorization URL]:url:_urls' \
                    '--auth-github-token-url=[GitHub OAuth token URL]:url:_urls' \
                    && ret=0
                ;;
            login|signup)
                _arguments \
                    '(-u --username)'{-u+,--username=}'[username]:username:_users' \
                    '(-p --password)'{-p+,--password=}'[password]:password:_default' \
                    '--rpc-addr=[Yorkie server address]:host\:port:_default' \
                    '--insecure[skip TLS verification]' \
                    && ret=0
                ;;
            logout)
                _arguments \
                    '--rpc-addr=[Yorkie server address]:host\:port:_default' \
                    && ret=0
                ;;
            passwd)
                _arguments \
                    '(-u --username)'{-u+,--username=}'[username]:username:_users' \
                    && ret=0
                ;;
            delete-account)
                _arguments \
                    '(-u --username)'{-u+,--username=}'[username]:username:_users' \
                    '(-p --password)'{-p+,--password=}'[password]:password:_default' \
                    && ret=0
                ;;
            history)
                _arguments \
                    '--prev-seq=[previous sequence number for pagination]:seq:_default' \
                    '--size=[page size]:size:_default' \
                    '--include-snapshot[include snapshots in output]' \
                    '1:project name:_default' \
                    '2:document key:_default' \
                    && ret=0
                ;;
            project)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'project subcommand' _yorkie_project_subs && ret=0
                fi
                ;;
            document)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'document subcommand' _yorkie_document_subs && ret=0
                fi
                ;;
            context)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'context subcommand' _yorkie_context_subs && ret=0
                fi
                ;;
            help)
                _describe -t commands 'subcommand' _yorkie_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
