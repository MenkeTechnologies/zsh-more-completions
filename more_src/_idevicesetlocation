#compdef idevicesetlocation
# _idevicesetlocation — set a simulated GPS location on an iOS device (libimobiledevice/libimobiledevice)
# upstream: https://github.com/libimobiledevice/libimobiledevice
# Flags from tools/idevicesetlocation.c.

_idevicesetlocation() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-u --udid)'{-u+,--udid=}'[target the specific device by UDID]:udid:' \
        '(-n --network)'{-n,--network}'[connect to a network-attached device]' \
        '(-d --debug)'{-d,--debug}'[enable communication debugging]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_idevicesetlocation_args' \
        '*::arg:' && ret=0

    return ret
}

(( $+functions[_idevicesetlocation_args] )) ||
_idevicesetlocation_args() {
    local -a entries
    entries=(
        'reset:remove the simulated location and revert to the real GPS'
        'LATITUDE\ LONGITUDE:set the simulated location (decimal degrees)'
    )
    _describe -t entries 'idevicesetlocation positional' entries
}

_idevicesetlocation "$@"
