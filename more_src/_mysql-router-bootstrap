#compdef mysql-router-bootstrap
# Documentation: https://man.archlinux.org/search?q=mysql-router-bootstrap
# Reference accessed: 2026-05-16

# mysql-router-bootstrap: bootstrap a Router config against an InnoDB cluster
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-B[bootstrap from cluster URL]:uri:' \
  '--bootstrap=[bootstrap from cluster URL]:uri:' \
  '-d[router instance directory]:dir:_files -/' \
  '--directory=[router instance directory]:dir:_files -/' \
  '--name=[router instance name]:name:' \
  '--force[force overwrite of config]' \
  '--force-password-validation[require password validation]' \
  '--account=[account name to create]:user:' \
  '--account-create=[mode]:mode:(always if-not-exists never)' \
  '--password-retries=[password retry count]:n:' \
  '--report-host=[report-host setting]:host:_hosts' \
  '--bootstrap-socket=[bootstrap socket]:file:_files' \
  '--connect-timeout=[connect timeout (s)]:s:' \
  '--read-timeout=[read timeout (s)]:s:' \
  '--ssl-mode=[SSL mode]:mode:(DISABLED PREFERRED REQUIRED VERIFY_CA VERIFY_IDENTITY)' \
  '--ssl-cipher=[SSL ciphers]:ciphers:' \
  '--tls-version=[TLS version]:ver:(TLSv1.0 TLSv1.1 TLSv1.2 TLSv1.3)' \
  '--ssl-ca=[SSL CA]:file:_files' \
  '--ssl-capath=[SSL CA path]:dir:_files -/' \
  '--ssl-crl=[SSL CRL]:file:_files' \
  '--ssl-crlpath=[SSL CRL path]:dir:_files -/' \
  '--ssl-cert=[SSL cert]:file:_files' \
  '--ssl-key=[SSL key]:file:_files' \
  '--conf-base-port=[base port]:port:' \
  '--conf-bind-address=[bind address]:host:' \
  '--conf-use-sockets[use unix sockets]' \
  '--conf-skip-tcp[skip TCP]' \
  '--conf-target-cluster=[target cluster]:cluster:' \
  '--conf-target-cluster-by-name=[target cluster by name]:cluster:' \
  '--conf-use-gr-notifications=[use GR notifications]:bool:(true false)' \
  '*::mysql-router-bootstrap args:_files' && ret=0
return ret
