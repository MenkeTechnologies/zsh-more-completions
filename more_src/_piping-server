#compdef piping-server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--http-port=[HTTP port]:port' \
  '--enable-https[enable HTTPS]' \
  '--https-port=[HTTPS port]:port' \
  '--key-path=[path to private key]:key file:_files' \
  '--crt-path=[path to certificate]:cert file:_files' && ret=0

return ret
