#compdef nuxi
# _nuxi-cli — Nuxt 3 / Nuxt 4 CLI (Pooya Parsa, NuxtLabs); replaces nuxt-cli, ships with Nuxt 3+
# upstream: https://github.com/nuxt/cli

_nuxi-cli() {
    local -a sub=(
        'init:create new project'
        'create:alias for init'
        'add:add a component/page/etc'
        'analyze:analyze production bundle'
        'build:build for production'
        'build-module:build a Nuxt module'
        'cleanup:clean .nuxt + .output'
        'dev:run dev server'
        'devtools:enable/disable Nuxt DevTools'
        'generate:full static generate'
        'info:print env info'
        'module:add/remove a Nuxt module'
        'prepare:prepare types and stubs'
        'preview:preview production build'
        'start:alias for preview'
        'test:run tests via @nuxt/test-utils'
        'typecheck:run vue-tsc'
        'upgrade:upgrade nuxt and deps'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nuxi subcommand' sub ;;
        args)
            case $words[1] in
                dev) _arguments \
                    '--host+[host]:host:_hosts' \
                    '--port+[port]:port:' \
                    '--https[serve over HTTPS]' \
                    '--clear[clear screen]' \
                    '--no-clear[no clear screen]' \
                    '--dotenv+[dotenv file]:file:_files' \
                    '--rootDir+[root dir]:dir:_files -/' \
                    '--logLevel+[log level]:level:(silent error warn info debug verbose)' \
                    '*:rootDir:_files -/' ;;
                build|generate|prepare|cleanup|preview|start) _arguments \
                    '--dotenv+[dotenv file]:file:_files' \
                    '--logLevel+[log level]:level:(silent error warn info debug verbose)' \
                    '*:rootDir:_files -/' ;;
                add) _arguments \
                    '1:type:(component composable layout middleware plugin page api server-handler server-middleware server-route server-util)' \
                    '*:name:' ;;
                module) _arguments \
                    '1:module cmd:(add remove search)' \
                    '*:module:' ;;
                init|create) _arguments \
                    '--template+[template]:template:' \
                    '--force[overwrite existing]' \
                    '--offline[offline]' \
                    '--prefer-offline[prefer offline]' \
                    '--no-install[skip install]' \
                    '--no-git-init[skip git init]' \
                    '--package-manager+[pkg manager]:pm:(npm yarn pnpm bun)' \
                    '1:dir:_files -/' ;;
                upgrade) _arguments '--force[force]' '--channel+[channel]:channel:(stable nightly)' ;;
                analyze) _arguments \
                    '--name+[bundle name]:name:' \
                    '--dotenv+[dotenv]:file:_files' \
                    '--logLevel+[log level]:level:(silent error warn info debug verbose)' \
                    '*:rootDir:_files -/' ;;
            esac
            ;;
    esac
}

_nuxi-cli "$@"
