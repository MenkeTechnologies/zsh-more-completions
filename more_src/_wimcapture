#compdef wimcapture
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-capture.1.html
# wimcapture — create a new WIM archive from a directory tree or NTFS volume

local ret=1

_arguments -s -S \
  '--boot[mark captured image as bootable]' \
  '--check[include integrity info and verify before capturing]' \
  '--include-integrity[add integrity info without prior verification]' \
  '--compress=[set compression type and optional level]:type:(none XPRESS LZX LZMS)' \
  '--chunk-size=[set compression chunk size in bytes]:size' \
  '--solid[create solid WIM for better compression ratio]' \
  '--solid-compress=[set compression for solid resources]:type:(none XPRESS LZX LZMS)' \
  '--solid-chunk-size=[set chunk size for solid resources]:size' \
  '--threads=[number of compression threads]:threads' \
  '--unix-data[store UNIX permissions, device nodes, xattrs]' \
  '--no-acls[exclude security descriptors from capture]' \
  '--strict-acls[fail if any security descriptor cannot be read]' \
  '--dereference[follow symlinks and archive their targets]' \
  '--rpfix[adjust absolute symlinks relative to tree root]' \
  '--norpfix[preserve absolute symlinks as-is]' \
  '--flags=[set XML FLAGS element for the image]:edition id' \
  '*--image-property=[assign arbitrary XML property to image]:name=value' \
  '--config=[exclusion/inclusion configuration file]:file:_files' \
  '--update-of=[optimize by referencing an existing image]:image' \
  '--delta-from=[create delta WIM omitting data already in base]:wim:_files' \
  '--pipable[create a pipable WIM for sequential streaming]' \
  '--not-pipable[create a regular non-pipable WIM]' \
  '--wimboot[mark as WIMBoot-compatible]' \
  '--snapshot[capture from a VSS filesystem snapshot]' \
  '--unsafe-compact[compact WIM in-place during append]' \
  '--source-list[capture from multiple sources listed in a file]' \
  '*:source:_files' && ret=0

return ret
