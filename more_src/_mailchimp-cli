#compdef mailchimp-cli mailchimp mc-cli
# _mailchimp-cli — Intuit Mailchimp mailchimp-cli CLI command-line frontend wrapping the Mailchimp Marketing Transactional Mandrill REST API managing audiences contacts campaigns templates automations tags segments file-manager landing-pages surveys reports reporting batch-operations webhooks merge-fields list-segments OAuth audience-fields (Intuit Mailchimp team, Go); cobra
# upstream: https://mailchimp.com/

_mailchimp-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'audience:audience list operations'
        'contact:contact operations'
        'campaign:campaign operations'
        'template:template operations'
        'automation:automation operations'
        'tag:tag operations'
        'segment:segment operations'
        'file:file manager operations'
        'landing-page:landing page operations'
        'survey:survey operations'
        'report:report operations'
        'webhook:webhook management'
        'batch:batch operations'
        'merge-field:merge field operations'
        'list:list operations'
        'send:send a campaign'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--server=+[name]:str:' \
        '--datacenter=+[dc]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mailchimp-cli subcommand' sub ;;
        args)
            case $words[1] in
                audience|contact|campaign|template|automation|tag|segment|file|landing-page|survey|report|webhook|batch|merge-field|list) _arguments '1:op:(list get create update delete send pause resume duplicate archive)' '*:id:' ;;
            esac
            ;;
    esac
}

_mailchimp-cli "$@"
