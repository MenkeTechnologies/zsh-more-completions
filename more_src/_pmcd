#compdef pmcd
# Documentation: https://man7.org/linux/man-pages/man1/pmcd.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-A[disable service advertisement]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-C --maxctx)'{-C,--maxctx=}'[max number of pending sslSetup contexts]:n:' \
  '-D+[debug flags]:flags:' \
  '(-f --foreground)'{-f,--foreground}'[do not daemonize]' \
  '(-H --hostname)'{-H,--hostname=}'[hostname]:host:_hosts' \
  '(-i --interface)'{-i,--interface=}'[ip address]:addr:' \
  '(-l --log)'{-l,--log=}'[log file]:file:_files' \
  '(-L --maxbytes)'{-L,--maxbytes=}'[max PDU size in bytes]:bytes:' \
  '(-M --maxmetric)'{-M,--maxmetric=}'[max number of metrics]:n:' \
  '(-N --uniqnames)'{-N,--uniqnames=}'[hostname for PMNS]:file:_files' \
  '(-n --namespace)'{-n,--namespace=}'[PMNS file]:file:_files' \
  '(-p --port)'{-p,--port=}'[port]:port:' \
  '-q+[client timeout sec]:sec:' \
  '(-Q --remotecert)'{-Q,--remotecert}'[require remote certificate]' \
  '(-s --socket)'{-s,--socket=}'[socket file]:file:_files' \
  '(-S --reqauth)'{-S,--reqauth}'[require authentication]' \
  '-t+[reply timeout]:sec:' \
  '(-T --trace)'{-T,--trace=}'[trace flag]:flag:' \
  '(-U --username)'{-U,--username=}'[run as user]:user:_users' \
  '(-v --verify)'{-v,--verify}'[verify config and exit]' \
  '-x+[fatal error file]:file:_files' && ret=0

return ret
