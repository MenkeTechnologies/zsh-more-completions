#compdef pmcd

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-A[disable PMNS]' \
  '-c+[config file]:file:_files' \
  '-C+[trust file]:file:_files' \
  '-D+[debug flags]:flags:' \
  '-f[do not daemonize]' \
  '-H+[host name]:host:_hosts' \
  '-i+[ip addr]:addr:' \
  '-l+[log file]:file:_files' \
  '-L+[max client count]:n:' \
  '-N+[hostname for PMNS]:host:' \
  '-n+[PMNS file]:file:_files' \
  '-p+[port]:port:' \
  '-P+[password file]:file:_files' \
  '-q+[client timeout sec]:sec:' \
  '-Q[use TLS only]' \
  '-s+[socket file]:file:_files' \
  '-t+[reply timeout]:sec:' \
  '-T+[max ready timeout]:sec:' \
  '-U+[run as user]:user:_users' \
  '-x+[fatal error file]:file:_files' && ret=0

return ret
