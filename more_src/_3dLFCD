#compdef 3dLFCD
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dLFCD.html
# AFNI: local functional connectivity density mapping

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-pearson -spearman -quadrant)-pearson[Pearson correlation (default)]' \
  '(-pearson -spearman -quadrant)-spearman[Spearman correlation]' \
  '(-pearson -spearman -quadrant)-quadrant[quadrant correlation]' \
  '-thresh[correlation threshold]:r:' \
  '(-faces -faces_edges -faces_edges_corners)-faces[6-connectivity neighborhood]' \
  '(-faces -faces_edges -faces_edges_corners)-faces_edges[18-connectivity neighborhood]' \
  '(-faces -faces_edges -faces_edges_corners)-faces_edges_corners[26-connectivity neighborhood]' \
  '-polort[polynomial detrend order]:m:' \
  '-autoclip[clip out non-brain voxels]' \
  '-automask[create mask from input]' \
  '-mask[mask dataset]:mmm:_files' \
  '-prefix[output dataset prefix]:p:_files' \
  '*:dataset:_files' && ret=0

return ret
