#compdef mdsf

autoload -U is-at-least

_mdsf() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--log-level=[]:LOG_LEVEL:(trace debug info warn error off)' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_mdsf_commands" \
"*::: :->mdsf" \
&& ret=0
    case $state in
    (mdsf)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:mdsf-command-$line[1]:"
        case $line[1] in
            (format)
_arguments "${_arguments_options[@]}" : \
'--config=[Path to config file]:CONFIG:_files' \
'--threads=[Amount of threads to use]:THREADS:_default' \
'--timeout=[Tool timeout in seconds]:TIMEOUT:_default' \
'--on-missing-language-definition=[What to do when a codeblock language has no tools defined]:ON_MISSING_LANGUAGE_DEFINITION:(ignore fail fail-fast)' \
'--on-missing-tool-binary=[What to do when the binary of a tool cannot be found]:ON_MISSING_TOOL_BINARY:(ignore fail fail-fast)' \
'--log-level=[]:LOG_LEVEL:(trace debug info warn error off)' \
'--stdin[Read input from stdin and write output to stdout]' \
'--debug[Log stdout and stderr of formatters]' \
'--cache[Cache results]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'*::input -- Path to files and/or directories:_files' \
&& ret=0
;;
(verify)
_arguments "${_arguments_options[@]}" : \
'--config=[Path to config file]:CONFIG:_files' \
'--threads=[Amount of threads to use]:THREADS:_default' \
'--timeout=[Tool timeout in seconds]:TIMEOUT:_default' \
'--on-missing-language-definition=[What to do when a codeblock language has no tools defined]:ON_MISSING_LANGUAGE_DEFINITION:(ignore fail fail-fast)' \
'--on-missing-tool-binary=[What to do when the binary of a tool cannot be found]:ON_MISSING_TOOL_BINARY:(ignore fail fail-fast)' \
'--log-level=[]:LOG_LEVEL:(trace debug info warn error off)' \
'--stdin[Read input from stdin and write output to stdout]' \
'--debug[Log stdout and stderr of formatters]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'*::input -- Path to files and/or directories:_files' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'--format=[]:FORMAT:(json toml yaml)' \
'--schema-version=[]:SCHEMA_VERSION:(locked stable development)' \
'--log-level=[]:LOG_LEVEL:(trace debug info warn error off)' \
'--force[Create config even if one already exists in current directory]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--log-level=[]:LOG_LEVEL:(trace debug info warn error off)' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':shell:(bash elvish fish nushell powershell zsh)' \
&& ret=0
;;
(cache-prune)
_arguments "${_arguments_options[@]}" : \
'--log-level=[]:LOG_LEVEL:(trace debug info warn error off)' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_mdsf__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:mdsf-help-command-$line[1]:"
        case $line[1] in
            (format)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(verify)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(cache-prune)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_mdsf_commands] )) ||
_mdsf_commands() {
    local commands; commands=(
'format:Run tools on input files' \
'verify:Verify files are formatted' \
'init:Create a new mdsf config' \
'completions:Generate shell completion' \
'cache-prune:Remove caches' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'mdsf commands' commands "$@"
}
