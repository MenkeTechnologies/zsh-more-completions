#compdef subinbigcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/subinbigcsv.c
# SUBINBIGCSV - make some cdps larger and delete all traces outside them

local ret=1

_arguments -s -S \
  'rfile=[read a K-file with grid definition]:f:_files' \
  'qout=[output K-file for parameter values]:f:_files' \
  'check=[1 print checking details]:c:(0 1)' \
  'intype=[input type option]:i:' \
  'igilist=[list of igi grid index values]:l:' \
  'igclist=[list of igc grid index values]:l:' \
  'igiout=[output igi values]:i:' \
  'igcout=[output igc values]:i:' \
  'igiext=[igi extension amount]:i:' \
  'igcext=[igc extension amount]:i:' \
  'reigi=[reset igi values]:r:' \
  'reigc=[reset igc values]:r:' \
  'recdp=[reset cdp values]:r:' \
  '*:SU file:_files' && ret=0

return ret
