#compdef fastmod

# Zsh completion for fastmod - fast code modification tool

_arguments -s -S \
  '(-A --accept-all)'{-A,--accept-all}'[Automatically accept all changes]' \
  '(-d --dir)'{-d,--dir}'[Directory to search]:directory:_directories' \
  '(-e --extensions)'{-e,--extensions}'[File extensions to process]:extensions:' \
  '(-F --fixed-strings)'{-F,--fixed-strings}'[Treat REGEX as a literal string]' \
  '(-g --glob)'{-g,--glob}'[Glob pattern to filter files]:glob pattern:' \
  '(-i --ignore-case)'{-i,--ignore-case}'[Case insensitive search]' \
  '(-m --multiline)'{-m,--multiline}'[Have . match newlines]' \
  '--print-changed-files-count[Print the count of changed files]' \
  '--hidden[Search hidden files and directories]' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '1:regex:' \
  '2:substitution:'
