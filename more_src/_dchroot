#compdef dchroot
# Documentation: man dchroot(1)
# Source: schroot dchroot (man) — Debian wrapper that runs commands inside a schroot chroot (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-l --list)'{-l,--list}'[list available chroots]' \
    '(-i --info)'{-i,--info}'[show detailed info about chroot]' \
    '(-p --path)'{-p,--path}'[print chroot path]' \
    '--config[print chroot configuration]' \
    '--location[print chroot location]' \
    '--directory=[change to directory inside chroot]:dir:_files -/' \
    '(-d --preserve-environment)'{-d,--preserve-environment}'[preserve user environment]' \
    '(-q --quiet)'{-q,--quiet}'[suppress non-essential output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-c --chroot --all -a)'{-c+,--chroot=}'[specific chroot]:chroot:_default' \
    '(-c --chroot --all -a)'{-a,--all}'[all chroots]' \
    '*::command args:_command_names -e' \
    && ret=0

return ret
