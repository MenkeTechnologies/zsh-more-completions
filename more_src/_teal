#compdef tl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:type-check Teal files'
  'gen:generate Lua code from Teal'
  'run:run a Teal script'
  'build:build a project'
  'types:print type information'
  'warnings:list available warnings'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-l+[require a module]:module name' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '--skip-compat53[skip compat53 loading]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'tl command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      check)
        _arguments -s -S \
          '-I+[add include directory]:directory:_directories' \
          '--include-dir=[add include directory]:directory:_directories' \
          '--wdisable=[disable warning]:warning' \
          '--werror=[treat warning as error]:warning' \
          '--gen-compat=[generate compat code]:version:(off 5.1 5.3)' \
          '--gen-target=[target Lua version]:version:(5.1 5.3 5.4)' \
          '*:Teal file:_files -g "*.tl"' && ret=0
        ;;
      gen)
        _arguments -s -S \
          '-o+[output file]:output file:_files -g "*.lua"' \
          '--output=[output file]:output file:_files -g "*.lua"' \
          '-I+[add include directory]:directory:_directories' \
          '--include-dir=[add include directory]:directory:_directories' \
          '--gen-compat=[generate compat code]:version:(off 5.1 5.3)' \
          '--gen-target=[target Lua version]:version:(5.1 5.3 5.4)' \
          '*:Teal file:_files -g "*.tl"' && ret=0
        ;;
      run)
        _arguments -s -S \
          '-I+[add include directory]:directory:_directories' \
          '--include-dir=[add include directory]:directory:_directories' \
          '*:Teal file:_files -g "*.tl"' && ret=0
        ;;
      build)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
