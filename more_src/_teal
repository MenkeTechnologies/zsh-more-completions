#compdef tl
# Documentation: https://github.com/teal-language/tl (tlcli/main.tl)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:type-check one or more Teal files'
  'gen:generate Lua code from Teal files'
  'run:run a Teal script'
  'warnings:list each kind of warning the compiler can produce'
  'types:report all types found in Teal files'
)

local -a global_opts=(
  '*--global-env-def=[predefined types from custom global environment]:dtlfilename:_files'
  '--no-stdlib[do not load the Lua standard library]'
  '*'{-I+,--include-dir=}'[prepend directory to module search path]:directory:_directories'
  '*--wdisable=[disable the given kind of warning]:warning:'
  '*--werror=[promote warning to error]:warning:'
  '--feat-arity=[define minimum arities based on optional arg annotations]:val:(off on)'
  '--gen-compat=[generate compatibility code]:val:(off optional required)'
  '--gen-target=[minimum targeted Lua version]:version:(5.1 5.3 5.4 5.5)'
  '--skip-compat53[skip compat53 insertions]'
  '--version[print version and exit]'
  '(-q --quiet)'{-q,--quiet}'[do not print information messages]'
  '(-p --pretend)'{-p,--pretend}'[type check and output what files would be generated]'
  '(- *)'{-h,--help}'[show help]'
)

_arguments -s -S \
  $global_opts \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'tl command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      check)
        _arguments -s -S \
          $global_opts \
          '*:Teal file:_files -g "*.tl"' && ret=0
        ;;
      gen)
        _arguments -s -S \
          $global_opts \
          '--root=[interpret module paths relative to given root]:dir:_directories' \
          '--no-check[do not fail on type errors]' \
          '--keep-hashbang[preserve hashbang line]' \
          '(-o --output)'{-o+,--output=}'[write to filename instead]:filename:_files' \
          '--output-dir=[base directory for output files]:dir:_directories' \
          '--custom-ext=[custom filename extension for generated output]:ext:' \
          '*:Teal file:_files -g "*.tl"' && ret=0
        ;;
      run)
        _arguments -s -S \
          $global_opts \
          '*'{-l+,--require=}'[require module for execution]:modulename:' \
          '*:Teal script:_files -g "*.tl"' && ret=0
        ;;
      types)
        _arguments -s -S \
          $global_opts \
          '(-p --position)'{-p+,--position=}'[report values in scope at line[\:column]]:position:' \
          '*:Teal file:_files -g "*.tl"' && ret=0
        ;;
      warnings)
        _arguments -s -S $global_opts && ret=0
        ;;
    esac
    ;;
esac

return ret
