#compdef openff openff-cli openff-toolkit openff-evaluator openff-interchange
# _openff — Open Force Field Initiative openff Python toolkit and CLI for atomistic force fields with consistent automated parameter (openforcefield team, Python); argparse
# upstream: https://github.com/openforcefield/openff-toolkit

_openff() {
    local -a sub=(
        'parameterize:apply a force field to a molecule'
        'check-versions:show installed package versions'
        'list-force-fields:list available SMIRNOFF force fields'
        'evaluate:evaluate a force field'
        'interchange:Interchange subcommands'
        'recharge:run recharge'
        'units:show units'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--force-field=+[force field file]:file:_files -g "*.offxml *.xml"' \
        '-ff+[force field file]:file:_files -g "*.offxml *.xml"' \
        '--molecule=+[mol file]:file:_files -g "*.sdf *.mol2 *.pdb *.xyz *.smi"' \
        '-mol+[mol file]:file:_files -g "*.sdf *.mol2 *.pdb *.xyz *.smi"' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--toolkit=+[toolkit]:t:(openeye rdkit ambertools builtin)' \
        '--allow-undefined-stereo[allow undefined stereo]' \
        '--charge-from-molecules[use charges from molecules]' \
        '--partial-charge-method=+[method]:m:(am1bcc am1-mulliken am1bccnosymspt gasteiger formal_charge mmff94 zeros none)' \
        '--debug[debug logging]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'openff subcommand' sub ;;
        args)
            case $words[1] in
                parameterize) _arguments \
                    '--force-field=+[force field file]:file:_files -g "*.offxml *.xml"' \
                    '--output-format=+[format]:f:(amber gromacs lammps charmm openmm)' \
                    '*:molecule:_files -g "*.sdf *.mol2 *.pdb *.xyz *.smi"' ;;
                interchange) _arguments '1:interchange cmd:(combine to-amber to-gromacs to-lammps to-openmm to-pdb to-toolkit-smirnoff topology-builder)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_openff "$@"
