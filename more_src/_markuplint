#compdef markuplint

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[config file]:config:_files' \
  '--fix[auto fix]' \
  '--format=[output format]:format:(json)' \
  '--locale=[locale]:locale' \
  '--no-color[disable color output]' \
  '--problem-only[show only problems]' \
  '--allow-warnings[do not exit with error on warnings]' \
  '--ignore-ext[ignore file extension check]' \
  '*:file:_files -g "*.(html|htm)(-.)"' && return 0
