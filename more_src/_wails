#compdef wails

local curcontext="$curcontext" state line ret=1

_wails_commands() {
  local -a commands=(
    'build:build the project'
    'dev:run in development mode'
    'doctor:diagnose development environment'
    'generate:generation tools'
    'init:initialise a new Wails project'
    'show:show various info'
    'update:update Wails'
    'version:print the version'
  )
  _describe -t commands 'wails command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :_wails_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      init)
        _arguments -s -S \
          '-n+[project name]:name' \
          '-t+[template name]:template' \
          '-d+[project directory]:dir:_directories' \
          '-l[list available templates]' \
          '-g[initialise git repository]' \
          '-ide[generate IDE project files]:ide:(vscode goland)' \
          '-q[suppress output]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '-clean[clean build directory before building]' \
          '-compiler=[Go compiler path]:compiler:_files' \
          '-debug[build debug version]' \
          '-devtools[enable devtools in production]' \
          '-dryrun[print build command without executing]' \
          '-f[force rebuild of application]' \
          '-garbleargs=[arguments to pass to garble]:args' \
          '-ldflags=[additional ldflags]:ldflags' \
          '-m[skip mod tidy before compile]' \
          '-nopackage[skip creating platform-specific package]' \
          '-nocolour[disable colour in output]' \
          '-nosyncgomod[do not sync go.mod with Wails version]' \
          '-nsis[generate NSIS installer for Windows]' \
          '-o+[output filename]:filename' \
          '-obfuscated[obfuscate the application using garble]' \
          '-platform=[target platform]:platform:(darwin linux windows darwin/amd64 darwin/arm64 linux/amd64 linux/arm64 windows/amd64 windows/arm64)' \
          '-race[build with Go race detector]' \
          '-s[skip frontend build]' \
          '-skipbindings[skip binding generation]' \
          '-tags=[build tags]:tags' \
          '-trimpath[remove all file system paths from binary]' \
          '-u[update go.sum]' \
          '-upx[compress binary with UPX]' \
          '-upxflags=[flags for UPX]:flags' \
          '-v=[log level]:level:(1 2 3)' \
          '-webview2=[WebView2 installer strategy]:strategy:(download embed browser error)' \
          '-windowsconsole[keep console window for Windows builds]' && ret=0
        ;;
      dev)
        _arguments -s -S \
          '-assetdir=[directory for served assets]:dir:_directories' \
          '-browser[open browser on startup]' \
          '-compiler=[Go compiler path]:compiler:_files' \
          '-debounce=[debounce time for recompilation]:ms' \
          '-devserver=[address for dev server]:address' \
          '-e=[extensions to trigger rebuilds]:extensions' \
          '-frontenddevserverurl=[URL for 3rd party dev server]:url' \
          '-ldflags=[additional ldflags]:ldflags' \
          '-loglevel=[log level]:level:(Trace Debug Info Warning Error)' \
          '-nocolour[disable colour in output]' \
          '-noreload[disable automatic reload]' \
          '-race[build with Go race detector]' \
          '-reloaddirs=[additional directories to trigger reloads]:dirs' \
          '-s[skip frontend build]' \
          '-save[save given flags as defaults]' \
          '-skipbindings[skip binding generation]' \
          '-tags=[build tags]:tags' \
          '-v=[log level]:level:(1 2 3)' && ret=0
        ;;
      generate)
        local -a gen_cmds=(
          'module:generate wailsjs modules'
          'template:generate a template from a project'
        )
        _describe -t gen-commands 'generate command' gen_cmds
        ;;
    esac
    ;;
esac

return ret
