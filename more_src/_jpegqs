#compdef jpegqs
# Documentation: https://manpages.debian.org/unstable/jpegqs/jpegqs.1.en.html
# JPEG artifacts removal based on quantization coefficients

local ret=1

_arguments -s -S \
  '(-q --quality)'{-q+,--quality=}'[quality setting (0-6, default 3)]:quality:(0 1 2 3 4 5 6)' \
  '(-n --niter)'{-n+,--niter=}'[number of iterations (default 3)]:iterations' \
  '(-t --threads)'{-t+,--threads=}'[number of CPU threads to use]:threads' \
  '(-o --optimize)'{-o,--optimize}'[produce smaller output file]' \
  '(-v --verbose)'{-v+,--verbose=}'[print libjpeg debug output]:level' \
  '(-i --info)'{-i+,--info=}'[print quantsmooth debug output (default 15)]:level' \
  '(-p --cpu)'{-p+,--cpu=}'[lower SIMD type if CPU detection fails]:type' \
  '1:input jpeg:_files -g "*.(jpg|jpeg|JPG|JPEG)"' \
  '2:output jpeg:_files -g "*.(jpg|jpeg)"' && ret=0

return ret
