#compdef git-multi git-relation git-old-branches
# Documentation: https://github.com/tkrajina/git-plus
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Extra git-* utilities from tkrajina/git-plus (excludes git-recent; conflicts with paulirish/git-recent)
# Flags below are a unified superset (git-multi: -c -b -a -d -e; git-relation: -a -v -u -sv -svn; git-old-branches: -d -r -a --merged --no-merged --delete)

_arguments -s -S \
  '-a[all (multi: archive; relation: all commits; old-branches: local+remote)]' \
  '-b[branch: show current branch for all repos]' \
  '-c[multi: only changed repositories]' \
  '-d[depth (multi) / days (old-branches)]:value:' \
  '-e[multi: exclude repositories]:repos:' \
  '-r[old-branches: check remote branches]' \
  '-u[relation: compare current branch with upstream]' \
  '-v[relation: verbose/brief output mode]' \
  '-sv[relation: compare HEAD with highest semver tag]' \
  '-svn[relation: compare HEAD with nth-last semver tag]:n:' \
  '--merged[old-branches: filter by merged]' \
  '--no-merged[old-branches: filter by not-merged]' \
  '--delete[old-branches: remove old branches]' \
  '*::args:_default' && return 0
