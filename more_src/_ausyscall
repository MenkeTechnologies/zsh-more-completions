#compdef ausyscall
# _ausyscall — Linux audit ausyscall (translate syscall numbers <-> names per architecture; --i386 / --x86_64 / --arm / --aarch64 / --ppc / --ppc64 / --ppc64le / --riscv32 / --riscv64 / --s390x / --mips select arch, --dump dump all, --exact require exact match; positional argument is the syscall name or number to translate)
# upstream: https://github.com/linux-audit/audit-userspace
# Flags from linux-audit/audit-userspace src/ausyscall.c on tip.

_ausyscall() {
    _arguments \
        '-h[show help]' \
        '--i386[i386]' \
        '--x86_64[x86_64]' \
        '--arm[arm]' \
        '--aarch64[aarch64]' \
        '--ppc[ppc]' \
        '--ppc64[ppc64]' \
        '--ppc64le[ppc64le]' \
        '--riscv32[riscv32]' \
        '--riscv64[riscv64]' \
        '--s390x[s390x]' \
        '--mips[mips]' \
        '--dump[dump all]' \
        '--exact[exact match]' \
        '1:syscall name or number:'
}

_ausyscall "$@"
