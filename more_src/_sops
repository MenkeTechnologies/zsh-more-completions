#compdef sops

# Zsh completion for sops - Secrets OPerationS

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-d,--decrypt}'[decrypt file and output to stdout]' \
  {-e,--encrypt}'[encrypt file and output to stdout]' \
  {-r,--rotate}'[rotate data encryption keys]' \
  {-i,--in-place}'[write output back to the same file]' \
  '--input-type[currently json, yaml, dotenv and binary are supported]:type:(json yaml dotenv binary ini)' \
  '--output-type[currently json, yaml, dotenv and binary are supported]:type:(json yaml dotenv binary ini)' \
  '--output[save output to file]:file:_files' \
  '--extract[extract a specific key or element]:path:' \
  '--set[set a specific key or element]:key-value:' \
  '--config[path to sops config file]:file:_files -g "*.{yaml,yml,json}"' \
  '--kms[KMS ARN]:arn:' \
  '--aws-profile[AWS profile]:profile:' \
  '--gcp-kms[GCP KMS resource ID]:resource:' \
  '--azure-kv[Azure Key Vault URL]:url:' \
  '--hc-vault-transit[HashiCorp Vault transit key]:path:' \
  '--age[age recipient]:recipient:' \
  '--pgp[PGP fingerprint]:fingerprint:' \
  '--encrypted-regex[set encrypted key regex]:regex:' \
  '--encrypted-suffix[set encrypted key suffix]:suffix:' \
  '--unencrypted-regex[set unencrypted key regex]:regex:' \
  '--unencrypted-suffix[set unencrypted key suffix]:suffix:' \
  '--mac-only-encrypted[compute MAC only over encrypted values]' \
  '--shamir-secret-sharing-threshold[number of keys required to decrypt]:threshold:' \
  '--verbose[enable verbose logging]' \
  '--ignore-mac[ignore MAC errors]' \
  '1:command:->command' \
  '*:file:_files' && ret=0

case $state in
  (command)
    local -a commands=(
      'exec-env:execute command with decrypted values in environment'
      'exec-file:execute command with decrypted file'
      'publish:publish sops file to a pre-configured destination'
      'keyservice:start a sops key service server'
      'groups:manage key groups'
      'updatekeys:update keys for a sops file'
      'filestatus:check if a file is encrypted'
    )
    _describe -t commands 'command' commands && ret=0
    _files && ret=0
    ;;
esac

return ret
