#compdef vips

# Zsh completion for vips (libvips image processing tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:List all operations or categories'
  'header:Print image header'
  'copy:Copy image'
  'jpegsave:Save as JPEG'
  'pngsave:Save as PNG'
  'tiffsave:Save as TIFF'
  'webpsave:Save as WebP'
  'heifsave:Save as HEIF'
  'gifsave:Save as GIF'
  'thumbnail:Generate thumbnail'
  'resize:Resize image'
  'rotate:Rotate image'
  'flip:Flip image'
  'crop:Extract area from image'
  'embed:Embed image within larger image'
  'gravity:Place image within a larger canvas'
  'smartcrop:Smart crop with attention/entropy detection'
  'linear:Calculate (a * in + b)'
  'invert:Invert an image'
  'flatten:Flatten alpha out of an image'
  'colourspace:Convert colorspace'
  'composite:Composite images together'
  'join:Join images side by side'
  'insert:Insert one image into another'
  'extract_band:Extract band from image'
  'bandjoin:Bandwise join of images'
  'gaussblur:Gaussian blur'
  'sharpen:Sharpen image'
)

_arguments -s -S -C \
  '--vips-concurrency=[Set concurrency level]:threads' \
  '--vips-progress[Show progress output]' \
  '--vips-cache-max=[Set max cache entries]:entries' \
  '--vips-cache-max-mem=[Set max cache memory in bytes]:bytes' \
  '--vips-cache-max-files=[Set max cached files]:files' \
  '--vips-leak[Print object leak report on exit]' \
  '--vips-version[Print libvips version]' \
  '1:command:->command' \
  '*:arguments' && ret=0

case $state in
  command)
    _describe -t commands 'vips operation' commands && ret=0
    ;;
esac

return ret
