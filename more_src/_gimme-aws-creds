#compdef gimme-aws-creds
# Documentation: https://github.com/Nike-Inc/gimme-aws-creds
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for gimme-aws-creds - AWS credentials via Okta

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[gimme-aws-creds profile to use]:profile' \
  '(-u --username)'{-u,--username}'=[Okta username]:username' \
  '(-r --resolve)'{-r,--resolve}'[resolve AWS account aliases]' \
  '(-m --remember-device)'{-m,--remember-device}'[remember MFA device]' \
  '(-o --output-format)'{-o,--output-format}'=[output format]:format:(json export windows)' \
  '--mfa-code=[provide MFA code]:code' \
  '--aws-cred-profile=[AWS credential profile name]:profile' \
  '--roles=[comma-separated list of roles to assume]:roles' \
  '--action-configure[configure gimme-aws-creds]' \
  '--action-list-profiles[list configuration profiles]' \
  '--action-list-roles[list available roles]' \
  '--action-store-json-creds[store JSON credentials from stdin]' \
  '--action-setup-fido-authenticator[register a new FIDO security key]' \
  && ret=0

return ret
