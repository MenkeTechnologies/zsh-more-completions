#compdef gimme-aws-creds

# Zsh completion for gimme-aws-creds - AWS credentials via Okta

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[AWS profile to use]:profile' \
  '--resolve[resolve AWS account aliases]' \
  '--force-classic[force classic login flow]' \
  '--configure[configure gimme-aws-creds]' \
  '--roles=[comma-separated list of roles to assume]:roles' \
  '--output-format=[output format]:format:(export json)' \
  '--action-list[list available roles]' \
  '--action-configure[configure the tool]' \
  '--action-register-device[register a new device]' \
  '--action-resolve[resolve account aliases]' \
  '--username=[Okta username]:username' \
  '--cred-profile=[credential profile to save to]:profile' \
  && ret=0

return ret
