#compdef noti

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  {-t,--title}'[notification title]:title' \
  {-m,--message}'[notification message]:message' \
  {-b,--banner}'[trigger banner notification]' \
  {-s,--speech}'[trigger speech notification]' \
  {-p,--pval}'[p-value for statistical significance]:p-value' \
  {-w,--time}'[time to trigger notification]:time' \
  '*:command:_command_names -e' \
  && ret=0

return ret
