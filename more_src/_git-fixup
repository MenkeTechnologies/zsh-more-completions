#compdef git-fixup
# Documentation: https://man.archlinux.org/search?q=git-fixup
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/git-fixup — git commit --fixup helper

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
