#compdef scite
# Documentation: https://www.scintilla.org/SciTEDoc.html
# SciTE text editor command-line file/command arguments

local ret=1

_arguments -s \
  '-p[print the file and exit]' \
  '-open\:-[open the specified file]:file:_files' \
  '-close\:-[close a buffer]' \
  '-cwd\:-[change working directory]:dir:_files -/' \
  '-find\:-[search for text]:text:' \
  '-goto\:-[jump to line and optional column]:line:' \
  '-loadsession\:-[load a session file]:session:_files' \
  '-saveas\:-[save with new name]:file:_files' \
  '-quit\:-[exit SciTE]' \
  '-import[import properties from directory]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
