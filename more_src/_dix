#compdef dix
# Documentation: https://github.com/manic-systems/dix
# Source: manic-systems/dix crates/dix/src/main.rs — fast diff tool for Nix store paths (Rust, clap).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--color=[when to use color]:when:(auto always never)' \
    '--force-correctness[skip SQLite immutable-mode fast path]' \
    '--output=[output format]:format:(human json)' \
    '*'{-v,--verbose}'[increase verbosity]' \
    '*'{-q,--quiet}'[decrease verbosity]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[print version]' \
    '1:old path:_files -/' \
    '2:new path:_files -/' \
    && ret=0

return ret
