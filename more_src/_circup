#compdef circup
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--version[show version]' \
  '--verbose[enable verbose output]' \
  '--path[path to CircuitPython directory]:directory:_directories' \
  '--password[password for web workflow]:password' \
  '--board-id[board identifier]:board id' \
  '--cpy-version[CircuitPython version]:version' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'install:install a library'
      'uninstall:uninstall a library'
      'list:list installed libraries'
      'show:show library details'
      'freeze:output installed libraries for requirements.txt'
      'update:update installed libraries'
      'bundle-install:install a bundle'
      'bundle-show:show installed bundles'
    )
    _describe -t commands 'circup command' commands && ret=0
    ;;
  args)
    case $words[1] in
      install|uninstall|show|update)
        _message 'library name' && ret=0
        ;;
    esac
    ;;
esac
return ret
