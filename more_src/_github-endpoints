#compdef github-endpoints
# Documentation: https://github.com/gwen001/github-endpoints
# Find endpoints on GitHub for a given domain.

local ret=1

_arguments -s -S \
  '-all[display urls of all other domains]' \
  '-d[domain you are looking for (required)]:domain' \
  '-e[extended mode, also look for <dummy>example.com]' \
  '-k[exit when all tokens have been disabled]' \
  '-o[output file (default <domain>.txt)]:file:_files' \
  '-r[display relative urls]' \
  '-raw[raw output]' \
  '-t[github token, comma list, or .tokens file (required)]:token' && ret=0

return ret
