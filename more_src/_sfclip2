#compdef sfclip2
# Documentation: https://www.reproducibility.org/blog/2011/09/03/program-of-the-month-sfclip/
# Madagascar: one- or two-sided data clipping

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'lower=[clip values below this lower bound]:lower:' \
  'upper=[clip values above this upper bound]:upper:' \
  '*: :_files' && ret=0

return ret
