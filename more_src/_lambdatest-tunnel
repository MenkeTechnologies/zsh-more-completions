#compdef LT lambdatest-tunnel lt-tunnel
# _lambdatest-tunnel — LambdaTest LT lambdatest-tunnel CLI cross-platform binary creating a secure tunnel between LambdaTest cloud-running browsers and a developer-machine local web server to test internal staging localhost applications private-networks intranet sites without firewall changes (LambdaTest team, Go); custom argparse
# upstream: https://www.lambdatest.com/support/docs/lambda-tunnel-modifiers/

_lambdatest-tunnel() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--user=+[user]:str:' \
        '-u+[user]:str:' \
        '--key=+[access key]:str:' \
        '-k+[access key]:str:' \
        '--tunnelName=+[name]:str:' \
        '--proxyHost=+[host]:_hosts' \
        '--proxyPort=+[port]:n:' \
        '--proxyUser=+[user]:str:' \
        '--proxyPass=+[password]:str:' \
        '--sharedTunnel[shared tunnel]' \
        '--logFile=+[file]:file:_files' \
        '--mode=+[m]:m:(ssh ws)' \
        '--ngrokFlag=+[flag]:str:' \
        '--port=+[port]:n:' \
        '--dir=+[dir]:dir:_files -/' \
        '--mitm[man-in-the-middle inspection]' \
        '--callbackURL=+[url]:str:' \
        '--bypassHosts=+[list]:str:' \
        '--allowHosts=+[list]:str:' \
        '--dns=+[ip]:_hosts' \
        '--env=+[env]:str:' \
        '--env-file=+[file]:file:_files' \
        '--maxIdleTimeout=+[sec]:n:' \
        '--no-ssl-verify[no ssl verify]' \
        '--ingress-only[ingress only]' \
        '*::'
}

_lambdatest-tunnel "$@"
