#compdef scil_labels_dilate
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_labels_dilate.html
# Scilpy: dilate labels in a label volume

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--distance=[maximum dilation distance]:distance' \
  '--labels_to_dilate=[labels to dilate]:labels' \
  '--labels_to_fill=[labels to fill]:labels' \
  '--labels_not_to_dilate=[labels not to dilate]:labels' \
  '--mask=[binary mask]:mask:_files' \
  '--processes=[number of sub-processes]:nbr' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_file:_files' \
  '2:out_file:_files' && ret=0

return ret
