#compdef pypublish
# Documentation: https://mpastell.com/pweave/script.html
# Pypublish: weave a Pweave document and convert it to PDF or HTML

local ret=1

_arguments -s -S \
  '(- *)--version[show version and exit]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:input file:_files' && ret=0

return ret
