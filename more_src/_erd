#compdef erd erdtree

# Zsh completion for erdtree (erd) - A multi-threaded file-tree visualizer and disk usage analyzer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --disk-usage)'{-d,--disk-usage}'[show disk usage]:type:(logical physical line-count word-count block-size)' \
  '--no-config[don'\''t read any config files]' \
  '(-f --follow)'{-f,--follow}'[follow symbolic links]' \
  '--hidden[show hidden files]' \
  '(.)-H[show hidden files]' \
  '(-I --icons)'{-I,--icons}'[show file icons]' \
  '--no-ignore[do not respect .gitignore files]' \
  '(-l --long)'{-l,--long}'[show extended metadata and attributes]' \
  '(-L --level)'{-L,--level}'[maximum depth to display]:depth:' \
  '(-p --pattern)'{-p,--pattern}'[only show entries matching glob]:glob pattern:' \
  '--glob[use glob for pattern matching (default)]' \
  '--regex[use regex for pattern matching]' \
  '--iglob[case-insensitive glob]' \
  '--iregex[case-insensitive regex]' \
  '(-P --prune)'{-P,--prune}'[remove empty directories from output]' \
  '(-s --sort)'{-s,--sort}'[sort entries]:sort type:(name size size-rev none)' \
  '(-S --suppress-size)'{-S,--suppress-size}'[suppress printing the total size]' \
  '(-t --threads)'{-t,--threads}'[number of threads to use]:number:' \
  '--dirs-first[list directories before files]' \
  '--dirs-only[only list directories]' \
  '--file-type=[filter by file type]:file type:(file dir link)' \
  '--layout=[set layout type]:layout:(flat inverted)' \
  '--size-left[show disk usage to the left of the tree]' \
  '--no-git[disable .gitignore rules]' \
  '--completions=[generate shell completions]:shell:(bash zsh fish)' \
  '--inverted[display the tree with the root at the bottom]' \
  '--truncate[truncate long file names]' \
  '*:directory:_files -/' && ret=0

return ret
