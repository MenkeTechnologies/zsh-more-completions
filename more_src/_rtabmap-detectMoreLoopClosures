#compdef rtabmap-detectMoreLoopClosures
# Documentation: https://github.com/introlab/rtabmap/blob/master/tools/DetectMoreLoopClosures/main.cpp
# Detect additional loop closures in an RTAB-Map database

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-r[cluster radius (default 1 m)]:m' \
  '-rx[cluster radius min (default 0 m)]:m' \
  '-a[cluster angle (default 30 deg)]:deg' \
  '-i[iterations (default 1)]:n' \
  '--intra[add only intra-session loop closures]' \
  '--inter[add only inter-session loop closures]' \
  '--session[add loop closures from/to specific map session ID]:id' \
  '*:database:_files -g "*.db"' && ret=0

return ret
