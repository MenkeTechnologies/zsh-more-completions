#compdef qsig
# _qsig-pbs — PBS qsig (send a UNIX signal to all processes of a running PBS job, plus the SIGNULL admin pseudo-signals (SuspendResume, Requeue, Admin); -s SIGNAL or its name, positional argument is the list of jobIDs)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qsig.c on tip.

_qsig-pbs() {
    _arguments \
        '-s+[signal]:signal:(HUP INT QUIT ILL TRAP ABRT BUS FPE KILL USR1 SEGV USR2 PIPE ALRM TERM CHLD CONT STOP TSTP TTIN TTOU URG XCPU XFSZ VTALRM PROF WINCH IO PWR SYS NULL SuspendResume Requeue Admin)' \
        '*:jobID:'
}

_qsig-pbs "$@"
