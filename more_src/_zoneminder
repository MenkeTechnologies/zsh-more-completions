#compdef zoneminder
# Documentation: (CCTV surveillance system; GUI-driven, controlled via systemd)
# Reference accessed: 2026-05-16
# Verified: ZoneMinder is controlled via systemd unit `zoneminder` or
# `zmpkg.pl start/stop/restart`. Bare `zoneminder` is not a primary
# user-facing CLI binary.

# zoneminder: CCTV surveillance system (GUI/systemd-driven)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::extra args:_files' && ret=0
return ret
