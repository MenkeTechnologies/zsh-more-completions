#compdef idme

# idme: read/write Amazon Fire / Kindle idme (HW info) partition
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-p[device]:device:_files' \
  '-r[read mode]' \
  '-w[write mode]' \
  '-d[dump]' \
  '*:tag value:' && ret=0
return ret
