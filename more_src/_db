#compdef db
# Documentation: https://github.com/infostreams/db
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# db — MySQL schema VCS (infostreams/db)

local curcontext="$curcontext" ret=1

local -a cmds=(change export import init load log nuke remove save server show structure test)

_arguments -s -S \
  "1:command:($cmds)" \
  '*::args:{ _message "server alias / subcommand args" }' && ret=0

return ret
