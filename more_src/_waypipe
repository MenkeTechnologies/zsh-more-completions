#compdef waypipe

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'ssh:run waypipe over SSH'
      'server:run as server'
      'client:run as client'
      'bench:run benchmarks'
    )
    _describe -t commands 'waypipe command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (ssh)
        _arguments -s -S \
          '(-s --socket)'{-s,--socket}'=[socket path]:socket:_files' \
          '--video[enable hardware video encoding]' \
          '(-c --compress)'{-c,--compress}'=[compression method]:method:(none lz4 zstd)' \
          '--threads=[number of threads]:threads' \
          '--login-shell=[login shell on remote]:shell:_files' \
          '--drm-node=[DRM render node]:node:_files -W /dev/dri' \
          '--oneshot[exit after first client disconnects]' \
          '--display=[wayland display]:display' \
          '--version[show version]' \
          '--help[show help]' \
          '*:ssh arguments' && ret=0
        ;;
      (server)
        _arguments -s -S \
          '(-s --socket)'{-s,--socket}'=[socket path]:socket:_files' \
          '--video[enable hardware video encoding]' \
          '(-c --compress)'{-c,--compress}'=[compression method]:method:(none lz4 zstd)' \
          '--threads=[number of threads]:threads' \
          '--drm-node=[DRM render node]:node:_files -W /dev/dri' \
          '--oneshot[exit after first client disconnects]' \
          '--display=[wayland display]:display' \
          '--version[show version]' \
          '--help[show help]' && ret=0
        ;;
      (client)
        _arguments -s -S \
          '(-s --socket)'{-s,--socket}'=[socket path]:socket:_files' \
          '--video[enable hardware video encoding]' \
          '(-c --compress)'{-c,--compress}'=[compression method]:method:(none lz4 zstd)' \
          '--threads=[number of threads]:threads' \
          '--oneshot[exit after first client disconnects]' \
          '--version[show version]' \
          '--help[show help]' && ret=0
        ;;
      (bench)
        _arguments -s -S \
          '--version[show version]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
