#compdef rootcheck_control
# Documentation: https://ossec-docs.readthedocs.io/en/latest/docs/programs/rootcheck_control.html
# Wazuh/OSSEC rootcheck database management tool

local ret=1

_arguments -s -S \
  '(- *)-h[show help message]' \
  '-l[list available agents]' \
  '-lc[list connected agents only]' \
  '-u+[update (clear) database for agent id or all]:id:' \
  '-i+[print database for agent id]:id:' \
  '-r[with -i, print resolved issues]' \
  '-q[with -i, print outstanding issues]' \
  '-L[with -i, print last scan]' \
  '-s[CSV output]' \
  '*::arg:_files' && ret=0

return ret
