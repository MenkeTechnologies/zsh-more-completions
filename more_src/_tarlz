#compdef tarlz
# Documentation: https://www.nongnu.org/lzip/tarlz.html
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)--help[show help]' \
  '(-A --concatenate -c --create -d --diff -r --append -t --list -x --extract --delete)'{-A,--concatenate}'[append tar archives to archive]' \
  '(-A --concatenate -c --create -d --diff -r --append -t --list -x --extract --delete)'{-c,--create}'[create a new archive]' \
  '(-A --concatenate -c --create -d --diff -r --append -t --list -x --extract --delete)'{-d,--diff}'[compare archive with filesystem]' \
  '(-A --concatenate -c --create -d --diff -r --append -t --list -x --extract --delete)'{-r,--append}'[append files to archive]' \
  '(-A --concatenate -c --create -d --diff -r --append -t --list -x --extract --delete)'{-t,--list}'[list contents of archive]' \
  '(-A --concatenate -c --create -d --diff -r --append -t --list -x --extract --delete)'{-x,--extract}'[extract files from archive]' \
  '(-A --concatenate -c --create -d --diff -r --append -t --list -x --extract --delete)--delete[delete members from archive]' \
  '(-z --compress)'{-z,--compress}'[compress the archive with lzip]' \
  '(-f --file)'{-f,--file}'[archive file]:archive file:_files' \
  '(-C --directory)'{-C,--directory}'[change to directory]:directory:_directories' \
  '(-h --dereference)'{-h,--dereference}'[follow symlinks]' \
  '(-n --threads)'{-n,--threads}'[number of worker threads]:threads: ' \
  '(-o --owner)'{-o,--owner}'[set owner for extracted files]:owner:_users' \
  '(-p --preserve-permissions)'{-p,--preserve-permissions}'[preserve permissions]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet operation]' \
  '--asolid[create solidly compressed appendable archive]' \
  '--dsolid[create per-directory solid archive]' \
  '--no-solid[create individually compressed archive]' \
  '--solid[create solidly compressed archive]' \
  '--anonymous[equivalent to --owner=root --group=root]' \
  '*--exclude[exclude files matching pattern]:pattern: ' \
  '--keep-damaged[do not delete partially extracted files]' \
  '--missing-crc[do not verify CRC of extracted files]' \
  '--out-slots[number of output slots]:slots: ' \
  '-0[compression level 0 (fastest)]' \
  '-1[compression level 1]' \
  '-2[compression level 2]' \
  '-3[compression level 3]' \
  '-4[compression level 4]' \
  '-5[compression level 5]' \
  '-6[compression level 6 (default)]' \
  '-7[compression level 7]' \
  '-8[compression level 8]' \
  '-9[compression level 9 (best)]' \
  '*:file:_files'
