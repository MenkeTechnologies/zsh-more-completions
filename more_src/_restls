#compdef restls
# Documentation: https://github.com/3andne/restls
# restls - a perfect impersonation of TLS to defeat active probing and traffic analysis

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --server-hostname)'{-s,--server-hostname}'=[the TLS server to impersonate]:hostname' \
  '(-l --listen)'{-l,--listen}'=[address and port to listen on]:addr' \
  '(-p --password)'{-p,--password}'=[restls authentication password]:password' \
  '(-f --forward-to)'{-f,--forward-to}'=[destination proxy server address]:addr' \
  '--script=[restls script for traffic obfuscation patterns]:script' \
  '--log-level=[logging verbosity level]:level:(off error warn info debug trace)' && ret=0

return ret
