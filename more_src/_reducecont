#compdef reducecont
# Documentation: https://bio3d.colorado.edu/imod/doc/man/reducecont.html
# reducecont - reduce the number of points in model contours

local ret=1

_arguments -s -S \
  '(-i --input)'{-i,-input}'[input model file]:file:_files' \
  '(-ou --output)'{-ou,-output}'[output model file]:file:_files' \
  '(-ob --objects)'{-ob,-objects}'[list of objects to reduce]:objects' \
  '(-t --tolerance)'{-t,-tolerance}'[max change in the model from removing a point]:tolerance' \
  '(-sm --smoothing)'{-sm,-smoothing}'[number of points and polynomial order]:points,order' \
  '(-sp --spaced)'{-sp,-spaced}'[target spacing for an alternative reduction method]:target' \
  '(-h --help)'{-h,-help}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
