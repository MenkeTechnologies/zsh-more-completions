#compdef gz-sim
# Documentation: https://gazebosim.org/docs
# Gazebo Sim server/GUI runner

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print Gazebo version information]' \
  '(-v --verbose)'{-v,--verbose}'=[adjust console output level 0-4]:level:(0 1 2 3 4)' \
  '-r[run simulation on start]' \
  '-s[run only the server, headless]' \
  '-g[run only the GUI]' \
  '--iterations=[number of iterations to execute]:count' \
  '-z[update rate in Hertz]:hz' \
  '--seed=[custom seed for random number generator]:seed' \
  '--headless-rendering[run rendering in headless mode]' \
  '--render-engine=[rendering engine plugin to load]:engine' \
  '--render-engine-gui=[rendering engine plugin for the GUI]:engine' \
  '--render-engine-server=[rendering engine plugin for the server]:engine' \
  '--physics-engine=[physics engine plugin to load]:engine' \
  '--gui-config=[Gazebo GUI configuration file]:file:_files' \
  '--levels[use the level system]' \
  '--network-role=[participant role in distributed simulation]:role' \
  '--network-secondaries=[number of secondary participants expected]:count' \
  '--initial-sim-time=[initial simulation time in seconds]:seconds' \
  '--record[enable logging system to record states]' \
  '--record-path=[custom path for recorded files]:path:_files -/' \
  '--record-resources[record meshes and material files]' \
  '--record-topic=[additional topics to record]:topic' \
  '--record-period=[time period between state recording]:period' \
  '--log-overwrite[overwrite existing files when recording]' \
  '--log-compress[compress final log files]' \
  '--playback=[use logging system to play back states]:path:_files -/' \
  '*:sdf file:_files' && ret=0

return ret
