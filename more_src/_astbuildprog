#compdef astbuildprog
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astbuildprog.html
# astbuildprog — compile and run C programs linked with Gnuastro libraries

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[only report errors, remain quiet about steps]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and abort]' \
  '(-a --la)'{-a,--la}'[libtool .la file to use instead of default]:file:_files' \
  '(-c --cc)'{-c,--cc}'[C compiler executable name]:compiler' \
  '(-e --noenv)'{-e,--noenv}'[exclude environment variables like LDFLAGS or CPPFLAGS]' \
  '(-I --includedir)'{-I,--includedir}'[directories to search for header files]:dir:_files -/' \
  '(-l --linklib)'{-l,--linklib}'[libraries to link]:lib' \
  '(-L --linkdir)'{-L,--linkdir}'[directory to search for libraries]:dir:_files -/' \
  '(-t --tag)'{-t,--tag}'[libtool tag for programming language]:tag' \
  '(-b --onlybuild)'{-b,--onlybuild}'[compile but do not execute the program]' \
  '(-d --deletecompiled)'{-d,--deletecompiled}'[remove compiled program after running]' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-g --debug)'{-g,--debug}'[include debugging symbols in binary]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-O --optimize)'{-O,--optimize}'[optimization level]:level:(0 1 2 3)' \
  '(-W --warning)'{-W,--warning}'[compilation warnings from command line]:warning' \
  '*:source:_files' && ret=0

return ret
