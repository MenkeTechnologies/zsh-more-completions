#compdef hackbench
# Documentation: https://wiki.linuxfoundation.org/realtime/documentation/howto/tools/rt-tests
# Source: rt-tests src/hackbench/hackbench.c — scheduler benchmark via pipes / Unix sockets.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-p --pipe)'{-p,--pipe}'[use pipes instead of Unix sockets]' \
    '(-s --datasize)'{-s+,--datasize=}'[message size (bytes)]:bytes:_default' \
    '(-l --loops)'{-l+,--loops=}'[message iterations]:n:_default' \
    '(-g --groups)'{-g+,--groups=}'[sender/receiver groups]:n:_default' \
    '(-f --fds)'{-f+,--fds=}'[file descriptors per group]:n:_default' \
    '(-T --threads -P --processes)'{-T,--threads}'[threaded mode]' \
    '(-P --processes -T --threads)'{-P,--processes}'[process mode (default)]' \
    '(-F --fifo)'{-F,--fifo}'[FIFO real-time scheduling]' \
    && ret=0

return ret
