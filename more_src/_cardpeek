#compdef cardpeek
# Documentation: https://github.com/L1L1/cardpeek
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Cardpeek: smart card content explorer (Lua engine)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--debug[debug logging]' \
  '--reader=[reader name]:reader:' \
  '*::cardpeek args:_files' && ret=0
return ret
