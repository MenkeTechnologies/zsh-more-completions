#compdef cardpeek
# Documentation: https://man.archlinux.org/search?q=cardpeek
# Reference accessed: 2026-05-16

# Cardpeek: smart card content explorer (Lua engine)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--debug[debug logging]' \
  '--reader=[reader name]:reader:' \
  '*::cardpeek args:_files' && ret=0
return ret
