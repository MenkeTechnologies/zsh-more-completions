#compdef cardpeek

# Cardpeek: GTK tool to inspect ISO 7816 smartcards
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-d[run in debug mode]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-r[card reader number]:n:' \
  '-x[run Lua script and exit]:file:_files -g "*.lua"' \
  '*::cardpeek args:_files' && ret=0
return ret
