#compdef dmmaskbin
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmmaskbin.html
# Group image pixels into bins defined by a mask image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input 2D image to rebin]:infile:_files' \
  'maskfile=[input 2D mask image]:maskfile:_files' \
  'outfile=[output image file name]:outfile:_files' \
  'errfile=[input variance/error estimate]:errfile:_files' \
  'snrfile=[output SNR image]:snrfile:_files' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:argument:_files' && ret=0

return ret
