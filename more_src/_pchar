#compdef pchar
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/pchar.8.html
# pchar - perform network measurements along an Internet path

local ret=1

_arguments -s -S \
  '(-h)-h[display usage information]' \
  '-a[analysis type for bandwidth estimation]:type:(lsq kendall lms lmsint)' \
  '-b[packet burst size to induce queueing]:size' \
  '-c[ignore routing changes during execution]' \
  '-C[enable pcap capture library (required for TCP probes)]' \
  '-d[debugging output level]:level' \
  '-g[mean inter-probe gap in seconds (default 0.25)]:seconds' \
  '-G[gap time distribution]:dist:(fixed exp)' \
  '-H[maximum hop count to probe (default 30)]:hops' \
  '-i[interface to listen on with -C]:iface' \
  '-I[probe packet size increment in bytes (default 32)]:bytes' \
  '-l[local source address for probe packets]:addr:_hosts' \
  '-m[maximum probe packet size (default 1500)]:bytes' \
  '-M[operational mode]:mode:(pchar trout)' \
  '-n[disable hostname resolution]' \
  '-p[probe protocol]:proto:(ipv4udp ipv4raw ipv4icmp ipv4tcp ipv6icmp ipv6udp)' \
  '-P[starting UDP port number (default 32768)]:port' \
  '-q[quiet mode: suppress all output]' \
  '-r[read measurements from file for offline analysis]:file:_files' \
  '-R[repetitions per probe packet size (default 32)]:count' \
  '-s[starting hop for probing (default 1)]:hop' \
  '-S[perform SNMP queries at each hop]' \
  '-t[ICMP timeout in seconds (default 3)]:seconds' \
  '-T[IP Type of Service bits]:tos' \
  '-v[verbose mode: print probe progress]' \
  '-V[display version and copyright]' \
  '-w[write statistics to file (- for stdout)]:file:_files' \
  '*::host:_hosts' && ret=0

return ret
