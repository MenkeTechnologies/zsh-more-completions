#compdef bundletool

# Zsh completion for bundletool - Android App Bundle tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build-apks:generate APKs from an app bundle'
  'build-bundle:build an app bundle from pre-compiled modules'
  'extract-apks:extract APKs from an APK set archive'
  'get-device-spec:get device spec for connected device'
  'get-size:get estimated download sizes'
  'install-apks:install APKs from an APK set archive'
  'install-multi-apks:install APK sets for multiple apps'
  'validate:validate an app bundle'
  'dump:dump information about an app bundle'
  'version:show version'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'bundletool command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      build-apks)
        _arguments \
          '--bundle=[path to app bundle]:bundle file:_files -g "*.aab"' \
          '--output=[output APK set archive]:output file:_files' \
          '--overwrite[overwrite output file if it exists]' \
          '--ks=[path to keystore]:keystore file:_files' \
          '--ks-pass=[keystore password]:password:' \
          '--ks-key-alias=[key alias]:alias:' \
          '--key-pass=[key password]:password:' \
          '--connected-device[generate APKs for connected device]' \
          '--device-spec=[device spec JSON]:spec file:_files -g "*.json"' \
          '--mode=[APK generation mode]:mode:(default universal system system_compressed)' \
          '--local-testing[enable local testing mode]'
        ;;
      install-apks)
        _arguments \
          '--apks=[path to APK set archive]:apks file:_files' \
          '--device-id=[device serial number]:device:' \
          '--modules=[comma-separated list of modules]:modules:' \
          '--allow-downgrade[allow version code downgrade]'
        ;;
      validate)
        _arguments \
          '--bundle=[path to app bundle]:bundle file:_files -g "*.aab"'
        ;;
      dump)
        _arguments \
          '1:what:(manifest resources config)' \
          '--bundle=[path to app bundle]:bundle file:_files -g "*.aab"' \
          '--module=[module name]:module:'
        ;;
      get-device-spec)
        _arguments \
          '--output=[output file]:output file:_files' \
          '--device-id=[device serial number]:device:' \
          '--overwrite[overwrite output file]'
        ;;
    esac
    ;;
esac

return ret
