#compdef grafana-agent-operator

# grafana-agent-operator: Kubernetes operator for Grafana Agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--kubelet-service=[kubelet service]:svc:' \
  '--namespace=[namespace]:ns:' \
  '--metrics-addr=[metrics bind address]:addr:' \
  '--enable-leader-election[enable leader election]' \
  '--health-probe-bind-address=[health probe bind address]:addr:' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--log-format=[log format]:fmt:(logfmt json)' \
  '*::grafana-agent-operator args:_files' && ret=0
return ret
