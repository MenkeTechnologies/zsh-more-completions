#compdef revsocks
# Documentation: https://github.com/kost/revsocks
# reverse SOCKS5 tunnel over TLS/WebSocket/DNS

local ret=1

_arguments -s -S \
  '-version[show version]' \
  '-connect[server address:port to connect to]:addr:' \
  '-listen[local address:port for reverse SOCKS server]:addr:' \
  '-socks[local SOCKS5 server address]:addr:' \
  '-pass[authentication password]:password:' \
  '-proxy[proxy server address for outbound]:addr:' \
  '-proxyauth[proxy auth (Domain/user:password)]:auth:' \
  '-proxytimeout[proxy response timeout ms]:ms:' \
  '-agent[custom User-Agent string]:agent:' \
  '-cert[TLS certificate file]:file:_files' \
  '-tls[enable TLS encryption]' \
  '-verify[verify TLS certificates]' \
  '-ws[enable WebSocket tunneling]' \
  '-dns[DNS domain for DNS tunneling]:domain:' \
  '-dnslisten[DNS server listen address]:addr:' \
  '-dnsdelay[delay between DNS requests]:delay:' \
  '-recn[max reconnection attempts (0=infinite)]:n:' \
  '-rect[seconds between reconnect attempts]:seconds:' \
  '-debug[enable debug output]' \
  '-q[quiet mode]' && ret=0

return ret
