#compdef SvtAv1DecApp
# Documentation: https://gitlab.com/AOMediaCodec/SVT-AV1/-/blob/master/Docs/svt-av1_decoder_user_guide.md
# SVT-AV1 reference decoder sample application

local ret=1

_arguments -s \
  '-help[show usage options and exit]' \
  '-i[input file name]:file:_files' \
  '-o[output file name]:file:_files' \
  '-skip[skip the first n input frames]:n:' \
  '-limit[stop decoding after n frames]:n:' \
  '-bit-depth[input bitdepth]:depth:(8 10)' \
  '-w[input picture width]:width:' \
  '-h[input picture height]:height:' \
  '-colour-space[input picture colour space]:csp:(400 420 422 444)' \
  '-threads[number of threads to launch]:n:' \
  '-parallel-frames[frames processed in parallel]:n:' \
  '-md5[MD5 support flag]' \
  '-fps-frm[show fps after each frame decoded]' \
  '-fps-summary[show fps summary]' \
  '-skip-film-grain[disable film grain]' && ret=0

return ret
