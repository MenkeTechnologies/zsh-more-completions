#compdef ludwig ludwig-cli
# _ludwig — Uber Ludwig declarative deep learning framework with YAML configs for tabular text vision audio (ludwig-ai team, Python); argparse
# upstream: https://github.com/ludwig-ai/ludwig

_ludwig() {
    local -a sub=(
        'train:train a model'
        'predict:run prediction'
        'evaluate:evaluate a model'
        'serve:serve a model'
        'experiment:run an experiment'
        'hyperopt:run hyperparameter optimization'
        'visualize:visualize results'
        'preprocess:preprocess dataset'
        'export-torchscript:export to TorchScript'
        'export-mlflow:export to MLflow'
        'export-carton:export to Carton'
        'export-triton:export to Triton'
        'export-neuropod:export to Neuropod'
        'datasets:datasets subcommands'
        'check-install:verify installation'
        'collect-activations:collect activations'
        'collect-weights:collect weights'
        'init-config:scaffold config'
        'render-config:render config schema'
        'upload:upload to model hub'
        'forecast:forecast on time-series'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--dataset=+[dataset file]:file:_files -g "*.csv *.parquet *.json *.tsv"' \
        '--training-set=+[train data]:file:_files' \
        '--validation-set=+[val data]:file:_files' \
        '--test-set=+[test data]:file:_files' \
        '--data-format=+[format]:f:(auto csv excel feather fwf hdf5 html htmls json jsonl parquet pickle sas spss stata tsv)' \
        '--model-path=+[model dir]:dir:_files -/' \
        '-mp+[model dir]:dir:_files -/' \
        '--output-directory=+[output dir]:dir:_files -/' \
        '-od+[output dir]:dir:_files -/' \
        '--experiment-name=+[name]:str:' \
        '--model-name=+[name]:str:' \
        '--gpus=+[gpu ids]:str:' \
        '--use-mixed-precision[mixed precision]' \
        '--batch-size=+[N]:n:' \
        '--epochs=+[N]:n:' \
        '--random-seed=+[N]:n:' \
        '--logging-level=+[level]:l:(notset debug info warning error critical)' \
        '--backend=+[backend]:b:(local ray horovod)' \
        '--profiler=+[profiler]:p:(simple advanced pytorch)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ludwig subcommand' sub ;;
    esac
}

_ludwig "$@"
