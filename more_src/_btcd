#compdef btcd btcctl
# _btcd — Conformal/Decred btcd alternative full-node Bitcoin implementation in Go and btcctl JSON-RPC client (btcsuite team, Go); go-flags
# upstream: https://github.com/btcsuite/btcd

_btcd() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-C+[config file]:file:_files' \
        '--configfile=+[config file]:file:_files' \
        '-A+[application data dir]:dir:_files -/' \
        '--datadir=+[block data dir]:dir:_files -/' \
        '--logdir=+[log dir]:dir:_files -/' \
        '--debuglevel=+[level]:l:(trace debug info warn error critical off)' \
        '-d+[level]:l:(trace debug info warn error critical off)' \
        '--addpeer=+[peer]:host:_hosts' \
        '--connect=+[peer]:host:_hosts' \
        '--listen=+[bind address]:str:' \
        '--maxpeers=+[N]:n:' \
        '--banduration=+[duration]:str:' \
        '--whitelist=+[CIDR]:str:' \
        '--rpcuser=+[rpc user]:user:_users' \
        '-u+[rpc user]:user:_users' \
        '--rpcpass=+[rpc password]:str:' \
        '-P+[rpc password]:str:' \
        '--rpclimituser=+[limit user]:user:_users' \
        '--rpclimitpass=+[limit password]:str:' \
        '--rpclisten=+[bind address]:str:' \
        '--rpccert=+[cert file]:file:_files' \
        '--rpckey=+[key file]:file:_files' \
        '--rpcmaxclients=+[N]:n:' \
        '--norpc[disable rpc]' \
        '--notls[disable tls]' \
        '--externalip=+[external ip]:host:_hosts' \
        '--proxy=+[socks proxy]:str:' \
        '--proxyuser=+[proxy user]:user:_users' \
        '--proxypass=+[proxy password]:str:' \
        '--testnet[testnet]' \
        '--regtest[regtest]' \
        '--simnet[simnet]' \
        '--signet[signet]' \
        '--addcheckpoint=+[height:hash]:str:' \
        '--nocheckpoints[disable checkpoints]' \
        '--dbtype=+[type]:t:(ffldb leveldb)' \
        '--profile=+[port]:port:_ports' \
        '--cpuprofile=+[file]:file:_files' \
        '--blocksonly[blocks only mode]' \
        '--relaynonstd[relay non-standard]' \
        '--rejectnonstd[reject non-standard]' \
        '--norelaypriority[no relay priority]' \
        '--upnp[upnp]' \
        '--maxorphantx=+[N]:n:' \
        '--blockmaxsize=+[bytes]:n:' \
        '--blockminsize=+[bytes]:n:' \
        '--blockmaxweight=+[w]:n:' \
        '--blockminweight=+[w]:n:' \
        '--blockprioritysize=+[bytes]:n:' \
        '--uacomment=+[comment]:str:'
}

_btcd "$@"
