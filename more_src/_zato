#compdef zato

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start a Zato component (server, web admin, scheduler, load-balancer)'
  'stop:stop a Zato component'
  'wait:wait for a component to become available'
  'info:print info about a Zato instance'
  'service:invoke a Zato service from CLI'
  'cache:cache management subcommands'
  'check-config:validate component configuration'
  'component-version:print component version'
  'create:create a Zato resource (cluster/odb/server/web-admin/secret-key/user)'
  'delete:delete a resource (e.g. odb)'
  'crypto:cryptographic operations (encrypt/decrypt/hash)'
  'encrypt:encrypt a value'
  'decrypt:decrypt a value'
  'hash:hash a value'
  'enmasse:bulk import/export of cluster objects'
  'ide:IDE-related helpers'
  'quickstart:run the quickstart wizard'
  'update:update commands (passwords, crypto material)'
  'from-config:run a stored config'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--store-config[record commands to a config file]' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zato command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start|stop)
        _arguments \
          '--fg[run in foreground]' \
          '--sync-internal[sync internal services]' \
          '--secret-key=[secret key]:key:' \
          '*::component_path:_files -/' && ret=0 ;;
      (create)
        local -a create_subs=(
          'cluster:create a new cluster'
          'lb:create a load-balancer'
          'odb:create operational database'
          'server:create a server instance'
          'user:create a user'
          'web_admin:create web-admin panel'
          'secret_key:create a secret key'
        )
        _describe -t cscmds 'create subcommand' create_subs && ret=0
        _arguments \
          '--postgresql-host=[postgres host]:host:_hosts' \
          '--postgresql-port=[postgres port]:port:' \
          '--cluster-name=[cluster name]:name:' \
          '--server-name=[server name]:name:' \
          '--admin-invoke-password=[admin password]:pass:' \
          '*::path:_files -/' && ret=0 ;;
      (delete)
        _arguments '*::sub:(odb)' && ret=0 ;;
      (cache)
        _arguments '*::sub:(get set remove keys list-from-server)' && ret=0 ;;
      (crypto|encrypt|decrypt|hash)
        _arguments \
          '--secret-key=[secret key]:key:' \
          '--secret-key-bytes=[bytes]:n:' \
          '*::value:' && ret=0 ;;
      (enmasse)
        _arguments \
          '--input=[input file]:file:_files -g "*.{yaml,yml,json}"' \
          '--export-local[export local YAML]' \
          '--export-odb[export ODB-only objects]' \
          '--import[import objects]' \
          '--cleanup[delete objects not in input]' \
          '--curdir[current directory]' && ret=0 ;;
      (service)
        _arguments \
          '--invoke=[service to invoke]:service:' \
          '--data-format=[data format]:format:(json xml dict)' \
          '--data=[request payload]:payload:' && ret=0 ;;
      (check-config)
        _arguments '*::path:_files -/' && ret=0 ;;
      (info)
        _arguments \
          '--output=[output format]:format:(json yaml text)' \
          '*::path:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
