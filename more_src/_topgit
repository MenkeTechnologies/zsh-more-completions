#compdef tg

# Zsh completion for tg (TopGit) - patch queue management using Git

local curcontext="$curcontext" state line ret=1

_tg_branches() {
  local branches
  branches=(${(f)"$(git for-each-ref --format='%(refname:short)' refs/heads/ 2>/dev/null)"})
  _describe -t branches 'branch' branches
}

_tg_remotes() {
  local remotes
  remotes=(${(f)"$(git remote 2>/dev/null)"})
  _describe -t remotes 'remote' remotes
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  {-r,--remote}'[specify remote]:remote:_tg_remotes' \
  {-w,--way}'[specify the way]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case "$state" in
  subcmd)
    local -a subcmds=(
      'create:create a new TopGit topic branch'
      'delete:delete a TopGit topic branch'
      'depend:add a new dependency to a topic branch'
      'export:export topic branches'
      'files:show files changed by a topic branch'
      'import:import commits as topic branches'
      'info:show information about a topic branch'
      'log:show log of a topic branch'
      'mail:send topic branch patches via email'
      'next:show the next branch in the dependency chain'
      'patch:generate a patch for a topic branch'
      'prev:show the previous branch in the dependency chain'
      'push:push a TopGit topic branch to a remote'
      'rebase:rebase a TopGit topic branch'
      'revert:revert changes in a topic branch'
      'status:show the status of a TopGit repository'
      'summary:show a summary of all topic branches'
      'tag:create a tag for a TopGit branch'
      'update:update a TopGit topic branch'
    )
    _describe -t subcommands 'tg subcommand' subcmds && ret=0
    ;;
  args)
    case "${line[1]}" in
      create)
        _arguments -s -S \
          {-d,--deps}'[specify dependencies]:dependencies' \
          '*:branch name:_tg_branches' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '*:branch:_tg_branches' && ret=0
        ;;
      export)
        _arguments -s -S \
          '--collapse[collapse all branches into one]' \
          '--quilt[export as quilt series]' \
          '--linearize[linearize the branch history]' \
          '--numbered[number the exported patches]' \
          '--flatten[flatten the directory structure]' \
          '--strip=[strip leading path components]:count' \
          '*:branch:_tg_branches' && ret=0
        ;;
      summary)
        _arguments -s -S \
          '--graphviz[output in graphviz dot format]' \
          '--sort[topologically sort the output]' \
          '--deps[show dependencies]' \
          '--rdeps[show reverse dependencies]' \
          '--tgish-only[only show TopGit branches]' \
          '--heads[show only head branches]' \
          '--orphans[show orphan branches]' \
          {-v,--verbose}'[verbose output]' \
          '-l[long listing format]' && ret=0
        ;;
      update)
        _arguments -s -S \
          '--all[update all TopGit branches]' \
          '--stash[stash changes before updating]' \
          '--no-stash[do not stash changes]' \
          '--no-commit[do not commit after update]' \
          '--edit[edit the merge commit message]' \
          '*:branch:_tg_branches' && ret=0
        ;;
      depend|files|info|log|mail|next|patch|prev|push|rebase|revert|tag)
        _arguments -s -S \
          '*:branch:_tg_branches' && ret=0
        ;;
      import)
        _arguments -s -S \
          '*:commit or branch:_tg_branches' && ret=0
        ;;
      status)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
