#compdef cookiecutter-cli
# _cookiecutter-cli — Audrey Roy Greenfeld Cookiecutter project template renderer CLI alias (cookiecutter team, Python); click
# upstream: https://github.com/cookiecutter/cookiecutter

_cookiecutter-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--no-input[no input prompts]' \
        '--checkout=+[branch/tag/sha]:str:' \
        '-c+[branch/tag/sha]:str:' \
        '--directory=+[subdirectory of template]:str:' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--config-file=+[config file]:file:_files' \
        '--default-config[default config]' \
        '--debug-file=+[debug log file]:file:_files' \
        '--accept-hooks=+[accept hooks]:b:(yes no ask)' \
        '--list-installed[list installed templates]' \
        '--overwrite-if-exists[overwrite if exists]' \
        '-f[overwrite if exists]' \
        '--skip-if-file-exists[skip if file exists]' \
        '-s[skip if file exists]' \
        '--replay[replay last context]' \
        '--replay-file=+[replay file]:file:_files' \
        '--keep-project-on-failure[keep project on failure]' \
        '--password=+[password for encrypted vcs]:str:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '*:template-and-context:_files'
}

_cookiecutter-cli "$@"
