#compdef lxc-create

# Zsh completion for lxc-create (create an LXC container)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --name)'{-n,--name}'[container name]:name' \
  '(-f --config)'{-f,--config}'[config file]:file:_files' \
  '(-t --template)'{-t,--template}'[template]:template:(alpine busybox centos debian download fedora gentoo opensuse oracle plamo sshd ubuntu)' \
  '(-B --bdev)'{-B,--bdev}'[backing store]:backend:(dir btrfs lvm loop zfs best overlay aufs)' \
  '--dir[place rootfs in directory]:directory:_files -/' \
  '--lvname[LVM logical volume name]:name' \
  '--vgname[LVM volume group name]:name' \
  '--fstype[filesystem type]:type:(ext3 ext4 xfs btrfs)' \
  '--fssize[filesystem size]:size' \
  '--zfsroot[ZFS root]:root' \
  '(-P --lxcpath)'{-P,--lxcpath}'[LXC path]:path:_files -/' \
  '(-o --logfile)'{-o,--logfile}'[log file]:file:_files' \
  '(-l --logpriority)'{-l,--logpriority}'[log priority]:priority:(FATAL CRIT ERROR WARN NOTICE INFO DEBUG)' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--:[template options]' && ret=0

return ret
