#compdef wslvar
# _wslvar — wslu wslvar (read a Windows environment variable from inside WSL; -s/--sys for built-in Windows system folder, -l/--local local-data shell vars, -e/--escape escape backslashes; positional argument is variable name (e.g. USERPROFILE, APPDATA, ProgramFiles))
# upstream: https://github.com/wslutilities/wslu
# Flags from wslu src/wslvar on tip.

_wslvar() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-s[(--sys) Windows system folder shortcut]' \
        '--sys[Windows system folder shortcut]' \
        '-l[(--local) local-data shell vars]' \
        '--local[local-data shell vars]' \
        '-e[(--escape) escape backslashes]' \
        '--escape[escape backslashes]' \
        '1:windows env var:(USERPROFILE APPDATA LOCALAPPDATA ProgramFiles ProgramData PUBLIC PROGRAMW6432 SystemRoot SystemDrive USERNAME COMPUTERNAME TEMP TMP HOMEDRIVE HOMEPATH OneDrive DESKTOP DOCUMENTS DOWNLOADS MUSIC PICTURES VIDEOS)'
}

_wslvar "$@"
