#compdef memcached_exporter
# Documentation: https://github.com/prometheus/memcached_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '--memcached.address=[address of the memcached instance]:address:' \
  '--memcached.timeout=[timeout for connecting to memcached]:duration:' \
  '--memcached.pid-file=[path to memcached pid file for process metrics]:file:_files' && ret=0

return ret
