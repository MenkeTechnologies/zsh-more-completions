#compdef bottle

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--bind=[bind socket to ADDRESS]:address:' \
  '-b+[bind socket to ADDRESS]:address:' \
  '--server=[use SERVER as backend]:server:' \
  '-s+[use SERVER as backend]:server:' \
  '--plugin=[install additional plugin/s]:plugin:' \
  '-p+[install additional plugin/s]:plugin:' \
  '*--conf=[load config values from FILE]:file:_files' \
  '*-c+[load config values from FILE]:file:_files' \
  '*--param=[override config value with KEY=VALUE]:key=value:' \
  '*-C+[override config value with KEY=VALUE]:key=value:' \
  '--debug[start server in debug mode]' \
  '--reload[auto-reload on file changes]' \
  '*:WSGI app entry (package.module\:app):' && ret=0

return ret
