#compdef corosync-quorumtool

# corosync-quorumtool: show/manage corosync quorum state
local curcontext="$curcontext" ret=1
_arguments -C \
  '-s[show quorum status]' \
  '-l[list nodes (long format)]' \
  '-p[machine-parseable output]' \
  '-i[show IP addresses for nodes]' \
  '-f[show quorum gain/lost events]' \
  '-o[sort nodes by name]:order:(a n i)' \
  '-V[show node votes]' \
  '-v[set expected votes]:n:' \
  '-h[show help]' \
  '-e[set expected votes]:n:' \
  '-H[show membership only]' \
  '-n[node-id of node to query]:nodeid:' \
  '*::corosync-quorumtool args:_files' && ret=0
return ret
