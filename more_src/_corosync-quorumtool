#compdef corosync-quorumtool
# Documentation: https://manpages.debian.org/testing/corosync/corosync-quorumtool.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream man page at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-s[show quorum status]' \
  '-m[continuously monitor quorum status]' \
  '-l[list nodes]' \
  '-p[machine-parsable output (with -s or -l)]' \
  '-i[show node IP addresses instead of resolved names]' \
  '-H[show node ids in hexadecimal]' \
  '-a[show all network interfaces, not just the first]' \
  '-f[forcefully unregister a quorum device]' \
  '-o+[sort node output by address/name/id]:order:((a\:address n\:name i\:id))' \
  '-v+[change votes for the current node (requires votequorum)]:votes:' \
  '-n+[node id used with -v]:nodeid:' \
  '-e+[change expected votes for cluster (requires votequorum)]:expected:' \
  '*::corosync-quorumtool args:_files' && ret=0
return ret
