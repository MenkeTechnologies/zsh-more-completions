#compdef corosync-quorumtool

# corosync-quorumtool: control corosync quorum state
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[show quorum status]' \
  '-l[list nodes]' \
  '-p[list nodes with periodic refresh]' \
  '-i[show node IDs and addresses]' \
  '-f[show full info]' \
  '-V[verbose output]' \
  '-o[output format]:fmt:(text xml json)' \
  '-n[show specific node]:node:' \
  '-e[set expected votes]:n:' \
  '-v[set votes for current node]:n:' \
  '*::corosync-quorumtool args:_files' && ret=0
return ret
