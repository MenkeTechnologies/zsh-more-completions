#compdef gnatprep
# Documentation: https://man.archlinux.org/search?q=gnatprep
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-a[strict mode]' \
  '-b[blank out preprocessor lines]' \
  '-c[do not emit symbol references]' \
  '-C[treat as C-style preprocessor]' \
  '-D+[define symbol]:sym=val:' \
  '-r[generate Source_Reference pragmas]' \
  '-s[show symbol references]' \
  '-T[suppress trailing whitespace]' \
  '-u[treat undefined as FALSE]' \
  '-v[verbose]' \
  '1:input:_files' \
  '2:output:_files' \
  '3:defs:_files' && ret=0

return ret
