#compdef knsupdate
# Documentation: https://www.knot-dns.cz/docs/latest/html/man_knsupdate.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '(-T --tcp)'{-T,--tcp}'[use TCP connection]' \
  '(-S --tls)'{-S,--tls}'[use TLS connection]' \
  '(-Q --quic)'{-Q,--quic}'[use QUIC connection]' \
  '(-p --port)'{-p,--port}'+[server port (default 53, 853 QUIC)]:port:' \
  '(-r --retry)'{-r,--retry}'+[UDP retry count (default 3)]:n:' \
  '(-t --timeout)'{-t,--timeout}'+[total timeout in seconds (default 12)]:seconds:' \
  '(-y --tsig)'{-y,--tsig}'+[TSIG key [alg:]name:key]:tsig:' \
  '(-k --tsigfile)'{-k,--tsigfile}'+[load TSIG key from file]:file:_files' \
  '(-H --hostname)'{-H,--hostname}'+[remote server hostname validation]:hostname:_hosts' \
  '(-P --pin)'{-P,--pin}'+[key-pinned privacy profile (base64)]:pin:' \
  '(-A --ca)'{-A,--ca}'+[certificate validation with PEM file]:file:_files' \
  '(-E --certfile)'{-E,--certfile}'+[client certificate file path]:file:_files' \
  '(-K --keyfile)'{-K,--keyfile}'+[client key file path]:file:_files' \
  '(-s --sni)'{-s,--sni}'+[Server Name Indication]:sni:' \
  '*::file:_files' && ret=0

return ret
