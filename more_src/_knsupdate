#compdef knsupdate

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-V[show version]' \
  '-d[enable debug messages]' \
  '-k+[TSIG key file for authentication]:file:_files' \
  '-p+[server port (default 53)]:port:' \
  '-r+[UDP retry count (default 3)]:n:' \
  '-t+[UDP total timeout in seconds]:seconds:' \
  '-T[use TCP connection]' \
  '-S[use TLS connection]' \
  '-Q[use QUIC connection]' \
  '-y+[TSIG key string name\[/alg/key\]]:tsig:' \
  '*::file:_files' && ret=0

return ret
