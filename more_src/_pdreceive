#compdef pdreceive
# Documentation: https://github.com/pure-data/pure-data/blob/master/src/u_pdreceive.c
# Reference accessed: 2026-05-27
# Verified: upstream pure-data/pure-data master branch src/u_pdreceive.c argv parsing

# Usage: pdreceive <portnumber> [udp|tcp] [host]
# pdreceive is a purely positional CLI with no flags.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:portnumber:' \
  '2:protocol:(tcp udp)' \
  '3:hostname:_hosts' && ret=0

return ret
