#compdef ompi-ps
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/ompi-ps.1.html
# Reference accessed: 2026-05-20
# Verified: upstream Open MPI ompi-ps(1) manpage.

# ompi-ps: list running MPI jobs/processes (OpenMPI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[display help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--daemons[display daemon job information]' \
  '(-j --jobid)'{-j+,--jobid=}'[display state of a specific job]:jobid:' \
  '(-p --vpid)'{-p+,--vpid=}'[display state of a specific vpid]:vpid:' \
  '(-n --nodes)'{-n,--nodes}'[display all allocated nodes]' \
  '*'{-mca,--mca}'[MCA parameter]:key:: :value:' \
  '*'{-gmca,--gmca}'[global MCA parameter]:key:: :value:' \
  '*::ompi-ps args:' && ret=0
return ret
