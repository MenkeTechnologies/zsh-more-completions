#compdef ompi-ps
# Documentation: https://man.archlinux.org/search?q=ompi-ps
# Reference accessed: 2026-05-16

# ompi-ps: list running MPI jobs/processes (OpenMPI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-mca[MCA parameter]:param value:' \
  '--mca=[MCA parameter]:param value:' \
  '*::ompi-ps args:_files' && ret=0
return ret
