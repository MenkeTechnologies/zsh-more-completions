#compdef cstream
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=cstream&sektion=1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '-V[show version]' \
  '-v[verbose level]:level:(0 1 2 3)' \
  '-b[block size]:n:' \
  '-B[buffer size bytes]:n:' \
  '-c[concurrency]:level:(0 1 2 3)' \
  '-n[total bytes (k/m/g)]:n:' \
  '-t[throughput bytes/sec]:n:' \
  '-i[input file (- self / "" stdin)]:file:_files' \
  '-o[output file (- sink / "" stdout)]:file:_files' \
  '-I[input file type]:type:' \
  '-O[output type chars (f F a N t D S M)]:chars:' \
  '-p[pid file]:file:_files' \
  '-l[include line count]' \
  '-w[write block size]:n:' \
  '-S[no SIGINFO stats]' \
  '-T[stats interval s]:s:' \
  '-6[IPv6 mode]:mode:(-1 1 2)' \
  '*:file:_files'
