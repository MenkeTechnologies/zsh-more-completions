#compdef weston-terminal
# _weston-terminal — Weston Wayland weston-terminal CLI demo client minimal terminal emulator launching a login shell or specified command inside a wl_surface with VT100 escape sequences keyboard handling clipboard input-method support for testing weston input layers (Weston team, C); getopt
# upstream: https://gitlab.freedesktop.org/wayland/weston

_weston-terminal() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--shell=+[shell]:file:_files -g "/bin/* /usr/bin/*"' \
        '--font=+[font]:str:' \
        '--font-size=+[size]:n:' \
        '--maximized[start maximized]' \
        '--fullscreen[fullscreen]' \
        '*:command:_files'
}

_weston-terminal "$@"
