#compdef create-vusion
# Documentation: https://www.npmjs.com/package/create-vusion
# Reference accessed: 2026-05-23
# Verified: npm view create-vusion bin; npm readme subcommands and template flags.

# Zsh completion for create-vusion - Vusion monorepo/block/component scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-V --version)'{-V,--version}'[show CLI version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' app block component repository template && ret=0
    ;;
  args)
    case $line[1] in
      app)
        _arguments -C \
          '(-c --client-template)'{-c,--client-template=}'[client template name]:template:' \
          '(-s --server-template)'{-s,--server-template=}'[server template name]:template:' \
          ':package name:' && ret=0
        ;;
      block|component|repository)
        _arguments -C \
          '(-t --template)'{-t,--template=}'[template name]:template:' \
          ':package name:' && ret=0
        ;;
      template)
        _arguments -C \
          ':template name:' && ret=0
        ;;
      *)
        _arguments -C \
          '(-c --client-template)'{-c,--client-template=}'[client template name]:template:' \
          ':project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
