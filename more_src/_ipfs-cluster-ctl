#compdef ipfs-cluster-ctl
# Documentation: https://man.archlinux.org/search?q=ipfs-cluster-ctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'id:show cluster peer info'
  'peers:manage cluster peers'
  'add:add content to the cluster'
  'pin:pin operations'
  'status:list status of tracked CIDs'
  'sync:re-sync against IPFS daemon'
  'recover:re-pin/unpin error CIDs'
  'health:health checks'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--host=[remote cluster peer]:host:_hosts' \
  '--basic-auth=[user:password]:auth:' \
  '--force-http[allow basic auth over HTTP]' \
  '--secret=[32-byte cluster secret]:secret:' \
  '--debug[debug request paths]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ipfs-cluster-ctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (peers)
        _values 'peers action' 'ls' 'rm' && ret=0
        ;;
      (pin)
        _values 'pin action' 'add' 'rm' 'ls' 'update' && ret=0
        ;;
    esac
    ;;
esac

return ret
