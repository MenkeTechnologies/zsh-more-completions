#compdef ch-build

# ch-build: Charliecloud Docker image build wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-b[build args]:args:' \
  '--build-arg=[build args]:args:' \
  '-f[Dockerfile path]:file:_files' \
  '--file=[Dockerfile path]:file:_files' \
  '--no-cache[disable build cache]' \
  '-t[image tag]:tag:' \
  '--tag=[image tag]:tag:' \
  '*:context directory:_files -/' && ret=0
return ret
