#compdef vcfannotategenotypes
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfannotategenotypes.md
# vcflib: annotate genotypes in the first VCF with genotypes from a second VCF

local ret=1

_arguments -s -S \
  ':annotation tag:' \
  ':first vcf file:_files' \
  ':second vcf file:_files' && ret=0

return ret
