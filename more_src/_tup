#compdef tup

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Initialize a tup database'
      'upd:Update build outputs'
      'monitor:Run the file monitor'
      'scan:Scan filesystem for changes'
      'refactor:Find broken dependencies'
      'graph:Generate a dependency graph'
      'node:Display node information'
      'variant:Create or manage build variants'
      'options:Display or modify tup options'
      'varsed:Substitute variables in a file'
      'version:Print version'
      'stop:Stop the monitor'
      'generate:Generate a build script'
    )
    _describe -t commands 'tup command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      upd|scan)
        _arguments -s -S \
          '--no-environ-check[skip environment variable check]' \
          '--debug-logging[enable debug logging]' \
          '--verbose[verbose output]' \
          '--quiet[quiet output]' \
          '--keep-going[continue after errors]' \
          '--no-sync[disable filesystem sync]' && ret=0
        ;;
      monitor)
        _arguments -s -S \
          {-f,--foreground}'[run in foreground]' \
          {-a,--autoupdate}'[automatically update on changes]' && ret=0
        ;;
      graph)
        _arguments -s -S \
          '--dirs[show directories]' \
          '--ghosts[show ghost nodes]' \
          '--env[show environment variables]' \
          '--combine[combine identical nodes]' \
          '--stickies[show sticky links]' && ret=0
        ;;
      init)
        _arguments -s -S \
          ':directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
