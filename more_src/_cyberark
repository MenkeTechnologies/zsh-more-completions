#compdef cyberark cyberark-cli pacli
# _cyberark — CyberArk cyberark CLI command-line frontend to the CyberArk Privileged Access Manager PAM Privilege Cloud Conjur Cloud REST API SDK Vaulted-Password-Vault credentials management providing safe account user vault platform group session activity recording authentication-PSM-CCP-AAM-Conjur retrieval (CyberArk team, Python); click
# upstream: https://www.cyberark.com/

_cyberark() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'safe:safe management'
        'account:account management'
        'user:user management'
        'group:group management'
        'platform:platform management'
        'pvwa:PVWA configuration'
        'pas:PAM operations'
        'conjur:Conjur secrets operations'
        'session:session monitoring'
        'cpm:CPM management'
        'psm:PSM management'
        'aim:AIM CCP operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '--tenant=+[name]:str:' \
        '--auth-type=+[t]:t:(cyberark windows ldap radius saml pkipipipi cybr-ldap aimws)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cyberark subcommand' sub ;;
        args)
            case $words[1] in
                safe|account|user|group|platform) _arguments '1:op:(list get create update delete)' '*:id-or-name:' ;;
                conjur) _arguments '1:op:(get put set delete list rotate)' '*:resource id:' ;;
            esac
            ;;
    esac
}

_cyberark "$@"
