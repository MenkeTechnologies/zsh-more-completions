#compdef hpssaducli
# Documentation: https://support.hpe.com/hpesc/public/docDisplay?docId=dp00002635en_us
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above (HPE SSA Diagnostics CLI).
# hpssaducli: HPE Smart Storage Administrator Diagnostics CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)help[show help]' \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '(- *)version[show version]' \
  'controller[controller subtarget]' \
  'array[array subtarget]' \
  'logicaldrive[logical drive subtarget]' \
  'physicaldrive[physical drive subtarget]' \
  'enclosure[enclosure subtarget]' \
  'show[show config / status / detail]' \
  'add[add a drive/spare]' \
  'create[create a new array or LD]' \
  'delete[delete an array or LD]' \
  'rescan[rescan]' \
  'modify[modify properties]' \
  'flash[flash firmware]' \
  'set[set parameter]' \
  'expand[expand array]' \
  'transform[migrate RAID level]' \
  '*:hpssaducli args:' && ret=0
return ret
