#compdef chainFilter
# filter chain files

local ret=1

_arguments -s -S \
  '-q=[restrict query side sequence to those named]:chroms' \
  '-notQ=[restrict query side sequence to those not named]:chroms' \
  '-t=[restrict target side sequence to those named]:chroms' \
  '-notT=[restrict target side sequence to those not named]:chroms' \
  '-id=[only get one with ID number matching N]:n' \
  '-minScore=[restrict to those scoring at least N]:n' \
  '-maxScore=[restrict to those scoring less than N]:n' \
  '-qStartMin=[restrict to those with qStart at least N]:n' \
  '-qStartMax=[restrict to those with qStart less than N]:n' \
  '-qEndMin=[restrict to those with qEnd at least N]:n' \
  '-qEndMax=[restrict to those with qEnd less than N]:n' \
  '-tStartMin=[restrict to those with tStart at least N]:n' \
  '-tStartMax=[restrict to those with tStart less than N]:n' \
  '-tEndMin=[restrict to those with tEnd at least N]:n' \
  '-tEndMax=[restrict to those with tEnd less than N]:n' \
  '-qOverlapStart=[query overlaps region starting here]:n' \
  '-qOverlapEnd=[query overlaps region ending here]:n' \
  '-tOverlapStart=[target overlaps region starting here]:n' \
  '-tOverlapEnd=[target overlaps region ending here]:n' \
  '-strand=[restrict strand]:strand:(+ -)' \
  '-long[output in long format]' \
  '-zeroGap[eliminate gaps of length zero]' \
  '-minGapless=[minimum gapless block of at least N]:n' \
  '-qMinGap=[minimum query gap size of at least N]:n' \
  '-tMinGap=[minimum target gap size of at least N]:n' \
  '-qMaxGap=[maximum query gap size no larger than N]:n' \
  '-tMaxGap=[maximum target gap size no larger than N]:n' \
  '-qMinSize=[minimum size of spanned query region]:n' \
  '-qMaxSize=[maximum size of spanned query region]:n' \
  '-tMinSize=[minimum size of spanned target region]:n' \
  '-tMaxSize=[maximum size of spanned target region]:n' \
  '-noRandom[suppress chains involving _random chromosomes]' \
  '-noHap[suppress chains involving _hap or _alt chromosomes]' \
  '*:chain file:_files -g "*.chain"' && ret=0

return ret
