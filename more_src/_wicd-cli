#compdef wicd-cli
# Documentation: https://man.archlinux.org/search?q=wicd-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-w --wireless)'{-w,--wireless}'[wireless network operations]' \
  '(-y --wired)'{-y,--wired}'[wired network operations]' \
  '(-l --list-networks)'{-l,--list-networks}'[list configured networks]' \
  '(-S --scan)'{-S,--scan}'[scan for wireless networks]' \
  '(-c --connect)'{-c,--connect}'[connect to a network]' \
  '(-d --disconnect)'{-d,--disconnect}'[disconnect]' \
  '(-n --network)'{-n,--network}'+[network id]:id:' \
  '(-i --info)'{-i,--info}'[print info about network]' \
  '(-D --details)'{-D,--details}'[print detailed info]' \
  '(-p --network-property)'{-p,--network-property}'+[set network property]:prop:' \
  '(-N --name)'{-N,--name}'+[network name]:name:' \
  '(-v --set-value)'{-v,--set-value}'+[value]:value:' \
  '(-s --status)'{-s,--status}'[print connection status]' && ret=0

return ret
