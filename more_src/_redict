#compdef redict-cli redict-server redict-benchmark

# Zsh completion for Redict (Redis fork)
# https://redict.io

local curcontext="$curcontext" state line ret=1

if [[ $service == "redict-cli" ]]; then
  _arguments -s -S \
    '-h[server hostname]:hostname:' \
    '-p[server port]:port:' \
    '-s[server socket]:socket:_files' \
    '-a[password]:password:' \
    '--user[username]:username:' \
    '-u[connection URI]:uri:_urls' \
    '-n[database number]:db:' \
    '--tls[use TLS]' \
    '--raw[raw output]' \
    '--csv[CSV output]' \
    '--stat[real-time stats]' \
    '--bigkeys[find large keys]' \
    '--memkeys[find memory-consuming keys]' \
    '--latency[sample latency]' \
    '--scan[list keys using SCAN]' \
    '--pattern[glob pattern for SCAN]:pattern:' \
    '--monitor[monitor server commands]' \
    '--version[show version]' \
    '--help[show help]' \
    '*:command:' && ret=0
elif [[ $service == "redict-server" ]]; then
  _arguments -s -S \
    '--version[show version]' \
    '--help[show help]' \
    '--test-memory[test memory]:megabytes:' \
    '*:config file:_files' && ret=0
elif [[ $service == "redict-benchmark" ]]; then
  _arguments -s -S \
    '-h[server hostname]:hostname:' \
    '-p[server port]:port:' \
    '-c[clients]:number:' \
    '-n[requests]:number:' \
    '-d[data size]:bytes:' \
    '--version[show version]' \
    '--help[show help]' && ret=0
fi

return ret
