#compdef mclient msqldump monetdb monetdbd
# Documentation: upstream MonetDB source at github.com/MonetDB/MonetDB
# Reference accessed: 2026-05-30 via gh api inspection of
# clients/mapiclient/{mclient,msqldump}.1 man pages and
# tools/merovingian/{client/monetdb.c,daemon/argvcmds.c} sources.
# MonetDB R66 — 4-stem multi-binary harvest covering the MonetDB
# client and control utilities. Server binary `mserver5` is deferred
# (different option style, large surface).

local curcontext="$curcontext" state line ret=1
local -a _formats _languages _timer_modes
_formats=( sql tab csv csv-noquote raw xml json trash test rowcount expanded )
_languages=( sql mal )
_timer_modes=( none clock performance )

case $service in

  mclient)
    # The MonetDB command-line SQL/MAL client.
    _arguments -s -S \
      '(-? --help)'{-\?,--help}'[show help]' \
      '(-v --version)'{-v,--version}'[print version and exit]' \
      '(-q --quiet)'{-q,--quiet}"[don't print welcome message at startup]" \
      '(-E --encoding)'{-E,--encoding=}'[character encoding of input]:encoding:' \
      '(-l --language)'{-l,--language=}'[query language]:language:($_languages)' \
      '(-d --database)'{-d,--database=}'[database name or URI]:database:' \
      '(-h --host)'{-h,--host=}'[server hostname (default localhost)]:host:_hosts' \
      '(-p --port)'{-p,--port=}'[server port (default 50000)]:port:' \
      '(-i --interactive)'{-i,--interactive}'[interpret backslash commands on stdin]' \
      '(-t --timer)'{-t,--timer=}'[timer mode]:mode:($_timer_modes)' \
      '(-u --user)'{-u,--user=}'[user name]:user:_users' \
      '(-f --format)'{-f,--format=}'[output format]:format:($_formats)' \
      '(-e --echo)'{-e,--echo}'[echo each line before executing it]' \
      '(-H --history)'{-H,--history}'[load and save history]' \
      '(-L --log)'{-L,--log=}'[log all queries to file]:file:_files' \
      '(-s --statement)'{-s,--statement=}'[execute statement and exit]:statement:' \
      '(-z --timezone)'{-z,--timezone}'[do not tell server about client timezone]' \
      '(-X --Xdebug)'{-X,--Xdebug}'[enable debugging on the Mapi layer]' \
      '(-\| --pager)'{-\|,--pager=}'[send output through pager command]:command:' \
      '(-n --null)'{-n,--null=}'[string to use for NULL values]:string:' \
      '(-a --autocommit)'{-a,--autocommit}'[toggle autocommit mode (default on)]' \
      '(-R --allow-remote)'{-R,--allow-remote}'[allow remote file reads (COPY FROM)]' \
      '(-r --rows)'{-r,--rows=}'[render output with N rows per page]:N:' \
      '(-w --width)'{-w,--width=}'[render output with N character width]:N:' \
      '(-D --dump)'{-D,--dump}'[create an SQL dump]' \
      '(-N --inserts)'{-N,--inserts}'[use INSERT statements when generating output]' \
      '*:file or database:_files' \
      && ret=0
    ;;

  msqldump)
    # MonetDB SQL dump utility.
    _arguments -s -S \
      '(-? --help)'{-\?,--help}'[show help]' \
      '(-d --database)'{-d,--database=}'[database name or URI]:database:' \
      '(-h --host)'{-h,--host=}'[server hostname]:host:_hosts' \
      '(-p --port)'{-p,--port=}'[server port]:port:' \
      '(-u --user)'{-u,--user=}'[user name]:user:_users' \
      '(-D --describe)'{-D,--describe}'[describe schema only (no data)]' \
      '(-N --inserts)'{-N,--inserts}'[use INSERT statements for data]' \
      '(-e --noescape)'{-e,--noescape}"[don't use escape characters in COPY INTO]" \
      '(-f --functions)'{-f,--functions}'[dump functions]' \
      '*'{-t,--table=}'[dump only the named table(s)]:table:' \
      '(-o --output)'{-o,--output=}'[output file]:file:_files' \
      '(-O --outputdir)'{-O,--outputdir=}'[output directory]:directory:_directories' \
      '(-x --compression)'{-x,--compression=}'[compress output (extension)]:extension:(gz bz2 xz zst)' \
      '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
      '(-X --Xdebug)'{-X,--Xdebug}'[enable Mapi layer debugging]' \
      && ret=0
    ;;

  monetdb)
    # Control utility for the MonetDB daemon.
    local -a _subs _snap_subs
    _subs=(
      'create:create a new database'
      'destroy:destroy a database'
      'lock:lock a database against client connections'
      'release:release a previously locked database'
      'status:show running databases'
      'start:start a database'
      'stop:stop a database'
      'kill:forcibly stop a database'
      'set:set database property'
      'get:get database property'
      'inherit:inherit a property from the default values'
      'discover:discover known databases'
      'master:make this database a master'
      'replica:make this database a replica of a master'
      'snapshot:database snapshot management (list/create/restore/destroy/write)'
      'help:show help for a subcommand'
      'version:show version'
    )
    _snap_subs=(
      'list:list snapshots'
      'create:create a snapshot'
      'restore:restore a snapshot'
      'destroy:destroy a snapshot'
      'write:write a snapshot to a tarball'
    )
    _arguments -C \
      '-h+[host]:host:_hosts' \
      '-p+[port]:port:' \
      '-P+[passphrase]:passphrase:' \
      '-q[quiet]' \
      '(- *)-v[show version]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd) _describe -t commands 'monetdb subcommand' _subs && ret=0 ;;
      subcmd_args)
        case $words[1] in
          snapshot)
            _arguments -C \
              '(-): :->snap_sub' \
              '(-)*:: :->snap_sub_args' && ret=0
            case $state in
              snap_sub) _describe -t commands 'monetdb snapshot subcommand' _snap_subs && ret=0 ;;
              snap_sub_args) _arguments '*:database:' && ret=0 ;;
            esac
            ;;
          create|destroy|lock|release|start|stop|kill|status|master|replica)
            _arguments '*:database:' && ret=0
            ;;
          set|get|inherit)
            _arguments \
              '1:property:(name shared nthreads ncopiedthreads nrthreads optpipe readonly embedr embedpy embedc mserver5 forward dbname mfunnel)' \
              '*:database:' && ret=0
            ;;
          discover)
            _arguments '*:pattern:' && ret=0
            ;;
          help)
            _arguments '*:topic:(create destroy lock release status start stop kill set get inherit discover master replica snapshot version)' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  monetdbd)
    # MonetDB daemon (Merovingian).
    local -a _dsubs
    _dsubs=(
      'create:create a new dbfarm directory'
      'start:start the daemon (foreground or background)'
      'stop:stop the daemon'
      'set:set a daemon property'
      'get:get a daemon property'
    )
    _arguments -C \
      '(- *)-h[show help]' \
      '(- *)-v[show version]' \
      '(-): :->dsubcmd' \
      '(-)*:: :->dsubcmd_args' && ret=0
    case $state in
      dsubcmd) _describe -t commands 'monetdbd subcommand' _dsubs && ret=0 ;;
      dsubcmd_args)
        case $words[1] in
          create|start|stop)
            _arguments '1:dbfarm directory:_directories' && ret=0
            ;;
          set|get)
            _arguments \
              '1:property:(logfile pidfile sockdir listenaddr port exittimeout forward discoveryttl discoveryport control passphrase mapisock controlsock)' \
              '2:dbfarm directory:_directories' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
