#compdef dRep
# Documentation: https://drep.readthedocs.io/en/latest/module_descriptions.html
# dRep - rapid genome dereplication and comparison

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'dereplicate:de-replicate a set of genomes'
      'compare:compare and cluster a set of genomes'
      'check_dependencies:check which dependencies are installed'
    )
    _describe -t commands 'dRep command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      dereplicate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-g --genomes)'{-g,--genomes}'+[input genome fasta files]:files:_files' \
          '(-p --processors)'{-p,--processors}'=[number of threads (default 6)]:threads' \
          '(-l --length)'{-l,--length}'=[minimum genome length (default 50000)]:length' \
          '(-comp --completeness)'{-comp,--completeness}'=[minimum completeness (default 75)]:pct' \
          '(-con --contamination)'{-con,--contamination}'=[maximum contamination (default 25)]:pct' \
          '--S_algorithm=[secondary clustering algorithm]:algo:(fastANI gANI goANI ANIn ANImf)' \
          '(-pa --P_ani)'{-pa,--P_ani}'=[primary cluster ANI threshold (default 0.9)]:ani' \
          '(-sa --S_ani)'{-sa,--S_ani}'=[secondary cluster ANI threshold (default 0.95)]:ani' \
          '1:work_directory:_files -/' && ret=0
        ;;
      compare)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-g --genomes)'{-g,--genomes}'+[input genome fasta files]:files:_files' \
          '(-p --processors)'{-p,--processors}'=[number of threads (default 6)]:threads' \
          '--S_algorithm=[secondary clustering algorithm]:algo:(fastANI gANI goANI ANIn ANImf)' \
          '(-pa --P_ani)'{-pa,--P_ani}'=[primary cluster ANI threshold (default 0.9)]:ani' \
          '(-sa --S_ani)'{-sa,--S_ani}'=[secondary cluster ANI threshold (default 0.95)]:ani' \
          '1:work_directory:_files -/' && ret=0
        ;;
      *)
        _arguments '(-h --help)'{-h,--help}'[show help]' '*:arg:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
