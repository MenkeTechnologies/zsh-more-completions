#compdef s6-ioconnect
# Documentation: source-direct extraction from upstream skarnet/s6
# src/conn-tools/s6-ioconnect.c USAGE string + subgetopt_r option
# spec. The flags -0/-1/-6/-7 are deprecated case-arm no-ops kept
# only for backward compatibility (auto-detected at runtime); not
# offered for completion.
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6 ioconnect R122d — bidirectional I/O splicer that
# shuttles bytes between (stdin -> fdw) and (fdr -> stdout) until
# either side closes. Typically used inside a UCSPI pipeline to
# connect a client to a service.

_arguments -s -S \
  '-t+[inactivity timeout in ms before exit]:ms:' \
  '-r+[file descriptor to read from (default 6)]:fd:' \
  '-w+[file descriptor to write to (default 7)]:fd:'
