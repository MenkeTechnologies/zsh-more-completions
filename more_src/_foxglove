#compdef foxglove
# Documentation: https://github.com/foxglove/foxglove-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for foxglove CLI (foxglove/foxglove-cli, cobra).
# Subcommands each define their own flags; deeper nesting: foxglove <cmd> --help

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--config[config file]:file:_files' \
  '--client-id[OAuth client id]:id' \
  '--debug[enable debug logging]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'auth:login, configure-api-key, info'
      'data:export, import, coverage, imports'
      'devices:list, add, edit'
      'sessions:list, get, add, recordings, delete'
      'extensions:list, publish, unpublish'
      'attachments:list, download'
      'recordings:list, delete'
      'events:list, add'
      'event-types:list'
      'pending-imports:list'
      'projects:list'
      'config:interactive config editor'
      'version:print version'
    )
    _describe -t commands 'foxglove command' commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
