# _bareos-database — Bareos GmbH bareos-database wrapper CLI for bareos-dbcheck bareos-dbcopy bareos-db-create-bareos-tables bareos-db-create-bareos-database bareos-db-drop bareos-db-update bareos-db-grant-privileges MySQL PostgreSQL SQLite catalog maintenance (bareos team, Bash); getopt
# upstream: https://github.com/bareos/bareos

_bareos-database() {
    local -a sub=(
        'check:check database consistency'
        'copy:copy database between backends'
        'create-tables:create catalog tables'
        'create-database:create catalog database'
        'drop-database:drop catalog database'
        'drop-tables:drop catalog tables'
        'update-tables:upgrade catalog tables'
        'grant-privileges:grant catalog privileges'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-b+[backend]:b:(mysql postgresql sqlite3 sqlite)' \
        '--backend=+[backend]:b:(mysql postgresql sqlite3 sqlite)' \
        '-u+[db user]:str:' \
        '--user=+[db user]:str:' \
        '-p+[db password]:str:' \
        '--password=+[db password]:str:' \
        '-d+[db name]:str:' \
        '--db-name=+[db name]:str:' \
        '-H+[db host]:h:_hosts' \
        '--host=+[db host]:h:_hosts' \
        '-P+[db port]:n:' \
        '--port=+[db port]:n:' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '-f[force]' \
        '--force[force]' \
        '-y[yes]' \
        '--yes[yes]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bareos-database subcommand' sub ;;
        args)
            case $words[1] in
                copy) _arguments \
                    '--from-backend=+[b]:b:(mysql postgresql sqlite3)' \
                    '--to-backend=+[b]:b:(mysql postgresql sqlite3)' \
                    '--from-db=+[name]:str:' \
                    '--to-db=+[name]:str:' ;;
                check) _arguments \
                    '--no-confirm[no confirm]' \
                    '--orphan-paths[check orphan paths]' \
                    '--no-orphan-paths[no check orphan paths]' \
                    '--orphan-files[check orphan files]' \
                    '--no-fix[no fix]' \
                    '--batch[batch mode]' ;;
            esac
            ;;
    esac
}

_bareos-database "$@"
