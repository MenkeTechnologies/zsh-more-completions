#compdef dy dynein

# https://github.com/awslabs/dynein — binary "dy" (Cargo [[bin]]); clap (src/cmd.rs)
local curcontext="$curcontext" state line ret=1

local -a dy_globals
dy_globals=(
  '(-h --help)'{-h,--help}'[help]'
  '-V[show version]'
  '--version[show version]'
  '(-r --region)'{-r,--region}'=-[AWS region or local]:region:'
  '(-p --port)'{-p,--port}'=-[DynamoDB local port]:port:'
  '(-t --table)'{-t,--table}'=-[default table name]:table:'
  '--shell[REPL mode]'
  '--third-party-attribution[show third-party notices]'
)

local -a dy_subs
dy_subs=(
  'admin:DynamoDB control-plane ops'
  'list:list tables'
  'ls:list tables'
  'desc:describe table'
  'show:describe table'
  'describe:describe table'
  'info:describe table'
  'scan:scan items'
  's:scan items'
  'get:get item'
  'g:get item'
  'query:query index or table'
  'put:put item'
  'del:delete item'
  'upd:update item'
  'bwrite:batch write'
  'batch-write-item:batch write'
  'batch-write:batch write'
  'bw:batch write'
  'use:set default table schema locally'
  'config:manage local config/cache'
  'bootstrap:sample tables'
  'export:export table data'
  'import:import table data'
  'backup:list backups'
  'restore:restore table'
)

_arguments -C \
  "$dy_globals[@]" \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'dynein command' dy_subs && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
