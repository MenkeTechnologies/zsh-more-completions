#compdef IDFilter
# OpenMS TOPP: filter peptide/protein identifications by various criteria

local ret=1

_arguments -s -S \
  '-in[input identification file]:input file:_files' \
  '-out[output identification file]:output file:_files' \
  '-precursor:rt[retention time range min:max]:range:' \
  '-precursor:mz[mass-to-charge range min:max]:range:' \
  '-precursor:length[peptide length range min:max]:range:' \
  '-precursor:charge[charge state range min:max]:range:' \
  '-score:psm[PSM hit score threshold]:score:' \
  '-score:peptide[peptide hit score threshold]:score:' \
  '-score:protein[protein hit score threshold]:score:' \
  '-score:proteingroup[protein group score threshold]:score:' \
  '-whitelist:proteins[FASTA of allowed proteins]:fasta:_files' \
  '-whitelist:protein_accessions[protein accessions to retain]:accessions:' \
  '-whitelist:peptides[peptide file for sequence matching]:file:_files' \
  '-whitelist:ignore_modifications[compare peptides by sequence only]' \
  '-blacklist:proteins[FASTA of proteins to exclude]:fasta:_files' \
  '-blacklist:protein_accessions[protein accessions to remove]:accessions:' \
  '-blacklist:peptides[peptide file for exclusion matching]:file:_files' \
  '-blacklist:ignore_modifications[compare peptides by sequence only]' \
  '-var_mods[keep only peptides with variable modifications]' \
  '-remove_shared_peptides[retain only single-protein-matching peptides]' \
  '-keep_unreferenced_protein_hits[retain proteins without peptide references]' \
  '-remove_decoys[filter decoy proteins]' \
  '-delete_unreferenced_peptide_hits[remove peptides lacking protein references]' \
  '-best:n_spectra[keep top N spectra by score]:n:' \
  '-best:n_peptide_hits[keep top N peptides per spectrum]:n:' \
  '-best:spectrum_per_peptide[one spectrum per peptide]:mode:' \
  '-best:n_protein_hits[keep top N protein hits]:n:' \
  '-best:strict[keep only highest scoring hit]' \
  '-missed_cleavages:number_of_missed_cleavages[allowed missed cleavages range]:range:' \
  '-in_silico_digestion:fasta[protein database for peptide validation]:fasta:_files' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
