#compdef flagsmith

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'get:get current flags for an environment'
      'environment:manage environments'
      'login:log in to Flagsmith'
      'logout:log out'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (get)
        _arguments \
          '--environment=[environment key]:key:' \
          '--api=[Flagsmith API URL]:url:' \
          '--entity=[entity identifier]:entity:' \
          '--feature=[specific feature name]:feature:' \
          '--output=[output format]:format:(json table)' && ret=0
        ;;
      (environment)
        _arguments '1:action:(list get)' && ret=0
        ;;
      (login)
        _arguments \
          '--api=[Flagsmith API URL]:url:' \
          '--email=[email address]:email:' && ret=0
        ;;
    esac
    ;;
esac

return ret
