#compdef virt-probe
# _virt-probe — KubeVirt readiness/liveness probe that talks to qemu-guest-agent via the cmd server
# upstream: https://github.com/kubevirt/kubevirt
# Flags from cmd/virt-probe/virt-probe.go on tip.

_virt-probe() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--socket=[cmd server socket]:socket:_files' \
        '--domainName=[domain name (namespace_vmname)]:name:' \
        '--command=[command to execute on the guest]:cmd:' \
        '--memProfile=[path to store a memory profile]:file:_files' \
        '--timeoutSeconds=[guest command timeout in seconds]:n:' \
        '--guestAgentPing[readiness based on guest-agent ping]' \
        '-v[klog verbosity level]:n:'
}

_virt-probe "$@"
