#compdef jikes
# Documentation: https://www.manpagez.com/man/1/jikes/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jikes: IBM Java source-to-bytecode compiler (archived)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h -help -\?)'{-h,-help,-\?}'[display option summary]' \
  '(-V -version)'{-V,-version}'[show version and contact info]' \
  '-bootclasspath[library class file path]:path:_files -/' \
  '(-classpath -cp)'{-classpath,-cp}'[user source/class search path]:path:_files -/' \
  '-d[output directory for class files]:dir:_files -/' \
  '-debug[recognized for compatibility (no effect)]' \
  '-depend[recompile all used classes]' \
  '-deprecation[report deprecated feature usage]' \
  '-encoding[source file character encoding]:encoding:' \
  '-extdirs[extensions directories path]:path:_files -/' \
  '-g[generate full debug info]' \
  '-gnone[generate no debug info]' \
  '-g\:source[generate source debug info only]' \
  '-g\:lines[generate line number debug info]' \
  '-g\:vars[generate local variable debug info]' \
  '-nowrite[skip class file generation]' \
  '-source[source release version]:release:' \
  '-target[target release version]:release:' \
  '-sourcepath[source path]:path:_files -/' \
  '(-v -verbose)'{-v,-verbose}'[verbose output]' \
  '(-q -nowarn)'{-q,-nowarn}'[suppress warnings]' \
  '-Werror[treat warnings as errors]' \
  '-Xswitchcheck[require switch default]' \
  '-Xstdout[output diagnostics to stdout]' \
  '(-O --optimize)'{-O,--optimize}'[enable optimization]' \
  '++[incremental compile mode]' \
  '--incremental[incremental compile mode]' \
  '*:Java source:_files -g "*.java(-.)"' && ret=0
return ret
