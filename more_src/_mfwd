#compdef mfwd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-to[set To header]:address:' \
  '-from[set From header]:address:' \
  '-cc[set Cc header]:address:' \
  '-bcc[set Bcc header]:address:' \
  '-subject[set Subject header]:subject:' \
  '-attach[attach a file]:file:_files' \
  '*:message:_files' && ret=0

return ret
