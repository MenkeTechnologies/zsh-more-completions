#compdef mfwd
# Documentation: https://manpages.debian.org/unstable/mblaze/mfwd.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mfwd: forward messages (mblaze)
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-r[forward as mshow rendered plain text (RFC 934)]' \
  '-to[set To header]:address:' \
  '-from[set From header]:address:' \
  '-cc[set Cc header]:address:' \
  '-bcc[set Bcc header]:address:' \
  '-subject[set Subject header]:subject:' \
  '-body[prepopulate draft body from file]:file:_files' \
  '*:message:_files' && ret=0

return ret
