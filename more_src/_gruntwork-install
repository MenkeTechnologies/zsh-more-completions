#compdef gruntwork-install
# Documentation: https://github.com/gruntwork-io/gruntwork-installer
# gruntwork-install - install Gruntwork Infrastructure as Code modules and binaries

local ret=1

_arguments -s -S \
  '--help[show the help text and exit]' \
  '--repo=[the GitHub repo to install from]:repo' \
  '--tag=[the version of the repo to install from]:tag' \
  '--module-name=[the name of a module to install]:name' \
  '--binary-name=[the name of a binary to install]:name' \
  '--binary-sha256-checksum=[the SHA256 checksum of the binary]:checksum' \
  '--binary-sha512-checksum=[the SHA512 checksum of the binary]:checksum' \
  '*--module-param=[a key=value pair to pass to the module]:param' \
  '--download-dir=[directory to download and install the module]:dir:_files -/' \
  '--binary-install-dir=[directory where binaries are placed]:dir:_files -/' \
  '--no-sudo[do not use sudo to install the binary]' \
  '--branch=[download the latest commit from this branch]:branch' \
  '--ref=[download the latest commit from this ref]:ref' && ret=0

return ret
