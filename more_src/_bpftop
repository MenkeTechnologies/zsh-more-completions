#compdef bpftop

# bpftop BPF program monitor completion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--sort-by=[sort programs by]:field:(name period total runtime events)' \
  '--sticky[keep programs visible after they stop]' \
  '--filter=[filter programs by name]:filter pattern' \
  && ret=0

return ret
