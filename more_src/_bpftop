#compdef bpftop
# Documentation: https://github.com/Netflix/bpftop
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bpftop - dynamic real-time view of running eBPF programs (Netflix)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --delay)'{-d+,--delay=}'[refresh interval in seconds (1-3600)]:seconds:' \
  && ret=0

return ret
