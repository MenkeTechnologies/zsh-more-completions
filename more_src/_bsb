#compdef bsb bsc
# _bsb — BuckleScript bsb/bsc compiler CLI alias (rescript-lang team, OCaml); custom argparse — legacy precursor to ReScript bsb
# upstream: https://github.com/rescript-lang/rescript-compiler

_bsb() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-init+[init project]:dir:_files -/' \
        '-theme+[init theme]:t:(basic basic-reason node minimal)' \
        '-make-world[make whole project]' \
        '-clean[clean build artifacts]' \
        '-clean-world[clean everything]' \
        '-w[watch mode]' \
        '-ws+[ws config]:str:' \
        '-no-color[no color]' \
        '-color=+[color]:c:(always never)' \
        '-cwd+[cwd]:dir:_files -/' \
        '-warn-error+[warn as error]:str:' \
        '-bs-suffix=+[suffix]:s:(.bs.js .js)' \
        '-bs-no-dev[no-dev mode]' \
        '-regen[regenerate build artifacts]' \
        '-verbose[verbose]' \
        '-no-deps[no deps install]' \
        '-install[install dependencies]' \
        '-bs-cmi-only[generate cmi only]' \
        '-bs-cmj-only[generate cmj only]' \
        '-bs-jsx=+[jsx version]:v:(2 3 4)' \
        '*:targets:'
}

_bsb "$@"
