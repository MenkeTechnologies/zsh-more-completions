#compdef chrome-devtools-mcp
# Documentation: https://github.com/ChromeDevTools/chrome-devtools-mcp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# chrome-devtools-mcp: MCP server exposing Chrome DevTools to AI agents

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--autoConnect[auto-connect to local Chrome (Chrome 144+)]' \
  '(-u --browserUrl)'{-u,--browserUrl}'=[connect to running Chrome instance URL]:url:' \
  '(-w --wsEndpoint)'{-w,--wsEndpoint}'=[WebSocket endpoint for Chrome]:url:' \
  '--wsHeaders=[custom JSON headers for WebSocket]:json:' \
  '--headless[run Chrome without UI]' \
  '(-e --executablePath)'{-e,--executablePath}'=[custom Chrome executable]:file:_files' \
  '--isolated[use temporary user-data-dir]' \
  '--userDataDir=[custom profile directory]:dir:_files -/' \
  '--channel=[Chrome channel]:channel:(canary dev beta stable)' \
  '--viewport=[initial viewport size (e.g. 1280x720)]:size:' \
  '--proxyServer=[proxy configuration]:proxy:' \
  '--acceptInsecureCerts[ignore TLS certificate errors]' \
  '*--chromeArg=[additional Chrome argument]:arg:' \
  '--logFile=[debug log file path]:file:_files' \
  '--slim[expose minimal 3-tool set]' \
  '*::args:_default' && return 0
