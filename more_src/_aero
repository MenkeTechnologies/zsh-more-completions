#compdef aero
# _aero — JUXT aero configuration file evaluator CLI alias (juxt team, Clojure); tools.deps function CLI
# upstream: https://github.com/juxt/aero

_aero() {
    local -a sub=(
        'read:read and resolve aero config'
        'validate:validate aero config'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--profile=+[profile]:str:' \
        '-p+[profile]:str:' \
        '--hostname=+[hostname override]:host:_hosts' \
        '-H+[hostname override]:host:_hosts' \
        '--user=+[user override]:user:_users' \
        '-u+[user override]:user:_users' \
        '--config=+[config file]:file:_files -g "*.{edn,aero}"' \
        '-c+[config file]:file:_files -g "*.{edn,aero}"' \
        '--reader=+[custom reader edn]:str:' \
        '--resolver=+[custom resolver edn]:str:' \
        '--format=+[output format]:f:(edn json yaml)' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aero subcommand' sub ;;
        args)
            case $words[1] in
                read|validate) _arguments \
                    '1:config file:_files -g "*.{edn,aero}"' \
                    '--profile=+[profile]:str:' \
                    '-p+[profile]:str:' \
                    '--format=+[output format]:f:(edn json yaml)' ;;
            esac
            ;;
    esac
}

_aero "$@"
