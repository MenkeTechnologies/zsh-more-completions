#compdef betterlockscreen

# Zsh completion for betterlockscreen (i3lock with better visuals)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-u --update)'{-u,--update}'=[Update lock screen image]:image:_files -g "*.{png,jpg,jpeg,bmp}"' \
  '(-l --lock)'{-l,--lock}'=[Lock screen with specified effect]:effect:(dim blur dimblur color pixel)' \
  '(-w --wall)'{-w,--wall}'=[Set wallpaper with specified effect]:effect:(dim blur dimblur color pixel)' \
  '--off=[Set screen off timeout in seconds]:seconds' \
  '-t+[Set custom lock text]:text' \
  '--text=[Set custom lock text]:text' \
  '--show-layout[Show keyboard layout on lock screen]' \
  '--span[Span image across all monitors]' \
  '--blur=[Set blur level]:level' \
  '--dim=[Set dim level]:level' \
  '--pixel=[Set pixelation level]:level' \
  '--color=[Set background color]:hex color' \
  '--desc=[Set description text]:text' \
  '--fx=[Comma-separated list of effects]:effects' \
  '--display=[Display resolution to use]:resolution' \
  '-q[Suppress output]' \
  '--quiet[Suppress output]' \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' && ret=0

return ret
