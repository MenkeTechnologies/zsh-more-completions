#compdef kea-admin
# Documentation: https://man.archlinux.org/search?q=kea-admin
# Reference accessed: 2026-05-16

# kea-admin: Kea database admin/migration tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'db-init:initialize database'
  'db-upgrade:upgrade database schema'
  'db-version:show database version'
  'lease-dump:dump leases'
  'lease-upload:upload leases'
  'stats-recount:recount statistics'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-u[user]:user:_users' \
  '-p[password]:pass:' \
  '-n[database name]:db:' \
  '-h[host]:host:_hosts' \
  '-P[port]:port:' \
  '-d[mysql or pgsql or memfile]:backend:(mysql pgsql memfile)' \
  '-4[DHCPv4]' \
  '-6[DHCPv6]' \
  '-o[output file]:file:_files' \
  '-x[execute extra option]:opt:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'kea-admin command' commands && ret=0 ;;
esac
return ret
