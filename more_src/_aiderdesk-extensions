#compdef aiderdesk-extensions
# Documentation: https://aiderdesk.hotovo.com/docs/extensions
# Reference accessed: 2026-05-23
# Verified: npx @aiderdesk/extensions --help.

# Zsh completion for aiderdesk-extensions - AiderDesk extension installer CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'aiderdesk-extensions command' \
      'install[install AiderDesk extensions]' \
      'list[list available extensions]' && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments \
          '(-g --global)'{-g,--global}'[install to global extensions directory]' \
          '(-d --directory)'{-d+,--directory=}'[custom install directory]:directory:_directories' \
          ':extension:extension id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
