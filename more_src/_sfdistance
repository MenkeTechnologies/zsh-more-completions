#compdef sfdistance
# Documentation: https://github.com/ahay/src/blob/master/user/fomels/Mdistance.c
# Madagascar: compute distance function by fast marching eikonal solver (3-D)

local ret=1

_arguments -s -S \
  'n1=[first dimension]:n1' \
  'n2=[second dimension]:n2' \
  'n3=[third dimension]:n3' \
  'd1=[first sampling interval]:d1' \
  'd2=[second sampling interval]:d2' \
  'd3=[third sampling interval]:d3' \
  'o1=[first origin]:o1' \
  'o2=[second origin]:o2' \
  'o3=[third origin]:o3' \
  'velocity=[velocity file]:velocity:_files' \
  'order=[accuracy order]:order' \
  'vel=[if y, input is velocity; n, slowness squared]:vel:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
