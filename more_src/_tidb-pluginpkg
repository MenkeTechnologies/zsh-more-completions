#compdef tidb-pluginpkg pluginpkg
# _tidb-pluginpkg — TiDB plugin packager
# upstream: https://github.com/pingcap/tidb
# Flags from cmd/pluginpkg/pluginpkg.go on tip.

_tidb-pluginpkg() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-pkg-dir=[plugin source folder]:dir:_files -/' \
        '-out-dir=[packaged plugin output folder]:dir:_files -/' \
        '-pgo-file=[Go PGO profile file]:file:_files' \
        '-next-gen=[build with next-gen plugin features]:bool:(true false)'
}

_tidb-pluginpkg "$@"
