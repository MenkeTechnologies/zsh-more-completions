#compdef show-snps
# Documentation: https://manpages.debian.org/testing/mummer/show-snps.1.en.html
# MUMmer utility to report SNPs from a delta alignment file

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-C[do not report SNPs from ambiguously mapped alignments]' \
  '-H[do not print the output header]' \
  '-I[do not report indels]' \
  '-l[include sequence length information]' \
  '-q[sort output lines by query IDs and SNP positions]' \
  '-r[sort output lines by reference IDs and SNP positions]' \
  '-S[report alignments passed as show-coords lines on stdin]' \
  '-T[switch to tab-delimited format]' \
  '-x+[include x characters of surrounding SNP context]:chars' \
  ':delta file:_files -g "*.delta"' && ret=0

return ret
