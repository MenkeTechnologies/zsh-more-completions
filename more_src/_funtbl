#compdef funtbl
# Documentation: https://linux.die.net/man/1/funtbl
# funtbl - display FITS binary table columns as ASCII

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-c[space-delimited list of column numbers to output]:cols' \
  '-h[add column names in a header line before the data]' \
  '-n[which table to extract (starting from 1)]:table' \
  '-p[awk-like program to run instead of the default]:prog' \
  '-s[separator string to put between columns]:sep' \
  '-T[output the data in rdb format]' \
  '*:fits table:_files' && ret=0

return ret
