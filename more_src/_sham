#compdef sham gmx-sham
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-sham.html
# gmx sham: compute free energies or other histograms from histograms

local ret=1

_arguments -s \
  '-f[xvgr/xmgr file]:file:_files' \
  '-ge[xvgr/xmgr file]:file:_files' \
  '-ene[xvgr/xmgr file]:file:_files' \
  '-dist[xvgr/xmgr file]:file:_files' \
  '-histo[xvgr/xmgr file]:file:_files' \
  '-bin[index file]:file:_files' \
  '-lp[X PixMap matrix file]:file:_files' \
  '-ls[X PixMap matrix file]:file:_files' \
  '-lsh[X PixMap matrix file]:file:_files' \
  '-lss[X PixMap matrix file]:file:_files' \
  '-ls3[protein data bank file]:file:_files' \
  '-g[log file]:file:_files' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-time[expect a time in the input]' \
  '-b[first time to read from set]:real:' \
  '-e[last time to read from set]:real:' \
  '-ttol[tolerance on time in appropriate units]:real:' \
  '-n[read this number of sets separated by ampersands]:int:' \
  '-d[use the derivative]' \
  '-sham[turn off energy weighting]' \
  '-tsham[temperature for single histogram analysis]:real:' \
  '-pmin[minimum probability threshold]:real:' \
  '-dim[dimensions for distances]:vector:' \
  '-ngrid[number of bins for energy landscapes]:vector:' \
  '-xmin[minimum axes values]:vector:' \
  '-xmax[maximum axes values]:vector:' \
  '-pmax[maximum probability in output]:real:' \
  '-gmax[maximum free energy in output]:real:' \
  '-emin[minimum enthalpy in output]:real:' \
  '-emax[maximum enthalpy in output]:real:' \
  '-nlevels[number of levels for energy landscape]:int:' && ret=0

return ret
