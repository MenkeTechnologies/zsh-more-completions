#compdef osmium-tool osmium
# Documentation: https://manpages.debian.org/bookworm/osmium-tool/osmium.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm osmium(1) manpage.
# Removed from prior file: fabricated -V/--version (real is --version
# only) and bogus man.archlinux.org search URL.

# osmium-tool: multipurpose OpenStreetMap data processing tool
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'add-locations-to-ways:add coordinates to way nodes'
  'apply-changes:apply OSC changes to OSM file'
  'cat:concatenate OSM files'
  'changeset-filter:filter changeset files'
  'check-refs:check for missing references'
  'derive-changes:derive OSC from two OSM files'
  'diff:show differences between two OSM files'
  'export:export OSM data to other formats'
  'extract:extract regions from OSM file'
  'fileinfo:show information about OSM file'
  'getid:filter objects by ID'
  'getparents:get parent objects'
  'help:show help for a subcommand'
  'merge:merge sorted OSM files'
  'merge-changes:merge OSC change files'
  'removeid:remove objects by ID'
  'renumber:renumber object IDs sequentially'
  'show:show OSM file contents'
  'sort:sort OSM file by ID'
  'tags-filter:filter objects by tags'
  'time-filter:filter objects by time'
)
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'osmium command' commands && ret=0 ;;
esac
return ret
