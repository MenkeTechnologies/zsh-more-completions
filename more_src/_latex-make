#compdef latex-make
# Documentation: https://ctan.org/pkg/latex-make
# Documentation: https://tug.ctan.org/support/latex-make/latex-make.pdf
# Documentation: https://tug.ctan.org/support/latexmake/makefile
# Reference accessed: 2026-05-27
# Verified: upstream LaTeX.mk Makefile target table (latexmake/Beebe and
# latex-make/Danjean-Legrand). latex-make is a Makefile snippet, not a
# standalone CLI; users invoke it via `make <target>` after including
# LaTeX.mk in their own Makefile. Some distributions ship a `latex-make`
# wrapper that takes the same target names; this completion lists those
# canonical targets.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '-f+[Makefile to use]:file:_files' \
  '-C+[change to directory before reading Makefile]:directory:_files -/' \
  '-n[dry-run, just print commands]' \
  '-k[keep going after errors]' \
  '-s[silent operation]' \
  '*:target:->target' && return

_values 'LaTeX.mk target' \
  'all[build the default flavours, typically dvi, ps, pdf and txt]' \
  'help[print usage information]' \
  'usage[show detailed commentary from LaTeX.mk]' \
  'check[verify required variables are set]' \
  'dvi[produce DVI output]' \
  'ps[produce PostScript output]' \
  'pdf[produce PDF output]' \
  'html[produce HTML output]' \
  'txt[produce plain text output]' \
  'rtf[produce RTF output]' \
  'view[open generated DVI/PDF in a viewer]' \
  'bibtex[run bibtex on intermediate aux files]' \
  'index[build the document index]' \
  'glossary[build the glossary]' \
  'clean[remove intermediate files (.aux, .log, .bbl, ...)]' \
  'cleangen[remove all generated output files]' \
  'clean-bak[remove backup files (~)]' \
  'clean-th[remove generated text/HTML/CSS files]' \
  'mostlyclean[remove intermediate but keep final output]' \
  'distclean[remove all generated and intermediate files]' \
  'veryclean[deepest clean target]'
