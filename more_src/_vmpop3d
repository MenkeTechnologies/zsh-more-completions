#compdef vmpop3d
# Documentation: https://man.archlinux.org/search?q=vmpop3d
# Reference accessed: 2026-05-16

# vmpop3d: virtual-mailbox POP3 daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[config file]:file:_files' \
  '-d[debug]' \
  '-D[daemonize]' \
  '-p[port]:port:' \
  '*::vmpop3d args:_files' && ret=0
return ret
