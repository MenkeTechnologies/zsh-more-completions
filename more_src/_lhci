#compdef lhci
# Documentation: https://www.npmjs.com/package/@lhci/cli
# Reference accessed: 2026-05-23
# Verified: npx @lhci/cli --help.

# Zsh completion for lhci - Lighthouse CI CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'collect:run Lighthouse and save results locally'
  'upload:upload results to the server'
  'assert:assert latest results meet expectations'
  'autorun:run collect/assert/upload with defaults'
  'healthcheck:validate Lighthouse CI configuration'
  'open:open HTML reports of collected runs'
  'wizard:interactive CI setup wizard'
  'server:run Lighthouse CI server'
)

_arguments -C   '--help[show help]'   '--version[show version]'   '--no-lighthouserc[disable automatic .lighthouserc usage]'   '--config=[JSON config file]:file:_files'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'lhci command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
