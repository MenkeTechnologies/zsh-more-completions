#compdef cargo-npm
# Documentation: https://github.com/abemedia/cargo-npm
# Reference accessed: 2026-05-23
# Verified: upstream README cargo npm generate/publish.

# Zsh completion for cargo-npm - package Rust CLI binaries as npm packages

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'generate:generate platform-specific npm packages from compiled binaries'
  'publish:publish generated npm packages to the registry'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'cargo npm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (generate|publish)
        _arguments \
          '--[pass additional args to npm publish]:npm args:' && ret=0 ;;
    esac ;;
esac

return ret
