#compdef neutron-db-manage
# Documentation: https://docs.openstack.org/neutron/latest/admin/ops-db.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# neutron-db-manage: DB schema management
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'upgrade:upgrade to a later schema version'
  'stamp:stamp DB with the given revision'
  'revision:create a new revision file'
  'history:list changeset scripts chronologically'
  'current:show current schema revision'
  'branches:show current branch points'
  'heads:show current head revisions'
  'check_migration:validate head file against branches'
  'has_offline_migrations:check for pending offline migrations'
  'help:show help'
)
_arguments -C \
\
  "(- *)"{-h,--help}"[show help]" \
  "--version[show version]" \
  "--config-file=[config file]:file:_files" \
  "--config-dir=[config dir]:dir:_files -/" \
  "--debug[set log level to debug]" \
  "-d[set log level to debug]" \
  "--log-config-append=[log config file]:file:_files" \
  "--log-date-format=[log date format]:fmt:" \
  "--log-dir=[log directory]:dir:_files -/" \
  "--log-file=[log file]:file:_files" \
  "--nodebug[do not set log level to debug]" \
  "--rate-limit-burst=[log rate limit burst]:n:" \
  "--rate-limit-except=[log rate limit except]:list:" \
  "--rate-limit-interval=[log rate limit interval]:n:" \
  "--rpc-conn-pool-size=[RPC conn pool size]:n:" \
  "--rpc-response-timeout=[RPC response timeout]:n:" \
  "--syslog-log-facility=[syslog facility]:facility:" \
  "--transport-url=[transport URL]:url:" \
  "--use-journal[log to systemd journal]" \
  "--use-json[log as JSON]" \
  "--use-syslog[log via syslog]" \
  "--watch-log-file[watch log file]" \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'neutron-db-manage command' commands && ret=0 ;;
esac
return ret
