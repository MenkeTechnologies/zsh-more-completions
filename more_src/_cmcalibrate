#compdef cmcalibrate
# Documentation: https://man.archlinux.org/search?q=cmcalibrate
# Reference accessed: 2026-05-16

# Infernal cmcalibrate: fit exponential tails to a CM for E-value calculations
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-L[length of random sequences to score (Mb)]:Mb:' \
  '--gtailn[number of tail hits used to fit local-glocal exponential]:n:' \
  '--ltailn[number of tail hits used to fit local exponential]:n:' \
  '--tailp[fraction of tail to fit (e.g. 0.04)]:frac:' \
  '--hfile[save histograms to file]:file:_files' \
  '--sfile[save scores to file]:file:_files' \
  '--qqfile[save Q-Q plot data to file]:file:_files' \
  '--ffile[save tail-fit data to file]:file:_files' \
  '--xfile[save random sequence scores file]:file:_files' \
  '--seed[random seed]:n:' \
  '--cpu[number of CPU threads]:n:' \
  '--forecast[predict required runtime without running]' \
  '--memreq[print memory requirements only]' \
  '--nforecast[do not predict runtime]' \
  '--exp[recalibrate exponential tails only]' \
  '--nonbanded[do not use HMM banding]' \
  '--nohmm[do not use HMM filter]' \
  '*:CM file:_files' && ret=0
return ret
