#compdef intel-gpu-tools
# _intel-gpu-tools — Intel GPU Tools developer/diagnostic CLI alias (Intel / freedesktop.org, C); custom argparse
# upstream: https://gitlab.freedesktop.org/drm/igt-gpu-tools

_intel-gpu-tools() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--device=+[device]:dev:_files -g "/dev/dri/card*"' \
        '-D+[device]:dev:_files -g "/dev/dri/card*"' \
        '--samples=+[samples]:n:' \
        '-s+[samples]:n:' \
        '--list-engines[list engines]' \
        '-L[list engines]' \
        '--engine=+[engine]:e:(rcs0 vcs0 vcs1 vecs0 ccs0 bcs0)' \
        '-e+[engine]:e:(rcs0 vcs0 vcs1 vecs0 ccs0 bcs0)' \
        '--time=+[time seconds]:n:' \
        '-t+[time seconds]:n:' \
        '--json[json output]' \
        '-j[json output]' \
        '--csv[csv output]' \
        '-c[csv output]' \
        '--interval=+[poll interval ms]:n:' \
        '-i+[poll interval ms]:n:' \
        '--list[list tests]' \
        '--run-subtest=+[run subtest]:str:' \
        '--list-subtests[list subtests]' \
        '*:arg:'
}

_intel-gpu-tools "$@"
