#compdef homeshick

# Zsh completion for homeshick - git dotfiles synchronizer

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'cd:change directory to a castle'
  'check:check if castles are up to date'
  'clone:clone a git repo as a castle'
  'generate:create a new castle'
  'help:show help information'
  'link:symlink files from castles into your home (alias of symlink)'
  'list:list cloned castles'
  'pull:pull updates for castles'
  'refresh:update castles that are out of date'
  'symlink:symlink files from castles into your home'
  'show-path:show full path to a castle'
  'track:start tracking a file within a castle'
  'updates:check for homeshick updates'
)

_homeshick_castles() {
  local -a castles
  castles=(${(f)"$(homeshick list 2>/dev/null | awk '{print $1}')"})
  _describe -t castles 'castle' castles
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-b --batch)'{-b,--batch}'[non-interactive mode]' \
  '(-f --force)'{-f,--force}'[force potentially dangerous operations]' \
  '(-s --skip)'{-s,--skip}'[skip potentially dangerous operations]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'homeshick command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (cd|check|pull|refresh|symlink|link|show-path|list)
        _arguments '*:castle:_homeshick_castles' && ret=0
        ;;
      (clone)
        _arguments '*:repository url:' && ret=0
        ;;
      (generate)
        _arguments '1:castle name:' && ret=0
        ;;
      (track)
        _arguments \
          '1:castle:_homeshick_castles' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
