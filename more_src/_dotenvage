#compdef dotenvage
# Documentation: https://man.archlinux.org/search?q=dotenvage
# Reference accessed: 2026-05-16

# Zsh completion for dotenvage (dataroadinc/dotenvage).

local -a subcmds
subcmds=(
  'keygen:generate a new age key pair (alias: gen)'
  'gen:alias for keygen'
  'encrypt:encrypt sensitive values in an env file'
  'edit:decrypt, open editor, re-encrypt'
  'set:set a secret KEY=VALUE'
  'get:print a decrypted secret'
  'list:list variables and encryption status'
  'dump:dump decrypted env to stdout'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[show which files are read]' \
  '1: :{_describe '\''command'\'' subcmds}' \
  '*:: :->args'

[[ $state == args ]] || return 0

case $line[1] in
  keygen|gen)
    _arguments -s -S \
      '(-o --output)'{-o,--output=}'[output key path]:file:_files' \
      '(-f --force)'{-f,--force}'[overwrite existing key]' \
      '--store=[where to store private key]:store:(file os both system)'
    ;;
  encrypt)
    _arguments -s -S \
      '::file:_files' \
      '(-k --keys)'{-k,--keys=}'[keys to encrypt, comma-separated]:keys' \
      '(-a --auto)'{-a,--auto=}'[auto-detect keys by name pattern]:auto:(true false)'
    ;;
  edit)
      _arguments '::file:_files'
    ;;
  set)
    _arguments \
      '1:key=value pair:' \
      '(-f --file)'{-f,--file=}'[env file]:file:_files'
    ;;
  get)
    _arguments \
      '1:variable name:' \
      '(-f --file)'{-f,--file=}'[read from this file only]:file:_files'
    ;;
  list)
    _arguments -s -S \
      '(-f --file)'{-f,--file=}'[list from this file]:file:_files' \
      '--show-values[show decrypted values]' \
      '(-p --plain)'{-p,--plain}'[ASCII-only output]' \
      '(-j --json)'{-j,--json}'[JSON output]'
    ;;
  dump)
    _arguments -s -S \
      '(-f --file)'{-f,--file=}'[dump this file]:file:_files' \
      '(-b --bash)'{-b,--bash}'[bash escaping]' \
      '(-m --make)'{-m,--make}'[GNU Make format]' \
      '--make-eval[Make $(eval ...) lines]' \
      '(-e --export)'{-e,--export}'[prefix export for bash]' \
      '(-d --docker)'{-d,--docker}'[docker --env-file format]'
    ;;
esac
