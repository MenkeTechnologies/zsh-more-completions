#compdef cockpit-machines
# Documentation: https://man.archlinux.org/search?q=cockpit-machines
# Reference accessed: 2026-05-16

# cockpit-machines: helper binary for Cockpit virtual machines plugin
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '*::extra args:_files' && ret=0
return ret
