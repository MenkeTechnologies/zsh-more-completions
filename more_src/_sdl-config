#compdef sdl-config

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--version[show version]' \
  '--cflags[print C compiler flags]' \
  '--libs[print linker flags]' && ret=0

return ret
