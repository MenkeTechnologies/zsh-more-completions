#compdef tmatch2
# Documentation: https://www.star.bris.ac.uk/~mbt/stilts/sun256/tmatch2-usage.html
# STILTS: crossmatch two tables using flexible criteria

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'ifmt1=[format of first input table]:fmt:' \
  'ifmt2=[format of second input table]:fmt:' \
  'icmd1=[filter commands for first input table]:cmds:' \
  'icmd2=[filter commands for second input table]:cmds:' \
  'ocmd=[output filter commands]:cmds:' \
  'omode=[output mode]:mode:(out meta stats count checksum cgi discard topcat samp plastic tosql gui)' \
  'out=[output table location]:out:_files' \
  'ofmt=[output table format]:fmt:' \
  'matcher=[matching algorithm type]:matcher:' \
  'values1=[match value expressions from table 1]:values:' \
  'values2=[match value expressions from table 2]:values:' \
  'params=[match tolerance values]:params:' \
  'tuning=[matching tuning values]:tuning:' \
  'join=[which rows appear in output]:join:(1and2 1or2 all1 all2 1not2 2not1 1xor2)' \
  'find=[multiple-match handling strategy]:find:(all best best1 best2)' \
  'fixcols=[column renaming strategy]:fixcols:(none dups all)' \
  'suffix1=[suffix for renamed table 1 columns]:suffix:' \
  'suffix2=[suffix for renamed table 2 columns]:suffix:' \
  'scorecol=[output match score column name]:col:' \
  'progress=[progress reporting level]:progress:(none log time profile)' \
  'runner=[threading implementation]:runner:(parallel parallel-all sequential classic partest)' \
  '*:in:_files' && ret=0

return ret
