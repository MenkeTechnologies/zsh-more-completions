#compdef ksniff
# Documentation: source-direct extraction from upstream
# eldadru/ksniff cmd/kubectl-sniff.go entrypoint +
# pkg/cmd/sniff.go `cmd.Flags().<TypeVarP>(...)` declarations
# (cobra+pflag via k8s.io/cli-runtime).
# Reference accessed: 2026-05-30 via gh api.
# eldadru ksniff R150b — kubectl plugin that runs tcpdump on a
# running pod by injecting a tcpdump container or running
# tcpdump statically inside the target pod. Note: also ships as
# `kubectl-sniff` (kubectl-plugin convention; invoked as
# `kubectl sniff`), but `kubectl-sniff` is already covered
# elsewhere in the corpus so it is intentionally omitted from
# this #compdef line per anti-dup policy.

_arguments -s -S \
  '(-n --namespace)'{-n+,--namespace=}'[K8s namespace]:namespace:' \
  '(-i --interface)'{-i+,--interface=}'[pod interface to capture (default any)]:iface:(any eth0 lo cni0 weave bridge)' \
  '(-c --container)'{-c+,--container=}'[container to attach to]:container:' \
  '(-f --filter)'{-f+,--filter=}'[tcpdump filter expression]:bpf-filter:' \
  '(-o --output-file)'{-o+,--output-file=}'[output pcap file (use - for stdout)]:file:_files' \
  '(-l --local-tcpdump-path)'{-l+,--local-tcpdump-path=}'[path to local tcpdump binary (used in static mode)]:file:_files' \
  '(-r --remote-tcpdump-path)'{-r+,--remote-tcpdump-path=}'[remote tcpdump install path in container]:path:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-p --privileged)'{-p,--privileged}'[run with privileged container (allows non-container mode)]' \
  '--pod-creation-timeout=[Go-duration timeout for ephemeral pod creation]:duration:' \
  '--image=[image used for the ephemeral pod container]:image:' \
  '--tcpdump-image=[tcpdump image (overrides default tcpdump source)]:image:' \
  '(-x --context)'{-x+,--context=}'[kubeconfig context name]:context:' \
  '*:pod name:'
