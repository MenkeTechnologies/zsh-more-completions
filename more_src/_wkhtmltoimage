#compdef wkhtmltoimage

# Zsh completion for wkhtmltoimage - convert HTML to image

_arguments -s -S \
  '--crop-h[set height for cropping]:pixels:' \
  '--crop-w[set width for cropping]:pixels:' \
  '--crop-x[set x coordinate for cropping]:pixels:' \
  '--crop-y[set y coordinate for cropping]:pixels:' \
  '--disable-javascript[do not allow web pages to run javascript]' \
  '--enable-javascript[allow web pages to run javascript (default)]' \
  '--format[output file format]:format:(bmp jpg png svg)' \
  '(-H --extended-help)'{-H,--extended-help}'[display more extensive help, detailing less common command switches]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '--height[set screen height (default 0 - dynamic)]:pixels:' \
  '--javascript-delay[wait N milliseconds for javascript finish]:milliseconds:' \
  '--load-error-handling[specify how to handle pages that fail to load]:handler:(abort ignore skip)' \
  '--load-media-error-handling[specify how to handle media that fail to load]:handler:(abort ignore skip)' \
  '--no-background[do not print background]' \
  '--background[do print background (default)]' \
  '--quality[output image quality (between 0 and 100)]:quality:' \
  '(-q --quiet)'{-q,--quiet}'[be less verbose]' \
  '--scaling-factor[sets the scaling factor for DPI]:factor:' \
  '(-V --version)'{-V,--version}'[output version information and exit]' \
  '--width[set screen width (default 1024)]:pixels:' \
  '--zoom[use this zoom factor]:factor:' \
  '*:HTML file or URL:_files -g "*.html *.htm"'
