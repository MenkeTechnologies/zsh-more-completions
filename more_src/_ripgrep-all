#compdef rga

# Zsh completion for rga (ripgrep-all) - ripgrep but also searches in PDFs, E-Books, Office docs, zip, tar.gz, etc.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[print version]' \
  '(- *)--rga-list-adapters[list all available adapters]' \
  '(- *)--rga-print-config-schema[print configuration schema as JSON]' \
  '--rga-adapters=[comma-separated list of adapters to use]:adapters:_values -s , adapter pandoc poppler zip decompress tar sqlite ffmpeg mbox' \
  '--rga-no-cache[disable caching of adapter outputs]' \
  '--rga-cache-path=[path to store cache]:cache directory:_directories' \
  '--rga-cache-max-blob-len=[maximum size of a blob to cache in bytes]:bytes' \
  '--rga-max-archive-depth=[maximum depth to recurse into archives]:depth' \
  '--rga-accurate[prefer accuracy over speed]' \
  '--rga-fzf[start interactive search using fzf]' \
  '*'{-e,--regexp}'[pattern to search for]:pattern' \
  '*'{-f,--file}'[file containing patterns to search for]:pattern file:_files' \
  '(-s --case-sensitive -S --smart-case)'{-i,--ignore-case}'[case insensitive search]' \
  '(-i --ignore-case -S --smart-case)'{-s,--case-sensitive}'[case sensitive search]' \
  '(-i --ignore-case -s --case-sensitive)'{-S,--smart-case}'[smart case search]' \
  {-v,--invert-match}'[invert matching]' \
  {-w,--word-regexp}'[only show matches surrounded by word boundaries]' \
  {-c,--count}'[show count of matching lines]' \
  '(-L --files-without-match)'{-l,--files-with-matches}'[show only file paths with matches]' \
  '(-l --files-with-matches)'{-L,--files-without-match}'[show only file paths without matches]' \
  '--json[output results in JSON Lines format]' \
  '(-N --no-line-number)'{-n,--line-number}'[show line numbers]' \
  '(-n --line-number)'{-N,--no-line-number}'[suppress line numbers]' \
  '(--no-filename)'{-H,--with-filename}'[show file name for each match]' \
  '(-H --with-filename)--no-filename[suppress file names]' \
  {-o,--only-matching}'[show only the matched part of each line]' \
  {-r,--replace}'[replace matches with given text]:replacement' \
  '*'{-g,--glob}'[include or exclude files matching glob]:glob pattern' \
  '*--iglob=[include or exclude files matching glob case-insensitively]:glob pattern' \
  '*'{-t,--type}'[only search files matching type]:file type' \
  '*'{-T,--type-not}'[do not search files matching type]:file type' \
  '(- *)--type-list[show all supported file types]' \
  {-m,--max-count}'[limit the number of matches per file]:count' \
  '--max-depth=[descend at most N directories]:depth' \
  '--max-filesize=[ignore files larger than this size]:size' \
  {-j,--threads}'[number of threads to use]:threads' \
  {-0,--null}'[print NUL byte after file paths]' \
  {-a,--text}'[search binary files as text]' \
  {-z,--search-zip}'[search in compressed files]' \
  '--hidden[search hidden files and directories]' \
  '--no-ignore[do not respect ignore files]' \
  {-F,--fixed-strings}'[treat pattern as a literal string]' \
  '--sort=[sort results]:sort key:(none path modified accessed created)' \
  '--sortr=[sort results in reverse]:sort key:(none path modified accessed created)' \
  {-C,--context}'[show NUM lines before and after each match]:lines' \
  {-B,--before-context}'[show NUM lines before each match]:lines' \
  {-A,--after-context}'[show NUM lines after each match]:lines' \
  '--color=[when to use colors]:when:(never auto always ansi)' \
  {-p,--pretty}'[alias for --color always --heading --line-number]' \
  {-q,--quiet}'[do not print anything to stdout]' \
  '--stats[print statistics about the search]' \
  '1:search pattern' \
  '*:file or directory:_files' && ret=0

return ret
