#compdef stfileinfo
# _stfileinfo — print Syncthing-style file info / hashes (syncthing/syncthing)
# upstream: https://github.com/syncthing/syncthing
# Flags from cmd/dev/stfileinfo/main.go (stdlib flag).

_stfileinfo() {
    _arguments \
        '(- *)-h[show help]' \
        '-s[use standard block size]' \
        '1:file:_files'
}

_stfileinfo "$@"
