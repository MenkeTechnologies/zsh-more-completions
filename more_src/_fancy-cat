#compdef fancy-cat
# Documentation: https://man.archlinux.org/search?q=fancy-cat
# Reference accessed: 2026-05-16

# Zsh completion for fancy-cat / freref/fancy-cat PDF terminal viewer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-p --path)'{-p,--path}'[open PDF path]:file:_files -g "*.pdf"' \
  '*:PDF:_files -g "*.pdf"' && ret=0

return ret
