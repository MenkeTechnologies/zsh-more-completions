#compdef buku

# Zsh completion for buku (bookmark manager)

_arguments -s -S \
  '(-a --add)'{-a,--add}'[add a bookmark]:URL:_urls' \
  '(-u --update)'{-u,--update}'[update a bookmark]:index:' \
  '(-d --delete)'{-d,--delete}'[delete a bookmark]:index:' \
  '(-w --write)'{-w,--write}'[edit a bookmark in editor]:index:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --sany)'{-s,--sany}'[search any keyword]:keywords:' \
  '(-S --sall)'{-S,--sall}'[search all keywords]:keywords:' \
  '(-r --sreg)'{-r,--sreg}'[search by regex]:pattern:' \
  '--deep[search in content]' \
  '(-t --stag)'{-t,--stag}'[search by tag]:tag:' \
  '--tag[set tags]:tags:' \
  '--title[set title]:title:' \
  '--comment[set comment]:comment:' \
  '--immutable[set immutability]:value:(0 1)' \
  '(-o --open)'{-o,--open}'[open bookmark in browser]:index:' \
  '--oa[open all search results in browser]' \
  '(-p --print)'{-p,--print}'[print bookmarks]:index:' \
  '(-f --format)'{-f,--format}'[limit fields in print output]:fields:(1 2 3 4 5 10 20 30 40 50)' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '--colors[set output colors]:color string:' \
  '(-n --count)'{-n,--count}'[results per page]:count:' \
  '--np[do not enable pagination]' \
  '--nc[disable color output]' \
  '(-e --export)'{-e,--export}'[export bookmarks]:file:_files' \
  '(-i --import)'{-i,--import}'[import bookmarks]:file:_files' \
  '--merge[merge bookmarks from another buku DB]:file:_files' \
  '--db[specify DB file]:file:_files' \
  '--suggest[show a list of suggestions]' \
  '--tacit[reduce verbosity]' \
  '--nostdin[do not wait for input]' \
  '--threads[max network connections]:threads:' \
  '--url-redirect[follow URL redirects]' \
  '--export-on[export specific field]:field:' \
  '--replace[replace a tag]:old tag:' \
  '--shorten[shorten a URL]:index:' \
  '--expand[expand a URL]:index:' \
  '--cached[show cached page]:index:' \
  '--unlock[decrypt database]' \
  '--lock[encrypt database]' && return 0
