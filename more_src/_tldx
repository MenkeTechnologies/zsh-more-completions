_tldx() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '(-t --tlds)'{-t,--tlds}'[TLDs to check (comma-separated)]:tlds:' \
    '(-p --prefixes)'{-p,--prefixes}'[prefixes to add (comma-separated)]:prefixes:' \
    '(-s --suffixes)'{-s,--suffixes}'[suffixes to add (comma-separated)]:suffixes:' \
    '--tld-preset[use a TLD preset]:preset:(popular tech)' \
    '(-r --regex)'{-r,--regex}'[enable regex pattern matching]' \
    '(-m --max-domain-length)'{-m,--max-domain-length}'[maximum domain name length]:length:' \
    '(-i --input)'{-i,--input}'[file to read keywords from (- for stdin)]:file:_files' \
    '(-a --only-available)'{-a,--only-available}'[show only available domains]' \
    '(-l --limit)'{-l,--limit}'[stop after finding N available domains]:n:' \
    '(-f --format)'{-f,--format}'[output format]:format:(text json json-stream json-array csv grouped grouped-tld)' \
    '--no-color[disable colored output]' \
    '--show-stats[show statistics at end of execution]' \
    '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
    '--dry-run[print domains without making network calls]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'show-presets:list built-in TLD presets'
        'mcp:run as Model Context Protocol server for LLM integration'
      )
      _describe -t subcommands 'tldx subcommand' subcmds
      ;;
  esac
}

_tldx "$@"
