#compdef stencil-cli
# _stencil-cli — Ionic Stencil web-components compiler CLI alias (Ionic, TypeScript); commander
# upstream: https://github.com/ionic-team/stencil

_stencil-cli() {
    local -a sub=(
        'build:build web components'
        'docs:generate docs'
        'generate:scaffold a component'
        'g:scaffold a component (alias)'
        'help:show help'
        'info:show env info'
        'init:scaffold project'
        'serve:run dev server'
        'test:run tests'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "stencil.config.ts stencil.config.js"' \
        '-c+[config file]:file:_files -g "stencil.config.ts stencil.config.js"' \
        '--ci[ci mode]' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'stencil subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '--dev[dev build]' \
                    '--prod[production build]' \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--serve[serve after build]' \
                    '--es5[es5 output]' \
                    '--esm[esm output]' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--prerender[prerender]' \
                    '--prerender-external[prerender external]' \
                    '--ssr[ssr]' \
                    '--docs[generate docs]' \
                    '--docs-api[generate docs API]' \
                    '--docs-json=+[docs json output]:file:_files' \
                    '--max-workers=+[max workers]:n:' \
                    '--log[print logs]' \
                    '--log-level=+[log level]:level:(debug info warn error)' \
                    '--cache[cache]' \
                    '--no-cache[no cache]' ;;
                serve) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--config=+[config file]:file:_files' \
                    '--root=+[root dir]:dir:_files -/' \
                    '--reload-strategy=+[reload strategy]:s:(hmr pageReload disabled)' \
                    '--open[open browser]' \
                    '--no-open[no open]' ;;
                test) _arguments \
                    '--spec[spec tests]' \
                    '--e2e[e2e tests]' \
                    '--screenshot[screenshot tests]' \
                    '--screenshot-connector=+[screenshot connector]:str:' \
                    '--watch[watch]' \
                    '--watch-all[watch all]' \
                    '--ci[ci mode]' \
                    '--update-screenshot[update screenshot]' \
                    '-u[update screenshot]' \
                    '--max-workers=+[max workers]:n:' \
                    '--silent[silent]' \
                    '--coverage[coverage]' \
                    '--devtools[devtools]' \
                    '--debug[debug]' \
                    '--no-build[no build]' \
                    '*:pattern:' ;;
                generate|g) _arguments \
                    '1:name:' \
                    '--styles=+[styles]:s:(css scss less none)' \
                    '--spec[include spec]' \
                    '--no-spec[no spec]' \
                    '--e2e[include e2e]' \
                    '--no-e2e[no e2e]' ;;
                docs) _arguments \
                    '1:type:(json readme vscode)' \
                    '*:arg:' ;;
                init) _arguments \
                    '*:starter:(component app ionic-pwa)' ;;
            esac
            ;;
    esac
}

_stencil-cli "$@"
