#compdef dotnet-serve
# Documentation: https://man.archlinux.org/search?q=dotnet-serve
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-d --directory)'{-d,--directory}'=[document root]:directory:_directories' \
  '-o+[open browser optional subpath]:path:' \
  '--open-browser+[open browser optional subpath]:path:' \
  '--port=[listen port 0=dynamic]:port:' \
  '*'{-a,--address}'+[listen addresses]:address:(localhost any)' \
  '--path-base=[URL path prefix]:path:' \
  '*'--reverse-proxy'=[path pattern=upstream URL]:mapping:' \
  '--default-extensions=-[comma default extensions]:exts:' \
  '--quiet[less output]' \
  '--verbose[more output]' \
  '*'{-h --headers}'+[response Header:value (repeatable)]:header:' \
  '--log=[Microsoft.Extensions.Logging level]:level:' \
  '(-S --tls)'{-S,--tls}'[HTTPS]' \
  '--cert=[PEM certificate]:file:_files' \
  '--key=[PEM private key]:file:_files' \
  '--pfx=[PKCS#12 cert]:file:_files' \
  '--pfx-pwd=[PFX password]:password:' \
  '*'{-m --mime}'+[ext=mime mapping]:map:' \
  '(-z --gzip)'{-z,--gzip}'[gzip]' \
  '(-b --brotli)'{-b,--brotli}'[brotli]' \
  '--compression-level=[System.IO.Compression.CompressionLevel]:level:' \
  '(-c --cors)'{-c,--cors}'[enable permissive CORS]' \
  '--save-options[write .netconfig]' \
  '--config-file=[.netconfig path]:file:_files' \
  '--fallback-file=[SPA fallback file]:file:_files' \
  '--help[help]' \
  '--version[version]'
