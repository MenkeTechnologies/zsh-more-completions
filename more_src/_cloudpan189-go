#compdef cloudpan189-go
# Documentation: https://github.com/tickstep/cloudpan189-go
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (urfave/cli main.go).

local curcontext="$curcontext" ret=1

_arguments -C \
  '--verbose[enable debug logging]' \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'cloudpan189-go command' compadd -- \
    login logout loglist su who family quota sign cd pwd ls mkdir rm cp xcp mv rename share backup upload rapidupload download export import config tool clear update quit run help
  ;;
rest)
  case $line[1] in
    run)
      _arguments '*::script args:_default' && ret=0
      ;;
    update)
      _arguments '-y[assume yes]' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
