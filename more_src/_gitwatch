#compdef gitwatch
# Documentation: https://github.com/gitwatch/gitwatch/blob/master/gitwatch.sh
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments \
  '-s[sleep seconds before committing]:seconds' \
  '-d[date format for commit messages]:format' \
  '-r[remote to push to after commit]:remote' \
  '-b[branch to push to]:branch' \
  '-m[commit message]:message' \
  '-l[include up to N diff lines in commit message (colored)]:lines' \
  '-L[include up to N diff lines in commit message (no color)]:lines' \
  '-e[inotify events to monitor]:events' \
  '-g[path to .git directory]:directory:_directories' \
  '-p[alias for -r remote]:remote' \
  '-c[custom command to generate commit message]:command' \
  '-C[pipe diffed file list to custom command]' \
  '-f[commit pending changes on startup before watching]' \
  '-M[skip commits during merge]' \
  '-R[git pull --rebase before pushing]' \
  '-v[verbose mode]' \
  '-x[exclude pattern from inotifywait]:pattern' \
  '-h[display help]' \
  '1:directory to watch:_directories'
