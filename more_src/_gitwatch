#compdef gitwatch

_arguments \
  '-s[polling sleep interval in seconds]:seconds' \
  '-d[date format for commit messages]:format' \
  '-r[remote to push to after commit]:remote' \
  '-b[branch to checkout and push to]:branch' \
  '-m[commit message]:message' \
  '-l[log file]:file:_files' \
  '-e[regex pattern for files to exclude]:pattern' \
  '-g[path to git directory]:directory:_directories' \
  '-p[path to push after commit]:remote path' \
  '-h[display help]' \
  '1:directory to watch:_directories'
