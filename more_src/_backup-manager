#compdef backup-manager
# _backup-manager — Alexis Sukrieh backup-manager CLI for the Linux backup tool wrapping tar dar zip dump rsync supporting per-directory rotation upload via SCP FTP S3 SSH-Tunnel with notifications encryption multi-backup-method (sukria team, Perl); getopt
# upstream: https://github.com/sukria/Backup-Manager

_backup-manager() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-c+[config file]:file:_files -g "*.conf backup-manager.conf"' \
        '--conffile=+[config file]:file:_files -g "*.conf backup-manager.conf"' \
        '-m+[mode]:m:(daily weekly monthly yearly)' \
        '--mode=+[mode]:m:(daily weekly monthly yearly)' \
        '-l+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '--no-warnings[no warnings]' \
        '--force[force backup]' \
        '--no-flush[no flush]' \
        '--pre-command=+[command]:str:' \
        '--post-command=+[command]:str:' \
        '--no-upload[no upload]' \
        '--no-purge[no purge]' \
        '--upload[upload only]' \
        '--purge[purge only]' \
        '--debug-archive[debug archive]'
}

_backup-manager "$@"
