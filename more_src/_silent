#compdef silent

# EMBOSS silent: find restriction enzyme cleavage sites that can be
# introduced into a DNA sequence by silent mutations (without changing
# the protein product). Useful for cloning strategies.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence (the coding strand)]:DNA USA:_files' \
  '-enzymes=[enzymes to test (comma-list, "all", "@file")]:enzymes:' \
  '-sshow[print original DNA sequence in output]' \
  '-tshow[print protein translation in output]' \
  '-allmut[show all possible base-pair mutations, not just silent]' \
  '-table=[genetic code (NCBI table)]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '-outfile=[output file]:file:_files' \
  '*:DNA USA:_files' && ret=0

return ret
