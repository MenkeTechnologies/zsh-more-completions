#compdef gpnorm
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/gpnorm.html
# Correct the polarisation leakage terms for an offset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'cal=[cal keyword]:cal:' \
  'select=[select keyword]:select:' \
  'options=[options keyword]:options:' \
  '*:visibility dataset:_files' && ret=0

return ret
