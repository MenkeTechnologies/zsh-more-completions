#compdef cairo-format
# Documentation: https://github.com/starkware-libs/cairo/tree/main/crates/bin/cairo-format
# Source: starkware-libs/cairo crates/bin/cairo-format/src/main.rs — formatter for the Cairo language.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-c --check)'{-c,--check}'[check mode: print diff without writing files]' \
    '(-r --recursive)'{-r,--recursive}'[format directories content recursively]' \
    '(-v --verbose)'{-v,--verbose}'[print verbose output]' \
    '(-p --print-parsing-errors)'{-p,--print-parsing-errors}'[print parsing errors]' \
    '(-s --sort-mod-level-items)'{-s+,--sort-mod-level-items=}'[sort module-level items]:bool:(true false)' \
    '--tuple-line-breaking=[tuple breaking behavior]:bool:(true false)' \
    '--fixed-array-line-breaking=[fixed array breaking behavior]:bool:(true false)' \
    '--macro-call-breaking-behavior=[macro call breaking behavior]:bool:(true false)' \
    '--merge-use-items=[enable merging of use items]:bool:(true false)' \
    '--allow-duplicates=[allow duplicates in use items]:bool:(true false)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*:file:_files' \
    && ret=0

return ret
