#compdef falkon
# Documentation: https://man.archlinux.org/search?q=falkon
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --author)'{-a,--author}'[show authors]' \
  '(-l --license)'{-l,--license}'[show license]' \
  '(-d --desktop-file)'{-d,--desktop-file}'[print desktop file path]' \
  '(-p --profile)'{-p+,--profile=}'[start with profile]:profile:' \
  '--no-extensions[start without extensions]' \
  '--no-remote[never reuse running instance]' \
  '--portable[run portable mode]' \
  '--private-browsing[start in private browsing]' \
  '--wmclass=[WM_CLASS hint]:name:' \
  '--current-tab=[open URL in current tab]:url:' \
  '--open-window=[open URL in new window]:url:' \
  '--new-tab=[open URL in new tab]:url:' \
  '--download-manager[show download manager]' \
  '--bookmarks=[show bookmarks dialog]' \
  '--history[show history dialog]' \
  '--prefs[show preferences dialog]' \
  '--fullscreen[fullscreen mode]' \
  '*:URL:' && ret=0

return ret
