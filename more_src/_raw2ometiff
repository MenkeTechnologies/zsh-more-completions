#compdef raw2ometiff
# Documentation: https://github.com/glencoesoftware/raw2ometiff
# Convert a Zarr pyramid directory to an OME-TIFF file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--legacy[generate a 5.9.x-compatible pyramid]' \
  '--rgb[store data in chunky RGB format]' \
  '--max_workers=[number of parallel tile-compression workers]:n' \
  '--compression=[compression type]:type:(Uncompressed LZW JPEG-2000 "JPEG-2000 Lossy" JPEG zlib)' \
  '--quality=[compression quality]:quality' \
  '--debug[enable debug-level logging]' \
  '--log-level=[set slf4j logging level]:level:(OFF ERROR WARN INFO DEBUG TRACE ALL)' \
  '1:input tile directory:_files -/' \
  '2:output OME-TIFF:_files' && ret=0

return ret
