#compdef ots-sanitize
# Documentation: https://github.com/khaledhosny/ots/blob/main/util/ots-sanitize.cc
# OpenType Sanitizer: validate and transcode a font file

local ret=1

_arguments -s -S \
  '--version[show package name and version]' \
  '--quiet[suppress stdout/stderr messages]' \
  '1:font file:_files' \
  '2:dest font file:_files' \
  '3:font index:' && ret=0

return ret
