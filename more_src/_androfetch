#compdef androfetch
# Documentation: https://github.com/laraib07/androfetch
# androfetch - a fetch script for Android/Termux

local ret=1

_arguments -s -S \
  '-h[print usage]' \
  '-c[build new cache]' \
  '-i[toggle icon visibility]' \
  '-t[toggle description title visibility]' \
  '-n[set user name]:name:' \
  '-l[set custom logo, use alone to restore default]:filepath:_files' && ret=0

return ret
