#compdef AverageAffineTransformNoRigid
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/AverageAffineTransformNoRigid.cxx — weighted average of affine transforms, no rigid (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-R+[reference transform]:file:_files -g "*.{txt,mat}"' \
    '*-i[take the inverse of the next transform]' \
    '1:ImageDimension:(2 3)' \
    '2:output_affine.txt:_files -g "*.{txt,mat}"' \
    '*:transform (optional weight follows):_files -g "*.{txt,mat}"' \
    && ret=0

return ret
