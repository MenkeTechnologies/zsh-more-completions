#compdef marcador
# Documentation: https://github.com/joajfreitas/marcador
# marcador - minimal bookmark manager with rofi front end

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--host[hostname of marcador server]:host' \
  '--db[bookmark database path]:file:_files' \
  '1:command:(rofi add list delete help)' \
  '*::arg:->args' && ret=0

return ret
