#compdef autoprefixer-cli
# Documentation: https://man.archlinux.org/search?q=autoprefixer-cli
# Reference accessed: 2026-05-16

# Zsh completion for autoprefixer-cli (ai/autoprefixer-cli / binary.js)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show Autoprefixer version]' \
  '(-i --info)'{-i,--info}'[print browser coverage summary]' \
  '(-b --browsers)'{-b,--browsers}'[Browserslist query string]:query' \
  '(-c --clean)'{-c,--clean}'[strip known prefixes instead of adding]' \
  '(-o --output)'{-o,--output}'[output file, or - for stdout]:file:_files' \
  '(-d --dir)'{-d,--dir}'[output directory for many inputs]:directory:_directories' \
  '(-m --map)'{-m,--map}'[emit source map]' \
  '--no-map[disable source maps]' \
  '(-I --inline-map)'{-I,--inline-map}'[force inline source map]' \
  '--no-inline-map[never inline maps]' \
  '--annotation[source map annotation path]:path' \
  '--no-map-annotation[omit map comment in CSS]' \
  '--sources-content[embed sources in map]' \
  '--no-sources-content[strip sources from map]' \
  '--no-cascade[no cascade layout for prefixes]' \
  '--no-remove[keep outdated prefixes]' \
  '*:CSS file:_files -g "*.(css|scss|less)(-.)"' && ret=0

return ret
