#compdef hipify-clang
# Documentation: https://rocm.docs.amd.com/projects/HIPIFY/en/latest/reference/hipify-clang-cmd.html
# Reference accessed: 2026-05-16
# Verified: AMD ROCm HIPIFY hipify-clang command reference.
# Removed from prior file: bogus man.archlinux.org search URL.

# hipify-clang: convert CUDA source code to HIP (Clang LibTooling)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-v[verbose output]' \
  '--cuda-path=[CUDA toolkit path (required)]:dir:_files -/' \
  '-o[output file]:file:_files' \
  '*-I+[include directory]:dir:_files -/' \
  '*-D+[preprocessor define]:macro:' \
  '--inplace[modify files in place]' \
  '--no-backup[disable .prehip backup files]' \
  '--o-dir=[output directory]:dir:_files -/' \
  '--no-output[no file output]' \
  '--hip-kernel-execution-syntax[use HIP kernel <<< >>> syntax]' \
  '--cuda-kernel-execution-syntax[use CUDA kernel <<< >>> syntax]' \
  '--amap[verify all converted names against actual HIP functions]' \
  '--roc[generate HIP code with rocPRIM/rocSPARSE etc]' \
  '--miopen[convert cuDNN to MIOpen]' \
  '--print-stats[print conversion statistics]' \
  '--examine[analyse without converting]' \
  '*:CUDA source:_files -g "*.(cu|cuh|h|hpp|c|cpp)(-.)"' && ret=0
return ret
