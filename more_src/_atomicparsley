#compdef atomicparsley AtomicParsley

local -a arguments

arguments=(
  '1:media file:_files -g "*.(mp4|m4a|m4v|m4b|m4p|3gp)"'
  '-T[list all tags in the file]'
  '-t[extract all tags to text file]'
  '--textdata[extract text data]'
  '--showDynamicRange[show dynamic range info]'
  '--artist=[set artist tag]:artist:'
  '--title=[set title tag]:title:'
  '--album=[set album tag]:album:'
  '--genre=[set genre tag]:genre:'
  '--tracknum=[set track number]:tracknum:'
  '--disk=[set disk number]:disknum:'
  '--year=[set year]:year:'
  '--lyrics=[set lyrics]:lyrics:'
  '--comment=[set comment]:comment:'
  '--composer=[set composer]:composer:'
  '--copyright=[set copyright]:copyright:'
  '--grouping=[set grouping]:grouping:'
  '--albumArtist=[set album artist]:album artist:'
  '--encodedBy=[set encoded by]:encoder:'
  '--bpm=[set BPM]:bpm:'
  '--compilation=[set compilation flag]:flag:(true false)'
  '--artwork=[set artwork from file]:image file:_files -g "*.(jpg|jpeg|png|bmp)"'
  '--artwork REMOVE_ALL[remove all artwork]'
  '--TVShowName=[set TV show name]:name:'
  '--TVEpisode=[set TV episode ID]:id:'
  '--TVEpisodeNum=[set TV episode number]:number:'
  '--TVSeasonNum=[set TV season number]:number:'
  '--TVNetwork=[set TV network]:network:'
  '--description=[set description]:description:'
  '--longdesc=[set long description]:description:'
  '--rating=[set rating]:rating:'
  '--stik=[set media type]:type:(Movie Normal Audiobook Music\ Video Short\ Film TV\ Show Bookmark)'
  '--advisory=[set advisory]:advisory:(Clean Explicit Inoffensive)'
  '--category=[set category]:category:'
  '--keyword=[set keyword]:keyword:'
  '--podcastFlag=[set podcast flag]:flag:(true false)'
  '--podcastURL=[set podcast URL]:url:'
  '--podcastGUID=[set podcast GUID]:guid:'
  '--purchaseDate=[set purchase date]:date:'
  '--encodingTool=[set encoding tool]:tool:'
  '--sortOrder=[set sort order]:field:(name artist album albumartist composer show)' \
  '--overWrite[overwrite the original file]'
  '--output=[output to specified file]:file:_files'
  '--DeepScan[deep scan for atoms]'
  '--freefree[remove free atoms]'
  '--metaCleanPadding[clean metadata padding]'
  '--manualAtomRemove=[remove atom by name]:atom:'
)

_arguments -s -S $arguments
