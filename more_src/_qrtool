#compdef qrtool

# Zsh completion for qrtool (sorairolake/qrtool).

_qrtool_cmds() {
  local -a c
  c=(
    'encode:encode input as QR code'
    'decode:decode QR from image'
    'completion:emit shell completion script'
  )
  _describe 'qrtool command' c
}

_qrtool() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '1: :->cmds' \
    '*:: :->args' && return 0

  case $state in
    cmds)
      _qrtool_cmds
      ;;
    args)
      case $line[1] in
        encode)
          _arguments -s -S \
            '(-o --output)'{-o,--output=}'[output file]:file:_files' \
            '(-r --read-from)'{-r,--read-from=}'[input file]:file:_files' \
            '(-s --size)'{-s,--size=}'[module size in pixels]:int:' \
            '(-l --error-correction-level)'{-l,--error-correction-level=}'[ECC level]:level:(l m q h)' \
            '(-v --symbol-version)'{-v,--symbol-version=}'[QR version]:int:' \
            '(-m --margin)'{-m,--margin=}'[margin width]:int:' \
            '(-t --type)'{-t,--type=}'[output format]:format:(png svg eps pic ascii ascii-invert unicode unicode-invert)' \
            '--mode=[data mode (needs version)]:mode:(numeric alphanumeric byte kanji)' \
            '--variant=[QR variant]:variant:(normal micro rmqr)' \
            '--foreground=[CSS color]:color:' \
            '--background=[CSS color]:color:' \
            '--verbose[print metadata to stderr]' \
            '*::data:'
          ;;
        decode)
          _arguments -s -S \
            '(-t --type)'{-t,--type=}'[input format]:format:(png jpeg gif svg bmp tiff webp)' \
            '--verbose[print metadata to stderr]' \
            '--metadata[only print metadata]' \
            '*::image:_files'
          ;;
        completion)
          _arguments '1:shell:(bash elvish fish nushell powershell zsh)'
          ;;
      esac
      ;;
  esac
}

_qrtool "$@"
