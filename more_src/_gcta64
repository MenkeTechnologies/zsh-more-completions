#compdef gcta64
# Documentation: https://yanglab.westlake.edu.cn/software/gcta/
# GCTA: Genome-wide Complex Trait Analysis

local ret=1

_arguments -s -S \
  '--bfile=[input PLINK binary PED files]:prefix:_files' \
  '--mbfile=[multiple PLINK binary files]:file:_files' \
  '--bgen=[input BGEN format genotypes]:file:_files -g "*.bgen"' \
  '--pfile=[input PLINK2 pgen format]:prefix:_files' \
  '--out=[output filename root]:prefix:_files' \
  '--keep=[include specific individuals]:file:_files' \
  '--remove=[exclude specific individuals]:file:_files' \
  '--chr=[specific chromosome]:chr' \
  '--autosome[use all autosomes]' \
  '--autosome-num=[number of autosomes]:num' \
  '--extract=[include SNP list]:file:_files' \
  '--exclude=[exclude SNP list]:file:_files' \
  '--maf=[minimum allele frequency]:maf' \
  '--max-maf=[maximum allele frequency]:maf' \
  '--make-grm[estimate genetic relationship matrix]' \
  '--make-grm-bin[GRM in binary format]' \
  '--make-grm-gz[GRM in compressed text]' \
  '--grm=[input GRM]:prefix:_files' \
  '--grm-bin=[input binary GRM]:prefix:_files' \
  '--mgrm=[multiple GRMs]:file:_files' \
  '--grm-cutoff=[remove relatives by threshold]:cutoff' \
  '--grm-singleton=[extract unrelated individuals]:cutoff' \
  '--pca[principal component analysis]' \
  '--reml[REML variance estimation]' \
  '--reml-maxit=[maximum iterations]:num' \
  '--pheno=[phenotype file]:file:_files' \
  '--mpheno=[select phenotype column]:num' \
  '--covar=[discrete covariates]:file:_files' \
  '--qcovar=[quantitative covariates]:file:_files' \
  '--prevalence=[disease prevalence]:val' \
  '--mlma[mixed linear model association]' \
  '--mlma-loco[MLMA leave-one-chromosome-out]' \
  '--fastGWA-mlm[fast mixed linear model association]' \
  '--fastGWA-glmm[generalized linear mixed model]' \
  '--cojo-file=[COJO conditional analysis]:file:_files' \
  '--cojo-slct[COJO stepwise model selection]' \
  '--cojo-cond=[COJO conditioning SNP list]:file:_files' \
  '--gsmr[GSMR Mendelian randomization]' \
  '--ld=[LD analysis SNP list]:file:_files' \
  '--thread-num=[number of threads]:num' \
  '--threads=[number of threads]:num' \
  '*:file:_files' && ret=0

return ret
