#compdef tdl
# Documentation: https://docs.iyear.me/tdl/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:login to Telegram'
  'download:download files from Telegram chats'
  'dl:download files from Telegram chats'
  'upload:upload files to Telegram'
  'up:upload files to Telegram'
  'forward:forward messages with routing'
  'chat:chat operations (list/export/users)'
  'backup:backup tdl data'
  'recover:recover tdl data from backup'
  'migrate:migrate session/storage'
  'extension:manage tdl extensions'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable debug mode]' \
  '--delay=[delay between tasks (e.g. 1s, 500ms)]:duration:' \
  '(-l --limit)'{-l+,--limit=}'[max concurrent tasks]:n:' \
  '(-n --ns)'{-n+,--ns=}'[Telegram session namespace]:namespace:' \
  '--ntp=[NTP server host]:host:' \
  '--pool=[DC pool size]:n:' \
  '--proxy=[proxy address]:proxy:' \
  '--reconnect-timeout=[reconnect backoff timeout]:duration:' \
  '*--storage=[storage option key=value]:kv:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tdl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (login)
        _arguments \
          '(-T --type)'{-T+,--type=}'[login type]:type:(desktop code)' \
          '--passcode=[2FA passcode]:passcode:' \
          '--desktop=[path to Telegram Desktop data]:dir:_files -/' && ret=0 ;;
      (download|dl)
        _arguments \
          '(-u --url)*'{-u+,--url=}'[message URL]:url:' \
          '(-f --files)*'{-f+,--files=}'[exported JSON file]:file:_files -g "*.json"' \
          '(-d --dir)'{-d+,--dir=}'[destination directory]:dir:_files -/' \
          '(-t --template)'{-t+,--template=}'[file naming template]:template:' \
          '*--include=[only include these extensions]:ext:' \
          '*--exclude=[exclude these extensions]:ext:' \
          '--desc[download newest first]' \
          '--takeout[use takeout session]' \
          '--continue[resume incomplete downloads]' \
          '--restart[restart from beginning]' \
          '--skip-same[skip files with same name+size]' \
          '--rewrite-ext[rewrite extension based on mime]' \
          '--serve[serve a local download proxy]' \
          '--port=[serve port]:port:' && ret=0 ;;
      (upload|up)
        _arguments \
          '(-p --path)*'{-p+,--path=}'[file or directory to upload]:path:_files' \
          '(-c --chat)'{-c+,--chat=}'[destination chat]:chat:' \
          '*--exclude=[exclude these extensions]:ext:' \
          '--remove[remove file after upload]' \
          '--photo[upload as photo]' && ret=0 ;;
      (forward)
        _arguments \
          '(-f --from)*'{-f+,--from=}'[source message URL]:url:' \
          '(-t --to)'{-t+,--to=}'[destination chat or expr]:chat:' \
          '--mode=[forward mode]:mode:(direct clone)' \
          '--single[per-message forward]' \
          '--silent[silent forward]' \
          '--dry-run[do not actually forward]' && ret=0 ;;
      (chat)
        local -a chat_subs=(
          'ls:list chats'
          'list:list chats'
          'export:export chat messages'
          'users:export chat members/subscribers'
        )
        _describe -t cs 'chat subcommand' chat_subs && ret=0
        _arguments \
          '(-c --chat)'{-c+,--chat=}'[chat id or username]:chat:' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '(-T --type)'{-T+,--type=}'[message type filter]:type:' \
          '(-i --input)'{-i+,--input=}'[input range expression]:expr:' \
          '*--filter=[message filter expression]:expr:' && ret=0 ;;
      (extension)
        _arguments \
          '*::sub:(install list remove update)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
