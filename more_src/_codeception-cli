#compdef codeception-cli
# _codeception-cli — Michael Bodnarchuk Codeception PHP full-stack test framework CLI alias (Codeception team, PHP); symfony console
# upstream: https://github.com/Codeception/Codeception

_codeception-cli() {
    local -a sub=(
        'bootstrap:setup codeception in current dir'
        'build:generate base classes for suites'
        'clean:clean output dir'
        'config:show config'
        'config:validate:validate config'
        'console:try out commands in tester console'
        'dry-run:list tests without running'
        'gherkin:snippets:print gherkin snippets'
        'gherkin:steps:list gherkin steps'
        'generate:cept:generate cept file'
        'generate:cest:generate cest file'
        'generate:feature:generate feature file'
        'generate:groupobject:generate group object'
        'generate:helper:generate helper class'
        'generate:pageobject:generate page object'
        'generate:phpunit:generate phpunit test'
        'generate:scenarios:generate scenarios'
        'generate:snapshot:generate snapshot'
        'generate:stepobject:generate step object'
        'generate:suite:generate suite'
        'generate:test:generate test'
        'init:initialize codeception'
        'list:list commands'
        'run:run tests'
        'self-update:update phar'
        'completion:dump completion script'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '-c+[config file]:file:_files -g "codeception.yml"' \
        '--config=+[config file]:file:_files -g "codeception.yml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'codeception subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '1:suite:' \
                    '2:test:' \
                    '--report[report mode]' \
                    '--html=+[html file]:file:_files' \
                    '--xml=+[xml file]:file:_files' \
                    '--phpunit-xml=+[phpunit xml file]:file:_files' \
                    '--tap=+[tap file]:file:_files' \
                    '--json=+[json file]:file:_files' \
                    '--colors[force colors]' \
                    '--no-colors[no colors]' \
                    '--silent[silent]' \
                    '--steps[show steps]' \
                    '--debug[debug]' \
                    '--coverage=+[coverage file]:file:_files' \
                    '--coverage-html=+[coverage html dir]:dir:_files -/' \
                    '--coverage-xml=+[coverage xml file]:file:_files' \
                    '--coverage-text=+[coverage text file]:file:_files' \
                    '--coverage-crap4j=+[crap4j file]:file:_files' \
                    '--coverage-phpunit=+[phpunit coverage file]:file:_files' \
                    '--coverage-cobertura=+[cobertura file]:file:_files' \
                    '--no-exit[no exit code]' \
                    '--group=+[group]:str:' \
                    '-g+[group]:str:' \
                    '--skip=+[skip suite]:str:' \
                    '-s+[skip suite]:str:' \
                    '--skip-group=+[skip group]:str:' \
                    '-x+[skip group]:str:' \
                    '--env=+[environment]:str:' \
                    '--fail-fast[fail fast]' \
                    '-f[fail fast]' \
                    '--no-redirect[no redirect]' \
                    '--no-rebuild[no rebuild]' \
                    '--seed=+[seed]:n:' \
                    '--shard=+[shard]:str:' \
                    '--ext=+[extension]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_codeception-cli "$@"
