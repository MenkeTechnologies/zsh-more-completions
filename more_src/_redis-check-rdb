#compdef redis-check-rdb
# Documentation: https://github.com/redis/redis/blob/unstable/src/redis-check-rdb.c
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. Argv parsing accepts exactly one
# argument: an rdb file path, or -v/--version.

_arguments -s \
  '(- *)'{-v,--version}'[show version and exit]' \
  '1:RDB file:_files -g "*.rdb"'
