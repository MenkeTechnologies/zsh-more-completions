#compdef opentelemetry-bootstrap
# Documentation: https://github.com/open-telemetry/opentelemetry-python
# Reference accessed: 2026-05-23
# Verified: opentelemetry-bootstrap --help (OpenTelemetry Python distro).

# Zsh completion for opentelemetry-bootstrap - auto-install OTel instrumentations

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-a --action)'{-a+,--action=}'[install or print requirements]:action:(install requirements)' && ret=0

return ret
