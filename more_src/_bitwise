#compdef bitwise
# Documentation: https://man.archlinux.org/search?q=bitwise
# Reference accessed: 2026-05-16

# Zsh completion for bitwise - terminal-based bit manipulator

_arguments -s -S \
  '(-w --width)'{-w+,--width=}'[set number of bits]:bits:(8 16 32 64)' \
  '(-i --interactive)'{-i,--interactive}'[launch interactive mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:expression:'
