#compdef wleave

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-b[number of buttons per row]:number:' \
  '-c[column spacing]:pixels:' \
  '-r[row spacing]:pixels:' \
  '-m[margin]:pixels:' \
  '-p[protocol]:protocol:(layer-shell xdg)' \
  '-C[CSS file]:css file:_files' \
  '-l[layout file]:layout file:_files' \
  '--selection-label[preselect a button]:label:' && ret=0

return ret
