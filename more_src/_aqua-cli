#compdef aqua-cli aquasec aquactl
# _aqua-cli — Aqua Security aqua-cli CLI command-line frontend to the Aqua Security Container Cloud-Native security platform managing image scanning vulnerability scanning runtime-protection compliance audit policies workloads admission-controller-Kubernetes-CSP-CSPM-DSPM scanner Trivy ecosystem-integration (Aqua Security team, Go); cobra
# upstream: https://www.aquasec.com/

_aqua-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'scan:scan image filesystem repo'
        'list:list scan results'
        'images:image management'
        'workloads:workload management'
        'policies:policy management'
        'vulnerabilities:vulnerability operations'
        'sbom:SBOM operations'
        'admission:admission controller'
        'plugins:plugin operations'
        'config:configuration'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '-f+[format]:f:(json yaml csv table sarif spdx cyclonedx)' \
        '--format=+[format]:f:(json yaml csv table sarif spdx cyclonedx)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aqua-cli subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments \
                    '--register[register image after scan]' \
                    '--registry=+[name]:str:' \
                    '--severity=+[list]:str:' \
                    '--show-will-not-fix[show will-not-fix]' \
                    '*:target:_files' ;;
                images|workloads|policies) _arguments '1:op:(list get add remove enable disable)' '*:name:' ;;
            esac
            ;;
    esac
}

_aqua-cli "$@"
