#compdef dockerize

_arguments -s \
  '-version[show version]' \
  '-poll[poll for changes]' \
  '*-template=[src:dest]:template:' \
  '*-stdout=[file]:file:_files' \
  '*-stderr=[file]:file:_files' \
  '*-wait=[URL]:url:' \
  '-wait-retry-interval=[duration]:duration:' \
  '*-wait-http-header=[name:value]:header:' \
  '-timeout=[duration]:duration:' \
  '-delims=[left:right]:delims:' \
  '-no-overwrite[no overwrite]' \
  '-skip-tls-verify[skip TLS]' \
  '*::command:_command_names'
