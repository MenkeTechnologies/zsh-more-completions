#compdef uu-mknod
# Source: Homebrew bottle
# Formula: uutils-coreutils
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

autoload -U is-at-least

_uu-mknod() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-m+[set file permission bits to MODE, not a=rw - umask]:MODE:_default' \
'--mode=[set file permission bits to MODE, not a=rw - umask]:MODE:_default' \
'--context=[like -Z, or if CTX is specified then set the SELinux or SMACK security context to CTX]::CTX:_default' \
'-Z[set SELinux security context of each created directory to the default type]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':name -- name of the new file:_files' \
':type -- type of the new file (b, c, u or p):_default' \
'::major -- major file type:_default' \
'::minor -- minor file type:_default' \
&& ret=0
}

(( $+functions[_uu-mknod_commands] )) ||
_uu-mknod_commands() {
    local commands; commands=()
    _describe -t commands 'uu-mknod commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-mknod" ]; then
    _uu-mknod "$@"
else
    compdef _uu-mknod uu-mknod
fi
