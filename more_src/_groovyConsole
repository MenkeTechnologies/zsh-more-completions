#compdef groovyConsole
# Documentation: https://groovy-lang.org/groovyconsole.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--configscript=[script for tweaking compiler config]:file:_files' \
  {-cp+,-classpath+,--classpath=}'[classpath]:path:_files' \
  '*'{-D+,--define=}'[define system property]:name=value:' \
  {-pa,--parameters}'[generate metadata for reflection on method params]' \
  {-pr,--enable-preview}'[enable preview Java features (JDK 12+)]' \
  {-V,--version}'[show version]' \
  '*:script file:_files -g "*.groovy"' && ret=0

return ret
