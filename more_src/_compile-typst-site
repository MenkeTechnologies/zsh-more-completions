#
#  Surface (verbatim from `src/internals/config.rs` Args struct
#  with `#[derive(OnlyArgs)]`):
#
#  Usage:
#    compile-typst-site [options]
#
#  Options:
#        --path <PATH>              Use the specified path as the
#                                   project root (default: current
#                                   working directory)
#        --watch                    Build and then watch for
#                                   changes (rebuild on file modification)
#        --serve                    Build and then watch for
#                                   changes while serving website
#                                   locally (HTTP server on a
#                                   default port)
#        --ignore-initial           Ignore initial full-site
#                                   compilation step (skip the
#                                   first build; useful when
#                                   restarting watch mode after
#                                   a successful initial build)
#        --verbose                  Enable verbose logging
#                                   (info-level + per-file build
#                                   timing)
#        --trace                    Enable very verbose logging
#                                   (debug + trace level; shows
#                                   Typst compiler invocations,
#                                   passthrough copies, etc.)
#        --color <MODE>             Whether to use color in
#                                   terminal output (default:
#                                   auto; choices: auto, always,
#                                   never; respects NO_COLOR env
#                                   var when "auto" and stdout
#                                   is not a TTY)
#    -h, --help                     Show help (auto from onlyargs)
#    -V, --version                  Show version (auto from
#                                   Cargo.toml via impl_version!)
#
#  Configuration file:
#    A TOML config file is also read from the project root
#    (typically `compile-typst-site.toml` or
#    `compile-typst-site-config.toml`).  CLI flags override
#    config-file values.  Config file keys include:
#      passthrough_copy              — globs to copy as-is
#      init                          — commands to run before build
#      post_processing_typ           — HTML post-processor command
#      literal_paths                 — keep .typ → .html naming
#                                      (default: transform to
#                                      .typ → /index.html)
#      file_listing                  — disabled | enabled | include-data
#      file_listing_extra_args       — args for `typst query`
#      compilation_extra_args        — args for `typst compile`
#      disable_incremental           — disable incremental build
#                                      in watch/serve mode
#
#  Examples:
#    compile-typst-site                                    # Build current dir
#    compile-typst-site --path ./my-site                   # Build specific dir
#    compile-typst-site --watch                            # Build + watch
#    compile-typst-site --serve                            # Build + watch + serve
#    compile-typst-site --serve --path ./my-site           # Serve from specific dir
#    compile-typst-site --watch --ignore-initial           # Watch only (skip initial build)
#    compile-typst-site --verbose --path ./my-site         # Verbose output
#    compile-typst-site --trace                            # Very verbose
#    compile-typst-site --color always                     # Force ANSI colors
#    compile-typst-site --color never --verbose            # Plain text verbose
#    compile-typst-site --version                          # Show version
#    compile-typst-site --help                             # Show help
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also parasyte/onlyargs users):
#    - taxcount (dcdpr/taxcount 9 stars — airgapped US tax
#      calculation for Bitcoiners; uses onlyargs_derive; FUTURE
#      candidate but complex flag surface for tax-specific
#      domain)
#    - kraken-export-fix (dcdpr/taxcount sub-binary — also uses
#      onlyargs; same project)
#    - ohlc-ness (dcdpr/taxcount sub-binary — OHLC chart
#      generator)
#    - parasyte/onlyargs repo itself (18 stars library not CLI)
# ============================================================================

_compile-typst-site() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '--path[use specified path as project root]:path:_directories' \
    '--watch[build and watch for changes]' \
    '--serve[build + watch + serve locally]' \
    '--ignore-initial[ignore initial full-site compilation step]' \
    '--verbose[enable verbose logging]' \
    '--trace[enable very verbose logging (debug + trace)]' \
    '--color[whether to use color]:mode:(auto always never)'
}

_compile-typst-site "$@"
