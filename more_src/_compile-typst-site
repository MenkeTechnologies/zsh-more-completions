#
#    // DERIVE usage (uses optional onlyargs_derive crate):
#    use onlyargs_derive::OnlyArgs;
#
#    /// Footer text via per-struct #[footer = "..."] attributes
#    /// can document extra context that doesn't fit in flag
#    /// descriptions
#    #[derive(OnlyArgs)]
#    #[footer = "Additional environment variables:"]
