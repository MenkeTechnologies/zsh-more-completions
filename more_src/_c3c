#compdef c3c
# Documentation: https://github.com/c3lang/c3c
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# c3c - C3 reference compiler.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'compile:compile C3 source files'
  'compile-run:compile and run'
  'compile-only:compile without linking'
  'compile-benchmark:compile benchmarks'
  'compile-test:compile unit tests'
  'init:initialise a new project'
  'init-lib:initialise a new library'
  'build:build the current project'
  'run:run the current project'
  'benchmark:run benchmarks for the current project'
  'test:run unit tests for the current project'
  'clean:clean build artifacts'
  'dist:create a distributable archive'
  'docs:generate documentation'
  'bench:run benchmarks for the current project'
  'clean-run:clean and run'
  'fetch:fetch dependencies / SDK components'
  'vendor-fetch:fetch vendor library bindings'
  'project:project management subcommands'
  'headers:generate C headers'
  'static-lib:build a static library'
  'dynamic-lib:build a dynamic library'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd) _describe -t commands 'c3c command' subcmds && ret=0 ;;
  rest) _files && ret=0 ;;
esac

return ret
