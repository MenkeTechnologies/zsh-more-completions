#compdef appimagetool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-n --no-appstream)'{-n,--no-appstream}'[do not check AppStream metadata]' \
  '(-u --updateinformation)'{-u,--updateinformation}'+[set update information]:update info:' \
  '--sign[sign the AppImage]' \
  '--sign-key+[GPG key for signing]:key ID:' \
  '--sign-args+[additional GPG arguments]:args:' \
  '--comp+[compression type]:type:(gzip xz zstd)' \
  '-g[guess update information from Travis CI/OBS]' \
  '--runtime-file+[use custom runtime]:file:_files' \
  '--no-plugins[do not use plugins]' \
  '--appimage-extract-and-run[extract before running]' \
  '1:source AppDir:_files -/' \
  '2:output AppImage:_files' && ret=0

return ret
