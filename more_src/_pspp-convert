#compdef pspp-convert
# Documentation: https://manpages.debian.org/testing/pspp/pspp-convert.1.en.html
# pspp-convert - convert SPSS data files to other formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage message]' \
  '(-v --version)'{-v,--version}'[print version information]' \
  '(-O --output-format)'{-O,--output-format=}'[set output format]:format:(csv txt sav sys por sps)' \
  '(-c --cases)'{-c,--cases=}'[limit number of cases written]:maxcases:' \
  '(-e --encoding)'{-e,--encoding=}'[override input character encoding]:charset:' \
  '(-k --keep)'{-k,--keep=}'[keep only listed variables]:vars:' \
  '(-d --drop)'{-d,--drop=}'[drop listed variables]:vars:' \
  '--labels[write value labels instead of raw values]' \
  '--no-var-names[omit variable names from first line]' \
  '--recode[recode user-missing values to system-missing]' \
  '--print-formats[honor variables print formats]' \
  '--decimal=[set decimal point character]:char:' \
  '--delimiter=[set field separator]:char:' \
  '--qualifier=[set quoting character]:char:' \
  '(-p --password)'{-p,--password=}'[decryption password]:password:' \
  '(-a --password-alphabet)'{-a,--password-alphabet=}'[character set for password search]:alphabet:' \
  '(-l --password-length)'{-l,--password-length=}'[maximum password length to attempt]:length:' \
  '--password-list=[file with passwords to try]:file:_files' \
  '1:input file:_files' \
  '2:output file:_files' && ret=0

return ret
