#compdef PositionBasedDownsampleSam
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#PositionBasedDownsampleSam
# Picard: downsample a SAM/BAM by retaining reads from a fraction of tile positions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM or BAM file to downsample]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output downsampled SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-F=,--FRACTION=}'[approximate fraction of reads to keep (0-1)]:float:' \
  '--STOP_AFTER=[stop after processing N reads]:int:' \
  '--ALLOW_MULTIPLE_DOWNSAMPLING_DESPITE_WARNINGS=[allow downsampling again despite warnings]:bool:(true false)' \
  '--REMOVE_DUPLICATE_INFORMATION=[reset duplicate tags since re-marking is required]:bool:(true false)' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
