#compdef kcli
# Documentation: https://kcli.readthedocs.io/en/latest/
# kcli: provision and manage VMs, networks and Kubernetes/OpenShift clusters across providers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-C[target specific provider/client host]:client' \
  '-d[enable debug output]' \
  '-r[specify remote hypervisor]:remote' \
  '*-P[override parameter as key=value]:param' \
  '--paramfile=[supply parameter configuration file]:file:_files' \
  '1:command:(create delete list start stop restart ssh scp console clone update info export download scale render render-bootstrap)' \
  '*::arg:->args' && ret=0

return ret
