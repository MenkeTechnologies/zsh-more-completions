#compdef s6-ipcserver-socketbinder
# _s6-ipcserver-socketbinder — s6 conn-tools s6-ipcserver-socketbinder (small piece of the s6-ipcserver pipeline: open a unix socket at `path`, bind/listen, then exec `prog` with the bound fd on stdin)
# upstream: https://github.com/skarnet/s6
# Flags from src/conn-tools/s6-ipcserver-socketbinder.c on tip.

_s6-ipcserver-socketbinder() {
    _arguments \
        '(-d -D)-d[dgram socket]' \
        '(-d -D)-D[stream socket (default)]' \
        '-b+[listen() backlog]:n:' \
        '(-M -m)-M[do not unlink stale socket file before bind]' \
        '(-M -m)-m[unlink stale socket file before bind (default)]' \
        '-a+[socket permissions]:perms:' \
        '-B[blocking socket (default: nonblocking)]' \
        '1:socket-path:_files' \
        '*::program:_command_names -e'
}

_s6-ipcserver-socketbinder "$@"
