#compdef turso

# Zsh completion for turso - Turso database CLI

local curcontext="$curcontext" state line ret=1

_turso_common_flags() {
  _arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '--config-path[path to config file]:file:_files' \
    "$@"
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config-path[path to config file]:file:_files' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a subcommands=(
      'auth:manage authentication'
      'contact:contact Turso support'
      'config:manage CLI configuration'
      'db:manage databases'
      'dev:start local development server'
      'group:manage database groups'
      'org:manage organizations'
      'plan:manage subscription plan'
      'quickstart:start Turso quickstart guide'
      'relax:take a break'
      'update:update the Turso CLI'
      'completion:generate shell completions'
      'help:show help for a command'
    )
    _describe -t commands 'turso command' subcommands && ret=0
    ;;
  args)
    case "${line[1]}" in
      auth)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:((
            login\:"log in to Turso"
            logout\:"log out from Turso"
            token\:"show authentication token"
            signup\:"sign up for Turso"
            whoami\:"show current user"
            api-tokens\:"manage API tokens"
          ))' && ret=0
        ;;
      db)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->db_commands' \
          '*::db arg:->db_args' && ret=0
        case "$state" in
          db_commands)
            local -a db_subcommands=(
              'list:list databases'
              'create:create a database'
              'destroy:destroy a database'
              'show:show database details'
              'inspect:inspect a database'
              'shell:open database shell'
              'tokens:manage database tokens'
              'replicate:replicate a database'
              'locations:manage database locations'
              'update:update database configuration'
              'config:manage database config'
            )
            _describe -t db-commands 'db subcommand' db_subcommands && ret=0
            ;;
          db_args)
            case "${line[1]}" in
              create)
                _turso_common_flags \
                  '--enable-extensions[enable SQLite extensions]' \
                  '--from-db[create from existing database]:database name: ' \
                  '--from-dump[create from SQL dump file]:dump file:_files' \
                  '--from-csv[create from CSV file]:csv file:_files -g "*.csv"' \
                  '--from-file[create from database file]:file:_files' \
                  '--group[database group]:group name: ' \
                  '--location[primary location]:region: ' \
                  '--size-limit[database size limit]:size: ' \
                  '--type[database type]:type:(regular schema)' \
                  '--schema[schema database]:database name: ' \
                  '--wait[wait for database to be ready]' \
                  '*:database name: ' && ret=0
                ;;
              destroy)
                _turso_common_flags \
                  '-y[skip confirmation]' \
                  '*:database name: ' && ret=0
                ;;
              shell)
                _turso_common_flags \
                  '*:database name: ' && ret=0
                ;;
              show|inspect)
                _turso_common_flags \
                  '*:database name: ' && ret=0
                ;;
              tokens)
                _turso_common_flags \
                  '*:database name: ' && ret=0
                ;;
              *)
                _turso_common_flags \
                  '*:database name: ' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      group)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->group_commands' \
          '*::group arg:->group_args' && ret=0
        case "$state" in
          group_commands)
            local -a group_subcommands=(
              'list:list groups'
              'create:create a group'
              'destroy:destroy a group'
              'locations:manage group locations'
              'transfer:transfer a group'
              'update:update a group'
              'unarchive:unarchive a group'
            )
            _describe -t group-commands 'group subcommand' group_subcommands && ret=0
            ;;
          group_args)
            _turso_common_flags \
              '*:group name: ' && ret=0
            ;;
        esac
        ;;
      org)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->org_commands' \
          '*::org arg:->org_args' && ret=0
        case "$state" in
          org_commands)
            local -a org_subcommands=(
              'list:list organizations'
              'create:create an organization'
              'destroy:destroy an organization'
              'switch:switch active organization'
              'billing:manage billing'
              'members:manage members'
              'invite:invite a member'
            )
            _describe -t org-commands 'org subcommand' org_subcommands && ret=0
            ;;
          org_args)
            _turso_common_flags \
              '*:organization: ' && ret=0
            ;;
        esac
        ;;
      dev)
        _turso_common_flags \
          '--port[port to listen on]:port: ' \
          '--db-file[database file]:file:_files' && ret=0
        ;;
      config)
        _turso_common_flags && ret=0
        ;;
      plan)
        _turso_common_flags && ret=0
        ;;
      update)
        _turso_common_flags && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      help)
        local -a help_topics=(
          'auth' 'contact' 'config' 'db' 'dev' 'group' 'org'
          'plan' 'quickstart' 'relax' 'update' 'completion'
        )
        _describe -t help-topics 'help topic' help_topics && ret=0
        ;;
      *)
        _turso_common_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
