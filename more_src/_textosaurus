#compdef textosaurus
# Documentation: https://man.archlinux.org/search?q=textosaurus
# Reference accessed: 2026-05-16

# Textosaurus: Qt + Scintilla-based text/source editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--no-singleinstance[allow multiple instances]' \
  '--debug[enable debug logging]' \
  '--reset[reset on startup]' \
  '*:files:_files' && ret=0
return ret
