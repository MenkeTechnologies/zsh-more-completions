#compdef ndfcopy
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss123.html
# KAPPA NDFCOPY - copy an NDF (or NDF section) to a new location

local ret=1

_arguments -C \
  'IN=[input NDF (or section) to be copied]:NDF file:_files' \
  'OUT=[output NDF data structure]:NDF file:_files' \
  'COMP=[component becoming the output DATA_ARRAY]:component:(Data Variance Error Quality)' \
  'EXTEN=[pad or trim extension NDFs to match output bounds]:flag:(TRUE FALSE)' \
  'LIKE=[template NDF whose shape selects the output region]:NDF file:_files' \
  'LIKEWCS=[use WCS bounds of the template]:flag:(TRUE FALSE)' \
  'TITLE=[title for the output NDF]:title:' \
  'TRIM=[remove single-pixel axes]:flag:(TRUE FALSE)' \
  'TRIMBAD=[exclude borders of bad pixels]:flag:(TRUE FALSE)' \
  'TRIMWCS=[reduce WCS Frame axes to match pixel axes]:flag:(TRUE FALSE)' \
  'USEAXIS=[WCS axes to retain]:axis:' \
  '*:NDF file:_files' && ret=0

return ret
