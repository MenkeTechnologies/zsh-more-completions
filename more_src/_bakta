#compdef bakta
# _bakta — Oliver Schwengers bakta CLI fast standardized bacterial archaeal viral genome annotation pipeline producing GFF3 GenBank JSON TSV INSDC-compliant output with database-driven prediction of CDS rRNA tRNA tmRNA CRISPR sORF ncRNA UniRef Pfam KEGG VFDB-detected features replacement-grade alternative to prokka (Oliver Schwengers team, Python); argparse
# upstream: https://github.com/oschwengers/bakta

_bakta() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--db=+[db dir]:dir:_files -/' \
        '--min-contig-length=+[N]:n:' \
        '--prefix=+[prefix]:str:' \
        '--output=+[dir]:dir:_files -/' \
        '--force[overwrite existing output]' \
        '--genus=+[genus]:str:' \
        '--species=+[species]:str:' \
        '--strain=+[strain]:str:' \
        '--plasmid=+[name]:str:' \
        '--complete[complete genome]' \
        '--prodigal-tf=+[file]:file:_files' \
        '--translation-table=+[n]:n:(11 4 25)' \
        '--gram=+[g]:g:(+ - ?)' \
        '--locus=+[name]:str:' \
        '--locus-tag=+[prefix]:str:' \
        '--locus-tag-increment=+[N]:n:' \
        '--keep-contig-headers[keep original contig headers]' \
        '--meta[metagenomic mode]' \
        '--regions=+[file]:file:_files -g "*.bed *.gff"' \
        '--proteins=+[file]:file:_files -g "*.faa *.fa"' \
        '--replicons=+[file]:file:_files -g "*.tsv"' \
        '--skip-trna[skip tRNA detection]' \
        '--skip-tmrna[skip tmRNA detection]' \
        '--skip-rrna[skip rRNA detection]' \
        '--skip-ncrna[skip ncRNA detection]' \
        '--skip-ncrna-region[skip ncRNA-region detection]' \
        '--skip-crispr[skip CRISPR detection]' \
        '--skip-cds[skip CDS prediction]' \
        '--skip-sorf[skip sORF prediction]' \
        '--skip-gap[skip gap detection]' \
        '--skip-ori[skip oriC oriV oriT detection]' \
        '--skip-pseudo[skip pseudogene detection]' \
        '--skip-plot[skip output plots]' \
        '--threads=+[N]:n:' \
        '--tmp-dir=+[dir]:dir:_files -/' \
        '*:fasta file:_files -g "*.fa *.fasta *.fna *.fas *.gz"'
}

_bakta "$@"
