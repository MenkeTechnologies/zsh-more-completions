#compdef cosmic-settings
# _cosmic-settings — COSMIC desktop settings application (pop-os/cosmic-settings)
# upstream: https://github.com/pop-os/cosmic-settings
# Subcommands from cosmic-settings/src/main.rs (clap derive PageCommands).

_cosmic-settings() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                accessibility accessibility-magnifier about appearance applications
                bluetooth date-time default-apps desktop displays dock dock-applet
                input keyboard legacy-applications mouse network panel panel-applet
                power region-language sound startup-apps system time touchpad
                users vpn wallpaper window-management wired wireless workspaces
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                appearance) _arguments '1:subcommand:(import export)' ;;
            esac
            ;;
    esac
}

_cosmic-settings "$@"
