#compdef ringcli
# ============================================================================
# _ringcli — zsh completion for RingCLI, a Colmi R02 smart-ring BLE CLI
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/smittytone/RingCLI
#   Author     : Tony Smith (@smittytone)
#   License    : MIT
#   Stars      : 27
#   Language   : Go
#   Module     : ringcli  (Go 1.22.6)
#   Binary     : ringcli  (built from main.go)
#   Last push  : 2025-11-28
#
# WHAT IT IS
#   RingCLI is "CLI access to data stored on the Colmi R02 smart ring" — a
#   Go cobra-based command-line client for the Colmi R02 family of low-cost
#   fitness smart rings.  Connects to a Colmi ring over Bluetooth Low Energy
#   to read step / calorie / distance activity data, heart-rate and SpO2
#   (blood oxygen) readings, and sleep records, plus housekeeping operations:
#   scan for nearby rings, bind a ring address to a local store so the
#   --address flag can be omitted on future runs, find a specific ring
#   (continuous LED flash), inspect battery state and device info, enable
#   /disable periodic heart-rate readings with configurable period, set the
#   ring's internal clock to (re)initialise it, and shut the ring down.
#
# CLI ARGUMENT GRAMMAR  (verbatim from main.go + commands/{root,data,utils}.go
#                       cobra Command tree + commands/{data,utils}/shared.go
#                       Flags() declarations)
#   ringcli <command> [subcommand] [flags]
#
#   Commands:
#     data     Access ring activity (steps, calories, distance) and
#              health data (heart rate, SpO2, sleep records)
#       steps         Read step / activity data
#                       --address <BLE>     ring's BLE address
#       heartrate     Read heart-rate data
#                       --address <BLE>
#                       -r, --realtime      display readings in real time
#       spo2          Read blood-oxygen (SpO2) data
#                       --address <BLE>
#                       -f, --full          show full / detailed output
#       sleep         Read sleep records
#                       --address <BLE>
#                       -f, --full          show full sleep records
#
#     utils    Scan, bind, find rings; manage device-level operations
#       battery       Read battery state
#                       -a, --address <BLE>
#       bind          Save a ring address locally so --address can be
#                     omitted on future invocations
#                       -a, --address <BLE>
#                       -n, --name <NAME>   display name ("not set" default)
#                       -o, --overwrite     replace existing binding
#                       -s, --show          show existing binding
#       find          Flash the ring's LED to physically locate it
#                       --address <BLE>
#                       -c, --continuous    flash continuously until cancelled
#       heartrate     Configure periodic heart-rate readings
#                       -a, --address <BLE>
#                       -s, --show          display current settings
#                       -p, --period <SEC>  period in seconds (0-255) [60]
#                           --enable        enable periodic readings
#                           --disable       disable periodic readings
#       info          Print device info (model / firmware / etc.)
#                       -a, --address <BLE>
#       scan          Scan for nearby Colmi R02 rings
#                       -f, --first         stop on first ring found
#                           --all           show all BLE devices (debug)
#                       -b, --bind          auto-bind first discovered ring
#       shutdown      Shut the ring down
#                       -a, --address <BLE>
#       time          Set the ring's internal clock to the current time
#                       -a, --address <BLE>
#
# AXIS / CORPUS POSITION
#   Direct dependency on `tinygo.org/x/bluetooth v0.11.0` declared in go.mod
#   — the canonical Go cross-platform BLE library maintained by the TinyGo
#   project (supports Linux/BlueZ, macOS/CoreBluetooth, Windows/WinRT, and
#   bare-metal microcontrollers via embedded HCI).  RingCLI's `lib/ble`
#   package wraps the tinygo bluetooth API for scanning, peripheral
#   connection, and GATT characteristic read/write.  Verified via:
#     gh api repos/smittytone/RingCLI/contents/go.mod
#       → tinygo.org/x/bluetooth v0.11.0
#   This entry is the Go=117 leader bump that continues Axis 62
#   (Bluetooth Low Energy (BLE) Library) opened at R837 with
#   Rust=btleplug 0.11.5 (dmtrKovalenko/blendr).
#
#   No completion for `ringcli` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_ringcli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_ringcli_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                data)     _ringcli_data   && ret=0 ;;
                utils)    _ringcli_utils  && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ringcli_commands] )) ||
_ringcli_commands() {
    local -a commands
    commands=(
        'data:access ring activity (steps, calories, distance) + health data (heart rate, SpO2, sleep)'
        'utils:scan, bind, find rings; manage device-level operations'
    )
    _describe -t commands 'ringcli command' commands
}

(( $+functions[_ringcli_data] )) ||
_ringcli_data() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1: :_ringcli_data_commands' \
        '*::arg:->dargs' && ret=0

    case $state in
        dargs)
            case $words[1] in
                steps)
                    _arguments \
                        '--address=[ring BLE address]:BLE address:' \
                        '(- *)'{-h,--help}'[help for steps]'
                    ;;
                heartrate)
                    _arguments \
                        '--address=[ring BLE address]:BLE address:' \
                        '(-r --realtime)'{-r,--realtime}'[display heart rate readings in real time]' \
                        '(- *)'{-h,--help}'[help for heartrate]'
                    ;;
                spo2)
                    _arguments \
                        '--address=[ring BLE address]:BLE address:' \
                        '(-f --full)'{-f,--full}'[show full SpO2 records]' \
                        '(- *)'{-h,--help}'[help for spo2]'
                    ;;
                sleep)
                    _arguments \
                        '--address=[ring BLE address]:BLE address:' \
                        '(-f --full)'{-f,--full}'[show full sleep records]' \
                        '(- *)'{-h,--help}'[help for sleep]'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ringcli_data_commands] )) ||
_ringcli_data_commands() {
    local -a commands
    commands=(
        'steps:read step/activity data (steps, calories, distance)'
        'heartrate:read heart-rate data'
        'spo2:read blood-oxygen (SpO2) data'
        'sleep:read sleep records'
    )
    _describe -t commands 'ringcli data command' commands
}

(( $+functions[_ringcli_utils] )) ||
_ringcli_utils() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1: :_ringcli_utils_commands' \
        '*::arg:->uargs' && ret=0

    case $state in
        uargs)
            case $words[1] in
                battery)
                    _arguments \
                        '(-a --address)'{-a+,--address=}'[ring BLE address]:BLE address:' \
                        '(- *)'{-h,--help}'[help for battery]'
                    ;;
                bind)
                    _arguments \
                        '(-a --address)'{-a+,--address=}'[ring BLE address]:BLE address:' \
                        '(-n --name)'{-n+,--name=}'[ring display name (default "not set")]:name:' \
                        '(-o --overwrite)'{-o,--overwrite}'[replace existing binding if present]' \
                        '(-s --show)'{-s,--show}'[show existing binding if present]' \
                        '(- *)'{-h,--help}'[help for bind]'
                    ;;
                find)
                    _arguments \
                        '--address=[ring BLE address]:BLE address:' \
                        '(-c --continuous)'{-c,--continuous}'[flash the ring LED continuously until cancelled]' \
                        '(- *)'{-h,--help}'[help for find]'
                    ;;
                heartrate)
                    _arguments \
                        '(-a --address)'{-a+,--address=}'[ring BLE address]:BLE address:' \
                        '(-s --show)'{-s,--show}'[display current periodic heart-rate settings]' \
                        '(-p --period)'{-p+,--period=}'[heart-rate period in seconds (0-255, default 60)]:seconds:' \
                        '(--disable)--enable[enable periodic heart-rate readings]' \
                        '(--enable)--disable[disable periodic heart-rate readings]' \
                        '(- *)'{-h,--help}'[help for heartrate]'
                    ;;
                info)
                    _arguments \
                        '(-a --address)'{-a+,--address=}'[ring BLE address]:BLE address:' \
                        '(- *)'{-h,--help}'[help for info]'
                    ;;
                scan)
                    _arguments \
                        '(-f --first)'{-f,--first}'[stop scanning once first ring found]' \
                        '--all[show all BLE devices (debug)]' \
                        '(-b --bind)'{-b,--bind}'[automatically bind first discovered ring]' \
                        '(- *)'{-h,--help}'[help for scan]'
                    ;;
                shutdown)
                    _arguments \
                        '(-a --address)'{-a+,--address=}'[ring BLE address]:BLE address:' \
                        '(- *)'{-h,--help}'[help for shutdown]'
                    ;;
                time)
                    _arguments \
                        '(-a --address)'{-a+,--address=}'[ring BLE address]:BLE address:' \
                        '(- *)'{-h,--help}'[help for time]'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ringcli_utils_commands] )) ||
_ringcli_utils_commands() {
    local -a commands
    commands=(
        'battery:read battery state'
        'bind:save a ring address locally so --address can be omitted'
        'find:flash the ring LED to physically locate it'
        'heartrate:configure periodic heart-rate readings'
        'info:print device info (model, firmware, etc.)'
        'scan:scan for nearby Colmi R02 rings'
        'shutdown:shut the ring down'
        'time:set the ring internal clock to current time'
    )
    _describe -t commands 'ringcli utils command' commands
}

_ringcli "$@"
