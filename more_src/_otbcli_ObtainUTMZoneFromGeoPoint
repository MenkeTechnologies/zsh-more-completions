#compdef otbcli_ObtainUTMZoneFromGeoPoint
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ObtainUTMZoneFromGeoPoint.html
# Orfeo ToolBox: obtain the UTM zone of a geographic point

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-lat[latitude value of desired point]:value:' \
  '-lon[longitude value of desired point]:value:' \
  '-utm[output UTM zone]:value:' \
  '*::arg:_files' && ret=0

return ret
