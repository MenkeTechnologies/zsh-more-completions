#compdef synx
# Documentation: https://github.com/venmo/synx
# synx - reorganize an Xcode project folder to match the project structure

local ret=1

_arguments -s -S \
  '(-p --prune)'{-p,--prune}'[remove source/image files not referenced by the project]' \
  '--no-color[remove all color from output]' \
  '--no-default-exclusions[do not exclude /Libraries, /Frameworks and /Products]' \
  '--no-sort-by-name[disable sorting groups by name]' \
  '(-q --quiet)'{-q,--quiet}'[silence all output]' \
  '*'{-e,--exclusion}'+[ignore a specific Xcode group while syncing]:exclusion:' \
  '1:project:_files -g "*.xcodeproj"' && ret=0

return ret
