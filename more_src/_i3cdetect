#compdef i3cdetect
# _i3cdetect — i3c-tools i3cdetect CLI scanner enumerating I3C/MIPI I3C dynamic-address targets on a Linux /dev/i3c-* character device controller bus printing PID BCR DCR registered addresses static/dynamic LVR mode hot-join I3C 1.0/1.1 compatibility matrix (Boris Brezillon team, C); getopt
# upstream: https://github.com/i3c-tools/i3c-tools

_i3cdetect() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-y[disable interactive mode]' \
        '-v[verbose]' \
        '-l[list buses]' \
        '-r[detect read-only]' \
        '-q[quick read]' \
        '*:i3c-bus device:_files -g "/dev/i3c-*"'
}

_i3cdetect "$@"
