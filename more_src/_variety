#compdef variety
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/variety.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for variety - wallpaper changer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show program version and exit]' \
  '--profile=[profile name or full path to config folder]:profile:' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging (repeat for more)]' \
  '(-q --quit)'{-q,--quit}'[make the running instance quit]' \
  '--pause[pause on current image]' \
  '--resume[resume regular image changes]' \
  '--toggle-pause[toggle pause/resume state]' \
  '--get[print the current wallpaper location]' \
  '--get-wallpaper[print the current wallpaper location]' \
  '--current[print the current wallpaper location]' \
  '--set=[set the given file as wallpaper (absolute path)]:file:_files -g "*.{jpg,jpeg,png,bmp,svg,gif,webp}"' \
  '(-n --next)'{-n,--next}'[show next wallpaper]' \
  '(-p --previous)'{-p,--previous}'[show previous wallpaper]' \
  '--fast-forward[show next wallpaper skipping forward history]' \
  '(-t --trash)'{-t,--trash}'[move current wallpaper to trash]' \
  '(-f --favorite)'{-f,--favorite}'[copy current wallpaper to favorites]' \
  '--move-to-favorites[move current wallpaper to favorites]' \
  '--toggle-no-effects[toggle Show Without Effects for current image]' \
  '--quotes-next[show next quote]' \
  '--quotes-previous[show previous quote]' \
  '--quotes-fast-forward[show next quote, skipping forward history]' \
  '--quotes-toggle-pause[toggle quotes pause/resume]' \
  '--quotes-save-favorite[save current quote to favorites]' \
  '--history[toggle history display]' \
  '--downloads[toggle recent downloads display]' \
  '--preferences[show preferences dialog]' \
  '--selector[show manual wallpaper selector]' \
  '--set-option=[set and apply an option]:option:' && ret=0

return ret
