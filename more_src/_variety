#compdef variety

# Zsh completion for variety - wallpaper changer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--next[show next wallpaper]' \
  '--previous[show previous wallpaper]' \
  '--fast-forward[skip current wallpaper and show a new one]' \
  '--pause[pause automatic wallpaper changing]' \
  '--resume[resume automatic wallpaper changing]' \
  '--toggle-pause[toggle pause/resume]' \
  '--trash[move current wallpaper to trash]' \
  '--favorite[copy current wallpaper to favorites]' \
  '--move-to-favorites[move current wallpaper to favorites]' \
  '--quotes-next[show next quote]' \
  '--quotes-previous[show previous quote]' \
  '--quotes-fast-forward[skip current quote and show a new one]' \
  '--quotes-toggle-pause[toggle quotes pause/resume]' \
  '--history[display wallpaper history]' \
  '--downloads[open the downloads folder]' \
  '--preferences[open preferences dialog]' \
  '--selector[open wallpaper selector]' \
  '--set=[set a specific wallpaper]:file:_files -g "*.{jpg,jpeg,png,bmp,svg,gif,webp}"' \
  '--quit[quit variety]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' && ret=0

return ret
