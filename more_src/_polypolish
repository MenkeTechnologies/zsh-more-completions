#compdef polypolish
# Documentation: https://github.com/rrwick/Polypolish/wiki/How-to-run-Polypolish
# Polypolish: short-read polishing tool for long-read assemblies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*::command:->command' && ret=0

case $state in
  command)
    if (( CURRENT == 1 )); then
      _values 'polypolish subcommand' \
        'polish[polish an assembly with short-read alignments]' \
        'filter[exclude SAM alignments from ambiguous pairs]' && ret=0
    else
      case $words[1] in
        polish)
          _arguments -s -S \
            '--debug=[file to store per-base information]:file:_files' \
            '(-i --fraction_invalid)'{-i+,--fraction_invalid=}'[invalid base fraction threshold]:fraction' \
            '(-v --fraction_valid)'{-v+,--fraction_valid=}'[valid base fraction threshold]:fraction' \
            '(-m --max_errors)'{-m+,--max_errors=}'[ignore alignments exceeding mismatch count]:count' \
            '(-d --min_depth)'{-d+,--min_depth=}'[minimum read depth for validity]:depth' \
            '--careful[ignore reads with multiple alignments]' \
            '1:assembly:_files -g "*.(fa|fasta)"' \
            '*:sam:_files -g "*.sam"' && ret=0
          ;;
        filter)
          _arguments -s -S \
            '--in1=[input SAM file - first read in pairs]:file:_files -g "*.sam"' \
            '--in2=[input SAM file - second read in pairs]:file:_files -g "*.sam"' \
            '--out1=[output SAM file - first read in pairs]:file:_files' \
            '--out2=[output SAM file - second read in pairs]:file:_files' \
            '--orientation=[expected pair orientation]:orientation' \
            '--low=[low percentile threshold]:percentile' \
            '--high=[high percentile threshold]:percentile' && ret=0
          ;;
      esac
    fi
    ;;
esac

return ret
