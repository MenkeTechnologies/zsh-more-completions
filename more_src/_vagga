#compdef vagga

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-E,--env,--environ}'=[NAME=VALUE]:env:' \
  '*'{-e,--use-env}'=[propagate var]:var:' \
  '--no-build[do not rebuild]' \
  '--no-version-check[skip version check]' \
  '-m[multi-command mode]' \
  '--no-prerequisites[skip prerequisites]' \
  '--isolate-network[isolated network]' \
  '*:command:'
