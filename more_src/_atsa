#compdef atsa
# Documentation: https://csound.com/docs/manual/
# Csound ATS (Analysis-Transformation-Synthesis) spectral analysis

local ret=1

_arguments -s -S \
  '-b+[start time in seconds]:start' \
  '-e+[duration in seconds]:duration' \
  '-l+[lowest frequency in Hz]:lowest' \
  '-H+[highest frequency in Hz]:highest' \
  '-d+[frequency deviation ratio]:deviation' \
  '-c+[window cycles]:cycles' \
  '-w+[window type]:type:(0 1 2 3)' \
  '-h+[hop size ratio]:hop' \
  '-m+[lowest magnitude in dB]:magnitude' \
  '-t+[track length in frames]:tracklen' \
  '-s+[minimum segment length in frames]:seglen' \
  '-g+[minimum gap length in frames]:gaplen' \
  '-T+[SMR threshold in dB SPL]:smrthresh' \
  '-S+[minimum segment SMR in dB SPL]:segsmr' \
  '-P+[last peak contribution]:peak' \
  '-M+[SMR contribution]:smr' \
  '-F+[file type]:type:(1 2 3 4)' \
  '*:soundfile:_files' && ret=0

return ret
