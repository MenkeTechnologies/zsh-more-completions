#compdef llm-cmd-comp
# Documentation: https://github.com/CGamesPlay/llm-cmd-comp
# Shell completion using LLM - complete the command on your command line

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '--init=[generate shell integration code]:shell:(fish zsh bash)' \
  '*:prompt:' && ret=0

return ret
