#compdef xcversion xcode-install
# _xcversion — Xcode version manager (Ruby); install + select Xcode versions, symbolicate dSYMs, manage simulators
# upstream: https://github.com/xcpretty/xcode-install

_xcversion() {
    local -a sub=(
        'install:install a specific Xcode version'
        'installed:list installed versions'
        'list:list available versions'
        'select:select active Xcode'
        'selected:show selected Xcode'
        'uninstall:uninstall a version'
        'update:refresh known versions list'
        'cleanup:remove cached .xip downloads'
        'simulators:manage simulator runtimes'
        'symbolicate:symbolicate a crash'
        'version:show xcversion version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xcversion subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall|select) _arguments '1:Xcode version:' ;;
                simulators) _arguments \
                    '--install=+[install runtime]:name:' \
                    '--remove=+[remove runtime]:name:' ;;
                symbolicate) _arguments '*:crash log:_files' ;;
            esac
            ;;
    esac
}

_xcversion "$@"
