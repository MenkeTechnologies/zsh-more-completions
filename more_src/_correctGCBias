#compdef correctGCBias
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/correctGCBias.html
# deepTools: correct GC bias in a BAM file using computeGCBias frequencies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bamfile)'{-b,--bamfile}'[sorted BAM file to correct]:bam:_files -g "*.bam"' \
  '--effectiveGenomeSize[mappable genome size]:size:' \
  '(-g --genome)'{-g,--genome}'[genome in 2bit format]:file:_files -g "*.2bit"' \
  '(-freq --GCbiasFrequenciesFile)'{-freq,--GCbiasFrequenciesFile}'[frequencies file from computeGCBias]:file:_files' \
  '(-o --correctedFile)'{-o,--correctedFile}'[output file (.bam/.bw/.bg)]:file:_files' \
  '--version[show version]' \
  '(-bs --binSize)'{-bs,--binSize}'[bin size in bases for bigWig/bedGraph output]:size:' \
  '(-r --region)'{-r,--region}'[genomic region to process]:region:' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' && ret=0

return ret
