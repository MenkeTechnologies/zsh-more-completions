#compdef frog
# Documentation: https://github.com/greghendershott/frog
# Frog Racket static blog generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--init[create a new project]' \
  '--doc[open the documentation]' \
  '(-n --new --new-markdown)'{-n,--new,--new-markdown}'=[create a new markdown post]:title:' \
  '(-N --new-scribble)'{-N,--new-scribble}'=[create a new scribble post]:title:' \
  '--edit=[edit a post]:title:' \
  '(-b --build)'{-b,--build}'[build the site]' \
  '(-c --clean)'{-c,--clean}'[delete generated files]' \
  '(-w --watch)'{-w,--watch}'[watch and rebuild]' \
  '(-s --serve)'{-s,--serve}'[start a web server]' \
  '(-p --preview)'{-p,--preview}'[build, serve and open a browser]' \
  '--port=[server port]:port:' \
  '--root=[project root]:dir:_files -/' \
  '(-S --silent)'{-S,--silent}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-V --very-verbose)'{-V,--very-verbose}'[very verbose output]' \
  '*::arg:_files' && ret=0

return ret
