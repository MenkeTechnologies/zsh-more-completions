#compdef bibclean

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-align-equals[align equals signs in entries]' \
  '-check-values[check for valid field values]' \
  '-error-log+[set error log file]:file:_files' \
  '-init-file+[read initialization file]:file:_files' \
  '-max-width+[set maximum output width]:width' \
  '-no-check-values[do not check field values]' \
  '-no-delete-empty-values[keep empty field values]' \
  '-no-fix-font-changes[do not fix font changes]' \
  '-no-fix-initials[do not fix author initials]' \
  '-no-fix-names[do not fix author names]' \
  '-no-prettyprint[do not pretty-print output]' \
  '-output-file+[set output file]:file:_files' \
  '-prettyprint[pretty-print output]' \
  '-remove-OPT-prefixes[remove OPT prefixes from field names]' \
  '-scribe[convert from Scribe format]' \
  '*:BibTeX file:_files -g "*.bib"' && ret=0

return ret
