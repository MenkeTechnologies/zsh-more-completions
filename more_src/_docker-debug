#compdef docker-debug
# Documentation: https://github.com/zeromake/docker-debug/blob/master/internal/command/root.go
# docker-debug: attach a new debug container into a running container's namespaces

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --volume)'{-v,--volume}'[attach a filesystem mount to the container]:mount' \
  '(-i --image)'{-i,--image}'[debug image to use]:image' \
  '(-n --name)'{-n,--name}'[docker config name reference]:name' \
  '(-H --host)'{-H,--host}'[docker daemon host (tcp://host:port)]:host' \
  '(-c --cert-dir)'{-c,--cert-dir}'[certificate directory for TLS]:dir:_files -/' \
  '(-d --detach-keys)'{-d,--detach-keys}'[override detach key sequence]:keys' \
  '(-u --user)'{-u,--user}'[username or UID (<name|uid>[:<group|gid>])]:user' \
  '(-p --privileged)'{-p,--privileged}'[give extended privileges to the command]' \
  '(-w --work-dir)'{-w,--work-dir}'[working directory inside the container]:dir' \
  '(-t --target-dir)'{-t,--target-dir}'[target working directory]:dir' \
  '(-s --security-opts)'{-s,--security-opts}'[add security options to the container]:opt' \
  '(-C --cap-adds)'{-C,--cap-adds}'[add Linux capabilities to the container]:cap' \
  '--ipc[share target container IPC namespace]' \
  '1:command:_values command info' \
  '*::args:_normal' && ret=0

return ret
