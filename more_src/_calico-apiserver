#compdef calico-apiserver
# _calico-apiserver — Calico aggregated API server for projectcalico.org (projectcalico/calico)
# upstream: https://github.com/projectcalico/calico
# Flags from apiserver/cmd/apiserver/server/{server,options}.go on tip.

_calico-apiserver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--print-swagger[print OpenAPI spec and exit]' \
        '--swagger-file-path=[directory to write the swagger file to]:dir:_files -/' \
        '--enable-validating-admission-policy=[enable ValidatingAdmissionPolicy support]:bool:(true false)' \
        '--secure-port=[HTTPS bind port]:port:' \
        '--bind-address=[HTTPS bind address]:ip:' \
        '--tls-cert-file=[TLS server certificate]:file:_files' \
        '--tls-private-key-file=[TLS server private key]:file:_files' \
        '--client-ca-file=[client-cert CA bundle]:file:_files' \
        '--authentication-kubeconfig=[apiserver-to-extension kubeconfig]:file:_files' \
        '--authorization-kubeconfig=[delegated authorization kubeconfig]:file:_files' \
        '--kubeconfig=[kubeconfig for the watched cluster]:file:_files' \
        '--audit-log-path=[audit log file path]:file:_files' \
        '--audit-policy-file=[audit policy YAML file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_calico-apiserver "$@"
