#compdef cargo-sort-derives
# Documentation: https://github.com/lusingander/cargo-sort-derives
# Cargo subcommand to sort derive attributes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --path)'{-p,--path}'=[file to sort]:file:_files -g "*.rs"' \
  '--order=[custom derive attribute order, comma-separated]:order' \
  '--preserve[keep original order for unspecified attributes]' \
  '--check[verify sorted without modifying files]' \
  '--stdin[read from stdin, write to stdout]' \
  '--color=[control colored output]:type:(auto always never)' \
  '--config=[load configuration from file]:file:_files' && ret=0

return ret
