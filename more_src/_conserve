#compdef conserve
# _conserve — Rust file-tree backup tool (sourcefrog/conserve)
# upstream: https://github.com/sourcefrog/conserve
# Subcommands + flags from src/bin/conserve.rs (clap).

_conserve() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-P --no-progress)'{-P,--no-progress}'[disable progress bars]' \
        '(-D --debug)'{-D,--debug}'[show debug trace to stdout]' \
        '--trace-tmp[write a detailed trace to a tmp file]' \
        '--trace-time=[timestamp style on stderr]:style:(none seconds millis micros nanos relative)' \
        '--log-json=[append a JSON log to this file]:file:_files' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_conserve_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                backup)
                    _arguments \
                        '--changes-json=[write change list as JSON to this file]:file:_files' \
                        '(-v --verbose)'{-v,--verbose}'[print copied file names]' \
                        '*'{-e+,--exclude=}'[exclude glob]:glob:' \
                        '*'{-E+,--exclude-from=}'[read excludes from file]:file:_files' \
                        '--no-stats[do not print statistics]' \
                        '(-l --long-listing)'{-l,--long-listing}'[show owner/perms/group]' \
                        '1:archive:_files -/' \
                        '2:source dir:_files -/'
                    ;;
                debug)
                    _arguments '1:debug subcommand:(index blocks referenced unreferenced)'
                    ;;
                restore|ls|size|validate|versions|gc|init|diff|delete|mount)
                    _arguments '1:archive:_files -/'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_conserve_commands] )) ||
_conserve_commands() {
    local -a commands
    commands=(
        'backup:copy a source directory into an archive'
        'restore:restore files from an archive'
        'ls:list contents of an archive'
        'versions:list backup versions in an archive'
        'diff:diff a backup against a source tree'
        'init:create a new empty archive'
        'gc:garbage-collect unreferenced blocks'
        'delete:delete a band/version from an archive'
        'mount:mount an archive via FUSE (read-only)'
        'size:print archive size'
        'validate:validate archive consistency'
        'debug:debug subcommands (index / blocks / referenced / unreferenced)'
    )
    _describe -t commands 'conserve command' commands
}

_conserve "$@"
