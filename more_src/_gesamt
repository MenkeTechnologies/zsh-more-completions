#compdef gesamt
# CCP4: general efficient structural alignment of macromolecules

local ret=1

_arguments -s -S \
  '-s+[select substructure (MMDB selection format)]:selection:' \
  '-d+[select substructure (SCOP selection scheme)]:selection:' \
  '-high[high-quality alignment mode (slower)]' \
  '-normal[normal alignment mode (default)]' \
  '-o+[output PDB file for transformed structure]:output:_files' \
  '-pdb+[directory of PDB files to screen]:directory:_files -/' \
  '-help[show usage]' \
  '*:structure:_files -g "*.(pdb|cif|ent|brk)"' && ret=0

return ret
