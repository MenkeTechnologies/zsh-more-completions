#compdef magic
# Documentation: https://man.archlinux.org/search?q=magic
# Reference accessed: 2026-05-16

# Magic: VLSI layout editor with built-in design-rule checker
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-dnull[disable GUI display]' \
  '-d[display type]:dtype:(NULL OGL X11 XR)' \
  '-T[technology file name]:tech:' \
  '-rcfile[magic rcfile]:file:_files' \
  '-noconsole[no console window]' \
  '-wrapper[Tcl/Tk wrapper mode]' \
  '-nowrapper[do not use Tk wrapper]' \
  '-w[no Tk wrapper]' \
  '-i[interactive Tcl shell]' \
  '-m[mode]:mode:' \
  '*:Magic layout (.mag) or script file:_files -g "*.(mag|gz|tcl)"' && ret=0
return ret
