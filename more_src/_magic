#compdef magic
# Documentation: http://opencircuitdesign.com/magic/manpages/magic_manpage.html
# Reference accessed: 2026-05-19
# Verified: upstream source utils/main.c in RTimothyEdwards/magic on GitHub.

# Magic: VLSI layout editor with built-in design-rule checker
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[display type]:dtype:(NULL X11 XWIND OGL 24BITS)' \
  '-g[graphics tty port]:tty' \
  '-i[mouse/tablet tty port]:tty' \
  '-m[monitor type]:monitor' \
  '-T[technology file name]:tech' \
  '-rcfile[startup .magicrc file]:file:_files' \
  '-recover[recover from crash file]' \
  '-norcfile[skip startup .magicrc file]' \
  '-noconsole[no Tk console window]' \
  '-nowindow[no initial layout window]' \
  '-wrapper[use Tcl/Tk wrapper mode]' \
  '-w[wrapper mode (implies -nowindow)]' \
  '-D[enable debugging]' \
  '*:Magic layout (.mag) or script file:_files -g "*.(mag|gz|tcl)"' && ret=0
return ret
