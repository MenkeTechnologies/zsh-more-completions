#compdef pdbcur
# Documentation: https://www.ccp4.ac.uk/html/pdbcur.html
# CCP4: analyse and manipulate the contents of a PDB coordinate file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZOUT[output coordinate file]:output:_files' \
  '*:file:_files -g "*.(pdb|cif|ent|brk)"' && ret=0

return ret
