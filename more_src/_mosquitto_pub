#compdef mosquitto_pub
# Documentation: https://mosquitto.org/man/mosquitto_pub-1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mosquitto_pub - MQTT publish client.
_arguments -s -S \
  '(- *)--help[show help]' \
  '(-h --host)'{-h+,--host=}'[MQTT broker host]:host:_hosts' \
  '--unix=[broker UNIX socket path]:socket:_files' \
  '(-p --port)'{-p+,--port=}'[MQTT broker port]:port' \
  '(-L --url)'{-L+,--url=}'[mqtt(s)://user:pw@host:port/topic URL]:url' \
  '-A+[bind to a specific source IP]:address' \
  '--nodelay[disable TCP Nagle algorithm]' \
  '-S[use SRV lookups to determine which host to connect to]' \
  '--ws[use MQTT over WebSockets]' \
  '--proxy=[SOCKS5 proxy URL]:proxy' \
  '(-t --topic)'{-t+,--topic=}'[MQTT topic to publish to]:topic' \
  '(-m --message)'{-m+,--message=}'[message payload]:message' \
  '(-f --file)'{-f+,--file=}'[send contents of file as message]:file:_files' \
  '(-l --stdin-line)'{-l,--stdin-line}'[send stdin as messages, one per line]' \
  '(-s --stdin-file)'{-s,--stdin-file}'[send entire stdin as a single message]' \
  '(-n --null-message)'{-n,--null-message}'[send a zero-length message]' \
  '(-q --qos)'{-q+,--qos=}'[quality of service level]:qos:(0 1 2)' \
  '(-r --retain)'{-r,--retain}'[mark message as retained]' \
  '--repeat=[number of times to repeat publishing]:count' \
  '--repeat-delay=[delay between repeated publishes (seconds)]:seconds' \
  '(-c --disable-clean-session)'{-c,--disable-clean-session}'[disable clean session]' \
  '*'{-D+,--property=}'[set an MQTT v5 property]:property' \
  '(-i --id)'{-i+,--id=}'[client ID]:client id' \
  '(-I --id-prefix)'{-I+,--id-prefix=}'[client ID prefix]:prefix' \
  '(-k --keepalive)'{-k+,--keepalive=}'[keepalive interval in seconds]:seconds' \
  '-x+[session expiry interval (v5)]:seconds' \
  '(-V --protocol-version)'{-V+,--protocol-version=}'[MQTT protocol version]:version:(mqttv31 mqttv311 mqttv5)' \
  '--will-topic=[will topic]:topic' \
  '--will-payload=[will message payload]:payload' \
  '--will-qos=[will QoS level]:qos:(0 1 2)' \
  '--will-retain[mark the will as a retained message]' \
  '(-u --username)'{-u+,--username=}'[username]:username:_users' \
  '(-P --pw)'{-P+,--pw=}'[password]:password' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '--quiet[do not print error messages]' \
  '-o+[parse extra options from named source]:source' \
  '--no-tls[disable TLS even if CA is provided]' \
  '--cafile=[CA certificate file]:file:_files' \
  '--capath=[CA certificates directory]:dir:_directories' \
  '--tls-use-os-certs[use OS-provided CA certificates]' \
  '--cert=[client certificate file]:file:_files' \
  '--key=[client private key file]:file:_files' \
  '--ciphers=[OpenSSL cipher list]:ciphers' \
  '--insecure[do not check server certificate hostname]' \
  '--tls-alpn=[TLS ALPN protocol name]:name' \
  '--tls-keylog=[TLS key log file]:file:_files' \
  '--tls-version=[TLS protocol version]:version:(tlsv1.2 tlsv1.3)' \
  '--tls-engine=[OpenSSL engine ID]:engine' \
  '--keyform=[private key file format]:format:(pem engine)' \
  '--tls-engine-kpass-sha1=[passphrase SHA1 for TLS engine key]:hash' \
  '--psk=[pre-shared key for PSK mode]:key' \
  '--psk-identity=[PSK identity]:identity'
