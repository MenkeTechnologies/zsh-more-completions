#compdef mosquitto_pub

# Zsh completion for mosquitto_pub - MQTT publish client

_arguments -s -S \
  '(-h --host)'{-h,--host}'[MQTT broker host]:host:_hosts' \
  '(-p --port)'{-p,--port}'[MQTT broker port]:port:' \
  '(-t --topic)'{-t,--topic}'[MQTT topic to publish to]:topic:' \
  '(-m --message)'{-m,--message}'[Message payload]:message:' \
  '(-f --file)'{-f,--file}'[Send contents of file as message]:file:_files' \
  '--stdin-line[Send stdin as messages, one per line]' \
  '--stdin-file[Send entire stdin as a single message]' \
  '(-n --null-message)'{-n,--null-message}'[Send a null (zero length) message]' \
  '(-q --qos)'{-q,--qos}'[Quality of service level]:qos:(0 1 2)' \
  '(-r --retain)'{-r,--retain}'[Mark message as retained]' \
  '(-i --id)'{-i,--id}'[Client ID]:client id:' \
  '(-I --id-prefix)'{-I,--id-prefix}'[Client ID prefix]:prefix:' \
  '(-k --keepalive)'{-k,--keepalive}'[Keepalive interval in seconds]:seconds:' \
  '(-u --username)'{-u,--username}'[Username]:username:' \
  '(-P --pw)'{-P,--pw}'[Password]:password:' \
  '--will-topic[Will topic]:topic:' \
  '--will-payload[Will message]:payload:' \
  '--will-qos[Will QoS level]:qos:(0 1 2)' \
  '--will-retain[Make the will a retained message]' \
  '--cafile[Path to CA certificate file]:file:_files' \
  '--capath[Path to directory with CA certificates]:directory:_directories' \
  '--cert[Path to client certificate file]:file:_files' \
  '--key[Path to client private key file]:file:_files' \
  '--insecure[Do not check that server certificate matches hostname]' \
  '--tls-version[TLS protocol version]:version:(tlsv1 tlsv1.1 tlsv1.2)' \
  '--repeat[Number of times to repeat publishing]:count:' \
  '--repeat-delay[Delay between repeated publishes]:seconds:' \
  '(-d --debug)'{-d,--debug}'[Enable debug messages]' \
  '--quiet[Do not print error messages]' \
  '(-v --verbose)'{-v,--verbose}'[Verbose output]' \
  '(-V --version)'{-V,--version}'[Print version]' \
  '(- *)--help[Show help]'
