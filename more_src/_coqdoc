#compdef coqdoc

_arguments -s \
  '--HTML[HTML output]' \
  '--LaTeX[LaTeX output]' \
  '--dvi[DVI output]' \
  '--ps[PostScript output]' \
  '--texmacs[TeXmacs output]' \
  '--stdout[write to stdout]' \
  '(-o --output)'{-o,--output=}'[output file]:file:_files' \
  '(-d --directory)'{-d,--directory=}'[output directory]:dir:_files -/' \
  '--body-only[omit header/footer]' \
  '(-p --preamble)'{-p,--preamble=}'[LaTeX preamble]:str:' \
  '*--vernac-file=[Coq source]:file:_files -g "*.v"' \
  '*--tex-file=[LaTeX file]:file:_files -g "*.tex"' \
  '--files-from=[filenames file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--no-index[no index]' \
  '--binder-index[binder index]' \
  '--multi-index[multi-page index]' \
  '--index=[index name]:str:' \
  '(-toc --table-of-contents)'{-toc,--table-of-contents}'[generate TOC]' \
  '--toc-depth=[TOC depth]:n:' \
  '*--glob-from=[glob file]:file:_files' \
  '--no-externals[no external links]' \
  '*--external=[external mapping]:url\:coqdir:' \
  '--coqlib_url=[coqlib URL]:url:' \
  '*-R[map physical to logical (recursive)]:dir:_files -/' \
  '*-Q[map physical to logical (non-recursive)]:dir:_files -/' \
  '(-s --short)'{-s,--short}'[short title]' \
  '--lib-name=[library name]:str:' \
  '--no-lib-name[no library name]' \
  '--lib-subtitles[library subtitles]' \
  '(-t --title)'{-t,--title=}'[title]:str:' \
  '(-g --gallina)'{-g,--gallina}'[gallina mode]' \
  '(-l --light)'{-l,--light}'[light mode]' \
  '--parse-comments[parse comments]' \
  '--plain-comments[plain comments]' \
  '--interpolate[interpolate identifiers]' \
  '--latin1[latin1 encoding]' \
  '--utf8[UTF-8 encoding]' \
  '--inputenc=[input encoding]:enc:' \
  '--charset=[charset]:charset:' \
  '*:source:_files -g "*.v"'
