#compdef nsys
# Documentation: https://man.archlinux.org/search?q=nsys
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'profile:start a profiling session'
      'launch:launch an application for later profiling'
      'start:start a profiling session'
      'stop:stop a profiling session'
      'cancel:cancel a profiling session'
      'stats:generate statistics from a report'
      'status:show profiling session status'
      'export:export a report to another format'
      'analyze:analyze a report'
      'sessions:list active sessions'
      'shutdown:shut down all sessions'
      'recipe:run a profiling recipe'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      profile)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-t,--trace}'[APIs to trace]:api:_values -s , api cuda nvtx osrt cublas cudnn opengl openacc openmp mpi ucx' \
          {-o,--output}'[output file]:file:_files' \
          {-w,--show-output}'[show application output]:bool:(true false)' \
          '--stats[generate summary statistics]:bool:(true false)' \
          '--force-overwrite[overwrite existing output]:bool:(true false)' \
          {-d,--duration}'[collection duration in seconds]:seconds' \
          '--sample[CPU sampling]:mode:(cpu none)' \
          '--cpuctxsw[CPU context switch tracing]:mode:(none process-tree system-wide)' \
          '--gpu-metrics-device[GPU metrics device]:device' \
          {-y,--delay}'[collection start delay in seconds]:seconds' \
          '--kill[signal to send on timeout]:signal' \
          '--session-new[create a new named session]:name' \
          '*:command:_files' && ret=0
        ;;
      launch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-t,--trace}'[APIs to trace]:api:_values -s , api cuda nvtx osrt cublas cudnn opengl openacc openmp mpi ucx' \
          '--session-new[create a new named session]:name' \
          '*:command:_files' && ret=0
        ;;
      start)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--session[session name]:name' && ret=0
        ;;
      stop|cancel)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--session[session name]:name' && ret=0
        ;;
      stats)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':report file:_files' && ret=0
        ;;
      status)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      export)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output}'[output file]:file:_files' \
          ':report file:_files' && ret=0
        ;;
      analyze)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':report file:_files' && ret=0
        ;;
      sessions)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      shutdown)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      recipe)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:recipe' && ret=0
        ;;
    esac
    ;;
esac

return ret
