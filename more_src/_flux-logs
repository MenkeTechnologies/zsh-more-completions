#compdef flux-logs
# Documentation: https://fluxcd.io/flux/cmd/flux_logs/
# FluxCD logs: view Flux controller logs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[display logs across all namespaces]' \
  '--flux-namespace=[the namespace where the Flux components are running]:namespace:' \
  '(-f --follow)'{-f,--follow}'[stream logs in real-time]' \
  '--kind=[filter by toolkit kind, e.g. GitRepository]:kind:' \
  '--level=[log level (debug, info, error)]:level:(debug info error)' \
  '--name=[show logs for a specific resource by name]:name:' \
  '--since=[show logs newer than a relative duration like 5s, 2m, 3h]:duration:' \
  '--since-time=[show logs after a specific RFC3339 date]:time:' \
  '--tail=[lines of recent log to display]:lines:' \
  '--context=[kubeconfig context to use]:context:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--timeout=[timeout for this operation]:duration:' \
  '--verbose[print generated objects]' && ret=0

return ret
