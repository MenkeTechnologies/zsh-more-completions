#compdef propmapped flattenGTF removeDup repair
# Documentation: upstream Subread package man pages at
# manpages.debian.org/bookworm/subread/{propmapped,flattenGTF,
# removeDup,repair}.1.en.html
# Reference accessed: 2026-05-30 via WebFetch.
# Subread utility helpers R103 — 4-stem multi-binary harvest
# completing the R102 deferral on small Subread auxiliary binaries.
# Sister tools to the R102-covered aligners (subread-align/subjunc/
# subread-buildindex/exactSNP/sublong) and the existing _featureCounts.

case $service in

  propmapped)
    # Calculate the proportion of mapped reads/fragments in a
    # SAM/BAM file.
    _arguments -s -S \
      '-i+[input SAM/BAM file (required)]:file:_files -g "*.(sam|bam)"' \
      '-o+[output statistics file]:file:_files' \
      '-f[count fragments (read pairs) instead of reads (paired-end only)]' \
      '-p[only count properly paired reads (paired-end only)]'
    ;;

  flattenGTF)
    # Flatten an annotation by merging overlapping exons of the
    # same gene into a non-overlapping set.
    _arguments -s -S \
      '-a+[input annotation file (GTF/GFF) - required]:file:_files -g "*.(gtf|gff|gff3)"' \
      '-o+[output flattened annotation file - required]:file:_files' \
      '-t+[feature type to extract (default exon)]:type:' \
      '-g+[attribute to group features by (default gene_id)]:attr:' \
      '-C[merge overlapping exons into multiple non-overlapping exons but keep all edges]'
    ;;

  removeDup)
    # Remove duplicate alignments by location-frequency threshold.
    _arguments -s -S \
      '-i+[input SAM/BAM file (required)]:file:_files -g "*.(sam|bam)"' \
      '-o+[output file (BAM unless -S)]:file:_files' \
      '-S[output in SAM format]' \
      '-r+[duplication threshold (default 10; locations with >= N hits removed)]:N:' \
      '-t+[temporary directory]:dir:_directories'
    ;;

  repair)
    # Pair-up reads from the same pair so they are adjacent in the
    # output (BAM/SAM). Inserts dummy reads for singletons unless -d.
    _arguments -s -S \
      '-i+[input file (BAM default, or SAM with -S) - required]:file:_files -g "*.(sam|bam)"' \
      '-o+[output BAM file - required]:file:_files' \
      '-S[input is in SAM format]' \
      '-c[compress output BAM (slower read access)]' \
      '-T+[number of CPU threads (default 8)]:N:' \
      "-d[don't add dummy reads for singletons]" \
      '-t[omit sequences and quality scores from output]'
    ;;

esac
