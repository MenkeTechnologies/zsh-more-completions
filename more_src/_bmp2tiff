#compdef bmp2tiff
# Documentation: http://www.libtiff.org/tools.html
# Source: libtiff tools/bmp2tiff.c — convert Windows BMP file to TIFF (C, getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r+[rows per strip]:rows:_default' \
    '-c+[output compression]:comp:(lzw zip jpeg packbits none)' \
    '*:files (one or more inputs + output tif):_files -g "*.{bmp,BMP,tif,tiff,TIF,TIFF}"' \
    && ret=0

return ret
