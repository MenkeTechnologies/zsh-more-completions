#compdef admb
# Documentation: https://github.com/admb-project/admb/blob/main/scripts/admb/admb
# admb - build AD Model Builder applications from .tpl template files

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[display help text]' \
  '-c[compile only object files, skip linking]' \
  '-d[build a shared library]' \
  '-f[build with fast optimized mode, no bounds checking]' \
  '-g[compile with debug symbols]' \
  '-o[specify custom output filename]:output:' \
  '-p[build portable executable with static linking]' \
  '-r[build with random effects library (ADMB-RE)]' \
  '-s[recognized but no action taken]' \
  '1:model template:_files -g "*.tpl"' \
  '*:source:_files -g "*.(c|cpp|cxx)"' && ret=0

return ret
