#compdef GermlineCNVCaller
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/GermlineCNVCaller.java
# Calls copy-number variants in germline samples given their counts and

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--input -I)'{--input,-I}'[Input paths for read-count files containing integer read counts in genomic intervals fo...]:value:_files' \
  '--run-mode=[Tool run-mode.]:value:' \
  '--contig-ploidy-calls=[Input contig-ploidy calls directory (output of DetermineGermlineContigPloidy).]:value:' \
  '--model=[Input denoising-model directory. In COHORT mode, this argument is optional; if provided,]:value:_files' \
  '--annotated-intervals=[Input annotated-intervals file containing annotations for GC content in genomic intervals]:value:_files' \
  '--output-prefix=[Prefix for output filenames.]:value:_files' \
  '(--output -O)'{--output,-O}'[Output directory. This will be created if it does not exist.]:value:_files' \
  '*:argument:_files' && ret=0

return ret
