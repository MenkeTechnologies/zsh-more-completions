#compdef veilid-server

# Zsh completion for Veilid P2P server node

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--set-assign[config assignment KEY=VALUE]:pair' \
  '--dump-config[emit effective YAML configuration]' \
  '*::args:{ _message "see veilid-server --help" }' && ret=0

return ret
