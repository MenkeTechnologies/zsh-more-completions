#compdef ocp-indent

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--config[configuration string]:config:' \
  '--syntax[syntax extension to use]:syntax:(lwt js)' \
  '--indent-empty[indent empty lines]' \
  '--lines[only indent specified line range]:range:' \
  '--numeric[output numeric indentation values]' \
  '(-o --output)'{-o,--output}'[output to file]:output file:_files' \
  '--debug[enable debug output]' \
  '*:file:_files' && ret=0

return ret
