#compdef llvm-extract
# _llvm-extract — LLVM module extractor (LLVM project, C++); extract globals/functions from LLVM bitcode
# upstream: https://github.com/llvm/llvm-project

_llvm-extract() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-f[force overwrite]' \
        '-o+[output file]:file:_files' \
        '-S[output LLVM IR]' \
        '--alias=+[extract alias]:name:' \
        '--ralias=+[extract alias regex]:regex:' \
        '--bb=+[extract basic block]:func:bb:' \
        '--func=+[extract function]:name:' \
        '--rfunc=+[extract function regex]:regex:' \
        '--glob=+[extract global]:name:' \
        '--rglob=+[extract global regex]:regex:' \
        '--keep-const-init[keep const init]' \
        '--delete[delete instead of extract]' \
        '--recursive[recursive]' \
        '*:file:_files -g "*.(bc|ll)"'
}

_llvm-extract "$@"
