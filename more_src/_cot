#compdef cot
# Documentation: https://github.com/cot-rs/cot
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cot-rs/cot - Rust web framework CLI (cot-cli).
# Subcommands per cot-cli/src/args.rs: new, migration {list,make,new}, cli {manpages,completions}.

local curcontext="$curcontext" state line ret=1
_arguments -s -S -C \
  {-q}'[reduce log verbosity]' \
  '*'{-v,--verbose}'[increase log verbosity]' \
  '1:subcommand:->cmd' \
  '*::args: _normal' && ret=0

case $state in
  cmd)
    local -a verbs
    verbs=( new migration cli )
    _describe -t commands 'cot' verbs && ret=0
    ;;
esac

return ret
