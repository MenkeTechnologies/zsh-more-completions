#compdef skeema

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'init:populate a directory with table definitions from a database'
      'diff:show differences between filesystem and database'
      'push:alter a database to match filesystem definitions'
      'pull:update filesystem definitions to match database'
      'lint:check filesystem definitions for problems'
      'format:reformat CREATE TABLE statements'
      'cloud:interact with Skeema Cloud'
      'help:show help for a command'
      'version:show version information'
    )
    _describe -t commands 'skeema command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments -s -S \
          '(-h --host)'{-h,--host}'=[database host]:host' \
          '(-P --port)'{-P,--port}'=[database port]:port' \
          '(-u --user)'{-u,--user}'=[database user]:user' \
          '(-p --password)'{-p,--password}'=[database password]:password' \
          '--socket=[Unix socket path]:socket:_files' \
          '(-s --schema)'{-s,--schema}'=[schema/database name]:schema' \
          '(-d --dir)'{-d,--dir}'=[target directory]:directory:_directories' \
          '--include-auto-inc[include AUTO_INCREMENT values]' \
          '--strip-definer[remove DEFINER clause from routines]' && ret=0
        ;;
      (diff|push)
        _arguments -s -S \
          '(-h --host)'{-h,--host}'=[database host]:host' \
          '(-P --port)'{-P,--port}'=[database port]:port' \
          '(-u --user)'{-u,--user}'=[database user]:user' \
          '(-p --password)'{-p,--password}'=[database password]:password' \
          '--socket=[Unix socket path]:socket:_files' \
          '--alter-algorithm=[algorithm for ALTER TABLE]:algorithm:(INPLACE COPY INSTANT DEFAULT)' \
          '--alter-lock=[locking for ALTER TABLE]:lock:(NONE SHARED EXCLUSIVE DEFAULT)' \
          '--safe-below-size=[skip tables below this size]:size' \
          '--allow-unsafe[allow unsafe operations]' \
          '--dry-run[show what would be done without doing it]' \
          '--brief[only show table names with differences]' \
          '--strip-definer[remove DEFINER clause]' \
          '--first-only[only process first dir]' \
          '1:directory:_directories' && ret=0
        ;;
      (pull)
        _arguments -s -S \
          '(-h --host)'{-h,--host}'=[database host]:host' \
          '(-P --port)'{-P,--port}'=[database port]:port' \
          '(-u --user)'{-u,--user}'=[database user]:user' \
          '(-p --password)'{-p,--password}'=[database password]:password' \
          '--socket=[Unix socket path]:socket:_files' \
          '--include-auto-inc[include AUTO_INCREMENT values]' \
          '--strip-definer[remove DEFINER clause]' \
          '--normalize[reformat to canonical style]' \
          '1:directory:_directories' && ret=0
        ;;
      (lint|format)
        _arguments -s -S \
          '--strip-definer[remove DEFINER clause]' \
          '1:directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
