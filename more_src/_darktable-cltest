#compdef darktable-cltest
# Documentation: https://man.archlinux.org/search?q=darktable-cltest
# Reference accessed: 2026-05-16

# darktable-cltest: tests OpenCL setup and prints capabilities to stderr
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help and exit]' \
  '(- *)-h[show help and exit]' \
  '--version[show version and exit]' \
  '-d[debug filter (cl/opencl/perf/all/etc)]:filter:(all cache control dev fswatch input camctl perf pwstorage opencl sql memory nan masks lua print camsupport ioporder undo signal tiling lighttable verbose)' \
  '--disable-opencl[disable OpenCL even if available]' \
  '--conf[set a configuration parameter]:key=value:' \
  '--configdir=[user config directory]:dir:_files -/' \
  '--cachedir=[user cache directory]:dir:_files -/' \
  '--tmpdir=[temporary directory]:dir:_files -/' \
  '--datadir=[install data directory]:dir:_files -/' \
  '--moduledir=[install module directory]:dir:_files -/' \
  '--localedir=[install locale directory]:dir:_files -/' && ret=0
return ret
