#compdef darktable-cltest

# darktable-cltest: probe OpenCL availability for darktable
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-d[debug subsystem]:subsys:(all opencl camsupport control cache memory perf input verbose)' \
  '*::darktable-cltest args:_files' && ret=0
return ret
