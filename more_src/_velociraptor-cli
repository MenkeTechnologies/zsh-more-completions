#compdef velociraptor velociraptor-cli velociraptor.exe

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'frontend:start the frontend'
  'gui:run the GUI'
  'config:configuration related commands'
  'artifacts:list/show/explain artifacts'
  'query:run a VQL query'
  'tools:tool related commands'
  'rpm:RPM related commands'
  'deb:DEB related commands'
  'msi:MSI related commands'
  'fuse:mount as FUSE filesystem'
  'unzip:unzip a velociraptor zip'
  'export:export collections'
  'import:import collections'
  'collect:run collection'
  'shell:run a shell client'
  'client:run a velociraptor client'
  'pool_client:run a pool client'
  'service:install/uninstall as service'
  'orgs:org related commands'
  'auth:authentication management'
  'acl:access control commands'
  'debug:debug commands'
  'sql:run an SQL query'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*--config=[config file]:file:_files' \
  '(-c --config)*'{-c+,--config=}'[config file]:file:_files' \
  '*--api_config=[api config]:file:_files' \
  '*--definitions=[artifact definitions dir]:dir:_files -/' \
  '--logging.output_directory=[log dir]:dir:_files -/' \
  '--logging.separate_logs_per_component=[separate logs]:b:(true false)' \
  '*--debug=[debug]:b:(true false)' \
  '--debug_port=[debug port]:port:' \
  '*--profile=[profile dir]:dir:_files -/' \
  '*--cpu_profile=[cpu profile]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'velociraptor command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
