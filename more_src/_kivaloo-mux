#compdef kivaloo-mux
# _kivaloo-mux — multiplex many client connections onto one target socket (Tarsnap/kivaloo)
# upstream: https://github.com/Tarsnap/kivaloo
# Flags from mux/main.c (libcperciva GETOPT).

_kivaloo-mux() {
    _arguments \
        '(- *)--version[print version]' \
        '-t+[target socket]:socket:' \
        '*-s+[source socket (repeatable)]:socket:' \
        '-n+[maximum number of concurrent connections]:n:' \
        '-p+[pidfile]:file:_files'
}

_kivaloo-mux "$@"
