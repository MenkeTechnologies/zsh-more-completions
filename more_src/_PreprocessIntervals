#compdef PreprocessIntervals
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/PreprocessIntervals.java
# Prepares bins for coverage collection

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--bin-length=[Length (in bp) of the bins. If zero, no binning will be performed.]:value:' \
  '--padding=[Length (in bp) of the padding regions on each side of the intervals.]:value:' \
  '(--output -O)'{--output,-O}'[Output Picard interval-list file containing the preprocessed intervals.]:value:_files' \
  '*:argument:_files' && ret=0

return ret
