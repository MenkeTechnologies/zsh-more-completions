#compdef confidant confidant-cli confidant-client
# _confidant — Lyft confidant secrets management CLI for IAM-authenticated KMS-backed secret storage with versioned credentials services and IAM-role-based access (lyft team, Python); argparse
# upstream: https://github.com/lyft/confidant

_confidant() {
    local -a sub=(
        'get-service:get service credentials'
        'list-services:list services'
        'create-service:create service'
        'get-credential:get credential'
        'list-credentials:list credentials'
        'create-credential:create credential'
        'update-credential:update credential'
        'archive-credential:archive credential'
        'get-credential-revisions:get revisions'
        'diff-credential:diff credential'
        'rotate-key:rotate KMS key'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--config-files=+[file]:file:_files' \
        '--config-profile=+[name]:str:' \
        '--auth-context=+[ctx]:str:' \
        '--auth-key=+[key]:str:' \
        '--token-lifetime=+[ms]:n:' \
        '--token-version=+[N]:n:' \
        '--token-cache-file=+[file]:file:_files' \
        '--no-token-cache[no token cache]' \
        '--user-type=+[t]:t:(user service)' \
        '--region=+[r]:str:' \
        '--url=+[url]:str:' \
        '--retries=+[N]:n:' \
        '--backoff=+[F]:f:' \
        '--ca-bundle=+[file]:file:_files' \
        '--assume-role=+[arn]:str:' \
        '--mfa-pin=+[mfa pin]:str:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'confidant subcommand' sub ;;
        args)
            case $words[1] in
                get-service|get-credential|list-credentials|diff-credential|get-credential-revisions) _arguments \
                    '--service=+[name]:str:' \
                    '--credential-id=+[id]:str:' \
                    '--revision=+[N]:n:' ;;
                create-credential|update-credential) _arguments \
                    '--name=+[name]:str:' \
                    '--credential-pairs=+[json]:str:' \
                    '--metadata=+[json]:str:' \
                    '--enabled[enabled]' \
                    '--disabled[disabled]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_confidant "$@"
