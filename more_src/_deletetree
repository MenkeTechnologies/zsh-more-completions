#compdef deletetree
# _deletetree — Trillian admin helper: soft/undelete a tree
# upstream: https://github.com/google/trillian
# Flags from cmd/deletetree/main.go on tip.

_deletetree() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-admin_server=[Trillian Admin Server host\:port]:host\:port:' \
        '-log_id=[Trillian LogID to (un)delete]:n:' \
        '-undelete_tree=[undelete instead of delete]:bool:(true false)'
}

_deletetree "$@"
