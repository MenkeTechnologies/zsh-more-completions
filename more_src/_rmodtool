#compdef rmodtool
# Documentation: https://github.com/coreboot/coreboot/blob/master/util/cbfstool/rmodtool.c
# coreboot relocatable module creation tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-i --inelf)'{-i,--inelf}'[input ELF file]:input:_files' \
  '(-o --outelf)'{-o,--outelf}'[output ELF file]:output:_files' && ret=0

return ret
