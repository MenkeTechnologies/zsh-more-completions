#compdef flowpipe

# Zsh completion for Flowpipe - workflow automation (Turbot)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'integration:manage integrations'
      'login:log in to Turbot Pipes'
      'mod:manage mods'
      'notifier:manage notifiers'
      'pipeline:manage pipelines'
      'process:manage processes'
      'server:start flowpipe server'
      'trigger:manage triggers'
      'variable:manage variables'
      'completion:generate shell completions'
    )
    _describe -t commands 'flowpipe command' commands && ret=0
    ;;
  args)
    case $line[1] in
      pipeline)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list run show)' && ret=0
        ;;
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--port=[port to listen on]:port' \
          '--listen=[listen address]:address:(local network)' \
          '--mod-location=[mod location]:directory:_directories' \
          '--var=[set variable]:KEY=VALUE' \
          '--var-file=[variable file]:file:_files -g "*.fpvars"' \
          '--base-url=[base URL]:url' \
          '--verbose[enable verbose logging]' && ret=0
        ;;
      mod)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(init install list show uninstall update)' && ret=0
        ;;
      trigger)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list show enable disable)' && ret=0
        ;;
      process)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list show tail)' && ret=0
        ;;
    esac
    ;;
esac

return ret
