#compdef cyrus-sync_client
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/sync_client.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org sync_client(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-sync_client: Cyrus mailstore replication client
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '*'{-v,--verbose}'[verbose (twice = protocol traffic)]' \
  '(-l --verbose-logging)'{-l,--verbose-logging}'[verbose logging]' \
  '(-L --local-only)'{-L,--local-only}'[local only (no mupdate)]' \
  '(-z --require-compression)'{-z,--require-compression}'[require protocol compression]' \
  '-S[replica server name]:server:' \
  '-f[input file: mailbox/user list or alt log]:file:_files' \
  '-F[rolling-mode shutdown sentinel file]:file:_files' \
  '-w[wait interval before start]:seconds:' \
  '-t[per-run timeout (default 600)]:seconds:' \
  '-d[minimum delay between runs (default 3)]:seconds:' \
  '(-R --foreground-rolling)'{-r,--rolling}'[rolling daemon mode]' \
  '(-r --rolling)'{-R,--foreground-rolling}'[rolling, no background]' \
  '(-1 --rolling-once)'{-1,--rolling-once}'[single log run]' \
  '-n[named rolling channel]:channel:' \
  '(-m --mailboxes)'{-u,--userids}'[arguments are usernames]' \
  '(-u --userids)'{-m,--mailboxes}'[arguments are mailboxes]' \
  '-p[replica partition]:partition:' \
  '(-A --all-users)'{-A,--all-users}'[replicate all users]' \
  '(-N --skip-locked)'{-N,--skip-locked}'[skip locked mailboxes]' \
  '(-s --sieve-mode)'{-s,--sieve-mode}'[replicate Sieve files]' \
  '(-O --no-copyback)'{-O,--no-copyback}'[stop on replica CRC error]' \
  '(-o --connect-once)'{-o,--connect-once}'[single connect attempt]' \
  '(-a --stage-to-archive)'{-a,--stage-to-archive}'[stage to archive partition]' \
  '*:arg:' && ret=0
return ret
