#compdef xmgrace grace gracebat grbatch
# Documentation: https://plasma-gate.weizmann.ac.il/Grace/doc/UsersGuide.html
# Reference accessed: 2026-05-21
# Verified: upstream Grace User's Guide.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' \
  '-usage[show usage]' \
  '-version[show version]' \
  '-autoscale+[autoscale axes]:type:(x y xy)' \
  '-barebones[no toolbars]' \
  '-batch+[execute batch file on startup]:file:_files' \
  '-block+[block data file]:file:_files' \
  '-bxy+[block data X,Y columns]:cols:' \
  '-netcdf+[NetCDF file]:file:_files' \
  '-netcdfxy+[NetCDF X,Y variables]:vars:' \
  '-nxy+[XY-paired data file]:file:_files' \
  '-pipe[read data from stdin]' \
  '-dpipe+[read from anonymous pipe]:descriptor:' \
  '-npipe+[named pipe to read]:pipe:' \
  '-remove[remove data file after reading]' \
  '-source+[next data source type]:source:(disk pipe)' \
  '-settype+[set data type]:type:(xy xydx xydy xydxdy xydydy xydxdx)' \
  '-display+[X display]:display:' \
  '-fixed[fixed canvas size]:WxH:' \
  '-free[free canvas size]' \
  '-graph+[set current graph number]:n:' \
  '-graphtype+[graph type]:type:' \
  '-hardcopy[no GUI, print and quit]' \
  '-hdevice+[hardcopy device]:device:' \
  '-log+[log axis]:type:(x y xy)' \
  '-legend+[legend placement]:loc:(load)' \
  '-maxpath+[max path length]:n:' \
  '-mono[monochrome output]' \
  '-noask[do not ask questions]' \
  '-noprint[do not print on exit]' \
  '-nosafe[allow unsafe code]' \
  '-nosigcatch[do not catch signals]' \
  '-safe[run in safe mode]' \
  '-param+[parameter file]:file:_files' \
  '-pexec+[interpret parameter string]:cmd:' \
  '-printfile+[hardcopy output file]:file:_files' \
  '-results+[write results file]:file:_files' \
  '-rvideo[reverse video]' \
  '-timer+[redraw interval ms]:n:' \
  '-timestamp[append timestamp to plot]' \
  '-install[install private colormap]' \
  '-noinstall[do not install colormap]' \
  '-seed+[RNG seed]:value:' \
  '-datehint+[date parsing hint]:hint:(iso european us days seconds nohint)' \
  '-viewport+[viewport coords]:xmin,ymin,xmax,ymax:' \
  '-world+[world coords]:xmin,ymin,xmax,ymax:' \
  '-wd+[working directory]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
