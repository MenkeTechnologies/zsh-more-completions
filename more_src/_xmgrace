#compdef xmgrace grace gracebat grbatch

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-autoscale+[autoscale axes]:type:(x y xy none)' \
  '-barebones[no toolbars]' \
  '-batch+[execute batch file on startup]:file:_files' \
  '-block+[block data file]:file:_files' \
  '-bxy+[block data X,Y file]:file:_files' \
  '-display+[X display]:display:' \
  '-fixed[fixed canvas size]:WxH:' \
  '-free[free canvas size]' \
  '-graph+[set current graph number]:n:' \
  '-graphtype+[graph type]:type:(xy logx logy logxy bar logbar pie polar smith fixed)' \
  '-hardcopy[no GUI, print and quit]' \
  '-hdevice+[hardcopy device]:device:(PostScript EPS PDF PNG SVG JPEG MIF)' \
  '-legend+[legend placement]:loc:(load none world view onlimit)' \
  '-log+[log axis]:type:(x y xy)' \
  '-maxpath+[max path]:n:' \
  '-mono[monochrome output]' \
  '-noask[do not ask questions]' \
  '-noprint[do not print on exit]' \
  '-nosafe[allow unsafe code]' \
  '-npipe+[named pipe to read]:pipe:' \
  '-nxy+[XY-paired data file]:file:_files' \
  '-pipe[read data from stdin]' \
  '-pexec+[execute parameter command]:cmd:' \
  '-printfile+[hardcopy output file]:file:_files' \
  '-result+[result file for batch hardcopy]:file:_files' \
  '-rvideo[reverse video]' \
  '-safe[run in safe mode]' \
  '-saveall+[save all data on exit]:file:_files' \
  '-source+[data file source]:source:(file pipe stdin)' \
  '-settype+[set data type]:type:(xy xyz xydx xydy xydxdy xydxdx xydydy xyboxplot)' \
  '-timer+[redraw interval ms]:n:' \
  '-type+[default data type]:type:(xy xyz xydx xydy xydxdy)' \
  '-usempos[use Motif default position]' \
  '-verbose[verbose log output]' \
  '-version[print version]' \
  '-viewport+[viewport coords]:xll,yll,xur,yur:' \
  '-world+[world coords]:xmin,ymin,xmax,ymax:' \
  '-wd+[working directory]:dir:_files -/' \
  '-write+[write file on exit]:file:_files' \
  '*:file:_files' && ret=0

return ret
