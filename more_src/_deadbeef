#compdef deadbeef

# Zsh completion for deadbeef - modular audio player

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--play[start playback]' \
  '--stop[stop playback]' \
  '--pause[pause playback]' \
  '--toggle-pause[toggle pause/play]' \
  '--play-pause[toggle play/pause]' \
  '--next[play next track]' \
  '--prev[play previous track]' \
  '--random[play random track]' \
  '--queue[append file(s) to existing playlist]' \
  '--quit[quit deadbeef]' \
  '--nowplaying=[print formatted now-playing info and exit]:format' \
  '--nowplaying-tf=[print now-playing in title format and exit]:format' \
  '--seek=[seek to position]:position (seconds or %)' \
  '--volume=[set volume]:volume (0-100)' \
  '--gui=[select GUI plugin]:plugin' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files -g "*.{mp3,flac,ogg,opus,wav,aac,m4a,wma,ape,mpc,wv,tta,aiff,cue,m3u,pls}"' && ret=0

return ret
