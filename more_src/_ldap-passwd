#compdef ldap-passwd
# _ldap-passwd — distro-shipped LDAP passwd wrapper (alias of ldappasswd(1); -H URI, -D bind DN, -w password, -y password file, -S prompt for new password, -s new password, -t file with new password, -A prompt for old, -a old password, -T file with old, -x simple bind, -Z TLS, -n dry run, -v verbose, -h help, -V version; positional argument is the user DN whose password to change)
# upstream: https://git.openldap.org/openldap/openldap (clients/tools/ldappasswd)
# Flags from OpenLDAP clients/tools/ldappasswd.c on tip.

_ldap-passwd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-H+[URI]:uri:' \
        '-D+[bind DN]:dn:' \
        '-w+[bind password]:password:' \
        '-y+[bind password file]:file:_files' \
        '-S[prompt for new password]' \
        '-s+[new password]:password:' \
        '-t+[new password file]:file:_files' \
        '-A[prompt for old password]' \
        '-a+[old password]:password:' \
        '-T+[old password file]:file:_files' \
        '-x[simple bind]' \
        '-Z[start TLS]' \
        '-ZZ[require start TLS]' \
        '-n[dry run]' \
        '-v[verbose]' \
        '1::user DN:'
}

_ldap-passwd "$@"
