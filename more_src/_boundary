#compdef boundary

# HashiCorp Boundary CLI completion

_boundary_subcommands() {
  local -a subcmds=(
    'authenticate:Authenticate to Boundary'
    'connect:Connect to a target'
    'targets:Manage targets'
    'sessions:Manage sessions'
    'scopes:Manage scopes'
    'hosts:Manage hosts'
    'host-catalogs:Manage host catalogs'
    'host-sets:Manage host sets'
    'accounts:Manage accounts'
    'auth-methods:Manage auth methods'
    'groups:Manage groups'
    'managed-groups:Manage managed groups'
    'roles:Manage roles'
    'users:Manage users'
    'credential-stores:Manage credential stores'
    'credential-libraries:Manage credential libraries'
    'credentials:Manage credentials'
    'workers:Manage workers'
    'aliases:Manage aliases'
    'policies:Manage policies'
    'storage-buckets:Manage storage buckets'
    'server:Start the Boundary server'
    'database:Manage the Boundary database'
  )
  _describe -t commands 'boundary subcommand' subcmds
}

_boundary() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '-addr=[Boundary address]:address' \
    '-token=[authentication token]:token' \
    '-recovery-config=[recovery config file]:file:_files' \
    '-output-curl-string[output equivalent curl command]' \
    '-keyring-type=[keyring type]:type:(auto wincred keychain pass secret-service none)' \
    '-format=[output format]:format:(table json)' \
    '-recursive[recursive operation]' \
    '1:subcommand:_boundary_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        authenticate)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:method:(password oidc ldap)' \
            '-addr=[Boundary address]:address' \
            '-login-name=[login name]:name' \
            '-password=[password]:password' \
            '-auth-method-id=[auth method ID]:id' \
            '-scope-id=[scope ID]:id' \
            '-format=[output format]:format:(table json)'
          ;;
        connect)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:protocol:(ssh http postgres rdp kube)' \
            '-target-id=[target ID]:id' \
            '-target-name=[target name]:name' \
            '-target-scope-id=[target scope ID]:id' \
            '-target-scope-name=[target scope name]:name' \
            '-host-id=[host ID]:id' \
            '-listen-addr=[local listen address]:address' \
            '-listen-port=[local listen port]:port' \
            '-format=[output format]:format:(table json)'
          ;;
        targets)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(list read create update delete authorize-session add-host-sources remove-host-sources set-host-sources add-credential-sources remove-credential-sources set-credential-sources)' \
            '-id=[target ID]:id' \
            '-scope-id=[scope ID]:id' \
            '-name=[target name]:name' \
            '-format=[output format]:format:(table json)' \
            '-recursive[recursive operation]'
          ;;
        sessions)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(list read cancel)' \
            '-id=[session ID]:id' \
            '-scope-id=[scope ID]:id' \
            '-format=[output format]:format:(table json)' \
            '-recursive[recursive operation]'
          ;;
        scopes)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(list read create update delete)' \
            '-id=[scope ID]:id' \
            '-scope-id=[parent scope ID]:id' \
            '-name=[scope name]:name' \
            '-format=[output format]:format:(table json)' \
            '-recursive[recursive operation]'
          ;;
        hosts|host-catalogs|host-sets|accounts|auth-methods|groups|managed-groups|roles|users|credential-stores|credential-libraries|credentials|workers|aliases|policies|storage-buckets)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(list read create update delete)' \
            '-id=[resource ID]:id' \
            '-scope-id=[scope ID]:id' \
            '-name=[resource name]:name' \
            '-format=[output format]:format:(table json)' \
            '-recursive[recursive operation]'
          ;;
        database)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(init migrate)'
          ;;
        server)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '-config=[config file]:file:_files'
          ;;
      esac
      ;;
  esac
}

_boundary "$@"
