# Reference accessed: 2026-05-22
# Verified: mlx_lm --help subcommand list (mlx-lm PyPI package).

# Zsh completion for mlx_lm - MLX local LLM tooling CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:subcommand:->cmds' && ret=0

case $state in
  cmds)
    _values 'mlx_lm subcommand' \
      'benchmark[benchmark models]' \
      'cache_prompt[cache prompt KV]' \
      'chat[interactive chat]' \
      'convert[convert model weights]' \
      'evaluate[evaluate model]' \
      'fuse[fuse LoRA weights]' \
      'generate[generate text]' \
      'lora[LoRA fine-tuning]' \
      'manage[manage models]' \
      'perplexity[compute perplexity]' \
      'awq[AWQ quantization]' \
      'dwq[DWQ quantization]' \
      'dynamic_quant[dynamic quantization]' \
      'gptq[GPTQ quantization]' \
      'server[run inference server]' \
      'upload[upload model]' \
      'share[share model]' && ret=0
    ;;
esac

return ret
