#compdef ceph-disk
# Documentation: https://man.archlinux.org/search?q=ceph-disk
# Reference accessed: 2026-05-16

# ceph-disk: legacy Ceph OSD lifecycle helper (deprecated; use ceph-volume)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'prepare:prepare a device'
  'activate:activate an OSD'
  'activate-all:activate all detected OSDs'
  'list:list disks'
  'zap:zap a disk'
  'fuse:run a FUSE on /var/lib/ceph'
  'trigger:internal udev trigger'
  'deactivate:deactivate an OSD'
  'destroy:destroy an OSD'
  'suppress-activate:create suppression marker'
  'unsuppress-activate:remove suppression marker'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--log-stdout[log to stdout]' \
  '--prepend-to-path=[prepend to PATH]:path:' \
  '--statedir=[state dir]:dir:_files -/' \
  '--sysconfdir=[ceph sysconfdir]:dir:_files -/' \
  '--setuser=[run as user]:user:_users' \
  '--setgroup=[run as group]:group:_groups' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ceph-disk command' commands && ret=0 ;;
esac
return ret
