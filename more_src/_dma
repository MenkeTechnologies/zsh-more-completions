#compdef dma
# Documentation: https://www.dragonflybsd.org/cgi/web-man?command=dma&section=ANY
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '-A=[sendmail compat mode]:mode:' \
  '-b=[operation mode]:mode:(p q)' \
  '-D[foreground/debug]' \
  '-f=[envelope sender]:sender:' \
  '-i[ignore single-dot lines]' \
  '-L=[syslog tag]:tag:' \
  '-O[no-op]' \
  '-o=[option]:opt:' \
  '-q=[process queue]:arg:' \
  '-r=[sender]:sender:' \
  '-t[recipients from headers]' \
  '*:recipient:'
