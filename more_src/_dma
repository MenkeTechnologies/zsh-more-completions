#compdef dma
# Documentation: https://man.archlinux.org/search?q=dma
# Reference accessed: 2026-05-16

_arguments -s \
  '-A=[sendmail compat mode]:mode:' \
  '-b=[operation mode]:mode:(p q)' \
  '-D[foreground/debug]' \
  '-f=[envelope sender]:sender:' \
  '-i[ignore single-dot lines]' \
  '-L=[syslog tag]:tag:' \
  '-O[no-op]' \
  '-o=[option]:opt:' \
  '-q=[process queue]:arg:' \
  '-r=[sender]:sender:' \
  '-t[recipients from headers]' \
  '*:recipient:'
