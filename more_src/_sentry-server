#compdef sentry-server
# Documentation: https://man.archlinux.org/search?q=sentry-server
# Reference accessed: 2026-05-16

# Sentry server: error tracking platform (self-hosted)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'run:run a server worker (web, worker, cron, ingest-consumer, post-process-forwarder, ...)'
  'upgrade:upgrade Sentry database'
  'createuser:create a user'
  'permissions:manage permissions'
  'celery:run celery commands'
  'cleanup:cleanup old data'
  'config:show config'
  'devserver:run dev server'
  'export:export data'
  'import:import data'
  'killswitches:configure killswitches'
  'queues:queue management'
  'shell:Django shell'
  'tsdb:tsdb operations'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'sentry-server command' commands && ret=0 ;;
esac
return ret
