#compdef ossec-execd
# Documentation: https://www.ossec.net/docs/programs/ossec-execd.html
# OSSEC active response execution daemon

local ret=1

_arguments -s \
  '-V[version and license message]' \
  '-h[show help]' \
  '*-d[debug mode (repeat to increase verbosity)]' \
  '-t[test configuration]' \
  '-f[run in foreground]' \
  '-g[run as this group]:group:_groups' \
  '-c[configuration file]:config file:_files' && ret=0

return ret
