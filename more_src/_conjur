#compdef conjur conjur-cli
# _conjur — CyberArk conjur secrets management CLI for Conjur Open Source and Enterprise machine identity policy retrieval Kubernetes authn-k8s OIDC authentication (cyberark team, Ruby); thor
# upstream: https://github.com/cyberark/conjur-cli

_conjur() {
    local -a sub=(
        'init:initialize connection'
        'authn:authenticate'
        'authn:login:login'
        'authn:logout:logout'
        'authn:whoami:show user'
        'host:host operations'
        'user:user operations'
        'variable:variable operations'
        'policy:policy operations'
        'role:role operations'
        'resource:resource operations'
        'env:env operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--insecure[allow self-signed certs]' \
        '--account=+[name]:str:' \
        '--api-url=+[url]:str:' \
        '--ca-bundle=+[file]:file:_files' \
        '--cert-file=+[file]:file:_files' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'conjur subcommand' sub ;;
        args)
            case $words[1] in
                variable) _arguments \
                    '1:action:(get set list versions)' \
                    '*:variable id:' ;;
                policy) _arguments \
                    '1:action:(load fetch replace update delete)' \
                    '-f+[policy file]:file:_files -g "*.yml *.yaml"' \
                    '-b+[branch]:str:' \
                    '*:policy id:' ;;
                host|user) _arguments \
                    '1:action:(create rotate-api-key list show)' \
                    '*:host or user id:' ;;
                role|resource) _arguments \
                    '1:action:(list show check exists members memberships permitted-roles)' \
                    '*:role or resource id:' ;;
                env) _arguments \
                    '1:action:(set get unset list export)' \
                    '*:key:' ;;
            esac
            ;;
    esac
}

_conjur "$@"
