#compdef woof

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-i+[IP address to bind to]:address' \
  '-p+[port to use]:port' \
  '-c+[number of times to serve the file]:count' \
  '-s[serve a directory as a compressed tar archive]' \
  '-z[serve a directory as a gzip-compressed tar archive]' \
  '-j[serve a directory as a bzip2-compressed tar archive]' \
  '-Z[serve a directory as a zip file]' \
  '-u[provide upload functionality]' \
  '-U[provide upload functionality and allow overwriting]' \
  '*:file:_files' && ret=0

return ret
