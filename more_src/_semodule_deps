#compdef semodule_deps
# Documentation: https://manpages.debian.org/buster/policycoreutils/semodule_deps.8
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# semodule_deps: show dependencies between SELinux policy modules.
local curcontext="$curcontext" ret=1
_arguments -s -S \
  '-v[verbose mode]' \
  '-g[output in Graphviz dot format]' \
  '-b[include dependencies to the base module]' \
  '*:policy module:_files' && ret=0
return ret
