#compdef semodule_deps
# Documentation: https://man.archlinux.org/search?q=semodule_deps
# Reference accessed: 2026-05-16

# semodule_deps: show dependencies between SELinux policy modules
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-V[show version]' \
  '-r[reverse dependencies (modules that depend on X)]' \
  '-i[ignore symbol]:symbol:' \
  '-d[show direct deps only]' \
  '*:module name:' && ret=0
return ret
