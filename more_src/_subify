_subify() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'dl:download subtitles for a video file'
        'list:list information about subify resources'
        'version:print subify version'
        'help:help about any command'
        'completion:generate shell completion'
    )

    local -a list_subs
    list_subs=(
        'apis:list supported subtitle APIs (tablewriter output)'
        'languages:list available subtitle languages (tablewriter output)'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--config=[config file (default $HOME/.subify.yaml|json|toml)]:config file:_files' \
        '(-v --verbose)'{-v,--verbose}'[print more information while executing]' \
        '--dev[development sandbox instead of production]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'subify subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                dl)
                    _arguments \
                        '(-l --languages)'{-l+,--languages=}'[comma-separated ISO 639-1 codes (default en)]:codes:' \
                        '(-a --apis)'{-a+,--apis=}'[comma-separated API names (default OpenSubtitles,Addic7ed)]:apis:(OpenSubtitles Addic7ed "OpenSubtitles,Addic7ed" "Addic7ed,OpenSubtitles")' \
                        '(-o --open)'{-o,--open}'[open video in default player after download]' \
                        '(-n --notify)'{-n,--notify}'[desktop notification on completion (default true)]' \
                        '--lang-in-filename[embed language in filename xxx.English.srt (default true)]' \
                        '1:video file:_files -g "*.(mp4|mkv|avi|mov|wmv|flv|webm|m4v|mpg|mpeg)"' && ret=0
                    ;;
                list)
                    _arguments -C \
                        '(-): :->lsub' \
                        '*::lsubarg:->lsubarg' && ret=0
                    case $state in
                        lsub)
                            _describe -t commands 'list subcommand' list_subs && ret=0
                            ;;
                        lsubarg)
                            case $line[1] in
                                languages)
                                    _arguments '--all[show all languages (not just common ones)]' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                completion)
                    _arguments '1:shell:(bash zsh fish powershell)' && ret=0
                    ;;
                version|help)
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_subify "$@"
