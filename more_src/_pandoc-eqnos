#compdef pandoc-eqnos
# Documentation: https://github.com/tomduck/pandoc-eqnos
# pandoc-eqnos: a Pandoc filter for numbering equations and equation references

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[show version and exit]' \
  '--pandocversion=[the pandoc version]:version:' \
  '1:format:' && ret=0

return ret
