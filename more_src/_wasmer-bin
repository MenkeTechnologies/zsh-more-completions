#compdef wasmer
# _wasmer-bin — Wasmer WebAssembly runtime (Rust); CLI runner + compiler + package manager
# upstream: https://github.com/wasmerio/wasmer

_wasmer-bin() {
    local -a sub=(
        'run:execute a .wasm module'
        'cache:cache subcommands'
        'compile:compile a .wasm to native object'
        'config:show wasmer config'
        'create-exe:create a native executable'
        'create-obj:create a native object'
        'inspect:inspect module info'
        'init:initialize a wasmer.toml package'
        'login:authenticate to wasmer.io'
        'logout:logout'
        'list:list local packages'
        'package:package subcommands'
        'publish:publish a package'
        'run-unstable:experimental run with WASIX/WASI variants'
        'self-update:update wasmer'
        'validate:validate a .wasm module'
        'whoami:print current user'
        'wasmer-create-exe:create native binary (deprecated)'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--log-format+[log format]:fmt:(text json)' \
        '--registry+[registry URL]:url:_urls' \
        '--token+[wasmer.io token]:token:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wasmer subcommand' sub ;;
        args)
            case $words[1] in
                run|validate|inspect|compile) _arguments \
                    '--singlepass[singlepass compiler]' \
                    '--cranelift[cranelift compiler]' \
                    '--llvm[LLVM compiler]' \
                    '--enable-all[enable all wasm features]' \
                    '--enable-threads[enable threads]' \
                    '--enable-simd[enable SIMD]' \
                    '--enable-reference-types[enable ref types]' \
                    '--enable-bulk-memory[enable bulk memory]' \
                    '--dir+[host dir]:dir:_files -/' \
                    '--mapdir+[guest=host map]:str:' \
                    '--env+[env var]:KEY=VAL:' \
                    '--invoke+[invoke function]:func:' \
                    '*:wasm or package:_files -g "*.wasm"' ;;
                login|logout) _arguments '--registry+[registry URL]:url:_urls' ;;
            esac
            ;;
    esac
}

_wasmer-bin "$@"
