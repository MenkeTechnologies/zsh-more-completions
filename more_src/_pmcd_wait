#compdef pmcd_wait
# _pmcd_wait — wait for PMCD to become available (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pmcd_wait/pmcd_wait.c (pmgetopt opts).

_pmcd_wait() {
    _arguments \
        '(- *)-?[show help]' \
        '-D+[debug specification]:spec:' \
        '(-h --host)'{-h+,--host=}'[wait for PMCD on host]:host:_hosts' \
        '(-t --interval)'{-t+,--interval=}'[max interval to wait (default 60s)]:secs:' \
        '(-v --verbose)'{-v,--verbose}'[turn on output messages]'
}

_pmcd_wait "$@"
