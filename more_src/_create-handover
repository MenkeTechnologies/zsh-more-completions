#compdef create-handover
# Documentation: https://www.npmjs.com/package/create-handover
# Reference accessed: 2026-05-23
# Verified: npm view create-handover bin; npm readme Options section.

# Zsh completion for create-handover - Handover white-label admin site scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--template=[bundled template id]:template:(next vite-react tanstack-start astro)'   '--list-templates[print bundled templates and exit]'   '--template-dir=[custom local template directory]:directory:_directories'   '--api-url=[Handover backend URL for env file]:url:'   '--api-key=[Handover API key for env file]:key:'   '--package-manager=[package manager for install]:manager:(pnpm npm yarn bun)'   '--install[install dependencies after scaffolding]'   '--no-install[skip dependency install]'   '--git[initialize git repository]'   '--no-git[skip git initialization]'   '--file=[registry path for add command]:file:_files'   '(-y --yes)'{-y,--yes}'[skip prompts]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' add && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments -C           '--file=[registry JSON path]:file:_files'           ':component key:'           ':component value:' && ret=0
        ;;
      *)
        _arguments -C           '--template=[template id]:template:(next vite-react tanstack-start astro)'           '--list-templates[list bundled templates and exit]'           '--package-manager=[package manager]:manager:(pnpm npm yarn bun)'           '--install[install dependencies]'           '--no-install[skip install]'           '--git[initialize git]'           '--no-git[skip git init]'           '(-y --yes)'{-y,--yes}'[skip prompts]'           ':project directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
