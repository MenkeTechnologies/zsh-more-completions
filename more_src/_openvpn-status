#compdef openvpn-status
# _openvpn-status — openvpn-status (Python parser turning OpenVPN's status.log into JSON/CSV/TSV reports; -i input status file (default /var/log/openvpn/status.log), -f format (json|csv|tsv|table), -k key field to sort on, -n no header, -t total only, -r resolve client IPs, --version print version)
# upstream: https://github.com/yuselg/openvpn-monitor (status parsers)
# Common flag shape from openvpn-monitor + openvpn-status parsers on tip.

_openvpn-status() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-i+[input file]:file:_files' \
        '-f+[format]:format:(json csv tsv table)' \
        '-k+[sort key]:key:' \
        '-n[no header]' \
        '-t[totals only]' \
        '-r[resolve client IPs]'
}

_openvpn-status "$@"
