_shiba() {
    _arguments -s -S \
        '(-h --help)'{-h,--help}'[print help and exit]' \
        '--version[print Shiba version and exit]' \
        '*'{-o+,--open=}'[open FILE in a new window (repeatable)]:file:_files -g "*.(md|markdown|mkd|mdown|mdwn|mkdn|mdtxt)"' \
        '(-t --theme)'{-t+,--theme=}'[window theme (default system)]:theme:(system dark light)' \
        '--no-watch[disable filesystem watching for auto-reload]' \
        '--no-restore[do not restore previous window state]' \
        '--generate-config-file[write default config file overwriting existing]' \
        '--config-dir=[override config directory path]:config dir:_files -/' \
        '--data-dir=[override application data directory path]:data dir:_files -/' \
        '--no-proc-singleton[do not reuse existing Shiba process - spawn fresh instance]' \
        '--debug[enable debug logging (Debug level instead of Info)]' \
        '*:Markdown file or directory to watch:_files -g "*.(md|markdown|mkd|mdown|mdwn|mkdn|mdtxt)"'
}

_shiba "$@"
