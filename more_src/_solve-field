#compdef solve-field
# Documentation: https://astrometry.net/doc/readme.html
# Documentation: https://github.com/dstndstn/astrometry.net/blob/main/solver/solve-field.c
# Documentation: https://github.com/dstndstn/astrometry.net/blob/main/solver/augment-xylist.c
# Reference accessed: 2026-05-27
# Verified: upstream solver/solve-field.c options[] and solver/augment-xylist.c options[] (dstndstn/astrometry.net)

# Zsh completion for solve-field (astrometry.net plate solver wrapper)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message]' \
  '--version[print version string and exit]' \
  '*'{-v,--verbose}'[be more chatty (repeat for more)]' \
  '(-D --dir)'{-D+,--dir=}'[place output files in specified directory]:directory:_files -/' \
  '(-o --out)'{-o+,--out=}'[base name for output files]:basename:' \
  '(-b --backend-config)'{-b+,--backend-config=}'[config file for astrometry-engine]:config:_files' \
  '--config=[config file for astrometry-engine]:config:_files' \
  '--index-dir=[search for index files in directory]:directory:_files -/' \
  '*--index-file=[add index file (wildcard supported)]:index:_files' \
  '(-G --use-wget)'{-G,--use-wget}'[use wget instead of curl]' \
  '(-O --overwrite)'{-O,--overwrite}'[overwrite existing output files]' \
  '(-K --continue)'{-K,--continue}'[skip overwrite; continue previous run]' \
  '(-J --skip-solved)'{-J,--skip-solved}'[skip input files with existing solved output]' \
  '--fits-image[assume input files are FITS images]' \
  '(-N --new-fits)'{-N+,--new-fits=}'[output FITS file with WCS header]:file:_files' \
  '(-Z --kmz)'{-Z+,--kmz=}'[create KMZ file for Google Sky]:file:_files' \
  '(-i --scamp)'{-i+,--scamp=}'[create SCAMP image object catalog]:file:_files' \
  '(-n --scamp-config)'{-n+,--scamp-config=}'[create SCAMP config snippet]:file:_files' \
  '(-U --index-xyls)'{-U+,--index-xyls=}'[output xylist of index stars]:file:_files' \
  '(-p --no-plots)'{-p,--no-plots}'[do not generate plots]' \
  '--plot-scale=[scale plots by factor]:factor:' \
  '--plot-bg=[set background JPEG for plots]:file:_files -g "*.(jpg|jpeg|JPG|JPEG)"' \
  '--just-augment[write augmented xylist files only]' \
  '-@[write augmented xylist files only]' \
  '--axy=[output filename for augmented xylist]:file:_files' \
  '--temp-axy[write axy file to temp location]' \
  '--timestamp[add timestamps to log messages]' \
  '(-f --files-on-stdin)'{-f,--files-on-stdin}'[read filenames from stdin]' \
  '--batch[run engine once for all files]' \
  '--scale-units=[units for scale-low/scale-high]:units:(degwidth arcminwidth arcsecperpix focalmm)' \
  '(-L --scale-low)'{-L+,--scale-low=}'[lower bound on field scale]:lo:' \
  '(-H --scale-high)'{-H+,--scale-high=}'[upper bound on field scale]:hi:' \
  '(-3 --ra)'{-3+,--ra=}'[only solve fields near this RA (deg or hh\:mm\:ss)]:ra:' \
  '(-4 --dec)'{-4+,--dec=}'[only solve fields near this Dec (deg or dd\:mm\:ss)]:dec:' \
  '(-5 --radius)'{-5+,--radius=}'[search radius around RA/Dec (deg)]:radius:' \
  '(-c --code-tolerance)'{-c+,--code-tolerance=}'[matching distance for quads (default 0.01)]:tol:' \
  '(-l --cpulimit)'{-l+,--cpulimit=}'[CPU time limit (seconds)]:seconds:' \
  '*--depth=[number of field objects to look at (e.g. 10,20,30)]:depth:' \
  '--objs=[cut field xylist to first N objects]:n:' \
  '--parity=[parity (pos/neg/both)]:parity:(pos neg both)' \
  '--sigma=[noise level estimate for source extraction]:sigma:' \
  '--downsample=[downsample image by integer factor before extraction]:factor:' \
  '--no-background-subtraction[skip image background subtraction]' \
  '--no-remove-lines[skip removing detected lines]' \
  '--uniformize=[grid uniformization (cells)]:n:' \
  '--no-verify[skip verification of existing WCS]' \
  '--use-source-extractor[use SExtractor for source extraction]' \
  '--source-extractor-path=[path to SExtractor binary]:executable:_files' \
  '--source-extractor-config=[SExtractor config file]:config:_files' \
  '--no-tweak[disable SIP polynomial tweak]' \
  '(-t --tweak-order)'{-t+,--tweak-order=}'[SIP polynomial order for tweak]:order:' \
  '--crpix-x=[set output WCS CRPIX X]:x:' \
  '--crpix-y=[set output WCS CRPIX Y]:y:' \
  '--crpix-center[set CRPIX to image center]' \
  '--tag=[FITS header keyword to copy from reference table]:keyword:' \
  '--tag-all[copy all FITS keywords from reference table]' \
  '--fields=[only process these field numbers (e.g. 1-100)]:fields:' \
  '--width=[image width in pixels (for xylists)]:width:' \
  '--height=[image height in pixels (for xylists)]:height:' \
  '(-x --x-column)'{-x+,--x-column=}'[X-axis FITS column name]:name:' \
  '(-y --y-column)'{-y+,--y-column=}'[Y-axis FITS column name]:name:' \
  '--sort-column=[FITS column to sort by]:name:' \
  '--sort-ascending[sort sort-column ascending]' \
  '--pixel-error=[positional uncertainty (pixels)]:pixels:' \
  '--quad-size-min=[lower bound on quad size (fraction of field)]:frac:' \
  '--quad-size-max=[upper bound on quad size (fraction of field)]:frac:' \
  '--odds-to-tune-up=[log-odds to attempt tune-up of WCS]:odds:' \
  '--odds-to-solve=[log-odds threshold to declare match]:odds:' \
  '--odds-to-reject=[log-odds threshold to reject hypothesis]:odds:' \
  '--odds-to-stop-looking=[log-odds threshold to stop searching]:odds:' \
  '(-W --wcs)'{-W+,--wcs=}'[output filename for WCS]:file:_files' \
  '(-R --rdls)'{-R+,--rdls=}'[output filename for RA/Dec list]:file:_files' \
  '--sort-rdls=[sort RDLS by named column]:column:' \
  '(-M --match)'{-M+,--match=}'[output filename for matched-quad info]:file:_files' \
  '(-S --solved)'{-S+,--solved=}'[output solved file]:file:_files' \
  '(-I --solved-in)'{-I+,--solved-in=}'[input solved file]:file:_files' \
  '--cancel=[touch this file to cancel solve]:file:_files' \
  '--scamp-ref=[output SCAMP reference catalog]:file:_files' \
  '--corr=[output correspondence FITS table]:file:_files' \
  '--pnm=[output PNM image used for source extraction]:file:_files' \
  '--force-ppm[force PNM output to PPM]' \
  '--keep-xylist=[keep xylist at this filename]:file:_files' \
  '--dont-augment[do not run augment step]' \
  '--invert[invert image before extraction]' \
  '--temp-dir=[directory for temp files]:directory:_files -/' \
  '--no-delete-temp[keep temporary files]' \
  '--resort[resort xylist by FLUX]' \
  '--predistort=[apply distortion to FITS image]:file:_files' \
  '--xscale=[scale X column by factor]:factor:' \
  '--extension=[FITS extension number to read]:n:' \
  '--verify=[verify the given WCS solution]:file:_files' \
  '--verify-ext=[FITS extension of WCS to verify]:n:' \
  '--options=[print the augment-xylist options]' \
  '*:image:_files -g "*.(fits|fit|fts|FITS|FIT|FTS|jpg|jpeg|png|tiff|tif|xyls|axy)"' && ret=0

return ret
