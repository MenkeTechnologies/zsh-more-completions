#compdef pdftotext

_arguments -s \
  '(- *)-v[show version]' \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-f=[first page to convert]:n:' \
  '-l=[last page to convert]:n:' \
  '-r=[resolution DPI]:dpi:' \
  '-x=[crop x]:px:' \
  '-y=[crop y]:px:' \
  '-W=[crop width]:px:' \
  '-H=[crop height]:px:' \
  '-layout[maintain original physical layout]' \
  '-fixed=[character width for layout]:n:' \
  '-raw[keep text in content stream order]' \
  '-nodiag[discard diagonal text]' \
  '-htmlmeta[generate HTML with metadata]' \
  '-bbox[output bounding box]' \
  '-bbox-layout[output bounding box layout]' \
  '-tsv[output as TSV]' \
  '-cropbox[use CropBox instead of MediaBox]' \
  '-colspacing=[column spacing]:n:' \
  '-enc=[output text encoding]:encoding:' \
  '-listenc[list available encodings]' \
  '-eol=[end-of-line convention]:eol:(unix dos mac)' \
  '-nopgbrk[do not insert page breaks]' \
  '-opw=[owner password]:password:' \
  '-upw=[user password]:password:' \
  '-q[do not print errors]' \
  '*:input:_files -g "*.pdf"'
