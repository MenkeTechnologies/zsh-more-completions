#compdef qsampler
# _qsampler — Qt frontend for LinuxSampler (rncbc/qsampler)
# upstream: https://github.com/rncbc/qsampler
# Flags from src/qsamplerOptions.cpp (QCommandLineParser).

_qsampler() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-s --start)'{-s,--start}'[start linuxsampler server locally]' \
        '(-n --hostname)'{-n+,--hostname=}'[linuxsampler server hostname (default localhost)]:name:' \
        '(-p --port)'{-p+,--port=}'[linuxsampler server port (default 8888)]:num:' \
        '*:session file:_files -g "*.lscp"'
}

_qsampler "$@"
