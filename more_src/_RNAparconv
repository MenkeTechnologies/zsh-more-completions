#compdef RNAparconv
# RNAparconv — convert energy parameter files from ViennaRNA 1.8.4 to 2.0 format (ViennaRNA)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--detailed-help[print help with all details and hidden options]' \
  '--full-help[print help including hidden options]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-i --input)'{-i,--input}'=[specify input file (stdin if missing)]:file:_files' \
  '(-o --output)'{-o,--output}'=[specify output file (stdout if missing)]:file:_files' \
  '--vanilla[minimal output; overrides other settings]' \
  '--dump[dump 1.8.4 parameters in 2.0 format; skip input]' \
  '--silent[suppress non-parameter output]' \
  '--without-HairpinE[exclude hairpin energies/enthalpies]' \
  '--without-StackE[exclude stacking energies/enthalpies]' \
  '--without-IntE[exclude internal loop parameters]' \
  '--without-BulgeE[exclude bulge loop parameters]' \
  '--without-MultiE[exclude multi-loop parameters]' \
  '--without-MismatchE[exclude exterior loop mismatch parameters]' \
  '--without-MismatchH[exclude hairpin mismatch parameters]' \
  '--without-MismatchI[exclude internal loop mismatch parameters]' \
  '--without-MismatchM[exclude multi-loop mismatch parameters]' \
  '--without-Dangle5[exclude 5 prime dangle parameters]' \
  '--without-Dangle3[exclude 3 prime dangle parameters]' \
  '--without-Misc[exclude misc parameters (TerminalAU, DuplexInit, lxc)]' \
  '--log-level=[set log level threshold]:level' \
  '--log-file=[print log messages to file]::file:_files' \
  '--log-time[include timestamp in log messages]' \
  '--log-call[include file and line of logging function]' && ret=0

return ret
