#compdef grype2
# _grype2 — Anchore grype2 CLI command-line frontend wrapping the Grype vulnerability scanner for container images and filesystems open-source written in Go scans the contents of a container image or filesystem to find known vulnerabilities supports Alpine Amazon Linux Busybox CentOS Debian Distroless Oracle Linux Red Hat RHEL SLES Photon OS Ubuntu Wolfi auto-update-DB Java Go Python Ruby Node.js Rust .NET Cargo Conan Cocoapods Composer Conda DotNet Erlang Gem Github Hex Linux-kernel Maven NPM-Yarn Nuget Pub Swift only-fixed only-notfixed (Anchore team, Go); cobra
# upstream: https://github.com/anchore/grype

_grype2() {
    local -a sub=(
        'db:DB operations'
        'completion:generate shell completion'
        'version:show version'
        'explain:explain a vulnerability'
        'config:show config'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g ".grype.yaml *.yaml *.yml"' \
        '--config=+[file]:file:_files -g ".grype.yaml *.yaml *.yml"' \
        '-o+[output format]:f:(table json cyclonedx cyclonedx-json sarif template)' \
        '--output=+[fmt]:f:(table json cyclonedx cyclonedx-json sarif template)' \
        '*-o+[output format]:f:(table json cyclonedx cyclonedx-json sarif template)' \
        '-f+[fail-on severity]:s:(negligible low medium high critical)' \
        '--fail-on=+[s]:s:(negligible low medium high critical)' \
        '-s+[scope]:s:(squashed all-layers)' \
        '--scope=+[s]:s:(squashed all-layers)' \
        '-t+[template]:file:_files -g "*.tmpl"' \
        '--template=+[t]:file:_files -g "*.tmpl"' \
        '--file=+[file]:file:_files' \
        '--only-fixed[only fixed]' \
        '--only-notfixed[only not fixed]' \
        '--ignore-states=+[states]:str:' \
        '--exclude=+[paths]:str:' \
        '*--exclude=+[paths]:str:' \
        '--add-cpes-if-none[add CPEs if none]' \
        '--by-cve[map GHSA to CVE]' \
        '--distro=+[distro:version]:str:' \
        '--show-suppressed[show suppressed]' \
        '--platform=+[os/arch]:str:' \
        '--name=+[name]:str:' \
        '--vex=+[vex docs]:str:' \
        '*--vex=+[vex docs]:str:' \
        '--registry-auth=+[u:p]:str:' \
        '*--registry-auth=+[u:p]:str:' \
        '--registry-url=+[url]:str:' \
        '--registry-token=+[token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'grype subcommand' sub ;;
        args)
            case $words[1] in
                db) _arguments '1:op:(check list status update import delete diff)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                explain) _arguments '*:cve:' ;;
            esac
            ;;
    esac
}

_grype2 "$@"
