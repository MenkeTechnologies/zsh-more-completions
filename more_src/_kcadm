#compdef kcadm

# Zsh completion for kcadm - Keycloak identity admin CLI

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'config:Set up credentials and configure request defaults'
  'create:Create a new resource'
  'delete:Delete a resource'
  'get:Get a resource'
  'get-roles:List roles for a user or group'
  'add-roles:Add realm or client roles to a user or group'
  'remove-roles:Remove realm or client roles from a user or group'
  'set-password:Set password for a user'
  'update:Update a resource'
  'help:Display help information'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'kcadm command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      config)
        _arguments \
          '1:subcommand:(credentials truststore)' \
          '--server=[server URL]:url' \
          '--realm=[realm name]:realm' \
          '--user=[admin username]:user' \
          '--password=[admin password]:password' \
          '--client=[client id]:client' \
          '--secret=[client secret]:secret' && ret=0
        ;;
      create)
        _arguments \
          '1:endpoint' \
          '(-r --target-realm)'{-r,--target-realm}'=[target realm]:realm' \
          '(-s --set)'{-s,--set}'=[set attribute value]:key=value' \
          '(-f --file)'{-f,--file}'=[JSON file with resource attributes]:file:_files' \
          '(-o --output)'{-o,--output}'[print the created resource]' \
          '--fields=[fields to output]:fields' \
          '--format=[output format]:format:(csv json)' \
          '--compressed[minimize output]' && ret=0
        ;;
      get)
        _arguments \
          '1:endpoint' \
          '(-r --target-realm)'{-r,--target-realm}'=[target realm]:realm' \
          '--fields=[fields to output]:fields' \
          '--format=[output format]:format:(csv json)' \
          '--offset=[paging offset]:offset' \
          '--limit=[max results]:limit' \
          '(-q --query)'{-q,--query}'=[query parameters]:query' \
          '--compressed[minimize output]' && ret=0
        ;;
      update)
        _arguments \
          '1:endpoint' \
          '(-r --target-realm)'{-r,--target-realm}'=[target realm]:realm' \
          '(-s --set)'{-s,--set}'=[set attribute value]:key=value' \
          '(-d --delete)'{-d,--delete}'=[remove an attribute]:key' \
          '(-f --file)'{-f,--file}'=[JSON file with resource attributes]:file:_files' \
          '(-o --output)'{-o,--output}'[print the updated resource]' \
          '--fields=[fields to output]:fields' \
          '--format=[output format]:format:(csv json)' \
          '--merge[merge attributes]' \
          '--compressed[minimize output]' && ret=0
        ;;
      delete)
        _arguments \
          '1:endpoint' \
          '(-r --target-realm)'{-r,--target-realm}'=[target realm]:realm' && ret=0
        ;;
      set-password)
        _arguments \
          '(-r --target-realm)'{-r,--target-realm}'=[target realm]:realm' \
          '--username=[target username]:username' \
          '--userid=[target user id]:userid' \
          '(-p --new-password)'{-p,--new-password}'=[new password]:password' \
          '--temporary[set as temporary password]' && ret=0
        ;;
      add-roles|remove-roles|get-roles)
        _arguments \
          '(-r --target-realm)'{-r,--target-realm}'=[target realm]:realm' \
          '--uusername=[target username]:username' \
          '--uid=[target user id]:userid' \
          '--gname=[target group name]:group' \
          '--gid=[target group id]:groupid' \
          '--rolename=[role name]:role' \
          '--roleid=[role id]:roleid' \
          '--cclientid=[client id for client roles]:client' \
          '--cid=[client UUID for client roles]:clientuuid' && ret=0
        ;;
    esac
    ;;
esac

return ret
