#compdef gpreload
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpreload.html
# Reload Greenplum Database table data sorting the data based on specified columns

local ret=1

_arguments -s -S \
  '(-h -? --help)'{-h,-\?,--help}'[display help information]' \
  '--version[display the utility version]' \
  '-d[database containing tables to reload]:database' \
  '-p[Greenplum coordinator port]:port' \
  '(-t --table-file)'{-t,--table-file}'=[file listing tables and columns to reload]:file:_files' \
  '-a[skip user confirmation prompts]' && ret=0

return ret
