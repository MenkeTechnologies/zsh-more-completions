#compdef redbean redbean.com
# Documentation: https://man.archlinux.org/search?q=redbean
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-d[daemonize]' \
  '-D+[document root]:dir:_files -/' \
  '-l+[listen address]:addr:' \
  '-p+[listen port]:port:' \
  '-w+[workers]:n:' \
  '-G+[group]:group:_groups' \
  '-U+[user]:user:_users' \
  '-c+[chmod]:mode:' \
  '-i[interpret as Lua interpreter]' \
  '-e+[evaluate Lua code]:code:' \
  '-A+[asset path]:asset:' \
  '-C+[ssl client cert]:file:_files' \
  '-K+[ssl key]:file:_files' \
  '-X+[ssl client trust]:file:_files' \
  '-L+[log file]:file:_files' \
  '-P+[pid file]:file:_files' \
  '-B[blackhole errors]' \
  '-Z+[zip path inside]:zip:' \
  '-Y+[redirect zip]:redir:' \
  '*:zip:_files -g "*.{zip,com}"' && ret=0

return ret
