#compdef mr

# Zsh completion for mr (myrepos) - manage multiple repositories

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'checkout:check out repositories'
  'update:update repositories'
  'status:show status of repositories'
  'commit:commit changes in repositories'
  'diff:show diffs in repositories'
  'log:show logs in repositories'
  'push:push changes in repositories'
  'pull:pull changes in repositories'
  'run:run arbitrary command in repositories'
  'register:register a repository in the config file'
  'config:modify configuration'
  'list:list registered repositories'
  'ls:list registered repositories'
  'bootstrap:bootstrap repositories from config URL'
  'online:mark available for network access'
  'offline:mark unavailable for network access'
  'remember:remember command to run when back online'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-d+[specify directory to work in]:directory:_files -/' \
  '-c+[specify config file]:config file:_files' \
  '-f[force operations]' \
  '-v[be verbose]' \
  '-q[be quiet]' \
  '-s[short output]' \
  '-n[no recurse / dry run]' \
  '-j+[number of parallel jobs]:number of jobs' \
  '-t[trust all mrconfig files]' \
  '--minimal[minimize output]' \
  '--stats[show statistics]' \
  '-p+[search path]:path:_files -/' \
  '-i[interactive mode]' \
  '1:subcommand:->subcmd' \
  '*::arguments:->args' \
  && ret=0

case "$state" in
  subcmd)
    _describe -t subcommands 'mr subcommand' subcommands && ret=0
    ;;
  args)
    case "${line[1]}" in
      run)
        _command_names -e && ret=0
        ;;
      bootstrap)
        _urls && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
