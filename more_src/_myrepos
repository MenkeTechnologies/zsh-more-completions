#compdef mr
# Documentation: https://manpages.debian.org/bookworm/myrepos/mr.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mr (myrepos) - manage multiple repositories

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'checkout:check out repositories'
  'co:check out repositories'
  'update:update repositories'
  'status:show status of repositories'
  'clean:clean repositories'
  'commit:commit changes in repositories'
  'ci:commit changes in repositories'
  'record:record changes in repositories'
  'fetch:fetch updates in repositories'
  'diff:show diffs in repositories'
  'log:show logs in repositories'
  'grep:grep across repositories'
  'push:push changes in repositories'
  'run:run arbitrary command in repositories'
  'bootstrap:bootstrap repositories from config URL'
  'register:register a repository in the config file'
  'config:modify configuration'
  'list:list registered repositories'
  'ls:list registered repositories'
  'online:mark available for network access'
  'offline:mark unavailable for network access'
  'remember:remember command to run when back online'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --directory)'{-d+,--directory=}'[specify directory to work in]:directory:_files -/' \
  '(-c --config)'{-c+,--config=}'[specify config file]:config file:_files' \
  '(-f --force)'{-f,--force}'[force operations]' \
  '--force-env[execute despite dangerous environment variables]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-q --quiet)'{-q,--quiet}'[be quiet]' \
  '(-s --stats)'{-s,--stats}'[show statistics]' \
  '(-m --minimal)'{-m,--minimal}'[minimize output]' \
  '(-n --no-recurse)'{-n,--no-recurse}'[limit recursion]' \
  '(-j --jobs)'{-j+,--jobs=}'[number of parallel jobs]:number:' \
  '(-t --trust-all)'{-t,--trust-all}'[trust all mrconfig files]' \
  '(-k --insecure)'{-k,--insecure}'[accept untrusted SSL certificates]' \
  '(-i --interactive)'{-i,--interactive}'[interactive subshell on failure]' \
  '--cache[save command output to cache]' \
  '--cached[use cached output]' \
  '--uncache[clear cached output]' \
  '--top[change to repo top before commands]' \
  '(-p --path)'{-p+,--path=}'[obsolete; ignored]:path:_files -/' \
  '1:subcommand:->subcmd' \
  '*::arguments:->args' \
  && ret=0

case "$state" in
  subcmd)
    _describe -t subcommands 'mr subcommand' subcommands && ret=0
    ;;
  args)
    case "${line[1]}" in
      run)
        _command_names -e && ret=0
        ;;
      bootstrap)
        _urls && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
