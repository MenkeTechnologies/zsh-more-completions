#compdef scil_labels_combine
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_labels_combine.html
# Scilpy: combine labels from multiple volumes into one

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--volume_ids=[volumes followed by their labels]:ids:_files' \
  '--out_labels_ids=[output label indices]:ids' \
  '--unique[keep only unique labels]' \
  '--group_in_m[group labels in millions]' \
  '--background=[background label id]:id' \
  '--merge_groups[merge groups of labels]' \
  '--not_save_empty[do not save empty result]' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:output:_files' && ret=0

return ret
