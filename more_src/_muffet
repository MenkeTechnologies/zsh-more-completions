#compdef muffet
# Documentation: https://raviqqe.com/muffet/usage
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--accepted-status-codes=[accepted HTTP response status codes]:codes' \
  '(-b --buffer-size)'{-b,--buffer-size}'=[HTTP response buffer size in bytes]:size' \
  '(-c --max-connections)'{-c,--max-connections}'=[max number of HTTP connections]:count' \
  '--max-connections-per-host=[max connections per host]:count' \
  '--max-response-body-size=[max response body size]:size' \
  '*'{-e,--exclude}'=[exclude URLs matched with given regex]:pattern' \
  '*'{-i,--include}'=[include URLs matched with given regex]:pattern' \
  '--follow-robots-txt[follow robots.txt when scraping pages]' \
  '--follow-sitemap-xml[scrape only pages listed in sitemap.xml]' \
  '*--header=[custom headers]:header' \
  '(-f --ignore-fragments)'{-f,--ignore-fragments}'[ignore URL fragments]' \
  '--max-retries=[max retry count for network errors]:count' \
  '--dns-resolver=[custom DNS resolver]:address' \
  '--format=[output format]:format:(text json junit)' \
  '(-r --max-redirections)'{-r,--max-redirections}'=[max number of redirections]:count' \
  '--rate-limit=[max requests per second]:rate' \
  '(-t --timeout)'{-t,--timeout}'=[timeout for HTTP requests in seconds]:seconds' \
  '(-v --verbose)'{-v,--verbose}'[show successful results too]' \
  '--proxy=[HTTP proxy host]:host' \
  '--skip-tls-verification[skip TLS certificate verification]' \
  '--one-page-only[only check links found in the given URL]' \
  '--color=[color output]:when:(auto always never)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:url' && ret=0
return ret
