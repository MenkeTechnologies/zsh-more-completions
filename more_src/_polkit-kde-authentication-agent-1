# polkit-kde-authentication-agent-1: PolKit auth agent for KDE Plasma
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '*::polkit-kde-authentication-agent-1 args:_files' && ret=0
return ret
