#compdef sfltool

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'csinfo:show code-signing info'
  'dumpbtm:dump background task management state'
  'archive:archive launch services lists'
  'clear:clear the launch services list'
  'resetbtm:reset BTM database'
  'resetlist:reset launch services list'
  'list:list launch services items'
  'list-info:show info for list items'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sfltool subcommand' subcommands && ret=0
    ;;
esac

return ret
