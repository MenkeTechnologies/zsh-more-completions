#compdef mstconfig mlxconfig
# Documentation: https://docs.nvidia.com/networking/display/mftv4260/mlxconfig+%E2%80%93+changing+device+configuration+tool
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'query:query the supported configurations'
  'set:set configurations'
  'reset:reset configurations to default'
  'clear_semaphore:clear tool semaphore'
  'set_raw:apply raw TLV configuration file'
  'get_raw:dump raw TLV configuration'
  'show_confs:show information about all configurations'
  'backup:save current TLV to file'
  'gen_tlvs_file:generate file listing supported configurations'
  'gen_xml_template:create XML template'
  'xml2raw:convert XML to raw TLV'
  'xml2bin:convert XML to binary dump'
  'create_conf:create NV configuration file'
  'apply:apply NV configurations to firmware'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '(-d --dev)'{-d+,--dev=}'[mst device]:dev:' \
  '(-f --file)'{-f+,--file=}'[configuration file]:file:_files' \
  '(-y --yes)'{-y,--yes}'[answer yes to prompts]' \
  '--enable_verbosity[show default and current configurations]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mlxconfig command' commands && ret=0 ;;
esac
return ret
