#compdef appsignal-cli appsignal
# _appsignal-cli — AppSignal appsignal-cli CLI command-line frontend wrapping the AppSignal application performance monitoring error tracking host metrics anomaly detection log management uptime monitoring platform CLI providing install demo deploy diagnose notify update push app namespace check user organization marker source-map upload-source-map magic-dashboard custom-metrics-Slack-OpsGenie-PagerDuty-webhook (AppSignal team, Ruby/Elixir/Node); thor
# upstream: https://www.appsignal.com/

_appsignal-cli() {
    local -a sub=(
        'install:install client'
        'demo:send demo data'
        'diagnose:run diagnose'
        'deploy:report a deployment'
        'notify:notify an event'
        'update:update gem'
        'push:push namespace'
        'app:application operations'
        'namespace:namespace operations'
        'check:check operations'
        'user:user operations'
        'organization:organization operations'
        'marker:marker operations'
        'source-map:source map operations'
        'upload-source-map:upload source map'
        'magic-dashboard:magic dashboard ops'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--push-api-key=+[key]:str:' \
        '--app-name=+[name]:str:' \
        '-a+[app]:str:' \
        '--app-id=+[id]:str:' \
        '--environment=+[env]:str:' \
        '-e+[env]:str:' \
        '--namespace=+[name]:str:' \
        '--revision=+[sha]:str:' \
        '--user=+[name]:_users' \
        '--message=+[text]:str:' \
        '--frontend=+[v]:v:(true false)' \
        '--app-version=+[v]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "appsignal.yml *.yml"' \
        '--config=+[file]:file:_files -g "appsignal.yml *.yml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'appsignal subcommand' sub ;;
        args)
            case $words[1] in
                deploy|notify) _arguments '*:arg:' ;;
                source-map|upload-source-map) _arguments '*:file:_files -g "*.map *.js"' ;;
                app|namespace|check|user|organization|marker) _arguments '1:op:(list get create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_appsignal-cli "$@"
