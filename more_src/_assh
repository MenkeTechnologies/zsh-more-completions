#compdef assh
# Documentation: https://github.com/moul/assh
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# moul/assh v2 — pkg/commands/*.go (cobra + viper)

local curcontext="$curcontext" state line ret=1

local -a ctx_cmds=(
  'build:render ~/.ssh/config from assh.yml'
  'json:dump config as JSON'
  'list:list configured hosts'
  'graphviz:emit Graphviz graph'
  'search:search hosts by text'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[print usage]' \
  '(-D --debug)'{-D,--debug}'[debug logging]' \
  '(-V --verbose)'{-V,--verbose}'[verbose logging]' \
  '--config=[assh config file]:file:_files' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    local -a top=(
      'ping:ssh reachability probe'
      'connect:hidden proxy connector (ProxyCommand)'
      'info:print environment and config stats'
      'config:manage ssh/assh configuration'
      'sockets:manage control sockets'
      'wrapper:hidden ssh wrapper'
    )
    _describe -t commands 'assh command' top && ret=0
    ;;
  (rest)
    case $line[1] in
      (ping)
        _arguments -s -S \
          '--no-rewrite[do not rewrite outdated config]' \
          '(-p)'{-p+,--port=}'[ssh port]:port:' \
          '(-c)'{-c+,--count=}'[stop after N probes]:count:' \
          '(-i)'{-i+,--wait=}'[seconds between probes]:seconds:' \
          '--o[exit after first successful reply]' \
          '(-W)'{-W+,--waittime=}'[per-packet reply timeout seconds]:seconds:' \
          '1:host:_hosts' && ret=0
        ;;
      (connect)
        _arguments -s -S \
          '--no-rewrite[do not rewrite outdated config]' \
          '(-p)'{-p+,--port=}'[ssh port]:port:' \
          '--dry-run[print connection plan only]' \
          '1:host:_hosts' && ret=0
        ;;
      (info)
        _nothing && ret=0
        ;;
      (config)
        if (( $#line == 1 )); then
          _describe -t commands 'assh config' ctx_cmds && ret=0
        else
          case $line[2] in
            (build)
              _arguments -s -S \
                '--no-automatic-rewrite[disable automatic ssh config regen]' \
                '(-e)'{-e,--expand}'[expand all hosts]' \
                '--ignore-known-hosts[ignore known_hosts]' && ret=0
              ;;
            (json)
              _arguments -s -S '(-e)'{-e,--expand}'[expand all hosts]' && ret=0
              ;;
            (list)
              _arguments -s -S '(-e)'{-e,--expand}'[expand all hosts]' && ret=0
              ;;
            (graphviz)
              _arguments -s -S \
                '--show-isolated-hosts[show isolated hosts]' \
                '--no-resolve-wildcard[do not expand gateway wildcards]' \
                '--no-inheritance-links[hide inheritance edges]' && ret=0
              ;;
            (search)
              _arguments -s -S '1:needle:' && ret=0
              ;;
            (*)
              _default && ret=0
              ;;
          esac
        fi
        ;;
      (sockets)
        if (( $#line == 1 )); then
          local -a sk=(
            'list:list control sockets'
            'flush:close control sockets'
            'master:open a master control socket'
          )
          _describe -t commands 'assh sockets' sk && ret=0
        else
          _default && ret=0
        fi
        ;;
      (wrapper)
        if (( $#line == 1 )); then
          _describe -t commands 'assh wrapper' '(ssh:wrap real ssh)' && ret=0
        else
          _arguments '*:ssh args: _default' && ret=0
        fi
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
