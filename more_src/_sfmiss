#compdef sfmiss
# Documentation: https://github.com/ahay/src/blob/master/user/gee/Mmiss.c
# Madagascar: multi-dimensional missing data interpolation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'prec=[if y, use preconditioning]:flag:(y n)' \
  'niter=[number of iterations]:count' \
  'exact=[if y, preserve known data values when prec=y]:flag:(y n)' \
  'eps=[regularization parameter]:value' \
  'padin=[pad beginning]:samples' \
  'padout=[pad end]:samples' \
  'lag=[optional input file with filter lags]:file:_files' \
  'mask=[optional input mask file for known data]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
