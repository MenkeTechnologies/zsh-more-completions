#compdef birdfont-export
# Documentation: https://man.archlinux.org/man/birdfont-export.1.en
# Generate TTF, EOT and SVG files from birdfont files

local ret=1

_arguments -s -S \
  '--filter[include only these characters]:characters:' \
  '(-h --help)'{-h,--help}'[print command line options]' \
  '(-o --output)'{-o,--output}'[write files to this directory]:directory:_files -/' \
  '(-s --svg)'{-s,--svg}'[write SVG font]' \
  '(-t --ttf)'{-t,--ttf}'[write TTF and EOT fonts]' \
  '*:file:_files' && ret=0

return ret
