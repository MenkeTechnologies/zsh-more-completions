#compdef bloomrpc
# _bloomrpc — BloomRPC gRPC GUI client CLI alias (BloomRPC team, JavaScript/Electron); custom argparse
# upstream: https://github.com/bloomrpc/bloomrpc

_bloomrpc() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--proto=+[proto file]:file:_files -g "*.proto"' \
        '-p+[proto file]:file:_files -g "*.proto"' \
        '--proto-path=+[proto path]:list:_files -/' \
        '-I+[proto path]:list:_files -/' \
        '--reflect[server reflection]' \
        '-r[server reflection]' \
        '--no-sandbox[no sandbox]' \
        '*:arg:'
}

_bloomrpc "$@"
