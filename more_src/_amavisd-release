#compdef amavisd-release
# Documentation: https://www.unix.com/man-page/osx/8/AMAVISD-RELEASE/
# release a quarantined mail message via the AM.PDP protocol

local ret=1

_arguments -s -S \
  '-D[enable debug output]' \
  '1:mail file:_files' \
  '2:secret id:' \
  '*:alt recipient:_email_addresses' && ret=0

return ret
