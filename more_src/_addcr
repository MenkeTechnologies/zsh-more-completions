#compdef addcr
# _addcr — DJB ucspi-tcp addcr (turn each LF on stdin into CR LF on stdout; a tiny filter used to make UNIX-line-ending output match internet text-protocol conventions)
# upstream: https://github.com/schmonz/ucspi-tcp
# Source: addcr.c on tip; no flags.

_addcr() {
    _arguments '(- *)-h[show help]'
}

_addcr "$@"
