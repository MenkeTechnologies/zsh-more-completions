#compdef sematic
# Documentation: https://github.com/sematic-ai/sematic/blob/main/sematic/cli
# Sematic open-source ML pipeline orchestrator CLI

local ret=1
local context state line
typeset -A opt_args

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'start:launch the Sematic web server locally'
      'stop:terminate the running Sematic application'
      'run:run a pipeline script'
      'cancel:cancel all unfinished runs in a pipeline'
      'new:create a new project from a template'
      'logs:print logs for a run'
      'clean:clean orphaned or stale runs and resources'
      'migrate:run database migrations'
      'settings:manage user settings'
      'version:print the Sematic version'
    )
    _describe -t commands 'sematic command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s \
          '--build[build the container image before running]' \
          '--no-cache[do not use cached layers when building]' \
          '--log-level=[set the log level]:level:(DEBUG INFO WARNING ERROR)' \
          '1:script path:_files' \
          '*:script arguments:' && ret=0
        ;;
      new)
        _arguments -s \
          '--from=[create the project from an example]:example:' \
          '1:project name:' && ret=0
        ;;
      logs)
        _arguments -s \
          '(-f --follow)'{-f,--follow}'[follow the log output]' \
          '1:run id:' && ret=0
        ;;
      clean)
        _arguments -s \
          '--orphaned-runs[clean orphaned runs]' \
          '--stale-pipeline-runs[clean stale pipeline runs]' \
          '--zombie-pipeline-runs[clean zombie pipeline runs]' \
          '--orphaned-jobs[clean orphaned jobs]' \
          '--orphaned-resources[clean orphaned external resources]' \
          '--force[skip confirmation prompts]' && ret=0
        ;;
      cancel)
        _arguments '1:run id:' && ret=0
        ;;
      settings)
        local -a sub
        sub=(
          'set:set a settings variable'
          'show:show active settings'
          'delete:delete a settings variable'
        )
        _describe -t subcommands 'settings subcommand' sub && ret=0
        ;;
      *)
        ret=0
        ;;
    esac
    ;;
esac

return ret
