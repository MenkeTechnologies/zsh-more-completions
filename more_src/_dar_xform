#compdef dar_xform
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/dar_xform.1.html
# dar_xform - disk archive "re-slicer", changes the slicing of an existing dar archive

local ret=1

_arguments -s \
  '-h[display help usage]' \
  '-V[display version information]' \
  '-b[make terminal ring when user interaction is required]' \
  '-s[size of the slices in bytes (suffixes k M G T P)]:slice size' \
  '-S[size of the first slice (requires -s)]:first slice size' \
  '-p[pause before writing to a new slice (optional every-n)]::pause every n slices' \
  '-n[do not allow overwriting of any slice]' \
  '-w[do not warn before overwriting slice]' \
  '-E[command to execute between slices of destination archive]:command' \
  '-F[command to execute between slices of source archive]:command' \
  '-aSI[use SI size prefixes (multiples of 10^3)]' \
  '-abinary[use binary size prefixes (multiples of 2^10)]' \
  '-Q[suppress stderr messages when not run from a terminal]' \
  '-^[permission and ownership for created slices]:perm[\:user[\:group]]' \
  '-3[generate on-the-fly hash file (md5 or sha1)]:algorithm:(md5 sha1)' \
  '-9[minimum number of digits for slice numbers]:src_num[,dst_num]' \
  '*:archive:_files' && ret=0

return ret
