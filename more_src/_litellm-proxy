#compdef litellm-proxy
# Documentation: https://github.com/BerriAI/litellm
# Reference accessed: 2026-05-22
# Verified: litellm/proxy/client/cli/main.py and commands/*.py Click CLI.

# Zsh completion for litellm-proxy - LiteLLM proxy server management CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show CLI and server version]' \
  '--base-url[LiteLLM proxy server URL]:url:' \
  '--api-key[API key for authentication]:key:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'litellm-proxy command' \
      'version[show CLI and server version]' \
      'login[authenticate with proxy server]' \
      'logout[clear stored credentials]' \
      'whoami[show current authentication]' \
      'models[manage proxy models]' \
      'credentials[manage credentials]' \
      'chat[interactive chat with proxy models]' \
      'http[send HTTP requests via proxy]' \
      'keys[manage proxy API keys]' \
      'teams[manage teams]' \
      'users[manage users]' && ret=0
    ;;
  args)
    case $line[1] in
      version|login|logout|whoami|chat) ret=0 ;;
      http)
        if (( CURRENT == 2 )); then
          _values 'http command' 'request[send HTTP request]' && ret=0
        fi
        ;;
      models)
        if (( CURRENT == 2 )); then
          _values 'models command' \
            'list[list models]' \
            'add[add model]' \
            'delete[delete model]' \
            'get[get model]' \
            'info[get models info]' \
            'update[update model]' \
            'import[import models from YAML]' && ret=0
        fi
        ;;
      keys)
        if (( CURRENT == 2 )); then
          _values 'keys command' \
            'list[list keys]' \
            'generate[generate key]' \
            'delete[delete keys]' \
            'import[import keys]' && ret=0
        fi
        ;;
      teams)
        if (( CURRENT == 2 )); then
          _values 'teams command' \
            'list[list teams]' \
            'available[list available teams]' \
            'assign-key[assign key to team]' && ret=0
        fi
        ;;
      users)
        if (( CURRENT == 2 )); then
          _values 'users command' \
            'list[list users]' \
            'get[get user]' \
            'create[create user]' \
            'delete[delete users]' && ret=0
        fi
        ;;
      credentials)
        if (( CURRENT == 2 )); then
          _values 'credentials command' \
            'list[list credentials]' \
            'create[create credential]' \
            'delete[delete credential]' \
            'get[get credential]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
