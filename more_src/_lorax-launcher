#compdef lorax-launcher
# Documentation: https://github.com/predibase/lorax/blob/main/launcher/src/main.rs
# LoRAX multi-LoRA inference server launcher

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model-id=[model id from HuggingFace hub or local path]:model id:' \
  '--adapter-id=[optional LoRA adapter model id]:adapter id:' \
  '--source=[model source]:source:(hub s3)' \
  '--default-adapter-source=[default source for dynamic adapters]:source:(hub s3 pbase)' \
  '--adapter-source=[source for static adapter loading]:source:(hub s3 pbase)' \
  '--revision=[model revision commit or branch]:revision:' \
  '--validation-workers=[number of tokenizer validation workers]:workers:' \
  '--sharded=[shard model across GPUs]:bool:(true false)' \
  '--num-shard=[number of GPU shards]:num:' \
  '--quantize=[quantization method]:method:(awq eetq exl2 gptq bitsandbytes bitsandbytes-nf4 bitsandbytes-fp4 hqq-4bit hqq-3bit hqq-2bit fp8)' \
  '--compile[enable CUDA graph compilation]' \
  '--eager[run in eager mode without CUDA compilation]' \
  '--compile-max-batch-size=[max batch size before disabling CUDA graphs]:size:' \
  '--compile-max-rank=[max adapter rank before disabling CUDA graphs]:rank:' \
  '--compile-batch-size=[initial batch size for CUDA compilations]:size:' \
  '--speculative-tokens=[number of speculative tokens per step]:num:' \
  '--speculation-max-batch-size=[max batch size for speculative decoding]:size:' \
  '--preloaded-adapter-ids=[adapter ids to preload]:ids:' \
  '--preloaded-adapter-source=[source for preloaded adapters]:source:' \
  '--predibase-api-token=[Predibase API token]:token:' \
  '--dtype=[model data type]:dtype:(float16 bfloat16)' \
  '--trust-remote-code[execute custom hub modeling code]' \
  '--max-concurrent-requests=[max concurrent inference requests]:num:' \
  '--max-best-of=[max best_of value]:num:' \
  '--max-stop-sequences=[max number of stop sequences]:num:' \
  '--max-input-length=[max input sequence length in tokens]:len:' \
  '--max-total-tokens=[max total tokens prompt plus generation]:tokens:' \
  '--waiting-served-ratio=[ratio for batching waiting vs running queries]:ratio:' \
  '--max-batch-prefill-tokens=[token limit for prefill operations]:tokens:' \
  '--max-batch-total-tokens=[total tokens allowed per batch]:tokens:' \
  '--max-waiting-tokens=[token threshold before forcing waiting into batch]:tokens:' \
  '--eager-prefill[prioritize prefill before decode]' \
  '--chunked-prefill[split prefill requests for batching]' \
  '--prefix-caching[enable prefix caching]' \
  '--merge-adapter-weights[merge adapter weights with base model]' \
  '--max-active-adapters=[max adapters on GPU accepting requests]:num:' \
  '--adapter-cycle-time-s=[seconds between adapter GPU exchanges]:sec:' \
  '--adapter-memory-fraction=[GPU memory reserved for adapters]:frac:' \
  '--hostname=[IP address to listen on]:host:' \
  '--port=[port number for server]:port:' \
  '--shard-uds-path=[unix domain socket path for shard comm]:path:_files' \
  '--master-addr=[master shard address]:addr:' \
  '--master-port=[master shard port]:port:' \
  '--huggingface-hub-cache=[override HuggingFace hub cache dir]:dir:_files -/' \
  '--weights-cache-override=[override model weights cache location]:dir:_files -/' \
  '--disable-custom-kernels[disable custom CUDA kernels]' \
  '--cuda-memory-fraction=[limit CUDA available memory]:frac:' \
  '--json-output[output logs in JSON format]' \
  '--otlp-endpoint=[OpenTelemetry endpoint for tracing]:endpoint:' \
  '*--cors-allow-origin=[CORS allowed origin]:origin:' \
  '*--cors-allow-header=[CORS allowed header]:header:' \
  '*--cors-expose-header=[CORS exposed header]:header:' \
  '*--cors-allow-method=[CORS allowed HTTP method]:method:' \
  '--cors-allow-credentials=[CORS credentials support]:bool:(true false)' \
  '--watermark-gamma=[watermarking gamma parameter]:gamma:' \
  '--watermark-delta=[watermarking delta parameter]:delta:' \
  '--ngrok[enable ngrok tunneling]' \
  '--ngrok-authtoken=[ngrok authentication token]:token:' \
  '--ngrok-edge=[ngrok edge configuration]:edge:' \
  '--env[display runtime environment information]' \
  '--download-only[download weights without launching server]' \
  '--tokenizer-config-path=[path to tokenizer configuration file]:path:_files' \
  '--backend=[attention backend]:backend:(fa2 flashinfer)' \
  '--embedding-dim=[embedding dimension for the model]:dim:' \
  '--disable-sgmv[disable selective gemm vector operations]' \
  '--memory-wiggle-room=[memory buffer fraction for stability]:frac:' && ret=0

return ret
