#compdef kyverno-cleanup-controller cleanup-controller
# _kyverno-cleanup-controller — Kyverno CleanupPolicy reconciler + admission webhook (kyverno/kyverno)
# upstream: https://github.com/kyverno/kyverno
# Flags from cmd/cleanup-controller/main.go + cmd/internal/flag.go on tip.

_kyverno-cleanup-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--dumpPayload[log admission request payloads]' \
        '--serverIP=[Kyverno controller external IP (out-of-cluster only)]:ip:' \
        '--servicePort=[Kyverno Service port]:port:' \
        '--webhookServerPort=[webhook server bind port (deprecated)]:port:' \
        '--maxQueuedEvents=[max queued events]:n:' \
        '--ttlReconciliationInterval=[CleanupPolicy reconcile interval]:dur:' \
        '--caSecretName=[secret containing webhook CA]:name:' \
        '--tlsSecretName=[secret containing webhook TLS pair]:name:' \
        '--renewBefore=[cert renewal lead time]:dur:' \
        '--apiCallTimeout=[policy HTTP API call timeout]:dur:' \
        '--autoDeleteWebhooks=[auto-delete webhooks on shutdown]:bool:(true false)' \
        '--tlsKeyAlgorithm=[self-signed TLS key algorithm]:algo:(RSA ECDSA Ed25519)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--clientRateLimitQPS=[Kubernetes client QPS]:f:' \
        '--clientRateLimitBurst=[Kubernetes client burst]:n:' \
        '--resyncPeriod=[informer resync period]:dur:' \
        '--profile[enable pprof]' \
        '--profilePort=[pprof port]:port:' \
        '--metricsHost=[Prometheus metrics bind host]:host:' \
        '--metricsPort=[Prometheus metrics bind port]:port:' \
        '--enableTracing[enable OTLP tracing]' \
        '--loggingFormat=[log format]:fmt:(text json)' \
        '-v[klog verbosity level]:n:'
}

_kyverno-cleanup-controller "$@"
