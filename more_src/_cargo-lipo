#compdef cargo-lipo
# Documentation: https://man.archlinux.org/search?q=cargo-lipo
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)*'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--release)--release[release]' \
  '(--manifest-path)--manifest-path=[manifest]:file:_files -g "*.toml"' \
  '(-p --package)*'{-p+,--package=}'[package]:p:' \
  '(--features)--features=[features csv]:list:' \
  '(--all-features)--all-features[all features]' \
  '(--no-default-features)--no-default-features[no default]' \
  '(--targets)--targets=[targets csv]:list:(aarch64-apple-ios aarch64-apple-ios-sim x86_64-apple-ios aarch64-apple-darwin x86_64-apple-darwin)' \
  '(--xcode-integ)--xcode-integ[xcode integration]' \
  '(--profile)--profile=[profile]:p:(release dev)' \
  '(--target-dir)--target-dir=[target dir]:dir:_files -/' \
  '(--allow-run-on-non-macos)--allow-run-on-non-macos[allow on non-macOS]' \
  '*: :_files' && ret=0

return ret
