#compdef findscu
# Documentation: https://support.dcmtk.org/docs-snapshot/findscu.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmnet/apps/findscu.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmnet/apps/findscu.cc OFCommandLine setup + dcmnet/docs/findscu.man.

local -a _findscu_loglevels
_findscu_loglevels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet -v --verbose -d --debug)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-q --quiet -v --verbose -d --debug)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-q --quiet -v --verbose -d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll,--log-level}'[use level l for the logger]:level:('"${_findscu_loglevels[*]}"')' \
  '(-lc --log-config)'{-lc,--log-config}'[use config file f for the logger]:file:_files' \
  '*'{-k,--key}'[override matching key]:key (gggg,eeee=value):' \
  '(-W --worklist -P --patient -S --study -O --psonly)'{-W,--worklist}'[use modality worklist information model (default)]' \
  '(-W --worklist -P --patient -S --study -O --psonly)'{-P,--patient}'[use patient root information model]' \
  '(-W --worklist -P --patient -S --study -O --psonly)'{-S,--study}'[use study root information model]' \
  '(-W --worklist -P --patient -S --study -O --psonly)'{-O,--psonly}'[use patient/study only information model]' \
  '(-i4 --ipv4 -i6 --ipv6 -i0 --ip-auto)'{-i4,--ipv4}'[use IPv4 only (default)]' \
  '(-i4 --ipv4 -i6 --ipv6 -i0 --ip-auto)'{-i6,--ipv6}'[use IPv6 only]' \
  '(-i4 --ipv4 -i6 --ipv6 -i0 --ip-auto)'{-i0,--ip-auto}'[use DNS lookup to determine IP protocol]' \
  '(-aet --aetitle)'{-aet,--aetitle}'[set my calling AE title]:aetitle:' \
  '(-aec --call)'{-aec,--call}'[set called AE title of peer]:aetitle:' \
  '(+u --enable-new-vr -u --disable-new-vr)'{+u,--enable-new-vr}'[enable support for new VRs (UN/UT) (default)]' \
  '(+u --enable-new-vr -u --disable-new-vr)'{-u,--disable-new-vr}'[disable support for new VRs]' \
  '-x=[propose uncompressed TS, explicit VR (default)]' \
  '--propose-uncompr[propose uncompressed TS, explicit VR (default)]' \
  '-xe[propose uncompressed TS, explicit VR little endian first]' \
  '--propose-little[propose uncompressed TS, explicit VR little endian first]' \
  '-xb[propose uncompressed TS, explicit VR big endian first]' \
  '--propose-big[propose uncompressed TS, explicit VR big endian first]' \
  '-xd[propose deflated explicit VR little endian TS]' \
  '--propose-deflated[propose deflated explicit VR little endian TS]' \
  '-xi[propose implicit VR little endian TS only]' \
  '--propose-implicit[propose implicit VR little endian TS only]' \
  '(+cl --compression-level)'{+cl,--compression-level}'[set deflate compression level (0..9, default: 6)]:level:' \
  '(-to --timeout)'{-to,--timeout}'[timeout for connection requests]:seconds:' \
  '(-ts --socket-timeout)'{-ts,--socket-timeout}'[timeout for network socket]:seconds:' \
  '(-ta --acse-timeout)'{-ta,--acse-timeout}'[timeout for ACSE messages]:seconds:' \
  '(-td --dimse-timeout)'{-td,--dimse-timeout}'[timeout for DIMSE messages]:seconds:' \
  '(-pdu --max-pdu)'{-pdu,--max-pdu}'[set max receive pdu to n bytes (4096..131072)]:bytes:' \
  '--repeat[repeat n times]:number:' \
  '--abort[abort association instead of releasing it]' \
  '--cancel[cancel after n responses]:number:' \
  '(-tls --disable-tls +tls --enable-tls +tla --anonymous-tls)'{-tls,--disable-tls}'[use normal TCP/IP connection (default)]' \
  '(-tls --disable-tls +tls --enable-tls +tla --anonymous-tls)'{+tls,--enable-tls}'[use authenticated secure TLS connection]:private key:_files:certificate:_files' \
  '(-tls --disable-tls +tls --enable-tls +tla --anonymous-tls)'{+tla,--anonymous-tls}'[use secure TLS connection without certificate]' \
  '(+ps --std-passwd +pw --use-passwd -pw --null-passwd)'{+ps,--std-passwd}'[prompt user for password on stdin (default)]' \
  '(+ps --std-passwd +pw --use-passwd -pw --null-passwd)'{+pw,--use-passwd}'[use specified password]:password:' \
  '(+ps --std-passwd +pw --use-passwd -pw --null-passwd)'{-pw,--null-passwd}'[use empty string as password]' \
  '(-pem --pem-keys -der --der-keys)'{-pem,--pem-keys}'[read keys and certificates as PEM file (default)]' \
  '(-pem --pem-keys -der --der-keys)'{-der,--der-keys}'[read keys and certificates as DER file]' \
  '*'{+cf,--add-cert-file}'[add certificate file to list of certificates]:file:_files' \
  '*'{+cd,--add-cert-dir}'[add certificates in directory to list]:directory:_files -/' \
  '*'{+crl,--add-crl-file}'[add certificate revocation list file]:file:_files' \
  '+crv[enable leaf CRL verification]' \
  '--enable-crl-vfy[enable leaf CRL verification]' \
  '+cra[enable full chain CRL verification]' \
  '--enable-crl-all[enable full chain CRL verification]' \
  '(+ph --list-profiles)'{+ph,--list-profiles}'[list supported TLS profiles and exit]' \
  '+pg[BCP 195 RFC 8996 TLS Profile (default)]' \
  '--profile-8996[BCP 195 RFC 8996 TLS Profile (default)]' \
  '+pm[Modified BCP 195 RFC 8996 TLS Profile]' \
  '--profile-8996-mod[Modified BCP 195 RFC 8996 TLS Profile]' \
  '+py[Non-downgrading BCP 195 TLS Profile (retired)]' \
  '--profile-bcp195-nd[Non-downgrading BCP 195 TLS Profile (retired)]' \
  '+px[BCP 195 TLS Profile (retired)]' \
  '--profile-bcp195[BCP 195 TLS Profile (retired)]' \
  '+pz[Extended BCP 195 TLS Profile (retired)]' \
  '--profile-bcp195-ex[Extended BCP 195 TLS Profile (retired)]' \
  '+pb[Basic TLS Secure Transport Connection Profile (retired)]' \
  '--profile-basic[Basic TLS Secure Transport Connection Profile (retired)]' \
  '+pa[AES TLS Secure Transport Connection Profile (retired)]' \
  '--profile-aes[AES TLS Secure Transport Connection Profile (retired)]' \
  '+pn[Authenticated unencrypted communication (retired)]' \
  '--profile-null[Authenticated unencrypted communication (retired)]' \
  '(+cc --list-ciphers)'{+cc,--list-ciphers}'[list supported TLS ciphersuites and exit]' \
  '*'{+cs,--cipher}'[add ciphersuite to list of negotiated suites]:ciphersuite name:' \
  '--no-sni[do not use SNI (default)]' \
  '--request-sni[request server name]:server name:' \
  '(+rs --seed)'{+rs,--seed}'[seed random generator with contents of file]:file:_files' \
  '(+ws --write-seed)'{+ws,--write-seed}'[write back modified seed]' \
  '(+wf --write-seed-file)'{+wf,--write-seed-file}'[write modified seed to file]:file:_files' \
  '(-rc --require-peer-cert -ic --ignore-peer-cert)'{-rc,--require-peer-cert}'[verify peer certificate, fail if absent (default)]' \
  '(-rc --require-peer-cert -ic --ignore-peer-cert)'{-ic,--ignore-peer-cert}'[do not verify peer certificate]' \
  '(-od --output-directory)'{-od,--output-directory}'[write output files to directory]:directory:_files -/' \
  '(+dc --enable-correction -dc --disable-correction)'{+dc,--enable-correction}'[enable automatic data correction]' \
  '(+dc --enable-correction -dc --disable-correction)'{-dc,--disable-correction}'[disable automatic data correction (default)]' \
  '(+sr --show-responses -sr --hide-responses)'{+sr,--show-responses}'[always output responses to the logger]' \
  '(+sr --show-responses -sr --hide-responses)'{-sr,--hide-responses}'[never output responses to the logger]' \
  '(-X --extract)'{-X,--extract}'[extract responses to DICOM file]' \
  '(-Xx --extract-xml)'{-Xx,--extract-xml}'[extract responses to XML file]' \
  '(-Xs --extract-xml-single)'{-Xs,--extract-xml-single}'[extract all responses to given XML file]:file:_files' \
  '(-Xlo --limit-output)'{-Xlo,--limit-output}'[limit number of extracted response files to n]:number:' \
  '1:peer:_hosts' \
  '2:port:' \
  '*:dcmfile-in:_files'
