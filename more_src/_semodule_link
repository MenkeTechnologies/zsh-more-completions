#compdef semodule_link
# _semodule_link — SELinux semodule_link (link multiple compiled .pp policy modules into a single linked module ready for semodule_expand; -o output file, -v verbose, -V version, -h help; positional argument is the list of input .pp module files to link)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux libsemanage tools/semodule_link.c on tip.

_semodule_link() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-o+[output file]:file:_files -g "*.pp"' \
        '-v[verbose]' \
        '*:input modules:_files -g "*.pp"'
}

_semodule_link "$@"
