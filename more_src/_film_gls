#compdef film_gls
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/task_fmri/feat/user_guide.html
# FSL FILM: GLS time-series analysis with prewhitening

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-rn[directory to store results in]:resultsdir:_files -/' \
  '-sa[smooth autocorrelation estimates]' \
  '-ms[susan mask size for smoothing autocorr estimates]:masksize:' \
  '-epith[susan brightness threshold for autocorr smoothing]:thresh:' \
  '-ac[perform autocorrelation estimation only]' \
  '-ar[fit autoregressive model for prewhitening]' \
  '-tukey[use Tukey window with taper size M]:taper:' \
  '-mt[use multitaper estimation with M tapers]:tapers:' \
  '-pava[estimate autocorrelations using PAVA]' \
  '-noest[do not estimate autocorrelations]' \
  '-output_pwdata[output prewhitened data and design matrix]' \
  '-v[verbose output]' \
  '*:image:_files' && ret=0

return ret
