#compdef falco

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(- *)--list=[list available fields]:source' \
  '(- *)--list-events[list supported events]' \
  '(- *)--list-plugins[list loaded plugins]' \
  '-c+[configuration file]:config file:_files' \
  '--config=[configuration file]:config file:_files' \
  '-r+[rules file]:rules file:_files' \
  '--rules=[rules file]:rules file:_files' \
  '-o+[override config option]:key=value' \
  '--option=[override config option]:key=value' \
  '-L[show support info]' \
  '--support[show support info]' \
  '-A[monitor all events]' \
  '-b+[buffer length]:bytes' \
  '--buffered-outputs[buffer output]' \
  '-d[run as daemon]' \
  '--daemon[run as daemon]' \
  '-D+[disable rule by name pattern]:pattern' \
  '--disable-rule=[disable rule by name pattern]:pattern' \
  '-e+[replay events from file]:file:_files' \
  '-k+[kube apiserver URL]:url' \
  '-K+[kube API cert and key]:paths' \
  '--mesos-api=[mesos API URL]:url' \
  '-p+[output format]:format' \
  '--print=[output format]:format' \
  '-P[print stats at exit]' \
  '--stats-interval=[stats interval]:milliseconds' \
  '-T+[disable rule by tag]:tag' \
  '--disable-tag=[disable rule by tag]:tag' \
  '-t+[only run rules with tag]:tag' \
  '--tag=[only run rules with tag]:tag' \
  '-U[unbuffered outputs]' \
  '--unbuffered[unbuffered outputs]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '--validate=[validate rules file]:rules file:_files' \
  '-V[validate rules and exit]' && ret=0

return ret
