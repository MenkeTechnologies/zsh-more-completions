#compdef falco
# Documentation: https://falco.org/docs/reference/daemon/cli-arguments/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(- *)--config-schema[print config JSON schema and exit]' \
  '(- *)--rule-schema[print rule JSON schema and exit]' \
  '(- *)--list-events[list supported events and exit]' \
  '(- *)--list-plugins[list loaded plugins and exit]' \
  '(- *)--list=[list available fields]:source:' \
  '(- *)--page-size[print system page size and exit]' \
  '(- *)--support[print support information in JSON]' \
  '-c+[configuration file]:config file:_files' \
  '*-r+[rules file or directory]:rules file:_files' \
  '*'{-o+,--option=}'[override config option (key=value)]:key=value:' \
  '--disable-source=[disable event source]:source:' \
  '--enable-source=[enable event source]:source:' \
  '--dry-run[run without processing events]' \
  '*-i[print performance-ignored events]' \
  '-L[show all rules and exit]' \
  '-l+[show specific rule and exit]:rule:' \
  '-M+[stop execution after specified seconds]:seconds:' \
  '--markdown[output in markdown format]' \
  '-N[print field names only]' \
  '-p+[append output info (deprecated)]:format:' \
  '--print=[append output info (deprecated)]:format:' \
  {-P+,--pidfile=}'[write PID to file]:pidfile:_files' \
  '--plugin-info=[print info for plugin]:plugin:' \
  {-U,--unbuffered}'[turn off output buffering]' \
  {-V+,--validate=}'[validate rules file and exit]:rules file:_files' \
  '-v[verbose output]' \
  '--gvisor-generate-config[generate gVisor config (deprecated)]' && ret=0

return ret
