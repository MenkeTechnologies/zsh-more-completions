#compdef jupyter-lab

# Zsh completion for JupyterLab

_arguments -s -S \
  '--no-browser[do not open browser]' \
  '--autoreload[auto-reload on extension changes]' \
  '--app-dir=[JupyterLab application directory]:directory:_files -/' \
  '--core-mode[run in core mode]' \
  '--dev-mode[run in dev mode]' \
  '--watch[watch for source changes]' \
  '--expose-app-in-browser[expose app object in browser]' \
  '--extensions-in-dev-mode[load extensions in dev mode]' \
  '--collaborative[enable collaborative mode]' \
  '--ip=[set the IP address]:ip address:' \
  '--port=[set the port]:port:' \
  '--port-retries=[number of port retries]:retries:' \
  '--notebook-dir=[set the notebook directory]:directory:_files -/' \
  '--browser=[browser to use]:browser:' \
  '--certfile=[SSL certificate file]:cert file:_files' \
  '--keyfile=[SSL key file]:key file:_files' \
  '--config=[config file]:config file:_files -g "*.py"' \
  '--generate-config[generate default config file]' \
  '-y[answer yes to any prompts]' \
  '--log-level=[set log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--ServerApp.token=[set authentication token]:token:' \
  '--ServerApp.password=[set password]:password:' \
  '--ServerApp.allow_origin=[set allowed origin]:origin:' \
  '--ServerApp.allow_remote_access=[allow remote access]:bool:(True False)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]'
