#compdef mlx

# Zsh completion for mlx - Apple MLX machine learning CLI

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'convert:Convert model weights to MLX format'
  'evaluate:Evaluate a model on a dataset'
  'fine-tune:Fine-tune a model'
  'generate:Generate text from a language model'
  'lora:Fine-tune a model using LoRA'
  'quantize:Quantize model weights'
  'server:Start an OpenAI-compatible API server'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'mlx command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      generate)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--model=[path or HuggingFace repo of the model]:model' \
          '--prompt=[prompt for generation]:prompt' \
          '--max-tokens=[max tokens to generate]:count' \
          '--temp=[sampling temperature]:temperature' \
          '--top-p=[top-p sampling]:p' \
          '--seed=[random seed]:seed' \
          '--repeat-penalty=[repetition penalty]:penalty' \
          '--adapter-path=[path to LoRA adapter]:path:_directories' \
          '--trust-remote-code[trust remote code]' \
          '--eos-token=[end of sequence token]:token' \
          '--colorize[colorize output]' && ret=0
        ;;
      convert)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--hf-path=[HuggingFace model path]:path' \
          '--mlx-path=[output MLX model path]:path:_directories' \
          '--dtype=[data type]:dtype:(float16 float32 bfloat16)' \
          '(-q --quantize)'{-q,--quantize}'[quantize the model]' \
          '--q-bits=[quantization bits]:bits:(2 4 8)' \
          '--q-group-size=[quantization group size]:size' \
          '--upload-repo=[upload to HuggingFace repo]:repo' \
          '--trust-remote-code[trust remote code]' && ret=0
        ;;
      fine-tune|lora)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--model=[model path]:model' \
          '--data=[path to training data]:path:_directories' \
          '--train[run training]' \
          '--test[run testing]' \
          '--iters=[number of iterations]:iters' \
          '--batch-size=[batch size]:size' \
          '--learning-rate=[learning rate]:rate' \
          '--lora-layers=[number of LoRA layers]:layers' \
          '--lora-rank=[LoRA rank]:rank' \
          '--val-batches=[number of validation batches]:count' \
          '--steps-per-report=[steps per report]:steps' \
          '--steps-per-eval=[steps per evaluation]:steps' \
          '--save-every=[save every N iterations]:iters' \
          '--adapter-path=[path to save adapter]:path:_directories' \
          '--resume-adapter-file=[path to resume from]:file:_files' \
          '--seed=[random seed]:seed' \
          '--trust-remote-code[trust remote code]' && ret=0
        ;;
      quantize)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--model=[model path]:model' \
          '--mlx-path=[output path]:path:_directories' \
          '--bits=[quantization bits]:bits:(2 4 8)' \
          '--group-size=[group size]:size' \
          '--trust-remote-code[trust remote code]' && ret=0
        ;;
      evaluate)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--model=[model path]:model' \
          '--data=[path to evaluation data]:path:_files' \
          '--batch-size=[batch size]:size' \
          '--seed=[random seed]:seed' \
          '--trust-remote-code[trust remote code]' && ret=0
        ;;
      server)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--model=[model path]:model' \
          '--host=[host to bind to]:host' \
          '--port=[port to listen on]:port' \
          '--adapter-path=[path to LoRA adapter]:path:_directories' \
          '--trust-remote-code[trust remote code]' && ret=0
        ;;
    esac
    ;;
esac

return ret
