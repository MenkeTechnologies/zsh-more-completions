#compdef sflapfill
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mlapfill.c
# Madagascar: missing data interpolation in 2-D by Laplacian regularization

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'niter=[number of iterations]:count' \
  'grad=[if y, use gradient instead of laplacian]:flag:(y n)' \
  'verb=[verbosity flag]:flag:(y n)' \
  'mask=[optional mask file with zeroes for missing data locations]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
