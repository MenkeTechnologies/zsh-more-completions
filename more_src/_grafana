#compdef grafana
# Documentation: https://man.archlinux.org/search?q=grafana
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'cli:plugin/admin management'
  'server:run Grafana server'
  'apiserver:run apiserver'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'grafana subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (server)
        _arguments \
          '--config=[config file]:file:_files' \
          '--homepath=[home directory]:dir:_files -/' \
          '--pidfile=[PID file]:file:_files' \
          '--packaging=[packaging type]:type:(deb rpm brew docker hosted)' \
          '*--configOverrides=[config overrides]:overrides:' && ret=0
        ;;
      (cli)
        _values 'cli action' \
          'plugins' 'admin' \
          'install' 'list-remote' 'list-versions' 'update' 'upgrade' \
          'update-all' 'upgrade-all' 'ls' 'uninstall' 'remove' \
          'reset-admin-password' 'data-migration' 'secrets-migration' \
          'secrets-consolidation' 'flush-rbac-seed-assignment' && ret=0
        ;;
    esac
    ;;
esac

return ret
