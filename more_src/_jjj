_jjj_commands() {
    local commands; commands=(
'ui:Open the interactive project browser (recommended starting point)' \
'status:Show what needs your attention\: open problems, pending reviews, critiques' \
'next:Print the highest-priority next action(s) (great for shell prompts)' \
'problem:Track problems to solve (the questions driving your work)' \
'solution:Propose and approve solutions — conjectures attached to jj change IDs' \
'critique:Add and resolve critiques that challenge or endorse a solution' \
'milestone:Group problems into time-based milestones and track progress' \
'search:Search problems, solutions, and critiques by text or semantic similarity' \
'timeline:Show the full history of a problem\: solutions, critiques, and decisions' \
'overlaps:Show files touched by multiple in-progress solutions (conflict detection)' \
'insights:Show aggregate statistics from the event log (approval rates, cycle times)' \
'events:Browse the structured event log (state changes, rationales, decisions)' \
'fetch:Pull jj changes and jjj metadata from a remote' \
'push:Push jj changes and jjj metadata to a remote' \
'sync:Fetch metadata from remote then push local changes back (shorthand for fetch + push)' \
'github:Bridge jjj problems and solutions with GitHub Issues and Pull Requests' \
'tags:List all tags in use with counts' \
'rank:View problem rankings for a milestone' \
'init:Initialize jjj metadata in the current jj repository' \
'db:Manage the local SQLite cache (full-text search index and embeddings)' \
'completion:Generate shell completions (bash, zsh, fish, etc.)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'jjj commands' commands "$@"
}
