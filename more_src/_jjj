# Documentation: https://github.com/doug/jjj
# Reference accessed: 2026-05-19
# Verified: clap-generated completion from `jjj completion zsh`
#           (cargo binstall jjj@0.4.1); jjj is a Jujutsu project
#           management / code review tool.

autoload -U is-at-least

_jjj() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_jjj_commands" \
"*::: :->jjj" \
&& ret=0
    case $state in
    (jjj)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:jjj-command-$line[1]:"
        case $line[1] in
            (ui)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(status)
