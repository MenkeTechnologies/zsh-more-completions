#compdef nsd-control

# Zsh completion for nsd-control - NSD remote control utility

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start NSD'
  'stop:stop NSD'
  'reload:reload zones'
  'reconfig:reread config file'
  'repattern:reload patterns and zones'
  'log_reopen:re-open the log file'
  'status:display NSD server status'
  'stats:print statistics'
  'stats_noreset:print statistics without resetting counters'
  'addzone:add a new zone'
  'delzone:remove a zone'
  'changezone:change a zone pattern'
  'addzones:add zones from stdin'
  'delzones:remove zones from stdin'
  'write:write zonefiles to disk'
  'notify:send NOTIFY messages to slaves'
  'transfer:transfer zone from master'
  'force_transfer:force transfer from master'
  'zonestatus:print status of a zone'
  'serverpid:show NSD server pid'
  'verbosity:change server verbosity'
  'print_tsig:print TSIG keys'
  'update_tsig:update TSIG key'
  'add_tsig:add TSIG key'
  'assoc_tsig:associate TSIG key with zone'
  'del_tsig:delete TSIG key'
  'add_cookie_secret:add cookie secret'
  'drop_cookie_secret:drop staging cookie secret'
  'activate_cookie_secret:activate staging cookie secret'
  'print_cookie_secrets:print cookie secrets'
)

_arguments -C \
  '(-h)-h[show help information]' \
  '-c+[config file]:file:_files' \
  '-s+[server control address]:addr:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'nsd-control command' commands && ret=0
    ;;
esac

return ret
