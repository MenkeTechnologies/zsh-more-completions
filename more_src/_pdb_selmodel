#compdef pdb_selmodel
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Extracts one or more models from a PDB file, e.g. -1 or -1,3

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[model id(s) to select, e.g. -1 or -1,3]:model id' \
  '*:PDB file:_files' && ret=0

return ret
