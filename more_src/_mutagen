#compdef mutagen

local curcontext="$curcontext" state line ret=1

_mutagen_commands() {
  local -a commands=(
    'compose:manage Mutagen Compose sessions'
    'create:create a new sync or forwarding session'
    'daemon:manage the Mutagen daemon'
    'flush:flush a session'
    'forward:manage forwarding sessions'
    'list:list sessions'
    'login:log in to mutagen.io'
    'logout:log out of mutagen.io'
    'monitor:monitor a session'
    'pause:pause a session'
    'project:manage Mutagen projects'
    'reset:reset a session'
    'resume:resume a session'
    'sync:manage sync sessions'
    'terminate:terminate a session'
    'tunnel:manage tunnels'
    'version:show version'
  )
  _describe -t commands 'mutagen command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:_mutagen_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      create)
        _arguments -s -S \
          '--default-directory-mode[default directory mode]:mode' \
          '--default-file-mode[default file mode]:mode' \
          '--ignore[ignore paths]:pattern' \
          '--ignore-vcs[ignore VCS directories]' \
          '--label[session label]:label' \
          '--name[session name]:name' \
          '--no-global-configuration[ignore global configuration]' \
          '--probe-mode[probe mode]:mode:(probe assume)' \
          '--scan-mode[scan mode]:mode:(full accelerated)' \
          '--stage-mode[stage mode]:mode:(mutagen neighboring)' \
          '--symlink-mode[symlink mode]:mode:(ignore portable posix-raw)' \
          '--sync-mode[sync mode]:mode:(two-way-safe two-way-resolved one-way-safe one-way-replica)' \
          '--watch-mode[watch mode]:mode:(portable force-poll no-watch)' \
          '--watch-polling-interval[polling interval]:seconds' \
          '*:endpoint' && ret=0
        ;;
      daemon)
        _arguments -s -S \
          '1:action:(start stop run register unregister)' && ret=0
        ;;
      sync|forward)
        _arguments -s -S \
          '1:action:(create list monitor pause resume reset terminate flush)' \
          '*:session' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-l --long)'{-l,--long}'[long format]' \
          '--label-selector[filter by label]:selector' \
          '*:session' && ret=0
        ;;
      monitor|pause|resume|reset|flush|terminate)
        _arguments -s -S \
          '--label-selector[filter by label]:selector' \
          '*:session' && ret=0
        ;;
      project)
        _arguments -s -S \
          '1:action:(start list flush pause resume reset terminate run)' \
          '-f[project file]:file:_files' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
