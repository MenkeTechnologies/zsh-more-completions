#compdef geojsonio
# Documentation: https://github.com/mapbox/geojsonio-cli
# Send files from your shell to geojson.io for visualization and editing

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--print[output the geojson.io URL instead of launching a browser]' \
  '--domain=[use a custom geojson.io instance]:domain' \
  '*:geojson file:_files -g "*.(geojson|json)"' && ret=0

return ret
