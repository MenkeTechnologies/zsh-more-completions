#compdef create-next-lite-app
# Documentation: https://www.npmjs.com/package/create-next-lite-app
# Reference accessed: 2026-05-24
# Verified: npm view create-next-lite-app bin; npm readme Options table.

# Zsh completion for create-next-lite-app - Next-Lite application scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--typescript[initialize as TypeScript project]' \
  '--use-npm[use npm as package manager]' \
  '--use-yarn[use yarn as package manager]' \
  '--use-pnpm[use pnpm as package manager]' \
  '--use-flash[use flash-install for faster dependency install]' \
  '--template=[project template]:template:(default minimal)' \
  '--example=[example from Next-Lite repository]:example:' \
  '--skip-install[skip dependency installation]' \
  ':project name:' && ret=0

return ret
