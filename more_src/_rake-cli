#compdef rake-cli
# _rake-cli — Ruby rake build tool CLI alias (Jim Weirich / Eric Hodel / Ruby community, Ruby); custom argparse
# upstream: https://github.com/ruby/rake

_rake-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A[don'\''t define always-make]' \
        '--always-make[treat all tasks as out of date]' \
        '-B[do all dependencies regardless of whether targets exist]' \
        '--build-all[do all dependencies regardless of whether targets exist]' \
        '--backtrace=+[show backtrace]:str:' \
        '--comments[show comments only]' \
        '-D[describe tasks]' \
        '--describe=+[describe tasks matching pattern]:str:' \
        '-e+[execute ruby code]:str:' \
        '--execute=+[execute ruby code]:str:' \
        '-E+[execute and continue]:str:' \
        '--execute-continue=+[execute and continue]:str:' \
        '-p+[execute and print]:str:' \
        '--execute-print=+[execute and print]:str:' \
        '-f+[rakefile]:file:_files -g "Rakefile *.rake"' \
        '--rakefile=+[rakefile]:file:_files -g "Rakefile *.rake"' \
        '-G[no system rakefiles]' \
        '--no-system[no system rakefiles]' \
        '-g[use system rakefiles]' \
        '--system[use system rakefiles]' \
        '-I+[include path]:list:_files -/' \
        '--libdir=+[include path]:list:_files -/' \
        '-j+[parallel jobs]:n:' \
        '--jobs=+[parallel jobs]:n:' \
        '-N[no search]' \
        '--no-search[no search]' \
        '-n[do nothing, just print]' \
        '--dry-run[do nothing, just print]' \
        '-P[show prerequisites]' \
        '--prereqs[show prerequisites]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-Q+[suppress description by namespace]:str:' \
        '--suppress-backtrace=+[suppress backtrace]:str:' \
        '-r+[require library]:list:' \
        '--require=+[require library]:list:' \
        '-R+[rakelib dir]:dir:_files -/' \
        '--rakelibdir=+[rakelib dir]:dir:_files -/' \
        '-s[silent]' \
        '--silent[silent]' \
        '-T[show tasks]' \
        '--tasks=+[show tasks matching pattern]:str:' \
        '-t[trace]' \
        '--trace=+[trace]:str:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-W[where defined]' \
        '--where=+[where matching pattern]:str:' \
        '-X+[suppress backtrace]:str:' \
        '-y[trust everywhere]' \
        '*:task:'
}

_rake-cli "$@"
