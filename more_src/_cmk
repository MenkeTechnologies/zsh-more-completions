#compdef cmk check_mk
# Documentation: https://docs.checkmk.com/latest/en/cmk_commandline.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '--debug[debug]' \
  '--profile[profiling]' \
  '--fake-dns=[fake DNS IP]:ip:' \
  '--cache[use cache]' \
  '--no-cache[never cache]' \
  '--no-tcp[only cache]' \
  '--usewalk[use snmpwalk data]' \
  '--snmp-backend=[backend]:backend:(inline classic stored-walk)' \
  '(-l --list-hosts)'{-l,--list-hosts}'[list hosts]' \
  '--all-sites[all sites]' \
  '--include-offline[include offline]' \
  '--list-tag=[list by tag]:tag:' \
  '(-L --list-checks)'{-L,--list-checks}'[list checks]' \
  '(-d --dump-agent)'{-d,--dump-agent}'=[host]:host:_hosts' \
  '(-D --dump)'{-D,--dump}'[dump info]' \
  '--update-dns-cache[update DNS cache]' \
  '--cleanup-piggyback[clean piggyback]' \
  '--snmptranslate[snmptranslate]' \
  '--snmpwalk[snmpwalk]' \
  '*--extraoid=[extra OID]:oid:' \
  '*--oid=[OID]:oid:' \
  '--snmpget=[OID]:oid:' \
  '--flush[flush data]' \
  '(-N --nagios-config)'{-N,--nagios-config}'[Nagios config]' \
  '(-U --update)'{-U,--update}'[update core config]' \
  '(-R --restart)'{-R,--restart}'[restart]' \
  '(-O --reload)'{-O,--reload}'[reload]' \
  '(-M --man)'{-M,--man}'=[manpage]:check:' \
  '(-r --renderer)'{-r,--renderer}'=[renderer]:fmt:(console nowiki)' \
  '(-m --browse-man)'{-m,--browse-man}'[browse manpages]' \
  '--automation=[helper]:command:' \
  '--check-discovery=[host]:host:_hosts' \
  '(-I --discover)'{-I,--discover}'[discover services]' \
  '--detect-sections=[sections]:list:' \
  '--plugins=[plugins]:list:' \
  '--detect-plugins=[plugins]:list:' \
  '--checks=[plugins]:list:' \
  '--only-host-labels[only labels]' \
  '--check[check services]' \
  '(-n --no-submit)'{-n,--no-submit}'[no submit]' \
  '(-p --perfdata)'{-p,--perfdata}'[show perfdata]' \
  '(-i --inventory)'{-i,--inventory}'[HW/SW inventory]' \
  '(-f --force)'{-f,--force}'[force]' \
  '--inventorize-marked-hosts[inventory marked]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:host:_hosts'
