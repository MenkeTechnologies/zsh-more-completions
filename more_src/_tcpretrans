#compdef tcpretrans tcpretrans-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/tcpretrans.py argparse)
# Reference accessed: 2026-05-29
# tcpretrans — trace TCP retransmits, including TLP attempts (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-s --sequence)'{-s,--sequence}'[display TCP sequence numbers]' \
  '(-l --lossprobe)'{-l,--lossprobe}'[include tail loss probe attempts]' \
  '(-c --count)'{-c,--count}'[count occurred retransmits per flow]' \
  '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[trace IPv4 family only]' \
  '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[trace IPv6 family only]' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
