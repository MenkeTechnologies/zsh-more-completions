#compdef aderyn

_aderyn() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '--scope[Limit the analysis to specific folders or files]:path:_files'
        '--exclude[Exclude specific folders or files]:path:_files'
        '--root[Specify the root directory of the project]:directory:_files -/'
        '(-o --output)'{-o,--output}'[Specify the output file name and format]:file:_files'
        '--stdout[Print the report directly to the terminal]'
        '(-c --config)'{-c,--config}'[Path to a custom aderyn.toml configuration file]:file:_files'
        '--no-clobber[Prevent overwriting an existing report file]'
        '(-h --help)'{-h,--help}'[Show help information]'
        '(-v --version)'{-v,--version}'[Show the version number]'
    )

    subcmds=(
        'init:Initializes an aderyn.toml configuration file'
        'help:Displays help information'
        'version:Prints the current version'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'aderyn commands' subcmds
            ;;
        args)
            case $line[1] in
                help)
                    _describe -t commands 'aderyn commands' subcmds
                    ;;
            esac
            ;;
    esac
}

_aderyn "$@"
