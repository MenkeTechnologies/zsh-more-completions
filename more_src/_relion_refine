#compdef relion_refine
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: 2D/3D classification and 3D auto-refinement (maximum-likelihood)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input particles (in a star-file)]:file:_files' \
  '--o=[output rootname]:file:_files' \
  '--continue=[_optimiser.star file to continue from]:file:_files' \
  '--ref=[image, stack or star-file with the reference(s)]:file:_files' \
  '--ini_high=[resolution (A) to limit refinement in first iteration]:value' \
  '--ctf[perform CTF correction]' \
  '--firstiter_cc[perform CC-calculation in the first iteration]' \
  '--iter=[maximum number of iterations to perform]:value' \
  '--tau2_fudge=[regularisation parameter T]:value' \
  '--particle_diameter=[diameter of circular mask on images (A)]:value' \
  '--K=[number of references to be refined]:value' \
  '--flatten_solvent[perform masking on the references as well]' \
  '--zero_mask[mask surrounding background in particles to zero]' \
  '--solvent_mask=[user-provided mask for the references]:file:_files' \
  '--solvent_mask2=[user-provided secondary mask]:file:_files' \
  '--oversampling=[adaptive oversampling order]:value' \
  '--healpix_order=[healpix order for angular sampling on the sphere]:value' \
  '--offset_range=[search range for origin offsets (pixels)]:value' \
  '--offset_step=[sampling rate for origin offsets (pixels)]:value' \
  '--sym=[symmetry group]:group' \
  '--norm[perform normalisation-error correction]' \
  '--scale[perform intensity-scale corrections on image groups]' \
  '--auto_refine[perform 3D auto-refine procedure]' \
  '--split_random_halves[refine two random halves separately]' \
  '--low_resol_join_halves=[resolution (A) up to which halves are not independent]:value' \
  '--auto_local_healpix_order=[min healpix order for local searches]:value' \
  '--helix[perform 3D classification or refinement for helices]' \
  '--pad=[oversampling factor for Fourier transforms]:value' \
  '--random_seed=[number for the random seed generator]:value' \
  '--j=[number of threads to run in parallel]:value' \
  '--gpu=[use available gpu resources]::device ids' \
  '--pool=[number of images to pool for each thread task]:value' \
  '--dont_combine_weights_via_disc[send summed weights via MPI instead of disc]' \
  '--preread_images[let the leader read all particles into memory]' \
  '*:file:_files' && ret=0

return ret
