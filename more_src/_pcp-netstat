#compdef pcp-netstat
# _pcp-netstat — PCP-based netstat-style network statistics (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/netstat/pcp-netstat.1 SYNOPSIS.

_pcp-netstat() {
    _arguments \
        '--statistics[print per-protocol statistics]' \
        '-p+[protocol filter]:proto:(TCP IP UDP ICMP)' \
        '-i[print interface statistics]' \
        '-s+[samples to collect]:n:' \
        '-a+[PCP archive folio]:archive:_files' \
        '-S+[start time]:time:' \
        '-T+[end time]:time:'
}

_pcp-netstat "$@"
