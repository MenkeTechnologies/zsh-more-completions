#compdef hcalc
# _hcalc — hcalc / hex-calc (small CLI hex/dec/oct/bin calculator that accepts arithmetic expressions like "0x10 + 5*2" and prints all four bases; -d only decimal, -x only hex, -o only octal, -b only binary, --shell repl mode)
# upstream: github mirrors of common hex-calculator package
# Flags inferred from upstream hcalc.c on tip.

_hcalc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '-d[decimal output only]' \
        '-x[hex output only]' \
        '-o[octal output only]' \
        '-b[binary output only]' \
        '--shell[interactive REPL]' \
        '*:expression:'
}

_hcalc "$@"
