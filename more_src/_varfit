#compdef varfit
# Documentation: https://lweb.cfa.harvard.edu/sma/miriad/manuals/SMAuguide/smauserhtml/varfit.html
# Analyse correlations of antenna gains and uv-variables

local ret=1

_arguments -s \
  'vis=[input UV dataset (gains from selfcal)]:dataset:_files' \
  'xaxis=[variable for horizontal axis (default time)]:xaxis' \
  'yaxis=[variable for vertical axis (default phase)]:yaxis' \
  'log=[output log file (default terminal)]:logfile:_files' \
  'device=[PGPLOT plot device]:device' \
  'nxy=[number of plots in x and y (default 3,3)]:nxy' \
  'xrange=[min,max range for x-axis]:xrange' \
  'yrange=[min,max range for y-axis]:yrange' \
  'refant=[reference antenna for gains and uv-variables]:refant' \
  'refant2=[reference antenna for cross-correlation fit]:refant2' \
  'phratio=[phase ratio for expected slope line (default 0)]:phratio' \
  'nsigma=[number of sigmas for rejecting bad gains (default 0)]:nsigma' \
  'options=[wrap,xscale,yscale,structure,allan,quad,uniscale,phareg,phatran,gflag,tambient]:options' \
  '*:dataset:_files' && ret=0

return ret
