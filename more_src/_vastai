#compdef vastai

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'search:search the marketplace (offers, etc.)'
  'create:create instance/ssh-key/api-key/template/role'
  'show:show user/instance/instances/machines/api-keys'
  'destroy:destroy an instance or other resource'
  'start:start (resume) a stopped instance'
  'stop:stop (pause) a running instance'
  'reboot:reboot an instance'
  'attach:attach SSH key to instance'
  'detach:detach a resource'
  'label:label an instance'
  'copy:copy files to/from an instance'
  'cloud:cloud copy/sync subcommands'
  'execute:execute a command on an instance'
  'logs:fetch instance logs'
  'ssh-url:print SSH URL for an instance'
  'set:set api-key, user info'
  'unset:unset settings'
  'reports:reports for invoices and usage'
  'change:change instance bid price'
  'cancel:cancel maintenance/audit'
  'self-test:run client self-test'
  'transfer:transfer credits'
  'invoice:show invoice'
  'help:show help for any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--api-key=[Vast.ai API key]:key:' \
  '--url=[server URL]:url:' \
  '--retry=[retry count]:n:' \
  '--raw[print raw json]' \
  '--explain[explain API request]' \
  '--curl[print curl command then exit]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vastai command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (search)
        local -a search_subs=(
          'offers:search GPU machine offers'
          'invoices:search invoices'
          'templates:search templates'
          'benchmarks:search benchmarks'
        )
        _describe -t scmds 'search subcommand' search_subs && ret=0
        _arguments \
          '(-o --order)'{-o+,--order=}'[sort order]:order:' \
          '(-t --type)'{-t+,--type=}'[contract type]:type:(on-demand reserved bid)' \
          '(-n --limit)'{-n+,--limit=}'[result limit]:n:' \
          '--storage=[disk size in GB]:gb:' \
          '--no-default[do not apply default filters]' \
          '--disable-bundling[disable bundling]' \
          '*: :' && ret=0 ;;
      (create)
        local -a create_subs=(
          'instance:rent a new instance'
          'ssh-key:add SSH key to account'
          'api-key:create scoped API key'
          'template:create a template'
          'role:create a team role'
        )
        _describe -t crcmds 'create subcommand' create_subs && ret=0
        _arguments \
          '--image=[Docker image]:image:' \
          '--disk=[disk size GB]:gb:' \
          '--ssh[enable SSH]' \
          '--jupyter[enable Jupyter]' \
          '--direct[direct port mapping]' \
          '--label=[label]:label:' \
          '--onstart=[onstart script path]:file:_files' \
          '--env=[env vars (-p key=value)]:env:' \
          '*: :' && ret=0 ;;
      (show)
        local -a show_subs=(
          'user:show your user account'
          'instance:show single instance'
          'instances:list your instances'
          'machines:list your machines (host mode)'
          'api-keys:list api keys'
          'ssh-keys:list ssh keys'
          'audit-logs:list audit logs'
          'invoices:show invoices'
          'subaccounts:show subaccounts'
          'team-members:show team members'
          'team-role:show team role'
          'connections:show network volume connections'
        )
        _describe -t shcmds 'show subcommand' show_subs && ret=0 ;;
      (destroy)
        local -a destroy_subs=(
          'instance:destroy an instance'
          'instances:destroy multiple instances'
        )
        _describe -t dcmds 'destroy subcommand' destroy_subs && ret=0
        _arguments '*::id:' && ret=0 ;;
      (start|stop|reboot)
        _arguments '*::id:' && ret=0 ;;
      (label)
        _arguments \
          '--label=[label text]:label:' \
          '*::id:' && ret=0 ;;
      (copy|cloud)
        _arguments '*::path:_files' && ret=0 ;;
      (set)
        local -a set_subs=(
          'api-key:store API key locally'
          'user:set user info'
        )
        _describe -t setcmds 'set subcommand' set_subs && ret=0 ;;
    esac ;;
esac

return ret
