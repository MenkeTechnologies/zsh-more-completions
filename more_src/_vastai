#compdef vastai
# Documentation: https://github.com/vast-ai/vast-python (vastai/cli/commands/*)
# Reference accessed: 2026-05-21
# Verified: upstream @parser.command() decorator names.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'search:search marketplace (offers/benchmarks/templates/invoices)'
  'create:create instance/api-key/cluster/env-var/ssh-key/workergroup/endpoint/template/subaccount'
  'show:show user/instance/instances/invoices/earnings/deposit/subaccounts/ipaddrs/audit-logs/env-vars/scheduled-jobs'
  'destroy:destroy an instance or multiple instances'
  'start:start (resume) a stopped instance or instances'
  'stop:stop (pause) a running instance or instances'
  'reboot:reboot an instance'
  'recycle:recycle an instance'
  'update:update instance/template/env-var'
  'label:label an instance'
  'prepay:prepay an instance'
  'launch:launch an instance'
  'attach:attach SSH key'
  'copy:copy files to/from an instance'
  'clone:clone a volume'
  'cloud:cloud copy/sync subcommands'
  'execute:execute a constrained remote command'
  'logs:fetch instance logs'
  'reports:get user reports'
  'ssh-url:ssh url helper'
  'scp-url:scp url helper'
  'take:take snapshot of a running container'
  'set:set api-key, user, subaccount info'
  'delete:delete env-var/scheduled-job/template'
  'tfa:two-factor authentication commands'
  'change:change instance bid price'
  'accept:accept price increase'
  'cancel:cancel copy/sync'
  'transfer:transfer credits'
  'help:print this help message'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--api-key=[Vast.ai API key]:key:' \
  '--url=[server URL]:url:' \
  '--retry=[retry count]:n:' \
  '--raw[print raw json]' \
  '--explain[explain API request]' \
  '--curl[print curl command then exit]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vastai command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (search)
        local -a search_subs=(
          'offers:search GPU machine offers'
          'invoices:search invoices'
          'templates:search templates'
          'benchmarks:search benchmarks'
        )
        _describe -t scmds 'search subcommand' search_subs && ret=0 ;;
      (create)
        local -a create_subs=(
          'instance:rent a new instance'
          'instances:rent multiple instances'
          'api-key:create scoped API key'
          'cluster:create a cluster'
          'env-var:create environment variable'
          'ssh-key:add SSH key to account'
          'workergroup:create worker group'
          'endpoint:create endpoint'
          'template:create a template'
          'subaccount:create a subaccount'
        )
        _describe -t crcmds 'create subcommand' create_subs && ret=0 ;;
      (show)
        local -a show_subs=(
          'user:show your user account'
          'instance:show single instance'
          'instances:list your instances'
          'invoices:show invoices'
          'earnings:show machine earnings'
          'deposit:show reserve deposit info'
          'subaccounts:show subaccounts'
          'ipaddrs:show ip address history'
          'audit-logs:show audit logs'
          'env-vars:show environment variables'
          'scheduled-jobs:list scheduled jobs'
        )
        _describe -t shcmds 'show subcommand' show_subs && ret=0 ;;
      (destroy)
        local -a destroy_subs=(
          'instance:destroy an instance'
          'instances:destroy multiple instances'
        )
        _describe -t dcmds 'destroy subcommand' destroy_subs && ret=0
        _arguments '*::id:' && ret=0 ;;
      (start|stop)
        local -a se_subs=(
          'instance:single instance'
          'instances:multiple instances'
        )
        _describe -t cmds 'subcommand' se_subs && ret=0 ;;
      (reboot|recycle|update|label|prepay|launch)
        _arguments '*::id:' && ret=0 ;;
      (copy|cloud)
        _arguments '*::path:_files' && ret=0 ;;
      (set)
        local -a set_subs=(
          'api-key:store API key locally'
          'user:set user info from JSON'
        )
        _describe -t setcmds 'set subcommand' set_subs && ret=0 ;;
      (delete)
        local -a del_subs=(
          'env-var:delete environment variable'
          'scheduled-job:delete a scheduled job'
          'template:delete a template'
        )
        _describe -t delcmds 'delete subcommand' del_subs && ret=0 ;;
    esac ;;
esac

return ret
