#compdef sambamba
# Documentation: https://lomereiter.github.io/sambamba/docs/sambamba-view.html
# tools for working with SAM/BAM/CRAM files

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'view:filter, convert and display alignments'
      'sort:sort a BAM file'
      'index:create an index for a BAM file'
      'merge:merge several sorted BAM files'
      'slice:output reads overlapping a region into a new BAM'
      'markdup:mark or remove duplicate reads'
      'flagstat:summarize alignment flags'
    )
    _describe -t commands 'sambamba command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      view)
        _arguments -s -S \
          '(-F --filter)'{-F,--filter}'=[set custom filter]:filter' \
          '(-f --format)'{-f,--format}'=[output format]:format:(sam bam cram json)' \
          '(-h --with-header)'{-h,--with-header}'[include header in SAM output]' \
          '(-H --header)'{-H,--header}'[output header only]' \
          '(-I --reference-info)'{-I,--reference-info}'[output reference names and lengths]' \
          '(-c --count)'{-c,--count}'[output only count of matching records]' \
          '(-v --valid)'{-v,--valid}'[output only valid alignments]' \
          '(-S --sam-input)'{-S,--sam-input}'[specify input is SAM]' \
          '(-p --show-progress)'{-p,--show-progress}'[show progressbar in STDERR]' \
          '(-l --compression-level)'{-l,--compression-level}'=[compression level 0-9]:level' \
          '(-o --output-filename)'{-o,--output-filename}'=[output filename]:file:_files' \
          '(-t --nthreads)'{-t,--nthreads}'=[number of threads]:nthreads' \
          '*:bam file:_files' && ret=0
        ;;
      sort)
        _arguments -s -S \
          '(-m --memory-limit)'{-m,--memory-limit}'=[approximate memory limit]:limit' \
          '--tmpdir=[directory for temporary files]:dir:_files -/' \
          '(-o --out)'{-o,--out}'=[output filename]:file:_files' \
          '(-n --sort-by-name)'{-n,--sort-by-name}'[sort by read name]' \
          '(-l --compression-level)'{-l,--compression-level}'=[compression level]:level' \
          '(-u --uncompressed-chunks)'{-u,--uncompressed-chunks}'[write uncompressed chunks]' \
          '(-p --show-progress)'{-p,--show-progress}'[show progressbar in STDERR]' \
          '(-t --nthreads)'{-t,--nthreads}'=[number of threads]:nthreads' \
          '*:bam file:_files' && ret=0
        ;;
      merge)
        _arguments -s -S \
          '(-t --nthreads)'{-t,--nthreads}'=[number of threads]:nthreads' \
          '(-l --compression-level)'{-l,--compression-level}'=[compression level 0-9]:level' \
          '(-H --header)'{-H,--header}'[output merged header only as SAM]' \
          '(-p --show-progress)'{-p,--show-progress}'[show progressbar in STDERR]' \
          '*:bam file:_files' && ret=0
        ;;
      slice)
        _arguments -s -S \
          '(-o --output-filename)'{-o,--output-filename}'=[output filename]:file:_files' \
          '*:bam file:_files' && ret=0
        ;;
      markdup)
        _arguments -s -S \
          '(-r --remove-duplicates)'{-r,--remove-duplicates}'[remove duplicates instead of marking]' \
          '(-p --show-progress)'{-p,--show-progress}'[show progressbar in STDERR]' \
          '(-t --nthreads)'{-t,--nthreads}'=[number of threads]:nthreads' \
          '(-l --compression-level)'{-l,--compression-level}'=[compression level 0-9]:level' \
          '--tmpdir=[directory for temporary files]:dir:_files -/' \
          '--hash-table-size=[hash table size]:size' \
          '--overflow-list-size=[overflow list size]:size' \
          '--io-buffer-size=[IO buffer size in MB]:size' \
          '*:bam file:_files' && ret=0
        ;;
      flagstat)
        _arguments -s -S \
          '(-t --nthreads)'{-t,--nthreads}'=[number of threads]:nthreads' \
          '(-p --show-progress)'{-p,--show-progress}'[show progressbar in STDERR]' \
          '*:bam file:_files' && ret=0
        ;;
      index)
        _arguments -s -S \
          '(-t --nthreads)'{-t,--nthreads}'=[number of threads]:nthreads' \
          '(-p --show-progress)'{-p,--show-progress}'[show progressbar in STDERR]' \
          '*:bam file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
