#compdef astaddframe
# Documentation: http://www.starlink.ac.uk/docs/sun210.htx/sun210ss4.html
# ATOOLS: adds a Frame to a FrameSet to define a new coordinate system

local ret=1

_arguments -s \
  'THIS=[input FrameSet]:frameset:_files' \
  'IFRAME=[index of the base Frame]:n' \
  'MAP=[Mapping from old to new system]:mapping:_files' \
  'FRAME=[Frame to be added]:frame:_files' \
  'RESULT=[output FrameSet]:result:_files' \
  'FMT=[output format for the result]:fmt' \
  '*:object:_files' && ret=0

return ret
