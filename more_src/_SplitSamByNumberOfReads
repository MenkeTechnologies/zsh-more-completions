#compdef SplitSamByNumberOfReads
# Documentation: https://github.com/broadinstitute/picard/blob/master/src/main/java/picard/sam/SplitSamByNumberOfReads.java
# Splits a SAM/BAM/CRAM file to multiple files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--INPUT -I)'{--INPUT,-I}'=[input SAM/BAM/CRAM file]:value:_files' \
  '(--OUTPUT -O)'{--OUTPUT,-O}'=[output directory]:dir:_files -/' \
  '(--SPLIT_TO_N_READS -N_READS)'{--SPLIT_TO_N_READS,-N_READS}'=[reads per output file]:value:' \
  '(--SPLIT_TO_N_FILES -N_FILES)'{--SPLIT_TO_N_FILES,-N_FILES}'=[number of output files]:value:' \
  '(--TOTAL_READS_IN_INPUT -TOTAL_READS)'{--TOTAL_READS_IN_INPUT,-TOTAL_READS}'=[total reads in input]:value:' \
  '--OUT_PREFIX=[prefix for output files]:value:' \
  '*:argument:_files' && ret=0

return ret
