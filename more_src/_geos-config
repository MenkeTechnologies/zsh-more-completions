#compdef geos-config
# Documentation: https://manpages.debian.org/bookworm/libgeos-dev/geos-config.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm geos-config(1) manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# geos-config: print build configuration for the GEOS library
local curcontext="$curcontext" ret=1
_arguments -C \
  '--prefix[print install prefix]' \
  '--version[print GEOS version]' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' \
  '--includes[print location of C++ header files]' \
  '--jtsport[print Java Topology Suite version GEOS was ported from]' && ret=0
return ret
