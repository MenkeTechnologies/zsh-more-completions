#compdef cargo-fix

# Zsh completion for cargo fix

_arguments -s -S \
  '--edition[fix code to latest edition]' \
  '--edition-idioms[fix warnings to follow edition idioms]' \
  '--broken-code[fix code even if it has compiler errors]' \
  '--allow-dirty[fix code even if working directory is dirty]' \
  '--allow-staged[fix code even if working directory has staged changes]' \
  '--allow-no-vcs[fix code even if a VCS was not detected]' \
  '(-p --package)'{-p+,--package=}'[package to fix]:package:' \
  '--all[fix all packages in workspace]' \
  '--workspace[fix all packages in workspace]' \
  '--exclude=[exclude packages from fix]:package:' \
  '--lib[fix only library]' \
  '--bin=[fix only specified binary]:binary:' \
  '--bins[fix all binaries]' \
  '--example=[fix only specified example]:example:' \
  '--examples[fix all examples]' \
  '--test=[fix only specified test target]:test:' \
  '--tests[fix all tests]' \
  '--bench=[fix only specified bench target]:bench:' \
  '--benches[fix all benches]' \
  '--all-targets[fix all targets]' \
  '--release[fix in release mode]' \
  '--profile=[fix with specified profile]:profile:(dev release test bench)' \
  '--features=[space or comma separated list of features]:features:' \
  '--all-features[activate all available features]' \
  '--no-default-features[do not activate default feature]' \
  '--target=[fix for target triple]:target triple:' \
  '(-j --jobs)'{-j+,--jobs=}'[number of parallel jobs]:jobs:' \
  '--manifest-path=[path to Cargo.toml]:manifest path:_files -g "*.toml"' \
  '--message-format=[error format]:format:(human json short)' \
  '(-v --verbose)'{-v,--verbose}'[use verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[require Cargo.lock and cache are up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without accessing the network]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::args:_default'
