#compdef buildevents
# Documentation: https://man.archlinux.org/search?q=buildevents
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:emit the root span for an entire build'
  'step:emit a step span (collection of related commands)'
  'cmd:run an individual command and emit its span'
  'watch:watch a CI build via API and emit spans'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-k --apikey)'{-k+,--apikey=}'[Honeycomb API key]:key:' \
  '(-d --dataset)'{-d+,--dataset=}'[Honeycomb dataset]:dataset:' \
  '(-c --ciprovider)'{-c+,--ciprovider=}'[CI provider name]:provider:(circleci travis-ci buildkite jenkins github-actions gitlab-ci codeship)' \
  '--apihost=[Honeycomb API host]:url:' \
  '--config=[config file]:file:_files' \
  '*--field=[span field key=value]:field:' \
  '*--header=[HTTP header]:header:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'buildevents command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '*::traceid_or_starttime_or_outcome:' && ret=0 ;;
      (step)
        _arguments \
          '*::stepid_or_starttime_or_name:' && ret=0 ;;
      (cmd)
        _arguments \
          '(-s --shell)'{-s+,--shell=}'[shell to use]:shell:_command_names' \
          '*::traceid_or_stepid_or_name:' && ret=0 ;;
      (watch)
        _arguments \
          '(-w --workflow-id)'{-w+,--workflow-id=}'[CI workflow id]:id:' \
          '(-j --job-name)'{-j+,--job-name=}'[CI job name]:name:' \
          '(-t --timeout)'{-t+,--timeout=}'[watch timeout (s)]:n:' && ret=0 ;;
    esac ;;
esac

return ret
