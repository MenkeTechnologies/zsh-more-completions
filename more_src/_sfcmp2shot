#compdef sfcmp2shot
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mcmp2shot.c
# Madagascar: convert CMPs to shots for regular 2-D geometry

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'positive=[initial offset orientation]:flag:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
