_mastodon-bluesky-sync() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c,--config}'=[config file (default mastodon-bluesky-sync.toml)]:config:_files -g "*.toml"' \
        '(-n --dry-run)'{-n,--dry-run}'[dry run — print what would be synced]' \
        '--skip-existing-posts[skip all existing posts (only sync future posts)]'
}

_mastodon-bluesky-sync "$@"
