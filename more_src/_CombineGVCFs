#compdef CombineGVCFs
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/CombineGVCFs.java
# GATK4: combine per-sample gVCF files into a single multi-sample gVCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-V,--variant}'[input gVCF file]:file:_files -g "*.(g.vcf|g.vcf.gz|vcf|vcf.gz)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-O --output)'{-O,--output}'[combined gVCF output file]:file:_files' \
  '(-D --dbsnp)'{-D,--dbsnp}'[dbSNP file to populate the ID column]:file:_files -g "*.(vcf|vcf.gz)"' \
  '--convert-to-base-pair-resolution[convert banded gVCFs to all-sites gVCFs]' \
  '--break-bands-at-multiples-of[break reference bands at multiples of this number]:n:' \
  '--call-genotypes[output called genotypes]' \
  '--input-is-somatic[merge inputs according to somatic (Mutect2) annotations]' \
  '--drop-somatic-filtering-annotations[drop filtering annotations from somatic gVCFs]' \
  '*:options:_files' && ret=0

return ret
