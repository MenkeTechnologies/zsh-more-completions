#compdef kpack-webhook webhook
# _kpack-webhook — kpack admission webhook (defaulting + validating + conversion for Image/Build/Builder/Buildpack/ClusterBuilder/ClusterBuildpack/ClusterStore/ClusterStack/ClusterLifecycle)
# upstream: https://github.com/buildpacks-community/kpack
# Source: cmd/webhook/main.go on tip; runtime config via Knative sharedmain + env vars (WEBHOOK_PORT) + knative.dev/pkg flags (--kubeconfig, --disable-ha).

_kpack-webhook() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--master=[k8s API server URL (overrides kubeconfig)]:url:_urls' \
        '--disable-ha[disable high availability functionality]'
}

_kpack-webhook "$@"
