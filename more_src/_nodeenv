#compdef nodeenv

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-n --node)'{-n,--node}'[Node.js version to install]:version' \
  '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs' \
  '--prebuilt[use prebuilt binaries]' \
  '--source[compile from source]' \
  '--without-ssl[build without SSL support]' \
  '--npm[npm version to install]:version' \
  '(-c --clean-src)'{-c,--clean-src}'[clean source after build]' \
  '(-l --list)'{-l,--list}'[list available Node.js versions]' \
  '--update[update to latest Node.js]' \
  '(-p --python)'{-p,--python}'[Python to use for building]:python:_files' \
  '--mirror[use mirror URL]:url' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--force[force reinstall]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:environment directory:_directories' && ret=0
return ret
