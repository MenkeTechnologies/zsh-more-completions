#compdef shasta
# _shasta — UC Santa Cruz Paolo Carnevali shasta CLI fast long-read de-novo genome assembler optimized for Oxford Nanopore reads using marker-graph approach producing GFA FASTA assembly graph through multi-stage pipeline supporting MinION PromethION GridION configurations for human genome low-resource scaling (UCSC team, C++); custom argparse
# upstream: https://github.com/paoloshasta/shasta

_shasta() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--input=+[fasta/q]:file:_files -g "*.fa *.fasta *.fq *.fastq *.gz"' \
        '--assemblyDirectory=+[dir]:dir:_files -/' \
        '--config=+[c]:c:(Nanopore-OldGuppy-Sep2020 Nanopore-Guppy3.0.5-May2020 Nanopore-Guppy3.6.0-May2020 Nanopore-Guppy5.0.7-May2021 Nanopore-Phased-Jan2022 Nanopore-Phased-R10-Fast-Nov2022 Nanopore-R10-Fast-Nov2022 Nanopore-R10-Slow-Nov2022 Nanopore-Phased-R9-Nov2022 Nanopore-Mode2-NotUseOldStyle-Nov2022 HiFi-Oct2021 Nanopore-Mode3-R9-Phased-Aug2023)' \
        '--threads=+[N]:n:' \
        '--memoryMode=+[m]:m:(anonymous filesystem disk anonymousMmap mmapBacked)' \
        '--memoryBacking=+[m]:m:(2M 4K)' \
        '--Kmers.k=+[N]:n:' \
        '--MinHash.m=+[N]:n:' \
        '--MinHash.minHashIterationCount=+[N]:n:' \
        '--MinHash.minBucketSize=+[N]:n:' \
        '--MinHash.maxBucketSize=+[N]:n:' \
        '--MinHash.minFrequency=+[N]:n:' \
        '--Align.alignMethod=+[m]:n:(0 1 3 4 5 6)' \
        '--Align.minAlignedMarkerCount=+[N]:n:' \
        '--Align.minAlignedFraction=+[N]:str:' \
        '--ReadGraph.creationMethod=+[m]:n:(0 1 2)' \
        '--ReadGraph.maxAlignmentCount=+[N]:n:' \
        '--MarkerGraph.minCoverage=+[N]:n:' \
        '--MarkerGraph.maxCoverage=+[N]:n:' \
        '--Reads.minReadLength=+[N]:n:' \
        '--Assembly.assembleAccessFunction=+[N]:n:' \
        '--Assembly.detangleMethod=+[m]:n:(0 1 2 3 4 5)' \
        '--Assembly.consensusCaller=+[c]:c:(Bayesian:guppy-3.0.5-a Bayesian:guppy-3.6.0-a Modal Median)' \
        '--Reads.palindromicReads.skipFlagging[skip palindrome flagging]' \
        '--command=+[cmd]:c:(assemble createBashCompletionScript explore listCommands listConfigurations cleanupBinaryData saveBinaryData)' \
        '*::'
}

_shasta "$@"
