#compdef pcp-collectl collectl
# Documentation: man pcp-collectl(1) / collectl(1p)
# Source: jmchilton/collectl collectl.pl — system collector, PCP wraps it (Perl Getopt::Long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-A --address)'{-A+,--address=}'[remote collector address[:port]]:host:_hosts' \
    '(-c --count)'{-c+,--count=}'[number of samples]:count:_default' \
    '(-C --config)'{-C+,--config=}'[config file]:file:_files' \
    '(-D --daemon)'{-D,--daemon}'[run in background]' \
    '(-d --debug)'{-d+,--debug=}'[debug mask]:mask:_default' \
    '(-f --filename)'{-f+,--filename=}'[output filename root]:file:_files' \
    '(-F --flush)'{-F+,--flush=}'[flush every N intervals]:n:_default' \
    '(-G --group)'{-G,--group}'[separate process records]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-i --interval)'{-i+,--interval=}'[sampling interval]:interval:_default' \
    '--iosize[show disk I/O sizes]' \
    '(-l --limits)'{-l+,--limits=}'[set value-change limits]:limits:_default' \
    '(-L --lustsvcs)'{-L+,--lustsvcs=}'[lustre services]:svcs:_default' \
    '(-m --messages)'{-m,--messages}'[show /var/log/messages]' \
    '(-N --nice)'{-N,--nice}'[run with nice priority]' \
    '(-o --options)'{-o+,--options=}'[user options]:options:_default' \
    '(-p --playback)'{-p+,--playback=}'[playback raw log]:file:_files' \
    '(-P --plot)'{-P,--plot}'[plot-format output]' \
    '--quiet[suppress informational messages]' \
    '(-r --rolllogs)'{-r+,--rolllogs=}'[roll logs at time/size]:spec:_default' \
    '(-R --runtime)'{-R+,--runtime=}'[runtime duration]:duration:_default' \
    '(-s --subsys)'{-s+,--subsys=}'[subsystems to collect]:subsys:_default' \
    '--sep=[output separator]:sep:_default' \
    '--ssh[allow remote ssh control]' \
    '--top=[top process display options]:opts:_default' \
    '--utc[use UTC timestamps]' \
    '--umask=[file creation umask]:mask:_default' \
    '--utime=[microsecond mask]:mask:_default' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-V --showdefs)'{-V,--showdefs}'[show defaults and switches]' \
    '(-w --wide)-w[wide output]' \
    '(-x --helpextend)'{-x,--helpextend}'[extended help]' \
    '(-X --helpall)'{-X,--helpall}'[full help]' \
    '--slabfilt=[slab filter]:pat:_default' \
    '--procfilt=[process filter]:pat:_default' \
    '--all[all subsystems]' \
    '--dskfilt=[disk filter]:pat:_default' \
    '--dskopts=[disk options]:opts:_default' \
    '--export=[export format]:fmt:_default' \
    '--from=[playback start time]:time:_default' \
    '--thru=[playback end time]:time:_default' \
    '--headerrepeat=[header repeat interval]:n:_default' \
    '--hr=[header repeat shortcut]:n:_default' \
    '--import=[import module]:mod:_default' \
    '--lustopts=[lustre options]:opts:_default' \
    '--memopts=[memory options]:opts:_default' \
    '--netfilt=[network filter]:pat:_default' \
    '--netopts=[network options]:opts:_default' \
    '--nfsopts=[NFS options]:opts:_default' \
    '--nfsfilt=[NFS filter]:pat:_default' \
    '--envopts=[environment options]:opts:_default' \
    '--envrules=[environment rules file]:file:_files' \
    '--envfilt=[environment filter]:pat:_default' \
    '--extract=[selective extraction]:opts:_default' \
    '--grep=[grep pattern]:pat:_default' \
    '--offsettime=[adjust timestamps]:offset:_default' \
    '--pname=[process display name]:name:_default' \
    '--procanalyze[process analysis mode]' \
    '--procopts=[process options]:opts:_default' \
    '--procstate=[process state filter]:state:_default' \
    '--rawtoo[also keep raw data]' \
    '--showsubsys[list subsystems]' \
    '--showoptions[list options]' \
    '--showheader[show data header]' \
    '--showcolheaders[show column headers]' \
    '--slabanalyze[slab analysis]' \
    '--slabopts=[slab options]:opts:_default' \
    '--verbose[verbose output]' \
    '--vmstat[vmstat-style output]' \
    '--whatsnew[show what is new]' \
    '--xopts=[extended options]:opts:_default' \
    && ret=0

return ret
