#compdef tfswitch

_tfswitch() {
    _arguments \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '(-l --list-all)'{-l,--list-all}'[list all available versions]' \
        '(-u --latest)'{-u,--latest}'[use latest stable version]' \
        '(-p --latest-pre)'{-p,--latest-pre}'[use latest pre-release version]' \
        '(-s --latest-stable)'{-s,--latest-stable}'=[use latest stable version matching constraint]:constraint' \
        '(-b --bin)'{-b,--bin}'=[custom binary path]:path:_files' \
        '(-d --default)'{-d,--default}'=[default version]:version' \
        '(-c --chdir)'{-c,--chdir}'=[directory with version file]:dir:_directories' \
        '--log-level=[log level]:level:(TRACE DEBUG INFO WARN ERROR FATAL PANIC)' \
        '--mirror=[mirror URL]:url' \
        '--show-latest[show latest version]' \
        '--show-latest-pre[show latest pre-release version]' \
        '1:version'
}

_tfswitch "$@"
