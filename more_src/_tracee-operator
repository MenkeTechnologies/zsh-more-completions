#compdef tracee-operator
# _tracee-operator — Kubernetes operator for managing Tracee installations (aquasecurity/tracee)
# upstream: https://github.com/aquasecurity/tracee
# Flags from cmd/tracee-operator/main.go (flag + controller-runtime).

_tracee-operator() {
    _arguments \
        '-metrics-bind-address=[metric endpoint bind address]:host\:port:' \
        '-health-probe-bind-address=[probe endpoint bind address]:host\:port:' \
        '-tracee-namespace=[namespace where Tracee is installed]:ns:' \
        '-tracee-name=[name of the Tracee DaemonSet]:name:' \
        '-configmap-name=[name of the Tracee ConfigMap]:name:' \
        '-leader-elect[enable leader election]' \
        '-zap-devel[development logging mode]' \
        '-zap-encoder=[zap log encoder]:enc:(json console)' \
        '-zap-log-level=[zap log level]:level:(debug info error)' \
        '-zap-stacktrace-level=[zap stack trace level]:level:(info error panic)'
}

_tracee-operator "$@"
