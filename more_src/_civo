#compdef civo

# Zsh completion for civo (Civo cloud CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[custom config file path]:file:_files' \
  '-o+[output format]:format:(json human custom)' \
  '--output=[output format]:format:(json human custom)' \
  '--pretty[pretty print JSON output]' \
  '--region=[API region]:region' \
  '-y[automatic yes to prompts]' \
  '--yes[automatic yes to prompts]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'apikey:manage API keys'
      'completion:generate shell completion'
      'database:manage databases'
      'diskimage:manage disk images'
      'domain:manage DNS domains'
      'firewall:manage firewalls'
      'instance:manage compute instances'
      'ip:manage reserved IP addresses'
      'kubernetes:manage Kubernetes clusters'
      'loadbalancer:manage load balancers'
      'network:manage networks'
      'objectstore:manage object stores'
      'permission:list available permissions'
      'quota:show quota usage'
      'region:manage regions'
      'size:list available instance sizes'
      'sshkey:manage SSH keys'
      'team:manage teams'
      'volume:manage volumes'
    )
    _describe -t commands 'civo command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      kubernetes)
        _arguments \
          '1:subcommand:(create list show update remove recycle config node-pool applications)' \
          '*:args' && ret=0
        ;;
      instance)
        _arguments \
          '1:subcommand:(create list show update remove reboot stop start tag firewall move-ip password public-ip)' \
          '*:args' && ret=0
        ;;
      firewall)
        _arguments \
          '1:subcommand:(create list show remove rule-create rule-list rule-remove)' \
          '*:args' && ret=0
        ;;
      network)
        _arguments \
          '1:subcommand:(create list show update remove)' \
          '*:args' && ret=0
        ;;
      volume)
        _arguments \
          '1:subcommand:(create list show update remove attach detach)' \
          '*:args' && ret=0
        ;;
      domain)
        _arguments \
          '1:subcommand:(create list show update remove record-create record-list record-show record-update record-remove)' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
