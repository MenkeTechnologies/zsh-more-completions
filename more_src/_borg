#compdef borg

# Zsh completion for borg - BorgBackup deduplicating archiver

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:Initialize an empty repository'
  'create:Create new archive'
  'extract:Extract archive contents'
  'check:Check repository consistency'
  'rename:Rename an existing archive'
  'list:List archive or repository contents'
  'diff:Diff contents of two archives'
  'delete:Delete an existing repository or archives'
  'prune:Prune repository archives according to rules'
  'compact:Free repository space by compacting segments'
  'info:Show repository or archive information'
  'mount:Mount repository or archive as FUSE filesystem'
  'umount:Unmount a FUSE filesystem'
  'key:Manage a repository key'
  'serve:Start in server mode'
  'upgrade:Upgrade a repository or archive'
  'recreate:Re-create archives'
  'export-tar:Create a tarball from an archive'
  'import-tar:Create a backup archive from a tarball'
  'config:Get and set configuration values'
  'with-lock:Run a user specified command with the repository lock held'
  'break-lock:Break the repository lock'
  'benchmark:Benchmark borg operations'
  'version:Display the borg version'
  'help:Extra help topics'
)

local -a common_flags=(
  '--critical[work on log level CRITICAL]'
  '--error[work on log level ERROR]'
  '--warning[work on log level WARNING (default)]'
  '(-v --info)'{-v,--info}'[work on log level INFO]'
  '--debug[enable debug output]'
  '--log-json[output one JSON object per log line]'
  '--lock-wait=[wait at most SECONDS for lock]:seconds:'
  '--show-version[show/log the borg version]'
  '--show-rc[show/log the return code]'
  '--umask=[set umask]:umask:'
  '--remote-path=[use PATH as borg executable on the remote]:path:'
  '--remote-ratelimit=[set network upload rate limit in kiByte/s]:rate:'
  '--consider-part-files[treat part files like normal files]'
  '--debug-topic=[enable TOPIC debugging]:topic:'
  '(-p --progress)'{-p,--progress}'[show progress information]'
  '(-h --help)'{-h,--help}'[show help message and exit]'
)

_arguments -s -S \
  $common_flags \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          $common_flags \
          '(-e --encryption)'{-e,--encryption}'=[select encryption key mode]:mode:(none authenticated authenticated-blake2 repokey repokey-blake2 keyfile keyfile-blake2)' \
          '--append-only[create an append-only mode repository]' \
          '--storage-quota=[set storage quota]:quota:' \
          '--make-parent-dirs[create parent directories]' \
          ':repository:' && ret=0
        ;;
      create)
        _arguments -s -S \
          $common_flags \
          '(-n --dry-run)'{-n,--dry-run}'[do not create a backup archive]' \
          '(-s --stats)'{-s,--stats}'[print statistics for the created archive]' \
          '--list[output verbose list of items]' \
          '--filter=[only display items matching the given filter]:filter:' \
          '--json[output stats as JSON]' \
          '(-e --exclude)'{-e,--exclude}'=[exclude paths matching pattern]:pattern:' \
          '--exclude-from=[read exclude patterns from file]:file:_files' \
          '--exclude-caches[exclude directories tagged as cache]' \
          '--exclude-if-present=[exclude directories containing file]:filename:' \
          '--keep-exclude-tags[if tag objects are specified with --exclude, don'\''t omit the tag objects]' \
          '(-C --compression)'{-C,--compression}'=[select compression algorithm]:compression:(none auto lz4 zlib zstd lzma)' \
          '--chunker-params=[specify chunker parameters]:params:' \
          '--one-file-system[stay in the same file system]' \
          '--numeric-ids[only store numeric user and group identifiers]' \
          '--noatime[do not store atime]' \
          '--noctime[do not store ctime]' \
          '--noflags[do not read and store flags]' \
          '--stdin-name=[use NAME in archive for stdin data]:name:' \
          '--stdin-user=[set user for stdin data]:user:' \
          '--stdin-group=[set group for stdin data]:group:' \
          '--stdin-mode=[set mode for stdin data]:mode:' \
          '--content-from-command[interpret PATH as command and store its stdout]' \
          ':archive:' \
          '*:path:_files' && ret=0
        ;;
      extract)
        _arguments -s -S \
          $common_flags \
          '--list[output verbose list of items]' \
          '(-n --dry-run)'{-n,--dry-run}'[do not actually change any files]' \
          '--numeric-ids[only obey numeric user and group identifiers]' \
          '--noflags[do not extract flags]' \
          '--noacls[do not extract ACLs]' \
          '--noxattrs[do not extract xattrs]' \
          '--stdout[write all extracted data to stdout]' \
          '--sparse[create holes in output sparse file]' \
          '(-e --exclude)'{-e,--exclude}'=[exclude paths matching pattern]:pattern:' \
          '--exclude-from=[read exclude patterns from file]:file:_files' \
          '--strip-components=[remove leading path components]:number:' \
          ':archive:' \
          '*:path:' && ret=0
        ;;
      list)
        _arguments -s -S \
          $common_flags \
          '--short[only print file/directory names]' \
          '--format=[specify format for file listing]:format:' \
          '--json[format output as JSON]' \
          '--json-lines[format output as JSON Lines]' \
          '(-e --exclude)'{-e,--exclude}'=[exclude paths matching pattern]:pattern:' \
          '--exclude-from=[read exclude patterns from file]:file:_files' \
          '--first=[consider first N archives]:number:' \
          '--last=[consider last N archives]:number:' \
          '--sort-by=[sort by keys]:keys:' \
          '--glob-archives=[only consider archives matching the glob]:glob:' \
          ':repository or archive:' && ret=0
        ;;
      delete)
        _arguments -s -S \
          $common_flags \
          '(-n --dry-run)'{-n,--dry-run}'[do not change the repository]' \
          '(-s --stats)'{-s,--stats}'[print statistics]' \
          '--cache-only[delete only the local cache]' \
          '--force[force deletion of corrupted archives]' \
          '--keep-security-info[keep the local security info]' \
          '--save-space[work slower but use less space]' \
          '--list[output verbose list of archives]' \
          '--first=[consider first N archives]:number:' \
          '--last=[consider last N archives]:number:' \
          '--glob-archives=[only consider archives matching the glob]:glob:' \
          ':repository or archive:' && ret=0
        ;;
      prune)
        _arguments -s -S \
          $common_flags \
          '(-n --dry-run)'{-n,--dry-run}'[do not change the repository]' \
          '(-s --stats)'{-s,--stats}'[print statistics]' \
          '--list[output verbose list of archives]' \
          '--force[force pruning of corrupted archives]' \
          '--keep-within=[keep all archives within this time interval]:interval:' \
          '--keep-last=[number of archives to keep]:number:' \
          '(-H --keep-hourly)'{-H,--keep-hourly}'=[number of hourly archives to keep]:number:' \
          '(-d --keep-daily)'{-d,--keep-daily}'=[number of daily archives to keep]:number:' \
          '(-w --keep-weekly)'{-w,--keep-weekly}'=[number of weekly archives to keep]:number:' \
          '(-m --keep-monthly)'{-m,--keep-monthly}'=[number of monthly archives to keep]:number:' \
          '(-y --keep-yearly)'{-y,--keep-yearly}'=[number of yearly archives to keep]:number:' \
          '--save-space[work slower but use less space]' \
          '--glob-archives=[only consider archives matching the glob]:glob:' \
          ':repository:' && ret=0
        ;;
      compact)
        _arguments -s -S \
          $common_flags \
          '--cleanup-commits[cleanup commit-only 17-byte segment files]' \
          '--threshold=[set minimum saved space percentage threshold]:percent:' \
          ':repository:' && ret=0
        ;;
      info)
        _arguments -s -S \
          $common_flags \
          '--json[format output as JSON]' \
          '--first=[consider first N archives]:number:' \
          '--last=[consider last N archives]:number:' \
          '--sort-by=[sort by keys]:keys:' \
          '--glob-archives=[only consider archives matching the glob]:glob:' \
          ':repository or archive:' && ret=0
        ;;
      mount)
        _arguments -s -S \
          $common_flags \
          '--foreground[stay in foreground, do not daemonize]' \
          '-o[extra mount options]:options:' \
          '--first=[consider first N archives]:number:' \
          '--last=[consider last N archives]:number:' \
          '--sort-by=[sort by keys]:keys:' \
          '--glob-archives=[only consider archives matching the glob]:glob:' \
          ':repository or archive:' \
          ':mountpoint:_directories' && ret=0
        ;;
      umount)
        _arguments -s -S \
          $common_flags \
          ':mountpoint:_directories' && ret=0
        ;;
      key)
        _arguments -s -S \
          $common_flags \
          ':subcommand:(change-passphrase export import migrate-to-repokey)' && ret=0
        ;;
      check)
        _arguments -s -S \
          $common_flags \
          '--repository-only[only perform repository checks]' \
          '--archives-only[only perform archive checks]' \
          '--verify-data[perform cryptographic archive data integrity verification]' \
          '--repair[attempt to repair any inconsistencies found]' \
          '--save-space[work slower but use less space]' \
          '--first=[consider first N archives]:number:' \
          '--last=[consider last N archives]:number:' \
          '--sort-by=[sort by keys]:keys:' \
          '--glob-archives=[only consider archives matching the glob]:glob:' \
          ':repository:' && ret=0
        ;;
      diff)
        _arguments -s -S \
          $common_flags \
          '--numeric-ids[only consider numeric user and group identifiers]' \
          '--same-chunker-params[override check of chunker parameters]' \
          '--sort[sort output lines]' \
          '--json-lines[format output as JSON Lines]' \
          '(-e --exclude)'{-e,--exclude}'=[exclude paths matching pattern]:pattern:' \
          '--exclude-from=[read exclude patterns from file]:file:_files' \
          ':archive1:' \
          ':archive2:' && ret=0
        ;;
      rename)
        _arguments -s -S \
          $common_flags \
          ':archive:' \
          ':new name:' && ret=0
        ;;
      serve)
        _arguments -s -S \
          $common_flags \
          '--restrict-to-path=[restrict repository access to path]:path:_directories' \
          '--restrict-to-repository=[restrict repository access to repository]:path:_directories' \
          '--append-only[only allow appending to repository segment files]' \
          '--storage-quota=[set storage quota]:quota:' && ret=0
        ;;
      config)
        _arguments -s -S \
          $common_flags \
          '(-c --cache)'{-c,--cache}'[get and set values from the repo cache]' \
          '(-d --delete)'{-d,--delete}'[delete the key from the config file]' \
          '--list[list the configuration of the repo]' \
          ':repository:' \
          ':name:' \
          ':value:' && ret=0
        ;;
      benchmark)
        _arguments -s -S \
          $common_flags \
          ':subcommand:(crud)' && ret=0
        ;;
      export-tar)
        _arguments -s -S \
          $common_flags \
          '--tar-filter=[filter program to pipe data through]:filter:' \
          '--list[output verbose list of items]' \
          '(-e --exclude)'{-e,--exclude}'=[exclude paths matching pattern]:pattern:' \
          '--exclude-from=[read exclude patterns from file]:file:_files' \
          '--strip-components=[remove leading path components]:number:' \
          ':archive:' \
          ':file:_files' && ret=0
        ;;
      import-tar)
        _arguments -s -S \
          $common_flags \
          '--tar-filter=[filter program to pipe data through]:filter:' \
          '(-s --stats)'{-s,--stats}'[print statistics]' \
          '--list[output verbose list of items]' \
          '--comment=[add a comment text to the archive]:comment:' \
          ':archive:' \
          ':file:_files' && ret=0
        ;;
      recreate)
        _arguments -s -S \
          $common_flags \
          '--list[output verbose list of items]' \
          '--filter=[only display items matching the given filter]:filter:' \
          '(-n --dry-run)'{-n,--dry-run}'[do not change the repository]' \
          '(-s --stats)'{-s,--stats}'[print statistics]' \
          '(-e --exclude)'{-e,--exclude}'=[exclude paths matching pattern]:pattern:' \
          '--exclude-from=[read exclude patterns from file]:file:_files' \
          '--exclude-caches[exclude directories tagged as cache]' \
          '--exclude-if-present=[exclude directories containing file]:filename:' \
          '(-C --compression)'{-C,--compression}'=[select compression algorithm]:compression:(none auto lz4 zlib zstd lzma)' \
          '--chunker-params=[specify chunker parameters]:params:' \
          '--comment=[add a comment text to the archive]:comment:' \
          '--target=[create a new archive with name]:name:' \
          '--glob-archives=[only consider archives matching the glob]:glob:' \
          ':repository or archive:' \
          '*:path:' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          $common_flags \
          '(-n --dry-run)'{-n,--dry-run}'[do not change the repository]' \
          '--inplace[rewrite repository in place]' \
          '--force[force upgrade]' \
          '--tam[require and enable manifest authentication]' \
          '--disable-tam[disable manifest authentication]' \
          ':repository:' && ret=0
        ;;
      with-lock)
        _arguments -s -S \
          $common_flags \
          ':repository:' \
          ':command:' \
          '*:arguments:' && ret=0
        ;;
      break-lock)
        _arguments -s -S \
          $common_flags \
          ':repository:' && ret=0
        ;;
    esac
    ;;
esac

return ret
