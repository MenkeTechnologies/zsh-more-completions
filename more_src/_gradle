#compdef gradle
# _gradle-cli — Gradle build automation tool (Gradle Inc, Groovy/Java/Kotlin); polyglot dependency + task runner
# upstream: https://github.com/gradle/gradle

_gradle-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-a[no rebuild project deps]' \
        '--no-rebuild[no rebuild project deps]' \
        '-b+[build file]:file:_files -g "*.gradle*"' \
        '--build-file+[build file]:file:_files -g "*.gradle*"' \
        '-c+[settings file]:file:_files' \
        '--settings-file+[settings file]:file:_files' \
        '--build-cache[enable build cache]' \
        '--no-build-cache[disable build cache]' \
        '--configuration-cache[enable config cache]' \
        '--no-configuration-cache[disable config cache]' \
        '--configuration-cache-problems+[config cache problems]:mode:(fail warn)' \
        '-D+[system property]:KEY=VAL:' \
        '-P+[project property]:KEY=VAL:' \
        '--project-prop+[project property]:KEY=VAL:' \
        '-i[info logging]' \
        '--info[info logging]' \
        '-w[warn logging]' \
        '--warn[warn logging]' \
        '-q[quiet logging]' \
        '--quiet[quiet logging]' \
        '-d[debug logging]' \
        '--debug[debug logging]' \
        '-S[full stack traces]' \
        '--full-stacktrace[full stack traces]' \
        '-s[stack traces]' \
        '--stacktrace[stack traces]' \
        '--profile[generate profile report]' \
        '--scan[generate build scan]' \
        '--no-scan[disable build scan]' \
        '--init-script+[init script]:file:_files' \
        '-I+[init script]:file:_files' \
        '-g+[gradle user home]:dir:_files -/' \
        '--gradle-user-home+[gradle user home]:dir:_files -/' \
        '-p+[project dir]:dir:_files -/' \
        '--project-dir+[project dir]:dir:_files -/' \
        '--project-cache-dir+[project cache dir]:dir:_files -/' \
        '--offline[offline]' \
        '--refresh-dependencies[refresh deps]' \
        '--rerun-tasks[rerun all tasks]' \
        '--max-workers+[max workers]:n:' \
        '--parallel[parallel project execution]' \
        '--no-parallel[no parallel]' \
        '--continue[continue on failure]' \
        '--continuous[continuous build]' \
        '-t[continuous build]' \
        '--watch-fs+[watch fs]:bool:(true false)' \
        '--daemon[force daemon]' \
        '--no-daemon[no daemon]' \
        '--foreground[run daemon in foreground]' \
        '--stop[stop daemon]' \
        '--status[print daemon status]' \
        '--dry-run[dry run]' \
        '-m[dry run]' \
        '--include-build+[composite build]:dir:_files -/' \
        '--export-keys[export gpg keys]' \
        '--write-locks[write deps locks]' \
        '--update-locks+[update locks]:str:' \
        '--write-verification-metadata+[write verification metadata]:str:' \
        '*:task:'
}

_gradle-cli "$@"
