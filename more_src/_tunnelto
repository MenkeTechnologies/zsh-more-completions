#compdef tunnelto

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'set-auth:store authentication key'
)

_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-k --key)'{-k,--key}'=[auth key]:key:' \
  '(-s --subdomain)'{-s,--subdomain}'=[requested subdomain]:name:' \
  '--host=[upstream host]:host:_hosts' \
  '(-t --use-tls)'{-t,--use-tls}'[use TLS to upstream]' \
  '(-p --port)'{-p,--port}'=[upstream port]:port:' \
  '--dashboard-port=[dashboard port]:port:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tunnelto subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (set-auth)
        _arguments '(-k --key)'{-k,--key}'=[auth key]:key:' && ret=0
        ;;
    esac
    ;;
esac

return ret
