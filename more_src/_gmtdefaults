#compdef gmtdefaults
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtdefaults.html
# Source: GenericMappingTools/gmt src/gmtdefaults.c — list/edit GMT defaults (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s \
    '(-D -L)-D-[print GMT system defaults]:scope:(s u)' \
    '(-D -L)-L[list user current GMT defaults]' \
    '*-V[verbose (stackable)]' \
    && ret=0

return ret
