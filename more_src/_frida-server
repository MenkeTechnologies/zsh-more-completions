#compdef frida-server
# Documentation: https://github.com/frida/frida-core/blob/main/server/server.vala
# Frida server daemon - exposes a frida endpoint to remote clients

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[output version information and exit]' \
  '--device=[serve device with the given ID]:device ID' \
  '(-l --listen)'{-l+,--listen=}'[listen on ADDRESS]:address' \
  '--certificate=[enable TLS using CERTIFICATE]:certificate:_files' \
  '--origin=[only accept requests with matching origin header]:origin' \
  '--token=[require authentication using TOKEN]:token' \
  '--asset-root=[serve static files inside ROOT]:root:_files -/' \
  '(-d --directory)'{-d+,--directory=}'[store binaries in DIRECTORY]:directory:_files -/' \
  '(-D --daemonize)'{-D,--daemonize}'[detach and become a daemon]' \
  '--policy-softener=[select policy softener]:softener:(system internal)' \
  '(-P --disable-preload)'{-P,--disable-preload}'[disable preload optimization]' \
  '(-C --ignore-crashes)'{-C,--ignore-crashes}'[disable native crash reporter integration]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' && ret=0

return ret
