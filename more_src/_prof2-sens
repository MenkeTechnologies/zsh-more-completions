#compdef prof2-sens
# Documentation: https://professor.hepforge.org/docs.sphinx213/
# prof2-sens - Professor2 gradient sensitivity to parameter shifts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--wfile=[weight file restricting plotting to a subset of histograms]:file:_files' \
  '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
  '--debug[turn on debug messages]' \
  '--quiet[turn off messages]' \
  '--grad[one-dimensional sensitivity based on gradient]' \
  '--cmap[colour map plots]' \
  '1:ipolfile:_files' && ret=0

return ret
