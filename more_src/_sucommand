#compdef sucommand
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/windowing_sorting_muting/sucommand.c
# Pipe traces having the same key header word to command

local ret=1

_arguments -s -S \
  'verbose=[wordy output]:verbose:(0 1)' \
  'key=[header key word to pipe on]:key' \
  'command=[command piped into]:command' \
  'dir=[0 change of key; -1 break in decrease; +1 break in increase]:dir:(0 -1 1)' \
  '*:file:_files' && ret=0

return ret
