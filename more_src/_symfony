#compdef symfony

# Zsh completion for symfony - Symfony CLI (local web server and project tools)

local curcontext="$curcontext" state line ret=1

_symfony_commands() {
  local -a commands=(
    'new:create a new Symfony project'
    'local\:server\:start:run a local web server'
    'local\:server\:stop:stop the local web server'
    'local\:server\:status:get the local web server status'
    'local\:server\:log:display the local web server log'
    'local\:server\:list:list local web servers'
    'local\:server\:ca\:install:create a local CA'
    'local\:server\:ca\:uninstall:uninstall the local CA'
    'local\:proxy\:start:start the local proxy'
    'local\:proxy\:stop:stop the local proxy'
    'local\:proxy\:status:get local proxy status'
    'local\:php\:list:list locally installed PHP versions'
    'local\:php\:refresh:refresh locally installed PHP versions'
    'local\:run:run a command with ENV vars for this project'
    'local\:security\:check:check for security issues in dependencies'
    'console:run a Symfony console command'
    'open\:local:open the local project in a browser'
    'open\:local\:rabbitmq:open the RabbitMQ dashboard'
    'open\:remote:open the remote project in a browser'
    'server\:start:alias for local:server:start'
    'server\:stop:alias for local:server:stop'
    'var-dump-server:run a dedicated HTTP server to collect dumps'
    'serve:alias for local:server:start'
    'link:link current project to a SymfonyCloud project'
    'book\:new:create a new Symfony Book'
    'book\:build:build a Symfony Book'
    'book\:serve:serve a Symfony Book'
    'cloud\:deploy:deploy a project to Platform.sh'
    'cloud\:ssh:SSH to the project'
    'cloud\:env\:list:list environments'
    'cloud\:env\:push:push code to an environment'
    'help:display help for a command'
    'list:list commands'
    'self-update:update symfony to the latest version'
    'version:display the Symfony CLI version'
  )
  _describe -t commands 'symfony command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-q --quiet)'{-q,--quiet}'[do not output any message]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-n --no-interaction)'{-n,--no-interaction}'[do not ask any interactive question]' \
  '--ansi[force ANSI output]' \
  '--no-ansi[disable ANSI output]' \
  '1: :_symfony_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      new)
        _arguments \
          '--version=[Symfony version]:version' \
          '--dir=[target directory]:dir:_directories' \
          '--webapp[create a webapp application]' \
          '--book[create a book project]' \
          '--full[create a full-stack application]' \
          '--demo[create the Symfony Demo application]' \
          '--cloud[initialize a Platform.sh cloud project]' \
          '--php=[PHP version]:version' \
          '--docker[install Docker setup]' \
          '--no-git[skip Git initialization]' \
          '--debug[enable debug mode]' \
          '*:project name' && ret=0
        ;;
      local:server:start|server:start|serve)
        _arguments \
          '-d[run in background]' \
          '--port=[preferred HTTP port]:port' \
          '--allow-http[prevent auto HTTPS]' \
          '--daemon[run in daemon mode]' \
          '--no-tls[use HTTP instead of HTTPS]' \
          '--document-root=[project document root]:dir:_directories' \
          '--passthru=[web front controller path]:file' \
          '--listen-ip=[bind IP address]:ip' \
          '--p12=[custom PKCS12 for HTTPS]:file:_files' \
          '--no-humans[disable human-readable output]' && ret=0
        ;;
      local:security:check)
        _arguments \
          '--format=[output format]:format:(ansi text json yaml markdown)' \
          '--disable-exit-code[do not exit with non-zero code]' \
          '--local[use local database]' && ret=0
        ;;
      self-update)
        _arguments \
          '--clean-old[remove old versions]' \
          '--enable-prereleases[enable pre-releases]' && ret=0
        ;;
    esac
    ;;
esac

return ret
