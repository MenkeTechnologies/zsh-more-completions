#compdef osmtest

# osmtest: OpenSM regression tester
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[config file]:file:_files' \
  '-f[flow id]:n:' \
  '-g[guid]:guid:' \
  '-w[wait]:s:' \
  '-d[log level]:n:' \
  '-l[log file]:file:_files' \
  '-i[inventory file]:file:_files' \
  '-s[stress mode]:n:' \
  '-V[show version]' \
  '*::osmtest args:_files' && ret=0
return ret
