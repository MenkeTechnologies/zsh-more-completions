_dsl() {
    _arguments -s \
        '-help[print information about available options]' \
        '-config=[path to TOML configuration file]:config file:_files -g "*.(toml|conf)"' \
        '-state-dir=[directory for persistent stats history (empty disables)]:state dir:_files -/' \
        '-secrets=[path to secrets file]:secrets file:_files' \
        '-d=[device type]:device type:(bintecelmeg_telnet bintecelmeg_ssh broadcom_telnet broadcom_ssh broadcom_http draytek_telnet draytek_ssh draytek_http fritzbox lancom_https lancom_ssh lantiq_telnet lantiq_ssh mediatek_http sagemcom_http speedport_http)' \
        '-u=[user name]:user:_users' \
        '*-o=[device-specific option (Key=Value, repeatable)]:option:' \
        '-private-key=[SSH private key file]:key file:_files' \
        '-known-hosts=[SSH known_hosts file (or IGNORE to skip)]:known_hosts file:_files' \
        '-web[start the web server (HTTP + SSE dashboard)]' \
        '-gui[start the graphical user interface (default; uses webview_go)]' \
        '1:host (modem IP or hostname):_hosts'
}

_dsl "$@"
