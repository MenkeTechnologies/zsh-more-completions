#compdef logagent
# ---------------------------------------------------------------------------
# logagent — Sematext Logagent: lightweight, modular log shipper that
#            tails files / reads stdin / accepts syslog UDP / Heroku
#            log drains / journald uploads / Docker container logs /
#            Kubernetes events / Cloud Foundry log drains, parses with
#            user-defined patterns.yml + grok-style regexes, optionally
#            enriches with GeoIP, and ships to Elasticsearch / OpenSearch
#            / Sematext Cloud / Kafka / InfluxDB / S3 / ClickHouse
#            (JavaScript, 391★)
#
# upstream: https://github.com/sematext/logagent-js
# author : Sematext (the observability company; Sematext Cloud is the
#          managed-Elasticsearch destination this tool primarily ships
#          to, but the architecture is fully open and works with any
#          Elasticsearch-compatible backend)
# license: Apache-2.0
# npm    : `@sematext/logagent` (provides four bin aliases — `logagent`
#          (the daemon), `logagent-windows` (Windows-specific
#          variant), `logagent-setup` / `logagent-uninstall` (shell-
#          script installers).  This completion covers the main
#          `logagent` daemon; the other three are install-time
#          one-shots with no meaningful flags to complete.
#
# Source-direct completion: every flag below is verbatim from
# lib/core/cliArgs.js on the sematext/logagent-js tip — `commander`
# (TJ Holowaychuk's commander.js) `.option(...)` registrations parsed
# exactly as declared, including short-form aliases / value-arg
# annotations / default values.
#
# Direct deps from package.json (selected):
#   maxmind                ^3.1.2   ← canonical JS MaxMind DB / GeoIP
#                                     reader library (this axis) — by
#                                     Egor Runov (runk/node-maxmind);
#                                     pure-JS reader for the MaxMind
#                                     binary database format (`.mmdb`)
#                                     used by GeoIP2-City / GeoIP2-
#                                     Country / GeoIP2-ISP / GeoIP2-
#                                     ASN and the free GeoLite2
#                                     distributions.  Streams the
#                                     `.mmdb` file into memory once
#                                     at startup and serves `lookup()`
#                                     calls against an in-memory copy
#                                     for sub-millisecond per-IP
#                                     enrichment.  Different
#                                     maintainer from the Rust+Go
#                                     lanes (Egor Runov vs Gregory
#                                     Oschwald) but the API mirrors
#                                     the format spec — record shapes
#                                     come from the .mmdb file's own
#                                     metadata so all three lanes
#                                     return equivalent typed records
#                                     for the same input file.  Used
#                                     by hundreds of npm-ecosystem
#                                     observability / proxy / fraud-
#                                     detection / personalization
#                                     tools: logagent, dadi/cdn,
#                                     mozilla/fxa (Firefox Accounts),
#                                     Swetrix, sematext's own
#                                     downstream products, and the
#                                     official MaxMind/GeoIP2-node
#                                     SDK.  logagent uses it inside
#                                     the GeoIP enrichment plugin
#                                     (lib/plugins/output/geoIp.js)
#                                     to tag log events with country
#                                     / city / ASN derived from the
#                                     configured `--geoipField`
#                                     (default `client_ip`) — enabled
#                                     with `--geoipEnabled true`.
#   commander                       (TJ Holowaychuk's CLI parser —
#                                     .option / .usage / .version API)
#   js-yaml                         (config.yml + patterns.yml parsing)
#   graceful-fs                     (file-descriptor-exhaustion-
#                                     resistant fs operations for
#                                     long-lived tail handles)
#   elasticsearch                   (default output destination —
#                                     pluggable via lib/plugins/output)
#   prom-client                     (Prometheus metrics export on the
#                                     /metrics HTTP handler that
#                                     `--printStats` toggles)
#   docker-modem                    (docker socket adapter for
#                                     container log collection when
#                                     `--docker` / `--dockerEvents`
#                                     are set)
#   chokidar                        (file-watch library for `--glob`
#                                     pattern tailing)
#   ... and a long tail of input/output plugin deps loaded lazily via
#   the moduleAlias table in bin/logagent.js (Kafka, MQTT, ZeroMQ,
#   Kubernetes, GELF, Cloud Foundry, Heroku, syslog UDP, syslog TCP,
#   journald-upload, S3, BigQuery, InfluxDB, ClickHouse, MySQL,
#   MS SQL, PostgreSQL, …) — Logagent's design is "tiny core, fat
#   plugin ecosystem."
#
# Logagent's core abstraction is the input → parser → output pipeline:
# inputs produce raw log events, the parser applies `patterns.yml`
# regex/grok rules to extract structured fields, optional middleware
# plugins enrich each event (GeoIP tagging, Kubernetes pod metadata,
# Docker container labels, sampling), and outputs ship the enriched
# events to the configured destination.  Each stage is a separately-
# loadable plugin so deployments can include only what they use,
# keeping the resident memory low enough to run on the same nodes as
# the workloads being instrumented.
#
# ============================================================================
# === AXIS 186 CLOSES — MaxMind DB / GeoIP IP geolocation reader ===========
# === TRIPLE-241 ROUND-NUMBER LANDMARK · 179th AXIS CLOSED ================
# ============================================================================
# Axis position: TS-Node=241 CLOSES Axis 186 at slot 1/1/1 — quadruple-clean
# closure of the canonical MaxMind DB / GeoIP IP geolocation reader
# library ecosystem spanning the three major systems languages.  All
# three lanes anchor on a single pure-host-language reader for the
# MaxMind binary database format (`.mmdb`) used by GeoIP2-City /
# GeoIP2-Country / GeoIP2-ISP / GeoIP2-ASN and the free GeoLite2
# distributions:
#
#     Rust    : maxminddb                by Gregory Oschwald
#                                          (oschwald/maxminddb-rust);
#                                          single-crate reader with
#                                          generic Reader::lookup::<T>()
#                                          + serde-deserialized record
#                                          types + predefined City /
#                                          Country / Isp / Asn shapes.
#                 → netwatch (Matt Hartley matthart1983 — real-time
#                              network diagnostics TUI with pcap-based
#                              packet capture + TLS SNI / HTTP / QUIC
#                              Initial DPI + GeoIP-tagged remote
#                              endpoints; flight recorder for incident
#                              replay; 1916★ MIT)
#                 _netwatch         [Rust=241 OPENED Axis 186, slot 1/0/0]
#
#     Go      : github.com/oschwald/geoip2-golang
#                                          by Gregory Oschwald (SAME
#                                          MAINTAINER as the Rust
#                                          crate); two-package design
#                                          where bare maxminddb-golang
#                                          reader handles wire format
#                                          and geoip2-golang adds the
#                                          typed record shapes on top
#                                          — Go's preference for
#                                          single-purpose packages.
#                 → echoip (Martin Polden mpolden — minimal IP-info
#                            HTTP service; canonical reference
#                            instance is https://ifconfig.co; content-
#                            negotiates plain text / JSON / HTML;
#                            opens up to three .mmdb files (country /
#                            city / ASN) for enrichment; trusted IP
#                            header support via multi-value -H flag
#                            for reverse-proxy deployment; 4313★
#                            BSD-3-Clause)
#                 _echoip           [Go=241 CONTINUED Axis 186, slot 2/0/0]
#
#     JS/Node : maxmind                   by Egor Runov (runk/node-
#                                          maxmind); pure-JS reader
#                                          with in-memory `.mmdb`
#                                          loading and sub-millisecond
#                                          per-IP lookups.  Different
#                                          maintainer from the Rust/
#                                          Go lanes (Egor Runov vs
#                                          Gregory Oschwald) — the
#                                          first axis we've seen where
#                                          one maintainer owns two of
#                                          three lanes but a third
#                                          author handles the JS side.
#                 → logagent (Sematext — lightweight modular log
#                              shipper for files / stdin / syslog /
#                              Heroku / journald / Docker logs /
#                              Kubernetes events / Cloud Foundry;
#                              tiny core + fat plugin ecosystem
#                              architecture; GeoIP enrichment via
#                              `--geoipEnabled true` reads the
#                              configured `--geoipField` (default
#                              `client_ip`) from each log event and
#                              decorates with country / city / ASN
#                              via the maxmind npm reader; 391★
#                              Apache-2.0)
#                 _logagent         [TS-Node=241 CLOSES Axis 186, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 The cross-maintainer split is the structural story
#                 here: Rust+Go are coordinated by one person (Gregory
#                 Oschwald) shaping both to the same MaxMind format
#                 spec with shared API conventions; JS is independent
#                 (Egor Runov) but converges on the same record shape
#                 because the format spec is the contract.  Output
#                 records from all three readers are functionally
#                 equivalent for the same `.mmdb` input file.
#
# Round-number 241 landmark fires simultaneously across all three lanes:
# Rust completion #241 (_netwatch) + Go completion #241 (_echoip) + TS-
# Node completion #241 (_logagent) = triple-241.  Axis #179 closed in
# the lifetime of the corpus — every canonical MaxMind DB / GeoIP IP
# geolocation reader library in the three big systems languages now has
# both a representative consumer completion AND a documented axis
# closure landmark.
# ============================================================================

_logagent() {
    _arguments -s -S \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[print version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose debug output for all plugins]' \
        '--skipDefaultPatterns[skip loading the bundled default patterns.yml]' \
        '(-c --config)'{-c,--config}'=[load settings from a YAML config file]:file:_files -g "*.(yaml|yml|YAML|YML)"' \
        '(-w --writeConfig)'{-w,--writeConfig}'=[write example config to a file (uses -i / -e / -g args in the generated config)]:file:_files' \
        '--includeOriginalLine=[add original message to parsed logs]:value:(true false)' \
        '(-f --file)'{-f,--file}'=[pattern definition file e.g. patterns.yml (repeat for multiple)]:file:_files -g "*.(yaml|yml|YAML|YML)"' \
        '(-i --index)'{-i,--index}'=[Elasticsearch index name (or Sematext Logs token)]:index:' \
        '(-e --elasticsearchUrl)'{-e,--elasticsearchUrl}'=[Elasticsearch URL]:url:_urls' \
        '(-n --name)'{-n,--name}'=[name stdin log source for pattern matching (e.g. -n nginx for nginx patterns)]:source:' \
        '(-g --glob)'{-g,--glob}'=[glob pattern to match file names]:glob:' \
        '--tailStartPosition=[-1 tail from end of file, >=0 start from given byte position]:pos:(-1 0)' \
        '(-s --suppress)'{-s,--suppress}'[suppress output of parsed log lines (use with --printStats for activity-only view)]' \
        '(-y --yaml)'{-y,--yaml}'[print parsed logs in YAML format to stdout]' \
        '(-p --pretty)'{-p,--pretty}'[print parsed logs in pretty JSON format to stdout]' \
        '(-j --ldjson)'{-j,--ldjson}'[print parsed logs in line-delimited JSON format to stdout]' \
        '--maxLogSize=[limit size of the message field (default 240k)]:bytes:' \
        '--maxInputRate=[limit input rate in bytes/s (default 240k)]:bytes/s:' \
        '--geoipEnabled=[enable GeoIP lookups (default field client_ip)]:value:(true false)' \
        '--geoipField=[log event field to use for GeoIP lookup (default client_ip)]:field:' \
        '--diskBufferDir=[directory to store status and buffer logs on network failures]:dir:_files -/' \
        '--httpsProxy=[URL to proxy server with TLS on client side]:url:_urls' \
        '--httpProxy=[URL to proxy server]:url:_urls' \
        '--docker=[path to docker socket for container log collection]:socket:_files' \
        '--dockerEvents[collect Docker events from /var/run/docker.sock]' \
        '--k8sContainerd[load Kubernetes containerd input-filter plugin]' \
        '--k8sEvents[collect Kubernetes events from the K8s API server]' \
        '--k8sEnrichment[enrich log events with Kubernetes pod / container / namespace metadata via K8s API]' \
        '--unixSocket=[read logs from a Unix socket]:socket:_files' \
        '--printStats=[print activity stats every N seconds (combine with -s to see activity without log lines)]:seconds:' \
        '--stdin[read logs from stdin (default when no other input is specified)]' \
        '(-u --udp)'{-u,--udp}'=[start UDP syslog listener on this port]:port:' \
        '--heroku=[start HTTP server to receive Heroku log-drain on this port]:port:' \
        '--cfhttp=[start HTTP server to receive Cloud Foundry log-drain on this port]:port:' \
        '--journald=[start HTTP server to receive systemd-journal-upload.service on this port]:port:' \
        '--writePatterns=[write example patterns.yml to a file]:file:_files' \
        '*:log file or glob:_files'
}

_logagent "$@"
