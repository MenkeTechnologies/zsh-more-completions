#compdef ocamlc
# _ocamlc-bin — OCaml bytecode compiler (OCaml/Inria, OCaml); compile .ml to bytecode + link
# upstream: https://github.com/ocaml/ocaml

_ocamlc-bin() {
    _arguments \
        '-a[build library]' \
        '-absname[print absolute paths]' \
        '-no-absname[print relative paths]' \
        '-annot[save annotations]' \
        '-args+[args file]:file:_files' \
        '-args0+[args file null sep]:file:_files' \
        '-bin-annot[save .cmt]' \
        '-c[compile only, no link]' \
        '-cc+[C compiler]:cmd:_command_names -e' \
        '-cclib+[C library]:str:' \
        '-ccopt+[C compiler option]:str:' \
        '-color+[color]:when:(auto always never)' \
        '-config[print config]' \
        '-config-var+[print config var]:var:' \
        '-custom[custom linking]' \
        '-dllib+[dynamic library]:str:' \
        '-dllpath+[dll search path]:dir:_files -/' \
        '-dtypes[save types]' \
        '-for-pack+[for pack]:str:' \
        '-g[debug info]' \
        '-no-g[no debug info]' \
        '-i[print signatures]' \
        '-I+[include path]:dir:_files -/' \
        '-H+[hidden include path]:dir:_files -/' \
        '-impl+[implementation file]:file:_files' \
        '-intf+[interface file]:file:_files' \
        '-intf-suffix+[intf suffix]:str:' \
        '-labels[use labels]' \
        '-linkall[link all]' \
        '-make-runtime[make runtime]' \
        '-modern[use labels]' \
        '-no-app-funct[no applicative functors]' \
        '-no-check-prims[no check prims]' \
        '-noassert[no assert]' \
        '-noautolink[no auto link]' \
        '-nolabels[no labels]' \
        '-nostdlib[no stdlib]' \
        '-o+[output file]:file:_files' \
        '-opaque[opaque]' \
        '-open+[open module]:mod:' \
        '-output-complete-exe[output complete exe]' \
        '-output-complete-obj[output complete object]' \
        '-output-obj[output object]' \
        '-pack[pack]' \
        '-pp+[preprocessor]:cmd:_command_names -e' \
        '-ppx+[ppx]:cmd:_command_names -e' \
        '-principal[principal mode]' \
        '-no-principal[no principal]' \
        '-rectypes[recursive types]' \
        '-no-rectypes[no rectypes]' \
        '-runtime-variant+[runtime variant]:str:' \
        '-with-runtime[with runtime]' \
        '-without-runtime[without runtime]' \
        '-S[keep assembly]' \
        '-shared[shared object]' \
        '-stop-after+[stop after pass]:pass:(parsing typing scheduling emit linking)' \
        '-strict-sequence[strict sequence]' \
        '-no-strict-sequence[no strict sequence]' \
        '-strict-formats[strict formats]' \
        '-no-strict-formats[no strict formats]' \
        '-thread[link with threads]' \
        '-unsafe[unsafe ops]' \
        '-unsafe-string[unsafe strings]' \
        '-safe-string[safe strings]' \
        '-use-runtime+[use runtime]:file:_files' \
        '-v[verbose]' \
        '-verbose[verbose]' \
        '-version[show version]' \
        '-vnum[show version number]' \
        '-vmthread[link with vmthreads]' \
        '-w+[warnings]:warnings:' \
        '-warn-error+[warn error]:warnings:' \
        '-warn-help[print warning help]' \
        '-where[print stdlib location]' \
        '*:file:_files'
}

_ocamlc-bin "$@"
