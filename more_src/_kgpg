#compdef kgpg
# Documentation: https://docs.kde.org/stable5/en/kgpg/kgpg/
# Reference accessed: 2026-05-16
# Verified: upstream KGpg handbook. Pure KDE GUI app; no documented
# app-specific CLI flags. Standard KAboutData/QCommandLineParser flags
# only.
# Removed from prior file: bogus man.archlinux.org search URL.

# kgpg: KDE GPG frontend (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' \
  '*:file:_files' && ret=0
return ret
