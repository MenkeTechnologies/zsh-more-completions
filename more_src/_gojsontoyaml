#compdef gojsontoyaml
# Documentation: https://github.com/brancz/gojsontoyaml
# Convert JSON to YAML (or YAML to JSON) on stdin/stdout

local ret=1

_arguments -s \
  '-yamltojson[convert yaml to json instead of the default json to yaml]' \
  '(-h -help --help)'{-h,-help,--help}'[show help]' && ret=0

return ret
