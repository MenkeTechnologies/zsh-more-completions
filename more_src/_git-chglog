#compdef git-chglog

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--init[generate .chglog config directory]' \
  '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
  '(-o --output)'{-o,--output}'[output path]:output file:_files' \
  '--next-tag=[treat unreleased commits as specified tag]:tag' \
  '--silent[suppress stdout output]' \
  '--no-color[disable color output]' \
  '--no-emoji[disable emoji output]' \
  '--no-case[case-insensitive tag pattern matching]' \
  '--tag-filter-pattern=[filter tags by pattern]:regex pattern' \
  '--sort=[sort order for entries]:order:(date semver)' \
  '--template=[path to custom template file]:template:_files' \
  '--repository-url=[URL of git repository]:URL' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '*:tag query' && ret=0

return ret
