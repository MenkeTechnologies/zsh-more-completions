#compdef mprof
# _mprof — memory_profiler timeline tool (pythonprofilers/memory_profiler)
# upstream: https://github.com/pythonprofilers/memory_profiler
# Subcommands from mprof.py ALL_ACTIONS.

_mprof() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'run:run a command or python file and record memory'
                'attach:attach to an existing process by PID or name'
                'rm:remove a given mprof file'
                'clean:remove all mprof files in cwd'
                'list:list existing profiles'
                'plot:plot memory consumption'
                'peak:print peak memory of a run'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                run|attach)
                    _arguments \
                        '--python[treat target as a python script]' \
                        '--include-children[track child processes]' \
                        '--multiprocess[track each process separately]' \
                        '-T+[sampling timeout (s)]:secs:' \
                        '--interval=[sampling interval (s)]:secs:' \
                        '-o+[output file]:file:_files' \
                        '--backend=[backend]:b:(psutil psutil_pss psutil_uss posix tracemalloc)' \
                        '*:command or PID:_command_names -e'
                    ;;
                plot)
                    _arguments \
                        '-o+[output image]:file:_files -g "*.(png|svg|pdf)"' \
                        '-t+[chart title]:title:' \
                        '-w+[plot window size (s)]:s:' \
                        '-b+[backend]:b:' \
                        '--xlabel=[X-axis label]:label:' \
                        '--ylabel=[Y-axis label]:label:' \
                        '--no-flame[do not draw flame plot]' \
                        '*:mprof file:_files -g "mprofile_*.dat"'
                    ;;
                rm)
                    _arguments '*:mprof file:_files -g "mprofile_*.dat"'
                    ;;
                list|peak)
                    _arguments '*:mprof file:_files -g "mprofile_*.dat"'
                    ;;
            esac
            ;;
    esac
}

_mprof "$@"
