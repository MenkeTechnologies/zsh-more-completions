#compdef cspell

# Zsh completion for CSpell - spell checker for code

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'lint:check files for spelling issues'
      'check:spell check files'
      'trace:trace a word through dictionaries'
      'suggest:suggest corrections for a word'
      'link:link dictionaries'
      'init:initialize cspell configuration'
    )
    _describe -t commands 'cspell command' commands && ret=0
    ;;
  args)
    case $line[1] in
      lint|check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[configuration file]:config:_files -g "*.{json,yaml,yml}"' \
          '--config=[configuration file]:config:_files -g "*.{json,yaml,yml}"' \
          '-v[verbose output]' \
          '--verbose[verbose output]' \
          '--locale=[locale]:locale' \
          '--language-id=[language ID]:language' \
          '-e+[exclude patterns]:patterns' \
          '--exclude=[exclude patterns]:patterns' \
          '--no-color[disable color output]' \
          '--color[enable color output]' \
          '--no-progress[disable progress]' \
          '--no-summary[disable summary]' \
          '--dot[include dot files]' \
          '--gitignore[respect .gitignore]' \
          '--no-gitignore[do not respect .gitignore]' \
          '--root=[root directory]:directory:_directories' \
          '--relative[show relative paths]' \
          '--show-context[show context for issues]' \
          '--show-suggestions[show suggestions]' \
          '--no-show-suggestions[hide suggestions]' \
          '--unique[report each word only once]' \
          '--words-only[only output the words]' \
          '--fail-fast[exit on first error]' \
          '--no-exit-code[always exit with 0]' \
          '--issues-summary-report[show issues summary]' \
          '-u+[issue format]:format:(legacy short full)' \
          '--issue-format=[issue format]:format:(legacy short full)' \
          '--cache[use cache]' \
          '--no-cache[do not use cache]' \
          '--cache-location=[cache location]:directory:_directories' \
          '--reporter=[reporter]:reporter:(default json csv)' \
          '*:file:_files' && ret=0
        ;;
      trace)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[configuration file]:config:_files -g "*.{json,yaml,yml}"' \
          '--config=[configuration file]:config:_files -g "*.{json,yaml,yml}"' \
          '--locale=[locale]:locale' \
          '--language-id=[language ID]:language' \
          '--all[show all dictionaries]' \
          '--only-found[show only found]' \
          '--no-color[disable color]' \
          '1:word' && ret=0
        ;;
      suggest)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[configuration file]:config:_files' \
          '--config=[configuration file]:config:_files' \
          '--num-suggestions=[number of suggestions]:num' \
          '1:word' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--output=[output file]:file:_files' \
          '--locale=[locale]:locale' && ret=0
        ;;
    esac
    ;;
esac

return ret
