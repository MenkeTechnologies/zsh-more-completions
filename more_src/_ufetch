#compdef ufetch
# Documentation: https://man.archlinux.org/search?q=ufetch
# Reference accessed: 2026-05-16

# Zsh completion for ufetch - tiny system info fetcher

local -a arguments

arguments=(
  '-h[show help information]'
  '-v[show ufetch version]'
  '-d[show default color scheme]'
  '-c[use custom colors]:colors:'
  '-p[do not show the logo]'
)

_arguments -s $arguments
