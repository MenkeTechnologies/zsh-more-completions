#compdef mgcb-editor
# Documentation: https://docs.monogame.net/articles/getting_started/tools/mgcb_editor.html
# MonoGame Content Builder Editor (mgcb-editor)

local ret=1

_arguments -s -S \
  '--register[register MGCB Editor as the default .mgcb handler]' \
  '--unregister[unregister MGCB Editor as the default .mgcb handler]' \
  '*:mgcb file:_files -g "*.mgcb"' && ret=0

return ret
