#compdef gosu
# Documentation: https://man.archlinux.org/search?q=gosu
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--version[display version]' \
  '--help[display help]' \
  '1:user[\:group]:_users' \
  '2:command:_command_names -e' \
  '*::args:_normal' && ret=0

return ret
