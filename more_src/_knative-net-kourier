#compdef knative-net-kourier
# _knative-net-kourier — Knative Serving Kourier (Envoy) ingress controller (sharedmain)
# upstream: https://github.com/knative-extensions/net-kourier
# Flags from cmd/kourier/main.go + knative.dev/pkg sharedmain on tip.

_knative-net-kourier() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-net-kourier "$@"
