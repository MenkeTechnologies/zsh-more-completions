#compdef prettyseq

# EMBOSS prettyseq: write DNA with translation in formatted layout
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s)]:DNA USA:_files' \
  '-range=[range of positions to display]:range:' \
  '-table=[genetic code]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '-ruler[draw a position ruler]' \
  '-plabel[label protein translation]' \
  '-nlabel[label nucleotide sequence]' \
  '-width=[output line width]:cols:' \
  '-outfile=[output file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
