#compdef rage rage-keygen rage-mount
# _rage-cli — rage Rust implementation of age file encryption (X25519/scrypt/ssh-rsa/ssh-ed25519); CLI-compatible with age
# upstream: https://github.com/str4d/rage

_rage-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-e --encrypt)'{-e,--encrypt}'[encrypt]' \
        '(-d --decrypt)'{-d,--decrypt}'[decrypt]' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-a --armor)'{-a,--armor}'[ASCII-armored output]' \
        '(-p --passphrase)'{-p,--passphrase}'[encrypt with passphrase]' \
        '(-r --recipient)'{-r,--recipient}'+[recipient]:recipient:' \
        '(-R --recipients-file)'{-R,--recipients-file}'+[recipients file]:file:_files' \
        '(-i --identity)'{-i,--identity}'+[identity file]:file:_files' \
        '(-j --plugin-name)'{-j,--plugin-name}'+[plugin]:name:' \
        '*:file:_files'
}

_rage-cli "$@"
