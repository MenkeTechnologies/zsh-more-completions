#   Last push  : 2026-02-21
#
# WHAT IT IS
#   Dada is an experimental programming language by Niko Matsakis and friends
#   that combines Rust-style ownership with Python-style ergonomics.  It
#   explores ideas such as "exclusive references" (Rust mutable refs
#   reformulated), Java-style shared/owned object models, async-by-default
#   evaluation, and an interpreter-first workflow.  The compiler is
#   implemented in Rust on top of the Salsa incremental query framework and
#   wired to a structopt-based CLI driver;  the workspace also contains
#   dada-lsp-server, dada-debug (live debugging server), dada-codegen (WASM
#   target), and dada-mdbook-preprocessor (the language playbook is rendered
#   from .md sources containing live Dada snippets).
#
# CLI ARGUMENT GRAMMAR  (verbatim from components/dada-lang/src/lib.rs structopt)
#   dada [GLOBAL OPTIONS] <command> [command options]
#
#   Global options (from `pub struct GlobalOptions`):
#     --no-color                 disable ANSI color in diagnostic rendering
#
#   Commands (from `pub enum Command`):
#     compile <INPUT>            Compile a Dada source file
#                                  INPUT  main source file to compile
#     run <INPUT>                Compile and immediately run a Dada source file
#                                  (flattens the same CompileOptions as compile)
#     test [OPTIONS] [INPUTS...] Run Dada test suite against one or more files
#                                  or directories
#                                  -v, --verbose    print each test as we run it
#                                  --porcelain      machine-readable JSON output
#                                                   instead of human-friendly text
#     debug [OPTIONS] <INPUT>    Launch the dada-debug live debug server
#                                  --port <N>       debug server port (default 2222)
#                                  + all compile options
#
# LANGUAGE-CORPUS POSITION
#   Dada is the 137th programming language entry in this completion corpus,
#   closing the 3+1 micro-cycle that began at R817 (_opcua-client/opcua 0.12
#   Rust=112 opens Axis 57) and continued through R818 (_opcuacheck/gopcua
#   Go=112) and R819 (_opcua-commander/node-opcua-client TS-Node=112 CLOSES
#   Axis 57 OPC-UA Industrial Automation Library at 1/1/1 + triple-112
#   landmark + 50-axes-closed half-century milestone).  Dada joins the
#   roster of exotic languages already in the corpus including Acton (R816
#   136th), Stanza (R812 135th), Rune, Egel, Mlatu, Gwion, Silq (quantum),
#   Mirth, Lawvere/bill, Cognac/Cognate, and Scrapscript.
#
#   No completion for `dada` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_dada() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--no-color[disable ANSI color in diagnostic rendering]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_dada_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                compile)   _dada_compile && ret=0 ;;
                run)       _dada_run     && ret=0 ;;
                test)      _dada_test    && ret=0 ;;
                debug)     _dada_debug   && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_dada_commands] )) ||
_dada_commands() {
    local -a commands
    commands=(
        'compile:compile a Dada source file'
        'run:compile and immediately run a Dada source file'
        'test:run the Dada test suite against one or more files or directories'
        'debug:launch the dada-debug live debug server'
    )
    _describe -t commands 'dada command' commands
}

(( $+functions[_dada_compile] )) ||
_dada_compile() {
    _arguments \
        '(- *)'{-h,--help}'[help for compile]' \
        ':main source file:_files -g "*.dada"'
}

(( $+functions[_dada_run] )) ||
_dada_run() {
    _arguments \
        '(- *)'{-h,--help}'[help for run]' \
        ':main source file:_files -g "*.dada"'
}

(( $+functions[_dada_test] )) ||
_dada_test() {
    _arguments \
        '(-v --verbose)'{-v,--verbose}'[print each test as we run it]' \
        '--porcelain[output machine-readable JSON instead of human-friendly text]' \
        '(- *)'{-h,--help}'[help for test]' \
        '*:test file or directory:_files -g "*.(dada|dadatest)"'
}

(( $+functions[_dada_debug] )) ||
_dada_debug() {
    _arguments \
        '--port=[debug server port (default 2222)]:port:' \
        '(- *)'{-h,--help}'[help for debug]' \
        ':main source file:_files -g "*.dada"'
}

_dada "$@"
