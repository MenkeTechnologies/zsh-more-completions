#compdef fls
# Documentation: https://www.sleuthkit.org/sleuthkit/man/fls.html
# Source: sleuthkit/sleuthkit man/fls.1 — lists file and directory names in a file system image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[display "." and ".." directory entries]' \
    '(-d -u)-d[display deleted entries only]' \
    '(-d -u)-u[display undeleted entries only]' \
    '(-D -F)-D[display directory entries only]' \
    '(-D -F)-F[display file (non-directory) entries only]' \
    '-f[specify file system type]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '-l[display file details in long format]' \
    '-m[display files in mactime format for timeline]:mount point:' \
    '-p[display full path for each entry]' \
    '-r[recursively display directories]' \
    '-s[time skew of original system in seconds]:seconds:' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset where file system starts in image]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-z[ASCII string of time zone of original system]:zone:' \
    '-v[verbose output to stderr]' \
    '-V[display version]' \
    '*:image file:_files' \
    && ret=0

return ret
