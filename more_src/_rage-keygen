#compdef rage-keygen
# Documentation: https://man.archlinux.org/search?q=rage-keygen
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-o+[write key to file]:key file:_files' \
  '--output=[write key to file]:key file:_files' && ret=0

return ret
