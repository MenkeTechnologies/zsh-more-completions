#compdef rage-keygen
# Documentation: https://github.com/str4d/rage
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-o+[write key to file]:key file:_files' \
  '--output=[write key to file]:key file:_files' \
  '-y[convert identity file to recipients file]' \
  '*:identity file:_files' && ret=0

return ret
