#compdef tegola
# Vector tile server for PostGIS and GeoPackage

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'cache:manage tile cache'
      'serve:start tile server'
      'version:show version information'
    )
    _describe -t commands 'tegola command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments \
          '--config[config file path]:file:_files' \
          '--port[port to listen on]:port:' && ret=0
        ;;
      cache)
        _arguments \
          '1:action:(seed purge)' \
          '--config[config file path]:file:_files' \
          '--map[map name]:map:' \
          '--min-zoom[minimum zoom level]:zoom:' \
          '--max-zoom[maximum zoom level]:zoom:' \
          '--bounds[tile bounds]:bounds:' \
          '--concurrency[number of workers]:n:' \
          '--overwrite[overwrite existing tiles]' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
