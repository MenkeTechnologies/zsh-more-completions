#compdef hererocks
# Documentation: https://github.com/luarocks/hererocks
# install Lua/LuaJIT and LuaRocks into a local directory

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help message and exit]' \
  '(-v --version)'{-v,--version}'[show program version number and exit]' \
  '(-l --lua)'{-l,--lua}'=[version of standard PUC-Rio Lua to install]:version' \
  '(-j --luajit)'{-j,--luajit}'=[version of LuaJIT to install]:version' \
  '(-r --luarocks)'{-r,--luarocks}'=[version of LuaRocks to install]:version' \
  '--show[show programs already present instead of installing]' \
  '(-i --ignore-installed)'{-i,--ignore-installed}'[install even if requested version already present]' \
  '--compat=[select compatibility flags for Lua]:flags:(default none all 5.1 5.2)' \
  '--patch[apply latest PUC-Rio Lua patches when available]' \
  '--cflags=[pass additional options to C compiler]:cflags' \
  '--target=[select how to build Lua]:target' \
  '--no-readline[do not use readline library when building Lua]' \
  '--timeout=[download timeout in seconds]:seconds' \
  '--downloads=[cache downloads and default git repos in directory]:dir:_files -/' \
  '--no-git-cache[do not cache default git repos]' \
  '--ignore-checksums[ignore checksum mismatches for downloads]' \
  '--builds=[cache Lua and LuaJIT builds in directory]:dir:_files -/' \
  '--verbose[show executed commands and their output]' \
  '*:location:_files -/' && ret=0

return ret
