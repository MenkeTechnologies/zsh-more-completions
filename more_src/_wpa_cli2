#compdef wpa_cli2 wpa-cli2 wpa-supplicant-cli2
# _wpa_cli2 — Jouni Malinen wpa_supplicant wpa_cli v2 CLI for the WPA Supplicant wireless authentication daemon control connecting to wpa_supplicant ctrl-iface scanning network configuration WPS PMKSA roaming status events (j-mw team, C); getopt
# upstream: https://w1.fi/wpa_supplicant/

_wpa_cli2() {
    local -a sub=(
        'status:show current status'
        'scan:scan for networks'
        'scan_results:show scan results'
        'add_network:add a network'
        'remove_network:remove a network'
        'set_network:set network parameter'
        'get_network:get network parameter'
        'select_network:select a network'
        'enable_network:enable a network'
        'disable_network:disable a network'
        'list_networks:list configured networks'
        'reconfigure:reload configuration'
        'reassociate:reassociate'
        'reconnect:reconnect'
        'disconnect:disconnect'
        'save_config:save configuration'
        'wps_pbc:start WPS PBC'
        'wps_pin:start WPS PIN'
        'wps_cancel:cancel WPS'
        'roam:roam to network'
        'level:set debug level'
        'log_level:set log level'
        'ping:ping wpa_supplicant'
        'quit:quit wpa_cli'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-i+[interface]:str:' \
        '-p+[ctrl path]:dir:_files -/' \
        '-P+[pid file]:file:_files' \
        '-B[run as daemon]' \
        '-g+[global ctrl iface]:str:' \
        '-G+[global timeout ms]:n:' \
        '-a+[action file]:file:_files' \
        '-r+[reconnect-on-failure path]:dir:_files -/' \
        '-s[silent]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wpa_cli2 subcommand' sub ;;
        args) ;;
    esac
}

_wpa_cli2 "$@"
