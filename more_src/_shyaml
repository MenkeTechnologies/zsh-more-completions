#compdef shyaml
# Documentation: https://man.archlinux.org/search?q=shyaml
# Reference accessed: 2026-05-16

# Zsh completion for shyaml YAML query helper (0k/shyaml)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '*::yaml path: _files' && ret=0

return ret
