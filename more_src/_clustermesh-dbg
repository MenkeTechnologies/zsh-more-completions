#compdef clustermesh-dbg
# _clustermesh-dbg — Cilium ClusterMesh debug CLI
# upstream: https://github.com/cilium/cilium
# Subcommands from clustermesh-apiserver/clustermesh-dbg/root.go on tip.

_clustermesh-dbg() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'troubleshoot:run guided ClusterMesh diagnostic flows'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_clustermesh-dbg "$@"
