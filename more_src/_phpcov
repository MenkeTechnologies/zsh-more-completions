#compdef phpcov
# Zsh completion for phpcov - PHP code coverage CLI tool
# https://github.com/sebastianbergmann/phpcov

local -a commands=(
  'execute:execute a PHP file and collect code coverage'
  'merge:merge code coverage reports'
  'patch-coverage:check patch coverage'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*::args:->args'

case $state in
  cmds)
    _describe -t commands 'phpcov command' commands
    ;;
  args)
    case $words[1] in
      execute)
        _arguments \
          '--configuration=[PHPUnit config file]:file:_files -g "*.xml(-.)"' \
          '--include=[include directory for coverage]:directory:_files -/' \
          '--add-uncovered[add uncovered files to report]' \
          '--process-uncovered[process uncovered files]' \
          '--clover=[generate Clover XML report]:file:_files' \
          '--cobertura=[generate Cobertura XML report]:file:_files' \
          '--crap4j=[generate Crap4J XML report]:file:_files' \
          '--html=[generate HTML report]:directory:_files -/' \
          '--php=[generate PHP report]:file:_files' \
          '--text=[generate text report]:file:_files' \
          '--xml=[generate XML report]:directory:_files -/' \
          '*:PHP file:_files -g "*.php(-.)"'
        ;;
      merge)
        _arguments \
          '--clover=[generate Clover XML report]:file:_files' \
          '--cobertura=[generate Cobertura XML report]:file:_files' \
          '--crap4j=[generate Crap4J XML report]:file:_files' \
          '--html=[generate HTML report]:directory:_files -/' \
          '--php=[generate PHP report]:file:_files' \
          '--text=[generate text report]:file:_files' \
          '--xml=[generate XML report]:directory:_files -/' \
          '*:coverage directory:_files -/'
        ;;
      patch-coverage)
        _arguments \
          '--clover=[Clover XML report to check]:file:_files -g "*.xml(-.)"' \
          '--diff=[unified diff to check]:file:_files' \
          '--path-prefix=[path prefix for mapping]:prefix:'
        ;;
    esac
    ;;
esac
