#compdef condor_on
# Documentation: https://man.archlinux.org/search?q=condor_on
# Reference accessed: 2026-05-16

# condor_on: start a Condor daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-pool[pool]:pool:' \
  '-name[daemon name]:name:' \
  '-addr[address]:sinful:' \
  '-master[master daemon]' \
  '-startd[startd]' \
  '-schedd[schedd]' \
  '-collector[collector]' \
  '-negotiator[negotiator]' \
  '-daemon[daemon type]:type:' \
  '-debug[debug]' \
  '-all[all hosts]' \
  '-constraint[constraint expression]:expr:' \
  '*:host:_hosts' && ret=0
return ret
