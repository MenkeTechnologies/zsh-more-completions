#compdef condor_on
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_on.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_on: start HTCondor daemons.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-pool[pool]:pool:' \
  '-name[daemon name / host]:name:' \
  '-addr[address (sinful)]:sinful:' \
  '-constraint[constraint expression]:expr:' \
  '-all[all hosts in pool]' \
  '-daemon[daemon type]:type:' \
  '*:host:_hosts' && ret=0
return ret
