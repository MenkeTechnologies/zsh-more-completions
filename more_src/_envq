#compdef envq
# Source: cargo binstall envq@0.1.3
# Probed via: completion zsh
# Repository: https://github.com/techouse/envq

autoload -U is-at-least

_envq() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[]' \
'--help[]' \
'--version[]' \
'--quiet[]' \
":: :_envq_commands" \
"*::: :->envq" \
&& ret=0
    case $state in
    (envq)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:envq-command-$line[1]:"
        case $line[1] in
            (get)
_arguments "${_arguments_options[@]}" : \
':KEY:_default' \
':PATH:_files' \
&& ret=0
;;
(set)
_arguments "${_arguments_options[@]}" : \
'--stdout[]' \
'--diff[]' \
'--check[]' \
':KEY:_default' \
':VALUE:_default' \
':PATH:_files' \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" : \
'--stdout[]' \
'--diff[]' \
'--check[]' \
':KEY:_default' \
':PATH:_files' \
&& ret=0
;;
(unset)
_arguments "${_arguments_options[@]}" : \
'--stdout[]' \
'--diff[]' \
'--check[]' \
':KEY:_default' \
':PATH:_files' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'--stdout[]' \
'--diff[]' \
'--check[]' \
':KEY:_default' \
':PATH:_files' \
&& ret=0
;;
(has)
_arguments "${_arguments_options[@]}" : \
':KEY:_default' \
':PATH:_files' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'--json[]' \
'--yaml[]' \
'--names[]' \
'--unique[]' \
':PATH:_files' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
':SHELL:(bash zsh fish powershell pwsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
'::COMMAND:(get set clear unset remove has list completion help)' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_envq_commands] )) ||
_envq_commands() {
    local commands; commands=(
'get:' \
'set:' \
'clear:' \
'unset:' \
'remove:' \
'has:' \
'list:' \
'completion:' \
'help:' \
    )
    _describe -t commands 'envq commands' commands "$@"
}
(( $+functions[_envq__subcmd__clear_commands] )) ||
_envq__subcmd__clear_commands() {
    local commands; commands=()
    _describe -t commands 'envq clear commands' commands "$@"
}
(( $+functions[_envq__subcmd__completion_commands] )) ||
_envq__subcmd__completion_commands() {
