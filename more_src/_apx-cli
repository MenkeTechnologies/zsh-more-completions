#compdef apx

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'autoremove:autoremove unused deps in subsystem'
  'clean:clean a subsystem'
  'completion:generate shell completion'
  'enter:open shell in subsystem'
  'export:export an app from subsystem'
  'help:show help'
  'init:initialize apx'
  'install:install package(s) in subsystem'
  'list:list installed packages'
  'pkgmanagers:manage package managers'
  'purge:remove package and configs'
  'remove:remove package'
  'run:run a command in a subsystem'
  'search:search for a package'
  'show:show package info'
  'stacks:manage stacks'
  'subsystems:manage subsystems'
  'unexport:remove exported app'
  'update:update package indexes'
  'upgrade:upgrade installed packages'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-n+[subsystem name]:n:' \
  '*--name=[subsystem name]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'apx command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (subsystems)
        _arguments \
          '1:subcommand:(list new rm reset)' \
          '*: :' && ret=0 ;;
      (stacks)
        _arguments \
          '1:subcommand:(list new rm update show export import)' \
          '*: :' && ret=0 ;;
      (pkgmanagers)
        _arguments \
          '1:subcommand:(list new rm export import show)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
