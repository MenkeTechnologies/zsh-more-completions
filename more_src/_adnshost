#compdef adnshost
# Documentation: adnshost --help (GNU adns)
# Source: GNU adns command-line DNS query tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(+e --no-env)'{+e,--no-env}'[do not look at environment]' \
    '(-f --pipe)'{-f,--pipe}'[read queries from stdin]' \
    '(-a --asynch)'{-a,--asynch}'[allow answers to be reordered]' \
    '(-Fs --fmt-simple -Fi --fmt-inline -Fa --fmt-asynch)'{-Fs,--fmt-simple}'[answers to stdout, errors to stderr (default)]' \
    '(-Fs --fmt-simple -Fi --fmt-inline -Fa --fmt-asynch)'{-Fi,--fmt-inline}'[answers and errors both to stdout]' \
    '(-Fs --fmt-simple -Fi --fmt-inline -Fa --fmt-asynch)'{-Fa,--fmt-asynch}'[fully-parseable output]' \
    '(-Vq --quiet -Vn --no-quiet -Vd --debug)'{-Vq,--quiet}'[no stderr output]' \
    '(-Vq --quiet -Vn --no-quiet -Vd --debug)'{-Vn,--no-quiet}'[unexpected problems only (default)]' \
    '(-Vq --quiet -Vn --no-quiet -Vd --debug)'{-Vd,--debug}'[debugging mode]' \
    '(--checkc --no-checkc --checkc-freq)--no-checkc[no developer consistency checks]' \
    '(--checkc --no-checkc --checkc-freq)--checkc[run consistency checks]' \
    '(--checkc --no-checkc --checkc-freq)--checkc-freq[checks very often]' \
    '--config=[config text override of /etc/resolv.conf]:config:' \
    '(-t --type)'{-t+,--type=}'[query type]:type:(a aaaa mx ns soa srv txt cname ptr hinfo rp loc)' \
    '(-i --ptr)'{-i+,--ptr=}'[reverse lookup]:addr:' \
    '--reverse[reverse in zone-like RBL]:addr zone:' \
    '(-s --search)'{-s,--search}'[use the search list]' \
    '*:query domain:_hosts' \
    && ret=0

return ret
