#compdef swayidle
# Documentation: https://man.archlinux.org/search?q=swayidle
# Reference accessed: 2026-05-16

# Zsh completion for swayidle - idle management daemon for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(-w)'-w'[wait for command to finish before continuing]' \
  '(-d)'-d'[enable debug output]' \
  '(-S)'-S'[specify seat]:seat' \
  '(-C)'-C'[path to config file]:file:_files' \
  '*:event specification'
