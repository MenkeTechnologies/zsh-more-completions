#compdef swayidle
# Documentation: https://manpages.debian.org/unstable/swayidle/swayidle.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for swayidle - idle management daemon for Wayland

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-d[enable debug output]' \
  '-w[wait for command to finish before continuing]' \
  '-S[specify seat to use]:seat:' \
  '-C[path to config file]:file:_files' \
  '*::event:->event' && ret=0

case $state in
  (event)
    local -a events=(
      'timeout:run command after N seconds of inactivity'
      'before-sleep:run command before system sleeps (systemd)'
      'after-resume:run command after system resumes (systemd)'
      'lock:run command on session lock signal (systemd)'
      'unlock:run command on session unlock signal (systemd)'
      'idlehint:set IdleHint after N seconds (systemd)'
    )
    _describe -t events 'event' events && ret=0
    ;;
esac

return ret
