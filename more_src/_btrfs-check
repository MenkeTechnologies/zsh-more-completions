#compdef btrfs-check

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--repair[try to repair the filesystem]' \
  '--readonly[run in read-only mode]' \
  '--init-csum-tree[create a new checksum tree]' \
  '--init-extent-tree[create a new extent tree]' \
  '--check-data-csum[verify data checksums]' \
  '--mode[check mode]:mode:(lowmem original)' \
  '--force[force check on a mounted filesystem]' \
  {-s,--super}'[use specified super block copy]:super block:(0 1 2)' \
  {-b,--tree-root}'[use specified tree root bytenr]:bytenr' \
  '--chunk-root[use specified chunk root bytenr]:bytenr' \
  '--progress[show progress]' \
  '-p[show progress]' \
  {-Q,--qgroup-report}'[report qgroup inconsistencies]' \
  ':device:_files' && ret=0

return ret
