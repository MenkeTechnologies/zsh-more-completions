#compdef msms
# Documentation: https://ccsb.scripps.edu/msms/documentation/
# Compute molecular surfaces by triangulation

local ret=1

_arguments -s \
  '-if[input file of sphere centers and radii]:file:_files' \
  '-of[output triangulated surface file prefix]:file:_files' \
  '-af[area output file]:file:_files' \
  '-probe_radius[probe sphere radius]:radius' \
  '-density[triangulation density vertex/A^2]:density' \
  '-hdensity[high density for problematic regions]:density' \
  '-no_area[disable surface area computation]' \
  '-no_header[omit 3-line headers from output]' \
  '-noh[skip hydrogen atoms]' \
  '-surface[surface type]:type:(tses ases)' \
  '-no_rest_on_pbr[do not restart on reentrant face errors]' \
  '-no_rest[do not restart computation]' \
  '-free_vertices[detect reduced surface free vertices]' \
  '-all_components[compute all surface components]' \
  '-one_cavity[compute one cavity from atom indices]:atoms' \
  '-socket[server mode via Unix domain socket]:service' \
  '-sinetd[server mode via internet daemon]' && ret=0

return ret
