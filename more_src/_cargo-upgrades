#compdef cargo-upgrades
# Documentation: https://gitlab.com/kornelski/cargo-upgrades
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Check for outdated dependencies in Cargo.toml. Simpler alternative to cargo-outdated.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--pre[include pre-release upgrades]' \
  '--plumbing[tab-separated machine output]' \
  '--manifest-path=[Cargo.toml]:file:_files -g "*.toml"'
