#compdef cargo-upgrades

# Zsh completion for cargo-upgrades (kornelski/cargo-upgrades, xflags CLI).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--pre[include pre-release upgrades]' \
  '--plumbing[tab-separated machine output]' \
  '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"'
