#compdef xmlchange
# Documentation: https://esmci.github.io/cime/versions/cesm2.2/html/Tools_user/xmlchange.html
# CIME: change variables in a case env_*.xml file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-d --debug)'{-d,--debug}'[print debug information to file]' \
  '(-v --verbose)'{-v,--verbose}'[add additional context to log messages]' \
  '(-s --silent)'{-s,--silent}'[print only warnings and error messages]' \
  '--caseroot[case directory to change (default current directory)]:dir:_files -/' \
  {--append,-append}'[append to the existing value rather than overwriting]' \
  {--subgroup,-subgroup}'[apply to this subgroup only]:subgroup' \
  {--id,-id}'[the variable to set]:id' \
  {--val,-val}'[the value to set]:value' \
  {--file,-file}'[XML file to edit]:file:_files' \
  {--delimiter,-delimiter}'[delimiter string in listofvalues (default comma)]:delimiter' \
  {--dryrun,-dryrun}'[parse settings and print key-value pairs without changing]' \
  {--noecho,-noecho}'[do not update CaseStatus with this change]' \
  '(-f --force)'{-f,--force}'[ignore typing checks and store value]' \
  '*:settings (var=value,...):' && ret=0

return ret
