#compdef nbb

# Zsh completion for nbb (Node.js babashka)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-e+[evaluate expression]:expression' \
  '-m+[call main function of namespace]:namespace' \
  '--classpath=[set classpath]:classpath' \
  '-cp+[set classpath]:classpath' \
  '--main=[call main function of namespace]:namespace' \
  '--nrepl-server[start nREPL server]' \
  '--port=[nREPL port]:port' \
  '--debug[enable debug output]' \
  '--help[show help]' \
  '--version[show version]' \
  '1:script file:_files -g "*.cljs"' \
  '*:script arguments' && ret=0

return ret
