#compdef nbb
# Documentation: https://github.com/babashka/nbb
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nbb (Node.js babashka)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-e+[evaluate Clojure expression]:expression' \
  '-m+[call -main function of namespace]:namespace' \
  '--classpath=[set classpath]:classpath' \
  '-cp+[set classpath]:classpath' \
  '--help[show help]' \
  '--version[show version]' \
  '1:script file or subcommand:_files -g "*.cljs"' \
  '*:script arguments' && ret=0

return ret
