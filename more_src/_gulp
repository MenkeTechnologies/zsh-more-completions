#compdef gulp
# Documentation: https://github.com/gulpjs/gulp-cli (lib/shared/options/cli-options.js)
# Reference accessed: 2026-05-29
# Gulp.js streaming JS build/task automation.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help information]' \
  '(- *)'{-v,--version}'[show version number]' \
  '*--preload=[preload a module before running tasks]:module:' \
  '(-f --gulpfile)'{-f,--gulpfile=}'[custom gulpfile path]:file:_files -g "gulpfile*.js"' \
  '--cwd=[current working directory]:dir:_directories' \
  '(-T --tasks)'{-T,--tasks}'[list all available tasks]' \
  '--tasks-simple[display tasks in simplified format]' \
  '--tasks-json[output task list as JSON]' \
  '--tasks-depth=[depth level for task hierarchy display]:depth:' \
  '--depth=[depth level for task hierarchy display]:depth:' \
  '--compact-tasks[display tasks in compact format]' \
  '--sort-tasks[sort tasks alphabetically]' \
  '--color[enable colored output]' \
  '--no-color[disable colored output]' \
  '(-S --silent)'{-S,--silent}'[suppress logging output]' \
  '--continue[continue execution after task failures]' \
  '--series[execute tasks serially instead of in parallel]' \
  '*'{-L,--log-level}'[control logging verbosity (stackable)]' \
  '*: :->args' && ret=0

case $state in
  args)
    local -a tasks
    if [[ -f gulpfile.js || -f gulpfile.mjs || -f gulpfile.ts || -f gulpfile.cjs ]]; then
      tasks=( ${(f)"$(gulp --tasks-simple 2>/dev/null)"} )
      [[ ${#tasks} -gt 0 ]] && _values 'gulp task' $tasks && ret=0
    fi
    [[ $ret -eq 1 ]] && _files && ret=0
    ;;
esac

return ret
