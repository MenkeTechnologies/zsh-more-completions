#compdef cadence-sql-tool
# _cadence-sql-tool — Cadence SQL schema management tool (cadence-workflow/cadence)
# upstream: https://github.com/cadence-workflow/cadence
# Subcommands from tools/sql/main.go (urfave/cli/v2).

_cadence-sql-tool() {
    local context state state_descr line
    typeset -A opt_args
    local -a common=(
        '(-ep --endpoint)'{-ep+,--endpoint=}'[SQL host]:host:_hosts'
        '(-p --port)'{-p+,--port=}'[SQL port]:port:'
        '(-u --user)'{-u+,--user=}'[SQL user]:user:'
        '(-pw --password)'{-pw+,--password=}'[SQL password]:pw:'
        '(-db --database)'{-db+,--database=}'[SQL database]:db:'
        '(-pl --plugin)'{-pl+,--plugin=}'[SQL plugin]:plugin:(mysql postgres sqlite)'
        '(-q --quiet)'{-q,--quiet}'[do not return error if quiet]'
        '--tls[enable TLS]'
        '--tls-cert-file=[TLS cert file]:file:_files'
        '--tls-key-file=[TLS key file]:file:_files'
        '--tls-ca-file=[TLS CA file]:file:_files'
    )

    _arguments -C \
        $common \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                setup-schema:'setup initial SQL schema'
                setup:'setup initial SQL schema'
                update-schema:'update SQL schema to a specific version'
                update:'update SQL schema to a specific version'
                create-database:'create database'
                create:'create database'
                drop-database:'drop database'
                drop:'drop database'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                setup-schema|setup)
                    _arguments $common \
                        '(-v --version)'{-v+,--version=}'[initial schema version]:ver:' \
                        '(-f --schema-file)'{-f+,--schema-file=}'[SQL schema file]:file:_files' \
                        '--disable-versioning[disable schema versioning]' \
                        '--overwrite[drop and recreate the schema]' ;;
                update-schema|update)
                    _arguments $common \
                        '(-d --schema-dir)'{-d+,--schema-dir=}'[directory of schema upgrades]:dir:_files -/' \
                        '(-v --version)'{-v+,--version=}'[target schema version]:ver:' \
                        '--dryrun[do not run, only print plan]' ;;
                create-database|create)
                    _arguments $common \
                        '(-db --database)'{-db+,--database=}'[database name]:name:' ;;
                drop-database|drop)
                    _arguments $common \
                        '(-db --database)'{-db+,--database=}'[database name]:name:' \
                        '(-f --force)'{-f,--force}'[do not prompt]' ;;
            esac
            ;;
    esac
}

_cadence-sql-tool "$@"
