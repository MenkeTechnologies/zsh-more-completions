# upstream: https://wapiti-scanner.github.io/

_wapiti-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbosity]:l:(0 1 2)' \
        '--verbose=+[l]:l:(0 1 2)' \
        '-u+[target URL]:str:' \
        '--url=+[url]:str:' \
        '--data=+[POST data]:str:' \
        '-f+[format]:f:(json xml html txt openvas csv)' \
        '--format=+[fmt]:f:(json xml html txt openvas csv)' \
        '-o+[output file/dir]:_files' \
        '--output=+[file]:_files' \
        '-m+[modules]:str:' \
        '--module=+[mods]:str:' \
        '-l+[scope]:s:(url folder domain page punk)' \
        '--scope=+[s]:s:(url folder domain page punk)' \
        '-x+[exclude URL]:str:' \
        '--exclude=+[url]:str:' \
        '-p+[proxy URL]:str:' \
        '--proxy=+[url]:str:' \
        '-c+[cookie file]:file:_files' \
        '--cookie=+[file]:file:_files' \
        '-a+[user:pwd]:str:' \
        '--auth-cred=+[user:pwd]:str:' \
        '--auth-type=+[t]:t:(basic digest ntlm post)' \
        '-r+[parameter remove]:str:' \
        '--remove=+[param]:str:' \
        '-n+[max links per page]:n:' \
        '--max-links-per-page=+[N]:n:' \
        '-d+[depth]:n:' \
        '--depth=+[N]:n:' \
        '-t+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '-T+[max scan time sec]:n:' \
        '--max-scan-time=+[sec]:n:' \
        '-S+[scan force]:s:(paranoid sneaky polite normal aggressive insane)' \
        '--scan-force=+[s]:s:(paranoid sneaky polite normal aggressive insane)' \
        '-H+[header]:str:' \
        '*-H+[header]:str:' \
        '--header=+[hdr]:str:' \
        '-A+[user agent]:str:' \
        '--user-agent=+[ua]:str:' \
        '--tasks=+[N]:n:' \
        '--update[update modules]' \
        '--list-modules[list modules]' \
        '--external-endpoint=+[url]:str:' \
        '--internal-endpoint=+[url]:str:' \
        '--no-bugreport[no bug report]' \
        '--color[enable color]' \
        '*:url:'
}

_wapiti-cli "$@"
