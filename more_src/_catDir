#compdef catDir
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# concatenate files in directory to stdout

local ret=1

_arguments -s -S \
  '-r[recurse into subdirectories]' \
  '-suffix=[restrict output to files ending with the specified suffix]:suffix' \
  '-wild=[match files using wildcard patterns]:pattern' \
  '-nonz[print the filename of non-zero length files]' \
  '*:dir:_files -/' && ret=0

return ret
