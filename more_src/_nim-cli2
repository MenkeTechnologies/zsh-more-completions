#compdef nim-cli2 nim2
# _nim-cli2 — Andreas Rumpf Nim Lang nim-cli2 CLI command-line frontend wrapping the Nim statically typed compiled systems programming language with Python-like syntax open-source originally Andreas Rumpf 2008 compiles to C C++ Objective-C JavaScript via NLVM LLVM-based backend metaprogramming macros generics templates concepts compile c cpp objc js compile build doc doc2 jsondoc check ctags buildIndex genDepend dump rst2html rst2tex e secret nop scriptcheck buildcache parsemd parseyaml nimsuggest pretty fenced markdown commands manyloops project (Andreas Rumpf Nim Lang Foundation team, Nim); custom argparse
# upstream: https://nim-lang.org/

_nim-cli2() {
    local -a sub=(
        'c:compile to C'
        'cc:compile to C'
        'cpp:compile to C++'
        'objc:compile to Objective-C'
        'js:compile to JavaScript'
        'compile:compile a project'
        'check:check syntax'
        'doc:generate documentation'
        'doc2:generate documentation v2'
        'jsondoc:generate JSON documentation'
        'ctags:generate ctags'
        'buildIndex:build doc index'
        'genDepend:generate dependency file'
        'dump:dump settings'
        'rst2html:convert RST to HTML'
        'rst2tex:convert RST to TeX'
        'e:run NimScript'
        'secret:run REPL'
        'nop:do nothing'
        'scriptcheck:check NimScript'
        'buildcache:rebuild caches'
        'parsemd:parse markdown'
        'parseyaml:parse YAML'
        'nimsuggest:nimsuggest server'
        'pretty:pretty print'
        'fenced:fenced output'
        'markdown:markdown output'
        'commands:list commands'
        'manyloops:show many loops'
        'project:show project info'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r[run]' \
        '--run[run after compile]' \
        '-d+[define]:str:' \
        '*-d+[define]:str:' \
        '--define=+[k=v]:str:' \
        '-u+[undefine]:str:' \
        '--undefine=+[name]:str:' \
        '-p+[path]:dir:_files -/' \
        '*-p+[path]:dir:_files -/' \
        '--path=+[dir]:dir:_files -/' \
        '*--path=+[dir]:dir:_files -/' \
        '-o+[out]:file:_files' \
        '--out=+[file]:file:_files' \
        '--outdir=+[dir]:dir:_files -/' \
        '--nimcache=+[dir]:dir:_files -/' \
        '--cc=+[name]:str:' \
        '--ccc=+[name]:str:' \
        '--cpu=+[name]:str:' \
        '--os=+[name]:str:' \
        '--debugger=+[d]:d:(native off gdb)' \
        '--debuginfo=+[v]:v:(on off)' \
        '--gc=+[mode]:m:(refc markandsweep boehm arc orc atomicArc go regions none)' \
        '--mm=+[mode]:m:(refc markandsweep boehm arc orc atomicArc go regions none)' \
        '--threads=+[v]:v:(on off)' \
        '--tlsEmulation=+[v]:v:(on off)' \
        '--app=+[t]:t:(console gui lib staticlib)' \
        '--checks=+[v]:v:(on off)' \
        '--objChecks=+[v]:v:(on off)' \
        '--fieldChecks=+[v]:v:(on off)' \
        '--rangeChecks=+[v]:v:(on off)' \
        '--boundChecks=+[v]:v:(on off)' \
        '--overflowChecks=+[v]:v:(on off)' \
        '--floatChecks=+[v]:v:(on off)' \
        '--nilChecks=+[v]:v:(on off)' \
        '--assertions=+[v]:v:(on off)' \
        '--warnings=+[v]:v:(on off)' \
        '--hints=+[v]:v:(on off)' \
        '--hint=+[h]:str:' \
        '*--hint=+[h]:str:' \
        '--warning=+[w]:str:' \
        '*--warning=+[w]:str:' \
        '--opt=+[level]:l:(none speed size)' \
        '--stackTrace=+[v]:v:(on off)' \
        '--lineTrace=+[v]:v:(on off)' \
        '--lineDir=+[v]:v:(on off)' \
        '--showAllMismatches=+[v]:v:(on off)' \
        '--styleCheck=+[v]:v:(hint error off)' \
        '--colors=+[v]:v:(on off)' \
        '--listCmd[list compilation commands]' \
        '--genScript[generate build script]' \
        '--genDeps[generate dependency file]' \
        '--cincludes=+[dir]:dir:_files -/' \
        '--clibdir=+[dir]:dir:_files -/' \
        '--clib=+[lib]:str:' \
        '--header=+[file]:file:_files' \
        '--passC=+[arg]:str:' \
        '*--passC=+[arg]:str:' \
        '--passL=+[arg]:str:' \
        '*--passL=+[arg]:str:' \
        '--cc.exe=+[path]:_files' \
        '--define:nimAllocPagesViaMalloc[alloc via malloc]' \
        '--mm=+[mode]:str:' \
        '--silent[silent]' \
        '--errorMax=+[N]:n:' \
        '--maxLoopIterationsVM=+[N]:n:' \
        '--processing=+[v]:v:(dots filenames off)' \
        '--threadanalysis=+[v]:v:(on off)' \
        '--tlsEmulation=+[v]:v:(on off)' \
        '--implicitStatic=+[v]:v:(on off)' \
        '--patterns=+[v]:v:(on off)' \
        '--experimental=+[feature]:str:' \
        '*--experimental=+[feature]:str:' \
        '--legacy=+[feature]:str:' \
        '*--legacy=+[feature]:str:' \
        '-w+[warnings level]:str:' \
        '--noMain=+[v]:v:(on off)' \
        '--useVersion=+[v]:str:' \
        '--multimethods=+[v]:v:(on off)' \
        '--genGuards=+[v]:v:(on off)' \
        '--asm[output asm]' \
        '--listFullPaths[full paths]' \
        '--seqsv2=+[v]:v:(on off)' \
        '--showTypes[show types]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nim subcommand' sub ;;
        args) _arguments '*:source:_files -g "*.nim *.nims *.nimble"' ;;
    esac
}

_nim-cli2 "$@"
