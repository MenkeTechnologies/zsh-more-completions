#compdef dawg2wordlist
# Documentation: https://man.archlinux.org/search?q=dawg2wordlist
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '(- *)'{-v,--version}'[show version]' \
  '1:unicharset file:_files' \
  '2:dawg file:_files' \
  '3:wordlist output file:_files' && ret=0

return ret
