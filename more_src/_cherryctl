#compdef cherryctl
# _cherryctl — Cherry Servers cherryctl official bare-metal cloud CLI for managing servers projects and SSH keys (cherryservers team, Go); cobra
# upstream: https://github.com/cherryservers/cherryctl

_cherryctl() {
    local -a sub=(
        'completion:generate completion'
        'image:image subcommands'
        'ip:ip subcommands'
        'order-options:order options subcommands'
        'plan:show available plans'
        'project:project subcommands'
        'region:region subcommands'
        'server:server subcommands'
        'sshkey:SSH key subcommands'
        'storage:block storage subcommands'
        'team:team subcommands'
        'user:show current user'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--token=+[api token]:str:' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '--debug[debug]' \
        '-d[debug]' \
        '--output=+[format]:f:(table json yaml csv)' \
        '-o+[format]:f:(table json yaml csv)' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cherryctl subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments '1:server cmd:(create get list update delete reboot reinstall rescue exit-rescue start stop reset-bmc-password)' ;;
                project|sshkey|team|ip|storage) _arguments '1:cmd:(create get list update delete)' ;;
                image|plan|region) _arguments '1:cmd:(list)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_cherryctl "$@"
