#compdef @codegenie/cli codegenie
# Documentation: https://github.com/CodeGenieApp/cli
# Reference accessed: 2026-05-22
# Verified: @codegenie/cli v1.8.0 oclif command reference.

# Zsh completion for @codegenie/cli - Code Genie serverless app generator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'codegenie command' \
      'generate[generate app definition or source code]' \
      'login[authenticate with Code Genie]' \
      'update[update CLI to latest channel]' \
      'autocomplete[generate shell completion script]' \
      'help[show command help]' && ret=0
    ;;
  args)
    case $line[1] in
      generate)
        _arguments \
          '--json[JSON output]' \
          '(-n --name)'{-n,--name}'[app name]:name:' \
          '(-d --description)'{-d,--description}'[app description]:text:' \
          '--deploy[deploy after generation]' \
          '(-p --awsProfileToCopy)'{-p,--awsProfileToCopy}'[AWS profile to copy]:profile:' \
          '(-r --replaceAppDefinition)'{-r,--replaceAppDefinition}'[replace existing app definition]' \
          '--generateAppDefinitionOnly[app definition only]' \
          '--idp[identity provider]:idp:(Google SAML)' && ret=0
        ;;
      update)
        _arguments '1:channel:' && ret=0
        ;;
      autocomplete)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
      login|help)
        _arguments '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
