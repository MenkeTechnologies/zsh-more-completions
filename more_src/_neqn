#compdef neqn
# Documentation: https://man7.org/linux/man-pages/man1/neqn.1.html
# groff eqn preprocessor for terminal (ascii) output; accepts eqn arguments

local ret=1

_arguments -s \
  '--help[display usage message]' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '-C[recognize .EQ and .EN followed by any character]' \
  '-d+[set left/right equation delimiters]:delimiters (xy)' \
  '-f+[set global equation font]:font' \
  '-m+[set minimum point size]:size' \
  '-M+[search dir for eqnrc first]:directory:_files -/' \
  '-N[prohibit newlines within delimiters]' \
  '-p+[set sub/superscript size offset in points]:points' \
  '-r[reduce sub/superscript type size at most once]' \
  '-R[do not load eqnrc]' \
  '-s+[set global point size]:size' \
  '-T+[prepare output for device]:device:(ascii latin1 utf8 cp1047 dvi html lbp lj4 ps pdf)' \
  '*:file:_files' && ret=0

return ret
