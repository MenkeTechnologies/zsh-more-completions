#compdef dipy_info
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_info.html
# DIPY: print information about NIfTI, bvals, bvecs or tractography files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--b0_threshold=[threshold for identifying b0 volumes]:thr' \
  '--bvecs_tol=[tolerance ensuring b-vectors are unit vectors]:tol' \
  '--bshell_thr=[threshold distinguishing b-values across shells]:thr' \
  '--reference=[reference anatomy for tractography files]:file:_files' \
  '*:input files:_files' && ret=0

return ret
