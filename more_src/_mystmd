#compdef mystmd myst
# MyST Markdown documentation tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a MyST project'
  'start:start development server'
  'build:build outputs'
  'clean:clean build artifacts'
  'templates:manage templates'
)

_arguments -s -S \
  '1:command:->command' \
  '--help[show help]' \
  '--version[show version]' \
  '--debug[enable debug mode]' \
  '*:argument:' && ret=0

case $state in
  (command)
    _describe -t commands 'mystmd command' commands && ret=0
    ;;
esac

return ret
