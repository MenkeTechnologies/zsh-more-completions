#compdef wstunnel
# Documentation: https://man.archlinux.org/search?q=wstunnel
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'client:run as a wstunnel client'
  'server:run as a wstunnel server'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)*'{-v,--verbose}'[verbose]' \
  '(--log-lvl)--log-lvl=[log level]:l:(off error warn info debug trace)' \
  '(--no-color)--no-color[no color]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wstunnel command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (client)
        _arguments \
          '*-L+[local-to-remote tunnel]:tun:' \
          '*-R+[remote-to-local tunnel]:tun:' \
          '*--upgrade-credentials=[upgrade creds]:creds:' \
          '*--upgrade-path-prefix=[path prefix]:p:' \
          '(--no-color)--no-color[no color]' \
          '(--connection-min-idle)--connection-min-idle=[min idle]:n:' \
          '(--connection-retry)--connection-retry=[connection retry]:t:' \
          '(--connection-retry-max)--connection-retry-max=[max retry]:n:' \
          '(--http-headers)*--http-headers=[HTTP header]:h:' \
          '(--http-proxy)--http-proxy=[HTTP proxy]:url:' \
          '(--http-proxy-login)--http-proxy-login=[proxy login]:u:' \
          '(--http-proxy-password)--http-proxy-password=[proxy password]:p:' \
          '(--socks5-proxy)--socks5-proxy=[SOCKS5 proxy]:url:' \
          '(--no-keep-alive)--no-keep-alive[no keep-alive]' \
          '(--websocket-mask-frame)--websocket-mask-frame[mask frame]' \
          '(--tls-sni-override)--tls-sni-override=[SNI]:s:' \
          '(--tls-sni-disable)--tls-sni-disable[disable SNI]' \
          '(--tls-verify-certificate)--tls-verify-certificate[verify cert]' \
          '(--tls-certificate)--tls-certificate=[client cert]:file:_files' \
          '(--tls-private-key)--tls-private-key=[client key]:file:_files' \
          '(--http-upgrade-path-prefix)--http-upgrade-path-prefix=[upgrade path]:p:' \
          '*: :' && ret=0 ;;
      (server)
        _arguments \
          '(--restrict-to)*--restrict-to=[restrict csv]:list:' \
          '(--restrict-config)--restrict-config=[restrict config]:file:_files' \
          '(--websocket-ping-frequency-sec)--websocket-ping-frequency-sec=[ping freq]:n:' \
          '(--websocket-mask-frame)--websocket-mask-frame[mask frame]' \
          '(--remote-to-local)*--remote-to-local=[R2L tunnel]:tun:' \
          '(--tls-certificate)--tls-certificate=[server cert]:file:_files' \
          '(--tls-private-key)--tls-private-key=[server key]:file:_files' \
          '(--tls-client-ca-certs)--tls-client-ca-certs=[client CA]:file:_files' \
          '(--http-proxy)--http-proxy=[HTTP proxy]:url:' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
