#compdef fftool
# Documentation: https://github.com/paduagroup/fftool/blob/master/README.md
# Build force-field input files for MD (LAMMPS, OpenMM, GROMACS, DL_POLY)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--box=[box length in A (cubic) or a,b,c[,alpha,beta,gamma]]:box dimensions' \
  '--rho=[density in mol/L]:density' \
  '--center[center box on origin]' \
  '--tol=[tolerance for Packmol (default 2.5)]:tolerance' \
  '--mix=[arithmetic or geometric sigma_ij]:mix:(a g)' \
  '--lmp[create LAMMPS files in.lmp data.lmp]' \
  '--allpairs[write all I-J pairs]' \
  '--units=[LAMMPS units real or metal]:units:(r m)' \
  '--pbc=[connect bonds across periodic boundaries]:axes:(x xy xyz)' \
  '--xml[create OpenMM files .xml .pdb/.mmcif]' \
  '--types[unique atom types for non-bonded pairs in xml]' \
  '--charmm[create CHARMM files .str .psf .pdb]' \
  '--gmx[create GROMACS files .top .gro .pdb]' \
  '--dlp[create DLPOLY files FIELD CONFIG]' \
  '--cos4[use cos4 dihedrals in DLPOLY FIELD]' \
  '*:n1 infile1 [n2 infile2 ...]:_files -g "*.(zmat|mol|pdb|xyz)"' && ret=0

return ret
