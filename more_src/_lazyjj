#compdef lazyjj

# Zsh completion for lazyjj - TUI for Jujutsu VCS

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --path)'{-p,--path}'[path to Jujutsu repository]:path:_files -/' \
  '(-r --revision)'{-r,--revision}'[initial revision to select]:revision:'
