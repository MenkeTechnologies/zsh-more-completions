#compdef lazyjj

# Zsh completion for lazyjj - TUI for Jujutsu version control system

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --path)'{-p,--path}'[specify repository path]:repo path:_files -/' \
  '(-r --revision)'{-r,--revision}'[specify initial revision]:revision'
