#compdef pcm-sensor-server
# Documentation: https://github.com/intel/pcm/blob/master/doc/PCM-EXPORTER.md
# Intel PCM metrics exporter over HTTP (JSON / Prometheus)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-d[run in the background]' \
  '-p[run on port]:port' \
  '(-l --listen)'{-l,--listen}'[listen on IP address]:address' \
  '(-r --reset)'{-r,--reset}'[reset programming of performance counters]' \
  '(-D --debug)'{-D,--debug}'[set debug verbosity level]:level' \
  '(-R --real-time)'{-R,--real-time}'[run with real-time priority]' && ret=0

return ret
