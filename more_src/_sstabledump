#compdef sstabledump
# Documentation: https://man.archlinux.org/search?q=sstabledump
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-d[output internal sstable structure for debugging]' \
  '-l[output as a list of partitions]' \
  '-t[only output token range]' \
  '-e[only output partition keys]' \
  '-x+[token range]:token:' \
  '-k+[only output specific keys]:key:' \
  '*:sstable file:_files -g "*-Data.db"' && ret=0

return ret
