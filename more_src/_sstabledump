#compdef sstabledump
# Documentation: https://cassandra.apache.org/doc/latest/cassandra/managing/tools/sstable/sstabledump.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-d[CQL row per line internal representation]' \
  '-e[enumerate partition keys only]' \
  '-l[output each row as a separate JSON object]' \
  '-t[print raw timestamps instead of iso8601]' \
  '*-k+[partition key(s) to include]:key:' \
  '*-x+[excluded partition key(s)]:key:' \
  '*:sstable file:_files -g "*-Data.db"' && ret=0

return ret
