#compdef podofopages
# Documentation: https://github.com/podofo/podofo/blob/master/tools/podofopages/podofopages.cpp
# podofopages - delete and move pages within a PDF document

local ret=1

_arguments -s -S \
  '--delete[delete the page NUMBER (0-based)]:page number' \
  '--move[move a page FROM TO (0-based)]:from page' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
