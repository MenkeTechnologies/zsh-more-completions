#compdef rawtextdump
# Documentation: https://www.libraw.org/docs (libraw samples)
# Reference accessed: 2026-05-20
# Verified: local `rawtextdump --help` output (libraw sample utility).

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input file:_files' \
  '2:start column:' \
  '3:start row:' \
  '4::raw channel:' \
  '5::area width:' \
  '6::area height:' && ret=0

return ret
