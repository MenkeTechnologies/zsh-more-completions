#compdef cnpg kubectl-cnpg
# Documentation: https://github.com/cloudnative-pg/cloudnative-pg
# Source: cloudnative-pg/cloudnative-pg cmd/kubectl-cnpg/main.go — kubectl plugin to manage CloudNativePG clusters.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _cnpg_cmds
_cnpg_cmds=(
    'backup:request an on-demand backup of a cluster'
    'certificate:manage cluster certificates'
    'destroy:destroy a cluster instance'
    'fence:fence one or more instances'
    'fio:run an fio storage benchmark on a cluster'
    'hibernate:hibernate a cluster'
    'install:generate operator install manifests'
    'logs:show logs from a cluster'
    'maintenance:set or unset maintenance mode on a cluster'
    'pgadmin:deploy pgAdmin against a cluster'
    'pgbench:run pgbench against a cluster'
    'promote:promote a designated instance'
    'psql:start a psql shell on the primary'
    'publication:manage logical replication publications'
    'reload:trigger a reload of a cluster'
    'report:produce a diagnostic report'
    'restart:restart a cluster'
    'snapshot:take a volume snapshot of a cluster'
    'status:show the status of a cluster'
    'subscription:manage logical replication subscriptions'
    'versions:show cnpg plugin and operator versions'
    'completion:generate shell completion script'
    'help:show help for a command'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'cnpg command' _cnpg_cmds && ret=0
        ;;
esac

return ret
