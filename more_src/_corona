#compdef corona
# Documentation: upstream README at github.com/ahmadawais/corona-cli
# Reference accessed: 2026-05-30
# corona-cli — track COVID-19 statistics globally from the terminal.
# Note: data sources aggregate from WHO/CDC; tool is npm-installed
# (`npm i -g corona-cli`) and invoked as `corona`.

local curcontext="$curcontext" state line ret=1
local -a _sort_fields
_sort_fields=(
  country
  cases
  cases-today
  deaths
  deaths-today
  recovered
  active
  critical
  per-million
)

_arguments -s -S \
  '(-s --sort)-s+[sort field]:field:($_sort_fields)' \
  '(-s --sort)--sort=[sort field]:field:($_sort_fields)' \
  '(-r --reverse)-r[reverse sort order]' \
  '(-r --reverse)--reverse[reverse sort order]' \
  '(-b --bar)-b[display bar chart (max 10 countries)]' \
  '(-b --bar)--bar[display bar chart (max 10 countries)]' \
  '(-c --chart)-c[display line chart]' \
  '(-c --chart)--chart[display line chart]' \
  '-g[logarithmic chart scale]' \
  '(-l --limit)-l+[restrict entries displayed]:N:' \
  '(-l --limit)--limit=[restrict entries displayed]:N:' \
  '(-m --minimal)-m[bare-bones table format]' \
  '(-m --minimal)--minimal[bare-bones table format]' \
  '(-x --xcolor)-x[single-color output]' \
  '(-x --xcolor)--xcolor[single-color output]' \
  '--help[show help]' \
  '1:target:(states $(echo china usa india brazil russia japan germany france italy uk))' \
  && ret=0

return ret
