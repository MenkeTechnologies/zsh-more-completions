#compdef adr-viewer
# Documentation: https://man.archlinux.org/search?q=adr-viewer
# Reference accessed: 2026-05-16

# adr-viewer — `adr-viewer --help`

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--adr-path=[ADR directory]:dir:_files -/'
  '--output=[HTML output path]:file:_files'
  '--title=[HTML title]:title:'
  '--serve[serve on localhost]'
  '--port=[HTTP port]:port:'
  '--template-dir=[template dir]:dir:_files -/'
  '--help[show help]' && ret=0

return ret
