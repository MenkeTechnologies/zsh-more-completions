#compdef abc2midi

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-h[show help]' \
  '-Q+[default tempo (default 120)]:bpm:' \
  '-EA[no rolls]' \
  '-NFNP[no fermata pause]' \
  '-NFER[no fermata effect]' \
  '-CSM[chord swing meter (style)]' \
  '-OCC[old chord convention]' \
  '-STFW[strict word handling]' \
  '-RS[restart silence]' \
  '-BF[B field is voice]' \
  '-NCOM[no comments]' \
  '-NCOMC[no centering of strings]' \
  '-CS[chord settings]' \
  '-NFOG[no fog effect]' \
  '-NPLAY[no playback]' \
  '-HARP[harpsichord style]' \
  '-VB[verbose mode]' \
  '-c+[transpose semitones]:n:' \
  '-RZ+[rhythm style]:n:' \
  '-T+[select tune number]:n:' \
  '-X+[select tune by reference number]:n:' \
  '-o+[output midi file]:file:_files -g "*.mid"' \
  '*:ABC tune file:_files -g "*.abc"' && ret=0

return ret
