#compdef trustcachectl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'query:query loaded trustcaches for the given cdhash'
  'load:load a trustcache'
  'help:show helpful information'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'trustcachectl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (load)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
