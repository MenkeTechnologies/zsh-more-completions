#compdef seiscomp
# Documentation: https://www.seiscomp.de/doc/apps/seiscomp.html
# SeisComP control script: manage SeisComP modules

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --interactive)'{-i,--interactive}'[allow interactive deletion]' \
  '--csv[machine-readable CSV output]' \
  '--invert[reverse module selection]' \
  '--wait=[lock acquisition timeout seconds]:seconds:' \
  '--asroot[allow execution as root]' \
  '1:command:(start stop restart reload enable disable check status exec setup update-config install-deps print list help alias shell)' \
  '*::module:' && ret=0

return ret
