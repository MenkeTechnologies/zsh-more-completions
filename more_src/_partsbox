#compdef partsbox
# Documentation: https://man.archlinux.org/search?q=partsbox
# Reference accessed: 2026-05-16

# PartsBox: electronics inventory management CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*::partsbox subcommand and args:_files' && ret=0
return ret
