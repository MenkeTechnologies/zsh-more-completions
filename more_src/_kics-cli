#compdef kics
# Documentation: https://man.archlinux.org/search?q=kics
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'analyze:run KICS analyzer'
  'completion:generate completion'
  'generate-id:generate query ID'
  'help:show help'
  'list-platforms:list supported platforms'
  'remediate:remediate findings'
  'scan:scan files for issues'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--ci[CI mode]' \
  '*--profiling=[profiling]:p:(CPU MEM)' \
  '*--log-format=[log format]:f:(json text pretty)' \
  '*--log-file[log to file]' \
  '*--log-level=[log level]:l:(TRACE DEBUG INFO WARN ERROR)' \
  '*--log-path=[log path]:dir:_files -/' \
  '*--no-color[no color]' \
  '*--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kics command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (scan)
        _arguments \
          '(-p --path)*'{-p+,--path=}'[scan paths csv]:list:' \
          '(-q --queries-path)*'{-q+,--queries-path=}'[queries path]:dir:_files -/' \
          '(-o --output-path)'{-o+,--output-path=}'[output dir]:dir:_files -/' \
          '*--output-name=[output filename]:s:' \
          '*--report-formats=[report formats csv]:list:(all asff csv cyclonedx glsast html json junit pdf sarif sonarqube gitlab-sast)' \
          '*--type=[platform type csv]:list:(Ansible CloudFormation Kubernetes Terraform OpenAPI Dockerfile DockerCompose AzureResourceManager GoogleDeploymentManager GRPC Crossplane Buildah ServerlessFW Common)' \
          '*--exclude-paths=[exclude paths csv]:list:' \
          '*--exclude-categories=[exclude cats csv]:list:' \
          '*--exclude-results=[exclude results csv]:list:' \
          '*--exclude-queries=[exclude queries csv]:list:' \
          '*--exclude-severities=[exclude severities csv]:list:' \
          '*--include-queries=[include queries csv]:list:' \
          '*--minimal-ui[minimal UI]' \
          '*--no-progress[no progress]' \
          '*--silent[silent]' \
          '*--config=[config file]:file:_files' \
          '*--secrets-regexes-path=[secrets regex]:file:_files' \
          '*--disable-secrets[disable secrets]' \
          '*--disable-cis-descriptions[disable CIS desc]' \
          '*--fail-on=[fail on csv]:list:(high medium low info trace)' \
          '*: :_files' && ret=0 ;;
      (remediate)
        _arguments \
          '(-r --results)'{-r+,--results=}'[results file]:file:_files' \
          '(-i --include-ids)*'{-i+,--include-ids=}'[ids csv]:list:' \
          '*--similarity-id=[similarity id]:id:' \
          '*: :_files' && ret=0 ;;
      (list-platforms|version)
        _arguments '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
