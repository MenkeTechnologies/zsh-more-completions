#compdef phenix.secondary_structure_restraints
# Documentation: https://phenix-online.org/documentation/reference/secondary_structure_restraints.html
# phenix.secondary_structure_restraints - detect and output H-bond/SS restraints

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'show_all_params=[show all parameters]:bool:(True False)' \
  'filter_outliers=[filter outliers]:bool:(True False)' \
  'format=[output restraint format]:fmt:(phenix phenix_refine phenix_bonds pymol pdb refmac kinemage csv)' \
  'quiet=[quiet output]:bool:(True False)' \
  'verbose=[verbosity level]:n:' \
  'output_prefix=[output file prefix]:prefix:' \
  'ignore_annotation_in_file=[ignore annotation present in input file]:bool:(True False)' \
  'file_name=[input file name]:file:_files' \
  'ss_by_chain=[find secondary structure within individual chains]:bool:(True False)' \
  'from_ca_conservative=[make from_ca method more conservative]:bool:(True False)' \
  'max_rmsd=[max RMSD for chain comparison]:val:' \
  'use_representative_chains=[use representative chains with identical sequences]:bool:(True False)' \
  'max_representative_chains=[maximum number of representative chains]:n:' \
  'enabled=[turn on secondary structure restraints (main switch)]:bool:(True False)' \
  'search_method=[method for searching protein secondary structure]:method:(ksdssp from_ca cablam)' \
  'distance_ideal_n_o=[target hydrogen bond length]:val:' \
  'distance_cut_n_o=[hydrogen bond cutoff distance]:val:' \
  'remove_outliers=[exclude bonds exceeding distance cutoff]:bool:(True False)' \
  'restrain_hbond_angles=[restrain hydrogen bond angles]:bool:(True False)' \
  'hbond_distance_cutoff=[nucleic acid hydrogen bond limit]:val:' \
  'scale_bonds_sigma=[multiplier for hydrogen bond length sigmas]:val:' \
  '*:file:_files' && ret=0

return ret
