#compdef umami-cli umami
# _umami-cli — Umami umami-cli CLI command-line frontend wrapping the Umami open-source privacy-focused web analytics REST API managing websites users teams sessions events pageviews realtime metrics insights reports goals automation share-token domain-tracking session-export-API-key-token (Umami team, Go); cobra
# upstream: https://umami.is/

_umami-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'website:website management'
        'user:user management'
        'team:team management'
        'event:event operations'
        'pageview:pageview operations'
        'session:session operations'
        'metric:metrics operations'
        'realtime:realtime stats'
        'insight:insight operations'
        'report:report operations'
        'goal:goal operations'
        'share:share token operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--api-key=+[key]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--website-id=+[id]:str:' \
        '--team-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--insecure[skip TLS verify]' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'umami-cli subcommand' sub ;;
        args)
            case $words[1] in
                website|user|team|event|pageview|session|insight|report|goal|share) _arguments '1:op:(list get create update delete enable disable)' '*:id:' ;;
            esac
            ;;
    esac
}

_umami-cli "$@"
