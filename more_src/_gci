#compdef gci
# Documentation: https://github.com/daixiang0/gci
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gci: tool to control Go package import order deterministically.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'write:write formatted imports to file'
      'list:print filenames that need formatting'
      'diff:print git-style diff to STDOUT'
      'print:output the formatted file'
      'completion:generate shell autocompletion script'
      'help:help about any command'
    )
    _describe -t commands 'gci command' commands && ret=0
    ;;
  args)
    case $line[1] in
      write|list|diff|print)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-s --section)'{-s+,--section=}'[section configuration]:section:(standard default blank dot alias newline)' \
          '--custom-order[enable custom order]' \
          '--skip-generated[skip generated files]' \
          '--skip-vendor[skip vendor directory]' \
          '(-d --debug)'{-d,--debug}'[enable debug output]' \
          '*:files:_files -g "*.go"' && ret=0
        ;;
    esac
    ;;
esac

return ret
