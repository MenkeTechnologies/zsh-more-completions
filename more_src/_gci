#compdef gci

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:format Go import lines'
      'write:write formatted import lines to file'
      'list:list files with unformatted imports'
      'diff:display diff of formatted imports'
      'print:print formatted imports'
    )
    _describe -t commands 'gci command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run|write|list|diff|print)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-s+[section configuration]:section:(standard default prefix\(github.com/foo\) dot blank newline alias)' \
          '--section=[section configuration]:section:' \
          '--skip-generated[skip generated files]' \
          '--skip-vendor[skip vendor directory]' \
          '--custom-order[enable custom order]' \
          '--no-inline-comments[disallow inline comments]' \
          '--no-prefix-comments[disallow prefix comments]' \
          '-d[display diffs]' \
          '*:files:_files -g "*.go"' && ret=0
        ;;
    esac
    ;;
esac

return ret
