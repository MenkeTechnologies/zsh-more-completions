#compdef zebra
# Documentation: https://docs.frrouting.org/en/latest/zebra.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: -e --keep_kernel (upstream -e is --ecmp,
# not keep_kernel), and short-flag forms (-h, -v, -i, -A, -P, -u, -g,
# -M, -o, -w, -f, -d, -N) not enumerated by FRR docs.
# Added verified: -a --allow_delete, -e --ecmp, --v6-rr-semantics,
# --routing-table, --asic-offload, --v6-with-v4-nexthops,
# --nexthop-weight-16-bit.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-b --batch)'{-b,--batch}'[parse config and terminate]' \
  '(-K --graceful_restart)'{-K,--graceful_restart=}'[graceful restart period (sec)]:sec:' \
  '(-a --allow_delete)'{-a,--allow_delete}'[allow other processes to delete zebra routes]' \
  '(-r --retain)'{-r,--retain}'[retain routes after exit]' \
  '(-e --ecmp)'{-e,--ecmp=}'[limit ECMP to N paths]:n:' \
  '(-n --vrfwnetns)'{-n,--vrfwnetns}'[VRF backend is netns (deprecated)]' \
  '(-z --socket)'{-z,--socket=}'[zapi control socket path]:file:_files' \
  '(-s --nl-bufsize)'{-s,--nl-bufsize=}'[netlink receive buffer size in bytes]:bytes:' \
  '--v6-rr-semantics[enable IPv6 route-replacement semantics]' \
  '--routing-table=[kernel routing table]:table:' \
  '--asic-offload=[ASIC offload notifications]:mode:(notify_on_offload notify_on_ack)' \
  '--v6-with-v4-nexthops[accept IPv6 routes with IPv4 nexthops]' \
  '--nexthop-weight-16-bit[use 16-bit nexthop weights]' \
  '*:options:' && ret=0

return ret
