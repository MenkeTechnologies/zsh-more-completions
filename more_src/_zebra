#compdef zebra
# Documentation: https://man.archlinux.org/search?q=zebra
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --batch)'{-b,--batch}'[batch mode]' \
  '(-d --daemon)'{-d,--daemon}'[daemonize]' \
  '(-N --pathspace)'{-N,--pathspace}'+[namespace]:ns:' \
  '(-K --graceful_restart)'{-K,--graceful_restart}'+[graceful restart period sec]:sec:' \
  '(-f --config_file)'{-f,--config_file}'+[config file]:file:_files' \
  '(-i --pid_file)'{-i,--pid_file}'+[pid file]:file:_files' \
  '(-z --socket)'{-z,--socket}'+[zebra socket]:file:_files' \
  '(-A --vty_addr)'{-A,--vty_addr}'+[VTY address]:addr:' \
  '(-P --vty_port)'{-P,--vty_port}'+[VTY port]:port:' \
  '(-u --user)'{-u,--user}'+[user]:user:_users' \
  '(-g --group)'{-g,--group}'+[group]:group:_groups' \
  '(-r --retain)'{-r,--retain}'[retain routes after exit]' \
  '(-s --nl-bufsize)'{-s,--nl-bufsize}'+[netlink buffer size]:bytes:' \
  '(-e --keep_kernel)'{-e,--keep_kernel}'[keep kernel routes]' \
  '(-n --vrfwnetns)'{-n,--vrfwnetns}'[VRF backend is netns]' \
  '(-M --moduledir)'{-M,--moduledir}'+[module dir]:dir:_files -/' \
  '(-o --vrfdefaultname)'{-o,--vrfdefaultname}'+[default VRF name]:name:' \
  '(-w --workdir)'{-w,--workdir}'+[working directory]:dir:_files -/' \
  '*:options:' && ret=0

return ret
