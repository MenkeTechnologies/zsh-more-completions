#compdef hbase
# Documentation: https://man.archlinux.org/search?q=hbase
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'shell:run hbase shell'
  'master:run HBase master'
  'regionserver:run a region server'
  'thrift:run thrift server'
  'thrift2:run thrift2 server'
  'rest:run REST server'
  'zookeeper:run ZK server'
  'snapshotinfo:show snapshot info'
  'wal:print HLog files'
  'hfile:print HFile contents'
  'hbck:run hbck check'
  'hbck2:run hbck2'
  'classpath:print classpath'
  'mapredcp:print MR classpath'
  'org.apache.hadoop.hbase.util.HBaseFsck:run HBaseFsck'
  'pe:performance evaluation'
  'ltt:LoadTestTool'
  'canary:health canary'
  'completebulkload:complete a bulk load'
  'verifyrep:verify replication'
  'export:export table'
  'import:import table'
  'importtsv:bulk-import TSV'
  'rowcounter:row counter'
  'cellcounter:cell counter'
  'clean:clean state'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*--config=[config dir]:dir:_files -/' \
  '*--hosts=[hosts list file]:file:_files' \
  '*--auth-as-server[auth as server]' \
  '*--internal-classpath[internal classpath]' \
  '*-D+[hadoop property k=v]:p:' \
  '*-conf+[conf file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hbase command' commands && ret=0 ;;
  (args) _arguments '*: :_files' && ret=0 ;;
esac

return ret
