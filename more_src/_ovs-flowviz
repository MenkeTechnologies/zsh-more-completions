#compdef ovs-flowviz
# Documentation: https://www.openvswitch.org/support/dist-docs/ovs-flowviz.8.txt
# visualize OpenFlow and datapath flows

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print a brief help message]' \
  '*'{-i,--input}'=[file to read flows from (default stdin)]:input:_files' \
  '(-c --config)'{-c,--config}'=[style configuration file to use]:file:_files' \
  '(-f --filter)'{-f,--filter}'=[flow filter expression]:filter' \
  '(-l --highlight)'{-l,--highlight}'=[highlight flows matching the filter expression]:filter' \
  '--style=[style defined in the style configuration file]:style' \
  '(-s --show-flows)'{-s,--show-flows}'[show all flows under each logical block]' \
  '(-d --ovn-detrace)'{-d,--ovn-detrace}'[use ovn-detrace to extract cookie information]' \
  '--ovn-detrace-path=[alternative path for ovn_detrace.py]:path:_files' \
  '--ovnnb-db=[OVN NB database connection method]:connection' \
  '--ovnsb-db=[OVN SB database connection method]:connection' \
  '--ovn-filter=[filter to run on the ovn-detrace information]:filter' \
  '1:flow type:(openflow datapath)' \
  '*:format:(console html graph json)' && ret=0

return ret
