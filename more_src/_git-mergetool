#compdef git-mergetool
# Documentation: https://git-scm.com/docs/git-mergetool
# Source: git/git git-mergetool.sh — run merge conflict resolution tools (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--tool=-[merge tool]:tool:(vimdiff vimdiff1 vimdiff2 vimdiff3 araxis bc bc3 codecompare deltawalker diffmerge diffuse ecmerge emerge examdiff guiffy gvimdiff gvimdiff1 gvimdiff2 gvimdiff3 kdiff3 meld nvimdiff nvimdiff1 nvimdiff2 nvimdiff3 opendiff p4merge smerge tkdiff tortoisemerge winmerge xxdiff)' \
    '--tool-help[print list of valid tools]' \
    '(-y --no-prompt)'{-y,--no-prompt}'[do not prompt before each invocation]' \
    '(-y --no-prompt --prompt)--prompt[prompt before each invocation]' \
    '(--no-gui)'{-g,--gui}'[use mergetool.guitool]' \
    '(-g --gui)--no-gui[use mergetool.tool]' \
    '-O+[order file]:orderfile:_files' \
    '*:files to merge:_files' \
    && ret=0

return ret
