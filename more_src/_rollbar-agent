#compdef rollbar-agent

# rollbar-agent: log shipper for Rollbar error tracking
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-c[config file]:file:_files -g "*.(cfg|ini|conf)"' \
  '--config=[config file]:file:_files -g "*.(cfg|ini|conf)"' \
  '-d[daemonize]' \
  '--daemonize[daemonize]' \
  '-D[debug]' \
  '--debug[debug]' \
  '*::rollbar-agent args:_files' && ret=0
return ret
