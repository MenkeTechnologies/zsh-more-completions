#compdef s6-fdholder-transferdump
# _s6-fdholder-transferdump — s6 fdholder s6-fdholder-transferdump (atomic move of every stored fd from one s6-fdholderd instance to another; used to upgrade an fd-holder without dropping descriptors)
# upstream: https://github.com/skarnet/s6
# Flags from src/fdholder/s6-fdholder-transferdump.c on tip.

_s6-fdholder-transferdump() {
    _arguments \
        '-t+[timeoutfrom:timeoutto (ms)]:spec:' \
        '1:socket-from:_files' \
        '2:socket-to:_files'
}

_s6-fdholder-transferdump "$@"
