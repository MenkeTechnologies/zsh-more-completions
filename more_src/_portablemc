_portablemc () {
  local curcontext=$curcontext state line
  integer ret=1
  _arguments -s -C \
    {-h,--help}'[Show this help message and exit.]' \
    --main-dir'[Set the main directory where libraries, assets and versions.]: :_files -/' \
    --work-dir'[Set the working directory where the game run and place for examples saves, screenshots (and resources for legacy versions), it also store runtime binaries and authentication.]: :_files -/' \
    --timeout'[Set a global timeout (in decimal seconds) for network requests.]: :' \
    --output'[Set the output format of the launcher, defaults to human-color, human if not a TTY.]: :->arg_out_kind' \
    \*-v'[Enable verbose output. The more -v argument you put, the more verbose the launcher will be, depending on subcommands'' support (usually -v, -vv, -vvv).]' \
    ': :->command' \
    '*:: :->option' \
    && ret=0
  case $state in
  command)
    local -a commands=(
      'search:Search for versions.'
      'start:Start the game.'
      'login:Login into your account and save the session.'
      'logout:Logout and invalidate a session.'
      'show:Show, debug and generate data unrelated to the game.'
    )
    _describe -t commands command commands && ret=0
    ;;
  option)
    case $line[1] in
    search) _portablemc_search ;;
    start) _portablemc_start ;;
    login) _portablemc_login ;;
    logout) _portablemc_logout ;;
    show) _portablemc_show ;;
    esac
    ;;
  arg_out_kind)
    local -a completions=(
      'human-color:Human readable output with color.'
      'human:Human readable output.'
      'machine:Machine readable output.'
    )
    _describe -t values value completions && ret=0
    ;;
  esac
}

