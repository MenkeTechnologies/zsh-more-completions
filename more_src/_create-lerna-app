#compdef create-lerna-app
# Documentation: https://www.npmjs.com/package/create-lerna-app
# Reference accessed: 2026-05-24
# Verified: npx create-lerna-app --help.

# Zsh completion for create-lerna-app - Lerna monorepo project scaffolder

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add-module:add a module to the monorepo'
  'clean:clean monorepo artifacts'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'create-lerna-app command' commands && ret=0
    ;;
  (args)
    _arguments '*::args:' && ret=0
    ;;
esac

return ret
