#compdef partition_to_vertex_separator
# Documentation: https://arxiv.org/pdf/1311.1714
# KaHIP: compute a k-way vertex separator from a k-way partition

local ret=1

_arguments -s \
  '--help[print help]' \
  '--k=[number of blocks the graph is partitioned into]:int' \
  '--input_partition=[input partition to compute the separator from]:file:_files' \
  '--seed=[seed for the random number generator]:int' \
  '--output_filename=[output filename (default tmpseparator)]:file:_files' \
  '*:graph file:_files' && ret=0

return ret
