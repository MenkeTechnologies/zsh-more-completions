#compdef deno-doc
# Documentation: https://docs.deno.com/runtime/reference/cli/doc/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--json[output as JSON]' \
  '--html[output as HTML]' \
  '--name=[name for use in docs (breadcrumbs)]:name' \
  '--output=[output directory for HTML]:directory:_directories' \
  '--filter=[dot-separated path to symbol]:filter' \
  '--private[include private items]' \
  '--lint[output documentation diagnostics]' \
  '--category-docs=[category docs JSON]:file:_files' \
  '--default-symbol-map=[default name mapping]:file:_files' \
  '--strip-trailing-html[remove trailing .html from links]' \
  '--symbol-redirect-map=[symbol redirect map JSON]:file:_files' \
  '(-I --allow-import)'{-I,--allow-import=}'[allow importing from remote hosts]:hosts' \
  '--deny-import=[deny importing from remote hosts]:hosts' \
  '--frozen[error if lockfile is out of date]' \
  '--import-map=[import map file]:file:_files' \
  '--lock=[lock file]:file:_files' \
  '--no-lock[disable auto-discovery of lock file]' \
  '--no-npm[do not resolve npm modules]' \
  '--no-remote[do not resolve remote modules]' \
  '(-c --config)'{-c,--config=}'[config file]:config:_files -g "deno.json*(-.)"' \
  '--no-config[do not use config file]' \
  '(-r --reload)'{-r,--reload=}'[reload source code cache]:cache blocklist' \
  '*:source file:_files -g "*.(ts|tsx|js|jsx|mts|mjs)(-.)"' && return 0
