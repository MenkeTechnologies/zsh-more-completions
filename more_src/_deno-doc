#compdef deno-doc

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--json[output as JSON]' \
  '--html[output as HTML]' \
  '--name=[package name]:name' \
  '--output=[output directory]:directory:_directories' \
  '--filter=[filter pattern]:filter' \
  '--private[include private items]' \
  '--import-map=[import map file]:file:_files' \
  '--config=[config file]:config:_files -g "deno.json*(-.)"' \
  '--no-config[do not use config file]' \
  '--reload[reload source code cache]' \
  '--lint[lint documentation]' \
  '*:source file:_files -g "*.(ts|tsx|js|jsx|mts|mjs)(-.)"' && return 0
