#compdef rocgdb

# rocgdb: AMD ROCm GDB (HIP/HSA debugger)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--args[program args]' \
  '-batch[batch mode]' \
  '-batch-silent[batch silent]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '-tui[TUI mode]' \
  '-x[execute commands file]:file:_files' \
  '-ex[execute single command]:cmd:' \
  '-iex[init command]:cmd:' \
  '-data-directory=[data dir]:dir:_files -/' \
  '-cd=[working dir]:dir:_files -/' \
  '-p[process to attach]:pid:' \
  '--pid=[process to attach]:pid:' \
  '*:program:_files' && ret=0
return ret
