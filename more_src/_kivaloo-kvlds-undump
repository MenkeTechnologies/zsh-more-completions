#compdef kivaloo-kvlds-undump
# _kivaloo-kvlds-undump — restore KVLDS contents from a dump (Tarsnap/kivaloo)
# upstream: https://github.com/Tarsnap/kivaloo
# Flags from kvlds-undump/main.c (libcperciva GETOPT).

_kivaloo-kvlds-undump() {
    _arguments \
        '(- *)--version[print version]' \
        '-t+[KVLDS socket]:socket:' \
        '--fs=[directory containing the dump]:dir:_files -/' \
        '*-v+[increase verbosity]:n:'
}

_kivaloo-kvlds-undump "$@"
