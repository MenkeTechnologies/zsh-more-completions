#compdef pcangsd
# Documentation: https://www.popgen.dk/software/index.php/PCAngsd
# PCAngsd: PCA and population genetics from genotype likelihoods

local ret=1

_arguments -s -S \
  '-beagle+[input genotype likelihoods in Beagle format]:file:_files' \
  '-plink+[binary PLINK file prefix]:prefix:_files' \
  '-out+[output file prefix]:prefix' \
  '-threads+[number of threads to use]:int' \
  '-minMaf+[minimum minor allele frequency threshold]:float' \
  '-filter+[file specifying which individuals to retain]:file:_files' \
  '-maf_iter+[maximum EM iterations for population allele frequencies]:int' \
  '-iter+[maximum iterations for individual allele frequency estimation]:int' \
  '-e+[number of eigenvalues]:int' \
  '-pi+[load previous individual allele frequency estimates]:file:_files' \
  '-hwe+[filter sites based on HWE test results]:file:_files' \
  '-selection[PC-based genome-wide selection scan]' \
  '-pcadapt[alternative selection scan method]' \
  '-inbreedSites[estimate per-site inbreeding coefficients]' \
  '-inbreedSamples[estimate per-individual inbreeding coefficients]' \
  '-admix[estimate admixture proportions and ancestral frequencies]' \
  '-geno+[call genotypes with defined threshold]:float' \
  '-tree[construct neighbor-joining tree of samples]' \
  '-pi_save[save individual allele frequencies]' \
  '-dosage_save[save genotype dosages]' \
  '-post_save[save posterior genotype probabilities]' && ret=0

return ret
