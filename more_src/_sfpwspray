#compdef sfpwspray
# Documentation: https://www.reproducibility.org/wiki/Guide_to_madagascar_programs
# Madagascar: plane-wave spray

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'ns=[spray radius]:ns:' \
  'order=[accuracy order]:order:' \
  'eps=[regularization]:eps:' \
  'rect=[smoothing radius]:rect:' \
  'reduce=[reduce operation (sum/dsum/mean)]:reduce:(sum dsum mean)' \
  'verb=[verbosity (y/n)]:verb:(y n)' \
  '*: :_files' && ret=0

return ret
