#compdef sfricker2
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mricker2.c
# Madagascar: nonstationary convolution with a Ricker wavelet

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'frequency=[peak frequency for Ricker wavelet (in Hz)]:Hz' \
  'freq=[peak frequency for Ricker wavelet (fraction of Nyquist)]:fraction' \
  'esp=[if norm=y, stable parameter]:value' \
  'norm=[normalization flag]:flag:(y n)' \
  'hiborder=[Hilbert transformer order]:order' \
  'hibref=[Hilbert transformer reference]:value' \
  'tfreq=[time-varying frequency file]:file:_files' \
  'tphase=[time-varying phase file]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
