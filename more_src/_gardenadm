#compdef gardenadm
# _gardenadm — Gardener self-hosted shoot cluster bootstrap CLI
# upstream: https://github.com/gardener/gardener
# Subcommands + flags from pkg/gardenadm/cmd on tip.

_gardenadm() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[log level]:level:(debug info error)' \
        '--log-format=[log format]:fmt:(text json)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'bootstrap:bootstrap a new self-hosted shoot cluster from a bootstrap cluster'
                'init:initialize the self-hosted shoot control plane on the current node'
                'join:join the current node to an existing self-hosted shoot cluster'
                'discover:discover cluster info from a garden cluster'
                'connect:connect a self-hosted shoot cluster to a garden cluster'
                'token:manage bootstrap tokens (create / list / delete / generate)'
                'version:print gardenadm version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                bootstrap)
                    _arguments \
                        '(-k --kubeconfig)'{-k,--kubeconfig=}'[bootstrap cluster kubeconfig]:file:_files' \
                        '--kubeconfig-output=[write shoot kubeconfig to this path (- for stdout)]:file:_files' \
                        '*--bastion-ingress-cidr=[restrict bastion ingress CIDR (repeatable)]:cidr:'
                    ;;
                init)
                    _arguments \
                        '--use-bootstrap-etcd=[keep bootstrap etcd (skip etcd-druid transition)]:bool:(true false)' \
                        '--use-host-network=[keep components in host network]:bool:(true false)' \
                        '(-z --zone)'{-z,--zone=}'[availability zone]:zone:'
                    ;;
                join)
                    _arguments \
                        '--ca-certificate=[base64 CA bundle of control plane]:b64:' \
                        '--bootstrap-token=[bootstrap token]:token:' \
                        '(-w --worker-pool-name)'{-w,--worker-pool-name=}'[worker pool name]:name:' \
                        '--control-plane=[start new control plane instance on this node]:bool:(true false)' \
                        '(-z --zone)'{-z,--zone=}'[availability zone]:zone:'
                    ;;
                discover)
                    _arguments \
                        '(-k --kubeconfig)'{-k,--kubeconfig=}'[garden cluster kubeconfig]:file:_files' \
                        '--managed-infrastructure=[Gardener manages shoot infrastructure]:bool:(true false)'
                    ;;
                connect)
                    _arguments \
                        '--ca-certificate=[base64 CA bundle of Gardener control plane]:b64:' \
                        '--bootstrap-token=[bootstrap token]:token:' \
                        '--force=[redeploy gardenlet if already present]:bool:(true false)'
                    ;;
                token)
                    local -a subs=(
                        'create:create a new bootstrap token'
                        'list:list bootstrap tokens'
                        'delete:delete a bootstrap token'
                        'generate:generate a random token value'
                    )
                    _describe -t commands subcommand subs
                    ;;
            esac
            ;;
    esac
}

_gardenadm "$@"
