#compdef pacseek
# Documentation: https://github.com/moson-mo/pacseek (main.go)
# Reference accessed: 2026-05-30
# pacseek — moson-mo's interactive TUI for searching + installing Arch Linux
# packages. Config in ~/.config/pacseek/config.json; most navigation is
# keyboard-driven inside the TUI, so the CLI surface is intentionally thin.

local curcontext="$curcontext" state line ret=1

# Common Arch repository names — seeds the -r CSV completion.
local -a _repos
_repos=(core extra multilib testing core-testing extra-testing multilib-testing aur chaotic-aur eos endeavouros-aur)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-r+[limit search to comma-separated repo list (default: all)]:repos:_values -s , "repo" $_repos' \
  '-s+[initial search term]:term:' \
  '-a[ASCII mode (no Unicode box-drawing)]' \
  '-m[monochrome mode (no colours)]' \
  '-u[show upgrades after startup]' \
  '-i[show installed packages after startup]' \
  && ret=0

return ret
