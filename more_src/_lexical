#compdef lexical
# Documentation: https://man.archlinux.org/search?q=lexical
# Reference accessed: 2026-05-16

# Zsh completion for Lexical (Elixir language server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' && ret=0

return ret
