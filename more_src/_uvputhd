#compdef uvputhd
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvputhd.html
# MIRIAD uvputhd - modify uv header variables

local ret=1

_arguments -s -S \
  'vis=[input MIRIAD dataset name]:vis:_files' \
  'hdvar=[header variable name to modify]:hdvar' \
  'type=[variable type i/r/d/a]:type:(i r d a)' \
  'length=[array length]:length' \
  'varval=[new values for the header variable]:varval' \
  'table=[table file of time-ordered values]:table:_files' \
  'time0=[time offset for table values]:time0' \
  'out=[output dataset name]:out:_files' \
  'options=[inter]:options' \
  '*:dataset:_files' && ret=0

return ret
