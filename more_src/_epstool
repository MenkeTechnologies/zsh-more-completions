#compdef epstool
# Documentation: https://man.archlinux.org/search?q=epstool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-b --bbox)'{-b,--bbox}'[update bounding box from gs bbox]' \
  '(--copy)--copy[copy EPS file]' \
  '(--extract-postscript)--extract-postscript[extract PostScript section]' \
  '(--extract-preview -v)'{--extract-preview,-v}'[extract preview section]' \
  '(-t1 --add-pict-preview)'{-t1,--add-pict-preview}'[add Mac PICT preview]' \
  '(-t4 --add-tiff4-preview)'{-t4,--add-tiff4-preview}'[add TIFF4 mono preview]' \
  '(-t6 --add-tiff-preview)'{-t6,--add-tiff-preview}'[add TIFF preview]' \
  '(-t6p --add-tiff6p-preview)'{-t6p,--add-tiff6p-preview}'[add packed TIFF preview]' \
  '(-w --add-windows-metafile-preview)'{-w,--add-windows-metafile-preview}'[add Windows MF preview]' \
  '--add-user-preview=[user preview file]:file:_files' \
  '(-i --add-interchange-preview)'{-i,--add-interchange-preview}'[add EPSI preview]' \
  '--bitmap[bitmap of bbox area]' \
  '--device=[ghostscript device]:dev:(bmp16 bmp16m bmp256 bmpgray bmpmono jpeg pdfwrite png16 png16m png256 pngalpha pngmono pngmonod tiff12nc tiff24nc tiff32nc tiff48nc tiff64nc tiffg3 tiffg32d tiffg4 tiffgray tiffsep tiffsep1 ppm pkm)' \
  '--dpi=[DPI]:dpi:' \
  '--gs=[ghostscript binary]:cmd:_command_names' \
  '--gs-args=[args to ghostscript]:args:' \
  '--ignore-aux[ignore aux files]' \
  '--missing-bbox=[behaviour for missing bbox]:b:(none calculate)' \
  '--page=[page number]:n:' \
  '--quiet[quiet mode]' \
  '--rasterize-resolution=[rasterize DPI]:dpi:' \
  '--triglinearfilter[triangular linear filter]' \
  '*:EPS file:_files -g "*.eps *.epsf *.epsi"' && ret=0

return ret
