#compdef plextraktsync PlexTraktSync

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'sync:perform Plex<->Trakt sync'
  'watch:listen to Plex events and scrobble'
  'info:print version and account info'
  'config:open or locate the config file'
  'login:log in to Plex and Trakt'
  'plex-login:log in to Plex only'
  'trakt-login:log in to Trakt only'
  'cache:manage requests cache'
  'inspect:inspect a Plex item'
  'imdb-import:import IMDB ratings from CSV'
  'bug-report:open a pre-filled bug report'
  'self-update:update plextraktsync to latest'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-progress-bar[disable progress bar]' \
  '--config=[config file path]:file:_files -g "*.{yml,yaml}"' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'plextraktsync command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sync)
        _arguments \
          '--sync=[what to sync]:scope:(all movies shows watchlist)' \
          '--library=[restrict to a Plex library]:name:' \
          '--show=[restrict to a single show]:show:' \
          '--movie=[restrict to a single movie]:movie:' \
          '--batch-delay=[seconds between batches]:n:' \
          '--dry-run[do not write changes]' && ret=0 ;;
      (config)
        _arguments \
          '--edit[open config in editor]' \
          '--locate[open config in file browser]' \
          '--copy=[copy default config to path]:file:_files' && ret=0 ;;
      (inspect)
        _arguments \
          '*::plex_id_or_url:' && ret=0 ;;
      (imdb-import)
        _arguments \
          '*::csv:_files -g "*.csv"' && ret=0 ;;
      (cache)
        _arguments \
          '*::sub:(prune expire purge size)' && ret=0 ;;
    esac ;;
esac

return ret
