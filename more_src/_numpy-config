#compdef numpy-config
# Documentation: https://numpy.org/doc/stable/reference/distutils.html
# NumPy: report build/configuration info about the installed NumPy

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print the version and exit]' \
  '--cflags[compile flag needed when using the NumPy headers]' \
  '--pkgconfigdir[print the pkgconfig directory in which numpy.pc is stored]' && ret=0

return ret
