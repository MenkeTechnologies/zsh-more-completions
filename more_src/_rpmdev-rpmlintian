#compdef rpmdev-rpmlintian
# Documentation: (not in upstream rpmdevtools)
# Reference accessed: 2026-05-16
# Verified: extensive search of upstream rpm-software-management/
# rpmdevtools and rsrchboy mirror finds no `rpmdev-rpmlintian` script.
# Likely a confused merge of `rpmlint` + `lintian`. Conservative stub
# retained per "do not delete files" directive.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# rpmdev-rpmlintian: not a known upstream binary
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:rpm or spec file:_files -g "*.(rpm|spec)(-.)"' && ret=0
return ret
