#compdef crd-puller
# _crd-puller — kcp tool that pulls existing CRDs from a cluster (kcp-dev/kcp)
# upstream: https://github.com/kcp-dev/kcp
# Flags from cmd/crd-puller/pull-crds.go on tip.

_crd-puller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '(-r --resources)'{-r,--resources=}'[resources to pull (comma-sep group/resource list)]:list:' \
        '-v[klog verbosity level]:n:'
}

_crd-puller "$@"
