#compdef bandwhich

# Zsh completion for bandwhich (bandwidth utilization monitor)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-i --interface)'{-i,--interface}'[capture packets on specified interface]:interface:_net_interfaces' \
  '(-r --raw)'{-r,--raw}'[machine-friendly output]' \
  '(-n --no-resolve)'{-n,--no-resolve}'[do not resolve hostnames]' \
  '(-s --show-dns)'{-s,--show-dns}'[show DNS queries]' \
  '(-d --dns-server)'{-d,--dns-server}'[custom DNS server]:dns server' \
  '(-t --total-utilization)'{-t,--total-utilization}'[show total utilization table only]' \
  '(-p --processes)'{-p,--processes}'[show processes table only]' \
  '(-c --connections)'{-c,--connections}'[show connections table only]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
