#compdef anyquery
# Documentation: https://github.com/julien040/anyquery
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'query:execute SQL queries'
  'run:execute SQL from the community repository'
  'server:enable remote MySQL/HTTP connections'
  'mcp:start the Model Context Protocol server'
  'gpt:open an HTTP server for ChatGPT function calls'
  'install:search and install plugins'
  'plugins:list installed plugins'
  'registry:list plugin registries'
  'connection:manage external database connections'
  'profiles:list configuration profiles'
  'alias:manage aliases'
  'tool:utility helpers'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration database path]:file:_files' \
  '(-d --database)'{-d+,--database=}'[database connection or :memory:]:db:_files' \
  '(-q --query)'{-q+,--query=}'[SQL query to execute]:query:' \
  '--csv[CSV output format]' \
  '--json[JSON output format]' \
  '--plain[plain text output]' \
  '--format=[output format]:format:(pretty json csv plain)' \
  '--prql[use PRQL]' \
  '--pql[use PQL]' \
  '--language=[query language]:lang:(sql prql pql)' \
  '--init=[SQL file to run before query]:file:_files' \
  '*--extension=[extension path]:file:_files' \
  '--dev[developer mode]' \
  '--log-level=[log level]:level:(trace debug info warn error)' \
  '--read-only[read-only mode]' \
  '--readonly[read-only mode]' \
  '--in-memory[open in-memory database]' \
  '--no-input[skip interactive input]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'anyquery command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (server)
        _arguments \
          '--host=[bind host]:host:_hosts' \
          '--port=[bind port]:port:' \
          '--user=[username]:user:' \
          '--password=[password]:password:' && ret=0 ;;
      (mcp)
        _arguments \
          '--stdio[use stdio transport]' \
          '--host=[bind host]:host:_hosts' \
          '--port=[bind port]:port:' \
          '--domain=[external domain]:domain:' && ret=0 ;;
      (install)
        _arguments \
          '*::plugin:' && ret=0 ;;
      (plugins|registry|profiles|alias|connection)
        _arguments '*::sub:(list add remove update show)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
