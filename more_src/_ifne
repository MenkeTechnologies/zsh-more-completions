#compdef ifne
# Documentation: man ifne (moreutils)
# Source: run a command only if standard input is/isn't empty.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-n[invert: run command only if stdin IS empty]' \
    '1:command:_command_names -e' \
    '*::args:_normal' \
    && ret=0

return ret
