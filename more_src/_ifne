#compdef ifne
# _ifne — moreutils ifne (run a command only when stdin is non-empty; -n inverts (run only when empty); passes stdin through to the child unchanged when it runs)
# upstream: https://salsa.debian.org/built-using-team/moreutils (joeyh)
# Flags from moreutils ifne.c on tip.

_ifne() {
    _arguments \
        '-n[run if stdin IS empty (invert)]' \
        '*:command:_command_names -e'
}

_ifne "$@"
