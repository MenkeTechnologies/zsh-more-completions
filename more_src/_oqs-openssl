#compdef oqs-openssl
# Documentation: https://github.com/open-quantum-safe/openssl
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# oqs-openssl: OpenSSL build with Open Quantum Safe post-quantum providers
# (deprecated upstream in favour of the OpenSSL 3 OQS provider).
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'genpkey:generate post-quantum private key'
  'pkey:show or convert a private key'
  'req:CSR / self-signed cert'
  's_client:TLS client'
  's_server:TLS server'
  'speed:speed test of algorithms'
  'list:list supported algorithms'
  'version:show version'
)
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'oqs-openssl command' commands && ret=0 ;;
esac
return ret
