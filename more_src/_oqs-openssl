#compdef oqs-openssl

# OQS-OpenSSL: post-quantum cryptography fork of OpenSSL
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'help:show help'
  'version:show version'
  'list:list configured algorithms / providers'
  'speed:benchmark crypto algorithms'
  'genpkey:generate private key'
  'pkey:public/private key processing'
  'pkeyutl:public/private key operations'
  'req:certificate request creation/processing'
  'x509:certificate operations'
  's_client:SSL/TLS client'
  's_server:SSL/TLS server'
  'ciphers:list supported ciphers'
  'dgst:compute message digest'
  'enc:symmetric encryption'
  'rand:generate random bytes'
  'rsa:RSA key processing'
  'ec:EC key processing'
  'ca:simple CA management'
  'crl:CRL operations'
  'pkcs7:PKCS#7 operations'
  'pkcs12:PKCS#12 operations'
  'asn1parse:parse ASN.1 sequence'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'oqs-openssl command' commands && ret=0 ;;
esac
return ret
