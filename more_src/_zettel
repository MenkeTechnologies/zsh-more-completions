#compdef zettel
# Documentation: https://github.com/rauletaveras/zettel
# zettel - CLI for Luhmann-style Zettelkasten management (zettel-cli)

local ret=1
local line

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'id:ID operations'
      'note:note management'
      'init:set up a new vault'
      'list:show all notes'
      'search:locate notes by text matching'
    )
    _describe -t commands 'zettel command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      id)
        local -a sub
        sub=(
          'next-sibling:generate next sibling ID'
          'next-child:generate child ID'
          'parse:extract ID from a filename'
          'validate:verify ID format validity'
        )
        _describe -t subcommands 'id subcommand' sub && ret=0
        ;;
      note)
        if (( CURRENT == 2 )); then
          local -a sub
          sub=(
            'create:generate new note with ID and title'
            'open:access note by identifier'
            'show:display note contents'
          )
          _describe -t subcommands 'note subcommand' sub && ret=0
        else
          case $line[2] in
            create)
              _arguments -s '--open[launch note in editor immediately]' && ret=0
              ;;
          esac
        fi
        ;;
      init)
        _arguments -s '*:path:_files -/' && ret=0
        ;;
      list)
        _arguments -s '--json[machine-readable output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
