#compdef veneur-emit
# Emit metrics, events and service checks to a Veneur/StatsD/SSF endpoint

local ret=1

_arguments -s -S \
  '-hostport=[address of destination hostport or listening URL]:hostport' \
  '-mode=[mode for veneur-emit]:mode:(metric event sc)' \
  '-debug[turns on debug messages]' \
  '-command[turns on command-timing mode]' \
  '-proxy=[proxy emit through given hostport]:hostport' \
  '-name=[name of metric to report]:name' \
  '-gauge=[report a gauge metric (float64)]:value' \
  '-timing=[report a timing metric]:duration' \
  '-count=[report a count metric (integer)]:value' \
  '-set=[report a set metric with a string value]:value' \
  '-tag=[tag(s) for metric, comma separated]:tags' \
  '-ssf[send packets via SSF instead of StatsD]' \
  '-grpc[send the metric over gRPC (SSF format)]' \
  '-e_title=[title of event]:title' \
  '-e_text=[text of event]:text' \
  '-e_time=[timestamp for the event]:time' \
  '-e_hostname=[hostname for the event]:hostname:_hosts' \
  '-e_aggr_key=[aggregation key to group event]:key' \
  '-e_priority=[priority of event]:priority:(low normal)' \
  '-e_source_type=[source type for the event]:type' \
  '-e_alert_type=[alert type for the event]:type:(error warning info success)' \
  '-e_event_tags=[tag(s) for event, comma separated]:tags' \
  '-sc_name=[service check name]:name' \
  '-sc_status=[check status (0 OK,1 WARN,2 CRIT,3 UNKNOWN)]:status:(0 1 2 3)' \
  '-sc_time=[timestamp for check]:time' \
  '-sc_hostname=[hostname for check]:hostname:_hosts' \
  '-sc_tags=[tag(s) for service check, comma separated]:tags' \
  '-sc_msg=[message describing current state of service check]:msg' \
  '-trace_id=[ID for the top-level trace span (activates tracing)]:id' \
  '-parent_span_id=[ID of the parent span]:id' \
  '-span_starttime=[start time of the span]:time' \
  '-span_endtime=[end time of the span]:time' \
  '-span_service=[service name for the span]:service' \
  '-indicator[mark the reported span as an indicator span]' \
  '-error[mark the reported span as having errored]' \
  '-span_tags=[tag(s) for span, comma separated]:tags' && ret=0

return ret
