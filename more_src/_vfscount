#compdef vfscount vfscount-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/vfscount.py — manual sys.argv parsing, no argparse)
# Reference accessed: 2026-05-29
# vfscount — count VFS function calls (BCC/eBPF). Single interval positional via manual sys.argv.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:interval (seconds, default unlimited):' \
  && ret=0

return ret
