#compdef convex
# Documentation: https://man.archlinux.org/search?q=convex
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'codegen:generate code from schema'
  'data:list/show data'
  'dashboard:open dashboard'
  'deploy:deploy to production'
  'dev:run dev server'
  'docs:open docs'
  'env:env var commands'
  'export:export data'
  'function-spec:show function spec'
  'help:show help'
  'import:import data'
  'init:initialize project'
  'install:install Convex'
  'logs:tail logs'
  'login:log in'
  'logout:log out'
  'mcp:run MCP server'
  'network-test:test network'
  'reinit:reinitialize'
  'run:run a function'
  'self-host:self-hosted setup'
  'update:update Convex CLI'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--prod[use production deployment]' \
  '*--preview-name=[preview name]:n:' \
  '*--admin-key=[admin key]:k:' \
  '*--url=[deployment URL]:url:' \
  '*--verbose[verbose]' \
  '*--no-color[no color]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'convex command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (dev)
        _arguments \
          '--once[run once]' \
          '--until-success[until success]' \
          '--run=[function]:f:' \
          '--run-component=[component]:c:' \
          '--run-sh=[shell command]:c:' \
          '--tail-logs[tail logs]' \
          '--typecheck=[typecheck mode]:m:(enable disable tsc)' \
          '--codegen=[codegen mode]:m:(enable disable)' \
          '*: :' && ret=0 ;;
      (deploy)
        _arguments \
          '--cmd=[deploy command]:c:' \
          '--cmd-url-env-var-name=[env var name]:n:' \
          '--dry-run[dry run]' \
          '--yes[yes]' \
          '-y[yes]' \
          '--write-push-request=[write request]:file:_files' \
          '*: :' && ret=0 ;;
      (run)
        _arguments \
          '--component=[component]:c:' \
          '--push[push first]' \
          '--watch[watch]' \
          '*: :' && ret=0 ;;
      (env)
        _arguments \
          '1:subcommand:(get list set remove)' \
          '*: :' && ret=0 ;;
      (import|export)
        _arguments \
          '--table=[table]:t:' \
          '--format=[format]:f:(jsonl json csv zip)' \
          '*: :_files' && ret=0 ;;
      (logs)
        _arguments \
          '--success[show success]' \
          '--history=[history n]:n:' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
