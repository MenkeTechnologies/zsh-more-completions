#compdef gprclean

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-aP+[project search path]:dir:_files -/' \
  '-c[clean compile artifacts only]' \
  '-eL[follow symlinks]' \
  '-f[force deletion]' \
  '-F[full path errors]' \
  '-h[help]' \
  '-n[dry-run]' \
  '-P+[project file]:file:_files -g "*.gpr"' \
  '-q[quiet]' \
  '-r[recursive]' \
  '-v[verbose]' \
  '-vP+[project verbosity]:level:(0 1 2)' \
  '-X+[scenario var]:var=val:' \
  '--config=+[config file]:file:_files' \
  '--autoconf=+[autoconf file]:file:_files' \
  '--target=+[target]:target:' \
  '--RTS=+[Ada runtime]:rts:' \
  '--db=+[knowledge base]:file:_files' \
  '--db-[ignore default knowledge base]' \
  '--no-indirect-imports[no indirect imports]' \
  '--unchecked-shared-lib-imports[unchecked shared lib imports]' && ret=0

return ret
