#compdef idris2

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[display help]'
  '--version[display version]'
  '--check[type check only, do not compile]'
  '-o[specify output file]:output file:_files'
  '--output[specify output file]:output file:_files'
  '--exec[execute expression after loading]:expression:'
  '--no-banner[suppress the banner]'
  '--no-color[disable colored output]'
  '--no-colour[disable colored output]'
  '--console-width[set console width for formatting]:width:(auto 0)'
  '--color[force colored output]'
  '--colour[force colored output]'
  '-p[add a package as a dependency]:package:'
  '--package[add a package as a dependency]:package:'
  '--build[build package from ipkg file]:ipkg file:_files -g "*.ipkg"'
  '--install[install package from ipkg file]:ipkg file:_files -g "*.ipkg"'
  '--mkdoc[build documentation for package]:ipkg file:_files -g "*.ipkg"'
  '--typecheck[type check package only]:ipkg file:_files -g "*.ipkg"'
  '--clean[clean build artifacts for package]:ipkg file:_files -g "*.ipkg"'
  '--repl[start REPL for package]:ipkg file:_files -g "*.ipkg"'
  '--find-ipkg[look for ipkg file in parent directories]'
  '-i[add directory to import path]:directory:_directories'
  '--source-dir[set source directory]:directory:_directories'
  '--build-dir[set build directory]:directory:_directories'
  '--output-dir[set output directory]:directory:_directories'
  '--prefix[set installation prefix]:directory:_directories'
  '--paths[show installation paths]'
  '--libdir[show library directory]'
  '--list-packages[list installed packages]'
  '--cg[set code generator]:codegen:(chez racket refc node javascript)'
  '--codegen[set code generator]:codegen:(chez racket refc node javascript)'
  '--directive[pass a directive to the current code generator]:directive:'
  '--inc[add a C include directory]:directory:_directories'
  '--log[set logging level]:level:'
  '--timing[display timing logs]'
  '--debug-elab-check[enable elaborator checking for debugging]'
  '--dumpcases[dump case trees to file]:file:_files'
  '--dumplifted[dump lambda-lifted definitions to file]:file:_files'
  '--dumpanf[dump ANF definitions to file]:file:_files'
  '--dumpvmcode[dump VM code to file]:file:_files'
  '*:source files:_files -g "*.idr"'
)

_arguments -s -S $arguments
