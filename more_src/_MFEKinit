#compdef MFEKinit
# Documentation: https://github.com/MFEK/init
# Initialize UFO-format fonts (.ufo) and glyphs (.glif)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '1:subcommand:(glif ufo help)' \
  '*::args:_files' && ret=0

return ret
