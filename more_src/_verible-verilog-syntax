#compdef verible-verilog-syntax

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--helpfull[show all options]' \
  '--printtokens[print lexer tokens]' \
  '--printrawtokens[print raw lexer tokens]' \
  '--printtree[print AST]' \
  '--export_json[export JSON AST]' \
  '--printfilteredtokens[print filtered tokens]' \
  '--verifytree[verify tree validity]' \
  '--lang=[language standard]:lang:(sv-2017 verilog-2005 unknown auto)' \
  '--error_limit=[max errors before stopping]:n:' \
  '--show_diagnostic_context[show diagnostic context]' \
  '*:file:_files -g "*.{v,sv,vh,svh}"' && ret=0

return ret
