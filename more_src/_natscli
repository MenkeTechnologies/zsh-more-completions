#compdef natscli nats
# Documentation: https://man.archlinux.org/search?q=natscli
# Reference accessed: 2026-05-16

# natscli: official command-line client for NATS
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'account:NATS account commands'
  'auth:NATS auth helpers'
  'bench:benchmark NATS'
  'consumer:manage consumers (JetStream)'
  'context:manage NATS connection contexts'
  'cheat:print example commands'
  'completion:emit shell completion'
  'errors:show NATS error codes'
  'events:listen for system events'
  'governor:rate-limited cron-like sync helper'
  'kv:Key/Value store commands'
  'latency:measure publisher to consumer latency'
  'micro:NATS Micro services helpers'
  'object:object-store commands'
  'plugins:manage natscli plugins'
  'pub:publish a message'
  'reply:start a service-style reply'
  'request:make a request and read reply'
  'rtt:show round trip time'
  'schema:JSON schema helpers'
  'server:server interaction commands'
  'stream:manage JetStream streams'
  'sub:subscribe to a subject'
  'traffic:show traffic stats'
  'trace:run subject tracing'
  'whoami:show client info'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-s[NATS servers (comma separated)]:servers:' \
  '--server=[NATS servers]:servers:' \
  '--context=[NATS context]:context:' \
  '--user=[username]:user:_users' \
  '--password=[password]:password:' \
  '--creds=[credentials file]:file:_files' \
  '--nkey=[nkey file]:file:_files' \
  '--tlscert=[TLS cert]:file:_files' \
  '--tlskey=[TLS key]:file:_files' \
  '--tlsca=[TLS CA]:file:_files' \
  '--tlsfirst[force TLS-first]' \
  '--connection-name=[connection name]:name:' \
  '--timeout=[command timeout]:duration:' \
  '--trace[trace network operations]' \
  '--no-context[ignore context]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'nats command' commands && ret=0 ;;
esac
return ret
