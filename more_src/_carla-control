#compdef carla-control
# Documentation: https://github.com/falkTX/Carla
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Carla OSC remote control client
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '*:OSC URL (e.g. osc.udp://host:port):' && ret=0
return ret
