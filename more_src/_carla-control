#compdef carla-control
# Documentation: https://man.archlinux.org/search?q=carla-control
# Reference accessed: 2026-05-16

# Carla OSC remote control client
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '*:OSC URL (e.g. osc.udp://host:port):' && ret=0
return ret
