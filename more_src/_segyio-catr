#compdef segyio-catr
# Documentation: https://github.com/equinor/segyio/blob/main/applications/segyio-catr.c
# segyio: print specific trace headers from a SEG-Y file

local ret=1

_arguments -s -S \
  '*'{-t,--trace=}'[trace to print]:number' \
  '*'{-r,--range=}'[range START STOP STEP of traces to print]:start' \
  '(-f --format)'{-f,--format=}'[override sample format]:format:(ibm ieee short long char)' \
  '(-s --strict)'{-s,--strict}'[fail on unreadable tracefields]' \
  '(-S --non-strict)'{-S,--non-strict}'[do not fail on unreadable fields (default)]' \
  '(-n --nonzero)'{-n,--nonzero}'[only print fields with non-zero values]' \
  '(-d --description)'{-d,--description}'[print with byte offset and field description]' \
  '(-k --segyio)'{-k,--segyio}'[print with segyio tracefield names]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--version[output version information and exit]' \
  '--help[display this help and exit]' \
  '*:SEG-Y file:_files' && ret=0

return ret
