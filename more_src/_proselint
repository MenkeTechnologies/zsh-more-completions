#compdef proselint
# Documentation: https://github.com/amperser/proselint
# Reference accessed: 2026-05-20
# Verified: upstream amperser/proselint README.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--output-format=[output format]:format:(json)' \
  '--config=[config file path]:config file:_files' \
  '1:command:(check)' \
  '*:file:_files' && ret=0

return ret
