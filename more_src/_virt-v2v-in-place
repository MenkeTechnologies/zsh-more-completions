#compdef virt-v2v-in-place
# Documentation: https://libguestfs.org/virt-v2v-in-place.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# virt-v2v-in-place: convert a disk image in place (KVM/RHEL conversion)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable debug messages]' \
  '-x[enable libguestfs API tracing]' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress bars]' \
  '-i+[input mode]:mode:(disk libvirt libvirtxml local ova vmx)' \
  '-ic+[libvirt connection URI for input]:uri:' \
  '-if+[input disk format]:format:(raw qcow2 vmdk)' \
  '-io+[input-mode option (KEY=VALUE)]:opt:' \
  '-ip+[password file]:file:_files' \
  '(-b --bridge)'{-b+,--bridge=}'[bridge network map]:map:' \
  '--block-driver=[Windows virtio block driver]:driver:(virtio-blk virtio-scsi)' \
  '--colors[colorize messages]' \
  '--colours[colorize messages]' \
  '--echo-keys[echo typed keys/passphrases]' \
  '--key=[LUKS encryption key]:key:' \
  '--keys-from-stdin[read keys from stdin]' \
  '(-m --memsize)'{-m+,--memsize=}'[adjust memory size]:mb:' \
  '--mac=[map NIC MAC address to network]:mac:' \
  '--machine-readable[machine-readable output format]' \
  '(-n --network)'{-n+,--network=}'[network map]:net:' \
  '--no-fstrim[skip filesystem trimming]' \
  '-O+[write post-conversion metadata file]:file:_files' \
  '--print-source[display source guest information]' \
  '--root=[choose root filesystem]:dev:' \
  '--smp=[set virtual CPU count]:n:' \
  '--wrap[enable message wrapping]' \
  '*:disk image:_files' && ret=0
return ret
