#compdef virt-v2v-in-place

# virt-v2v-in-place: convert a disk image in place (KVM/RHEL conversion)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-x[trace]' \
  '--trace[trace]' \
  '-i[input mode]:mode:(disk libvirt libvirtxml ova vmx)' \
  '--input=[input mode]:mode:(disk libvirt libvirtxml ova vmx)' \
  '-O[input format]:format:(raw qcow2 vmdk vhd vpc vdi)' \
  '--input-format=[input format]:format:(raw qcow2 vmdk vhd vpc vdi)' \
  '--in-place[in-place conversion]' \
  '--remove-bdf=[remove boot disk filter]:bdf:' \
  '--root=[root device]:dev:' \
  '*:disk image:_files' && ret=0
return ret
