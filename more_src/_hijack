#compdef hijack

_arguments \
  '-n[container name]:name' \
  '-p[PID to attach to]:pid' \
  '-t[target namespace types]:types' \
  '-s[signal to send]:signal:_signals' \
  '-l[log level]:level:(debug info warn error)' \
  '--no-tty[do not allocate a TTY]' \
  '--user[user to run as]:user' \
  '-h[display help]' \
  '--help[display help]' \
  '-V[display version]' \
  '--version[display version]' \
  '*:container ID or name'
