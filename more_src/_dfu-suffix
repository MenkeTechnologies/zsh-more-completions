#compdef dfu-suffix

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --check)'{-c,--check}'+[check suffix]:file:_files' \
  '(-a --add)'{-a,--add}'+[add suffix]:file:_files' \
  '(-D --delete)'{-D,--delete}'+[delete suffix]:file:_files' \
  '(-p --pid)'{-p,--pid}'+[product id]:pid:' \
  '(-d --did)'{-d,--did}'+[device id]:did:' \
  '(-v --vid)'{-v,--vid}'+[vendor id]:vid:' \
  '(-s --stellaris)'{-s,--stellaris}'[stellaris file]' \
  '(-T --stellaris-address)'{-T,--stellaris-address}'+[stellaris addr]:addr:' && ret=0

return ret
