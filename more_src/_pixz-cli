#compdef pixz-cli
# _pixz-cli — Dave Vasilevsky pixz parallel indexed xz compression CLI alias (vasi team, C); custom argparse
# upstream: https://github.com/vasi/pixz

_pixz-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d[force decompress]' \
        '-x[create xz archive]' \
        '-l[list files in xz archive]' \
        '-i+[file from xz archive]:file:_files' \
        '-o+[output file]:file:_files' \
        '-t[treat as tar]' \
        '-T[do not treat as tar]' \
        '-k[keep input]' \
        '-r[do not include path]' \
        '-q[quiet]' \
        '-c+[level]:n:' \
        '-0[level 0 (no compression)]' \
        '-1[level 1]' \
        '-2[level 2]' \
        '-3[level 3]' \
        '-4[level 4]' \
        '-5[level 5]' \
        '-6[level 6]' \
        '-7[level 7]' \
        '-8[level 8]' \
        '-9[level 9]' \
        '-e[extreme compression]' \
        '-p+[processes]:n:' \
        '-f+[block factor mb]:n:' \
        '*:files:_files -g "*.{xz,tar.xz,txz,tar.lzma,tlz}"'
}

_pixz-cli "$@"
