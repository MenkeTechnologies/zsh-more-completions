#compdef cabal2nix

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-r --revision)'{-r,--revision}'+[revision]:rev:' \
  '(-f --flag)'{-f,--flag}'+[flag]:flag:' \
  '--system=+[target system]:sys:' \
  '--haskell-resolver=+[haskell resolver]:res:' \
  '--subpath=+[subpath in repo]:path:' \
  '--shell[generate shell.nix]' \
  '--no-haddock[no haddock]' \
  '--no-check[skip tests]' \
  '--no-benchmark[no benchmark]' \
  '--jailbreak[jailbreak]' \
  '--hyperlink-source[hyperlink source]' \
  '--enable-library-profiling[enable library profiling]' \
  '--enable-executable-profiling[enable exec profiling]' \
  '--enable-profiling[enable profiling]' \
  '--maintainer=+[maintainer]:name:' \
  '--extra-arguments=+[extra args]:args:' \
  '--hpack[use hpack]' \
  '--compiler=+[ghc compiler]:ghc:' \
  '*:URL or path:_files' && ret=0

return ret
