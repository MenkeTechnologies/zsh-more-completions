#compdef gptcache_server
# Documentation: https://github.com/zilliztech/GPTCache
# Reference accessed: 2026-05-23
# Verified: gptcache_server/server.py argparse (embedchain/gptcache PyPI).

# Zsh completion for gptcache_server - GPTCache HTTP cache server

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --host)'{-s+,--host=}'[hostname to listen on]:host:' \
  '(-p --port)'{-p+,--port=}'[port to listen on]:port:' \
  '(-d --cache-dir)'{-d+,--cache-dir=}'[cache data directory]:directory:_files -/' \
  '(-k --cache-file-key)'{-k+,--cache-file-key=}'[cache file download key]:key:' \
  '(-f --cache-config-file)'{-f+,--cache-config-file=}'[cache config file]:file:_files' \
  '(-o --openai)'{-o,--openai}'[enable OpenAI completions proxy]' \
  '(-of --openai-cache-config-file)'{-of+,--openai-cache-config-file=}'[OpenAI proxy cache config]:file:_files' && ret=0

return ret
