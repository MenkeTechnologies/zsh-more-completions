#compdef AppCompatCacheParser
# Documentation: https://github.com/EricZimmerman/AppCompatCacheParser
# Parses AppCompatCache (ShimCache) data from SYSTEM hive

local ret=1

_arguments -s -S \
  '-f[full path to SYSTEM hive (live registry if omitted)]:file:_files' \
  '-c[ControlSet to parse (default all)]:controlset' \
  '-t[sort last modified timestamps descending]' \
  '--csv[directory where CSV results are saved]:directory:_files -/' \
  '--csvf[filename for CSV output]:filename' \
  '--dt[custom date/time format]:format' \
  '--nl[ignore transaction log files for dirty hives]' \
  '--debug[enable debug mode]' && ret=0

return ret
