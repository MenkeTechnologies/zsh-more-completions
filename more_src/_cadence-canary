#compdef cadence-canary
# _cadence-canary — Cadence canary worker for continuous E2E validation (cadence-workflow/cadence)
# upstream: https://github.com/cadence-workflow/cadence
# Subcommands from cmd/canary/main.go (urfave/cli/v2).

_cadence-canary() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-r --root)'{-r+,--root=}'[root directory of execution environment]:dir:_files -/' \
        '(-c --config)'{-c+,--config=}'[config directory relative to root]:dir:_files -/' \
        '(-e --env)'{-e+,--env=}'[runtime environment]:env:(development production)' \
        '(--az --zone)'{--az+,--zone=}'[availability zone]:az:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start canary worker or cron or both'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '(-m --mode)'{-m+,--mode=}'[canary mode]:mode:(worker cron all)' ;;
            esac
            ;;
    esac
}

_cadence-canary "$@"
