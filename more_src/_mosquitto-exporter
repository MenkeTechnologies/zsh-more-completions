#compdef mosquitto-exporter
# Documentation: https://github.com/sapcc/mosquitto-exporter
# Prometheus exporter for Eclipse Mosquitto MQTT broker $SYS metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e --endpoint)'{-e,--endpoint}'=[endpoint for the Mosquitto message broker]:url' \
  '(-b --bind-address)'{-b,--bind-address}'=[listen address for metrics HTTP endpoint]:addr' \
  '(-u --user)'{-u,--user}'=[username for broker authentication]:user' \
  '(-p --pass)'{-p,--pass}'=[password for broker authentication]:pass' \
  '(-c --cert)'{-c,--cert}'=[TLS certificate .pem file]:file:_files' \
  '(-k --key)'{-k,--key}'=[TLS private key .pem file]:file:_files' \
  '(-i --client-id)'{-i,--client-id}'=[client ID for broker connection]:id' \
  '(-v --version)'{-v,--version}'[print the version]' && ret=0

return ret
