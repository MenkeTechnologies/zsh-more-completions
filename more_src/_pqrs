#compdef pqrs

_pqrs_commands() {
  local -a commands=(
    'cat:Print Parquet file content'
    'head:Print first rows of Parquet file'
    'count:Print row count'
    'rowcount:Print row count'
    'schema:Print schema'
    'sample:Sample random rows'
    'merge:Merge Parquet files'
    'size:Print file size info'
    'help:Show help'
  )
  _describe 'command' commands
}

_pqrs() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '1:command:_pqrs_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        cat)
          _arguments \
            '(-j --json)'{-j,--json}'[output as JSON]' \
            '(-c --csv)'{-c,--csv}'[output as CSV]' \
            '--columns=[select columns]:columns' \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:file:_files'
          ;;
        head)
          _arguments \
            '(-n --records)'{-n,--records}'=[number of records]:count' \
            '(-j --json)'{-j,--json}'[output as JSON]' \
            '(-c --csv)'{-c,--csv}'[output as CSV]' \
            '--columns=[select columns]:columns' \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:file:_files'
          ;;
        count|rowcount)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:file:_files'
          ;;
        schema)
          _arguments \
            '(-j --json)'{-j,--json}'[output as JSON]' \
            '(-d --detailed)'{-d,--detailed}'[show detailed schema]' \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:file:_files'
          ;;
        sample)
          _arguments \
            '(-n --records)'{-n,--records}'=[number of records]:count' \
            '(-j --json)'{-j,--json}'[output as JSON]' \
            '(-c --csv)'{-c,--csv}'[output as CSV]' \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:file:_files'
          ;;
        merge)
          _arguments \
            '(-o --output)'{-o,--output}'=[output file]:file:_files' \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:file:_files'
          ;;
        size)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:file:_files'
          ;;
      esac
      ;;
  esac
}

_pqrs "$@"
