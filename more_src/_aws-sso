#compdef aws-sso

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'cache:manage SSO token and role cache'
  'config:manage aws-sso configuration'
  'config-profiles:manage AWS profiles in ~/.aws/config'
  'console:open AWS console in browser'
  'credentials:print credentials for assumed role'
  'default-region:print default region'
  'eval:print export commands for current credentials'
  'exec:execute command with role credentials'
  'list:list available roles'
  'login:authenticate with AWS SSO'
  'logout:invalidate SSO token'
  'process:credential_process JSON output for AWS SDK'
  'setup:run setup wizard'
  'tags:manage tag-based selection'
  'time:print remaining session time'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-S+,--sso=}'[SSO instance to use]:sso:' \
  {-L+,--level=}'[log level]:level:(error warn info debug trace)' \
  '--lines[append file:line to log messages]' \
  '--config=[config file]:file:_files -g "*.yaml"' \
  '--cache=[cache file]:file:_files' \
  '--browser=[browser to use]:browser:' \
  '--url-action=[URL handler]:action:(clip exec open print printurl)' \
  '--threads=[concurrent thread count]:n:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'aws-sso subcommand' subcommands && ret=0
    ;;
esac

return ret
