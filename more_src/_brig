#compdef brig
# Documentation: https://github.com/brigadecore/brigade
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Brigade brig CLI (v2/cli/main.go — urfave/cli/v2 top-level Commands)

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'event:manage Brigade events'
  'init:scaffold Brigade project files'
  'login:authenticate to Brigade'
  'logout:end session'
  'project:manage Brigade projects'
  'role:grant/revoke system roles'
  'service-account:service account CRUD'
  'user:user administration'
  'term:embedded Kubernetes shell'
  'version:print client version'
  'whoami:show current API identity'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'brig command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
