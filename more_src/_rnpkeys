#compdef rnpkeys
# Documentation: https://manpages.debian.org/unstable/rnp/rnpkeys.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# rnpkeys: OpenPGP key management utility (RNP suite)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-l --list-keys)'{-l,--list-keys}'[list keys]' \
  '--with-sigs[also list signatures]' \
  '(-g --generate-key)'{-g,--generate-key}'[generate new key pair]' \
  '--numbits[RSA key bits]:bits:' \
  '--expiration[expiration time]:time:' \
  '--expert[expert mode]' \
  '--userid[user-id]:uid:' \
  '--hash[hash algorithm]:hash:' \
  '--cipher[cipher algorithm]:cipher:' \
  '--s2k-iterations[S2K iterations]:n:' \
  '--s2k-msec[S2K target msec]:ms:' \
  '--allow-weak-hash[allow weak hashes]' \
  '--allow-sha1-key-sigs[allow SHA1 key signatures]' \
  '--import[import keys or signatures]' \
  '--import-keys[import keys]' \
  '--import-sigs[import signatures]' \
  '--permissive[ignore errors during import]' \
  '--export-key[export keys]:filter:' \
  '--export-rev[export revocation]:key:' \
  '--secret[operate on secret keys]' \
  '--output[output path]:file:_files' \
  '--rev-type[revocation type]:type:' \
  '--rev-reason[revocation reason]:reason:' \
  '--revoke-key[revoke key]:key:' \
  '--remove-key[remove key]:key:' \
  '--edit-key[edit key]:key:' \
  '--add-subkey[add subkey]' \
  '--check-cv25519-bits[check Cv25519 bits]' \
  '--fix-cv25519-bits[fix Cv25519 bits]' \
  '--set-expire[set expiration]:time:' \
  '--homedir[home directory]:dir:_files -/' \
  '--overwrite[overwrite output file]' \
  '--pass-fd[password from fd]:fd:' \
  '--password[password (insecure)]:pass:' \
  '--force[force]' \
  '--notty[do not use terminal]' \
  '--current-time[reference time]:time:' \
  '*::rnpkeys args:_files' && ret=0
return ret
