#compdef resolvconf-cli
# _resolvconf-cli — Thomas Hood resolvconf manage resolver configuration CLI alias (debian/openresolv team, Shell); custom argparse
# upstream: https://salsa.debian.org/debian/resolvconf

_resolvconf-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[interface]:_net_interfaces' \
        '-d+[interface]:_net_interfaces' \
        '-f[force]' \
        '-l+[interface]:_net_interfaces' \
        '-p[mark as private]' \
        '-u[update resolv.conf]' \
        '-x[exclusive]' \
        '-m+[metric]:n:' \
        '-i+[suffix]:str:' \
        '-I[ignore]' \
        '*:arg:'
}

_resolvconf-cli "$@"
