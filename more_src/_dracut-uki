#compdef dracut-uki
# Documentation: https://github.com/dracut-ng/dracut-ng
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dracut-uki: build Unified Kernel Image with dracut initramfs
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kver=[kernel version]:ver:' \
  '--kernel-image=[kernel image path]:file:_files' \
  '--uefi-stub=[UEFI stub binary]:file:_files' \
  '--cmdline=[kernel command line]:cmdline:' \
  '--output=[output UKI]:file:_files' \
  '*::extra args:_files' && ret=0
return ret
