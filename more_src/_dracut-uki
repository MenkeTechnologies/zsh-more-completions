#compdef dracut-uki

# dracut-uki: build a Unified Kernel Image (UKI) - convenience wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--kernel=[kernel image to embed]:file:_files' \
  '--initrd=[initramfs to embed]:file:_files' \
  '--cmdline=[kernel command line]:cmdline:' \
  '--osrel=[os-release file to embed]:file:_files' \
  '--out=[output UKI .efi file]:file:_files' \
  '*::dracut-uki args:_files' && ret=0
return ret
