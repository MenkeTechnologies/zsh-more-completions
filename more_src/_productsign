#compdef productsign
# Documentation: macOS man productsign(1)
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--sign[signing identity name]:identity'
    '--keychain[keychain to search for signing identity]:keychain:_files'
    '*--cert[intermediate certificate to embed]:certificate'
    '--timestamp[include a trusted timestamp]'
    '--timestamp=-[disable trusted timestamp when value is none]:value:(none)'
    '1:input product:_files -g "*.pkg"'
    '2:output product:_files -g "*.pkg"'
)

_arguments -s -S $arguments
