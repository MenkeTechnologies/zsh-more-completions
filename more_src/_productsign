#compdef productsign
# Documentation: https://man.archlinux.org/search?q=productsign
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '--sign[Signing identity]:identity'
    '--keychain[Keychain to search for signing identity]:keychain:_files'
    '--cert[Certificate to include]:certificate:_files'
    '--timestamp[Include a trusted timestamp]'
    '--no-timestamp[Do not include a timestamp]'
    '--quiet[Suppress non-error output]'
    '1:input product:_files -g "*.pkg"'
    '2:output product:_files -g "*.pkg"'
)

_arguments -s -S $arguments
