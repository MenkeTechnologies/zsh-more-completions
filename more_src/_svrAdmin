#compdef svrAdmin
# _svrAdmin — Ghidra server user/repository admin tool (NationalSecurityAgency/ghidra)
# upstream: https://github.com/NationalSecurityAgency/ghidra
# Flags from Ghidra/RuntimeScripts/server/svrAdmin (script header).

_svrAdmin() {
    _arguments \
        '*-add+[add user with default password (sid; --p to prompt)]:sid:_users' \
        '*-dn+[set user x500 DN for PKI auth (sid dn)]:sid:_users' \
        '*-remove+[remove user (sid)]:sid:_users' \
        '*-reset+[reset password to changeme (sid; --p to prompt)]:sid:_users' \
        '*-admin+[mark user as admin of repository (sid repo)]:sid:_users' \
        '-list[list all repositories]' \
        '-users[list all users]' \
        '*-migrate+[migrate named repository to indexed storage]:repo:' \
        '-migrate-all[migrate all repositories to indexed storage]' \
        '--p[prompt for password]'
}

_svrAdmin "$@"
