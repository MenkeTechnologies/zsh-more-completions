#compdef wait-for-it wait-for-it.sh
# Documentation: https://github.com/vishnubob/wait-for-it
# wait until a TCP host:port is available then run a command

local ret=1

_arguments -s -S \
  '(-h --host)'{-h+,--host=}'[host or IP under test]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[TCP port under test]:port' \
  '(-s --strict)'{-s,--strict}'[only execute subcommand if the test succeeds]' \
  '(-q --quiet)'{-q,--quiet}'[do not output any status messages]' \
  '(-t --timeout)'{-t+,--timeout=}'[timeout in seconds, zero for no timeout]:seconds' \
  '*::command:_command_names -e' && ret=0

return ret
