#compdef tetra

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '--server-address=[server address]:address:' \
  '--timeout=[connection timeout]:timeout:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'getevents:get events from tetragon'
      'health:check tetragon health'
      'status:show tetragon status'
      'sensors:manage sensors'
      'tracingpolicy:manage tracing policies'
      'bugtool:collect debugging information'
      'policyfilter:manage policy filters'
      'debug:debug tetragon'
      'loglevel:get or set the log level'
      'version:show version information'
      'completion:generate shell completions'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (getevents)
        _arguments \
          '(-o --output)'{-o,--output}'=[output format]:format:(json compact)' \
          '--color=[color output]:mode:(auto never always)' \
          '--namespaces=[filter by namespaces]:namespaces:' \
          '--namespace=[filter by namespace]:namespace:' \
          '--pods=[filter by pods]:pods:' \
          '--pod=[filter by pod]:pod:' \
          '--processes=[filter by processes]:processes:' \
          '--process=[filter by process]:process:' \
          '--host[include host events]' \
          '--event-types=[filter by event types]:types:' \
          '--timestamps[include timestamps]' \
          '--tty-encode=[tty encoding]:encoding:(text base64)' && ret=0
        ;;
      (sensors)
        _arguments \
          '1:action:(list enable disable rm add)' \
          '*:sensor name:' && ret=0
        ;;
      (tracingpolicy)
        _arguments \
          '1:action:(list add delete generate)' \
          '*:policy:_files -g "*.yaml"' && ret=0
        ;;
      (loglevel)
        _arguments \
          '1:action:(get set)' \
          '2:level:(debug info warning error fatal panic)' && ret=0
        ;;
    esac
    ;;
esac

return ret
