#compdef ish-cli
# _ish-cli — iSH iOS Alpine Linux env shell CLI alias (Theodore Dubois / ish-app, C/Swift); custom argparse
# upstream: https://github.com/ish-app/ish

_ish-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--root=+[root dir]:dir:_files -/' \
        '-r+[root dir]:dir:_files -/' \
        '--shell=+[shell]:str:' \
        '-s+[shell]:str:' \
        '--cwd=+[working dir]:dir:_files -/' \
        '-w+[working dir]:dir:_files -/' \
        '--env=+[env var KEY=VALUE]:list:' \
        '-e+[env var KEY=VALUE]:list:' \
        '--login[login shell]' \
        '-l[login shell]' \
        '*:cmd-and-args:_command_names -e'
}

_ish-cli "$@"
