#compdef smithy
# Documentation: https://smithy.io/2.0/guides/smithy-cli/index.html
#                + smithy-cli/src/main/java/software/amazon/smithy/cli/commands/*.java
# Reference accessed: 2026-05-29
# AWS Smithy IDL CLI for service-model build/validate/diff.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'ast:export a Smithy model as JSON AST'
  'build:build the model and generate plugin artifacts (projections)'
  'clean:remove the smithy-build output directory'
  'diff:compare two Smithy models for compatibility/breaking changes'
  'format:format Smithy IDL files'
  'init:initialize a new Smithy project from a template'
  'lock:create or update the smithy-lock.json file'
  'migrate:migrate a Smithy 1.0 model to 2.0'
  'select:select shapes from a model using a Smithy selector expression'
  'validate:validate one or more Smithy models'
  'version:show Smithy CLI version'
  'warmup:warm up the JVM (compile classes ahead of time)'
  'help:show help for a subcommand'
)

local -a _config
_config=(
  '(-c --config)'{-c,--config=}'[path to smithy-build.json config file]:file:_files -g "*.json"'
  '--no-config[do not load a smithy-build.json file]'
)

local -a _discovery
_discovery=(
  '--discover[discover models on the classpath]'
  '--discover-classpath=[classpath used for model discovery]:classpath:'
)

local -a _validator
_validator=(
  '--severity=[minimum severity level to report]:level:(NOTE WARNING DANGER ERROR)'
  '--no-validate[skip model validation]'
  '*--hide-validators=[hide validators by ID]:id:'
  '*--show-validators=[only show validators by ID]:id:'
  '--quiet-validation-summary[do not print the validation summary]'
)

local -a _standard
_standard=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '(-q --quiet)'{-q,--quiet}'[silence non-error output]'
  '--debug[enable debug logging]'
  '--stacktrace[show stacktrace on errors]'
  '--logging=[log level]:level:(OFF SEVERE WARNING INFO CONFIG FINE FINER FINEST ALL)'
  '--no-color[disable colored output]'
  '--force-color[force colored output]'
)

_arguments -C \
  $_standard \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'smithy subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      ast)
        _arguments \
          $_standard $_config $_discovery $_validator \
          '*:model file/dir:_files' && ret=0
        ;;
      build)
        _arguments \
          $_standard $_config $_discovery $_validator \
          '--projection=[only generate artifacts for this projection]:projection:' \
          '--plugin=[only generate artifacts for this plugin]:plugin:' \
          '--output=[output directory for build artifacts]:dir:_directories' \
          '*:model file/dir:_files' && ret=0
        ;;
      clean)
        _arguments \
          $_standard $_config && ret=0
        ;;
      diff)
        _arguments \
          $_standard $_validator \
          '--mode=[diff mode]:mode:(arbitrary project git)' \
          '--old=[old model path]:path:_files' \
          '--new=[new model path]:path:_files' \
          '--old-format=[old model output format]:fmt:(text csv json)' \
          '--new-format=[new model output format]:fmt:(text csv json)' \
          '--format=[diff output format]:fmt:(text csv json)' \
          '--events-format=[format for diff events]:fmt:(text csv json)' \
          '*:model file/dir:_files' && ret=0
        ;;
      format)
        _arguments \
          $_standard \
          '*:Smithy IDL file:_files -g "*.smithy"' && ret=0
        ;;
      init)
        _arguments \
          $_standard \
          '(-l --list)'{-l,--list}'[list available templates]' \
          '(-o --output)'{-o,--output=}'[output directory]:dir:_directories' \
          '(-t --template)'{-t,--template=}'[template name]:template:' \
          '(-u --url)'{-u,--url=}'[template repository URL]:url:_urls' \
          '--include-archive[include archived examples]' && ret=0
        ;;
      lock)
        _arguments \
          $_standard $_config && ret=0
        ;;
      migrate)
        _arguments \
          $_standard $_config \
          '(-d --dry-run)'{-d,--dry-run}'[do not write changes]' \
          '*:Smithy file:_files -g "*.smithy"' && ret=0
        ;;
      select)
        _arguments \
          $_standard $_config $_discovery \
          '(-e --expression)'{-e,--expression=}'[Smithy selector expression]:expr:' \
          '--show-traits[show shape traits in output]' \
          '--vars[show selector variables]' \
          '*:model file/dir:_files' && ret=0
        ;;
      validate)
        _arguments \
          $_standard $_config $_discovery $_validator \
          '*:model file/dir:_files' && ret=0
        ;;
      version|warmup)
        _arguments $_standard && ret=0
        ;;
    esac
    ;;
esac

return ret
