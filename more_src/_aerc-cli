#compdef aerc-cli aerc
# _aerc-cli — Drew DeVault aerc terminal email client CLI alias (aerc team, Go); custom argparse
# upstream: https://git.sr.ht/~rjarry/aerc

_aerc-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--accounts=+[accounts csv]:str:' \
        '-a+[accounts csv]:str:' \
        '--no-ipc[disable IPC]' \
        '--no-tagged-frame[no tagged frame]' \
        '--query=+[ipc command]:str:' \
        '-Q+[ipc command]:str:' \
        '--command=+[startup command]:str:' \
        '-C+[startup command]:str:' \
        '*:mailto/share URL:'
}

_aerc-cli "$@"
