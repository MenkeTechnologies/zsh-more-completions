#compdef anubis
# Documentation: https://github.com/TecharoHQ/anubis
# Source: TecharoHQ/anubis cmd/anubis/main.go — challenge-based reverse proxy that weighs incoming requests to stop AI crawlers.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-base-prefix=[base prefix (root URL) the application is served under]:prefix:_default' \
    '-bind=[network address to bind HTTP to]:bind:_default' \
    '-bind-network=[network family to bind HTTP to]:network:(tcp unix)' \
    '-difficulty=[difficulty of the challenge]:n:_default' \
    '-cookie-domain=[top-level domain that the Anubis cookie will be valid for]:domain:_default' \
    '-cookie-dynamic-domain[set the cookie Domain value based on the request domain]' \
    '-cookie-expiration-time=[duration the authorization cookie is valid]:duration:_default' \
    '-cookie-prefix=[prefix for browser cookies created by Anubis]:prefix:_default' \
    '-cookie-partitioned[set the partitioned flag on Anubis cookies (CHIPS)]' \
    '-cookie-secure[set the secure flag on Anubis cookies]' \
    '-cookie-same-site=[same site option]:value:(None Lax Strict Default)' \
    '-difficulty-in-jwt[add a difficulty field in the JWT claims]' \
    '-use-simplified-explanation[show simplified explanation text]' \
    '-forced-language=[force this language instead of Accept-Language]:lang:_default' \
    '-hs512-secret=[secret used to sign JWTs (uses ed25519 if not set)]:secret:_default' \
    '-ed25519-private-key-hex=[ed25519 private key in hex]:key:_default' \
    '-ed25519-private-key-hex-file=[file containing the ed25519 private key hex]:file:_files' \
    '-metrics-bind=[network address to bind metrics to]:bind:_default' \
    '-metrics-bind-network=[network family for the metrics server]:network:(tcp unix)' \
    '-socket-mode=[socket mode for unix domain sockets]:mode:_default' \
    '-serve-robots-txt[serve a robots.txt that disallows all robots]' \
    '-policy-fname=[full path to anubis policy document]:file:_files' \
    '-redirect-domains=[comma-separated allowed redirect domains]:domains:_default' \
    '-slog-level=[logging level]:level:(DEBUG INFO WARN ERROR)' \
    '-strip-base-prefix[strip the base prefix from requests forwarded to the target]' \
    '-target=[target URL to reverse proxy to]:url:_default' \
    '-target-sni=[TLS handshake hostname when forwarding requests]:sni:_default' \
    '-target-host=[Host header value when forwarding to the target]:host:_default' \
    '-target-insecure-skip-verify[skip TLS validation for the backend]' \
    '-target-disable-keepalive[disable HTTP keep-alive for the backend]' \
    '-healthcheck[run a health check against Anubis]' \
    '-use-remote-address[read the client IP from the network request]' \
    '-debug-benchmark-js[respond to every request with a challenge for benchmarking]' \
    '-og-passthrough[enable Open Graph tag passthrough]' \
    '-og-expiry-time=[Open Graph tag cache expiration time]:duration:_default' \
    '-og-cache-consider-host[use host in the Open Graph tag cache]' \
    '-extract-resources=[extract static resources to the specified folder]:dir:_files -/' \
    '-webmaster-email=[email displayed on the reject page]:email:_default' \
    '-public-url=[externally accessible URL for this Anubis instance]:url:_default' \
    '-xff-strip-private[strip private addresses from X-Forwarded-For]' \
    '-custom-real-ip-header=[header name to read remote IP from]:header:_default' \
    '-thoth-insecure[connect to Thoth over plain HTTP/2]' \
    '-thoth-url=[URL for Thoth IP reputation database]:url:_default' \
    '-thoth-token=[API token for Thoth]:token:_default' \
    '-jwt-restriction-header=[header name JWT is bound to]:header:_default' \
    '-version[print Anubis version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
