#compdef mate-notification-properties
# Documentation: https://manpages.debian.org/buster/mate-notification-daemon-common/mate-notification-properties.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mate-notification-properties: the man page documents no command-line options
# (the SYNOPSIS lists just the program name). Standard MATE/GTK options accepted.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options including GTK]' \
  '(- *)--help-gtk[show GTK options]' \
  '--display=[X display]:display:' \
  '*::args:_files' && ret=0
return ret
