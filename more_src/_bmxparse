#compdef bmxparse bmxtimecode
# Documentation: source-direct extraction from upstream
# bbc/bmx apps/bmxparse/bmxparse.cpp + apps/bmxtimecode.cpp.
# Both binaries use a hand-rolled
#   for (cmdln_index = 1; cmdln_index < argc; cmdln_index++)
# argv-walking loop with
#   strcmp(argv[cmdln_index], "--flag")
# arms instead of getopt — same convention as R206's dvrescue.
# Reference accessed: 2026-05-30 via gh api.
# BBC bmx R207 — partial follow-up to R206's hunt-skip on "BBC
# bmx tools (bmxparse, bmxtimecode, bmxtranswrap, mxf2raw,
# raw2bmx) are the modern MXF toolset but each needs its own
# extraction round - deferred".  This round picks off the two
# small binaries (bmxparse + bmxtimecode); bmxtranswrap
# (5075 lines), mxf2raw (3450 lines), and raw2bmx (6361 lines)
# each deserve their own dedicated round given their hundreds-
# of-flags surface.  Sister tools to R206's dvrescue and the
# heavily-covered video/MXF/codec family already in the corpus.

case $service in

  bmxparse)
    # Text-dump raw essence files using the bmx library's
    # parser class.  Used to inspect AVC / DV / J2C / MJPEG /
    # M2V / RDD36 / VC2 / VC3 raw streams that have been
    # demuxed out of an MXF wrapper.  Usage:
    #   bmxparse <<Options>> <type> <filename>
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '(-v --version)'{-v,--version}'[print version info and exit]' \
      '-l+[log to file (default stderr)]:file:_files' \
      '--log-level=[log level (0=debug 1=info 2=warning 3=error; default 1)]:level:((0\:debug 1\:info 2\:warning 3\:error))' \
      '--single-field[assume MJPEG single-field encoding (default = parse field pairs)]' \
      '--avc-picture[parse AVC field/frame coded picture without combining field pairs]' \
      '1:raw essence type:(avc dv j2c mjpeg m2v rdd36 vc2 vc3)' \
      '2:raw essence file:_files'
    ;;

  bmxtimecode)
    # Convert between timecode (HH:MM:SS:FF or HH:MM:SS;FF for
    # drop-frame) and frame-count.  Useful for SMPTE timecode
    # math and for testing parse_timecode() / get_timecode_
    # string() round-trips.  Usage:
    #   bmxtimecode [--output ...] [--rate ...] (all|<tc>|<n>)
    # If positional is "all", emits the full enumeration of
    # frame-count -> timecode for the chosen rate (up to
    # GetMaxOffset() per the timecode wraparound at 24h).
    _arguments -s -S \
      '--output=[output format]:format:((tc-drop\:drop-frame-timecode tc-non-drop\:non-drop-frame-timecode count\:integer-frame-count))' \
      '--rate=[frame rate (integer or numerator/denominator e.g. "25" or "30000/1001")]:rate:(24 25 30 50 60 24000/1001 30000/1001 60000/1001)' \
      '1:value (all OR HH:MM:SS:FF / HH:MM:SS;FF OR frame-count integer):'
    ;;

esac
