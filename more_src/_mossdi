#compdef mossdi
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/mossdi.html
# MIRIAD mossdi - SDI clean for mosaicked images

local ret=1

_arguments -s -S \
  'map=[input dirty map (Jy/beam)]:map:_files' \
  'beam=[input dirty beam]:beam:_files' \
  'model=[initial model of deconvolved image]:model:_files' \
  'out=[output map (Jy/pixel)]:out:_files' \
  'gain=[clean loop gain]:gain' \
  'niters=[maximum number of iterations]:niters' \
  'cutoff=[residual threshold stopping criterion]:cutoff' \
  'clip=[relative clipping level]:clip' \
  'region=[region of interest]:region' \
  'options=[positive]:options' \
  '*:dataset:_files' && ret=0

return ret
