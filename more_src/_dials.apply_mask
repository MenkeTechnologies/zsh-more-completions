#compdef dials.apply_mask
# Documentation: https://dials.github.io/documentation/programs/dials_apply_mask.html
# Apply a mask to the given experiments, one mask per imageset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*input.mask=[the mask filenames, one mask per imageset]:file:_files' \
  'output.experiments=[name of output experiments file]:file:_files' \
  '*:arg:_files' && ret=0

return ret
