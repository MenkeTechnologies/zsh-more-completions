#compdef semodule_compile
# _semodule_compile — SELinux semodule_compile (compile a single .te/.fc source pair into a binary .pp module ready for semodule -i; -o output file, -v verbose, -V version, -h help; positional argument is the .te module to compile)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux libsemanage tools/semodule_compile.c on tip.

_semodule_compile() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-o+[output file]:file:_files -g "*.pp"' \
        '-v[verbose]' \
        '1:source module:_files -g "*.(te|cil)"'
}

_semodule_compile "$@"
