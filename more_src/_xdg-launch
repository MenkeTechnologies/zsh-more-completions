#compdef xdg-launch
# Documentation: https://man.archlinux.org/search?q=xdg-launch
# Reference accessed: 2026-05-16

_arguments -s \
  '(-U --autostart)'{-U,--autostart}'[search AutoStart entries]' \
  '(-X --xsession)'{-X,--xsession}'[search XSession entries]' \
  '(-E --session)'{-E,--session}'[launch XSession + autostart]' \
  '(-B --startup)'{-B,--startup}'[autostart only]' \
  '(-I --info)'{-I,--info}'[print info instead of launch]' \
  '(-c --chain)'{-c,--chain}'[chain from previous launch]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-C,--copying}'[show copying info]' \
  '(-a --appid)'{-a,--appid=}'[application ID]:appid:' \
  '(-A --action)'{-A,--action=}'[action]:action:' \
  '--mimetype=[mime type]:mime:' \
  '--category=[category]:category:' \
  '--desktop=[desktop entry]:desktop:' \
  '(-f --file)'{-f,--file=}'[file]:file:_files' \
  '(-u --url)'{-u,--url=}'[URL]:url:' \
  '(-x --exec)'{-x,--exec=}'[exec command]:cmd:' \
  '*-e[exec args]:args:' \
  '(-L --launcher)'{-L,--launcher=}'[launcher name]:name:' \
  '(-l --launchee)'{-l,--launchee=}'[launchee]:name:' \
  '(-S --sequence)'{-S,--sequence=}'[sequence]:seq:' \
  '(-n --hostname)'{-n,--hostname=}'[hostname]:host:_hosts' \
  '(-m --monitor)'{-m,--monitor=}'[monitor]:n:' \
  '(-s --screen)'{-s,--screen=}'[screen]:n:' \
  '(-w --workspace)'{-w,--workspace=}'[workspace]:n:' \
  '(-t --timestamp)'{-t,--timestamp=}'[timestamp]:ts:' \
  '(-N --name)'{-N,--name=}'[name]:name:' \
  '(-i --icon)'{-i,--icon=}'[icon]:icon:' \
  '(-b --binary)'{-b,--binary=}'[binary]:bin:' \
  '(-d --description)'{-d,--description=}'[description]:desc:' \
  '(-W --wmclass)'{-W,--wmclass=}'[wm class]:class:' \
  '(-q --silent)'{-q,--silent=}'[silent]:n:(0 1)' \
  '(-p --pid)'{-p,--pid=}'[PID]:pid:_pids' \
  '--ppid=[parent PID]:pid:' \
  '(-P --pointer)'{-P,--pointer}'[use pointer location]' \
  '(-K --keyboard)'{-K,--keyboard}'[use keyboard focus]' \
  '--assist[enable assist]' \
  '--no-assist[disable assist]' \
  '(-T --toolwait)'{-T,--toolwait}'[wait for tool]' \
  '--timeout=[timeout secs]:secs:' \
  '--mappings=[N windows]:n:' \
  '--withdrawn[withdrawn windows]' \
  '--noprop[no properties]' \
  '--autowait[auto wait]' \
  '--no-autowait[disable auto wait]' \
  '(-M --manager)'{-M,--manager}'[wait for manager]' \
  '(-Y --tray)'{-Y,--tray}'[wait for tray]' \
  '(-G --pager)'{-G,--pager}'[wait for pager]' \
  '(-O --composite)'{-O,--composite}'[wait for composite]' \
  '(-R --audio)'{-R,--audio}'[wait for audio]' \
  '(-g --guard)'{-g,--guard=}'[guard secs]:secs:' \
  '--delay=[delay secs]:secs:' \
  '--history[enable history]' \
  '--no-history[disable history]' \
  '(-k --keep)'{-k,--keep=}'[keep N entries]:n:' \
  '(-r --recent)'{-r,--recent=}'[recent file]:file:_files' \
  '--set-default[set default]' \
  '--set-preferred[set preferred]' \
  '--default[is default]' \
  '--no-default[not default]' \
  '--recommend[recommend]' \
  '--no-recommend[do not recommend]' \
  '--fallback[fallback]' \
  '--no-fallback[no fallback]' \
  '*'{-v,--verbose}'[verbose]' \
  '*'{-D,--debug}'[debug]'
