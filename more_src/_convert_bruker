#compdef convert_bruker
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/convert_bruker.html
# Source: MRtrix3/mrtrix3 bin/convert_bruker — convert Bruker 2dseq + scan header to MRtrix .mih (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:2dseq input:_files' \
    '2:output header file:_files -g "*.mih"' \
    && ret=0

return ret
