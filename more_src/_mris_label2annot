#compdef mris_label2annot
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_label2annot
# FreeSurfer: convert a set of label files into an annotation

local ret=1

_arguments -s -S \
  '(- *)--help[display help information]' \
  '(- *)--version[display version information]' \
  '--ctab[colortable file]:ctab file:_files' \
  '*--l[label file to include]:label file:_files' \
  '--ldir[directory of label files]:labeldir:_files -/' \
  '--ldir-default[use default label directory]' \
  '(--s --subject)'{--s,--subject}'[FreeSurfer subject]:subject' \
  '(--a --annot)'{--a,--annot}'[output annotation name]:annot name' \
  '(--h --hemi)'{--h,--hemi}'[hemisphere]:hemi:(lh rh)' \
  '--no-unknown[start label numbering at index 0]' \
  '--nhits[diagnostic overlay of label count per vertex]:nhits file:_files' \
  '--offset[add value to label number for CTAB indexing]:IndexOffset' \
  '--sd[subjects directory]:dir:_files -/' \
  '--noverbose[suppress overlap and stat override messages]' \
  '--maxstatwinner[retain label with highest stat value]' \
  '--thresh[filter labels by statistics field threshold]:thres' \
  '--surf[surface name (default orig)]:surfname' \
  '--checkopts[check options only]' \
  '--nocheckopts[disable options checking]' \
  '--debug[enable debug mode]' \
  '*:argument:_files' && ret=0

return ret
