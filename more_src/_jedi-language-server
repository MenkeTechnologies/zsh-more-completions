#compdef jedi-language-server
# Documentation: https://github.com/pappasam/jedi-language-server
# jedi-language-server - Python language server powered by Jedi

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information and exit]' \
  '--version[show the program version number and exit]' \
  '--tcp[use TCP server instead of stdio]' \
  '--ws[use WebSocket server instead of stdio]' \
  '--host=[bind to this address]:host' \
  '--port=[bind to this port]:port' \
  '--log-file=[redirect logs to the given file]:file:_files' \
  '*'{-v,--verbose}'[increase verbosity of log output]' && ret=0

return ret
