#compdef buildah

# Zsh completion for Buildah - tool for building OCI container images

local curcontext="$curcontext" state line ret=1

_buildah_commands() {
  local -a commands=(
    'add:add content to the container'
    'build:build an image using Containerfile instructions'
    'commit:create an image from a working container'
    'config:update image configuration settings'
    'containers:list working containers and their base images'
    'copy:copy content into the container'
    'from:create a working container based on an image'
    'images:list images in local storage'
    'info:display buildah system information'
    'inspect:inspect a build container or image'
    'login:log in to a container registry'
    'logout:log out of a container registry'
    'manifest:manipulate manifest lists and image indexes'
    'mount:mount a working container root filesystem'
    'mounts:list mounted containers'
    'pull:pull an image from a registry'
    'push:push an image to a specified destination'
    'rename:rename a local container'
    'rm:remove one or more working containers'
    'rmi:remove one or more images from local storage'
    'run:run a command inside of the container'
    'source:create, push, pull, and manage source images'
    'tag:add an additional name to a local image'
    'umount:unmount the root file system of a working container'
    'unmount:unmount the root file system of a working container'
    'unshare:run a command in a modified user namespace'
    'version:display buildah version information'
  )
  _describe -t commands 'buildah command' commands
}

_buildah_from() {
  _arguments -s -S \
    '--add-host[add a custom host-to-IP mapping]:host\:ip' \
    '--arch[set the architecture of the image]:arch:(amd64 arm64 arm s390x ppc64le)' \
    '--authfile[path of the authentication file]:file:_files' \
    '--cap-add[add Linux capability]:capability' \
    '--cap-drop[drop Linux capability]:capability' \
    '--cert-dir[directory of TLS certificates]:dir:_directories' \
    '--cgroup-parent[optional parent cgroup]:cgroup' \
    '--cidfile[write the container ID to the file]:file:_files' \
    '--cpu-period[limit CPU CFS period]:period' \
    '--cpu-quota[limit CPU CFS quota]:quota' \
    '--creds[credentials for the registry]:username\:password' \
    '--decryption-key[decryption key for encrypted images]:key:_files' \
    '--device[add a host device to the container]:device:_files' \
    '--dns[set custom DNS servers]:dns' \
    '--dns-option[set custom DNS options]:option' \
    '--dns-search[set custom DNS search domains]:domain' \
    '--format[image manifest and metadata format]:format:(oci docker)' \
    '--http-proxy[pass through HTTP proxy environment variables]' \
    '--isolation[process isolation]:type:(oci rootless chroot)' \
    '--memory[memory limit]:limit' \
    '--memory-swap[swap limit]:limit' \
    '--name[name for the working container]:name' \
    '--network[set the network mode]:mode:(host none bridge private ns\: container\: slirp4netns pasta)' \
    '--os[set the OS of the image]:os:(linux windows darwin)' \
    '--pid[PID namespace]:ns' \
    '--platform[set the OS/ARCH of the image]:platform' \
    '--pull[pull policy]:policy:(always missing never ifnewer)' \
    '--quiet[do not output the container ID]' \
    '--retry[number of retries]:num' \
    '--retry-delay[delay between retries]:duration' \
    '--security-opt[set security options]:option' \
    '--shm-size[size of /dev/shm]:size' \
    '--tls-verify[require HTTPS and verify certificates]' \
    '--ulimit[set ulimits]:ulimit' \
    '--userns[set the user namespace mode]:mode' \
    '--userns-gid-map[GID map for user namespace]:map' \
    '--userns-uid-map[UID map for user namespace]:map' \
    '--variant[override variant of the image]:variant' \
    '--volume[bind mount a volume]:volume:_directories' \
    '1:image:' && ret=0
}

_buildah_build() {
  _arguments -s -S \
    '--add-host[add a custom host-to-IP mapping]:host\:ip' \
    '--all-platforms[build for all available platforms]' \
    '--annotation[set metadata annotations]:key=value' \
    '--arch[set the architecture of the image]:arch' \
    '--authfile[path of the authentication file]:file:_files' \
    '--build-arg[set build-time variables]:key=value' \
    '--build-arg-file[file with build-time variables]:file:_files' \
    '--build-context[additional build contexts]:name=value' \
    '--cache-from[images to use as cache sources]:image' \
    '--cache-to[remote repository to cache to]:repo' \
    '--cache-ttl[cache time-to-live]:duration' \
    '--cap-add[add Linux capability]:capability' \
    '--cap-drop[drop Linux capability]:capability' \
    '--cert-dir[directory of TLS certificates]:dir:_directories' \
    '--cgroup-parent[optional parent cgroup]:cgroup' \
    '--cgroupns[cgroup namespace]:mode:(host private)' \
    '--compress[compress the build context]' \
    '--cpp-flag[set additional flag to pass to C preprocessor]:flag' \
    '--cpu-period[limit CPU CFS period]:period' \
    '--cpu-quota[limit CPU CFS quota]:quota' \
    '--cpu-shares[CPU shares]:shares' \
    '--cpuset-cpus[allowed CPUs]:cpus' \
    '--cpuset-mems[allowed memory nodes]:mems' \
    '--creds[credentials for the registry]:username\:password' \
    '--decryption-key[decryption key for encrypted images]:key:_files' \
    '--device[add a host device to the container]:device' \
    '--disable-compression[disable layer compression]' \
    '--dns[set custom DNS servers]:dns' \
    '--dns-option[set custom DNS options]:option' \
    '--dns-search[set custom DNS search domains]:domain' \
    '(-f --file)'{-f,--file}'[pathname of the Containerfile]:file:_files' \
    '--force-rm[always remove intermediate containers]' \
    '--format[image manifest and metadata format]:format:(oci docker)' \
    '--from[image name to use as replacement for FROM]:image' \
    '--group-add[add groups to container process]:group' \
    '--http-proxy[pass through HTTP proxy environment variables]' \
    '--identity-label[add default identity label]' \
    '--ignorefile[ignore file path]:file:_files' \
    '--iidfile[write the image ID to the file]:file:_files' \
    '--isolation[process isolation]:type:(oci rootless chroot)' \
    '--jobs[number of build jobs]:num' \
    '--label[set metadata for an image]:key=value' \
    '--layers[use caching of each step]' \
    '--logfile[log to file]:file:_files' \
    '--loglevel[set log level]:level:(0 1 2 3)' \
    '--manifest[add the image to a manifest list]:manifest' \
    '--memory[memory limit]:limit' \
    '--memory-swap[swap limit]:limit' \
    '--network[set the network mode]:mode:(host none bridge private)' \
    '--no-cache[do not use existing cached images]' \
    '--no-hostname[do not create /etc/hostname]' \
    '--no-hosts[do not create /etc/hosts]' \
    '--os[set the OS of the image]:os:(linux windows darwin)' \
    '--output[output destination]:output' \
    '--pid[PID namespace]:ns' \
    '--platform[set the OS/ARCH/VARIANT]:platform' \
    '--pull[pull policy]:policy:(always missing never ifnewer true false)' \
    '(-q --quiet)'{-q,--quiet}'[suppress build output]' \
    '--retry[number of retries]:num' \
    '--retry-delay[delay between retries]:duration' \
    '--rm[remove intermediate containers after build]' \
    '--runtime[OCI runtime]:runtime:_files' \
    '--runtime-flag[add global flags for the OCI runtime]:flag' \
    '--sbom[SBOM scanner image]:image' \
    '--sbom-image-output[path for SBOM in image]:path' \
    '--sbom-image-purl-output[path for SBOM purl in image]:path' \
    '--sbom-merge-strategy[SBOM merge strategy]:strategy' \
    '--sbom-output[path for SBOM output]:file:_files' \
    '--sbom-purl-output[path for SBOM purl output]:file:_files' \
    '--sbom-scanner-command[SBOM scanner command]:command' \
    '--sbom-scanner-image[SBOM scanner image]:image' \
    '--secret[expose a secret file]:id=src' \
    '--security-opt[security options]:option' \
    '--shm-size[size of /dev/shm]:size' \
    '--sign-by[GPG key to sign the image]:key' \
    '--skip-unused-stages[skip stages not used in final image]' \
    '--squash[squash new image layers into a single layer]' \
    '--squash-all[squash all image layers into a single layer]' \
    '--ssh[SSH agent socket or keys]:ssh' \
    '--stdin[pass stdin to the build]' \
    '(-t --tag)'{-t,--tag}'[tag the image]:tag' \
    '--target[set the target build stage]:stage' \
    '--timestamp[set created timestamp]:timestamp' \
    '--tls-verify[require HTTPS and verify certificates]' \
    '--ulimit[ulimit options]:ulimit' \
    '--unsetenv[unset environment variables]:var' \
    '--unsetlabel[unset image labels]:label' \
    '--userns[set user namespace mode]:mode' \
    '--userns-gid-map[GID map for user namespace]:map' \
    '--userns-uid-map[UID map for user namespace]:map' \
    '--uts[UTS namespace]:ns' \
    '--variant[override variant of the image]:variant' \
    '(-v --volume)'{-v,--volume}'[bind mount a volume]:volume:_directories' \
    '1:context:_directories' && ret=0
}

_buildah_commit() {
  _arguments -s -S \
    '--authfile[path of the authentication file]:file:_files' \
    '--cert-dir[directory of TLS certificates]:dir:_directories' \
    '--creds[credentials for the registry]:username\:password' \
    '--disable-compression[disable compression of layers]' \
    '--encryption-key[encryption key]:key' \
    '(-f --format)'{-f,--format}'[image manifest and metadata format]:format:(oci docker)' \
    '--identity-label[add default identity label]' \
    '--iidfile[write the image ID to the file]:file:_files' \
    '--manifest[add the image to a manifest list]:manifest' \
    '--omit-history[do not include cmd history in built image]' \
    '(-q --quiet)'{-q,--quiet}'[suppress output]' \
    '--referenceTime[set creation timestamp]:time' \
    '--rm[remove the container after committing]' \
    '--sign-by[GPG key to sign the image]:key' \
    '--squash[squash newly built layers into a single layer]' \
    '--timestamp[set created timestamp]:timestamp' \
    '--tls-verify[require HTTPS and verify certificates]' \
    '1:container:' '2:image:' && ret=0
}

_buildah_run() {
  _arguments -s -S \
    '--add-history[add an entry to the history]' \
    '--cap-add[add Linux capability]:capability' \
    '--cap-drop[drop Linux capability]:capability' \
    '--cgroup-manager[cgroup manager]:manager:(cgroupfs systemd)' \
    '--cgroupns[cgroup namespace]:mode:(host private)' \
    '--hostname[set the hostname]:hostname' \
    '--isolation[process isolation]:type:(oci rootless chroot)' \
    '--ipc[IPC namespace]:ns' \
    '--mount[attach a filesystem mount]:mount' \
    '--network[set the network mode]:mode:(host none bridge private)' \
    '--no-hostname[do not create /etc/hostname]' \
    '--no-hosts[do not create /etc/hosts]' \
    '--no-pivot[do not use pivot root]' \
    '--pid[PID namespace]:ns' \
    '--runtime[OCI runtime]:runtime:_files' \
    '--runtime-flag[add global flags for the OCI runtime]:flag' \
    '--terminal[allocate a pseudo-TTY]' \
    '--user[set the user]:user' \
    '--uts[UTS namespace]:ns' \
    '--volume[bind mount a volume]:volume:_directories' \
    '1:container:' '*:command:' && ret=0
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--log-level[log level]:level:(trace debug info warn error fatal panic)' \
  '--registries-conf[path to registries.conf]:file:_files' \
  '--registries-conf-dir[path to registries.conf.d directory]:dir:_directories' \
  '--root[storage root dir]:dir:_directories' \
  '--runroot[storage state dir]:dir:_directories' \
  '--short-name-alias-conf[path to short name alias conf]:file:_files' \
  '--storage-driver[storage driver]:driver:(overlay vfs)' \
  '--storage-opt[storage driver option]:option' \
  '--userns-gid-map[default GID map]:map' \
  '--userns-uid-map[default UID map]:map' \
  '--version[display version information]' \
  '1: :_buildah_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      bud|build)    _buildah_build ;;
      from)         _buildah_from ;;
      commit)       _buildah_commit ;;
      run)          _buildah_run ;;
      images)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[show all images]' \
          '--digests[show digests]' \
          '(-f --filter)'{-f,--filter}'[filter output]:filter' \
          '--format[Go template format]:format' \
          '--history[display history]' \
          '--json[output in JSON format]' \
          '(-n --noheading)'{-n,--noheading}'[do not print column headings]' \
          '--no-trunc[do not truncate output]' \
          '(-q --quiet)'{-q,--quiet}'[only display image IDs]' && ret=0
        ;;
      containers)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[show all containers]' \
          '(-f --filter)'{-f,--filter}'[filter output]:filter' \
          '--format[Go template format]:format' \
          '--json[output in JSON format]' \
          '(-n --noheading)'{-n,--noheading}'[do not print column headings]' \
          '--no-trunc[do not truncate output]' \
          '(-q --quiet)'{-q,--quiet}'[only display container IDs]' && ret=0
        ;;
      rm)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[remove all containers]' \
          '*:container:' && ret=0
        ;;
      rmi)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[remove all images]' \
          '(-f --force)'{-f,--force}'[force removal]' \
          '--prune[prune dangling images]' \
          '*:image:' && ret=0
        ;;
      pull)
        _arguments -s -S \
          '--all-tags[pull all tags]' \
          '--arch[set the architecture]:arch' \
          '--authfile[authentication file]:file:_files' \
          '--cert-dir[certificates directory]:dir:_directories' \
          '--creds[credentials]:username\:password' \
          '--decryption-key[decryption key]:key:_files' \
          '--os[set the OS]:os' \
          '--platform[set the platform]:platform' \
          '--policy[pull policy]:policy:(always missing never ifnewer)' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '--retry[number of retries]:num' \
          '--retry-delay[delay between retries]:duration' \
          '--tls-verify[require HTTPS and verify certificates]' \
          '--variant[set the variant]:variant' \
          '1:image:' && ret=0
        ;;
      push)
        _arguments -s -S \
          '--all[push all tagged images]' \
          '--authfile[authentication file]:file:_files' \
          '--cert-dir[certificates directory]:dir:_directories' \
          '--compression-format[compression format]:format:(gzip zstd)' \
          '--compression-level[compression level]:level' \
          '--creds[credentials]:username\:password' \
          '--digestfile[write digest to file]:file:_files' \
          '--disable-compression[disable compression]' \
          '--encryption-key[encryption key]:key' \
          '(-f --format)'{-f,--format}'[manifest type]:format:(oci v2s1 v2s2 docker)' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '--retry[number of retries]:num' \
          '--retry-delay[delay between retries]:duration' \
          '--rm[remove image after push]' \
          '--sign-by[GPG key to sign]:key' \
          '--tls-verify[require HTTPS and verify certificates]' \
          '1:image:' '2::destination:' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'[Go template format]:format' \
          '--type[type of object to inspect]:type:(container image)' \
          '1:object:' && ret=0
        ;;
      config)
        _arguments -s -S \
          '--add-history[add entry to history]' \
          '--annotation[set annotations]:key=value' \
          '--arch[set architecture]:arch' \
          '--author[set author]:author' \
          '--cmd[set default command]:cmd' \
          '--comment[set comment]:comment' \
          '--created-by[set created-by]:creator' \
          '--domainname[set domain name]:domain' \
          '--entrypoint[set entrypoint]:entrypoint' \
          '(-e --env)'{-e,--env}'[set environment variables]:key=value' \
          '--healthcheck[set healthcheck]:command' \
          '--healthcheck-interval[healthcheck interval]:interval' \
          '--healthcheck-retries[healthcheck retries]:num' \
          '--healthcheck-start-period[healthcheck start period]:period' \
          '--healthcheck-timeout[healthcheck timeout]:timeout' \
          '--history-comment[set history comment]:comment' \
          '--hostname[set hostname]:hostname' \
          '(-l --label)'{-l,--label}'[set labels]:key=value' \
          '--onbuild[set ONBUILD instructions]:instruction' \
          '--os[set OS]:os' \
          '(-p --port)'{-p,--port}'[set exposed ports]:port' \
          '--shell[set default shell]:shell' \
          '--stop-signal[set stop signal]:signal' \
          '(-u --user)'{-u,--user}'[set user]:user' \
          '(-v --volume)'{-v,--volume}'[set volumes]:volume' \
          '--workingdir[set working directory]:dir' \
          '1:container:' && ret=0
        ;;
      add|copy)
        _arguments -s -S \
          '--add-history[add entry to history]' \
          '--chmod[set permissions]:mode' \
          '--chown[set ownership]:user\:group' \
          '--contextdir[context directory]:dir:_directories' \
          '--from[source container or image]:source' \
          '--ignorefile[ignore file]:file:_files' \
          '--quiet[suppress output]' \
          '1:container:' '*:source:_files' && ret=0
        ;;
      mount)
        _arguments '1:container:' && ret=0
        ;;
      umount|unmount)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[unmount all containers]' \
          '*:container:' && ret=0
        ;;
      rename)
        _arguments '1:container:' '2:new name:' && ret=0
        ;;
      tag)
        _arguments '1:image:' '*:new names:' && ret=0
        ;;
      manifest)
        local -a manifest_commands=(
          'add:add images to a manifest list'
          'annotate:add or update information about an entry'
          'create:create a manifest list'
          'exists:check if a manifest list exists'
          'inspect:display a manifest list'
          'push:push a manifest list to a registry'
          'rm:remove manifest lists'
          'remove:remove an entry from a manifest list'
        )
        _describe -t manifest-commands 'manifest command' manifest_commands
        ;;
      login)
        _arguments -s -S \
          '--authfile[authentication file]:file:_files' \
          '--cert-dir[certificates directory]:dir:_directories' \
          '--get-login[print current login user]' \
          '(-p --password)'{-p,--password}'[password]:password' \
          '--password-stdin[read password from stdin]' \
          '--tls-verify[require HTTPS and verify certificates]' \
          '(-u --username)'{-u,--username}'[username]:username' \
          '1:registry:' && ret=0
        ;;
      logout)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[remove all authentications]' \
          '--authfile[authentication file]:file:_files' \
          '1:registry:' && ret=0
        ;;
      unshare)
        _arguments '*:command:' && ret=0
        ;;
    esac
    ;;
esac

return ret
