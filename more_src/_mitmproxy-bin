#compdef mitmproxy
# _mitmproxy-bin — mitmproxy interactive HTTPS proxy TUI (Aldo Cortesi et al, Python); intercept + edit HTTP/2/QUIC traffic
# upstream: https://github.com/mitmproxy/mitmproxy

_mitmproxy-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(--version)--version[show version]' \
        '--mode+[proxy mode]:mode:(regular transparent socks5 reverse upstream)' \
        '--no-anticache[disable anticache]' \
        '--anticomp[disable compression]' \
        '--listen-host+[listen host]:host:_hosts' \
        '-p+[listen port]:port:' \
        '--listen-port+[listen port]:port:' \
        '--server-side-events[server side events]' \
        '--scripts+[load script]:file:_files' \
        '-s+[load script]:file:_files' \
        '--set+[option=value]:str:' \
        '--ssl-insecure[skip TLS verify]' \
        '--ssl-version-client+[TLS client]:str:' \
        '--ssl-version-server+[TLS server]:str:' \
        '--certs+[cert file]:file:_files' \
        '--client-certs+[client certs]:file:_files' \
        '--ciphers-client+[client ciphers]:str:' \
        '--ciphers-server+[server ciphers]:str:' \
        '-r+[read flows from file]:file:_files' \
        '--rfile+[read flows]:file:_files' \
        '-w+[write flows to file]:file:_files' \
        '--save-stream-file+[save stream file]:file:_files' \
        '--save-stream-filter+[save stream filter]:filter:' \
        '--stickycookie+[sticky cookie filter]:filter:' \
        '--stickyauth+[sticky auth filter]:filter:' \
        '-q[quiet]' \
        '-v[verbose]' \
        '--show-host[show host header in flow list]' \
        '--no-mouse[disable mouse]' \
        '--allow-hosts+[allow hosts regex]:regex:' \
        '--ignore-hosts+[ignore hosts regex]:regex:' \
        '--tcp-hosts+[tcp hosts regex]:regex:' \
        '--upstream-auth+[upstream auth]:str:' \
        '--upstream-trusted-ca+[upstream trusted ca]:file:_files' \
        '--proxyauth+[proxy auth]:str:' \
        '--add-upstream-certs-to-client-chain[add upstream certs to client chain]' \
        '--web-host+[web host]:host:_hosts' \
        '--web-port+[web port]:port:' \
        '*::script args:'
}

_mitmproxy-bin "$@"
