#compdef indigo-cano
# Documentation: https://lifescience.opensource.epam.com/indigo/utilities.html
# Indigo canonical SMILES generator

local ret=1

_arguments -s -S \
  '(-smiles -layered)-smiles[output canonical SMILES (default)]' \
  '(-smiles -layered)-layered[output canonical layered code]' \
  '-no-arom[do not aromatize molecules]' \
  '-no-cistrans[ignore cis-trans bonds information]' \
  '-no-tetrahedral[ignore tetrahedral stereocenters]' \
  '-id+[ID field in SDF file]:field:' \
  '*:molecule file:_files' && ret=0

return ret
