#compdef xxhsum xxh32sum xxh64sum xxh128sum xxh3sum
# _xxhsum — xxHash extremely fast non-crypto hash (C); xxhsum CLI computes XXH32/XXH64/XXH3/XXH128 sums of files
# upstream: https://github.com/Cyan4973/xxHash

_xxhsum() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-H+[hash family]:n:(0 1 2 3)' \
        '(-b --benchmark)'{-b,--benchmark}'[benchmark mode]' \
        '(-B --benchmark-size)'{-B,--benchmark-size}'+[bench size]:n:' \
        '-i+[bench iters]:n:' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-c --check)'{-c,--check}'[check sums]' \
        '--strict[strict check mode]' \
        '--status[no output on check, exit code only]' \
        '--warn[warn on improperly formatted lines]' \
        '--tag[BSD-style tag output]' \
        '(--binary)'{--binary,-b}'[binary mode]' \
        '(--text)'{--text,-t}'[text mode]' \
        '--quiet[quiet]' \
        '*:file:_files'
}

_xxhsum "$@"
