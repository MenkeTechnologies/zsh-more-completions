#compdef espgen-extra
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools espgen: generate esp file for resp from QM output

local ret=1

_arguments -s -S \
  '-i[input file name]:file:_files' \
  '-o[output file name]:file:_files' \
  '-f[input format]:format:(1 2 3)' \
  '-p[generate esp for pGM]:flag:(0 1)' \
  '-dq[print out dipole and quadrupole moments]:flag:(0 1)' \
  '-re[print out remark line]:flag:(0 1)' \
  '*:file:_files' && ret=0

return ret
