#compdef 3dANOVA2
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dANOVA2.html
# AFNI: two-factor analysis of variance for 3D datasets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-type[ANOVA model type (1=fixed 2=random 3=mixed)]:k:' \
  '-alevels[number of levels of factor A]:a:' \
  '-blevels[number of levels of factor B]:b:' \
  '*-dset[dataset for level i j]:i j filename:_files' \
  '-voxel[print results for given voxel]:num:' \
  '-diskspace[print required disk space]' \
  '-mask[mask dataset]:mset:_files' \
  '-ftr[F for treatment effect]:prefix:_files' \
  '-fa[F for factor A]:prefix:_files' \
  '-fb[F for factor B]:prefix:_files' \
  '-fab[F for A*B interaction]:prefix:_files' \
  '*-amean[mean of factor A level i]:i prefix:' \
  '*-bmean[mean of factor B level j]:j prefix:' \
  '*-xmean[mean of cell i j]:i j prefix:' \
  '*-adiff[difference between A levels]:i j prefix:' \
  '*-bdiff[difference between B levels]:i j prefix:' \
  '*-xdiff[difference between cells]:i j k l prefix:' \
  '*-acontr[contrast of factor A levels]:c1..ca prefix:' \
  '*-bcontr[contrast of factor B levels]:c1..cb prefix:' \
  '*-xcontr[contrast of cells]:c11..cab prefix:' \
  '-bucket[output bucket dataset]:prefix:_files' \
  '-old_method[use old computation method]' \
  '-OK[acknowledge old method]' \
  '-assume_sph[assume sphericity]' \
  '*:dataset:_files' && ret=0

return ret
