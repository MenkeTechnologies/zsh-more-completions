#compdef nuxi
# Documentation: https://nuxt.com/docs/api/commands
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nuxi - Nuxt CLI

local curcontext="$curcontext" state line ret=1

local -a nuxi_commands
nuxi_commands=(
  'init:initialize a new Nuxt project'
  'dev:run development server'
  'build:build for production'
  'generate:pre-render every route as static HTML'
  'preview:preview production build'
  'prepare:prepare the project for development'
  'analyze:analyze production bundle'
  'info:show project information'
  'module:manage Nuxt modules'
  'typecheck:run type checking'
  'cleanup:clean up generated files'
  'upgrade:upgrade Nuxt'
  'add:add a template to the project'
  'devtools:enable or disable Nuxt DevTools'
  'test:run tests'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cwd=[working directory]:directory:_directories' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'nuxi command' nuxi_commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      dev)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'=[port to listen on]:port:' \
          '(-h --host)'{-h,--host}'=[host to listen on]:host:' \
          '--https[enable HTTPS]' \
          '(-o --open)'{-o,--open}'[open browser on start]' \
          '--clipboard[copy URL to clipboard]' \
          '--clear[clear console on restart]' \
          '--no-fork[disable forked mode]' \
          '--tunnel[open tunnel using untun]' \
          '--qr[display QR code of public URL]' \
          '--public[listen to all network interfaces]' \
          '(-e --extends)'{-e,--extends}'=[extend from a Nuxt layer]:layer:' \
          '--envName=[environment for resolving config overrides]:env:' \
          '--dotenv=[path to .env file]:env file:_files' \
          '--logLevel=[log level]:level:(silent info verbose)' \
          '*:root directory:_directories' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--prerender[pre-render every route]' \
          '--preset=[deployment preset]:preset:' \
          '--dotenv=[path to .env file]:env file:_files' \
          '--logLevel=[log level]:level:(silent info verbose)' \
          '*:root directory:_directories' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '--preset=[deployment preset]:preset:' \
          '--dotenv=[path to .env file]:env file:_files' \
          '--logLevel=[log level]:level:(silent info verbose)' \
          '*:root directory:_directories' && ret=0
        ;;
      init)
        _arguments -s -S \
          '1:project name:' \
          '*:directory:_directories' && ret=0
        ;;
      add)
        _arguments -s -S \
          '1:template type:(component composable layout page plugin middleware api)' \
          '2:name:' && ret=0
        ;;
      module)
        _arguments -s -S \
          '1:action:(add)' \
          '2:module name:' && ret=0
        ;;
      *)
        _arguments -s -S \
          '*:root directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
