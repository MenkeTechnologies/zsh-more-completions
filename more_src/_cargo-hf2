#compdef cargo-hf2
# _cargo-hf2 — cargo subcommand to flash Microsoft HF2-bootloader devices (jacobrosenthal/hf2-rs)
# upstream: https://github.com/jacobrosenthal/hf2-rs
# Flags from cargo-hf2/src/main.rs (structopt).

_cargo-hf2() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '--bin=[binary target to build + flash]:bin:'
        '--example=[example target to build + flash]:example:'
        '(-p --package)'{-p+,--package=}'[package to build]:package:'
        '--release[build in release mode]'
        '--target=[Rust target triple]:triple:'
        '--manifest-path=[Cargo.toml path]:file:_files -g "*.toml"'
        '--no-default-features[do not build with default features]'
        '--all-features[build with all features enabled]'
        '*--features=[features to enable]:features:'
        '--pid=[USB product ID in hex]:pid:'
        '--vid=[USB vendor ID in hex]:vid:'
    )
    _arguments -s $args
}

_cargo-hf2 "$@"
