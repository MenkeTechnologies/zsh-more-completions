#compdef esl-selectn
# Documentation: https://man.archlinux.org/search?q=esl-selectn
# Reference accessed: 2026-05-16

# Easel esl-selectn: select random subset of N lines from input
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-s[random seed]:n:' \
  '-N[number of lines to select]:n:' \
  '*:input file:_files' && ret=0
return ret
