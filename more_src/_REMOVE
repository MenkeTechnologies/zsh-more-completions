#compdef REMOVE
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/utils/html/PkgUtils.html
# R CMD REMOVE: remove installed add-on R packages

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print short help message and exit]' \
  '(-v --version)'{-v,--version}'[print REMOVE version info and exit]' \
  '(-l --library)'{-l,--library=}'[remove packages from library tree LIB]:dir:_files -/' \
  '*:package:' && ret=0

return ret
