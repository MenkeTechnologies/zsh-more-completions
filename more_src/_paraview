#compdef paraview pvpython pvbatch pvserver

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--data=[load data file]:file:_files' \
  '--state=[load state file]:file:_files -g "*.pvsm"' \
  '--script=[run Python script]:script:_files -g "*.py"' \
  '--server-url=[connect to server]:url:' \
  '--connect-id=[connection ID]:id:' \
  '--test-directory=[test output directory]:dir:_files -/' \
  '--test-script=[test script]:script:_files -g "*.py"' \
  '--test-baseline=[test baseline directory]:dir:_files -/' \
  '--test-threshold=[test threshold]:threshold:' \
  '--exit[exit after loading]' \
  '--multi-clients[enable multi-client mode]' \
  '--multi-servers[enable multi-server mode]' \
  '--live=[enable Catalyst live]:port:' \
  '--disable-registry[disable registry]' \
  '--force-offscreen-rendering[force offscreen rendering]' \
  '--force-onscreen-rendering[force onscreen rendering]' \
  '--mesa-llvm[use Mesa LLVM]' \
  '--egl[use EGL for rendering]' \
  '--osmesa[use OSMesa for rendering]' \
  '-dr[disable registry]' \
  '*:file:_files' && ret=0

return ret
