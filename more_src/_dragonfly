#compdef dragonfly

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--port=[listen port]:port:' \
  '--bind=[bind address]:address:_hosts' \
  '--requirepass=[require password]:password:' \
  '--maxmemory=[max memory limit]:bytes:' \
  '--dbfilename=[snapshot filename]:filename:' \
  '--dir=[working directory]:directory:_directories' \
  '--proactor_threads=[number of proactor threads]:threads:' \
  '--cache_mode[enable cache mode]' \
  '--hz=[server frequency in hz]:hz:' \
  '--tcp_backlog=[TCP listen backlog]:size:' \
  '--timeout=[client idle timeout in seconds]:seconds:' \
  '--loglevel=[log level]:level:(warning notice verbose debug)' \
  '--logfile=[log file path]:file:_files' \
  '--databases=[number of databases]:count:' \
  '--save_schedule=[RDB save schedule]:schedule:' \
  '--snapshot_cron=[cron expression for snapshots]:cron:' \
  '--memcached_port=[memcached-compatible port]:port:' \
  '--admin_port=[admin port]:port:' \
  '--admin_nopass[disable password for admin port]' \
  '--primary_port_http_enabled[enable HTTP on primary port]' \
  '--keys_output_limit=[limit for KEYS output]:limit:' \
  '--list_max_listpack_size=[max listpack size for lists]:size:' \
  '--list_max_ziplist_size=[max ziplist size for lists]:size:' \
  '--maxclients=[max number of clients]:count:' \
  '--alsologtostderr[also log to stderr]' \
  '--logtostderr[log to stderr instead of files]' \
  '--flagfile=[load flags from file]:file:_files' \
  && ret=0

return ret
