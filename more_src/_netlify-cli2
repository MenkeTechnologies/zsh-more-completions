#compdef netlify-cli2 ntl2
# _netlify-cli2 — Netlify netlify-cli2 CLI command-line frontend wrapping the Netlify CLI command-line interface for the Netlify edge platform delivering modern web applications open-source written in JavaScript Node deploy continuous deployment open dev pull init link unlink login logout watch logout addons env build serve switch sites recipes status open functions sites secrets serverless blob-store edge-functions completion api recipe lm dev help info plugins (Netlify team Matt Biilmann Chris Bach Mathias Biilmann Christensen, JavaScript/TypeScript); commander
# upstream: https://www.netlify.com/

_netlify-cli2() {
    local -a sub=(
        'addons:add-on operations'
        'api:make a Netlify API call'
        'blobs:blob storage operations'
        'build:build a project locally'
        'completion:generate shell completion'
        'deploy:deploy site'
        'dev:run local dev server'
        'env:env operations'
        'functions:Functions operations'
        'help:show help'
        'init:create a new Netlify project'
        'link:link to a Netlify project'
        'lm:Large Media operations'
        'login:authenticate'
        'logout:revoke session'
        'logs:show logs'
        'open:open Netlify dashboard'
        'plugins:plugins operations'
        'recipes:recipe operations'
        'redirects:redirect operations'
        'serve:serve a build locally'
        'sites:site operations'
        'status:show login status'
        'switch:switch account'
        'unlink:unlink current project'
        'version:show version'
        'watch:watch for deploys'
        'secrets:secret operations'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--auth=+[token]:str:' \
        '-a+[auth]:str:' \
        '--filter=+[expr]:str:' \
        '--http-proxy=+[url]:str:' \
        '--http-proxy-certificate-filename=+[file]:file:_files' \
        '--json[JSON output]' \
        '--telemetry-disable[disable telemetry]' \
        '--telemetry-enable[enable telemetry]' \
        '--account=+[id]:str:' \
        '-s+[site id]:str:' \
        '--site=+[id]:str:' \
        '--context=+[name]:str:' \
        '--build[build before deploy]' \
        '--dir=+[dir]:dir:_files -/' \
        '-D+[dir]:dir:_files -/' \
        '--functions=+[dir]:dir:_files -/' \
        '-f+[functions]:dir:_files -/' \
        '--prod[production]' \
        '-p[production]' \
        '--prod-if-unlocked[prod if unlocked]' \
        '--branch=+[name]:str:' \
        '--alias=+[name]:str:' \
        '-m+[message]:str:' \
        '--message=+[text]:str:' \
        '--open[open browser]' \
        '-o[open browser]' \
        '--skip-functions-cache[skip functions cache]' \
        '--no-build[no build]' \
        '--timeout=+[sec]:n:' \
        '--config=+[file]:file:_files -g "netlify.toml *.toml"' \
        '-c+[config]:file:_files -g "netlify.toml *.toml"' \
        '--port=+[port]:n:' \
        '-P+[port]:n:' \
        '--offline[offline]' \
        '--live[live mode]' \
        '--country=+[code]:str:' \
        '--locale=+[loc]:str:' \
        '--targetPort=+[port]:n:' \
        '--framework=+[name]:str:' \
        '--target=+[t]:t:(staging production)' \
        '--token=+[token]:str:' \
        '--with-ci[in CI]' \
        '--non-interactive[non interactive]' \
        '--manual[manual setup]' \
        '--gitRemoteName=+[name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'netlify subcommand' sub ;;
        args)
            case $words[1] in
                sites|env|addons|functions|blobs|secrets|redirects) _arguments '1:op:(list create delete update unlink list:env import:env create:list invoke build serve)' '*:arg:' ;;
                api) _arguments '*:method:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_netlify-cli2 "$@"
