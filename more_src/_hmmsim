#compdef hmmsim
# Documentation: https://github.com/EddyRivasLab/hmmer/blob/master/src/hmmsim.c
# Reference accessed: 2026-05-27
# Verified: upstream src/hmmsim.c ESL_OPTIONS table (HMMER 3.x)

# HMMER hmmsim: collect profile HMM score distributions on random sequences
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help on version and usage]' \
  '-a[obtain alignment length statistics too]' \
  '-v[verbose: print scores]' \
  '-L[length of random target sequences]:length:' \
  '-N[number of random target sequences]:count:' \
  '--mpi[run as an MPI parallel program]' \
  '-o[direct output to file, not stdout]:file:_files' \
  '--afile[output alignment lengths to file]:file:_files' \
  '--efile[output E vs. E plots to file in xy format]:file:_files' \
  '--ffile[output filter fraction data]:file:_files' \
  '--pfile[output P(S>x) plots to file in xy format]:file:_files' \
  '--xfile[output bitscores as binary double vector to file]:file:_files' \
  '--fs[multihit local alignment (default)]' \
  '--sw[unihit local alignment]' \
  '--ls[multihit glocal alignment]' \
  '--s[unihit glocal alignment]' \
  '--vit[score sequences with Viterbi algorithm (default)]' \
  '--fwd[score sequences with Forward algorithm]' \
  '--hyb[score sequences with Hybrid algorithm]' \
  '--msv[score sequences with MSV algorithm]' \
  '--fast[use optimized versions of scoring algorithms]' \
  '--tmin[lower bound tail mass for forward/island]:mass:' \
  '--tmax[upper bound tail mass for forward/island]:mass:' \
  '--tpoints[number of tail probabilities to try]:n:' \
  '--tlinear[use linear not log spacing of tail probabilities]' \
  '--EmL[length of sequences for MSV Gumbel mu fit]:length:' \
  '--EmN[number of sequences for MSV Gumbel mu fit]:count:' \
  '--EvL[length of sequences for Viterbi Gumbel mu fit]:length:' \
  '--EvN[number of sequences for Viterbi Gumbel mu fit]:count:' \
  '--EfL[length of sequences for Forward exp tail tau fit]:length:' \
  '--EfN[number of sequences for Forward exp tail tau fit]:count:' \
  '--Eft[tail mass for Forward exponential tail tau fit]:mass:' \
  '--stall[arrest after start for debugging MPI under gdb]' \
  '--seed[set random number seed]:seed:' \
  '--bgflat[set uniform background frequencies]' \
  '--bgcomp[set background frequencies to model average composition]' \
  '--x-no-lengthmodel[turn the H3 length model off]' \
  '--nu[set nu parameter (number of expected HSPs) for GMSV]:nu:' \
  '--pthresh[P-value threshold for --ffile]:pvalue:' \
  '*:HMM file:_files' && ret=0
return ret
