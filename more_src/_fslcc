#compdef fslcc
# Documentation: https://git.fmrib.ox.ac.uk/fsl/avwutils/-/blob/master/fslcc.cc
# fslcc - cross-correlate every volume in one 4D dataset with every volume in another

local ret=1

_arguments -s -S \
  '-m[mask file name]:mask file:_files' \
  '--noabs[do not return absolute values (keep sign)]' \
  '--nodemean[do not demean the input files]' \
  '-t[correlation threshold (default 0.1)]:threshold:' \
  '-p[number of decimal places to display (default 2)]:precision:' \
  '1:first input:_files' \
  '2:second input:_files' && ret=0

return ret
