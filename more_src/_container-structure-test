#compdef container-structure-test

# Zsh completion for container-structure-test - Test container structure

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'test:Run structure tests'
      'version:Print version'
    )
    _describe -t commands 'container-structure-test command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      test)
        _arguments -s -S \
          '--image=[container image to test]:image' \
          '*--config=[test config file]:config file:_files -g "*.{yaml,yml,json}"' \
          '--driver=[driver to use]:driver:(docker tar host)' \
          '--force[force pull image]' \
          '--no-color[disable colorized output]' \
          '--output=[output format]:format:(json junit text)' \
          '--pull[always pull image]' \
          '--save[save container state]' \
          '--test-report=[path to test report file]:report file:_files' \
          '--quiet[suppress output]' \
          '--verbose[enable verbose output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
