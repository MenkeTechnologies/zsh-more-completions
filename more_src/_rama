#compdef rama gmx-rama
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-rama.html
# gmx rama: compute Ramachandran plots

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-o[xvgr/xmgr file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' && ret=0

return ret
