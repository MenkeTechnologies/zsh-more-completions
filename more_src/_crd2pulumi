#compdef crd2pulumi
# Documentation: https://github.com/pulumi/crd2pulumi
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --force)'{-f,--force}'[overwrite generated files]' \
  '(-d --dotnet)'{-d,--dotnet}'[generate .NET]' \
  '(-g --go)'{-g,--go}'[generate Go]' \
  '(-j --java)'{-j,--java}'[generate Java]' \
  '(-n --nodejs)'{-n,--nodejs}'[generate NodeJS]' \
  '(-p --python)'{-p,--python}'[generate Python]' \
  '--dotnetPath=[.NET output directory]:dir:_files -/' \
  '--dotnetName=[.NET package name]:name:' \
  '--dotnetNamespace=[.NET namespace]:ns:' \
  '--goPath=[Go output directory]:dir:_files -/' \
  '--goName=[Go package name]:name:' \
  '--javaPath=[Java output directory]:dir:_files -/' \
  '--javaName=[Java package name]:name:' \
  '--javaBasePackage=[Java base package]:pkg:' \
  '--nodejsPath=[NodeJS output directory]:dir:_files -/' \
  '--nodejsName=[NodeJS package name]:name:' \
  '--nodejsNamespace=[NodeJS namespace]:ns:' \
  '--pythonPath=[Python output directory]:dir:_files -/' \
  '--pythonName=[Python package name]:name:' \
  '--pythonPackagePrefix=[Python package prefix]:prefix:' \
  '*:CRD YAML or directory:_files'
