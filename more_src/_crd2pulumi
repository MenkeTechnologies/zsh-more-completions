#compdef crd2pulumi
# Documentation: https://man.archlinux.org/search?q=crd2pulumi
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --force)'{-f,--force}'[overwrite generated files]' \
  '--lang=[language target]:lang:(dotnet go nodejs python typescript)' \
  '--package-name=[generated package name]:name:' \
  '--output-dir=[output directory]:dir:_files -/' \
  '1:CRD YAML or directory:_files'
