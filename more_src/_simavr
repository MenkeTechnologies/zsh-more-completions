#compdef simavr
# Documentation: https://github.com/buserror/simavr
# simavr AVR simulator runner (run_avr)

local ret=1

_arguments -s -S \
  '(-h --help -\?)'{-h,--help,-\?}'[display usage message and exit]' \
  '--list-cores[list all supported AVR cores and exit]' \
  '*-v[raise verbosity level (repeatable)]' \
  '(-f --freq)'{-f,--freq}'[set frequency in Hz for an .hex firmware]:freq' \
  '(-m --mcu)'{-m,--mcu}'[set MCU type for an .hex firmware]:device' \
  '(-g --gdb)'{-g,--gdb}'[listen for gdb connection on port (default 1234)]::port' \
  '(-t --trace)'{-t,--trace}'[run full scale decoder trace]' \
  '-ti[add traces for IRQ vector]:vector' \
  '(-i --input)'{-i,--input}'[VCD file to use as input signals]:file:_files' \
  '(-o --output)'{-o,--output}'[VCD file to save traced signals]:file:_files' \
  '(-at --add-trace)'{-at,--add-trace}'[add signal to VCD output: name=kind@addr/mask]:trace' \
  '-ff[load next .hex file as flash]:file:_files' \
  '-ee[load next .hex file as eeprom]:file:_files' \
  '*:firmware:_files' && ret=0

return ret
