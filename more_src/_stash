# -----------------------------------------------------------------------------
#
# THE stash CLI
#
# stash is a single-command HTTP server launcher
# built on spf13/pflag.  Invocation:
#   stash [flags]
#
# Most configuration happens via the YAML config
# file read at startup (default location ~/.stash/
# config.yml on first run; created with defaults if
# not present).  Command-line flags only override
# the most-frequently-changed settings.
#
# Flags:
#       --host <IP>                   listen IP
#                                     (default
#                                     0.0.0.0 — all
#                                     interfaces)
#       --port <PORT>                 listen port
#                                     (default 9999)
#   -c, --config <PATH>               config file to
#                                     use (default
#                                     ~/.stash/
#                                     config.yml)
#       --nobrowser                   don't open a
#                                     browser window
#                                     after launch
#   -u, --ui-location <PATH>          path to the
#                                     webui (default
#                                     embedded assets)
#       --cpuprofile <FILE>           pprof CPU
#                                     profile file
#       --help                        show help
#
# Configuration file (config.yml) — major sections
# (consult docs.stashapp.cc for full schema):
#   host                              listen IP
#   port                              listen port
#   stash                             list of media
#                                     directories
#   generated                         output directory
#                                     for thumbnails/
#                                     previews
#   cache                             cache directory
#   database                          SQLite database
#                                     path
#   plugins_path                      plugin
#                                     directory
#   scrapers_path                     scraper
#                                     configuration
#                                     directory
#   ffmpeg_path                       ffmpeg binary
#                                     path
#   ffprobe_path                      ffprobe binary
#                                     path
#   theme                             UI theme (light/
#                                     dark/auto)
#   language                          UI language
#
# Common invocations:
#   # Run with default config + open browser
#   stash
#
#   # Run as headless server (no browser open)
#   stash --nobrowser
#
#   # Listen on specific IP + port
#   stash --host 127.0.0.1 --port 8080
#
#   # Use custom config file
#   stash -c /etc/stash/config.yml
#   stash --config ~/myconfig.yml
#
#   # Specify custom UI assets path (for development)
#   stash -u ./ui/v2.5/dist
#   stash --ui-location ./ui/v2.5/dist
#
#   # Run with CPU profiling
#   stash --cpuprofile cpu.prof
#
#   # systemd service launcher
#   ExecStart=/usr/bin/stash --nobrowser
#
#   # Docker container CMD
#   CMD ["stash", "--nobrowser", "-c", "/config/config.yml"]
#
# OPTIONS (sourced directly from
# https://github.com/stashapp/stash/blob/develop/internal/manager/config/init.go):
#
#   --host <IP>                       listen IP (default 0.0.0.0)
#   --port <N>                        port (default 9999)
#   -c, --config <PATH>               config file
#   --nobrowser                       don't open browser
#   -u, --ui-location <PATH>          webui path
#   --cpuprofile <FILE>               pprof CPU profile output
#   --help                            show help
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)--help[show help]' \
    '--host=[listen IP address (default 0.0.0.0)]:ip: ' \
    '--port=[listen port (default 9999)]:port: ' \
    '(-c --config)'{-c,--config}'=[config file path]:config:_files -g "*.(yml|yaml)"' \
    '--nobrowser[do not open browser window after launch]' \
    '(-u --ui-location)'{-u,--ui-location}'=[path to webui assets]:dir:_directories' \
    '--cpuprofile=[CPU profile output file]:profile:_files' \
    && ret=0

return ret
