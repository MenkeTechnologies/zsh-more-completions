#compdef avfctl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'play:play a DV tape'
  'record:record to DV tape'
  'capture:capture from DV device'
  'status:show device status'
)

_arguments -s -S -C \
  '--help[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'avfctl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      capture)
        _arguments -s -S \
          '-o[output file]:file:_files' \
          '--output[output file]:file:_files' \
          '--device[device index]:index:' \
          '--timeout[timeout]:seconds:' \
          '--help[show help]' && ret=0
        ;;
      play|record)
        _arguments -s -S \
          '--device[device index]:index:' \
          '1:file:_files -g "*.dv(|.mov)"' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
