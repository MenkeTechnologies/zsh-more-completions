#compdef pxctl
# Documentation: https://docs.portworx.com/portworx-enterprise/reference/cli/cluster/
# pxctl — Portworx Enterprise storage cluster management CLI

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--ca=[path to CA certificate file]:ca file:_files' \
  '--cert=[path to client certificate file]:cert file:_files' \
  '--color[enable colorized output]' \
  '--config=[path to config file]:config file:_files' \
  '--context=[name of the context to use]:context' \
  '--json[output in JSON format]' \
  '--key=[path to client key file]:key file:_files' \
  '--output-type=[output type]:type:(json yaml wide)' \
  '--raw[raw output]' \
  '--ssl[use SSL for the API endpoint]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'pxctl command' \
      'cluster[cluster operations]' \
      'volume[create and manage volumes]' \
      'service[service mode utilities]' \
      'credentials[manage cloud credentials]' \
      'context[manage connection contexts]' \
      'status[display cluster and node status]' \
      'cloudsnap[cloud snapshot operations]' \
      'cloudmigrate[cloud migration operations]' \
      'host[host-level operations]' \
      'alerts[manage alerts]' \
      'auth[authentication configuration]' \
      'license[license operations]' \
      'role[manage RBAC roles]' \
      'secrets[manage secrets]' \
      'upgrade[upgrade operations]' && ret=0
    ;;
esac

return ret
