#compdef conversion-gen
# _conversion-gen — Kubernetes API conversion-function generator (kubernetes/code-generator)
# upstream: https://github.com/kubernetes/code-generator
# Flags from cmd/conversion-gen/args/args.go on tip.

_conversion-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--output-file=[generated conversion file basename]:file:_files' \
        '*--base-peer-dirs=[base peer directories (comma-sep)]:list:' \
        '*--extra-peer-dirs=[extra peer directories (comma-sep)]:list:' \
        '--skip-unsafe=[skip unsafe.Pointer conversions]:bool:(true false)' \
        '--go-header-file=[Go header file prepended to generated files]:file:_files' \
        '--build-tag=[Go build tag identifying generated files]:tag:' \
        '*--lint-rules=[gengo lint rules to enable (comma-sep)]:rules:' \
        '-v[klog verbosity level]:n:' \
        '*:input-package:'
}

_conversion-gen "$@"
