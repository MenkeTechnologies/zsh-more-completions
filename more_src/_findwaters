#compdef findwaters coot-findwaters
# Documentation: https://www2.mrc-lmb.cam.ac.uk/personal/pemsley/coot/web/docs/coot.html
# Coot findwaters - add water molecules from a map

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--pdbin[input protein coordinates file]:pdb file:_files' \
  '--hklin[input MTZ reflection data file]:mtz file:_files' \
  '--mapin[input CCP4-format map (instead of --hklin --f --phi)]:map file:_files' \
  '--f[structure factor column label]:F label:' \
  '--phi[phase column label]:PHI label:' \
  '--pdbout[output coordinates file for waters]:pdb file:_files' \
  '--cifout[output mmCIF file for waters]:cif file:_files' \
  '--sigma[contour sigma level (default 2.0)]:sigma-level:' \
  '--min-dist[minimum distance to protein]:min-dist:' \
  '--max-dist[maximum distance to protein]:max-dist:' \
  '--flood[fill everything with waters, not just peaks]' \
  '--flood-atom-radius[contact distance for flood (default 1.4)]:radius:' \
  '--chop[remove waters below given sigma-level]' \
  '*:file:_files' && ret=0

return ret
