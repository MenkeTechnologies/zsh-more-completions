#compdef sufilter
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/sufilter.c
# SUFILTER - applies a zero-phase, sine-squared tapered filter

local ret=1

_arguments -s -S \
  'f=[array of filter frequencies (Hz)]:f:' \
  'amps=[array of filter amplitudes]:amps:' \
  'dt=[time sampling interval (sec)]:dt:' \
  'verbose=[=1 for advisory messages]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
