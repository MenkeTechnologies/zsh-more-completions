#compdef mstflint flint

# mstflint: Mellanox firmware burn/query tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'b:burn firmware'
  'burn:burn firmware'
  'q:query firmware info'
  'query:query firmware info'
  'qrom:query expansion ROM'
  'verify:verify firmware'
  'swreset:software reset'
  'rrom:read ROM from device'
  'brom:burn ROM to device'
  'drom:delete ROM'
  'rw:read word'
  'ww:write word'
  'wbne:write block (no erase)'
  'wb:write block'
  'rb:read block'
  'ri:read image'
  'dc:dump configuration'
  'dh:dump hex'
  'cfi:run command-line script'
  'set_key:set secure boot key'
  'hw_access:hw access control'
  'sign:sign firmware image'
  'extract_hashes_file:extract hashes'
  'qg:query GUIDs'
  'sg:set GUIDs'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-d[device specification]:dev:' \
  '--device=[device specification]:dev:' \
  '-i[firmware image]:file:_files -g "*.(bin|mfa|mfa2)"' \
  '--image=[firmware image]:file:_files -g "*.(bin|mfa|mfa2)"' \
  '-y[answer yes]' \
  '--yes[answer yes]' \
  '-no[answer no]' \
  '--no[answer no]' \
  '-no_image_signature[skip image signature check]' \
  '--blank_guids[no GUIDs in image]' \
  '--guid=[set GUID]:guid:' \
  '--guids=[set GUIDs]:list:' \
  '--mac=[set MAC]:mac:' \
  '--macs=[set MACs]:list:' \
  '--use_image_ps[use image PSID]' \
  '--ignore_dev_data[skip device data]' \
  '--clear_semaphore[clear flash semaphore]' \
  '--allow_psid_change[allow PSID change]' \
  '--low_cpu[low cpu mode]' \
  '--silent[silent]' \
  '-vv[very verbose]' \
  '--verbosity=[verbosity level]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mstflint command' commands && ret=0 ;;
esac
return ret
