#compdef gtk4-icon-editor
# Documentation: https://man.archlinux.org/search?q=gtk4-icon-editor
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-gapplication[show GApplication options]' \
  '*:icon file:_files -g "*.(svg|png)"' && ret=0

return ret
