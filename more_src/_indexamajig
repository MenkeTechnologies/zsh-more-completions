  '*--copy-hdf5-field=[copy hdf5 field to stream]:field:' \
  '--no-peaks-in-stream[do not record peak search]' \
  '--no-refls-in-stream[do not record reflections]' \
  '--serial-offset=[start serial numbers at n]:n:' \
  '--harvest-file=[write JSON parameters to file]:file:_files' \
