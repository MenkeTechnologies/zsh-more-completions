#compdef indexamajig
# Documentation: https://www.desy.de/~twhite/crystfel/manual-indexamajig.html
# Index and integrate serial crystallography patterns (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-i --input)'{-i+,--input=}'[read image list from file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[write data stream to file]:file:_files' \
  '(-g --geometry)'{-g+,--geometry=}'[read detector geometry from file]:file:_files' \
  '(-x --prefix)'{-x+,--prefix=}'[prefix filenames with path]:prefix:' \
  '-j+[run n analyses in parallel]:n:' \
  '(-p --pdb)'{-p+,--pdb=}'[unit cell file]:file:_files' \
  '--zmq-input=[receive data over ZeroMQ]:address:' \
  '*--zmq-subscribe=[subscribe to ZeroMQ message type]:tag:' \
  '--zmq-request=[request data over ZeroMQ REQ]:msg:' \
  '--asapo-endpoint=[ASAP::O endpoint]:endpoint:' \
  '--asapo-token=[ASAP::O auth token]:token:' \
  '--asapo-beamtime=[ASAP::O beamtime id]:beamtime:' \
  '--asapo-source=[ASAP::O data source]:source:' \
  '--asapo-group=[ASAP::O consumer group]:group:' \
  '--asapo-stream=[ASAP::O stream name]:stream:' \
  '--asapo-wait-for-stream[wait for ASAP::O stream]' \
  '--data-format=[input data format]:format:(msgpack hdf5 seedee)' \
  '--basename[remove directory parts from filenames]' \
  '--no-check-prefix[do not correct prefix]' \
  '--wait-for-file=[wait n seconds for each file]:n:' \
  '--temp-dir=[temporary folder path]:path:_files -/' \
  '--no-image-data[load only metadata]' \
  '--profile[display timing data]' \
  '--peaks=[peak detection method]:method:(hdf5 cxi zaef peakfinder8 peakfinder9)' \
  '--peak-radius=[three-ring peak search radii]:inner,middle,outer:' \
  '--min-peaks=[min peaks to attempt indexing]:n:' \
  '--median-filter=[apply median filter, box radius]:n:' \
  '--filter-noise[apply noise filter]' \
  '--threshold=[overall threshold]:thres:' \
  '--min-squared-gradient=[squared gradient threshold]:grad:' \
  '--min-snr=[min I/sigma(I) for peaks]:snr:' \
  '--min-snr-biggest-pix=[min SNR for biggest pixel]:n:' \
  '--min-snr-peak-pix=[min SNR for peak pixel]:n:' \
  '--min-sig=[min background stddev]:n:' \
  '--min-peak-over-neighbour=[peakfinder9 speed param]:n:' \
  '--min-pix-count=[min pixels per peak]:n:' \
  '--max-pix-count=[max pixels per peak]:n:' \
  '--local-bg-radius=[local background radius]:n:' \
  '--min-res=[min distance from center]:n:' \
  '--max-res=[max distance from center]:n:' \
  '--no-use-saturated[ignore saturated peaks]' \
  '--use-saturated[use saturated peaks]' \
  '--no-revalidate[skip external peak list validation]' \
  '--no-half-pixel-shift[disable half-pixel offset]' \
  '--check-hdf5-snr[check SNR for hdf5/cxi peaks]' \
  '--peakfinder8-fast[precalc coordinate tables]' \
  '--indexing=[indexing method]:method:(dirax mosflm asdf felix xds taketwo xgandalf pinkIndexer none)' \
  '--tolerance=[unit cell comparison tolerances]:a,b,c,ang:' \
  '--no-check-cell[do not check cell against reference]' \
  '--no-check-peaks[do not verify peaks]' \
  '--multi[enable multi-lattice indexing]' \
  '--wavelength-estimate=[approx wavelength in metres]:m:' \
  '--camera-length-estimate=[approx camera length in metres]:m:' \
  '--max-indexer-threads=[max threads per engine]:n:' \
  '--no-retry[disable retry]' \
  '--no-refine[skip prediction refinement]' \
