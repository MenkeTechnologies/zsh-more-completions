#compdef fabric

# Zsh completion for fabric-ai

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--setup[run interactive setup]' \
  '--list[list available patterns]' \
  {-p,--pattern}'=[pattern to use]:pattern' \
  {-s,--stream}'[stream output]' \
  {-m,--model}'=[model to use]:model' \
  {-c,--context}'=[context to use]:context' \
  '--session=[session name]:session' \
  '--gui[launch GUI interface]' \
  {-o,--output}'=[output to file]:output file:_files' \
  '--copy[copy output to clipboard]' \
  '--agents[use agents mode]' \
  '--temperature=[temperature value]:temperature' \
  '--top_p=[top-p sampling value]:top_p' \
  '--frequency_penalty=[frequency penalty]:frequency_penalty' \
  '--presence_penalty=[presence penalty]:presence_penalty' \
  '--listmodels[list available models]' \
  '--remoteOllamaServer=[remote Ollama server URL]:url' \
  '--changeDefaultModel[change the default model]' \
  '--latestPatterns=[update patterns]:update:(y n)' \
  '--text=[input text]:text' \
  '--url=[URL to process]:url' \
  '--youtube=[YouTube URL to process]:youtube url' && ret=0

return ret
