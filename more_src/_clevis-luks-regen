#compdef clevis-luks-regen
# Documentation: https://github.com/latchset/clevis/blob/master/src/luks/clevis-luks-regen
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# clevis luks regen: regenerate metadata for a clevis-bound LUKS slot
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-d[LUKS device]:device:_files' \
  '-s[LUKS keyslot]:slot:' \
  '-q[quiet mode (skip prompts)]' && ret=0
return ret
