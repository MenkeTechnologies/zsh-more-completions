#compdef clevis-luks-regen

# clevis luks regen: regenerate metadata for a clevis-bound LUKS slot
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-d[LUKS device]:device:_files' \
  '-s[LUKS keyslot]:slot:' \
  '-q[quiet mode (skip prompts)]' \
  '*:LUKS device:_files' && ret=0
return ret
