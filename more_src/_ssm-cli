#compdef ssm-cli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'get-diagnostics:run agent diagnostics'
  'get-instance-information:print instance info'
  'flush-cached-credentials:flush cached credentials'
  'get-offline-command-invocation:fetch offline command'
  'send-offline-command:send offline command'
)

_arguments -C \
  '--output=[output format]:fmt:(table json text)' \
  'help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ssm-cli subcommand' subcommands && ret=0
    ;;
esac

return ret
