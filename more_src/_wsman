#compdef wsman

# wsman: OpenWSMAN client for WS-Management protocol
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'identify:CIM identify request'
  'enumerate:CIM enumerate request'
  'get:CIM get request'
  'put:CIM put request'
  'invoke:CIM method invoke'
  'create:CIM create instance'
  'delete:CIM delete instance'
  'set:WSMAN set property'
  'subscribe:WSMAN subscribe to events'
  'unsubscribe:WSMAN unsubscribe'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-u --username)'{-u,--username=}'[user]:user:' \
  '(-p --password)'{-p,--password=}'[password]:pwd:' \
  '(-y --encoding)'{-y,--encoding=}'[encoding scheme]:enc:' \
  '(-a --auth)'{-a,--auth=}'[auth method]:auth:(basic digest pass ntlm gss)' \
  '(-A --ca-cert-dir)'{-A,--ca-cert-dir=}'[CA cert directory]:dir:_files -/' \
  '(-C --ca-cert)'{-C,--ca-cert=}'[CA cert file]:file:_files' \
  '(-c --cert)'{-c,--cert=}'[client cert file]:file:_files' \
  '(-K --sslkey)'{-K,--sslkey=}'[client key file]:file:_files' \
  '(-x --xml)'{-x,--xml=}'[XML request body file]:file:_files' \
  '(-J --input)'{-J,--input=}'[input XML file]:file:_files' \
  '(-O --output)'{-O,--output=}'[output file]:file:_files' \
  '(-d --debug)'{-d,--debug=}'[debug level]:n:' \
  '(-r --refresh)'{-r,--refresh=}'[refresh interval]:sec:' \
  '(-N --namespace)'{-N,--namespace=}'[namespace]:ns:' \
  '(-D --dump-request)'{-D,--dump-request}'[dump request to stdout]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '-h[host]:host:port:' \
  '-P[port]:port:' \
  '-Y[XML response output]' \
  '-Z[disable response handling]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'wsman command' commands && ret=0 ;;
esac
return ret
