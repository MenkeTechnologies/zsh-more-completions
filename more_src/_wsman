#compdef wsman
# Documentation: https://man.archlinux.org/search?q=wsman
# Reference accessed: 2026-05-16

# wsman: WS-Management CLI client (openwsman)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-V[show version]' \
  '-d[debug level]:level:(0 1 2 3 4 5 6)' \
  '--debug=[debug level]:level:(0 1 2 3 4 5 6)' \
  '-y[auth method]:method:(basic digest gssapi)' \
  '--auth=[auth method]:method:(basic digest gssapi)' \
  '-u[username]:user:_users' \
  '--user=[username]:user:_users' \
  '-p[password]:password:' \
  '--password=[password]:password:' \
  '-h[remote host]:host:_hosts' \
  '--hostname=[remote host]:host:_hosts' \
  '-P[port]:port:' \
  '--port=[port]:port:' \
  '-v[CA cert file]:file:_files' \
  '--cacert=[CA cert file]:file:_files' \
  '-y[encoding]:encoding:' \
  '-N[CIM namespace]:ns:' \
  '--cimnamespace=[CIM namespace]:ns:' \
  '-Z[input file with body XML]:file:_files' \
  '--input=[input file with body XML]:file:_files' \
  '-O[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '-J[JSON body]:json:' \
  '-x[XPath filter]:xpath:' \
  '--filter=[selector filter]:filter:' \
  '-D[dialect URI]:dialect:' \
  '1:action:(identify get put create delete enumerate pull release invoke wait subscribe unsubscribe renew)' \
  '*::resource URI:' && ret=0
return ret
