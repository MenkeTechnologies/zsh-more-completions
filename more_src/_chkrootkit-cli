#compdef chkrootkit

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-l[list available tests]' \
  '-d[debug]' \
  '-q[quiet]' \
  '-x[expert mode]' \
  '-r+[root dir]:dir:_files -/' \
  '-p+[path]:dir:_files -/' \
  '-n[skip NFS mounted]' \
  '-T[show test results]' \
  '*: :_values "test" aliens asp bindshell lkm rexedcs sniffer w55808 wted scalper slapper z2 chkutmp' && ret=0

return ret
