#compdef chkrootkit
# Documentation: http://manpages.ubuntu.com/manpages/jammy/man8/chkrootkit.8.html
# Reference accessed: 2026-05-17
# Verified: upstream Ubuntu manpage at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-l[list available tests]' \
  '-d[debug mode]' \
  '-q[quiet mode (only "infected" output)]' \
  '-x[expert mode]' \
  '-r+[root directory]:dir:_files -/' \
  '-p+[colon-separated PATH for trusted external commands]:path:' \
  '-n[skip NFS-mounted directories]' \
  '-e+[exclude files from results]:files:' \
  '-s+[regex filter for sniffer test output]:regexp:' \
  '*: :_values "test" aliens asp bindshell lkm rexedcs sniffer w55808 wted scalper slapper z2 chkutmp' && ret=0

return ret
