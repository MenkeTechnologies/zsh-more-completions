#compdef gdk-pixbuf-query-loaders gdkpixbuf-query-loaders
# Documentation: https://man.archlinux.org/search?q=gdk-pixbuf-query-loaders
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--version[show version]' \
  '--update-cache[update default cache]' \
  '*:loader:_files' && ret=0

return ret
