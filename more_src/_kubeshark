#compdef kubeshark

# Zsh completion for kubeshark - Kubernetes API traffic viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-s,--set}'[override a value in the config]:key=value' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'tap:start capturing traffic'
      'clean:remove kubeshark resources from the cluster'
      'config:manage kubeshark configuration'
      'logs:show kubeshark logs'
      'pro:manage kubeshark pro features'
      'version:print the version'
      'help:show help for a command'
    )
    _describe -t commands 'kubeshark command' commands && ret=0
    ;;
  args)
    case $words[1] in
      tap)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*'{-s,--set}'[override a value in the config]:key=value' \
          '--docker[run in Docker mode]' \
          '-A+[namespaces to tap]:namespaces' \
          '--allnamespaces[tap all namespaces]' \
          '--dryrun[dry run, do not deploy]' \
          && ret=0
        ;;
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--regenerate[regenerate the config file]' \
          && ret=0
        ;;
      logs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f[follow log output]' \
          && ret=0
        ;;
      help)
        local -a subcmds=(tap clean config logs pro version)
        _describe -t commands 'kubeshark command' subcmds && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
