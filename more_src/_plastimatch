#compdef plastimatch
# Documentation: https://plastimatch.org/plastimatch.html
# Plastimatch: medical image registration and processing

local ret=1
local -a cmds

cmds=(
  'add:combine multiple images with optional weighting'
  'adjust:modify intensity values (scaling, histogram matching)'
  'average:compute weighted average of multiple images'
  'autolabel:ML-based thoracic vertebrae identification'
  'boundary:extract image boundaries'
  'compare:subtract one image from another and report statistics'
  'compose:combine two transforms'
  'convert:transform files between formats'
  'crop:extract rectangular image region'
  'dice:compare binary labels using Dice coefficient'
  'diff:subtract one image from another and save result'
  'dmap:create distance map from binary image'
  'dose:dose-related operations'
  'drr:generate digitally reconstructed radiographs'
  'dvh:create dose-volume histograms'
  'fdk:cone-beam reconstruction algorithm'
  'fill:fill masked regions with constant intensity'
  'filter:apply filtering (Gaussian, Gabor, custom kernels)'
  'gamma:compare images using gamma criterion'
  'header:display image properties'
  'intersect:logical intersection of images'
  'jacobian:compute Jacobian determinant of vector field'
  'lm-warp:deformable registration via landmark matching'
  'mabs:multi-atlas based segmentation'
  'mask:mask regions outside a mask file'
  'maximum:find maximum values'
  'ml-convert:machine learning format conversion'
  'probe:examine intensity/displacement at positions'
  'register:linear or deformable image registration'
  'resample:change image geometry'
  'scale:multiply voxels by a constant'
  'segment:threshold-based segmentation'
  'stats:display basic image statistics'
  'synth:create synthetic images'
  'synth-vf:create synthetic vector fields'
  'threshold:create binary labelmap from intensity image'
  'thumbnail:generate 2D thumbnail from volume'
  'union:logical union of images'
  'warp:apply transforms to images (alias for convert)'
  'xf-convert:convert between transform types'
  'xf-invert:invert a transformation'
)

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version information]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'plastimatch command' cmds && ret=0 ;;
  args) _files && ret=0 ;;
esac

return ret
