#compdef xenballoond
# Documentation: https://github.com/maddingue/xenballoond (lib/xenballoond/cmdline.py)
# Reference accessed: 2026-05-21
# Verified: upstream OptionParser definition in lib/xenballoond/cmdline.py.
# Real flags: -V/--version, -c/--config, -D/--detach (+ --nodetach/--no-detach
# suppressed), -p/--pidfile. No -d, -f, -l, -h short options upstream.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-V,--version}'[show version and exit]' \
  '(-c --config)'{-c+,--config=}'[alternate configuration file]:file:_files' \
  '(-D --detach --nodetach --no-detach)'{-D,--detach}'[daemonize and detach from terminal]' \
  '(-D --detach)--nodetach[do not daemonize]' \
  '(-D --detach)--no-detach[do not daemonize]' \
  '(-p --pidfile)'{-p+,--pidfile=}'[path to PID file]:file:_files' && ret=0
return ret
