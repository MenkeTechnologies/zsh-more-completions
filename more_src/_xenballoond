#compdef xenballoond
# Documentation: https://github.com/maddingue/xenballoond
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# xenballoond: Xen memory ballooning daemon (guest side)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[config file]:file:_files' \
  '-d[do not daemonize]' \
  '-f[run in foreground]' \
  '-l[log file]:file:_files' \
  '*::xenballoond args:_files' && ret=0
return ret
