#compdef PRSolve
# Documentation: https://github.com/SGL-UT/GPSTk/blob/main/core/apps/positioning/PRSolve.cpp
# GPSTk pseudorange (RAIM) positioning solution

local ret=1

_arguments -s \
  '*--obs[RINEX observation file name]:file:_files' \
  '*--sol[solution(s) System:Frequencies:Codes]:sol' \
  '*--eph[ephemeris file (SP3 or RINEX nav)]:file:_files' \
  '*--nav[RINEX navigation file]:file:_files' \
  '*--clk[clock (RINEX format) file]:file:_files' \
  '*--met[RINEX meteorological file]:file:_files' \
  '*--dcb[differential code bias (P1-C1) file]:file:_files' \
  '--obspath[input obs file path]:dir:_files -/' \
  '--ephpath[input eph file path]:dir:_files -/' \
  '--navpath[input nav file path]:dir:_files -/' \
  '--clkpath[input clk file path]:dir:_files -/' \
  '--metpath[input met file path]:dir:_files -/' \
  '--dcbpath[input dcb file path]:dir:_files -/' \
  '--start[begin processing at specified epoch]:epoch' \
  '--stop[stop processing at specified epoch]:epoch' \
  '--decimate[thin data to time interval]:dt' \
  '--elev[minimum elevation mask (deg)]:deg' \
  '*--exSat[exclude satellite]:sat' \
  '--wt[weight measurements by elevation]' \
  '--rms[RMS residual limit]:lim' \
  '--slope[RAIM slope limit]:lim' \
  '--nrej[maximum satellites to reject]:n' \
  '--log[output log file]:file:_files' \
  '--out[output RINEX with solutions]:file:_files' \
  '--ORDs[write observed range deviations]:file:_files' \
  '--ref[reference position for residuals]:pos' \
  '--Trop[troposphere model]:model' \
  '--SOLhelp[show solution descriptor help]' \
  '--verbose[increase verbosity]' \
  '--debug[increase debug level]' \
  '--help[print help usage]' && ret=0

return ret
