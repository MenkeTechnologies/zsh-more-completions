#compdef clair

# Zsh completion for clair (container vulnerability scanner)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-D[Enable debug logging]' \
  '--debug[Enable debug logging]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'report:Request a vulnerability report for a manifest'
      'export:Export updater data'
      'import:Import updater data'
      'check-config:Validate configuration file'
      'delete:Delete an index report'
    )
    _describe -t commands 'clair command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      report)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--host=[Clair server address]:host' \
          '-o+[Output format]:format:(json text)' \
          '--out=[Output format]:format:(json text)' \
          '1:manifest' && ret=0
        ;;
      export|import)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--host=[Clair server address]:host' \
          '*:file:_files' && ret=0
        ;;
      check-config)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:config-file:_files' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--host=[Clair server address]:host' \
          '1:manifest-hash' && ret=0
        ;;
    esac
    ;;
esac

return ret
