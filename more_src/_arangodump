#compdef arangodump

# Zsh completion for arangodump - ArangoDB data dump utility

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--server.endpoint=[server endpoint]:endpoint' \
  '--server.database=[database name]:database' \
  '--server.username=[username]:user' \
  '--server.password=[password]:password' \
  '--server.authentication=[enable authentication]:enable:(true false)' \
  '--server.connection-timeout=[connection timeout in seconds]:seconds' \
  '--server.request-timeout=[request timeout in seconds]:seconds' \
  '--ssl.protocol=[SSL protocol]:protocol:(1 2 3 4 5 6 9)' \
  '--ssl.cafile=[CA certificate file]:file:_files' \
  '--output-directory=[output directory for dump files]:directory:_files -/' \
  '--overwrite[overwrite existing dump files]' \
  '--all-databases[dump all databases]' \
  '--include-collection=[collection to include]:collection' \
  '--include-system-collections[include system collections]' \
  '--compress-output[compress output files]' \
  '--dump-data=[dump document data]:enable:(true false)' \
  '--dump-dependencies=[dump view dependencies]:enable:(true false)' \
  '--envelope=[wrap results in envelope]:enable:(true false)' \
  '--flush=[flush WAL before dumping]:enable:(true false)' \
  '--batch-size=[batch size for data transfer]:bytes' \
  '--initial-batch-size=[initial batch size]:bytes' \
  '--threads=[number of dump threads]:count' \
  '--max-wait-for-replication=[max wait for replication in seconds]:seconds' \
  '--use-gzip-for-replication=[use gzip compression]:enable:(true false)' \
  '--progress=[show progress]:enable:(true false)' \
  '--log.level=[log level]:level:(fatal error warning info debug trace)' \
  '--configuration=[configuration file]:file:_files'
