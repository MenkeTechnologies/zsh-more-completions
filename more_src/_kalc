#compdef kalc
# _kalc — complex/precision/vector CLI calculator + grapher (bgkillas/kalc)
# upstream: https://github.com/bgkillas/kalc
# Flags from src/main.rs + kalc-lib/src/options.rs (custom arg parser).

_kalc() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '(- *)--man[print full manual]'
        '--default[restore default settings + exit]'
        '-i[force interactive mode after evaluating arguments]'
        '*:expression / setting= override:'
    )
    _arguments -s $args
}

_kalc "$@"
