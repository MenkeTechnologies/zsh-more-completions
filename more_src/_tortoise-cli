#compdef tortoise-cli
# Documentation: https://github.com/tortoise/tortoise-cli
# tortoise-cli command-line tool for Tortoise ORM

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-c --config)'{-c,--config}'=[TortoiseORM config dictionary path]:config' \
  '--generate-schemas[generate schemas after initialization]' \
  '--no-generate-schemas[do not generate schemas after initialization]' \
  '1:command:(shell)' \
  '*::arg:_default' && ret=0

return ret
