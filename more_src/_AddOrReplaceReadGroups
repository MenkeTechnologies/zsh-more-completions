#compdef AddOrReplaceReadGroups
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/AddOrReplaceReadGroups.java
# Picard: assign all reads in a file to a single new read-group

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input BAM/SAM/CRAM or GA4GH url]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output SAM/BAM/CRAM file]:file:_files' \
  '(-SO --SORT_ORDER)'{-SO,--SORT_ORDER}'=[optional output sort order]:order:(queryname coordinate duplicate unsorted)' \
  '(-ID --RGID)'{-ID,--RGID}'=[read-group ID]:id:' \
  '(-LB --RGLB)'{-LB,--RGLB}'=[read-group library]:lib:' \
  '(-PL --RGPL)'{-PL,--RGPL}'=[read-group platform]:pl:(ILLUMINA SOLID LS454 HELICOS PACBIO IONTORRENT ONT)' \
  '(-PU --RGPU)'{-PU,--RGPU}'=[read-group platform unit]:pu:' \
  '(-SM --RGSM)'{-SM,--RGSM}'=[read-group sample name]:sm:' \
  '(-CN --RGCN)'{-CN,--RGCN}'=[read-group sequencing center name]:cn:' \
  '(-DS --RGDS)'{-DS,--RGDS}'=[read-group description]:ds:' \
  '(-DT --RGDT)'{-DT,--RGDT}'=[read-group run date]:dt:' \
  '(-KS --RGKS)'{-KS,--RGKS}'=[read-group key sequence]:ks:' \
  '(-FO --RGFO)'{-FO,--RGFO}'=[read-group flow order]:fo:' \
  '(-PI --RGPI)'{-PI,--RGPI}'=[read-group predicted insert size]:pi:' \
  '(-PG --RGPG)'{-PG,--RGPG}'=[read-group program group]:pg:' \
  '(-PM --RGPM)'{-PM,--RGPM}'=[read-group platform model]:pm:' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
