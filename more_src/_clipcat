#compdef clipcat clipcatd clipcatctl clipcat-menu

local curcontext="$curcontext" state line ret=1

case ${service} in
  clipcatd|clipcat)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '--no-daemon[do not daemonize]' \
      '-r[replace running daemon]' && ret=0
    ;;
  clipcatctl)
    local -a commands=(
      'list:list stored clips'
      'get:get a clip by ID'
      'insert:insert a clip'
      'remove:remove a clip by ID'
      'clear:clear all clips'
      'length:show number of stored clips'
      'promote:promote a clip to the top'
      'version:show version'
    )
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '1:command:->command' && ret=0
    case $state in
      (command)
        _describe -t commands 'clipcatctl command' commands && ret=0
        ;;
    esac
    ;;
  clipcat-menu)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '-f[finder tool]:finder:(skim fzf rofi dmenu custom)' \
      '--custom-finder[custom finder command]:command:_command_names' && ret=0
    ;;
esac

return ret
