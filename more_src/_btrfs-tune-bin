#compdef btrfstune
# _btrfs-tune-bin — btrfs filesystem feature tuning (btrfs-progs); enable/disable optional features on an offline btrfs
# upstream: https://github.com/kdave/btrfs-progs

_btrfs-tune-bin() {
    _arguments \
        '-S+[set seeding flag]:bool:(0 1)' \
        '-r[enable extended inode refs]' \
        '-x[enable skinny metadata extent refs]' \
        '-n[enable no_holes feature]' \
        '-f[force]' \
        '-m+[set fsid]:uuid:' \
        '-M+[set metadata uuid]:uuid:' \
        '-u[generate new fsid]' \
        '-U+[set fsid (deprecated)]:uuid:' \
        '-b[enable big metadata blocks]' \
        '--convert-to-block-group-tree[migrate to block-group tree]' \
        '--convert-from-block-group-tree[migrate from block-group tree]' \
        '--enable-free-space-tree[enable free-space tree]' \
        '--disable-free-space-tree[disable free-space tree]' \
        '--remove-block-group-tree[remove block-group tree]' \
        '-h[show help]' \
        '-V[show version]' \
        '*:device:_files'
}

_btrfs-tune-bin "$@"
