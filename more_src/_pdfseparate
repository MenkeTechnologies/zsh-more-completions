#compdef pdfseparate
# Documentation: https://manpages.debian.org/pdfseparate.1
# Source: poppler-utils — split a PDF into per-page PDF files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[first page (default 1)]:n:' \
    '-l[last page (default last)]:n:' \
    '(- *)-v[print copyright + version]' \
    '(- *)-h[print usage]' \
    '*:input.pdf then output-pattern-%d.pdf:_files' \
    && ret=0

return ret
