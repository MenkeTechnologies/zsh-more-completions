#compdef ossec-syscheckd
# Documentation: https://www.ossec.net/docs/programs/ossec-syscheckd.html
# OSSEC file integrity and rootcheck daemon

local ret=1

_arguments -s \
  '-V[version and license message]' \
  '-h[show help]' \
  '*-d[debug mode (repeat to increase verbosity)]' \
  '-t[test configuration]' \
  '-f[run in foreground]' \
  '-c[configuration file]:config file:_files' && ret=0

return ret
