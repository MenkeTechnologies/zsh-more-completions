#compdef ulogd2
# _ulogd2 — netfilter ulogd2 binary alias (modern ulogd2 daemon with shorter version-tagged stem; -c config file, -d daemonize, -i plugin path, -p pidfile, -u run-as user, -l/-L log level + log file, -v verbose, --help; same surface as ulogd(8) — kept for distro compatibility scripts)
# upstream: https://www.netfilter.org/projects/ulogd/
# Flags from netfilter/ulogd src/ulogd.c on tip.

_ulogd2() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '-d[daemonize]' \
        '-i+[plugin path]:file:_files -g "*.so"' \
        '-p+[pidfile]:file:_files' \
        '-u+[run as user]:user:_users' \
        '-l+[log level]:level:(emerg alert crit err warning notice info debug)' \
        '-L+[log file]:file:_files' \
        '-v[verbose]'
}

_ulogd2 "$@"
