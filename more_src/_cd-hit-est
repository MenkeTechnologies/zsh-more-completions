#compdef cd-hit-est cd-hit-est-2d cd-hit-2d
# _cd-hit-est — Weizhong Li cd-hit-est CLI nucleotide-sequence variant of CD-HIT clustering DNA RNA sequences at chosen identity threshold producing representative clusters greedy incremental short-word filter heuristic for transcriptome deduplication amplicon dereplication EST UniGene SILVA 16S workflows (Weizhong Li team, C++); getopt
# upstream: https://github.com/weizhongli/cdhit

_cd-hit-est() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-i+[input nucleotide fasta]:file:_files -g "*.fa *.fasta *.fna *.fas"' \
        '-o+[output prefix]:str:' \
        '-c+[identity threshold]:n:' \
        '-G+[global identity]:n:(0 1)' \
        '-b+[band width]:n:' \
        '-M+[memory MB]:n:' \
        '-T+[threads]:n:' \
        '-n+[word size]:n:(7 8 9 10 11 12)' \
        '-l+[max length difference]:n:' \
        '-t+[tolerance redundance]:n:' \
        '-d+[length description]:n:' \
        '-s+[length difference cutoff]:n:' \
        '-S+[length difference cutoff bp]:n:' \
        '-aL+[align coverage long]:n:' \
        '-AL+[align coverage long bp]:n:' \
        '-aS+[align coverage short]:n:' \
        '-AS+[align coverage short bp]:n:' \
        '-A+[min align region bp]:n:' \
        '-uL+[max unmatched long bp]:n:' \
        '-uS+[max unmatched short bp]:n:' \
        '-U+[max unmatched bp]:n:' \
        '-B+[long input on disk]:n:(0 1)' \
        '-P+[primer assignment]:n:(0 1)' \
        '-cx+[crosslink length]:n:' \
        '-cy+[crosslink length 2d]:n:' \
        '-r+[strand mode]:n:(0 1)' \
        '-g+[accurate but slow]:n:(0 1)' \
        '-mask+[mask letters]:str:' \
        '-match+[matching score]:str:' \
        '-mismatch+[mismatch score]:str:' \
        '-gap+[gap score]:str:' \
        '-gap-ext+[gap ext score]:str:' \
        '*::'
}

_cd-hit-est "$@"
