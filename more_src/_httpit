#compdef httpit
# Documentation: https://github.com/gonetx/httpit
# httpit - rapid http(s) benchmark tool with a real-time TUI

local ret=1

_arguments -s -S \
  '(-c --connections)'{-c,--connections}'[maximum number of concurrent connections]:connections:' \
  '(-n --requests)'{-n,--requests}'[number of requests]:requests:' \
  '--qps[highest qps value for a fixed benchmark]:qps:' \
  '(-d --duration)'{-d,--duration}'[duration of test]:duration:' \
  '(-t --timeout)'{-t,--timeout}'[socket/request timeout]:timeout:' \
  '(-X --method)'{-X,--method}'[HTTP request method]:method:(GET POST PUT DELETE HEAD PATCH OPTIONS)' \
  '*'{-H,--header}'[HTTP request header K: V]:header:' \
  '--host[override request host]:host:' \
  '(-a --disableKeepAlives)'{-a,--disableKeepAlives}'[disable HTTP keep-alive]' \
  '(-b --body)'{-b,--body}'[HTTP request body string]:body:' \
  '(-f --file)'{-f,--file}'[read HTTP request body from file path]:file:_files' \
  '(-s --stream)'{-s,--stream}'[use stream body to reduce memory usage]' \
  '(-J --json)'{-J,--json}'[send json request]' \
  '(-F --form)'{-F,--form}'[send form request]' \
  '(-k --insecure)'{-k,--insecure}'[skip server certificate verification]' \
  '--cert[path to the clients TLS certificate]:file:_files' \
  '--key[path to the clients TLS certificate private key]:file:_files' \
  '--httpProxy[HTTP proxy address]:proxy:' \
  '--socksProxy[socks proxy address]:proxy:' \
  '(-p --pipeline)'{-p,--pipeline}'[use fasthttp pipeline client]' \
  '--follow[follow 30x Location redirects for debug mode]' \
  '--maxRedirects[max redirect count of following 30x]:count:' \
  '(-D --debug)'{-D,--debug}'[send request once and show request and response detail]' \
  '(-h --help)'{-h,--help}'[help for httpit]' \
  '(-v --version)'{-v,--version}'[version for httpit]' \
  '*:url:_urls' && ret=0

return ret
