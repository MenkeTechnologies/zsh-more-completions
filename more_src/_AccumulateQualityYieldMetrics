#compdef AccumulateQualityYieldMetrics
# Documentation: https://github.com/broadinstitute/picard/blob/master/src/main/java/picard/util/AccumulateQualityYieldMetrics.java
# Combines multiple QualityYieldMetrics files into a single file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{--INPUT,-I}'=[input QualityYieldMetrics files]:value:_files' \
  '(--OUTPUT -O)'{--OUTPUT,-O}'=[output file]:value:_files' \
  '*:argument:_files' && ret=0

return ret
