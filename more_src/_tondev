#compdef tondev
# _tondev — TON Labs tondev TON Development Environment CLI for The Open Network blockchain managing solc tvm-cli SDK projects FreeTON contract deployments (tonlabs team, TypeScript); commander.js
# upstream: https://github.com/tonlabs/tondev

_tondev() {
    local -a sub=(
        'setup:setup environment'
        'solidity:solidity operations'
        'sol:solidity operations'
        'tonos-cli:tonos-cli operations'
        't:tonos-cli operations'
        'tvm-linker:tvm-linker operations'
        'evm:EVM operations'
        'controller:controller operations'
        'se:start node SE'
        'network:network operations'
        'net:network operations'
        'signer:signer operations'
        'js:JS operations'
        'js-cli:JS CLI operations'
        'help:show help'
        'version:show version'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tondev subcommand' sub ;;
        args)
            case $words[1] in
                solidity|sol) _arguments \
                    '1:action:(version create compile install update set use)' \
                    '*:contract file:_files -g "*.sol *.tvc *.code *.abi.json"' ;;
                se) _arguments \
                    '1:action:(start stop reset update info config version delete set)' \
                    '*:instance:' ;;
                network|net) _arguments \
                    '1:action:(list add remove info default credentials giver)' \
                    '*:network name:' ;;
                signer) _arguments \
                    '1:action:(list add remove default get info generate phrase keys)' \
                    '*:signer name:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_tondev "$@"
