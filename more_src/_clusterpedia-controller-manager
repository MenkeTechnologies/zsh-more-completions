#compdef clusterpedia-controller-manager
# _clusterpedia-controller-manager — Clusterpedia controller manager (reconciles PediaCluster + ClusterSyncResources CRs)
# upstream: https://github.com/clusterpedia-io/clusterpedia
# Flags from cmd/controller-manager/app/options/options.go on tip.

_clusterpedia-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version=[print version and exit]:fmt:(true raw)' \
        '--master=[Kubernetes API URL (overrides kubeconfig)]:url:_urls' \
        '--kubeconfig=[path to kubeconfig file]:file:_files' \
        '--kube-api-content-type=[content type for requests to the apiserver]:ct:' \
        '--feature-gates=[csv of feature gates]:gates:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader-election lease duration]:duration:' \
        '--leader-elect-renew-deadline=[leader-election renew deadline]:duration:' \
        '--leader-elect-retry-period=[leader-election retry period]:duration:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr]:bool:(true false)' \
        '--logging-format=[log format]:fmt:(text json)'
}

_clusterpedia-controller-manager "$@"
