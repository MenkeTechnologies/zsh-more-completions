#compdef wazuh-analysisd
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/daemons/wazuh-analysisd.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Wazuh/analysisd subdaemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-c[config file]:file:_files' \
  '-d[debug]' \
  '-f[run in foreground]' \
  '-t[test config]' \
  '-u[user]:user:_users' \
  '-g[group]:group:_groups' \
  '-D[runtime directory]:dir:_files -/' \
  '*::wazuh-analysisd args:_files' && ret=0
return ret
