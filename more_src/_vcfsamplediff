#compdef vcfsamplediff
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfsamplediff.md
# Tag records by germline/somatic/loh status comparing two samples

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --strict)'{-s,--strict}'[require no observations in the germline support the somatic alternate]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
