#compdef eidos
# Documentation: https://github.com/MesserLab/SLiM/blob/master/eidostool/main.cpp
# Eidos: standalone interpreter for the Eidos scripting language (SLiM). Flags mirror PrintUsageAndDie() in eidostool/main.cpp.

local ret=1

_arguments -s -S \
  '(-v -version)'{-v,-version}'[print version and exit]' \
  '(-u -usage -\?)'{-u,-usage,-\?}'[print command-line usage and exit]' \
  '(-te -testEidos)'{-te,-testEidos}'[run Eidos self-tests]' \
  '(-t -time)'{-t,-time}'[print wall-clock execution time]' \
  '(-m -mem)'{-m,-mem}'[print peak memory usage]' \
  '-maxThreads[maximum number of OpenMP threads]:threads:' \
  '-perTaskThreads[per-task thread counts]:spec:' \
  '*:Eidos script:_files' && ret=0

return ret
