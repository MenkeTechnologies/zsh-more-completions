#compdef gntpc
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gNtpConv.cxx
# gntpc - GENIE ntuple conversion utility (GHEP to other formats)

local ret=1

_arguments -s -S \
  '-i[input GENIE event file]:file:_files' \
  '-o[output filename (default derived from input name and format)]:outfile:_files' \
  '-f[output file format]:format:(gst gxml ghep_mock_data rootracker rootracker_mock_data t2k_rootracker numi_rootracker t2k_tracker nuance_tracker ghad ginuke)' \
  '-n[number of events to process (default all)]:nevents:' \
  '-v[output format version (default latest)]:version:' \
  '-c[copy MC job metadata (gconfig and genv TFolders) from input]' \
  '--seed[random number seed]:seed:' \
  '--message-thresholds[XML file customizing message stream thresholds]:xml:_files' \
  '--event-record-print-level[verbosity for event record output]:level:' \
  '*: :_files' && ret=0

return ret
