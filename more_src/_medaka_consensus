#compdef medaka_consensus
# Documentation: https://github.com/nanoporetech/medaka/blob/master/scripts/medaka_consensus
# medaka wrapper to polish a draft assembly with basecalls

local ret=1

_arguments -s -S \
  '-h[display help text]' \
  '-i+[fastx input basecalls (required)]:file:_files' \
  '-d+[fasta input assembly (required)]:file:_files' \
  '-o+[output folder]:dir:_files -/' \
  '-p+[prefix for output files]:prefix' \
  '-g[do not fill gaps in consensus with draft sequence]' \
  '-r[use gap-filling character instead of draft sequence]' \
  '-m+[medaka model]:model' \
  '-f[force overwrite of outputs]' \
  '-x[force recreation of alignment index]' \
  '-t+[number of threads to create features]:threads' \
  '-b+[batchsize, controls memory use]:size' \
  '-q[output consensus with per-base quality scores]' \
  '-B+[regions to polish]:regions' \
  '-M+[minimum mapQ]:mapq' \
  '--bacteria[automatically select best model for bacteria and plasmids]' && ret=0

return ret
