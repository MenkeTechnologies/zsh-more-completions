#compdef dockutil

# macOS Dock helper — github.com/kcrawford/dockutil README “USAGE”

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h)'-h'[help]' \
  '(--version)'--version'[show version]' \
  '(--add)'--add'[add dock item]:path or URL:_files' \
  '(--remove)'--remove'[remove by label, path, url, all, or spacer-tiles]:item label (or all|spacer-tiles)' \
  '(--move)'--move'[move item]:dock item label' \
  '(--find)'--find'[find item]:needle' \
  '(--list)'--list'[list dock items]' \
  '(--label)'--label'[set label]:label' \
  '(--type)'--type'[item type]:type:(spacer folder)' \
  '(--replacing)'--replacing'[replace existing item]:dock label' \
  '(--position)'--position'[insert position]:position:(beginning end middle)' \
  '(--after)'--after'[insert after label]:dock label' \
  '(--before)'--before'[insert before label]:dock label' \
  '(--section)'--section'[dock section]:section:(apps others)' \
  '(--view)'--view'[folder stack view]:view:(grid fan list auto)' \
  '(--display)'--display'[folder display]:display:(folder stack)' \
  '(--sort)'--sort'[folder sort]:sort:(name dateadded datemodified datecreated kind)' \
  '(--no-restart)'--no-restart'[do not restart Dock]' \
  '(--allhomes)'--allhomes'[act on all user home dirs]' \
  '(--homeloc)'--homeloc'[/Users parent path]:directory:_files -/' \
  '*::extra plist or paths:_files' && ret=0

return ret
