#compdef gce-pd-csi-driver
# _gce-pd-csi-driver — Google Compute Engine Persistent Disk CSI driver
# upstream: https://github.com/kubernetes-sigs/gcp-compute-persistent-disk-csi-driver
# Flags from cmd/gce-pd-csi-driver/main.go on tip.

_gce-pd-csi-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--cloud-config=[GCE cloud provider config]:file:_files' \
        '--fail-close-on-auth-error[fail controller startup if initial auth token fetch fails]' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--run-controller-service=[activate controller service]:bool:(true false)' \
        '--run-node-service=[activate node service]:bool:(true false)' \
        '--http-endpoint=[Prometheus metrics HTTP address]:addr:' \
        '--metrics-path=[Prometheus metrics path]:path:' \
        '--grpc-log-char-cap=[max chars per gRPC response in logs]:n:' \
        '--enable-otel-tracing[enable OpenTelemetry tracing]' \
        '--backoff-initial-duration-ms=[initial backoff duration for publish/unpublish (ms)]:ms:' \
        '--backoff-max-duration-ms=[max backoff duration for publish/unpublish (ms)]:ms:' \
        '--extra-labels=[csv key=value labels added to each PD]:csv:' \
        '--attach-disk-backoff-duration=[attachDisk backoff duration]:duration:' \
        '--attach-disk-backoff-steps=[attachDisk backoff steps]:n:' \
        '--attach-disk-backoff-cap=[attachDisk backoff cap]:duration:' \
        '--wait-op-backoff-duration=[wait-for-op backoff duration]:duration:' \
        '--wait-op-backoff-steps=[wait-for-op backoff steps]:n:' \
        '--wait-op-backoff-cap=[wait-for-op backoff cap]:duration:' \
        '--enable-device-in-use-check-on-node-unstage=[block NodeUnstageVolume while device in use]:bool:(true false)' \
        '--device-in-use-timeout=[device-in-use wait timeout on unstage]:duration:' \
        '--maxprocs=[GOMAXPROCS override]:n:' \
        '--max-concurrent-format=[max concurrent format exec calls]:n:' \
        '--concurrent-format-timeout=[max format duration before token release]:duration:' \
        '--max-concurrent-format-and-mount=[max concurrent format+mount calls per node]:n:' \
        '--format-and-mount-timeout=[max format+mount duration]:duration:' \
        '--fallback-requisite-zones=[csv of fallback requisite zones]:csv:' \
        '--enable-storage-pools[enable Storage Pools]' \
        '--allow-hdha-provisioning[allow Hyperdisk-balanced High Availability provisioning]' \
        '--enable-data-cache[enable Data Cache configuration]' \
        '--enable-multitenancy[support running on multitenant GKE clusters]' \
        '--enable-pd-conversion[convert eligible PDs at attach time]' \
        '--node-name=[node this driver is running on]:name:' \
        '--multi-zone-volume-handle-disk-types=[csv of disk types allowed for multi-zone volumeHandle]:csv:' \
        '--multi-zone-volume-handle-enable[enable multi-zone volumeHandle feature]' \
        '--use-instance-api-to-poll-attachment-disk-types=[csv of disk types using instances.get for attach polling]:csv:' \
        '--use-instance-api-to-list-volumes-published-nodes[use instances.list for ListVolumes published_node_ids]' \
        '--instances-list-filters=[csv of filters for instances.list]:csv:' \
        '--supports-dynamic-iops-provisioning=[csv of disk types supporting dynamic IOPS]:csv:' \
        '--supports-dynamic-throughput-provisioning=[csv of disk types supporting dynamic throughput]:csv:' \
        '--extra-tags=[csv of parent_id/key/value tags for Compute resources]:csv:' \
        '--disk-topology[add disk-type.gke.io/[disk-type] topology label]' \
        '--dynamic-volumes[auto-select compatible disk type from StorageClass]' \
        '--gce-disk-status[update volume-publish-status-gke-io label after attach]' \
        '--enable-disk-cleanup[cleanup leaked GCE disks on startup]' \
        '--cluster-ownership-id=[cluster identifier label applied to GCE disks]:id:' \
        '--disk-cache-sync-period=[disk cache sync period (/dev/disk/by-id/)]:duration:' \
        '--enable-disk-size-validation[validate requested disk size matches physical size]' \
        '--run-taint-controller[enable Taint Cleanup Controller]' \
        '--run-taint-webhook[enable Mutating Admission Webhook for startup taints]' \
        '--webhook-port=[admission webhook port]:port:' \
        '--taint-metrics-addr=[taint controller metrics bind address]:addr:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_gce-pd-csi-driver "$@"
