#compdef disklabel

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-r[read or write the on-disk label]' \
  '-w[install initial label]' \
  '-e[edit existing label]' \
  '-d[delete labels]' \
  '-c[create new label]' \
  '-i[interactive]' \
  '-n[do not write changes (simulation)]' \
  '-v[verbose]' \
  '-A[automount]' \
  '-h[print human-readable sizes]' \
  '-p+[partition]:partition:' \
  '-s+[sector]:sector:' \
  '*:disk device:_files -g "/dev/(r)disk*"' && ret=0

return ret
