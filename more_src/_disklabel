#compdef disklabel
# Documentation: https://man.openbsd.org/disklabel.8
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# OpenBSD disklabel(8).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-A[automatically allocate all OpenBSD disk space]' \
  '-c[clear in-core copy of label and update from disk]' \
  '-d[use default label]' \
  '-E[use built-in command-driven label editor]' \
  '-e[edit existing label with $EDITOR]' \
  '-F+[write fstab entries to file]:fstab file:_files' \
  '-f+[fstab file]:fstab file:_files' \
  '-h[print partition sizes in human-readable format]' \
  '-n[make no permanent changes (debugging)]' \
  '-p+[print sizes in unit]:unit:(b c k m g t)' \
  '-R[restore disk label from ASCII file]' \
  '-T+[allocation template file]:template:_files' \
  '-t[format label as disktab entry]' \
  '-v[verbose]' \
  '-w[write standard label on drive]' \
  '*:disk device:_files -g "/dev/(r)disk*"' && ret=0

return ret
