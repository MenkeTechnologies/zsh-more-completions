#compdef varlock
# Documentation: https://varlock.dev/reference/cli-commands/
# varlock - AI-safe .env files: schema-driven, type-safe env var and secrets management

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_varlock_commands() {
  local -a commands
  commands=(
    'init:set up varlock in the current project'
    'load:resolve and load env vars from .env files'
    'run:run a command with resolved env vars injected'
    'printenv:resolve and print a single env var value'
    'scan:scan project files for plaintext sensitive values'
    'encrypt:encrypt sensitive plaintext values'
    'reveal:securely view or copy a sensitive value'
    'lock:re-lock revealed sensitive values'
    'audit:audit resolved config for issues'
    'cache:manage the resolution cache'
    'typegen:generate type definitions for env vars'
    'telemetry:enable or disable telemetry'
    'generate-key:generate a new device-local encryption key'
    'help:show help'
  )
  _describe -t commands 'varlock command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :_varlock_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '--agent[run in non-interactive agent mode]' && ret=0
        ;;
      load)
        _arguments -s -S \
          '--format=[output format]:format:(pretty json env shell json-full)' \
          '--agent[run in non-interactive agent mode]' \
          '--compact[compact output]' \
          '--show-all[show all items including non-sensitive]' \
          '--env=[environment to load]:env:' \
          '*'{-p,--path=}'[path to a .env file or directory]:path:_files' \
          '--clear-cache[clear the resolution cache first]' \
          '--skip-cache[bypass the resolution cache]' && ret=0
        ;;
      run)
        _arguments -s -S \
          '--redact-stdout[redact sensitive values in stdout]' \
          '--no-redact-stdout[disable output redaction]' \
          '--no-inject-graph[do not inject serialized config graph]' \
          '*'{-p,--path=}'[path to a .env file or directory]:path:_files' \
          '--clear-cache[clear the resolution cache first]' \
          '--skip-cache[bypass the resolution cache]' \
          '*::command:_command_names -e' && ret=0
        ;;
      printenv)
        _arguments -s -S \
          '*'{-p,--path=}'[path to a .env file or directory]:path:_files' \
          '--clear-cache[clear the resolution cache first]' \
          '--skip-cache[bypass the resolution cache]' \
          '1:env var:' && ret=0
        ;;
      scan)
        _arguments -s -S \
          '--staged[scan only staged files]' \
          '--include-ignored[also scan git-ignored files]' \
          '--install-hook[install a pre-commit scan hook]' \
          '*'{-p,--path=}'[path to a .env file or directory]:path:_files' && ret=0
        ;;
      encrypt)
        _arguments -s -S \
          '--file=[encrypt all sensitive values in this .env file in-place]:file:_files' && ret=0
        ;;
      reveal)
        _arguments -s -S \
          '--copy[copy the value to the clipboard]' \
          '(-p --path)'{-p,--path=}'[path to a .env file or directory]:path:_files' \
          '--env=[environment to use]:env:' \
          '1:env var:' && ret=0
        ;;
      audit)
        _arguments -s -S \
          '*'{-p,--path=}'[path to a .env file or directory]:path:_files' \
          '*'{-i,--ignore=}'[ignore rule]:rule:' && ret=0
        ;;
      cache)
        _arguments -s -S \
          '--plugin=[scope cache operation to a plugin]:plugin:' \
          '(-y --yes)'{-y,--yes}'[assume yes to prompts]' && ret=0
        ;;
      typegen)
        _arguments -s -S \
          '*'{-p,--path=}'[path to a .env file or directory]:path:_files' && ret=0
        ;;
      telemetry)
        _arguments -s -S \
          '1:action:(enable disable)' && ret=0
        ;;
    esac
    ;;
esac

return ret
