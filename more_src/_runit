#compdef sv
# Documentation: https://smarden.org/runit/sv.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-v[wait up to 7 seconds for up/down/term/once/cont/exit]' \
  '-w+[override default 7s timeout]:seconds' \
  '1:command:(status up down once pause cont hup alarm interrupt quit 1 2 term kill exit start stop reload restart shutdown force-stop force-reload force-restart force-shutdown try-restart check)' \
  '*:service:_files -W /etc/service -/' && return 0
