#compdef mun
# =============================================================================
# mun — the Mun programming language compiler, runtime, and SDK.  Mun is a
#       small embeddable language designed for FAST ITERATION — specifically,
#       hot-reload of game logic in production game engines.  Mun's
#       primary use case is replacing Lua / Squirrel / AngelScript in
#       indie game projects with a strongly-typed compiled-to-native-via-
#       LLVM alternative that maintains the same edit-and-continue
#       development loop.
#
# Author:  The Mun team (Bas Zalmstra and contributors)
# Source:  https://github.com/mun-lang/mun
# CLI:     crates/mun/src/lib.rs (uses clap-derive)
# Library: clap-rs/clap (with derive feature) — clap-derive (R275)
# License: MIT or Apache-2.0
# Status:  Active — 2,117+ stars; recommended embedded scripting language
#          for Rust game engines that want hot-reload without GC, and a
#          notable case study in the "fast game-scripting iteration" niche.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — MUN IS NOW LANGUAGE 57
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy crosses from
# 56 to 57 documented languages.  Mun joins the canonical roster alongside:
# Rust, Go, TypeScript-Node, Python, Ruby, Perl, C, C++, Lua, Java, Kotlin,
# Scala, Haskell, OCaml, Elixir, Erlang, Clojure, Common Lisp, Scheme/Racket,
# Julia, Crystal, Pony, Nim, Zig, V, Swift, R, Dart, Fortran, Tcl, Ada, Janet,
# D, Picat, BQN, Frege, Lobster, Curry, Mercury, Wren, Idris2, F#, Jakt,
# Ur/Web, Beluga, REBOL, Io, Pure, Yeti, Whiley, Boogie, Beef, Luau, Tact,
# min, Daml, and now Mun.  mun is documented as the FIRST Mun CLI library
# variant in the taxonomy (Rust clap-derive via the Mun compiler driver
# binary written in Rust) — bringing the total to 236 cross-language CLI
# library variants.
# -----------------------------------------------------------------------------
#
# WHAT IS MUN AND WHY DOES IT WARRANT ITS OWN LANGUAGE DOCUMENTATION CATEGORY?
#
# Mun is a programming language designed to FILL A SPECIFIC NICHE: hot-
# reloadable game scripting with native performance and strong typing.
# It exists because every alternative for the same niche has weaknesses:
#
#   * Lua — fast and embeddable but dynamically typed; type errors only
#     surface at runtime when the bug runs.
#   * AngelScript — strongly typed but slow; ~10x slower than C++.
#   * GameMonkey / Squirrel — niche, small community.
#   * Wren — fast and elegant but no hot-reload; you restart the engine
#     to pick up script changes.
#   * Compiled-to-bytecode (CSharp/F#/Java) — fast but JIT warmup time
#     is incompatible with frame-time-critical hot-reload.
#
# Mun fills the gap with:
#
#   * NATIVE LLVM CODEGEN — Mun compiles ahead-of-time to native machine
#     code via the same LLVM toolchain that powers rustc / clang.  No
#     interpreter overhead.
#   * HOT-RELOAD AS THE PRIMARY DESIGN CONSTRAINT — Mun's memory model
#     was DESIGNED around the requirement that recompiling and reloading
#     a function must work without restarting the host process.  Function
#     pointers are indirected through a runtime table so hot-swapping
#     a function updates the indirection rather than requiring relocation
#     of every caller.  This is the FIRST documented language whose
#     PRIMARY DESIGN CONSTRAINT is "must support function-level hot-
#     reload at frame rate."
#   * STRUCT INDIRECTION FOR FIELD HOT-RELOAD — Mun struct layouts go
#     through a runtime "memory mapping" table, so adding/removing a
#     field at edit time updates the mapping and all existing struct
#     instances get migrated forward.  Most languages with hot-reload
#     (Erlang/Elixir) tolerate only function-level changes; Mun extends
#     hot-reload to DATA STRUCTURE LAYOUT CHANGES.
#   * GARBAGE-COLLECTED but TIME-BOUNDED — Mun's GC is an incremental
#     mark-and-sweep designed to fit within frame budgets.  No stop-
#     the-world pauses longer than ~1ms on typical workloads.
#   * EMBEDDABLE-FIRST — the Mun runtime is a C ABI library (~150KB)
#     that game engines link against.  Mun source compiles to "munlibs"
#     which the host loads at runtime.
#
# Mun is distinct from every language documented in the corpus because:
#
#   * It is the FIRST documented language whose PRIMARY USE CASE is
#     EMBEDDED GAME SCRIPTING WITH HOT-RELOAD.  Lua (in corpus) is
#     embeddable but dynamic.  Wren (R...) is embeddable but no hot-
#     reload.  Mun is purpose-built for the niche.
#   * Its STRUCT MEMORY MAPPING for field hot-reload is unique among
#     documented languages.  Erlang's BEAM has function hot-reload but
#     records are immutable; mutating a field's offset would invalidate
#     all existing record instances.  Mun's mapping table makes
#     field-layout changes atomic across the runtime.
#   * Its INCREMENTAL FRAME-BUDGET-AWARE GC is closer to console-game
#     allocator designs than to traditional GC implementations.
#
# Mun's IMPLEMENTATION LANGUAGE is Rust — the mun compiler driver
# (crates/mun in the source tree) is written in Rust, compiled to a
# native binary, and links against the same LLVM toolchain rustc uses.
# The CLI parser uses clap-derive (same as R275 clap-derive's documented
# entry for native Rust binaries).
#
# -----------------------------------------------------------------------------
# MUN'S CLI LIBRARY — Rust clap-derive (via the Mun compiler binary)
# -----------------------------------------------------------------------------
#
# The Mun compiler binary is written in Rust and uses **clap (with the
# derive feature)** — the same library family documented in R275 (clap-
# derive), R440 (clap-builder), R486 (structopt — clap 2.x predecessor),
# R494 (structopt-toml — TOML extension).  Documenting Mun's CLI here
# captures the FIRST MUN-LANGUAGE entry in the taxonomy: Mun's compiler
# driver uses clap-derive as its argv parser.
#
# The Mun-specific Args definition (verbatim from crates/mun/src/lib.rs):
#
#     use clap::{Parser, Subcommand};
#
#     #[derive(Parser)]
#     #[clap(author, version, about, long_about = None)]
#     struct Args {
#         #[clap(subcommand)]
#         command: Command,
#     }
#
#     #[derive(Subcommand)]
#     enum Command {
#         /// Run the Mun language server
#         LanguageServer(language_server::Args),
#
#         /// Compiles a local Mun file into a module
#         Build(build::Args),
#
#         /// Create a new Mun project at the specified location
#         New(new::Args),
#
#         /// Initialize a new Mun project in the specified location
#         Init(init::Args),
#
#         /// Invoke a function from a munlib
#         Start(start::Args),
#     }
#
# Each subcommand has its own typed `Args` struct, and clap-derive
# dispatches based on the subcommand name.
#
# The `build` subcommand's Args (verbatim from ops/build.rs):
#
#     #[derive(clap::Args)]
#     pub struct Args {
#         /// Path to the manifest of the project
#         #[clap(long)]
#         manifest_path: Option<PathBuf>,
#
#         /// Optimization level [0,3]
#         #[clap(long, short = 'O', default_value_t = 2)]
#         opt_level: u8,
#
#         /// Use color in output
#         #[clap(long, value_enum)]
#         color: Option<UseColor>,
#
#         /// Emits IR instead of a *.munlib
#         #[clap(long)]
#         emit_ir: bool,
#
#         /// Run the compiler in watch mode
#         #[clap(long)]
#         watch: bool,
#
#         /// Target for machine code
#         #[clap(long, value_parser=parse_target_triple)]
#         target: Option<Target>,
#     }
#
# This is canonical clap-derive — same patterns used by ~80% of Rust
# CLIs today.  Documenting clap-derive's usage in MUN's specific
# context captures the language → library mapping for the taxonomy.
#
# Why document this as a separate language entry?
#
#   1. Mun is a DISTINCT LANGUAGE — different from any other documented
#      language in design intent (hot-reload-first), implementation
#      strategy (LLVM native via runtime indirection), and target use
#      case (game-scripting niche).
#
#   2. The Mun-clap-derive pair is a NEW LANGUAGE×LIBRARY pair in the
#      cross-language taxonomy.  The variant count tracks pairs, not
#      libraries alone — so Mun adding clap-derive to its language
#      column increments the variant total.
#
#   3. clap-derive is the DEFAULT choice for new Rust-implemented
#      language compilers (cairo R489-attempted, jakt R457, mun THIS,
#      and many others).  Documenting Mun's specific use confirms the
#      pattern: when a new programming language is implemented in Rust,
#      its compiler driver almost universally chooses clap-derive over
#      any of the more exotic Rust CLI alternatives.
#
# -----------------------------------------------------------------------------
# MUN'S CLI SURFACE (verbatim from crates/mun/src/lib.rs)
# -----------------------------------------------------------------------------
#
# USAGE:
#   mun <SUBCOMMAND> [OPTIONS]
#
# Subcommands:
#   build [OPTIONS]               Compile a local Mun project into a module
#   new <PATH>                    Create a new Mun project at PATH
#   init [PATH]                   Initialize Mun in PATH or cwd
#   start <LIBRARY> [ENTRY]       Invoke function from a munlib
#                                 (default entry: "main")
#   language-server               Run the Mun LSP language server
#
# build subcommand options:
#   --manifest-path <FILE>        Path to project mun.toml manifest
#                                 (default: search up from cwd)
#   -O, --opt-level <0-3>         Optimization level (default: 2)
#                                 0 = None, 1 = Less, 2 = Default,
#                                 3 = Aggressive
#   --color <auto|enable|disable> Use color in compiler output
#                                 (default: respects $MUN_TERMINAL_COLOR
#                                  env var, then auto)
#   --emit-ir                     Emit LLVM IR instead of *.munlib
#                                 (useful for debugging codegen)
#   --watch                       Watch input files and recompile on change
#                                 (the canonical hot-reload development
#                                  workflow)
#   --target <TRIPLE>             Target triple for machine code (default:
#                                 host triple; useful for cross-compilation)
#
# new / init subcommand:
#   <PATH>                        Project directory path (required for new,
#                                 optional for init — defaults to cwd)
#
# start subcommand:
#   <LIBRARY>                     Path to the compiled .munlib file
#   [ENTRY]                       Function name to invoke (default: "main")
#
# Global:
#   --help                        Print help
#   --version                     Print version
#
# Environment variables:
#   MUN_TERMINAL_COLOR            Override --color (disable|enable|auto)
#
# Manifest file (mun.toml):
#   [package]
#   name = "my-game-scripts"
#   version = "0.1.0"
#   [dependencies]
#   physics = "1.0"
#
# Typical workflow:
#   $ mun new my-scripts        # scaffold project
#   $ cd my-scripts && mun init # init existing dir
#   $ mun build --watch          # build + hot-reload watch
#   $ mun start target/my-scripts.munlib main
#
# =============================================================================

_mun() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands colors opt_levels

    subcommands=(
        'build:compile a local Mun project into a module'
        'new:create a new Mun project at PATH'
        'init:initialize Mun in PATH or cwd'
        'start:invoke function from a munlib'
        'language-server:run the Mun LSP language server'
    )

    colors=(
        'auto:respect terminal capabilities (default)'
        'enable:force color on'
        'disable:force color off'
    )

    opt_levels=(
        '0:no optimization'
        '1:less optimization'
        '2:default optimization (default)'
        '3:aggressive optimization'
    )

    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t subcommands 'mun subcommand' subcommands && ret=0
            ;;
        (args)
            case $line[1] in
                (build)
                    _arguments \
                        '--manifest-path[path to project mun.toml manifest]:manifest:_files -g "*.toml"' \
                        '(-O --opt-level)'{-O,--opt-level}'[optimization level]:level:->opt' \
                        '--color[use color in compiler output]:color:->color' \
                        '--emit-ir[emit LLVM IR instead of *.munlib]' \
                        '--watch[watch input files and recompile (hot-reload)]' \
                        '--target[target triple for machine code]:triple:' \
                        && ret=0
                    ;;
                (new)
                    _files -/  && ret=0
                    ;;
                (init)
                    _files -/  && ret=0
                    ;;
                (start)
                    _arguments \
                        ':munlib file:_files -g "*.munlib"' \
                        ':entry function (default main):' \
                        && ret=0
                    ;;
                (language-server)
                    ;;
            esac
            ;;
    esac

    case $state in
        (color)
            _describe -t colors 'output color mode' colors && ret=0
            ;;
        (opt)
            _describe -t opt_levels 'optimization level' opt_levels && ret=0
            ;;
    esac

    return ret
}

_mun "$@"
