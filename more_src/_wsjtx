#compdef wsjtx
# Documentation: https://manpages.debian.org/bookworm/wsjtx/wsjtx.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm wsjtx(1) manpage OPTIONS. Real flags:
# -r/--rig-name, -v/--version, -h/--help, --test-mode.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -c/--config and -t short for --test-mode (--test-mode is
# long-only); fabricated jt9/jt65code/ft8code aliases (those are
# separate binaries with separate completion needs).

# wsjtx: WSJT-X amateur radio digital modes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --rig-name)'{-r+,--rig-name=}'[rig name]:name:' \
  '--test-mode[run in test mode]' \
  '--language=[UI language ISO 639-1]:lang:' && ret=0
return ret
