#compdef potential gmx-potential
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-potential.html
# gmx potential: calculate the electrostatic potential across the box

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-n[index file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-o[xvgr/xmgr file (potential)]:file:_files' \
  '-oc[xvgr/xmgr file (charge)]:file:_files' \
  '-of[xvgr/xmgr file (field)]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting mode]:format:(xmgrace xmgr none)' \
  '-d[normal direction on membrane]:dir:(X Y Z)' \
  '-sl[number of slices dividing the box]:int:' \
  '-cb[discard first slices of box for integration]:int:' \
  '-ce[discard last slices of box for integration]:int:' \
  '-tz[translation distance along box direction]:real:' \
  '-spherical[calculate in spherical coordinates]' \
  '-ng[number of groups to consider]:int:' \
  '-center[perform binning relative to box center]' \
  '-symm[symmetrize density along axis]' \
  '-correct[assume net zero charge of groups]' && ret=0

return ret
