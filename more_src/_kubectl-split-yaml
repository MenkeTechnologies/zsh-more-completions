#compdef kubectl-split-yaml
# Documentation: https://man.archlinux.org/search?q=kubectl-split-yaml
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --prefix)'{-p+,--prefix=}'[output filename prefix]:prefix:' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '*:args:_default'
