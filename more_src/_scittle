#compdef scittle
# Documentation: https://github.com/babashka/scittle
# Reference accessed: 2026-05-21
# Verified: upstream README. Scittle is a browser-embedded ClojureScript
# interpreter (script-tag based), not a CLI tool. No CLI flags exist.
# Pre-existing --classpath/--js-eval/--node/-e flags were fabricated
# and have been removed.
# STUB: scittle is not a CLI binary.

local curcontext="$curcontext" ret=1
_arguments \
  '*:script file:_files -g "*.(clj|cljs)(-.)"' && ret=0
return ret
