#compdef scittle

# Zsh completion for scittle - Clojure scripting tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-cp --classpath)'{-cp,--classpath}'=[set classpath]:classpath: ' \
  '--js-eval[evaluate JavaScript]' \
  '--node[use Node.js]' \
  '-e[evaluate expression]:expression: ' \
  '*:script file:_files -g "*.clj(-.)"' && ret=0

return ret
