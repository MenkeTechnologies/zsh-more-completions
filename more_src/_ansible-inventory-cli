#compdef ansible-inventory-cli
# _ansible-inventory-cli — Red Hat Ansible inventory display/dump CLI alias (ansible team, Python); argparse
# upstream: https://github.com/ansible/ansible

_ansible-inventory-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-vvv[more verbose]' \
        '--ask-vault-pass[ask vault password]' \
        '--export[export inventory]' \
        '--graph[show graph]' \
        '-y[yaml format]' \
        '--yaml[yaml format]' \
        '--toml[toml format]' \
        '--inventory=+[file]:file:_files' \
        '-i+[file]:file:_files' \
        '--limit=+[subset]:str:' \
        '-l+[subset]:str:' \
        '--list[list hosts]' \
        '--host=+[host]:str:' \
        '--playbook-dir=+[dir]:dir:_files -/' \
        '--output=+[file]:file:_files' \
        '--vars[include vars]' \
        '--vault-id=+[id]:str:' \
        '--vault-password-file=+[file]:file:_files' \
        '*:pattern:'
}

_ansible-inventory-cli "$@"
