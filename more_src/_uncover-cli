#compdef uncover-cli uncover
# _uncover-cli — ProjectDiscovery Uncover uncover-cli CLI command-line frontend wrapping the Uncover quickly discover exposed hosts on the internet using multiple search engines open-source written in Go Shodan Shodan-InternetDB Censys Fofa Hunter QuakeAPI Zoomeye Netlas CriminalIP-Asset-DB Publicwww-search-engine HunterHow ICP-license-search Daydream BinaryEdge ODIN intelligence-x rate-limit field-selection custom-output URL-IP-host-port (ProjectDiscovery team Sandeep Singh Sajan Karuthedath, Go); goflags
# upstream: https://github.com/projectdiscovery/uncover

_uncover-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q+[search query]:str:' \
        '*-q+[query]:str:' \
        '-query=+[q]:str:' \
        '-e+[engines]:e:(shodan shodan-idb censys fofa quake hunter zoomeye netlas criminalip publicwww hunterhow daydream binaryedge odin)' \
        '*-e+[engine]:e:(shodan shodan-idb censys fofa quake hunter zoomeye netlas criminalip publicwww hunterhow daydream binaryedge odin)' \
        '-engine=+[name]:str:' \
        '-l+[limit]:n:' \
        '-limit=+[N]:n:' \
        '-shodan-api+[key]:str:' \
        '-shodan-idb-api+[key]:str:' \
        '-censys-api+[key]:str:' \
        '-fofa-api+[key]:str:' \
        '-quake-api+[key]:str:' \
        '-hunter-api+[key]:str:' \
        '-zoomeye-api+[key]:str:' \
        '-netlas-api+[key]:str:' \
        '-criminalip-api+[key]:str:' \
        '-publicwww-api+[key]:str:' \
        '-hunterhow-api+[key]:str:' \
        '-config+[file]:file:_files -g "*.yaml *.yml"' \
        '-pc+[provider config]:file:_files -g "provider-config.yaml *.yaml"' \
        '-f+[fields]:f:(ip port host url)' \
        '-fields=+[fields]:str:' \
        '-j[JSON output]' \
        '-json[JSON output]' \
        '-raw[raw output]' \
        '-csv[CSV output]' \
        '-o+[output file]:file:_files' \
        '-output=+[file]:file:_files' \
        '-r+[retries]:n:' \
        '-retries=+[N]:n:' \
        '-rl+[rate limit per min]:n:' \
        '-timeout+[sec]:n:' \
        '-silent[silent]' \
        '-nc[no color]' \
        '-no-color[no color]' \
        '-up[update]' \
        '-duc[disable update check]' \
        '*:query:'
}

_uncover-cli "$@"
