#compdef vcfcombine
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfcombine.md
# Combine multiple VCF files, merging records by position

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-r --region)'{-r,--region}'[region specifier (chrN:x-y) to bound the merge]:region' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
