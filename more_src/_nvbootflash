#compdef nvbootflash
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# nvbootflash: NVIDIA Tegra bootloader flasher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-d[device]:dev:' \
  '-c[config]:file:_files' \
  '-i[image]:file:_files' \
  '*::nvbootflash args:_files' && ret=0
return ret
