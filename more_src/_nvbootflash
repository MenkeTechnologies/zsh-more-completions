#compdef nvbootflash
# Documentation: https://man.archlinux.org/search?q=nvbootflash
# Reference accessed: 2026-05-16

# nvbootflash: NVIDIA Tegra bootloader flasher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-d[device]:dev:' \
  '-c[config]:file:_files' \
  '-i[image]:file:_files' \
  '*::nvbootflash args:_files' && ret=0
return ret
