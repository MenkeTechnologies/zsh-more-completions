#compdef tuist-cli
# _tuist-cli — Pedro Piñera Tuist Xcode at scale CLI alias (Tuist team, Swift); custom argparse
# upstream: https://github.com/tuist/tuist

_tuist-cli() {
    local -a sub=(
        'analytics:analytics commands'
        'auth:auth commands'
        'build:build a project'
        'cache:cache commands'
        'cancel:cancel a remote build'
        'cleanup:clean Tuist data'
        'clean:clean cache and build artifacts'
        'completion:generate shell completion'
        'create-issue:open issue creator'
        'dump:dump project model'
        'edit:edit project manifests'
        'generate:generate Xcode project'
        'graph:export project graph'
        'init:scaffold project'
        'install:install dependencies'
        'list:list installable templates'
        'logout:logout'
        'login:login'
        'migration:migrate from Xcode'
        'plugin:plugin commands'
        'project:project commands'
        'release:release commands'
        'run:run a target'
        'scaffold:scaffold from template'
        'share:create share link'
        'signal:cancel a remote build'
        'test:run tests'
        'session:show session info'
        'upgrade:upgrade Tuist'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--path=+[project path]:dir:_files -/' \
        '-p+[project path]:dir:_files -/' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tuist subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments \
                    '--no-open[no open project]' \
                    '-n[no open project]' \
                    '--no-cache[no cache]' \
                    '--profile=+[profile]:str:' \
                    '*:source:_files' ;;
                init) _arguments \
                    '--template=+[template]:str:' \
                    '-t+[template]:str:' \
                    '--name=+[name]:str:' \
                    '--platform=+[platform]:p:(iOS macOS tvOS watchOS visionOS)' ;;
                build|test|run) _arguments \
                    '--configuration=+[configuration]:c:(debug release)' \
                    '-c+[configuration]:c:(debug release)' \
                    '--scheme=+[scheme]:str:' \
                    '-s+[scheme]:str:' \
                    '--device=+[device]:str:' \
                    '-d+[device]:str:' \
                    '--platform=+[platform]:p:(iOS macOS tvOS watchOS visionOS)' \
                    '--build-output-path=+[build output path]:dir:_files -/' \
                    '--rosetta[run under rosetta]' \
                    '--clean[clean]' \
                    '--generate[generate before action]' \
                    '*:arg:' ;;
                edit) _arguments \
                    '--permanent[permanent]' \
                    '-P[permanent]' \
                    '--only-current-directory[only current directory]' ;;
                graph) _arguments \
                    '--format=+[format]:fmt:(dot json yaml png svg)' \
                    '--algorithm=+[algorithm]:a:(dot neato circo fdp osage sfdp twopi)' \
                    '--output-path=+[output path]:dir:_files -/' \
                    '--skip-test-targets[skip test targets]' \
                    '--skip-external-dependencies[skip external dependencies]' \
                    '--platform=+[platform]:p:(iOS macOS tvOS watchOS visionOS)' \
                    '*:target:' ;;
                install) _arguments \
                    '--update[update dependencies]' \
                    '-u[update dependencies]' ;;
                plugin) _arguments \
                    '1:cmd:(archive build run test install)' \
                    '*:arg:' ;;
                cache) _arguments \
                    '1:cmd:(warm print-hashes clean)' \
                    '*:arg:' ;;
                project) _arguments \
                    '1:cmd:(list show tokens update delete)' \
                    '*:arg:' ;;
                migration) _arguments \
                    '1:cmd:(check-empty-build-settings list-targets settings-to-xcconfig targets-by-dependencies)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_tuist-cli "$@"
