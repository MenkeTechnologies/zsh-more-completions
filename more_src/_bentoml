#compdef bentoml

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build:build a Bento from a BentoML service'
      'cloud:manage BentoCloud'
      'containerize:containerize a Bento as OCI image'
      'delete:delete a Bento'
      'deploy:deploy to BentoCloud'
      'deployment:manage deployments'
      'env:print environment information'
      'export:export a Bento to a file'
      'get:get a Bento'
      'import:import a Bento from a file'
      'list:list Bentos'
      'models:manage models'
      'pull:pull a Bento from remote registry'
      'push:push a Bento to remote registry'
      'serve:serve a BentoML service'
      'start:start BentoML API server'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      serve|start)
        _arguments -s -S \
          '--port=[port to serve on]:port' \
          '--host=[host to bind to]:host' \
          '--api-workers=[number of API workers]:workers' \
          '--backlog=[backlog size]:backlog' \
          '--reload[enable auto-reload]' \
          '--working-dir=[working directory]:directory:_directories' \
          '--development[development mode]' \
          '--production[production mode]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:bento or service:_files' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--version=[bento version]:version' \
          '-f[bentofile path]:bentofile:_files -g "*.yaml"' \
          '--bentofile=[bentofile path]:bentofile:_files -g "*.yaml"' \
          '--output=[output format]:format:(default json)' \
          '(- *)'{-h,--help}'[show help]' \
          '1:service:_files -g "*.py"' && ret=0
        ;;
      containerize)
        _arguments -s -S \
          '-t[image tag]:tag' \
          '--docker-image-tag=[image tag]:tag' \
          '--progress=[show build progress]:progress:(auto plain tty)' \
          '--add-host=[add hosts]:host' \
          '--label=[set label]:label' \
          '(- *)'{-h,--help}'[show help]' \
          '1:bento' && ret=0
        ;;
      list)
        _arguments -s -S \
          '--output=[output format]:format:(default json yaml table)' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      models)
        _arguments -s -S \
          '1:action:(delete export get import list pull push)' && ret=0
        ;;
    esac
    ;;
esac

return ret
