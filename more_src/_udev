#compdef udev systemd-udevd
# _udev — systemd-udevd device event manager daemon CLI alias (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_udev() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--daemon[run as daemon]' \
        '-d[run as daemon]' \
        '--debug[debug]' \
        '-D[debug]' \
        '--children-max=+[max worker children]:n:' \
        '-c+[max worker children]:n:' \
        '--exec-delay=+[exec delay seconds]:n:' \
        '-e+[exec delay seconds]:n:' \
        '--event-timeout=+[event timeout seconds]:n:' \
        '-t+[event timeout seconds]:n:' \
        '--resolve-names=+[resolve names]:r:(early late never)' \
        '-N+[resolve names]:r:(early late never)' \
        '*:arg:'
}

_udev "$@"
