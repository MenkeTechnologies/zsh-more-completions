#compdef r.flow
# Documentation: https://grass.osgeo.org/grass-stable/manuals/r.flow.html
# GRASS GIS: construct flowlines from elevation, length and density

local ret=1

_arguments -s \
  '(- *)--help[print usage summary]' \
  '-u[compute upslope flowlines instead of downhill]' \
  '-3[3D lengths instead of 2D]' \
  '-m[use less memory at a performance penalty]' \
  '--overwrite[allow output files to overwrite existing files]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  '--qq[very quiet module output]' \
  '--ui[force launching GUI dialog]' \
  'elevation=[name of input elevation raster map]:map:' \
  'aspect=[name of input aspect raster map]:map:' \
  'barrier=[name of input barrier raster map]:map:' \
  'skip=[number of cells between flowlines]:int:' \
  'bound=[maximum number of segments per flowline]:int:' \
  'flowline=[name for output flow line vector map]:map:' \
  'flowlength=[name for output flow path length raster map]:map:' \
  'flowaccumulation=[name for output flowline density raster map]:map:' \
  '*::arg:_files' && ret=0

return ret
