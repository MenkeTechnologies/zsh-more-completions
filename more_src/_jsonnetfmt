#compdef jsonnetfmt

# Zsh completion for jsonnetfmt (Jsonnet code formatter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --indent)'{-n,--indent}'[number of spaces for indentation]:spaces' \
  '--max-blank-lines[maximum number of consecutive blank lines]:count' \
  '--string-style[string quoting style]:style:((d\:"double quotes" s\:"single quotes" l\:"leave as-is"))' \
  '--comment-style[comment style]:style:((h\:"hash comments" s\:"slash comments" l\:"leave as-is"))' \
  '--sort-imports[sort imports]' \
  '--no-sort-imports[do not sort imports]' \
  '--pad-arrays[pad array brackets with spaces]' \
  '--no-pad-arrays[do not pad array brackets]' \
  '--pad-objects[pad object braces with spaces]' \
  '--no-pad-objects[do not pad object braces]' \
  '--pretty-field-names[use unquoted field names where possible]' \
  '--no-pretty-field-names[always quote field names]' \
  '(-i --in-place)'{-i,--in-place}'[edit file in place]' \
  '--test[test if formatting would change the file]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:jsonnet file:_files -g "*.jsonnet(|lib)(N)"' && ret=0

return ret
