#compdef urlgrab
# Documentation: https://github.com/IAmStoxe/urlgrab
# golang utility to spider through a website with support for JavaScript rendering

local ret=1

_arguments -s -S \
  '-cache-dir[directory to utilize caching]:dir:_files -/' \
  '-debug[extremely verbose debugging output]' \
  '-delay[milliseconds to randomly apply as a delay between requests]:ms' \
  '-depth[maximum limit on the recursion depth of visited URLs]:n' \
  '-headless[display browser while crawling (requires render-js)]' \
  '-ignore-query[strip the query portion of the URL before dedup]' \
  '-ignore-ssl[scrape pages with invalid SSL certificates]' \
  '-js-timeout[seconds before a request to render javascript should timeout]:n' \
  '-json[filename where we should store the output JSON file]:file:_files' \
  '-max-body[limit of the retrieved response body in kilobytes]:kb' \
  '-no-head[do not send HEAD requests prior to GET]' \
  '-output-all[directory where we should store the output files]:dir:_files -/' \
  '-proxy[the SOCKS5 proxy to utilize (comma-separated)]:proxy' \
  '-random-agent[utilize a random user agent string]' \
  '-render-js[utilize a headless chrome instance to render javascript]' \
  '-root-domain[the root domain we should match links against]:domain' \
  '-threads[the number of threads to utilize]:n' \
  '-timeout[seconds before a request should timeout]:n' \
  '-url[the URL where we should start crawling]:url:_urls' \
  '-urls[file path that contains a list of urls (requires root-domain)]:file:_files' \
  '-user-agent[a user agent string]:ua' \
  '-verbose[verbose output]' && ret=0

return ret
