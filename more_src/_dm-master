#compdef dm-master
# _dm-master — DM cluster master node (pingcap/tiflow / Data Migration)
# upstream: https://github.com/pingcap/tiflow/tree/master/dm
# Flags from dm/master/config.go.

_dm-master() {
    local -a args
    args=(
        '(- *)-V[print version and exit]'
        '--print-sample-config[print sample dm-master config file and exit]'
        '--openapi[enable OpenAPI]'
        '--config=[path to TOML config file]:file:_files -g "*.toml"'
        '--master-addr=[master API server and status addr]:addr:'
        '--advertise-addr=[advertise address for client traffic]:addr:'
        '-L+[log level]:level:(debug info warn error fatal)'
        '--log-file=[log file path]:file:_files'
        '--log-format=[log format]:fmt:(text json)'
        '--name=[human-readable name for this dm-master member]:name:'
        '--data-dir=[path to the data directory]:dir:_files -/'
        '--initial-cluster=[initial cluster configuration for bootstrapping]:spec:'
        '--peer-urls=[URLs for peer traffic]:urls:'
        '--advertise-peer-urls=[advertise URLs for peer traffic]:urls:'
        '--join=[join an existing cluster (master-addr list)]:masters:'
        '--auto-compaction-mode=[etcd auto-compaction-mode]:mode:(periodic revision)'
        '--auto-compaction-retention=[etcd auto-compaction-retention]:value:'
        '--ssl-ca=[trusted CA file]:file:_files -g "*.pem"'
        '--ssl-cert=[X509 certificate file]:file:_files -g "*.pem"'
        '--ssl-key=[X509 key file]:file:_files -g "*.pem"'
        '--v1-sources-path=[v1.0.x source config dir for upgrade]:dir:_files -/'
        '--secret-key-path=[hex AES-256 secret-key file for password crypto]:file:_files'
    )
    _arguments -s -S $args
}

_dm-master "$@"
