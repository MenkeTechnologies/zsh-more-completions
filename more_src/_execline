#compdef execline
# execline scripting language interpreter

local ret=1

_arguments -s -S \
  '-e[execute inline script]:script:' \
  '-c[execute command line]:command:' \
  '-p[positional parameters]' \
  '-P[strict positional parameter count]:count:' \
  '-S[shift count for positional parameters]:count:' \
  '-s[shift mode for positional parameters]:count:' \
  '-q[quiet mode]' \
  '1:script file:_files' \
  '*:arguments:' && ret=0

return ret
