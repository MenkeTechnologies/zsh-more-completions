#compdef postsuper

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-c+[main.cf configuration directory]:dir:_files -/' \
  '*-d+[delete message by queue id (- for stdin, ALL for all)]:queue id:' \
  '*-h+[hold message by queue id]:queue id:' \
  '*-H+[release held message by queue id]:queue id:' \
  '*-r+[requeue message by queue id]:queue id:' \
  '-p[purge old temporary files]' \
  '-s[structure check (rename misplaced queue files)]' \
  '-S[strict structure check]' \
  '-v[verbose]' \
  '*:directory:_files -/' && ret=0

return ret
