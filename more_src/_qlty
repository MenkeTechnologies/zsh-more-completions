#compdef qlty

# Zsh completion for qlty (qltysh/qlty, qlty-cli). Globals + public subcommands from qlty-cli/src/arguments.rs (hidden Auth/Build/Githooks/Panic/Parse/Patch/Telemetry/Validate omitted).

local -a sub
sub=(
  'cache:manage CLI cache'
  'check:run linters and analyzers'
  'completions:emit or install shell completions'
  'config:inspect configuration'
  'coverage:view or publish coverage data'
  'dashboard:open Qlty Cloud in the browser'
  'deinit:remove Qlty from the repository'
  'discord:open community Discord'
  'docs:open documentation site'
  'fmt:rewrite files with configured formatters'
  'init:initialize Qlty in the working tree'
  'install:install plugins and tool dependencies'
  'metrics:compute quality metrics'
  'plugins:manage plugins'
  'smells:find duplication and complexity'
  'sources:manage plugin sources'
  'upgrade:upgrade the Qlty CLI'
  'version:print CLI version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--debug[verbose logs]' \
  '--no-upgrade-check[do not check for updates]' \
  '1: :{_describe '\''qlty command'\'' sub}' \
  '*::arguments:_default'
