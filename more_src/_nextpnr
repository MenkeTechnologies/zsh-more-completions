#compdef nextpnr-ice40 nextpnr-ecp5 nextpnr-gowin nextpnr-nexus nextpnr-machxo2 nextpnr-himbaechel nextpnr

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-q[quiet output]' \
  '--quiet[quiet output]' \
  '-l+[log output to file]:log file:_files' \
  '--log=[log output to file]:log file:_files' \
  '--json=[input design JSON]:JSON file:_files -g "*.json"' \
  '--write=[output design JSON]:JSON file:_files -g "*.json"' \
  '--top=[set top module]:module name' \
  '--seed=[set random seed]:seed' \
  '-r[randomize seed]' \
  '--randomize-seed[randomize seed]' \
  '--placer=[placer algorithm]:placer:(sa heap)' \
  '--router=[router algorithm]:router:(router1 router2)' \
  '--router2-tmg-ripup[use timing-driven ripup in router2]' \
  '--slack-redist-iter=[slack redistribution interval]:iterations' \
  '--cstrweight=[constraint weight]:weight' \
  '--pack-only[only run packing]' \
  '--no-place[do not run placement]' \
  '--no-route[do not run routing]' \
  '--ignore-loops[ignore combinational loops]' \
  '--ignore-rel-clk[ignore relative clock constraints]' \
  '--timing-allow-fail[allow timing failures]' \
  '--no-tmdriv[do not use timing-driven placement]' \
  '--sdf=[write SDF file]:SDF file:_files -g "*.sdf"' \
  '--pcf=[constraint file]:PCF file:_files -g "*.pcf"' \
  '--lpf=[constraint file]:LPF file:_files -g "*.lpf"' \
  '--xdc=[constraint file]:XDC file:_files -g "*.xdc"' \
  '--textcfg=[output textual bitstream]:text config:_files' \
  '--asc=[output textual bitstream (iCE40)]:ASC file:_files -g "*.asc"' \
  '--bitstream=[output bitstream]:bitstream file:_files' \
  '--freq=[target frequency in MHz]:frequency' \
  '--report=[write timing report]:report file:_files -g "*.json"' \
  '--detailed-timing-report[print detailed timing report]' \
  '--placed-svg=[write placed SVG]:SVG file:_files -g "*.svg"' \
  '--routed-svg=[write routed SVG]:SVG file:_files -g "*.svg"' \
  '--gui[launch GUI]' \
  '--gui-no-aa[disable GUI antialiasing]' \
  '--threads=[number of threads]:threads' \
  '--parallel-refine[run placement refinement in parallel]' \
  '*:input file:_files -g "*.json"' && ret=0

return ret
