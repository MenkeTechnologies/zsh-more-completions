#compdef gnubackgammon gnubg
# Documentation: https://manpages.debian.org/bookworm/gnubg/gnubg.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm gnubg(6) manpage OPTIONS list (gnubackgammon
# is a symlink to gnubg).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -V/--version flag (gnubg uses -v/--version) and
# -s/--script and -p/--python flag semantics.

# gnubg/gnubackgammon: GNU Backgammon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-b --no-bearoff)'{-b,--no-bearoff}'[do not use bearoff databases]' \
  '(-c --commands)'{-c+,--commands=}'[evaluate commands in FILE and exit]:file:_files' \
  '(-d --datadir)'{-d+,--datadir=}'[data directory]:dir:_files -/' \
  '(-l --lang)'{-l+,--lang=}'[language locale]:lang:' \
  '(-n --new-weights)'{-n,--new-weights}'[create new neural net weights]' \
  '(-q --quiet)'{-q,--quiet}'[disable sound effects]' \
  '(-p --python)'{-p+,--python=}'[evaluate python code in FILE and exit]:file:_files -g "*.py(-.)"' \
  '(-r --no-rc)'{-r,--no-rc}'[do not read .gnubgrc]' \
  '(-t --tty)'{-t,--tty}'[start in tty mode]' \
  '(-w --window-system-only)'{-w,--window-system-only}'[only start GUI]' \
  '*:saved game:_files -g "*.(sgf|mat|pos|bkg)(-.)"' && ret=0
return ret
