#compdef gnubackgammon

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --commands)'{-c,--commands}'+[commands]:cmds:' \
  '(-d --datadir)'{-d,--datadir}'+[data dir]:dir:_files -/' \
  '(-l --lang)'{-l,--lang}'+[language]:lang:' \
  '(-p --python)'{-p,--python}'+[python script]:file:_files -g "*.py"' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-r --no-rc)'{-r,--no-rc}'[do not read rc]' \
  '(-s --script)'{-s,--script}'+[script file]:file:_files' \
  '(-t --tty)'{-t,--tty}'[start in tty mode]' \
  '(-w --window-system-only)'{-w,--window-system-only}'[gui only]' \
  '*:file:_files' && ret=0

return ret
