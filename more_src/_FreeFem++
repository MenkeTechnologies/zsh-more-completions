#compdef FreeFem++
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/FreeFem++.1.html
# FreeFEM finite element PDE solver

local ret=1

_arguments -s -S \
  '-v[verbosity level (0 -- 1000000)]:verbosity' \
  '-fglut[file name for saving all the plots]:file:_files' \
  '-glut[command name of glut (default ffglut)]:command:_command_names' \
  '-nw[no ffglut (no graphics windows)]' \
  '-ne[no edp script output]' \
  '-wait[wait after launching a window]' \
  '-nowait[do not wait after launching a window]' \
  '-cd[change dir to script dir]' \
  '-f[script file]:script:_files -g "*.edp"' \
  '*:script:_files -g "*.edp"' && ret=0

return ret
