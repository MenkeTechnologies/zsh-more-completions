#compdef pvcreate
# _pvcreate — initialize a disk or partition as PV (LVM2); writes LVM label to make it usable in a vg
# upstream: https://gitlab.com/lvmteam/lvm2

_pvcreate() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-y --yes)'{-y,--yes}'[no prompts]' \
        '(-u --uuid)'{-u,--uuid}'+[uuid]:uuid:' \
        '(-Z --zero)'{-Z,--zero}'+[zero first sector]:bool:(y n)' \
        '--bootloaderareasize+[bootloader area size]:size:' \
        '--dataalignment+[data alignment]:size:' \
        '--dataalignmentoffset+[data alignment offset]:size:' \
        '--labelsector+[label sector]:n:' \
        '--metadatasize+[metadata size]:size:' \
        '--metadatatype+[metadata type]:type:(lvm1 lvm2)' \
        '--metadataignore+[ignore metadata]:bool:(y n)' \
        '--norestorefile[ignore restore]' \
        '--restorefile+[restore from backup]:file:_files' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '--setphysicalvolumesize+[force size]:size:' \
        '--pvmetadatacopies+[metadata copies]:n:' \
        '--pvmetadatasize+[metadata size]:size:' \
        '*:device:_files'
}

_pvcreate "$@"
