#compdef openapi-generator-cli openapi-generator

# Zsh completion for openapi-generator-cli - OpenAPI code generator

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)--version[display version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'generate:Generate code from an OpenAPI specification'
      'validate:Validate an OpenAPI specification'
      'list:List available generators'
      'config-help:Show configuration help for a generator'
      'meta:Generate a new generator module'
      'version:Show version information'
      'completion:Generate shell completion script'
      'help:Display help information'
      'author:Utilities for authoring generators'
      'batch:Generate code in batch via external configs'
    )
    _describe -t commands 'openapi-generator commands' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      generate)
        _arguments -s -S \
          '(-i --input-spec)'{-i,--input-spec}'=[path to OpenAPI spec]:spec file:_files -g "*.{yaml,yml,json}"' \
          '(-g --generator-name)'{-g,--generator-name}'=[generator name]:generator:' \
          '(-o --output)'{-o,--output}'=[output directory]:output directory:_directories' \
          '(-t --template-dir)'{-t,--template-dir}'=[template directory]:template directory:_directories' \
          '(-c --config)'{-c,--config}'=[configuration file]:config file:_files -g "*.{yaml,yml,json}"' \
          '(-a --auth)'{-a,--auth}'=[authorization headers]:auth:' \
          '(-s --skip-validate-spec)'{-s,--skip-validate-spec}'[skip validation of the spec]' \
          '--api-package=[package for generated API classes]:package:' \
          '--model-package=[package for generated model classes]:package:' \
          '--invoker-package=[package for generated invoker classes]:package:' \
          '--group-id=[group ID for generated artifact]:group id:' \
          '--artifact-id=[artifact ID for generated artifact]:artifact id:' \
          '--artifact-version=[artifact version]:version:' \
          '--library=[library template]:library:' \
          '--git-user-id=[Git user ID]:user id:' \
          '--git-repo-id=[Git repo ID]:repo id:' \
          '--git-host=[Git host]:host:' \
          '(-p --additional-properties)'{-p,--additional-properties}'=[additional generator properties]:properties:' \
          '--type-mappings=[type mappings]:mappings:' \
          '--import-mappings=[import mappings]:mappings:' \
          '--reserved-words-mappings=[reserved words mappings]:mappings:' \
          '--language-specific-primitives=[language-specific primitives]:primitives:' \
          '--server-variables=[server variables]:variables:' \
          '--enable-post-process-file[enable post-processing of files]' \
          '--generate-alias-as-model[generate alias as model]' \
          '--minimal-update[only update changed files]' \
          '--strict-spec[treat spec warnings as errors]' \
          '(-e --engine)'{-e,--engine}'=[template engine]:engine:(mustache handlebars)' \
          '--global-property=[global properties]:properties:' \
          '--dry-run[dry run, output only]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '(-i --input-spec)'{-i,--input-spec}'=[path to OpenAPI spec]:spec file:_files -g "*.{yaml,yml,json}"' \
          '--recommend[provide recommendations]' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-s --short)'{-s,--short}'[short output]' \
          '(-i --include)'{-i,--include}'=[include category]:category:(all stable beta experimental deprecated)' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      config-help)
        _arguments -s -S \
          '(-g --generator-name)'{-g,--generator-name}'=[generator name]:generator:' \
          '(-f --format)'{-f,--format}'=[output format]:format:(text markdown yamlsample)' \
          '--named-header[include named header in output]' \
          '--full-details[show full details]' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      meta)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'=[output directory]:output directory:_directories' \
          '(-n --name)'{-n,--name}'=[generator name]:name:' \
          '(-p --package)'{-p,--package}'=[package name]:package:' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
