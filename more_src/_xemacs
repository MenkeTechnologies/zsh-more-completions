#compdef xemacs

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-q[no init file]' \
  '--no-init-file[no init file]' \
  '-no-site-file[no site file]' \
  '-debug-init[debug init]' \
  '-batch[batch mode]' \
  '-no-shared-memory[no shared memory]' \
  '-l+[load file]:file:_files -g "*.el"' \
  '-load+[load file]:file:_files -g "*.el"' \
  '-f+[function]:fn:' \
  '-funcall+[function]:fn:' \
  '-eval+[expression]:expr:' \
  '-execute+[expression]:expr:' \
  '-insert+[file]:file:_files' \
  '-find-file+[file]:file:_files' \
  '-visit+[file]:file:_files' \
  '-kill[kill at end]' \
  '-vanilla[vanilla mode]' \
  '-no-autoloads[no autoloads]' \
  '-no-early-packages[no early packages]' \
  '-no-packages[no packages]' \
  '-user+[user init]:user:_users' \
  '-u+[user init]:user:_users' \
  '-fg+[foreground]:color:' \
  '-bg+[background]:color:' \
  '-fn+[font]:font:' \
  '-d+[display]:disp:' \
  '-name+[application name]:name:' \
  '-title+[window title]:title:' \
  '*:file:_files' && ret=0

return ret
