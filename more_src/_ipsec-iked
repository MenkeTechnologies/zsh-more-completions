#compdef ipsec-iked iked
# Documentation: https://man.openbsd.org/iked.8
# Reference accessed: 2026-05-16
# Verified: OpenBSD iked(8) manpage.

# iked: OpenBSD IKEv2 daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '*-D[define macro for cmd line]:macro=value:' \
  '-d[do not daemonize, log to stderr]' \
  '-f[config file (default /etc/iked.conf)]:file:_files' \
  '-n[configtest mode]' \
  '-p[UDP encapsulation port (implies -t)]:port:' \
  '-S[start in passive mode]' \
  '-s[control socket (default /var/run/iked.sock)]:socket:_files' \
  '-T[disable NAT-Traversal]' \
  '-t[enforce NAT-Traversal]' \
  '-V[show version]' \
  '*-v[more verbose (repeatable)]' && ret=0
return ret
