#compdef cosmic-ray

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[Show help]' \
  '1:command:->cmds' \
  '*::arg:->args' \
  && ret=0

case $state in
  cmds)
    local -a commands=(
      'init:Initialize a mutation testing session'
      'baseline:Verify that tests pass on unmutated code'
      'exec:Execute mutation testing'
      'report:Report on mutation testing results'
      'operators:List available mutation operators'
      'worker:Internal worker process'
    )
    _describe -t commands 'cosmic-ray command' commands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--config[Configuration file]:file:_files' \
          '--timeout[Test suite timeout in seconds]:seconds:' \
          ':session file:_files' \
          && ret=0
        ;;
      baseline)
        _arguments \
          ':session file:_files' \
          && ret=0
        ;;
      exec)
        _arguments \
          '--config[Configuration file]:file:_files' \
          '--timeout[Test suite timeout in seconds]:seconds:' \
          '--no-local-import[Do not allow local imports]' \
          '--dist[Distribute testing across workers]' \
          ':session file:_files' \
          && ret=0
        ;;
      report)
        _arguments \
          '--config[Configuration file]:file:_files' \
          '--show-pending[Show pending mutations]' \
          '--show-output[Show test output]' \
          ':session file:_files' \
          && ret=0
        ;;
      operators)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
