#compdef ConvertSurface
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/ConvertSurface.html
# Read and write surfaces in different formats

local ret=1

_arguments -s \
  '-i[input surface, type auto-detected]:surface:_files' \
  '-i_TYPE[input surface with type]:surface:_files' \
  '-ipar_TYPE[parent surface for patch output]:surface:_files' \
  '-o[output surface, type auto-detected]:surface:_files' \
  '-o_TYPE[output surface format]:surface:_files' \
  '-sv[surface volume for alignment]:dataset:_files' \
  '-orient_out[output AFNI coordinate orientation]:orient' \
  '-native[write in format native coordinate system]' \
  '-tlrc[apply Talairach transform]' \
  '-MNI_rai[apply MNI transform to RAI coords]' \
  '-MNI_lpi[apply MNI transform to LPI coords]' \
  '-acpc[apply ACPC transform]' \
  '-make_consistent[ensure proper triangle winding]' \
  '-flip_orient[reverse triangle winding]' \
  '-patch2surf[convert patch to full surface]' \
  '-merge_surfs[combine surfaces into one]' \
  '-radial_to_sphere[scale nodes to radius]:radius' \
  '-xmat_1D[apply affine transform from matrix]:file:_files' \
  '-ixmat_1D[apply inverse transform from matrix]:file:_files' \
  '-XYZscale[scale coordinates]:factors' \
  '-xcenter[rotation center]:center' \
  '-polar_decomp[apply polar decomposition]' \
  '-node_depth[project nodes and output depth]' \
  '-pc_proj[project onto principal components]' \
  '-onestate[make all surfaces appear at once]' \
  '-anatomical[label surfaces as anatomically correct]' \
  '-novolreg[ignore volume registration]' \
  '-noxform[same as -novolreg]' \
  '-seed[seed random generator]:seed' \
  '-setenv[set environment variable]:var' \
  '-trace[debug and memory tracing]' \
  '-TRACE[extreme tracing]' \
  '-nomall[disable memory tracing]' \
  '-yesmall[enable memory tracing]' \
  '*:surface:_files' && ret=0

return ret
