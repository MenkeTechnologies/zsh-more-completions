#compdef testcafe

# Zsh completion for TestCafe - end-to-end testing framework

local curcontext="$curcontext" state line ret=1

_testcafe_browsers() {
  local -a browsers
  browsers=(
    'chrome:Google Chrome'
    'firefox:Mozilla Firefox'
    'safari:Apple Safari'
    'edge:Microsoft Edge'
    'ie:Internet Explorer'
    'chrome\:headless:Chrome in headless mode'
    'firefox\:headless:Firefox in headless mode'
    'edge\:headless:Edge in headless mode'
    'all:All installed browsers'
  )
  _describe -t browsers 'browser' browsers
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-b --list-browsers)'{-b,--list-browsers}'[list available browsers]' \
  '(-r --reporter)'{-r+,--reporter=}'[reporter type and output file]:reporter:(spec list minimal xunit json)' \
  '(-s --screenshots)'{-s+,--screenshots=}'[screenshots options or base directory]:path:_directories' \
  '--screenshot-path-pattern=[screenshot path pattern]:pattern:' \
  '--screenshot-on-fails[take screenshot on test failure]' \
  '(-S --screenshots-on-fails)'{-S,--screenshots-on-fails}'[take screenshot on test failure]' \
  '(-q --quarantine-mode)'{-q,--quarantine-mode}'[enable quarantine mode for failed tests]' \
  '(-d --debug-mode)'{-d,--debug-mode}'[execute in debug mode]' \
  '--debug-on-fail[pause on test failure]' \
  '(-e --skip-js-errors)'{-e,--skip-js-errors}'[skip JavaScript errors on page]' \
  '--skip-uncaught-errors[skip uncaught errors and unhandled promise rejections]' \
  '(-c --concurrency)'{-c+,--concurrency=}'[number of concurrent browser instances]:number:' \
  '--selector-timeout=[selector timeout in milliseconds]:milliseconds:' \
  '--assertion-timeout=[assertion timeout in milliseconds]:milliseconds:' \
  '--page-load-timeout=[page load timeout in milliseconds]:milliseconds:' \
  '--ajax-request-timeout=[AJAX request timeout in milliseconds]:milliseconds:' \
  '--page-request-timeout=[page request timeout in milliseconds]:milliseconds:' \
  '--browser-init-timeout=[browser initialization timeout in milliseconds]:milliseconds:' \
  '--test-execution-timeout=[test execution timeout in milliseconds]:milliseconds:' \
  '--run-execution-timeout=[total run execution timeout in milliseconds]:milliseconds:' \
  '--speed=[test execution speed (0.01 to 1)]:speed:' \
  '--ports=[custom port range]:ports (port1,port2):' \
  '--hostname=[hostname to use]:hostname:' \
  '--proxy=[proxy server URL]:proxy url:' \
  '--proxy-bypass=[URLs to bypass proxy]:urls:' \
  '--ssl=[SSL options]:ssl options:' \
  '--disable-page-caching[disable page caching]' \
  '--disable-page-reloads[disable page reloads between tests]' \
  '--dev[enable development mode]' \
  '--qr-code[output QR code for remote testing]' \
  '(-sf --stop-on-first-fail)'{-sf,--stop-on-first-fail}'[stop after first test failure]' \
  '--ts-config-path=[TypeScript configuration file path]:path:_files -g "*.json"' \
  '--compiler-options=[compiler options]:options:' \
  '(-t --test)'{-t+,--test=}'[run test by name]:test name:' \
  '(-T --test-grep)'{-T+,--test-grep=}'[run tests matching regex]:regex pattern:' \
  '(-f --fixture)'{-f+,--fixture=}'[run fixture by name]:fixture name:' \
  '(-F --fixture-grep)'{-F+,--fixture-grep=}'[run fixtures matching regex]:regex pattern:' \
  '--test-meta=[filter tests by metadata]:meta (key=value):' \
  '--fixture-meta=[filter fixtures by metadata]:meta (key=value):' \
  '--app=[application launch command]:command:' \
  '--app-init-delay=[delay before running tests after app launch (ms)]:milliseconds:' \
  '--color[enable colored output]' \
  '--no-color[disable colored output]' \
  '--video=[save video of test runs]:directory:_directories' \
  '--video-options=[video recording options]:options:' \
  '--video-encoding-options=[video encoding options]:options:' \
  '--live[enable live mode for debugging]' \
  '--retry-test-pages[retry loading test pages on failure]' \
  '--disable-multiple-windows[disable multiple browser windows]' \
  '--disable-native-automation[disable native automation and use CDP]' \
  '--base-url=[base URL for tests]:url:' \
  '--client-scripts=[inject scripts into tested pages]:scripts:_files -g "*.js"' \
  '1:browser:_testcafe_browsers' \
  '*:test files:_files -g "*.{js,ts,coffee}"' && ret=0

return ret