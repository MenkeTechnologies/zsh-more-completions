#compdef emojify

# Zsh completion for emojify (emoji in terminal strings)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-l --list)'{-l,--list}'[list available emoji codes]' \
  '*:text or file:_files' && ret=0

return ret
