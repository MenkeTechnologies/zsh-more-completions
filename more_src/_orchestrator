#compdef orchestrator orchestrator-client
# _orchestrator — Shlomi Noach orchestrator orchestrator-client CLI command-line frontend wrapping the Orchestrator MySQL high availability replication topology management discovery automated-failover GTID-aware downtime tag-based-rules host pseudo-GTID Slack notification raft-consensus pseudo-fault-tolerance (Shlomi Noach team, Go); custom argparse
# upstream: https://github.com/openark/orchestrator

_orchestrator() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbosity level]:l:(0 1 2 3 4)' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--api=+[url]:str:' \
        '--user=+[user]:str:' \
        '--password=+[password]:str:' \
        '--config=+[file]:file:_files -g "*.conf.json *.json"' \
        '--alias=+[name]:str:' \
        '--cluster=+[name]:str:' \
        '--host=+[host:port]:str:' \
        '--destination=+[host:port]:str:' \
        '--instance=+[host:port]:str:' \
        '--master=+[host:port]:str:' \
        '--reason=+[reason]:str:' \
        '--ignore-key=+[key]:str:' \
        '--ssh-user=+[user]:str:' \
        '--ssh-keypath=+[file]:file:_files' \
        '--owner=+[name]:str:' \
        '--http=+[host:port]:str:' \
        '-c+[command]:str:' \
        '*:command:(discover forget topology relocate move-up move-below relocate-slaves match match-up match-up-slaves take-master make-master make-co-master begin-maintenance end-maintenance set-read-only set-writeable register-candidate flush-binary-logs restart-replica start-replica stop-replica detach-replica reattach-replica recover graceful-master-takeover canonical-hostname discover-instance forget-instance replication-analysis get-cluster-aliases get-cluster-instances-pretty get-cluster-info get-cluster-master clusters-info instance-master-equivalence smart-failover ack-recovery ack-cluster-recoveries ack-instance-recoveries register-listener bulk-promotion-rules promotion-rule replication-lag-time gtid-error-codes which-cluster which-cluster-domain which-cluster-master which-cluster-osc-running-replicas which-cluster-osc-replicas which-cluster-master)'
}

_orchestrator "$@"
