#compdef sha512deep

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'-h'[show help]' \
  '-r[recursive mode]' \
  '-e[show estimated time remaining]' \
  '-l[use relative file paths]' \
  '-b[print bare filename only]' \
  '-z[print file size before hash]' \
  '-0[use null character as line terminator]' \
  '-c[compute mode]' \
  '-x[negative matching file]:file:_files' \
  '-a[audit mode]' \
  '-k[load known hashes file]:file:_files' \
  '-p[piecewise hashing block size]:size' \
  '-j[number of threads]:threads' \
  '-o[expert mode flags]:flags:(f b d l)' \
  '-s[silent mode]' \
  '-v[verbose mode]' \
  '-V[display version]' \
  '-d[output in DFXML]' \
  '*:file:_files' && ret=0

return ret
