#compdef vqmt
# Documentation: https://github.com/Rolinh/VQMT
# Video Quality Measurement Tool (PSNR/SSIM/MS-SSIM/VIFp/PSNR-HVS)

local ret=1

_arguments -s \
  ':original video (raw YUV):_files' \
  ':processed video (raw YUV):_files' \
  ':height:' \
  ':width:' \
  ':number of frames:' \
  ':chroma format:(0 1 2 3)' \
  ':output filename prefix:_files' \
  '*:metric:(PSNR SSIM MSSSIM VIFP PSNRHVS PSNRHVSM)' && ret=0

return ret
