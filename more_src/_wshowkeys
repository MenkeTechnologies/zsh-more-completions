#compdef wshowkeys
# Documentation: https://github.com/ammgws/wshowkeys
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b+[background color #RRGGBB\[AA\]]:color:' \
  '-f+[foreground color #RRGGBB\[AA\]]:color:' \
  '-s+[special key color #RRGGBB\[AA\]]:color:' \
  '-F+[font (Pango format e.g. "monospace 24")]:font:' \
  '-t+[timeout before clearing old keystrokes]:seconds:' \
  '*-a+[anchor edge (may be specified twice)]:position:(top bottom left right)' \
  '-m+[margin in pixels from nearest edge]:margin:' \
  '-o+[output display (unimplemented)]:output:' && ret=0

return ret
