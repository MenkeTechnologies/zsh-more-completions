#compdef wshowkeys

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-b+[background color]:color:' \
  '-f+[font description]:font:' \
  '-F+[foreground text color]:color:' \
  '-s+[font size]:size:' \
  '-t+[timeout in seconds before hiding]:seconds:' \
  '-a+[anchor position]:position:(top bottom left right)' \
  '-m+[margin]:margin:' && ret=0

return ret
