#compdef ktsctl
# Documentation: https://man.archlinux.org/search?q=ktsctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'fetch:fetch grammar/query sources'
  'compile:compile grammar/query sources'
  'install:install compiled artifacts'
  'sync:fetch + compile + install for one or all languages'
  'manage:manage installed grammars/queries (alias: m)'
  'info:show information about installed grammars/queries'
  'list:list available languages from sources'
  'remove:remove an installed grammar/query'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file path]:file:_files -g "*.toml"' \
  '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ktsctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (fetch|compile|install|sync|info|remove)
        _arguments \
          '(-a --all)'{-a,--all}'[apply to all languages]' \
          '(-l --lang)*'{-l+,--lang=}'[target language]:lang:' \
          '*::language:' && ret=0 ;;
      (manage|m)
        _arguments '*::sub:(install remove list info)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
