#compdef curseofwar
# Documentation: https://github.com/a-nikolaev/curseofwar
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Real-time strategy game by Alexey Nikolaev.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-W+[map width]:width:' \
  '-H+[map height]:height:' \
  '-S+[map shape]:shape:(rhombus rect hex)' \
  '-l+[number of countries]:n:' \
  '-i+[inequality level]:level:(0 1 2 3 4)' \
  '-q+[player location quality]:n:' \
  '-r[randomize initial conditions]' \
  '-d+[difficulty]:level:(ee e n h hh)' \
  '-s+[game speed]:speed:(p sss ss s n f ff fff)' \
  '-R+[random seed]:seed:' \
  '-T[show timeline]' \
  '-E+[server mode for N clients]:n:' \
  '-e+[server port]:port:' \
  '-C+[client mode, server IP]:ip:' \
  '-c+[client port]:port:' && ret=0

return ret
