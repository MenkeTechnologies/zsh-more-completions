#compdef impacket-owneredit
# Documentation: https://github.com/fortra/impacket/blob/master/examples/owneredit.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-owneredit: read or modify the owner of an Active Directory object via LDAP
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[enable DEBUG output]' \
  '-ts[add timestamp to logging]' \
  '-use-ldaps[use LDAPS]' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (hex)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-dc-host[domain controller hostname]:host:' \
  '-new-owner[new owner sAMAccountName]:owner:' \
  '-new-owner-sid[new owner SID]:sid:' \
  '-new-owner-dn[new owner DN]:dn:' \
  '-target[target sAMAccountName]:name:' \
  '-target-sid[target SID]:sid:' \
  '-target-dn[target DN]:dn:' \
  '-action[action]:action:(read write)' \
  '1:identity (DOMAIN/user[:password]):' && ret=0
return ret
