#compdef impacket-owneredit

# Impacket owneredit.py: change owner of AD object (LDAP)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-action[action]:action:(read write)' \
  '-target[target sAMAccountName]:target:' \
  '-new-owner[new owner sAMAccountName]:owner:' \
  '-target-dn[target DN]:dn:' \
  '-new-owner-dn[new owner DN]:dn:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-dc-host[DC hostname]:host:' \
  '*:domain/user[:password]:' && ret=0
return ret
