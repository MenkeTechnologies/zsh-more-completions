#compdef dep-tree
# Documentation: https://github.com/gabotechs/dep-tree
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a _dep_tree_cmds
_dep_tree_cmds=(
  'entropy:rank files by dependency entropy'
  'tree:render dependency tree'
  'check:validate dependency rules from .dep-tree.yml'
  'config:inspect merged configuration'
  'explain:explain dependencies between two sets of files'
)

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version information]' \
  '(-c --config)'{-c,--config}'[path to dep-tree config]:config file:_files -g "*.yml"' \
  '--unwrap-exports[trace re-exports to declaration file]' \
  '--js-tsconfig-paths[follow tsconfig paths when resolving imports]' \
  '--js-workspaces[use package.json workspaces for path resolution]' \
  '--python-exclude-conditional-imports[exclude imports in if/try blocks]' \
  '*--only[glob; files outside pattern ignored]:pattern' \
  '*--exclude[glob; matching files ignored]:pattern' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'dep-tree command' _dep_tree_cmds && ret=0
    ;;
  args)
    case $line[1] in
      check)
        _arguments -s -S '*:entry files:_files' && ret=0
        ;;
      tree|entropy)
        _arguments -s -S '*:entry files:_files' && ret=0
        ;;
      explain)
        _arguments -s -S \
          '(-l --overlap-left)'{-l,--overlap-left}'[keep common files on left only]' \
          '(-r --overlap-right)'{-r,--overlap-right}'[keep common files on right only]' \
          '*:globs:_files' && ret=0
        ;;
      config)
        _arguments -s -S '*::arguments:_default' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
