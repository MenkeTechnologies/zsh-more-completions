#compdef openMVG_main_SfMInit_ImageListing
# Documentation: https://github.com/openMVG/openMVG/blob/develop/docs/sphinx/rst/software/SfM/SfM.rst
# openMVG: create SfM_Data scene from an image directory

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --imageDirectory)'{-i,--imageDirectory}'[input image directory]:dir:_files -/' \
  '(-d --sensorWidthDatabase)'{-d,--sensorWidthDatabase}'[sensor width database file]:file:_files' \
  '(-o --outputDirectory)'{-o,--outputDirectory}'[output directory]:dir:_files -/' \
  '(-f --focal)'{-f,--focal}'[camera focal length in pixels]:focal' \
  '(-k --intrinsics)'{-k,--intrinsics}'[intrinsic matrix "f;0;ppx;0;f;ppy;0;0;1"]:intrinsics' \
  '(-c --camera_model)'{-c,--camera_model}'[camera model (1 Pinhole 2 Radial1 3 Radial3 4 Brown 5 Fisheye 7 Spherical)]:model' \
  '(-g --group_camera_model)'{-g,--group_camera_model}'[group shared camera intrinsics]:group' \
  '(-P --use_pose_prior)'{-P,--use_pose_prior}'[use pose prior from GPS EXIF]' \
  '(-W --prior_weights)'{-W,--prior_weights}'[prior weights "x;y;z"]:weights' \
  '(-m --gps_to_xyz_method)'{-m,--gps_to_xyz_method}'[GPS to XYZ method (0 ECEF 1 UTM)]:method' \
  '*:arg:_files' && ret=0

return ret
