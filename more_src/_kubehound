#compdef kubehound
# Documentation: https://kubehound.io/user-guide/common-operations/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'backend:manage the KubeHound backend stack'
      'dump:extract Kubernetes resources from a cluster'
      'ingest:load dumped data into the backend'
      'config:generate or print configuration'
      'server:run the KubeHound server'
      'version:print version information'
      'completion:generate shell completion scripts'
      'help:help about any command'
    )
    _describe -t commands 'kubehound command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      backend)
        local -a backend_cmds=(
          'up:start the backend stack'
          'down:stop the backend stack'
          'reset:restart backend services'
          'wipe:remove backend data (irreversible)'
        )
        _describe -t backend 'backend subcommand' backend_cmds && ret=0
        ;;
      dump)
        _arguments \
          '1:target:(local)' \
          '--no-compress[create uncompressed raw dump]' \
          '*: :_default' && ret=0
        ;;
      ingest)
        _arguments \
          '1:target:(local remote)' \
          '*: :_default' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments '*: :_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
