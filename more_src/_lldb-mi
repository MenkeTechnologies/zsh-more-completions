#compdef lldb-mi
# Documentation: source-direct extraction from upstream
# lldb-tools/lldb-mi src/MIDriverMgr.cpp `if (... strArg) == "--foo"`
# argv-walking checks (hand-rolled strcmp-style argv parser, NOT
# getopt/argparse).
# Reference accessed: 2026-05-30 via gh api.
# llvm lldb-mi R149b — LLDB Machine Interface (MI) driver. The
# GDB/MI-protocol frontend bridge to LLDB used by Eclipse CDT,
# VS Code's lldb-mi adapter, and similar IDEs. Sister tool to
# the lldb/lldb-server family already in the corpus.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--version[show short version string]' \
  '--versionLong[show long version string with build details]' \
  '--interpreter[run as MI interpreter (emit MI protocol on stdout; consumed by IDE clients like Eclipse CDT)]' \
  '--executable=[specify executable for the debug session (alternative to --interpreter)]:file:_files' \
  '--log[enable debug logging to lldb-mi.log in current directory]' \
  '*:executable file or LLDB MI commands:_files'
