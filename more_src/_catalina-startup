#compdef catalina-startup catalina-startup.sh startup.sh
# Documentation: https://github.com/apache/tomcat/blob/main/bin/startup.sh
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Tomcat startup.sh is a thin wrapper that exec's `catalina.sh start "$@"`.
# It forwards args directly to catalina.sh; the only documented flag
# accepted with `start` is -security to enable the Java SecurityManager.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-security[run with the Java SecurityManager]' \
  && ret=0

return ret
