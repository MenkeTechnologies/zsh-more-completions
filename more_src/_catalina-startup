#compdef catalina-startup catalina-startup.sh
# Documentation: https://man.archlinux.org/search?q=catalina-startup
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-config+[config file]:file:_files -g "*.xml"' \
  '-nonaming[disable JNDI naming]' \
  '-help[show usage]' && ret=0

return ret
