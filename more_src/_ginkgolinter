#compdef ginkgolinter
# Documentation: https://github.com/nunnatsa/ginkgolinter
# enforces standards of using ginkgo and gomega

local ret=1

_arguments -s -S \
  '-fix[apply the fix suggestions to the source code]' \
  '--forbid-focus-container[trigger a warning for focused containers]' \
  '--suppress-len-assertion[suppress wrong length and cap assertions warning]' \
  '--suppress-nil-assertion[suppress wrong nil assertion warning]' \
  '--suppress-err-assertion[suppress wrong error assertion warning]' \
  '--suppress-compare-assertion[suppress wrong comparison assertion warning]' \
  '--suppress-async-assertion[suppress function call in async assertion warning]' \
  '--suppress-type-compare-assertion[suppress warning for comparing values from different types]' \
  '--allow-havelen-0[do not warn for HaveLen(0)]' \
  '--force-expect-to[force using Expect with To, ToNot or NotTo]' \
  '--validate-async-intervals[enable validation of async timing intervals]' \
  '--force-succeed[force using the Succeed matcher for error functions]' \
  '--force-assertion-description[force adding description to assertions]' \
  '--force-tonot[force using NotTo or ShouldNot instead of To(Not())]' \
  '-V[print version and exit]' \
  '-c=[display offending line with this many lines of context]:n:' \
  '-flags[print analyzer flags in JSON]' \
  '-json[emit JSON output]' \
  '*:packages:_files' && ret=0

return ret
