#compdef doc8
# Documentation: https://github.com/PyCQA/doc8/blob/main/README.rst
# Style checker for sphinx (or other) rst documentation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message and exit]' \
  '--config=[user config file location]:file:_files' \
  '--allow-long-titles[allow long section titles]' \
  '*--ignore=[ignore the given error code(s)]:code' \
  '--no-sphinx[do not ignore sphinx specific false positives]' \
  '*--ignore-path=[ignore the given directory or file]:path:_files' \
  '*--ignore-path-errors=[ignore the given specific errors in the provided file]:path:_files' \
  '--default-extension=[default file extension to use when a file is found without one]:extension' \
  '--file-encoding=[set input files text encoding]:encoding' \
  '--max-line-length=[maximum allowed line length (default: 79)]:int' \
  '*'{-e+,--extension=}'[check file extensions of the given type]:extension' \
  '(-q --quiet)'{-q,--quiet}'[only print violations]' \
  '(-v --verbose)'{-v,--verbose}'[run in verbose mode]' \
  '--version[show the version and exit]' \
  '*:path:_files' && ret=0

return ret
