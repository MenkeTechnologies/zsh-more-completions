#compdef v.in.db
# Documentation: https://grass.osgeo.org/grass-stable/manuals/v.in.db.html
# GRASS GIS: create new vector point map from a database table with coordinates

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-t[use imported table as attribute table for new map]' \
  '--overwrite[allow output to overwrite existing files]' \
  '--verbose[verbose output]' \
  '--quiet[quiet output]' \
  '--table=[input table name]:table:' \
  '--x=[column containing x coordinate]:column:' \
  '--y=[column containing y coordinate]:column:' \
  '--z=[column containing z coordinate]:column:' \
  '--output=[output vector map]:name:' \
  '--driver=[database driver]:driver:(dbf odbc ogr pg sqlite)' \
  '--database=[database location/connection string]:database:' \
  '--key=[column containing category number]:column:' \
  '--where=[SQL WHERE conditions]:where:' && ret=0

return ret
