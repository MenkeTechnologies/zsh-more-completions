#compdef conftest
# Documentation: https://man.archlinux.org/search?q=conftest
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'completion:generate completion'
  'fmt:format Rego policies'
  'help:show help'
  'parse:parse files'
  'plugin:plugin commands'
  'pull:pull policies from OCI'
  'push:push policies to OCI'
  'test:test against policies'
  'verify:verify Rego policies'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--no-color[no color]' \
  '*--quiet[quiet]' \
  '*--trace[trace]' \
  '*-p+[policy dir/file]:p:_files' \
  '*--policy=[policy]:p:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'conftest command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (test)
        _arguments \
          '*-d+[data file/dir]:d:_files' \
          '*--data=[data]:d:_files' \
          '*--namespace=[namespace]:n:' \
          '*--all-namespaces[all namespaces]' \
          '*--combine[combine inputs]' \
          '*--fail-on-warn[fail on warn]' \
          '*--no-fail[no fail]' \
          '*--ignore=[ignore regex]:re:' \
          '*--input=[input parser]:p:(toml json yaml hcl1 hcl2 dockerfile cue ini cyclonedx edn vcl xml properties)' \
          '*--parser=[parser]:p:(toml json yaml hcl1 hcl2 dockerfile cue ini cyclonedx edn vcl xml properties)' \
          '*--output=[format]:f:(stdout json tap table junit github gitlab azuredevops sarif teamcity)' \
          '*-o+[format]:f:' \
          '*--rego-version=[Rego version]:v:(v0 v1)' \
          '*--show-builtin-errors[show builtin errors]' \
          '*--strict[strict]' \
          '*--update=[update urls csv]:list:' \
          '*--capabilities=[capabilities]:file:_files' \
          '*--proto-file-dirs=[proto dirs csv]:list:_files -/' \
          '*--report-status[report status]' \
          '*--suppress-exceptions[suppress exceptions]' \
          '*: :_files' && ret=0 ;;
      (verify)
        _arguments \
          '*-d+[data]:d:_files' \
          '*--data=[data]:d:_files' \
          '*--report=[report]:f:' \
          '*--output=[format]:f:(stdout json tap table junit github gitlab azuredevops sarif)' \
          '*--rego-version=[Rego version]:v:(v0 v1)' \
          '*: :_files' && ret=0 ;;
      (push|pull)
        _arguments \
          '*--policy=[policy dir]:dir:_files -/' \
          '*: :' && ret=0 ;;
      (parse)
        _arguments \
          '*--input=[input parser]:p:' \
          '*--parser=[parser]:p:' \
          '*: :_files' && ret=0 ;;
      (fmt)
        _arguments \
          '*--check[check only]' \
          '*--list[list]' \
          '*: :_files' && ret=0 ;;
      (plugin)
        _arguments \
          '1:subcommand:(install list remove)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
