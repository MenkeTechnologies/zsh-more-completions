#compdef pdtm

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-ua --update-all)'{-ua,--update-all}'[update all installed tools]' \
  '(-i --install)'{-i,--install}'=[install specified tool]:tool:' \
  '(-u --update)'{-u,--update}'=[update specified tool]:tool:' \
  '(-r --remove)'{-r,--remove}'=[remove specified tool]:tool:' \
  '(-l --list)'{-l,--list}'[list available tools]' \
  '(-li --list-installed)'{-li,--list-installed}'[list installed tools]' \
  '(-s --show)'{-s,--show}'=[show tool information]:tool:' \
  '(-sp --set-path)'{-sp,--set-path}'=[set custom install path]:path:_files -/' \
  '--include-disabled[include disabled tools in listing]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-nc --no-color)'{-nc,--no-color}'[disable color output]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-version --version)'{-version,--version}'[show version information]' \
  && ret=0

return ret
