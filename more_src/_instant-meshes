#compdef instant-meshes
# Documentation: https://github.com/wjakob/instant-meshes
# Instant Meshes: interactive field-aligned mesh generator (batch mode via -o)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '(-o --output)'{-o,--output}'+[write result to PLY/OBJ file (batch mode)]:output:_files' \
  '(-t --threads)'{-t,--threads}'+[number of threads for parallel computation]:threads:' \
  '(-d --deterministic)'{-d,--deterministic}'[use deterministic (slower) algorithms]' \
  '(-c --crease)'{-c,--crease}'+[dihedral angle threshold for creases]:angle:' \
  '(-S --smooth)'{-S,--smooth}'+[smoothing & ray tracing reprojection steps]:steps:' \
  '(-D --dominant)'{-D,--dominant}'[generate tri/quad dominant mesh (not pure)]' \
  '(-i --intrinsic)'{-i,--intrinsic}'[use intrinsic mode instead of extrinsic]' \
  '(-b --boundaries)'{-b,--boundaries}'[align to boundaries (for non-closed meshes)]' \
  '(-r --rosy)'{-r,--rosy}'+[orientation symmetry type (2, 4, or 6)]:rosy:(2 4 6)' \
  '(-p --posy)'{-p,--posy}'+[position symmetry type (3 or 4)]:posy:(3 4)' \
  '(-s --scale -f --faces -v --vertices)'{-s,--scale}'+[desired edge length in output mesh]:scale:' \
  '(-s --scale -f --faces -v --vertices)'{-f,--faces}'+[desired face count in output mesh]:faces:' \
  '(-s --scale -f --faces -v --vertices)'{-v,--vertices}'+[desired vertex count in output mesh]:vertices:' \
  '(-C --compat)'{-C,--compat}'[compatibility mode for old software versions]' \
  '(-k --knn)'{-k,--knn}'+[point cloud mode: adjacent points to consider]:knn:' \
  '(-F --fullscreen)'{-F,--fullscreen}'[open in fullscreen mode]' \
  '*:mesh:_files' && ret=0

return ret
