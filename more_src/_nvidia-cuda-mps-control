#compdef nvidia-cuda-mps-control
# Documentation: https://man.archlinux.org/search?q=nvidia-cuda-mps-control
# Reference accessed: 2026-05-16

# nvidia-cuda-mps-control: NVIDIA CUDA Multi-Process Service control
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[daemonize]' \
  '-f[run in foreground]' \
  '*:command:(quit shutdown_server get_client_list get_server_list get_active_thread_percentage set_active_thread_percentage get_default_active_thread_percentage set_default_active_thread_percentage get_device_pinned_mem_limit set_device_pinned_mem_limit get_default_device_pinned_mem_limit set_default_device_pinned_mem_limit start_server help)' && ret=0
return ret
