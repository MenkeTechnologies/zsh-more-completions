#compdef cli-forge
# Documentation: https://www.npmjs.com/package/cli-forge
# Reference accessed: 2026-05-23
# Verified: npx cli-forge --help.

# Zsh completion for cli-forge - toolkit for cli-forge based CLIs

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'generate-documentation:generate documentation for a CLI'
  'init:scaffold a new cli-forge CLI'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'cli-forge command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (generate-documentation|init)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
