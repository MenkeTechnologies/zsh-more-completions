#compdef liquidctl
# Documentation: https://github.com/liquidctl/liquidctl
# Reference accessed: 2026-05-17
# Verified: liquidctl/liquidctl upstream README.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list compatible devices'
  'initialize:initialise device'
  'status:show device status'
  'set:set channel value'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-g --debug)'{-g,--debug}'[debug logging]' \
  '--match=[match device by substring]:str:' \
  '--vendor=[USB vendor ID]:vid:' \
  '--product=[USB product ID]:pid:' \
  '--release=[USB release]:rel:' \
  '--serial=[device serial]:serial:' \
  '--bus=[USB bus]:bus:' \
  '--address=[USB address]:addr:' \
  '--device=[device index]:n:' \
  '--single[fail on multiple matches]' \
  '--pump-mode=[pump mode]:mode:(quiet balanced extreme)' \
  '--legacy-690lc[treat as legacy 690LC]' \
  '--non-volatile[persist to non-volatile storage]' \
  '--unsafe=[unsafe features csv]:list:' \
  '--direct-access[bypass driver]' \
  '--export-format=[output format]:fmt:(json text)' \
  '--json[JSON output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'liquidctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (set)
        _arguments \
          '1:channel:(fan fan1 fan2 fan3 pump led led1 led2 sync)' \
          '2:property:(speed color)' \
          '*:value or args:' && ret=0 ;;
      (initialize) _values 'arg' 'all' 'pump-mode' && ret=0 ;;
    esac ;;
esac

return ret
