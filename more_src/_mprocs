#compdef mprocs

# Zsh completion for mprocs - Run multiple processes

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config[path to config file]:file:_files -g "*.{yaml,yml,json,toml}"' \
  '--names[names for processes, separated by comma]:names:' \
  '--npm[run scripts from package.json]' \
  '--server[remote control server address]:address:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'help:show help for a subcommand'
    )
    _describe -t commands 'command' commands && ret=0
    _command_names -e && ret=0
    ;;
  (args)
    _default && ret=0
    ;;
esac

return ret
