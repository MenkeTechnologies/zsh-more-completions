#compdef msd gmx-msd
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-msd.html
# Compute mean square displacement and diffusion constants (Einstein relation)

local ret=1

_arguments -s -S \
  '-f+[input trajectory or configuration]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-s+[input structure]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-n+[extra index groups]:index file:_files -g "*.ndx"' \
  '-o+[MSD output]:xvg file:_files -g "*.xvg"' \
  '-mol+[diffusion coefficients per molecule]:xvg file:_files -g "*.xvg"' \
  '-b+[first frame ps]:time:' \
  '-e+[last frame ps]:time:' \
  '-dt+[frame sampling interval ps]:time:' \
  '-tu+[time unit]:unit:(fs ps ns us ms s)' \
  '-fgroup+[atoms in trajectory file]:selection:' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-sf+[selection file]:file:_files' \
  '-selrpos+[selection reference positions]:position:' \
  '-seltype+[default selection output positions]:position:' \
  '-sel+[selections for MSD computation]:selection:' \
  '-type+[MSD type]:type:(x y z unused)' \
  '-lateral+[lateral MSD]:axis:(x y z unused)' \
  '-trestart+[time between restart points ps]:time:' \
  '-maxtau+[maximum time delta ps]:time:' \
  '-beginfit+[fit start time point]:time:' \
  '-endfit+[fit end time point]:time:' \
  '-rmpbc[make molecules whole per frame]' \
  '-pbc[use periodic boundary conditions]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
