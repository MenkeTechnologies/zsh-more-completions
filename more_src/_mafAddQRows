#compdef mafAddQRows
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: add quality data to a maf

local ret=1

_arguments -s -S \
  '-divisor=[value to divide Q value by (default 5)]:n' \
  '1:species list:_files' \
  '2:input maf:_files -g "*.maf"' \
  '3:output maf:_files -g "*.maf"' && ret=0

return ret
