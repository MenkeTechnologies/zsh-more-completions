#compdef arvados-client
# =============================================================================
# arvados-client — the Arvados CLI (Go implementation).  Arvados is an
#                  open-source platform for managing and analyzing biomedical
#                  big data — used in cancer genomics, pharmacogenomics, and
#                  hospital-scale clinical data lakes by institutions like
#                  Curii (the project's commercial steward) and pharma R&D
#                  groups.  arvados-client replaces the older Ruby
#                  `arv` CLI with a Go reimplementation that speaks the
#                  same `getopt(3)` command grammar (so legacy SDK
#                  invocations remain compatible).  Commands span:
#                  generic API CRUD (`get`, `create`, `edit`, `tag`),
#                  keep-store object I/O (`keep get/put`), workflow
#                  containers, websocket event streaming, FUSE mount,
#                  SSH into containers, deduplication reporting,
#                  diagnostics.
#
# Author:  The Arvados Authors (project led by Curii Corporation — Tom
#          Clegg, Peter Amstutz, Brett Smith, et al.; lineage descends
#          from Harvard Medical School / Children's Hospital Boston
#          informatics work)
# Source:  https://github.com/arvados/arvados (cmd/arvados-client/)
# CLI:     lib/cli/flags.go (uses rsc.io/getopt for legacy CLI flags)
# Library: rsc.io/getopt
#          ("Package getopt parses command lines using getopt(3) syntax.
#           Replacement for flag.Parse but still expects flags themselves
#           to be defined in package flag")
# License: Apache-2.0 (Arvados); BSD-style (rsc/getopt)
# Status:  Stable — Arvados 418+ stars; rsc/getopt is a Russ-Cox-authored
#          getopt(3) wrapper around Go's stdlib flag package.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CLIMBS TO 35 (TIES RUST)
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 35TH Go CLI library variant.  Go climbs from 34 to 35 documented libraries
# (rsc.io/getopt via arvados-client).  New leaderboard: Rust=35, Go=35
# (TWO-WAY TIE RESTORED at the R510 decade-milestone solo-lead chased down),
# TypeScript-Node=34.  Taxonomy now spans 250 cross-language CLI library
# variants across 60 documented languages — a ROUND-NUMBER MILESTONE
# (250 documented CLI library variants).
# -----------------------------------------------------------------------------
#
# WHAT IS rsc.io/getopt AND WHY IS IT A DISTINCT 35TH GO CLI LIBRARY?
#
# rsc.io/getopt (https://github.com/rsc/getopt) is **Russ Cox's
# "Package getopt parses command lines using getopt(3) syntax.
# Replacement for flag.Parse but still expects flags themselves to be
# defined in package flag"**.  Russ Cox is one of the Go core
# language team — co-author of Go 1, longtime steward of the Go
# standard library, designer of the module proxy system.  He wrote
# rsc/getopt in 2017 as a UTILITY LIBRARY for the **specific case of
# rewriting a legacy getopt(3)-syntax tool in Go** without breaking
# the existing command-grammar contract.  The package documentation
# is explicit: *"In general Go flag parsing is preferred for new
# programs ... This package is meant to be used in situations where,
# for legacy reasons, it is important to use exactly getopt(3)
# syntax, such as when rewriting in Go an existing tool that already
# uses getopt(3)."*
#
# rsc/getopt is DISTINCT from every documented Go CLI library on FIVE
# specific axes:
#
#   1. THIN ALIAS-OVERLAY ON STDLIB `flag` (NOT A REPLACEMENT) — every
#      other documented Go CLI library is either a stdlib-`flag`
#      REPLACEMENT (cobra, urfave/cli, kingpin, kong, go-arg, opts,
#      mow.cli, mkideal/cli, clir, teris-io/cli, jessevdk/go-flags,
#      flaggy, akamensky/argparse) or a different KERNEL for argv
#      parsing (peterbourgon/ff family, go-getoptions R483).  rsc/getopt
#      is UNIQUELY a **THIN OVERLAY** on stdlib flag:
#         import (
#             "flag"
#             "rsc.io/getopt"
#         )
#         flag.BoolVar(&dryRun, "dry-run", false, "...")
#         flag.StringVar(&format, "format", "json", "...")
#         flag.BoolVar(&verbose, "verbose", false, "...")
#         getopt.Alias("n", "dry-run")     // short alias overlay
#         getopt.Alias("f", "format")
#         getopt.Alias("v", "verbose")
#         getopt.Parse()                    // replaces flag.Parse()
#      All flag DEFINITIONS use stdlib `flag`; rsc/getopt only adds
#      **POSIX-style short aliases** and **strict getopt(3) parsing
#      rules** (one dash for short, two for long).  Compare:
#        cobra (Go):          `BoolVarP(&dryRun, "dry-run", "n", false, "...")`
#                              — DEFINES the alias at flag-creation time,
#                              not as a separate overlay step
#        urfave/cli (Go):     struct list with `Aliases: []string{"n"}` field
#                              on the flag spec
#        kingpin (Go):        `kingpin.Flag("dry-run", "...").Short('n').Bool()`
#                              — fluent builder with short on the same chain
#        kong R465:           struct-tag `short:"n"` on the field
#        rsc/getopt:          DECOUPLED — flag is defined with stdlib `flag`,
#                              the alias is registered SEPARATELY via
#                              `getopt.Alias(short, long)`.
#      **First documented Go CLI library whose ONLY contribution is a
#      POSIX-getopt(3)-syntax-with-aliases OVERLAY on stdlib flag.**
#
#   2. PAIRED `Alias(short, long)` REGISTRATION SYNTAX — rsc/getopt's
#      API surface for aliases is **deliberately minimal**:
#         getopt.Alias("n", "dry-run")           // single pair
#         getopt.Alias("v", "verbose")           // single pair
#         getopt.Aliases(                        // variadic batch
#             "n", "dry-run",
#             "f", "format",
#             "s", "short",
#             "v", "verbose",
#         )
#      One name in each pair must already be defined in package `flag`
#      (either "n" or "dry-run", and also either "v" or "verbose").
#      Compare:
#        cobra:             `BoolVarP(name, short_letter, ...)` — combined
#        kingpin:           `.Short('n')` — combined
#        urfave:            `Aliases: []string{"n"}` — list per flag
#        rsc/getopt:        SEPARATE Alias() call per pair, OR variadic
#                            Aliases() batch — DECOUPLED registration.
#      The separate-registration design lets you keep your flag DEFINITION
#      identical to a non-getopt program (same stdlib flag calls) and
#      OPT IN to getopt-style aliases via a single block of getopt.Alias()
#      calls.  Used by Arvados to retrofit POSIX short-aliases onto a
#      pre-existing flag-based CLI without rewriting every flag def.
#
#   3. NEW `flag.Usage` AUTO-INSTALLED AT init() — rsc/getopt's `init()`
#      function rebinds `flag.Usage` to call `getopt.PrintDefaults`
#      (which renders alias info) instead of `flag.PrintDefaults`:
#         func init() {
#             flag.Usage = func() {
#                 fmt.Fprintf(os.Stderr, "Usage of %s:\n", os.Args[0])
#                 PrintDefaults()  // getopt's version, with aliases
#             }
#             CommandLine.FlagSet = flag.CommandLine
#             // ...
#         }
#      The mere act of importing `rsc.io/getopt` mutates `flag.Usage`
#      to a getopt-aware version.  Compare:
#        Other Go CLI libs:  do not touch stdlib flag's globals
#        rsc/getopt:         REPLACES flag.Usage at init() so help output
#                             reflects aliases without explicit caller
#                             setup.  UNIQUE init-side-effect behavior.
#      A package-level side-effect on import is *generally* frowned upon
#      in Go, but rsc/getopt's use case (legacy tool rewrite where
#      `flag.PrintDefaults` doesn't show getopt aliases) justifies it.
#
#   4. STRICT GETOPT(3) DASH-COUNT RULES — rsc/getopt enforces the
#      classic Unix getopt(3) convention:
#         -n           short alias, single dash
#         --dry-run    long name, double dash
#         -nvalue      short with attached value (e.g. -fjson)
#         -n value     short with space-separated value
#         --long=v     long with equals value
#         --long v     long with space value
#         -nfv         CLUSTERED short flags (n + f + v together)
#      Compare:
#        stdlib flag (Go):    `-x` AND `--x` BOTH WORK for both short
#                              and long — non-pedantic about dashes
#        cobra (Go):          enforces POSIX (single dash short, double
#                              long) when configured to do so
#        rsc/getopt:          STRICT getopt(3) — `-` for short, `--` for
#                              long, ERROR if mismatched.  CLUSTERED
#                              short flags supported (-nfv == -n -f -v).
#      The strictness exists because rsc/getopt's purpose is exact
#      grammar-compatibility with legacy getopt(3)-based tools.
#      Loosening dash rules would defeat the package's reason for being.
#
#   5. `FlagSet` SUB-PARSER WRAPPING stdlib `flag.FlagSet` — rsc/getopt
#      provides a parallel `getopt.FlagSet` type wrapping
#      `flag.FlagSet`:
#         flags := getopt.NewFlagSet("subcmd", flag.ContinueOnError)
#         flags.BoolVar(&dryRun, "dry-run", false, "...")
#         flags.Alias("n", "dry-run")
#         flags.Parse(args)
#      This lets a multi-subcommand binary (like arvados-client)
#      maintain a SEPARATE FlagSet per subcommand, each with its own
#      getopt aliases.  Compare:
#        stdlib flag (Go):    `flag.NewFlagSet(name, errMode)` returns
#                              a FlagSet without alias support
#        rsc/getopt:          `getopt.NewFlagSet(name, errMode)` returns
#                              a getopt-aware FlagSet with `.Alias()`
#                              method.
#      Arvados uses this in `lib/cli/flags.go`'s `LegacyFlagSet()`
#      function that returns the FlagSet + values for each invocation
#      of legacy commands (`copy`, `create`, `edit`, `get`, `tag`).
#
# THE rsc.io/getopt API SURFACE (verbatim from upstream)
#
#   import (
#       "flag"
#       "rsc.io/getopt"
#   )
#
#   // Step 1: define flags with stdlib flag as usual
#   var dryRun bool
#   var format string
#   var verbose bool
#   flag.BoolVar(&dryRun,   "dry-run", false, "Don't actually do anything")
#   flag.StringVar(&format, "format",  "json", "Output format")
#   flag.BoolVar(&verbose,  "verbose", false, "Verbose output")
#
#   // Step 2: declare POSIX-style short aliases
#   getopt.Alias("n", "dry-run")
#   getopt.Alias("f", "format")
#   getopt.Alias("v", "verbose")
#   // OR variadic batch:
#   getopt.Aliases(
#       "n", "dry-run",
#       "f", "format",
#       "v", "verbose",
#   )
#
#   // Step 3: parse argv
#   getopt.Parse()              // replaces flag.Parse()
#
#   // For sub-flagsets:
#   flags := getopt.NewFlagSet("subcmd", flag.ContinueOnError)
#   flags.BoolVar(&dryRun, "dry-run", false, "...")
#   flags.Alias("n", "dry-run")
#   flags.Parse(args)
#
# Functions:
#   getopt.Parse()                 // top-level argv parse
#   getopt.Alias(short, long)      // register one short-alias pair
#   getopt.Aliases(short1, long1,
#                  short2, long2,
#                  ...)            // variadic batch alias registration
#   getopt.PrintDefaults()         // alias-aware help-rendering
#   getopt.NewFlagSet(name, mode)  // sub-flagset with alias support
#
# Types:
#   getopt.FlagSet                 // wraps flag.FlagSet, adds .Alias()
#
# CONTRAST WITH OTHER GO CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * flag (stdlib)                — base library; rsc/getopt overlays
#   * cobra                        — framework + codegen
#   * urfave/cli                   — struct-list declarative
#   * kingpin                      — fluent builder
#   * kong R465                    — struct-tag declarative
#   * go-arg R475                  — single MustParse(&struct)
#   * opts R479                    — frictionless struct
#   * mow.cli R470                 — SPEC-string grammar
#   * go-getoptions R483           — Perl Getopt::Long port (DIFFERENT
#                                    library — go-getoptions is a Perl
#                                    Getopt::Long-style replacement,
#                                    rsc/getopt is a Unix getopt(3)
#                                    overlay on stdlib flag)
#   * commando R487                — package-level singleton + colon ns
#   * mkideal/cli R491             — struct-tag comma-aliases
#   * clir R495                    — explicit constructor + pointer
#                                    setters
#   * teris-io/cli R499            — With*-prefix fluent builder
#   * jessevdk/go-flags R503       — reflection on struct fields
#   * akamensky/argparse R507      — Python-argparse-faithful port
#   * peterbourgon/ff R363         — functional-options flag parser
#   * peterbourgon/ff/v3/ffcli R431 — ff + subcommand dispatch
#   * flaggy (integrii)            — pointer-bind imperative builder
#   * rsc/getopt (THIS)            — thin POSIX-getopt(3) alias overlay
#                                    on stdlib flag, by Russ Cox; the
#                                    minimal-dependency choice when
#                                    rewriting a legacy getopt-tool
#                                    in Go.
#
# rsc/getopt occupies a UNIQUE NICHE — the **MINIMAL-DEPENDENCY choice
# for rewriting a legacy getopt(3)-syntax tool in Go**.  Where every
# other documented Go CLI library brings its own opinionated API for
# flag definition, rsc/getopt **adds aliases and getopt grammar on
# top of the stdlib flag package** without making you learn anything
# new about flag-declaration ergonomics.
#
# REAL-WORLD rsc.io/getopt USERS:
#
#   * arvados/arvados:arvados-client (THIS, 418*) — Go reimplementation
#       of Arvados's CLI to replace the older Ruby `arv` command-line
#       while preserving its getopt-style grammar (`-n` for `--dry-run`,
#       `-f` for `--format`, etc.).
#   * rsc/mailgun:cmd/mailgun-mail — Russ Cox's own mailgun mail CLI
#   * hyung-hwan/hawk:bin/getopt.go — Hawk language tooling
#   * Hakkin/twitchpipe — Twitch Live stream piping tool
#   * Projeto-Pindorama/zipar — ZIP archiver tool
#   * santihernandezc/devnull — null-output utility
#   * OMRIFIJI/anicli-ru — Anime CLI in Russian
#   * 4nd3r5on/ptester — Performance tester
#   * calico32/texty — text tool
#
# rsc/getopt's adoption pattern: **legacy getopt-tool rewrites in Go**
# plus **Russ-Cox-adjacent personal projects** (mailgun-mail, etc.).
# Arvados is by far the highest-profile adopter and the canonical
# example of "tool was written in Ruby with getopt() bindings, we
# rewrote it in Go, but the CLI grammar contract is fixed".
#
# -----------------------------------------------------------------------------
# ARVADOS-CLIENT'S CLI SURFACE (verbatim from cmd/arvados-client/cmd.go)
# -----------------------------------------------------------------------------
#
# USAGE:
#   arvados-client <SUBCOMMAND> [args...] [legacy flags]
#
# Subcommands (handler.Multi map):
#
#   Version:
#     version, -version, --version, -e   Print version and exit
#
#   Generic CRUD (use LegacyFlagSet with -n/-f/-s/-v aliases):
#     get      <UUID|name>                Fetch a record
#     create   <resource> [k=v ...]       Create a new resource
#     edit     <UUID|name> [k=v ...]      Edit an existing resource
#     copy     <UUID> <dest>              Copy a record between clusters
#     tag      <UUID> <tag> [tag ...]     Tag a record
#     ws       (websocket)                Stream Arvados events via WS
#
#   Resource-typed API calls (each dispatches to APICall handler):
#     api_client_authorization            Manage API tokens
#     api_client                          Manage API clients
#     authorized_key                      Manage SSH public keys
#     collection                          Manage Keep collections
#     container                           Manage container objects
#     container_request                   Manage CR objects
#     group                               Manage user groups
#     keep_service                        Manage Keep services
#     link                                Manage Arvados links
#     log                                 Manage audit logs
#     user_agreement                      Manage TOS agreements
#     user                                Manage user accounts
#     virtual_machine                     Manage shell VMs
#     workflow                            Manage CWL workflows
#
#   Keep object I/O:
#     keep      get|put|...               Keep blob CRUD
#
#   Container/cluster operations:
#     connect-ssh                         SSH into a running container
#     deduplication-report                Generate dedup analysis
#     diagnostics                         Cluster health diagnostics
#     logs                                Stream container logs
#     mount                               FUSE-mount Keep collections
#     shell                               Interactive Arvados shell
#     sudo                                Run command as another user
#
# Legacy flags (registered via rsc.io/getopt.Alias from
#                lib/cli/flags.go LegacyFlagSet):
#   -n, --dry-run            Don't actually do anything
#   -f, --format <fmt>       Output format: json | yaml | uuid
#   -s, --short              Return only UUIDs (equiv to --format=uuid)
#   -v, --verbose            Print more debug/progress messages
#
# Typical usage:
#   $ arvados-client get my-collection-uuid -f yaml
#   $ arvados-client create collection name="My Data" -n
#   $ arvados-client tag <uuid> sequencing-2026 production -v
#   $ arvados-client container_request list --filters '...'
#   $ arvados-client keep get <locator> > data.bin
#   $ arvados-client diagnostics --debug
#   $ arvados-client deduplication-report -o report.txt
#   $ arvados-client mount /mnt/keep
#
# Related Arvados binaries:
#   arvados-server          — the Arvados controller/keep/dispatcher
#   crunch-dispatch-local   — local job dispatcher
#   crunch-run              — single-container runner
#
# =============================================================================

_arvados-client() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands resource_types format_choices

    subcommands=(
        'get:fetch a record'
        'create:create a new resource'
        'edit:edit an existing resource'
        'copy:copy a record between clusters'
        'tag:tag a record'
        'ws:stream Arvados events via websocket'
        'keep:Keep blob CRUD (get|put|...)'
        'connect-ssh:SSH into a running container'
        'deduplication-report:generate dedup analysis'
        'diagnostics:cluster health diagnostics'
        'logs:stream container logs'
        'mount:FUSE-mount Keep collections'
        'shell:interactive Arvados shell'
        'sudo:run command as another user'
        'version:print version and exit'
        'api_client_authorization:manage API tokens'
        'api_client:manage API clients'
        'authorized_key:manage SSH public keys'
        'collection:manage Keep collections'
        'container:manage container objects'
        'container_request:manage container request objects'
        'group:manage user groups'
        'keep_service:manage Keep services'
        'link:manage Arvados links'
        'log:manage audit logs'
        'user_agreement:manage TOS agreements'
        'user:manage user accounts'
        'virtual_machine:manage shell VMs'
        'workflow:manage CWL workflows'
    )

    format_choices=('json:JSON output' 'yaml:YAML output' 'uuid:UUID only')

    _arguments -C \
        '(-n --dry-run)'{-n,--dry-run}'[do not actually do anything]' \
        '(-f --format)'{-f,--format}'[output format]:format:->format' \
        '(-s --short)'{-s,--short}'[return only UUIDs (equiv to --format=uuid)]' \
        '(-v --verbose)'{-v,--verbose}'[print more debug/progress messages]' \
        '(- *)--version[print version and exit]' \
        '(- *)-version[print version and exit]' \
        '(- *)-e[print version and exit]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t commands 'arvados-client command' subcommands && ret=0
            ;;
        (format)
            _describe -t formats 'output format' format_choices && ret=0
            ;;
        (args)
            _arguments \
                '(-n --dry-run)'{-n,--dry-run}'[do not actually do anything]' \
                '(-f --format)'{-f,--format}'[output format]:format:->format' \
                '(-s --short)'{-s,--short}'[return only UUIDs]' \
                '(-v --verbose)'{-v,--verbose}'[verbose output]' \
                '*: :_default' && ret=0
            case $state in
                (format)
                    _describe -t formats 'output format' format_choices && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_arvados-client "$@"
