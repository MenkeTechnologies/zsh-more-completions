#compdef 1dUpsample
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dUpsample.html
# Upsample a 1D time series to a finer time grid

local ret=1

_arguments -s -S \
  '(-1 -one)'{-1,-one}'[use 1st order polynomials for linear interpolation]' \
  '*:file:_files' && ret=0

return ret
