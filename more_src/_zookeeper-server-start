#compdef zookeeper-server-start
# Documentation: https://zookeeper.apache.org/doc/r3.9.1/zookeeperAdmin.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: zookeeper-server-start is a Kafka/Confluent wrapper around
# zkServer.sh start-foreground; takes a zookeeper.properties file as
# positional argument. No documented dash-flags on the wrapper itself
# beyond the optional -daemon flag inherited from Kafka launch scripts.

local curcontext="$curcontext" state line ret=1

_arguments \
  '-daemon[run as daemon]' \
  '*:zookeeper.properties:_files -g "*.properties"' && ret=0

return ret
