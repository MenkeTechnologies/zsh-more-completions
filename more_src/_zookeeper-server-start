#compdef zookeeper-server-start

local curcontext="$curcontext" state line ret=1

_arguments \
  '-daemon[run as daemon]' \
  '-name+[process name]:name:' \
  '-loggc[enable GC logging]' \
  '*-override+[config override]:key=value:' \
  '*:zookeeper.properties:_files -g "*.properties"' && ret=0

return ret
