#compdef v.net
# GRASS GIS: perform network maintenance (build, connect, report) on a vector map

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-c[assign unique categories to new points]' \
  '-s[snap points to network]' \
  '--overwrite[allow output to overwrite existing files]' \
  '--verbose[verbose output]' \
  '--quiet[quiet output]' \
  '--input=[input vector map]:name:' \
  '--points=[input vector point map]:name:' \
  '--output=[output vector map]:name:' \
  '--operation=[operation to be performed]:operation:(nodes connect arcs report nreport turntable)' \
  '--arc_layer=[layer number for arcs]:layer:' \
  '--arc_type=[input feature type]:type:(line boundary)' \
  '--node_layer=[layer number for nodes]:layer:' \
  '--turn_layer=[layer for turntable attachment]:layer:' \
  '--turn_cat_layer=[layer with unique categories]:layer:' \
  '--threshold=[distance threshold for connecting points]:threshold:' && ret=0

return ret
