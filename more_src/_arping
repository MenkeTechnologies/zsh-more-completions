#compdef arping
# _arping — iputils arping (ARP-level liveness ping; sends Layer-2 ARP REQUEST/REPLY to detect responding hosts on the local segment; useful for duplicate-address detection)
# upstream: https://github.com/iputils/iputils
# Flags from arping.c getopt on tip; needs CAP_NET_RAW.

_arping() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-V[show version and exit]' \
        '-b[only send broadcast ARP requests (no IP target)]' \
        '-D[DAD mode (duplicate-address detection)]' \
        '-U[send unsolicited ARP updates]' \
        '-A[send ARP REPLY advertisements]' \
        '-q[quiet (no output)]' \
        '-c+[stop after N replies]:n:' \
        '-w+[timeout (sec)]:sec:' \
        '-i+[interval between probes (sec)]:sec:' \
        '-I+[network interface]:iface:_net_interfaces' \
        '-f[finish on first reply]' \
        '-s+[source IP address]:ip:' \
        '1:target:_hosts'
}

_arping "$@"
