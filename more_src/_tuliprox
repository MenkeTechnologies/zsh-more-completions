#compdef tuliprox
# ============================================================================
# tuliprox - Flexible IPTV playlist processor & proxy (Rust, MIT)
#
# Author : euzu
# Upstream: https://github.com/euzu/tuliprox
#
# tuliprox ingests IPTV playlists in M3U, Xtream Codes, or HDHR
# format, applies user-defined processing rules (channel filtering,
# group remapping, regex-based renames, EPG enrichment, dedup,
# logo rewriting), and re-serves the processed playlist as an
# HTTP proxy. Acts as the middleware between upstream IPTV
# providers and downstream players (Kodi/Tivimate/PerfectPlayer/
# etc.), enabling per-user playlist customization without
# editing the upstream M3U file.
#
# Modes:
#   batch (default) - process playlists once and exit
#   server (-s)     - run as HTTP proxy serving processed playlists
#
# Major flags (clap derive):
#   -H, --home <dir>           - base for config/storage/backup/downloads
#   -p, --config-path <dir>    - config directory
#   -c, --config <file>        - main config file
#   -i, --source <file>        - source/upstream playlist config
#   -m, --mapping <file>       - channel mapping rules
#   -T, --template <file>      - per-target Handlebars template
#   -t, --target <names>       - restrict to specific targets
#   -a, --api-proxy <file>     - user/API-proxy config
#   -s, --server               - run in server mode (default: batch)
#   -l, --log-level <level>    - logging level (trace|debug|info|warn|error)
#       --genpwd               - generate hashed password to stdout + exit
#       --healthcheck          - run health check + exit (Docker HEALTHCHECK)
#       --scan-library         - scan local Library directory
#       --force-library-rescan - force rescan of all local Library files
#       --dbx/dbm/dbe/dbv/dbms/dbq <file>  - per-database file overrides
#       --sh <inline-json|@f>  - query stream history snapshot
#
# The Pest lane is built on `pest = "2.8.6"` + `pest_derive =
# "2.8.6"` (declared verbatim at upstream workspace Cargo.toml
# HEAD), the canonical Rust PEG (Parsing Expression Grammar)
# library by Dragoș Tiselice + the pest-parser org
# (github.com/pest-parser/pest, 4700+ stars). pest takes a .pest
# grammar file (PEG-format BNF) at compile time, derive-generates
# a typed parser via the `#[derive(Parser)]` macro, and exposes
# a `Pairs<Rule>` iterator over the parsed tree. tuliprox uses
# pest to parse the channel-filter mini-language that runs the
# include/exclude/rename rules - PEG is the natural fit for
# user-authored DSLs where readability + Pratt-style operator
# precedence matter more than raw parse speed.
#
# ----------------------------------------------------------------------------
# AXIS 221 :: PEG (Parsing Expression Grammar) parser generators  [OPENS]
# Round 1361 :: Rust slot 1 of 4 :: OPENS Axis 221
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : pest-parser/pest             - derive-driven PEG grammar parser
#   Go      : pointlander/peg OR mna/pigeon - Go PEG parser generators
#   TS/Node : peggyjs/peggy (active PEG.js fork) - canonical JS PEG generator
#
# PEG is the modern alternative to LALR(k) / LR(k) for hand-
# authored grammars: unlike CFG-based generators (yacc/bison/
# lalrpop), PEG resolves ambiguity through ordered choice
# (`A / B / C` always tries A first), which lets grammar
# authors write rules that read closely to the language they
# describe without worrying about reduce-reduce conflicts.
# The cost: no left recursion (or only via PEG-specific
# memoization tricks like Pest's Pratt parser support), and
# worst-case O(n) memory for packrat memoization.
#
# All three lanes target the original Ford (2004) PEG paper -
# grammar syntax is broadly portable across pest, pigeon, and
# peggy with mechanical translation. The structural
# differentiator is *how the parsed tree is exposed*: pest
# yields a Pairs<Rule> iterator with manual tree-walk; pigeon
# emits a Go AST type per grammar rule; peggy returns a
# JavaScript object literal tree built by inline grammar
# actions. Same grammar formalism, three different host-language
# tree models.
# ============================================================================

_tuliprox() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-H --home)'{-H,--home}'[home directory (base for config, storage, backup, downloads)]:dir:_files -/' \
        '(-p --config-path)'{-p,--config-path}'[config directory]:dir:_files -/' \
        '(-c --config)'{-c,--config}'[main config file]:file:_files -g "*.(yaml|yml|json|toml)"' \
        '(-i --source)'{-i,--source}'[source/upstream playlist config file]:file:_files -g "*.(yaml|yml|json)"' \
        '(-m --mapping)'{-m,--mapping}'[channel mapping rules file]:file:_files -g "*.(yaml|yml|json)"' \
        '(-T --template)'{-T,--template}'[per-target Handlebars template file]:file:_files' \
        '*'{-t,--target}'[restrict to specific target names]:target:' \
        '(-a --api-proxy)'{-a,--api-proxy}'[user / API-proxy config file]:file:_files -g "*.(yaml|yml|json)"' \
        '(-s --server)'{-s,--server}'[run in server mode (default: batch then exit)]' \
        '(-l --log-level)'{-l,--log-level}'[log level]:level:(trace debug info warn error)' \
        '--genpwd[generate a hashed password to stdout and exit]' \
        '--healthcheck[run health check and exit (suitable for Docker HEALTHCHECK)]' \
        '--scan-library[scan the local Library directory]' \
        '--force-library-rescan[force rescan of all local Library files]' \
        '--dbx[Xtream DB file name override]:file:_files' \
        '--dbm[M3U DB file name override]:file:_files' \
        '--dbe[EPG DB file name override]:file:_files' \
        '--dbv[target ID mapping DB file name override]:file:_files' \
        '--dbms[metadata retry status DB file name override]:file:_files' \
        '--dbq[QoS snapshot DB file name override]:file:_files' \
        '--sh[query stream history (inline JSON or @file.json)]:json or @file:' \
        '(- *)'{-V,--version}'[print version]' \
        '(- *)'{-h,--help}'[print help]'
}

_tuliprox "$@"
