#compdef relion_class_ranker
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: rank and auto-select 2D class averages with a trained network

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--opt=[input optimiser.star file]:file:_files' \
  '--o=[directory name for output files]:dir:_files -/' \
  '--ext=[extension for root filenames of output star files]:ext' \
  '--auto_select[perform auto-selection based on score thresholds]' \
  '--min_score=[minimum selected score to include in selection]:value' \
  '--max_score=[maximum selected score to include in selection]:value' \
  '--select_min_nr_particles=[select at least this many particles]:value' \
  '--select_min_nr_classes=[OR select at least this many classes]:value' \
  '--relative_thresholds[interpret min/max scores as fractions of max]' \
  '--fn_sel_parts=[output star file with selected particles]:file:_files' \
  '--fn_sel_classavgs=[output star file with selected class averages]:file:_files' \
  '--fn_root=[rootname for output model.star and optimiser.star]:name' \
  '--train[only write output files for training purposes]' \
  '--select=[input class_averages.star or backup_selection.star]:file:_files' \
  '--fn_score=[input job score file]:file:_files' \
  '--cf_file=[input class feature star file]:file:_files' \
  '--only_class_nr=[class number of the class of interest]:value' \
  '--skip_angular_errors[skip angular error calculation]' \
  '--do_granularity_features[calculate granularity features]' \
  '--save_masks[save generated 2D solvent masks for all references]' \
  '--mask_folder_name=[folder name for saving all masks]:dir:_files -/' \
  '--extract_subimages[extract subimages for each class]' \
  '--nr_subimages=[number of subimages to extract randomly]:value' \
  '--subimage_boxsize=[boxsize (pixels) for subimages]:value' \
  '--lowpass=[image lowpass filter threshold for binary masks]:value' \
  '--binary_threshold=[threshold for generating binary masks]:value' \
  '--debug=[debug level]:value' \
  '--verb=[verbosity level]:value' \
  '--fn_features=[output features star file]:file:_files' \
  '--write_normalized_features[also write out normalized feature vectors]' \
  '*:file:_files' && ret=0

return ret
