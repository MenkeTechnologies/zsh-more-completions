#compdef ivstools
# _ivstools — Aircrack-ng ivstools (manipulate .ivs capture files used by aircrack-ng; --convert wpa pcap -> ivs, --merge combine multiple ivs files, -h help, -V version; positional arguments are input/output files depending on the subcommand)
# upstream: https://github.com/aircrack-ng/aircrack-ng
# Flags from aircrack-ng src/ivstools.c on tip.

_ivstools() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '--convert[convert pcap -> ivs]' \
        '--merge[merge ivs files]' \
        '*:file:_files -g "*.(ivs|cap|pcap)"'
}

_ivstools "$@"
