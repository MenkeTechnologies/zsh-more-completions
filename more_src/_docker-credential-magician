#compdef docker-credential-magician
# _docker-credential-magician — augment container images with credential helpers (docker-credential-magic/docker-credential-magic)
# upstream: https://github.com/docker-credential-magic/docker-credential-magic
# Subcommands from cmd/docker-credential-magician/main.go (cobra).

_docker-credential-magician() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                mutate:'augment an image with one or more credential helpers'
                version:'print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                mutate)
                    _arguments \
                        '(-t --tag)'{-t+,--tag=}'[push to custom location]:tag:' \
                        '--helpers-dir=[directory containing helper binaries]:dir:_files -/' \
                        '--mappings-dir=[directory containing helper mapping files]:dir:_files -/' \
                        '*'{-i+,--include=}'[helper to include (repeatable)]:helper:' \
                        '1:image reference:' ;;
            esac
            ;;
    esac
}

_docker-credential-magician "$@"
