# Verified: upstream argparse in gguf-py/gguf/scripts/gguf_editor_gui.py

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--verbose[increase output verbosity]' \
  '1:GGUF model:_files -g "*.gguf"' && ret=0

return ret
