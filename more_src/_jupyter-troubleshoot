#compdef jupyter-troubleshoot
# Documentation: https://man.archlinux.org/search?q=jupyter-troubleshoot
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '--help[Show help message]'
    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)'
    '--config=[Load this config file]:config file:_files'
)

_arguments -s -S $arguments
