#compdef pyftfeatfreeze
# Documentation: https://github.com/twardoch/fonttools-opentype-feature-freezer
# Permanently "freeze" OpenType features into a font's default glyph set

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-f --features)'{-f,--features}'=[comma-separated OpenType feature tags]:tags' \
  '(-s --script)'{-s,--script}'=[OpenType script tag]:script' \
  '(-l --lang)'{-l,--lang}'=[OpenType language tag]:lang' \
  '(-S --suffix)'{-S,--suffix}'[add suffix to font family name from feature tags]' \
  '(-U --usesuffix)'{-U,--usesuffix}'=[use custom suffix when -S is active]:suffix' \
  '(-R --replacenames)'{-R,--replacenames}'=[search and replace strings in font names]:rules' \
  '(-z --zapnames)'{-z,--zapnames}'[zap glyph names from TTF fonts]' \
  '(-i --info)'{-i,--info}'[update font version string]' \
  '(-r --report)'{-r,--report}'[report features, scripts, languages instead of processing]' \
  '(-n --names)'{-n,--names}'[output names of remapped glyphs]' \
  '(-v --verbose)'{-v,--verbose}'[print detailed processing information]' \
  '(-V --version)'{-V,--version}'[show program version]' \
  '*:font file:_files -g "*.(ttf|otf|TTF|OTF)"' && ret=0

return ret
