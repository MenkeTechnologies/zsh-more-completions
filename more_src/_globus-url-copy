#compdef globus-url-copy
# Documentation: https://man.archlinux.org/search?q=globus-url-copy
# Reference accessed: 2026-05-16

# globus-url-copy: third-party transfer client (Globus GridFTP)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-v[verbose]' \
  '-vb[verbose progress bar]' \
  '-q[quiet]' \
  '-r[recursive]' \
  '-c[create destination directories]' \
  '-cd[create destination dirs]' \
  '-f[file with source/dest pairs]:file:_files' \
  '-cred[credential file]:file:_files' \
  '-no-data-channel-authentication[no DCAU]' \
  '-nodcau[no DCAU]' \
  '-data-channel-protection=[protection]:level:(none safe private)' \
  '-data-channel-safe[safe protection]' \
  '-data-channel-private[private protection]' \
  '-tcp-buffer-size=[TCP buffer size]:bytes:' \
  '-tcp-bs=[TCP buffer size]:bytes:' \
  '-parallel=[parallel streams]:n:' \
  '-p=[parallel streams]:n:' \
  '-stripe-count=[stripe count]:n:' \
  '-block-size=[block size]:bytes:' \
  '-bs=[block size]:bytes:' \
  '-checksum-alg=[checksum algorithm]:algo:(MD5 ADLER32)' \
  '-b[binary mode]' \
  '-a[ASCII mode]' \
  '-fast[fast transfer]' \
  '-list[list source]' \
  '-len=[number of bytes to transfer]:bytes:' \
  '-partial-offset=[partial offset]:bytes:' \
  '-partial-length=[partial length]:bytes:' \
  '*:source dest:' && ret=0
return ret
