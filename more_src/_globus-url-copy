#compdef globus-url-copy
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/globus-url-copy.1.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# globus-url-copy: GridFTP / multi-protocol third-party transfer client
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-usage[show help]' \
  '-versions[show module versions]' \
  '-v[verbose]' \
  '-vb[verbose performance / progress bar]' \
  '-q[quiet]' \
  '-r[recursive]' \
  '(-c -continue-on-error)'{-c,-continue-on-error}'[continue on error]' \
  '-cd[create destination directories]' \
  '-create-dest[create destination directories]' \
  '-f+[file with source/dest pairs]:file:_files' \
  '-cred+[credential file]:file:_files' \
  '-src-cred+[source credential file]:file:_files' \
  '-dst-cred+[destination credential file]:file:_files' \
  '-no-data-channel-authentication[no DCAU]' \
  '-nodcau[no DCAU]' \
  '-data-channel-protection=[protection]:level:(none safe private)' \
  '-dcsafe[safe protection]' \
  '-dcprivate[private protection]' \
  '-tcp-buffer-size=[TCP buffer size in bytes]:bytes:' \
  '-tcp-bs=[TCP buffer size in bytes]:bytes:' \
  '(-p -parallel)'{-p,-parallel}'=[parallel data connections]:n:' \
  '-stripe[enable striped transfers]' \
  '-stripe-bs=[striped block size]:bytes:' \
  '-sbs=[striped block size]:bytes:' \
  '-block-size=[block size in bytes]:bytes:' \
  '-bs=[block size in bytes]:bytes:' \
  '-checksum-alg=[checksum algorithm]:algo:(MD5 ADLER32)' \
  '-b[binary mode]' \
  '-a[ASCII mode]' \
  '-fast[fast transfer (MODE E)]' \
  '-list+[list source URL]:url:' \
  '-len=[number of bytes to transfer]:bytes:' \
  '-partial-offset=[partial offset]:bytes:' \
  '-partial-length=[partial length]:bytes:' \
  '-sync[only transfer when destination differs]' \
  '-t+[transfer duration limit in seconds]:seconds:' \
  '-rst-retries=[retry attempts]:n:' \
  '*:source dest:' && ret=0
return ret
