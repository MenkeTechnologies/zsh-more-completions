#compdef lsyncd

# Zsh completion for lsyncd - Live Syncing Daemon

local -a arguments

arguments=(
  '-delay[delay before synchronizing in seconds]:seconds'
  '-help[show help message]'
  '-insist[continue running even if startup sync fails]'
  '-log[set logging category]:log category:(all scarce Exec Inotify)'
  '-logfile[log to specified file]:log file:_files'
  '-nodaemon[do not detach, run in foreground]'
  '-pidfile[write PID to file]:PID file:_files'
  '-runner[load a Lua runner file]:lua file:_files -g "*.lua"'
  '-version[show version information]'
  '*:config file or source/target:_files'
)

_arguments -s -S $arguments
