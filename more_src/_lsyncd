#compdef lsyncd
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/lsyncd.1.html
# Reference accessed: 2026-05-19
# Verified: Ubuntu jammy lsyncd(1) manpage.

# Zsh completion for lsyncd - Live Syncing Daemon
local -a arguments

arguments=(
  '-delay[delay before syncing in seconds]:seconds:'
  '-help[show help message]'
  '-insist[continue running even if startup sync fails]'
  '-log[set log level/category]:log category:(all scarce Exec Inotify Normal Error)'
  '-logfile[log to specified file]:log file:_files'
  '-nodaemon[do not detach, run in foreground]'
  '-pidfile[write PID to file]:PID file:_files'
  '-runner[load a Lua runner file]:lua file:_files -g "*.lua"'
  '-rsync[rsync mode SOURCEDIR TARGET]'
  '-rsyncssh[rsyncssh mode SOURCEDIR TARGETHOST TARGETDIR]'
  '-direct[direct mode SOURCEDIR TARGETDIR]'
  '-version[show version information]'
  '*:config file or source/target:_files'
)

_arguments -s -S $arguments
