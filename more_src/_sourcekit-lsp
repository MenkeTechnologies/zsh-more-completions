#compdef sourcekit-lsp
# Documentation: https://github.com/swiftlang/sourcekit-lsp
# Reference accessed: 2026-05-21
# Verified: `sourcekit-lsp --help` output from installed binary.

local curcontext="$curcontext" state line ret=1

local -a subcommands
subcommands=(
  'diagnose:Create a bundle to help diagnose sourcekit-lsp issues'
  'debug:Commands to debug sourcekit-lsp (for sourcekit-lsp developers)'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help information]' \
  '--configuration=[build configuration]:configuration:(debug release)' \
  '(--scratch-path --build-path)'{--scratch-path,--build-path}'=[build/cache directory (--build-path is deprecated)]:directory:_directories' \
  '*-Xcc[pass flag through to all C compiler invocations]:arg:' \
  '*-Xcxx[pass flag through to all C++ compiler invocations]:arg:' \
  '*-Xlinker[pass flag through to all linker invocations]:arg:' \
  '*-Xswiftc[pass flag through to all Swift compiler invocations]:arg:' \
  '*-Xclangd[pass options to clangd command-line]:arg:' \
  '*-index-prefix-map[override prefix map from build system (remote=local)]:mapping:' \
  '--default-workspace-type=[override default workspace type]:type:(swiftPM compilationDatabase buildServer)' \
  '*--compilation-db-search-path=[search path for compile_commands.json relative to workspace root]:path:' \
  '--generated-files-path=[directory where generated files will be stored]:path:_directories' \
  '*--experimental-feature=[enable experimental sourcekit-lsp feature]:feature:(on-type-formatting structured-logs)' \
  '1:subcommand:->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
esac

return ret
