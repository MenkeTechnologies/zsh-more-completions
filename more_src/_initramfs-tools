#compdef update-initramfs mkinitramfs
# _initramfs-tools — Debian initramfs builder/updater; rebuild initrd image after kernel/module/config change
# upstream: https://salsa.debian.org/kernel-team/initramfs-tools

_initramfs-tools() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '-c[create new initramfs]' \
        '-d[delete existing initramfs]' \
        '-u[update existing initramfs]' \
        '-k+[kernel version]:ver:' \
        '-t[take backup if creating]' \
        '-v[verbose]' \
        '-r+[root device for image]:dev:_files' \
        '-b+[bootdir]:dir:_files -/' \
        '-o+[output file]:file:_files' \
        '-c[skip kernel check]' \
        '*:kernel version:'
}

_initramfs-tools "$@"
