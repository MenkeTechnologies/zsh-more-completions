#compdef pyxplot
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/pyxplot.1.html
# pyxplot - command-line data processing, vector graphics and graph-plotting tool

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display this help]' \
  '(-v --version)'{-v,--version}'[display version number]' \
  '(-q --quiet)'{-q,--quiet}'[turn off initial welcome message]' \
  '(-V --verbose)'{-V,--verbose}'[turn on initial welcome message]' \
  '(-c --colour --color)'{-c,--colour,--color}'[use coloured highlighting of output]' \
  '(-m --monochrome)'{-m,--monochrome}'[turn off coloured highlighting]' \
  '*:script:_files' && ret=0

return ret
