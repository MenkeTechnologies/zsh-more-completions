#compdef frida-ps

# Zsh completion for frida-ps - list processes

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-D+[connect to device with the given ID]:device ID' \
  '--device=[connect to device with the given ID]:device ID' \
  '-U[connect to USB device]' \
  '--usb[connect to USB device]' \
  '-R[connect to remote frida-server]' \
  '--remote[connect to remote frida-server]' \
  '-H+[connect to remote frida-server on host]:host' \
  '--host=[connect to remote frida-server on host]:host' \
  '-a[include all processes]' \
  '--applications[list only applications]' \
  '-i[include all installed applications]' \
  '--installed[include all installed applications]' \
  '-j[output as JSON]' \
  '--json[output as JSON]' && ret=0

return ret
