#compdef radsecproxy radsec
# _radsec — radsecproxy (RADIUS-over-TLS / TCP proxy implementing the RadSec protocol; -c config file, -f foreground, -p pidfile, -d debug level, -V version, -h help; reads /etc/radsec/radsec.conf for upstream realm declarations + TLS material and listens on UDP/RADIUS, TLS/RadSec or DTLS/RadSec)
# upstream: https://github.com/radsecproxy/radsecproxy
# Flags from radsecproxy/radsecproxy radsecproxy.c on tip.

_radsec() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-f[foreground]' \
        '-p+[pidfile]:file:_files' \
        '-d+[debug level]:level:'
}

_radsec "$@"
