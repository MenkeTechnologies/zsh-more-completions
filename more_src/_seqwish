#compdef seqwish
# Documentation: https://github.com/ekg/seqwish
# seqwish: induce a variation graph from alignments

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --seqs)'{-s+,--seqs=}'[input sequences in FASTA/FASTQ]:file:_files' \
  '(-p --paf-alns)'{-p+,--paf-alns=}'[input alignments in PAF]:file:_files' \
  '(-g --gfa)'{-g+,--gfa=}'[output graph in GFA v1.0]:file:_files' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:threads' \
  '(-b --temp-dir)'{-b+,--temp-dir=}'[directory for temporary files]:dir:_files -/' \
  '(-M --in-memory)'{-M,--in-memory}'[use in-memory interval trees]' \
  '(-k --min-match-len)'{-k+,--min-match-len=}'[minimum exact match length]:length' \
  '(-r --repeat-max)'{-r+,--repeat-max=}'[maximum copies in transitive closure]:max' \
  '(-l --min-repeat-distance)'{-l+,--min-repeat-distance=}'[minimum distance for repeat handling]:distance' \
  '(-f --sparse-factor)'{-f+,--sparse-factor=}'[sparsify input matches by hash-minimizing fraction]:factor' \
  '(-B --transclose-batch)'{-B+,--transclose-batch=}'[transitive closure batch size in bp]:size' \
  '(-P --show-progress)'{-P,--show-progress}'[log progress messages]' \
  '(-T --keep-temp)'{-T,--keep-temp}'[keep intermediate temporary files]' && ret=0

return ret
