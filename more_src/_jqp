#compdef jqp
# Documentation: https://github.com/noahgorstein/jqp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jqp - a TUI playground for jq

local -a themes
themes=(
  abap algol arduino autumn average base16snazzy borland
  catppuccin-frappe catppuccin-latte catppuccin-macchiato catppuccin-mocha
  colorful doom-one doom-one2 dracula emacs friendly fruity github
  github-dark gruvbox gruvbox-light hrdark igor lovelace manni monokai
  monokai-light murphy native onesenterprise paraiso-dark paraiso-light
  pastie perldoc pygments rrt solarized-dark solarized-dark256
  solarized-light swapoff tango trac vim visual_studio vulcan witchhazel
  xcode xcode-dark
)

local -a arguments
arguments=(
  '--config[path to config file (default $HOME/.jqp.yaml)]:config file:_files'
  {-f,--file}'[path to the input JSON file]:input file:_files'
  {-t,--theme}'[set the jqp theme]:theme:($themes)'
  '(- *)'{-h,--help}'[help for jqp]'
  '(- *)'{-v,--version}'[version for jqp]'
)

_arguments -s -S $arguments
