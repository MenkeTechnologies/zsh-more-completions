#compdef CollectVariantCallingMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectVariantCallingMetrics
# Picard: collect per-sample and aggregate metrics from a VCF call set

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input VCF file]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  {-O=,--OUTPUT=}'[output metrics file basename]:basename:' \
  '--DBSNP=[reference dbSNP file]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  '--TARGET_INTERVALS=[target intervals to restrict analysis]:interval_list:_files -g "*.interval_list"' \
  '--SEQUENCE_DICTIONARY=[dictionary for faster dbSNP loading]:dict:_files' \
  '--GVCF_INPUT=[true if running on a single-sample GVCF]:bool:(true false)' \
  '--THREAD_COUNT=[number of threads for processing]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf file:_files -g "*.(vcf|vcf.gz|bcf)"' && ret=0

return ret
