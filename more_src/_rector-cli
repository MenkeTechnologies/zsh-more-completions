#compdef rector-cli
# _rector-cli — Rector PHP code upgrade tool CLI alias (Tomas Votruba / rectorphp, PHP); Symfony Console
# upstream: https://github.com/rectorphp/rector

_rector-cli() {
    local -a sub=(
        'process:apply rules'
        'worker:internal worker'
        'init:scaffold rector.php'
        'list-rules:list available rules'
        'detect-node-class-of-file:detect node class'
        'custom-rule:create new custom rule'
        'setup-ci:setup CI'
        'config-builder:configure builder'
        'list:list commands'
        'help:show help'
        'completion:dump completion script'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "rector.php *.php"' \
        '-c+[config file]:file:_files -g "rector.php *.php"' \
        '--memory-limit=+[memory limit]:str:' \
        '--clear-cache[clear cache]' \
        '--debug[debug]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rector subcommand' sub ;;
        args)
            case $words[1] in
                process) _arguments \
                    '--dry-run[dry run]' \
                    '-n[dry run]' \
                    '--no-progress-bar[no progress bar]' \
                    '--output-format=+[output format]:f:(console json gitlab github)' \
                    '--no-diffs[no diffs]' \
                    '--xdebug[allow xdebug]' \
                    '--clear-cache[clear cache]' \
                    '--rules=+[rules csv]:list:' \
                    '*:path:_files' ;;
                custom-rule) _arguments '1:rule-name:' ;;
                init|setup-ci|config-builder) _arguments '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_rector-cli "$@"
