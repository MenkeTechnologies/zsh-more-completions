#compdef r.out.png
# Export a GRASS raster map as a non-georeferenced PNG image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-t[make NULL cells transparent]' \
  '-w[output world file]' \
  '--overwrite[allow output files to overwrite existing files]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  'input=[name of input raster map]:input:' \
  'output=[name for new PNG file (- for stdout)]:output:_files' \
  'compression=[compression level 0-9]:compression:' \
  '*:param:' && ret=0

return ret
