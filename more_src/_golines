#compdef golines

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-m+[max line length]:length' \
  '--max-len=[max line length]:length' \
  '--tab-len=[tab character width]:width' \
  '--shorten-comments[shorten long comments]' \
  '--no-shorten-comments[do not shorten comments]' \
  '--reformat-tags[reformat struct tags]' \
  '--no-reformat-tags[do not reformat struct tags]' \
  '-w[write result to source file]' \
  '--write-output[write result to source file]' \
  '-l[list files that would be changed]' \
  '--list-files[list files that would be changed]' \
  '--base-formatter=[base formatter to use]:formatter:(gofmt goimports)' \
  '--chain-split-dots[split chained method calls on dots]' \
  '--no-chain-split-dots[do not split chained method calls on dots]' \
  '-d[show diff of changes]' \
  '--diff[show diff of changes]' \
  '--dry-run[show changes without writing]' \
  '--ignored-dirs=[directories to ignore]:dirs' \
  '--profile[enable profiling]' \
  '*:go files or directories:_files' && ret=0

return ret
