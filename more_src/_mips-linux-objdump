#compdef mips-linux-objdump mips-linux-gnu-objdump mipsel-linux-gnu-objdump mips64-linux-gnuabi64-objdump mips64el-linux-gnuabi64-objdump
# _mips-linux-objdump — GNU binutils mips-linux-objdump CLI cross-arch ELF object dumper disassembling MIPS32 MIPS64 mips mipsel microMIPS MIPS16 DSP MSA Loongson MMI instructions printing section headers symbol tables relocations source-mixed listings dwarf for OpenWRT routers Linux binaries (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_mips-linux-objdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a[archive headers]' \
        '--archive-headers[archive headers]' \
        '-f[file headers]' \
        '--file-headers[file headers]' \
        '-p[private headers]' \
        '--private-headers[private headers]' \
        '-h[section headers]' \
        '--section-headers[section headers]' \
        '--headers[section headers]' \
        '-x[all headers]' \
        '--all-headers[all headers]' \
        '-d[disassemble]' \
        '--disassemble[disassemble]' \
        '-D[disassemble all]' \
        '--disassemble-all[disassemble all]' \
        '-S[source-mixed]' \
        '--source[source-mixed]' \
        '-l[line numbers]' \
        '--line-numbers[line numbers]' \
        '-C[demangle]' \
        '--demangle[demangle]' \
        '-r[relocations]' \
        '--reloc[relocations]' \
        '-R[dynamic relocations]' \
        '--dynamic-reloc[dynamic relocations]' \
        '-s[section contents]' \
        '--full-contents[section contents]' \
        '-t[symbol table]' \
        '--syms[symbol table]' \
        '-T[dynamic symbol table]' \
        '--dynamic-syms[dynamic symbol table]' \
        '-g[debugging info]' \
        '--debugging[debugging info]' \
        '-W[dwarf]' \
        '--dwarf[dwarf]' \
        '--dwarf=+[type]:t:(info abbrev decodedline rawline loc Ranges pubnames frames frames-interp str gdb_index addr cu_index links follow-links)' \
        '-j+[section]:str:' \
        '--section=+[section]:str:' \
        '-b+[bfd]:str:' \
        '--target=+[bfd]:str:' \
        '-m+[arch]:a:(mips mips:isa32 mips:isa32r2 mips:isa32r6 mips:isa64 mips:isa64r2 mips:isa64r6 mips:loongson_2e mips:loongson_2f mips:loongson_3a mips:octeon)' \
        '--architecture=+[arch]:a:(mips mips:isa32 mips:isa64)' \
        '-M+[disassembler options]:str:' \
        '--disassembler-options=+[opts]:str:' \
        '--prefix=+[path]:dir:_files -/' \
        '--prefix-strip=+[N]:n:' \
        '--start-address=+[addr]:str:' \
        '--stop-address=+[addr]:str:' \
        '*:file:_files'
}

_mips-linux-objdump "$@"
