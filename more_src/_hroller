#compdef hroller

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-L --luxi)'{-L,--luxi}'+[LUXI socket]:socket:_files' \
  '(-t --text-data)'{-t,--text-data}'+[read data from file]:file:_files' \
  '(--rapi-data)--rapi-data=+[read from RAPI URL]:url:' \
  '(-G --group)'{-G,--group}'+[only group]:group:' \
  '(-O --offline)'{-O,--offline}'+[mark offline]:node:' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '(--print-moves)--print-moves[print resulting moves]' \
  '(--node-tags)--node-tags=+[filter by node tags]:tags:' \
  '(--ignore-non-redundant)--ignore-non-redundant[ignore non-redundant instances]' \
  '(--full-evacuation)--full-evacuation[do a full evacuation]' \
  '(--skip-non-redundant)--skip-non-redundant[skip non-redundant instances]' \
  '(-S --save-cluster)'{-S,--save-cluster}'+[save cluster state]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' && ret=0

return ret
