#compdef dnsgen
# Documentation: https://github.com/ProjectAnte/dnsgen
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-l --wordlen)'{-l,--wordlen}'=[min length of custom words (default 6)]:n:' \
  '(-w --wordlist)'{-w,--wordlist}'=[path to custom wordlist]:file:_files' \
  '(-f --fast)'{-f,--fast}'[fast generation mode]' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--help[show help]' \
  '*:file:_files' && ret=0

return ret
