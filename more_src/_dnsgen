#compdef dnsgen
# Documentation: https://man.archlinux.org/search?q=dnsgen
# Reference accessed: 2026-05-16

# Zsh completion for dnsgen
# Upstream: Generates DNS names from existing domain names
# Conservative fallback — run `dnsgen --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
