#compdef privategpt private-gpt
# _privategpt — Zylon AI privateGPT interact with documents using local LLM 100% private no internet (zylon-ai team, Python); argparse + uvicorn
# upstream: https://github.com/zylon-ai/private-gpt

_privategpt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--profile=+[settings profile]:str:' \
        '-p+[settings profile]:str:' \
        '--host=+[host]:host:_hosts' \
        '--port=+[port]:port:_ports' \
        '--reload[reload on changes]' \
        '--ui[run UI]' \
        '--no-ui[no UI]' \
        '--ingest=+[file or dir]:file:_files' \
        '--ingest-folder=+[folder]:dir:_files -/' \
        '--watch[watch folder for changes]' \
        '--clear-storage[clear stored documents]' \
        '--llm-mode=+[mode]:m:(local mock ollama llama-cpp openai openai-like anthropic sagemaker)' \
        '--embedding-mode=+[mode]:m:(local mock ollama huggingface openai openai-like sagemaker)' \
        '--vectorstore=+[store]:s:(chroma qdrant postgres clickhouse)' \
        '--reset-db[reset vector database]' \
        '--log-level=+[level]:l:(debug info warning error critical)' \
        '--log-format=+[format]:f:(default json yaml)' \
        '--config=+[config file]:file:_files -g "settings*.yaml *.yml"'
}

_privategpt "$@"
