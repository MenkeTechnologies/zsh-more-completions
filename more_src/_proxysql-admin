#compdef proxysql-admin
# Documentation: https://docs.couchbase.com/server/current/tools/cbimport.html
# Percona tool to configure cluster nodes into ProxySQL

local ret=1

_arguments -s -S \
  '--help[show usage information]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--config-file=[read login credentials from a config file]:path:_files' \
  '--login-file=[encrypted credential file]:path:_files' \
  '--login-password=[decrypt login file]:password:' \
  '--login-password-file=[file with decryption password]:path:_files' \
  '--writer-hg=[default writer hostgroup]:hg:' \
  '--reader-hg=[read-only hostgroup]:hg:' \
  '--backup-writer-hg=[backup writer hostgroup]:hg:' \
  '--offline-hg=[offline node hostgroup]:hg:' \
  '(-e --enable)'{-e,--enable}'[auto-configure cluster nodes into ProxySQL]' \
  '(-d --disable)'{-d,--disable}'[remove cluster configuration from ProxySQL]' \
  '--update-cluster[add new cluster nodes to configuration]' \
  '--syncusers[sync MySQL user accounts to ProxySQL]' \
  '--sync-multi-cluster-users[sync without deleting unmatched users]' \
  '--add-query-rule[create query rules for synced users]' \
  '--status[display current configuration report]' \
  '--quick-demo[set up a test environment without auth]' \
  '--mode=[read/write configuration mode]:mode:(loadbal singlewrite)' \
  '--max-connections=[maximum backend connections]:num:' \
  '--max-transactions-behind=[queued writeset threshold]:num:' \
  '--use-ssl[enable SSL for ProxySQL backend connections]' \
  '--writers-are-readers[control whether writers serve reads]:val:' \
  '--debug[enable verbose logging]' \
  '--force[bypass existing configuration validation]' && ret=0

return ret
