#compdef dotnet-format

# Zsh completion for dotnet-format - .NET code formatter

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'whitespace:run whitespace formatting'
  'style:run code style analyzers'
  'analyzers:run 3rd party analyzers'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '--version[show dotnet-format version]' \
  '--diagnostics[diagnostic IDs to fix]:diagnostics:' \
  '--severity[severity of analyzers to run]:level:(info warn error)' \
  '--no-restore[do not restore project prior to formatting]' \
  '--verify-no-changes[verify no changes would be made]' \
  '--include[space-separated files to include]:files:_files' \
  '--exclude[space-separated files to exclude]:files:_files' \
  '--include-generated[format generated files]' \
  '(-v --verbosity)'{-v,--verbosity}'[output verbosity]:level:(q quiet m minimal n normal d detailed diag diagnostic)' \
  '--binarylog[write binary log]:file:_files' \
  '--report[write report to directory]:dir:_files -/' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'dotnet-format command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (whitespace|style|analyzers)
        _arguments \
          '--folder[treat path as folder rather than solution/project]' \
          '--include[files to include]:files:_files' \
          '--exclude[files to exclude]:files:_files' \
          '--no-restore[skip restore]' \
          '--verify-no-changes[verify no changes]' \
          '(-v --verbosity)'{-v,--verbosity}'[verbosity]:level:(q quiet m minimal n normal d detailed diag diagnostic)' \
          '1:workspace:_files -g "*.(sln|csproj|fsproj|vbproj)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
