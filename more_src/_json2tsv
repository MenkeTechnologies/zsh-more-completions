#compdef json2tsv
# Documentation: https://git.codemadness.org/json2tsv/file/json2tsv.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (json2tsv.1 man page).

# codemadness json2tsv — reads JSON from stdin, writes TSV to stdout

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-n[show the indices for array types]' \
  '-r[show all control-characters]' \
  '-u[unbuffered: flush output after each value]' \
  '-F+[field separator (default TAB)]:sep:' \
  '-R+[record separator (default newline)]:sep:' && ret=0

return ret
