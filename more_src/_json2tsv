#compdef json2tsv

# codemadness json2tsv — json2tsv.c usage()

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-n[debug node bookkeeping]' \
  '-r[treat JSON numbers as raw strings]' \
  '-u[decode \\uXXXX escapes in strings]' \
  '-F+[field separator char]:sep:' \
  '-R+[record separator char]:sep:' && ret=0

return ret
