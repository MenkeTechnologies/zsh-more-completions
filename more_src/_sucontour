#compdef sucontour
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/extras/UnderbarMains/sucontour.c
# Contouring program for data plotting

local ret=1

_arguments -s -S \
  'title=[plot title]:title' \
  'ylabel=[vertical axis label]:ylabel' \
  'xlabel=[horizontal axis label]:xlabel' \
  'titlsz=[title print size]:titlsz' \
  'lablsz=[axis label print size]:lablsz' \
  'ticsz=[tic label print size]:ticsz' \
  'nytic=[number of tics on y-axis]:nytic' \
  'nxtic=[number of tics on x-axis]:nxtic' \
  'ymin=[minimum y value for tics]:ymin' \
  'dy=[y increment for tics (0 = no tic labels)]:dy' \
  'xmin=[minimum x value for tics]:xmin' \
  'dx=[x increment for tics (0 = no tic labels)]:dx' \
  'grid=[tics or lines for grid lines]:grid:(tics lines)' \
  'dash=[=1 to cycle thru dashed contours]:dash:(0 1)' \
  'c0=[minimum contour value]:c0' \
  'nc=[number of contours]:nc' \
  'cntrcol=[contour color (1..6) or all]:cntrcol' \
  'zeroy=[base of plot to bottom of screen]:zeroy' \
  'zerox=[left of plot to left of screen]:zerox' \
  'sizey=[vertical box size (inches)]:sizey' \
  'sizex=[horizontal box size (inches)]:sizex' \
  'tpow=[gain: power of time]:tpow' \
  'epow=[gain: exponential damping power]:epow' \
  'gpow=[gain: power of amplitude]:gpow' \
  'agc=[gain: automatic gain control]:agc:(0 1)' \
  'wagc=[gain: agc window length]:wagc' \
  'qbal=[gain: quantile balance]:qbal:(0 1)' \
  'pbal=[gain: power balance]:pbal' \
  'scale=[gain: scale factor]:scale' \
  '*:file:_files' && ret=0

return ret
