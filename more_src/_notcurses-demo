#compdef notcurses-demo
# Documentation: https://www.mankier.com/1/notcurses-demo
# notcurses-demo - show off some Notcurses features

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage message and exit]' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '-p[look in the specified path for data files]:path:_files -/' \
  '-d[apply a non-negative rational multiplier to the standard delay]:delaymult' \
  '-l[log between everything (7) and nothing (0) to stderr]:loglevel:(0 1 2 3 4 5 6 7)' \
  '-J[emit JSON summary of run to jsonfile]:jsonfile:_files' \
  '-m[define rendering margins]:margins' \
  '-k[inhibit use of the alternate screen]' \
  '-c[do not attempt to seed the PRNG]' \
  '*:demospec:' && ret=0

return ret
