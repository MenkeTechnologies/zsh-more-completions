autoload -U is-at-least

_todoke() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'--todoke-to=[Bypass rules, force the target (entry under \[todoke.<name>\])]:NAME:_default' \
'--todoke-group=[Bypass rules, force group]:NAME:_default' \
'--todoke-as=[Force how each argument is classified (skip auto-detection)]:KIND:(file url raw)' \
'*--todoke-verbose[Increase log verbosity (repeat for more\: --todoke-verbose --todoke-verbose)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::files -- Files, URLs, or raw strings to dispatch (no subcommand = default dispatch):_files' \
":: :_todoke_commands" \
"*::: :->todoke" \
&& ret=0
    case $state in
    (todoke)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:todoke-command-$line[2]:"
        case $line[2] in
            (list)
_arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'--alive-only[Only show instances that respond to ping]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(kill)
_arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'()--all[Kill every known instance]' \
'--force[Escalate to OS-level kill (SIGKILL / TerminateProcess) when \`\:qall!\` doesn'\''t take effect]' \
'-h[Print help]' \
'--help[Print help]' \
'::group:_default' \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
'*::inputs:_files' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
":: :_todoke__subcmd__config_commands" \
"*::: :->config" \
&& ret=0

    case $state in
    (config)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:todoke-config-command-$line[1]:"
        case $line[1] in
            (path)
_arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'--rendered[Print the TOML after Tera pre-render (no rule/file context is provided)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_todoke__subcmd__config__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:todoke-config-help-command-$line[1]:"
        case $line[1] in
            (path)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'--todoke-config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_todoke__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:todoke-help-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(kill)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
":: :_todoke__subcmd__help__subcmd__config_commands" \
"*::: :->config" \
&& ret=0

    case $state in
    (config)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:todoke-help-config-command-$line[1]:"
        case $line[1] in
            (path)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_todoke_commands] )) ||
_todoke_commands() {
    local commands; commands=(
'list:List alive editor instances' \
'kill:Terminate editor instance(s) by group' \
'check:Dry-run\: show the dispatch plan for the given inputs without executing' \
'doctor:Inspect the config for common footguns (unreachable rules, uncovered paths, …)' \
'config:Inspect or edit the config file' \
'completion:Generate shell completion script' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'todoke commands' commands "$@"
}
