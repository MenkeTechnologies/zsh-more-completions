#compdef cjpegli

_arguments -s \
  '--disable_output[do not write output]' \
  '*'{-x,--dec-hints}'=[decoder hint]:key=value:' \
  '(-d --distance)'{-d,--distance}'=[Butteraugli distance]:dist:' \
  '(-q --quality)'{-q,--quality}'=[quality]:n:' \
  '--chroma_subsampling=[subsampling]:sub:(444 440 422 420)' \
  '(-p --progressive_level)'{-p,--progressive_level}'=[progressive level]:level:(0 1 2)' \
  '--xyb[XYB color encoding]' \
  '--std_quant[standard quant tables]' \
  '--noadaptive_quantization[no adaptive quantization]' \
  '--fixed_code[fixed code]' \
  '--target_size=[target bytes]:n:' \
  '--num_reps=[encode N times]:n:' \
  '--quiet[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '1:input:_files' \
  '2:output:_files'
