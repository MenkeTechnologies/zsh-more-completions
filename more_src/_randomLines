#compdef randomLines
# UCSC kent: pick out random lines from file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-seed=[set seed used for randomizing]:n:' \
  '-decomment[remove blank lines and those starting with #]' \
  ':in file:_files' \
  ':count:' \
  ':out file:_files' && ret=0

return ret
