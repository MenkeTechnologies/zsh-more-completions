#compdef fluid-csi
# _fluid-csi — Fluid CSI plugin (fluid-cloudnative/fluid)
# upstream: https://github.com/fluid-cloudnative/fluid
# Subcommands + flags from cmd/csi/app/csi.go on tip.

_fluid-csi() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start the Fluid CSI driver'
                version:'print version and exit'
            )
            _describe -t commands 'fluid-csi command' cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--nodeid=[node ID exposed to Kubernetes]:id:' \
                        '--endpoint=[CSI gRPC endpoint URI]:uri:' \
                        '--prune-path=[prune path written to /etc/updatedb.conf]:path:_files -/' \
                        '--metrics-addr=[metrics bind address]:host\:port:' \
                        '--pprof-addr=[pprof bind address]:host\:port:' \
                        '--kubelet-kube-config=[kubelet kubeconfig path]:file:_files'
                    ;;
            esac
            ;;
    esac
}

_fluid-csi "$@"
