#compdef lspasswd
# Documentation: https://www.bsc.es/support/LSF/9.1.2/lsf_command_ref/lspasswd.1.html
# Reference accessed: 2026-05-19
# Verified: BSC mirror of Platform LSF 9.1.2 lspasswd(1) reference.
# Removed from prior file: bogus man.archlinux.org search URL;
# missing -p (password literal), -t (host_type), -r (remove), -c
# (check valid).

# lspasswd: maintain LSF user password file (Windows / eauth)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[print usage]' \
  '(- *)-V[print version]' \
  '-u+[DOMAIN\\user_name]:user:_users' \
  '-p+[password (avoid on CLI)]:password:' \
  '-t+[Windows server host type]:host_type:' \
  '-r[remove user entry]' \
  '-c[check that password is valid]' && ret=0
return ret
