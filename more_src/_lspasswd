#compdef lspasswd
# Documentation: https://man.archlinux.org/search?q=lspasswd
# Reference accessed: 2026-05-16

# lspasswd: maintain LSF user password file (eauth)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-u[user]:user:_users' \
  '*::lspasswd args:_files' && ret=0
return ret
