#compdef ReblockGVCF
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/variantutils/ReblockGVCF.java
# Condenses homRef blocks in a single-sample GVCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'[File to which variants should be written]:value:_files' \
  '--drop-low-quals=[Exclude variants and homRef blocks that are GQ0 from the reblocked GVCF to save space;...]:value:' \
  '(--rgq-threshold-to-no-call -rgq-threshold)'{--rgq-threshold-to-no-call,-rgq-threshold}'[Reference genotype quality (PL\[0\]) value below which variant sites will be converted...]:value:' \
  '--tree-score-threshold-to-no-call=[Tree score value below which variant sites will be converted to GQ0 homRef calls. Disab...]:value:' \
  '--annotations-to-keep=[Annotations that are not recognized by GATK to keep, that should be kept in final GVCF...]:value:' \
  '--format-annotations-to-remove=[FORMAT level annotations to remove from all genotypes in final GVCF.]:value:' \
  '(--do-qual-score-approximation -do-qual-approx)'{--do-qual-score-approximation,-do-qual-approx}'[Add necessary INFO field annotation to perform QUAL approximation downstream; required...]' \
  '--allow-missing-hom-ref-data[Fill in homozygous reference genotypes with no PLs and no GQ with PL=\[0,0,0\]. Necessa...]' \
  '--keep-all-alts[Keep all ALT alleles and full PL array for most accurate GQs]' \
  '(--keep-site-filters -keep-filters)'{--keep-site-filters,-keep-filters}'[Keep site level filters for variants (not ref blocks).]' \
  '--add-site-filters-to-genotype[Add site level filters to genotype level. Site level filters removed by default, if the...]' \
  '*:argument:_files' && ret=0

return ret
