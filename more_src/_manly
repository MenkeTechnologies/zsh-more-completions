#compdef manly
# Documentation: https://github.com/carlbordum/manly
# manly - explain how flags modify a command's behaviour using its man page

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[display version information and exit]' \
  '1:command:_command_names' \
  '*::flags:' && ret=0

return ret
