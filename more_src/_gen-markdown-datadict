#compdef gen-markdown-datadict
# _gen-markdown-datadict — emit a Markdown data dictionary from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/markdowndatadictgen.py (click).

_gen-markdown-datadict() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.md"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(markdown md)'
        '*'{-c+,--classes=}'[class(es) to emit (repeatable)]:class:'
        '--anchor-style=[Markdown anchor style]:style:(slugified raw)'
        '--separate-erd-components[emit one ER diagram per logical component]'
        '--single-erd[emit a single ER diagram for the whole schema]'
        '--omit-standalone-classes[skip classes that are not connected to others]'
        '--debug[emit debug-level diagnostic output]'
        '--kroki-server=[Kroki server URL for diagram rendering]:url:'
        '--diagram-dir=[directory for generated diagram images]:dir:_files -/'
        '--pretty-format-svg[pretty-format generated SVG diagrams]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-markdown-datadict "$@"
