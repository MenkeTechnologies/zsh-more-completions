#compdef uvlist
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvlist.html
# MIRIAD uvlist - list contents of a uv dataset

local ret=1

_arguments -s -S \
  'vis=[input uv dataset name]:vis:_files' \
  'options=[brief,full,data,variables,sigma,spectral,array,source,nocal,nopol,nopass]:options' \
  'select=[uv data selection]:select' \
  'stokes=[Stokes parameter]:stokes' \
  'line=[uv line type for data options]:line' \
  'recnum=[number of output records to limit]:recnum' \
  'log=[output file for listing results]:log:_files' \
  '*:visibility data:_files' && ret=0

return ret
