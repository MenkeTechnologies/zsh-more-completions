#compdef edje_player
# Documentation: https://man.archlinux.org/search?q=edje_player
# Reference accessed: 2026-05-16

# edje_player: play .edj files for testing
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-S[scale factor]:scale:' \
  '--scale=[scale factor]:scale:' \
  '-Z[zoom factor]:zoom:' \
  '--zoom=[zoom factor]:zoom:' \
  '-g[group name]:group:' \
  '--group=[group name]:group:' \
  '-G[list groups]' \
  '--list-groups[list groups]' \
  '-w[output width]:w:' \
  '--width=[output width]:w:' \
  '-W[wayland]' \
  '--wayland[wayland]' \
  '-h[output height]:h:' \
  '--height=[output height]:h:' \
  '-L[loop animation]' \
  '--loop[loop animation]' \
  '-p[disable parts swallow placeholders]' \
  '--no-stop[do not stop on Escape]' \
  '-s[load size N from object]:size:' \
  '*:file:_files -g "*.edj"' && ret=0
return ret
