#compdef edje_player
# Documentation: https://github.com/Enlightenment/efl/blob/master/src/bin/edje/edje_player.c
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above.

# edje_player: play .edj files for testing
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-L,--license}'[show license information]' \
  '(- *)'{-C,--copyright}'[show copyright information]' \
  '(-g --group)'{-g,--group=}'[edje group to view (default main)]:group:' \
  '(-G --list-groups)'{-G,--list-groups}'[list groups in the file]' \
  '(-e --engine)'{-e,--engine=}'[Ecore-Evas engine to use]:engine:' \
  '(-E --list-engines)'{-E,--list-engines}'[list Ecore-Evas engines]' \
  '(-Z --size)'{-Z,--size=}'[size to use in WxH form]:size:' \
  '(-c --bg-color)'{-c,--bg-color=}'[background color (if not shaped/alpha)]:color:' \
  '(-b --borderless)'{-b,--borderless}'[display window without border]' \
  '(-y --sticky)'{-y,--sticky}'[display window sticky]' \
  '(-s --shaped)'{-s,--shaped}'[display window shaped]' \
  '(-a --alpha)'{-a,--alpha}'[display window with alpha channel]' \
  '(-t --title)'{-t,--title=}'[set window title]:title:' \
  '(-p --print)'{-p,--print}'[print signals and messages to stdout]' \
  '(-S --slave-mode)'{-S,--slave-mode}'[listen for commands on stdin]' \
  '(-z --scale)'{-z,--scale=}'[scale factor]:scale:' \
  '(-P --pad)'{-P,--pad=}'[pixel padding around object]:pad:' \
  '*:file:_files -g "*.edj"' && ret=0
return ret
