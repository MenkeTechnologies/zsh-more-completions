#compdef tsftrunc
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsftrunc.cpp
# tsftrunc - truncate an MPEG transport stream file to a packet boundary

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-b --byte)'{-b,--byte}'=[truncate at next packet boundary after byte size]:bytes:' \
  '(-n --noaction)'{-n,--noaction}'[do not perform truncation, check mode only]' \
  '(-p --packet)'{-p,--packet}'=[index of first packet to truncate]:packet:' \
  '(-s --size-of-packet)'{-s,--size-of-packet}'=[TS packet size in bytes (default 188)]:size:' \
  '*:ts file:_files -g "*.ts *.m2ts *.mpg"' && ret=0

return ret
