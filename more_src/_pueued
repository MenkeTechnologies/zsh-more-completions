#compdef pueued
# Documentation: https://github.com/Nukesor/pueue/blob/main/pueue/src/bin/pueued.rs
# Reference accessed: 2026-05-20
# Verified: upstream pueued.rs clap definitions.

# pueued: pueue daemon
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[path to config file]:file:_files' \
  '--profile=[profile to load]:profile:' \
  '(-v --verbose)*'{-v,--verbose}'[verbose output (repeatable)]' \
  '(-d --daemonize)'{-d,--daemonize}'[run as a daemon in the background]' && ret=0

return ret
