#compdef pueued

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --port)'{-p,--port}'[the port to listen on]:port' \
  '--config=[path to config file]:config file:_files' \
  '-v[verbose output (use multiple times for more verbosity)]' \
  '--verbose[verbose output]' && ret=0

return ret
