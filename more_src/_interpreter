#compdef interpreter
# Documentation: https://man.archlinux.org/search?q=interpreter
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-p --profile)'{-p,--profile}'=[profile yaml]:profile:' \
  '-ci+[custom instructions]:text:' \
  '--custom_instructions+[custom instructions]:text:' \
  '-sm+[system message]:text:' \
  '--system_message+[system message]:text:' \
  '(-y --auto_run)'{-y,--auto_run}'[automatically run generated code]' \
  '(-nhl --no_highlight_active_line)'{-nhl,--no_highlight_active_line}'[disable active line highlighting]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
  '(-m --model)'{-m,--model}'=[language model]:model:' \
  '(-t --temperature)'{-t,--temperature}'=[model temperature]:float:' \
  '-lsv[LLM supports vision]' \
  '--llm_supports_vision[LLM supports vision]' \
  '--no-llm_supports_vision[LLM does not support vision]' \
  '-lsf[LLM supports function calls]' \
  '--llm_supports_functions[LLM supports function calls]' \
  '--no-llm_supports_functions[LLM does not support function calls]' \
  '(-cw --context_window)'{-cw,--context_window}'=[context window size]:n:' \
  '(-x --max_tokens)'{-x,--max_tokens}'=[max tokens]:n:' \
  '(-b --max_budget)'{-b,--max_budget}'=[max budget USD]:amount:' \
  '(-ab --api_base)'{-ab,--api_base}'=[API base URL]:url:' \
  '(-ak --api_key)'{-ak,--api_key}'=[API key]:key:' \
  '(-av --api_version)'{-av,--api_version}'=[API version]:version:' \
  '(-xo --max_output)'{-xo,--max_output}'=[max output characters]:n:' \
  '--loop[loop until task admits complete or failed]' \
  '(-dt --disable_telemetry)'{-dt,--disable_telemetry}'[disable telemetry]' \
  '(-o --offline)'{-o,--offline}'[disable online features]' \
  '(-sp --speak_messages)'{-sp,--speak_messages}'[read messages aloud (macOS)]' \
  '(-safe --safe_mode)'{-safe,--safe_mode}'=[safety mode]:mode:(off ask auto)' \
  '(-debug --debug)'{-debug,--debug}'[developer debug]' \
  '(-f --fast)'{-f,--fast}'[fast gpt-4o-mini profile]' \
  '(-ml --multi_line)'{-ml,--multi_line}'[multi-line input with ```]' \
  '(-l --local)'{-l,--local}'[local model profile]' \
  '--codestral[codestral profile]' \
  '--assistant[assistant profile]' \
  '--llama3[llama3 profile]' \
  '--groq[groq profile]' \
  '(-vi --vision)'{-vi,--vision}'[vision profile]' \
  '--os[OS control profile]' \
  '--reset_profile-[reset profile(s)]:profile:' \
  '--profiles[open profiles directory]' \
  '--local_models[open local models directory]' \
  '--conversations[list conversations]' \
  '--server[run API server]' \
  '--version[print version]' \
  '--contribute_conversation[contribute conversation to OSS training]' \
  '(-pl --plain)'{-pl,--plain}'[plain text display]' \
  '(-s --stdin)'{-s,--stdin}'[stdin mode]' \
  '*::initial prompt: _default'
