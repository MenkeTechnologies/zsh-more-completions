#compdef btg-cli bitcoingold-cli
# _btg-cli — Bitcoin Gold btg-cli JSON-RPC client CLI for the Equihash 144-5 GPU-friendly fork of Bitcoin daemon issuing wallet getbalance sendtoaddress listunspent generate getblockchaininfo getmempoolinfo addnode getpeerinfo importprivkey (BTCGPU team, C++); custom argparse
# upstream: https://github.com/BTCGPU/BTCGPU

_btg-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf bitcoingold.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-named[use named JSON-RPC]' \
        '-rpcconnect=+[host]:h:_hosts' \
        '-rpcport=+[port]:n:' \
        '-rpcwait[wait for RPC server]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcclienttimeout=+[seconds]:n:' \
        '-rpccookiefile=+[file]:file:_files' \
        '-stdin[read input from stdin]' \
        '-stdinrpcpass[read RPC password from stdin]' \
        '-getinfo[print info]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getnetworkinfo getmempoolinfo getmininginfo getbalance listunspent listtransactions sendtoaddress getnewaddress validateaddress dumpprivkey importprivkey importwallet dumpwallet generate generatetoaddress getrawtransaction createrawtransaction signrawtransaction sendrawtransaction addnode getpeerinfo getnettotals setban listbanned)'
}

_btg-cli "$@"
