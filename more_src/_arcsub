#compdef arcsub
# Documentation: https://www.nordugrid.org/arc/arc7/users/client_tools.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# arcsub: submit an ARC compute job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-d[debug level]:level:(FATAL ERROR WARNING INFO VERBOSE DEBUG)' \
  '--debug=[debug level]:level:(FATAL ERROR WARNING INFO VERBOSE DEBUG)' \
  '-c[cluster URL]:url:' \
  '--cluster=[cluster URL]:url:' \
  '-y[broker]:broker:' \
  '--broker=[broker]:broker:' \
  '-x[direct match]' \
  '--dryrun[dryrun]' \
  '-D[dryrun]' \
  '-f[ARC job description]:file:_files' \
  '--jobdescrfile=[ARC job description]:file:_files' \
  '-e[job description string]:expr:' \
  '--jobdescrstring=[job description string]:expr:' \
  '-i[index server]:url:' \
  '--index=[index server]:url:' \
  '-q[do not query brokers]' \
  '-o[output job IDs to file]:file:_files' \
  '--jobids-output=[output job IDs to file]:file:_files' \
  '-C[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-Z[runtime envs]:list:' \
  '*:job description file:_files' && ret=0
return ret
