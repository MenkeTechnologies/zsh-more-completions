#compdef bd beads
# Documentation: https://github.com/steveyegge/beads
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bd / beads: Git-friendly issue tracker for AI coding agents

_bd() {
    local line state
    local -a commands
    commands=(
        'init:initialize beads in a project'
        'create:create a new task'
        'ready:list tasks ready to work on (no open blockers)'
        'show:display task details and history'
        'update:update task status / properties'
        'remember:store a persistent project insight'
        'close:mark a task as complete'
        'sync:synchronize with remote Git repository'
        'prime:output workflow context and memories'
        'dep:manage task dependencies'
        'setup:install agent integrations'
        'dolt:manage Dolt database operations'
        'backup:handle data backups and migrations'
        'daemon:run background service'
    )

    _arguments -C \
        '--json[output JSON]' \
        '--stealth[git-free operation (init)]' \
        '--contributor[fork-based workflow (init)]' \
        '--server[server mode connection (init)]' \
        '--skip-agents[omit agent files (init)]' \
        '--server-host=[server host]:host:' \
        '--server-port=[server port]:port:' \
        '--server-socket=[server socket]:socket:' \
        '--server-user=[server user]:user:' \
        '-p+[priority level (create)]:priority:' \
        '-t+[task type (create), e.g. bug]:type:' \
        '--claim[atomically claim a task (update)]' \
        '--thread=[message threading]:thread:' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'beads command' commands
            ;;
        args)
            case $line[1] in
                update|close|show)
                    _arguments '1:task-id:'
                    ;;
                create)
                    _arguments '1:task-name:'
                    ;;
                remember)
                    _arguments '1:insight:'
                    ;;
                dep)
                    _arguments '1:subcommand:(add remove list)'
                    ;;
            esac
            ;;
    esac
}

_bd "$@"
