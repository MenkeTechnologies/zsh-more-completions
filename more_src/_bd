#compdef bd beads

_bd() {
    local line state
    local -a commands
    commands=(
        'init:Initialize Beads in project'
        'create:Create a new task'
        'ready:List tasks ready to work on'
        'update:Mark a task as in-progress'
        'remember:Store a persistent project insight'
        'close:Mark a task as complete'
        'sync:Synchronize with remote Git repository'
    )

    _arguments -C \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'beads command' commands
            ;;
        args)
            case $line[1] in
                update|close)
                    _arguments '1:task-id:'
                    ;;
                create)
                    _arguments '1:task-name:'
                    ;;
                remember)
                    _arguments '1:insight:'
                    ;;
            esac
            ;;
    esac
}

_bd "$@"
