#compdef mongocompass

# MongoDB Compass: official GUI for MongoDB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--no-sandbox[Electron: disable sandbox]' \
  '--disable-gpu[Electron: disable GPU]' \
  '--enable-logging[Electron: enable logging]' \
  '--remote-debugging-port=[Electron: remote debugging port]:port:' \
  '--user-data-dir=[Electron user data dir]:dir:_files -/' \
  '--theme=[theme]:theme:(LIGHT DARK OS_THEME)' \
  '--enable-feedback-panel[enable feedback panel]' \
  '--no-protocol-listener[do not register mongodb:// protocol handler]' \
  '--cli-connection-string[CLI connection string]:uri:' \
  '*:URI or file:_files' && ret=0
return ret
