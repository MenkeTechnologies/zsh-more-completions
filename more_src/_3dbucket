#compdef 3dbucket
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dbucket.html
# AFNI collect sub-bricks from multiple datasets into one bucket dataset

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '(-prefix -output)'{-prefix,-output}'[output dataset prefix]:prefix' \
  '-session[output session directory]:dir:_files -/' \
  '-glueto[append bricks to end of existing dataset]:dataset:_files' \
  '-aglueto[create or append to existing dataset]:dataset:_files' \
  '-dry[dry run; show what would be done]' \
  '-verb[verbose output]' \
  '-fbuc[create a functional bucket dataset]' \
  '-abuc[create an anatomical bucket dataset]' \
  '*:dataset:_files' && ret=0

return ret
