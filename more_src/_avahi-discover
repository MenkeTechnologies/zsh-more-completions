#compdef avahi-discover
# _avahi-discover — Avahi avahi-discover (GTK browser presenting the mDNS / DNS-SD service tree in real time; --version prints version, --domain DOMAIN starts scoped to a non-local domain, --no-host-name disables resolver display; takes no positional arguments)
# upstream: https://github.com/avahi/avahi
# Flags from avahi avahi-discover-standalone/main.py on tip.

_avahi-discover() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-d+[domain]:domain:' \
        '--domain+[domain]:domain:' \
        '--no-host-name[no host name display]'
}

_avahi-discover "$@"
