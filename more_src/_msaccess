#compdef msaccess
# Documentation: https://proteowizard.sourceforge.io/tools/msaccess.html
# ProteoWizard: command-line access to mass-spec data files

local ret=1

_arguments -s -S \
  '(-f --filelist)'{-f,--filelist}'[text file containing filenames to process]:file:_files' \
  '(-o --outdir)'{-o,--outdir}'[output directory]:dir:_files -/' \
  '(-c --config)'{-c,--config}'[configuration file (settings as optionName=value)]:file:_files' \
  '*'{-x,--exec}'[execute command, e.g. --exec "tic mz=409-412"]:command:' \
  '*--filter[add a spectrum list filter, e.g. --filter="msLevel [2,3]"]:filter:' \
  '(-v --verbose)'{-v,--verbose}'[print progress messages]' \
  '--help[show usage with extra detail on filter options]' \
  '*:data file:_files' && ret=0

return ret
