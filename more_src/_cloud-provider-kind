#compdef cloud-provider-kind
# Documentation: https://github.com/kubernetes-sigs/cloud-provider-kind
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# kubernetes-sigs/cloud-provider-kind: cloud controller for kind clusters

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '--gateway-channel=[Gateway API release channel]:channel:(standard experimental disabled)' \
  '--enable-lb-port-mapping[enable port mapping for LoadBalancer services]' \
  '*::args:_default' && return 0
