#compdef podracer
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/podracer.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-c,-catchup,--catchup,catchup}'[run in catchup mode]' \
  '(- *)'{-v,-version,--version,version}'[show version information and exit]' && ret=0

return ret
