#compdef xbcrypt

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-d --decrypt)'{-d,--decrypt}'[decrypt data (default is encrypt)]' \
  '(-i --input)'{-i,--input=}'[input file]:file:_files' \
  '(-o --output)'{-o,--output=}'[output file]:file:_files' \
  '(-a --encrypt-algo)'{-a,--encrypt-algo=}'[encryption algorithm]:algo:(AES128 AES192 AES256)' \
  '(-k --encrypt-key)'{-k,--encrypt-key=}'[encryption key]:key:' \
  '(-f --encrypt-key-file)'{-f,--encrypt-key-file=}'[key file]:file:_files' \
  '(-s --encrypt-chunk-size)'{-s,--encrypt-chunk-size=}'[chunk size in bytes]:bytes:' \
  '--encrypt-threads=[parallel worker threads]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]'
