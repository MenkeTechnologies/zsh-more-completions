#compdef json2msgpack
# Documentation: https://github.com/ludocode/msgpack-tools/blob/develop/docs/json2msgpack.md
# json2msgpack - convert JSON to MessagePack

local ret=1

_arguments -s -S \
  '-h[print usage]' \
  '-i[read from the given file instead of standard input]:in-file:_files' \
  '-o[write to the given file instead of standard output]:out-file:_files' \
  '-l[lax mode: permit comments and trailing commas in JSON]' \
  '-f[convert real numbers to floats instead of doubles]' \
  '-b[interpret base64: prefixed strings as binary objects]' \
  '-B[auto-detect base64 on non-key strings of at least min-bytes length]:min-bytes' && ret=0

return ret
