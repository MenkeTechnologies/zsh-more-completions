#compdef wal-g

# Zsh completion for WAL-G - archival and restoration for databases

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:config:_files -g "*.{json,yaml,yml}"' \
  '--turbo[enable turbo mode]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'backup-push:push a new backup'
      'backup-fetch:fetch a backup'
      'backup-list:list available backups'
      'backup-mark:mark a backup'
      'backup-delete:delete a backup'
      'wal-push:push WAL segment'
      'wal-fetch:fetch WAL segment'
      'wal-show:show WAL storage'
      'wal-verify:verify WAL segments'
      'delete:delete old backups and WAL'
      'catchup-push:push a catchup backup'
      'catchup-fetch:fetch a catchup backup'
      'copy:copy backups between storages'
      'st:storage tools'
      'daemon:run WAL-G daemon'
    )
    _describe -t commands 'wal-g command' commands && ret=0
    ;;
  args)
    case $line[1] in
      backup-push)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--full[force full backup]' \
          '--delta-from-name=[delta from backup name]:name' \
          '--delta-from-user-data=[delta from user data]:data' \
          '--pgdata=[pg data directory]:directory:_directories' \
          '1:pgdata directory:_directories' && ret=0
        ;;
      backup-fetch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--restore-only=[restore specific databases]:databases' \
          '--reverse-unpack[unpack in reverse order]' \
          '--skip-redundant-tars[skip redundant tars]' \
          '1:destination:_directories' \
          '2:backup name' && ret=0
        ;;
      backup-list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--json[output in JSON format]' \
          '--pretty[pretty print JSON output]' \
          '--detail[show detailed information]' && ret=0
        ;;
      backup-delete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--confirm[confirm deletion]' \
          '1:backup name' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--confirm[confirm deletion]' \
          '1:target:(before retain everything)' && ret=0
        ;;
      wal-push)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:WAL file:_files' && ret=0
        ;;
      wal-fetch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:WAL name' \
          '2:destination:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
