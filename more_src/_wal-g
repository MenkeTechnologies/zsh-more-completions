#compdef wal-g
# Documentation: https://github.com/wal-g/wal-g
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for WAL-G - archival and restoration for databases

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:config:_files -g "*.{json,yaml,yml}"' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'backup-push:push a new backup'
      'backup-fetch:fetch a backup'
      'backup-list:list available backups'
      'backup-mark:mark a backup permanent/temporary'
      'backup-delete:delete a backup'
      'wal-push:push WAL segment'
      'wal-fetch:fetch WAL segment'
      'wal-show:show WAL storage'
      'wal-verify:verify WAL segments'
      'wal-receive:stream WAL via replication'
      'wal-restore:recover missing WAL segments for pg_rewind'
      'delete:delete old backups and WAL'
      'catchup-push:push a catchup backup'
      'catchup-fetch:fetch a catchup backup'
      'catchup-send:send catchup backup to lagging replica'
      'catchup-receive:receive catchup backup'
      'copy:copy backups between storages'
      'st:storage tools'
      'daemon:run WAL-G daemon'
    )
    _describe -t commands 'wal-g command' commands && ret=0
    ;;
  args)
    case $line[1] in
      backup-push)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--permanent[mark backup as permanent]' \
          '--rating-composer[use rating composer]' \
          '--copy-composer[use copy composer]' \
          '--database-composer[use database composer]' \
          '--without-files-metadata[do not store files metadata]' \
          '--verify[verify backup after push]' \
          '--delta-from-name=[delta from backup name]:name' \
          '--delta-from-user-data=[delta from user data]:data' \
          '1:pgdata directory:_directories' && ret=0
        ;;
      backup-fetch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--target-user-data=[target user data]:data' \
          '--restore-only=[restore specific databases]:databases' \
          '--reverse-unpack[unpack in reverse order]' \
          '--skip-redundant-tars[skip redundant tars]' \
          '1:destination:_directories' \
          '2:backup name' && ret=0
        ;;
      backup-list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--json[output in JSON format]' \
          '--pretty[pretty print output]' \
          '--detail[show detailed information]' && ret=0
        ;;
      backup-mark)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-i+[backup name]:name' \
          '1:backup name' && ret=0
        ;;
      backup-delete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--confirm[confirm deletion]' \
          '1:backup name' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--confirm[confirm deletion]' \
          '--use-sentinel-time[order backups by sentinel time]' \
          '--after=[retain backups after name/time]:value' \
          '--target-user-data=[delete by user data]:data' \
          '1:target:(before retain everything target garbage)' && ret=0
        ;;
      wal-push)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:WAL file:_files' && ret=0
        ;;
      wal-fetch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:WAL name' \
          '2:destination:_files' && ret=0
        ;;
      wal-show)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--without-backups[exclude backup info]' \
          '--detailed-json[detailed JSON output]' && ret=0
        ;;
      wal-verify)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--json[output in JSON format]' \
          '1:check type:(integrity timeline)' && ret=0
        ;;
      catchup-push)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--from-lsn=[starting LSN]:lsn' && ret=0
        ;;
      copy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--from=[source storage]:storage' \
          '--to=[destination storage]:storage' \
          '--backup-name=[backup name]:name' \
          '--with-history[include history]' && ret=0
        ;;
    esac
    ;;
esac

return ret
