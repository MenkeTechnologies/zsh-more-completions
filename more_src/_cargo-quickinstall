#compdef cargo-quickinstall
# Documentation: https://github.com/cargo-bins/cargo-quickinstall
# Reference accessed: 2026-05-21
# Verified: upstream main.rs flag handling at the URL above.

# cargo-quickinstall: install prebuilt cargo binaries (often via cargo-binstall).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--help[print help information]' \
  '--version[print version]' \
  '--no-binstall[use curl-based installation instead of cargo-binstall]' \
  '--dry-run[simulate installation without executing]' \
  '--try-upstream[attempt to download from upstream sources]' \
  '--fallback[enable fallback compilation strategy]' \
  '--force[force installation even if already present]' \
  '--target=[target triple]:triple:' \
  '*:crate:' && ret=0

return ret
