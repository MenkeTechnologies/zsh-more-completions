#compdef cimcli
# Documentation: https://collaboration.opengroup.org/pegasus/pp/documents/12259/cimcliCmdHelp.htm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (OpenPegasus cimcli reference).

# cimcli: OpenPegasus CIM client CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'gc:get class'
  'gi:get instance'
  'ec:enumerate classes'
  'ein:enumerate instance names'
  'ecn:enumerate class names'
  'ei:enumerate instances'
  'mi:modify instance'
  'ci:create instance'
  'di:delete instance'
  'a:associators'
  'an:association names'
  'r:references'
  'rn:reference names'
  'gp:get property'
  'sp:set property'
  'im:invoke method'
  'ns:list namespaces'
  'ts:test connection to server'
  'sub:subscribe'
  'unsub:unsubscribe'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-n[namespace]:ns:' \
  '-u[user]:user:_users' \
  '-w[password]:pass:' \
  '-l[CIM host]:host:_hosts' \
  '-p[port]:port:' \
  '-s[use SSL]' \
  '-t[timeout]:seconds:' \
  '-o[output format]:fmt:(mof xml table json)' \
  '-r[role/result-role]:role:' \
  '-ac[assoc class]:class:' \
  '-rc[result class]:class:' \
  '-pl[property list]:props:' \
  '-niq[no include qualifiers]' \
  '-di[deep inheritance]' \
  '-lo[local only]' \
  '-iq[include qualifiers]' \
  '-co[show client output details]' \
  '-v[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'cimcli command' commands && ret=0 ;;
esac
return ret
