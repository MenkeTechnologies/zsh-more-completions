#compdef cimcli

# cimcli: OpenPegasus CIM/WBEM client
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'ci:CreateInstance'
  'cn:Class Names enumerate'
  'cni:Class Names instance enumerate'
  'co:Class enumerate operations'
  'cq:Query'
  'cr:Class references'
  'ec:EnumerateClasses'
  'ecn:EnumerateClassNames'
  'ei:EnumerateInstances'
  'ein:EnumerateInstanceNames'
  'gc:GetClass'
  'gi:GetInstance'
  'gp:GetProperty'
  'gq:GetQualifier'
  'sp:SetProperty'
  'sq:SetQualifier'
  'dq:DeleteQualifier'
  'di:DeleteInstance'
  'dc:DeleteClass'
  'im:InvokeMethod'
  'ns:enumerate Namespaces'
  'r:References (instance)'
  'rn:ReferenceNames'
  'a:Associators'
  'an:AssociatorNames'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '-n[namespace]:ns:' \
  '-l[location URL]:url:' \
  '-u[username]:user:' \
  '-p[password]:pwd:' \
  '-t[reply timeout (seconds)]:sec:' \
  '-v[verbose]' \
  '-T[trace level]:n:' \
  '-cert[client cert file]:file:_files' \
  '-key[client key file]:file:_files' \
  '-c[count of results]:n:' \
  '-d[max depth]:n:' \
  '-r[reverse output order]' \
  '-S[summary]' \
  '-x[XML output]' \
  '-mlo[max line output]:n:' \
  '-noverify[no TLS verification]' \
  '1: :->cmd' \
  '*::cimcli subcommand args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'cimcli command' commands && ret=0 ;;
esac
return ret
