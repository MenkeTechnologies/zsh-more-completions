#compdef code-minimap

# Zsh completion for code-minimap (code minimap generator)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--hscale=[horizontal scale]:scale' \
  '--vscale=[vertical scale]:scale' \
  '--padding=[padding between characters]:padding' \
  '-H+[output height in lines]:height' \
  '--horizontal-output[render minimap horizontally]' \
  '--output=[output mode]:mode:(characters unicode-block-elements)' \
  '*:file:_files'
