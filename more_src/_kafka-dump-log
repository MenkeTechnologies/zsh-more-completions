#compdef kafka-dump-log

local -a arguments

arguments=(
    '--files[Comma-separated list of data and index log files to dump]:files:_files'
    '--deep-iteration[Use deep iteration instead of shallow iteration]'
    '--max-message-size[Maximum record batch size]:bytes:'
    '--print-data-log[Print the messages in the log]'
    '--index-sanity-check[Check index sanity without printing contents]'
    '--verify-index-only[Verify the index log without printing contents]'
    '--transaction-log-decoder[Decode transaction log]'
    '--cluster-metadata-decoder[Decode cluster metadata log]'
    '--offsets-decoder[Decode offset commit log]'
    '--value-decoder-class[Custom decoder class for values]:class:'
)

_arguments -s -S $arguments
