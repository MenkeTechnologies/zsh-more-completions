#compdef wmenu wmenu-run
# Documentation: https://man.archlinux.org/search?q=wmenu
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-b[bottom of screen]' \
  '-i[case-insensitive match]' \
  '-x[allow X11 keys]' \
  '-l+[lines to display]:n:' \
  '-o+[output number]:n:' \
  '-O+[output name]:name:' \
  '-p+[prompt]:prompt:' \
  '-N+[normal background color]:color:' \
  '-n+[normal foreground color]:color:' \
  '-M+[selected background color]:color:' \
  '-m+[selected foreground color]:color:' \
  '-S+[selection background color]:color:' \
  '-s+[selection foreground color]:color:' \
  '-f+[font]:font:' \
  '-c+[max chars]:n:' \
  '-P+[password char]:char:' \
  '-d+[delimiter]:char:' && ret=0

return ret
