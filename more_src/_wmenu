#compdef wmenu wmenu-run
# Documentation: https://man.archlinux.org/man/extra/wmenu/wmenu.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. wmenu has single-letter flags only.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-b[appear at the bottom of the screen]' \
  '-i[case-insensitive item matching]' \
  '-P[password mode (replace input with asterisks)]' \
  '-v[show version]' \
  '-f+[font in Pango format]:font' \
  '-l+[list items vertically with given lines]:lines' \
  '-o+[output to display menu on]:output' \
  '-p+[prompt displayed left of input field]:prompt' \
  '-N+[normal background color (RRGGBB[AA])]:color' \
  '-n+[normal foreground color (RRGGBB[AA])]:color' \
  '-M+[prompt background color (RRGGBB[AA])]:color' \
  '-m+[prompt foreground color (RRGGBB[AA])]:color' \
  '-S+[selection background color (RRGGBB[AA])]:color' \
  '-s+[selection foreground color (RRGGBB[AA])]:color' && ret=0

return ret
