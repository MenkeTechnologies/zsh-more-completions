#compdef pdfsandwich
# Documentation: https://manpages.debian.org/bookworm/pdfsandwich/pdfsandwich.1.en.html
# generate sandwich OCR pdfs from scanned pdf files

local ret=1

_arguments -s -S \
  '(-help --help)'{-help,--help}'[display list of options]' \
  '-convert[name of convert binary]:binary:_command_names -e' \
  '-coo[additional convert options]:options' \
  '-debug[keep all temporary files in /tmp]' \
  '-enforcehocr2pdf[use hocr2pdf even if tesseract >= 3.03]' \
  '-first_page[page number to start OCR from]:page' \
  '-gray[use grayscale for images]' \
  '-grayfilter[enable unpaper gray filter]' \
  '-gs[name of gs binary]:binary:_command_names -e' \
  '-hocr2pdf[name of hocr2pdf binary]:binary:_command_names -e' \
  '-hoo[additional hocr2pdf options]:options' \
  '-identify[name of identify binary]:binary:_command_names -e' \
  '-lang[language of the text (tesseract)]:lang' \
  '-last_page[page number up to which to process OCR]:page' \
  '-layout[layout of scanned pages]:layout:(single double none)' \
  '-list_langs[list available languages and exit]' \
  '-maxpixels[max pixels allowed for input file]:pixels' \
  '-noimage[do not place the image over the text]' \
  '-nopreproc[do not preprocess with unpaper]' \
  '-nthreads[number of parallel threads]:n' \
  '-o[output file]:file:_files' \
  '-omp_thread_limit[threads tesseract may use per page]:n' \
  '-pagesize[output pdf page size]:size' \
  '-pdfinfo[name of pdfinfo binary]:binary:_command_names -e' \
  '-pdfunite[name of pdfunite binary]:binary:_command_names -e' \
  '-quiet[suppress output]' \
  '-resolution[resolution (dpi) used for OCR]:dpi' \
  '-rgb[use RGB color space for images]' \
  '-sloppy_text[sloppily place text, group words]' \
  '-tesseract[name of tesseract binary]:binary:_command_names -e' \
  '-tesso[additional tesseract options]:options' \
  '-unpaper[name of unpaper binary]:binary:_command_names -e' \
  '-unpo[additional unpaper options]:options' \
  '-verbose[produce more output]' \
  '-version[print version and quit]' \
  '*:pdf file:_files -g "*.pdf"' && ret=0

return ret
