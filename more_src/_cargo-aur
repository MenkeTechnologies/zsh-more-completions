#compdef cargo-aur
# Documentation: https://man.archlinux.org/search?q=cargo-aur
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(--musl)--musl[build with musl]' \
  '(--gnu)--gnu[build with gnu]' \
  '(--musl-static)--musl-static[force static musl]' \
  '(--musl-dynamic)--musl-dynamic[dynamic musl]' \
  '(-o --output)'{-o+,--output=}'[output dir]:dir:_files -/' \
  '(--package)--package=[package]:p:' \
  '(-p)-p+[package]:p:' \
  '(--target)--target=[target triple]:t:' \
  '(--no-build)--no-build[skip build]' \
  '*: :' && ret=0

return ret
