#compdef elastix
# Documentation: https://elastix.dev/doxygen/commandlinearg.html
# elastix - intensity-based medical image registration (ITK-based)

local ret=1

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[print version information and exit]' \
  '-f[fixed image file name]:fixed image:_files -g "*.{nii,nii.gz,mhd,mha,hdr,img,gipl}"' \
  '-m[moving image file name]:moving image:_files -g "*.{nii,nii.gz,mhd,mha,hdr,img,gipl}"' \
  '-out[output directory]:output dir:_files -/' \
  '*-p[parameter file (repeatable for sequential registrations)]:parameter file:_files' \
  '-fMask[mask file for the fixed image]:fixed mask:_files -g "*.{nii,nii.gz,mhd,mha,hdr,img}"' \
  '-mMask[mask file for the moving image]:moving mask:_files -g "*.{nii,nii.gz,mhd,mha,hdr,img}"' \
  '-t0[initial transform parameter file]:initial transform:_files' \
  '-fp[file of fixed image landmark points]:fixed points:_files' \
  '-mp[file of moving image landmark points]:moving points:_files' \
  '-priority[process priority (Windows): belownormal or high]:priority:(belownormal high)' \
  '-threads[maximum number of threads to use]:threads:' && ret=0

return ret
