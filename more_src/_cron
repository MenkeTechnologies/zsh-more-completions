#compdef cron
# Documentation: man cron(8) (Vixie Cron)
# Source: Vixie Cron daemon (macOS launchd-managed; also generic Unix).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s[special handling for GMT-offset transitions]' \
    '-o[disable the special handling enabled by -s]' \
    '-x+[debug flag(s)]:debugflag:(sch process pars load misc command bit)' \
    && ret=0

return ret
