#compdef appwrite

# Zsh completion for appwrite - Appwrite CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--json[output in JSON format]' \
  '--force[force operation]' \
  '--verbose[verbose output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize a new project'
      'deploy:deploy resources'
      'login:log in to Appwrite'
      'logout:log out of Appwrite'
      'register:register a new account'
      'console:open Appwrite console'
      'client:configure client'
      'account:manage account'
      'avatars:manage avatars'
      'databases:manage databases'
      'functions:manage functions'
      'graphql:execute GraphQL queries'
      'health:check server health'
      'locale:manage locale'
      'messaging:manage messaging'
      'project:manage current project'
      'projects:manage projects'
      'proxy:manage proxy'
      'storage:manage storage'
      'teams:manage teams'
      'users:manage users'
      'vcs:manage version control'
      'assistant:AI assistant'
      'migrations:manage migrations'
    )
    _describe -t commands 'appwrite command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '--all[initialize all resources]' \
          '--id=[project ID]:project id' \
          '--name=[project name]:project name' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '--all[deploy all resources]' \
          '--function-id=[function ID to deploy]:function id' \
          '--no-confirm[skip confirmation]' && ret=0
        ;;
      login)
        _arguments -s -S \
          '--endpoint=[Appwrite endpoint]:endpoint' \
          '--email=[email address]:email' \
          '--password=[password]:password' \
          '--mfa-code=[MFA code]:code' && ret=0
        ;;
    esac
    ;;
esac

return ret
