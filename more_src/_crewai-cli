#compdef crewai-cli
# Documentation: https://github.com/crewAIInc/crewAI
# Reference accessed: 2026-05-23
# Verified: crewai --help (see also _crewai).

# Zsh completion for crewai-cli - CrewAI package CLI name

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'crewai command' \
      'chat[start conversation with Crew]' \
      'checkpoint[browse checkpoints]' \
      'config[CLI configuration]' \
      'create[create crew or flow]' \
      'deploy[deploy Crew]' \
      'enterprise[enterprise configuration]' \
      'env[environment variables]' \
      'flow[flow commands]' \
      'install[install Crew]' \
      'log-tasks-outputs[latest task outputs]' \
      'login[login to CrewAI AMP]' \
      'logout[logout]' \
      'memory[Memory TUI]' \
      'org[organization management]' \
      'replay[replay execution]' \
      'reset-memories[reset memories]' \
      'run[run Crew]' \
      'template[browse templates]' \
      'test[test and evaluate]' \
      'tool[tool repository]' \
      'traces[trace management]' \
      'train[train crew]' \
      'triggers[trigger commands]' \
      'update[update pyproject.toml]' \
      'uv[uv wrapper]' \
      'version[show version]' && ret=0
    ;;
esac

return ret
