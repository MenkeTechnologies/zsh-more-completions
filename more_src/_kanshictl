#compdef kanshictl
# Documentation: https://man.archlinux.org/man/kanshictl.1.en
# kanshictl: control a running kanshi output-profile daemon

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    reload\:"reload the config file"
    status\:"print current state"
    switch\:"switch to a different profile"
  ))' \
  '*::arg:_default' && ret=0

return ret
