#compdef gowatch
# Documentation: https://github.com/silenceper/gowatch
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:generate a default gowatch.yml configuration file'
)

_arguments -s -S \
  '-h[show help]' \
  '-v[display gowatch version]' \
  '-o+[target file path for the build output]:name' \
  '-p+[package or single file to build]:package:_files' \
  '-args+[program runtime arguments]:arguments' \
  '-l+[log level]:level:(debug info warn error)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    _describe -t commands 'gowatch command' commands && ret=0
    ;;
esac

return ret
