#compdef gowatch

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-o+[output binary name]:name' \
  '-p+[set listening port]:port' \
  '-d+[directory to watch]:directory:_directories' \
  '-e+[file extensions to watch]:extensions' \
  '-args+[arguments to pass to binary]:arguments' \
  '-build+[custom build command]:command' \
  '-cmd+[command to run after build]:command' \
  '-graceful-kill[graceful shutdown]' \
  '-log-prefix[enable log prefix]' \
  '-vendor[watch vendor directory]' \
  '*:package or directory:_files -/' && ret=0

return ret
