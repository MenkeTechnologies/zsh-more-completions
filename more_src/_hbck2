#compdef hbck2 HBCK2

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'addFsRegionsMissingInMeta:add missing regions in meta'
  'assigns:queue Assign procedures for given regions'
  'bypass:bypass running procedures'
  'extraRegionsInMeta:detect extra regions in meta'
  'filesystem:check or fix filesystem layout'
  'fixMeta:run server-side hbck chore'
  'generateMissingTableDescriptorFile:generate missing table descriptor'
  'recoverUnknown:recover unknown server state'
  'regionInfoMismatch:fix region info mismatches'
  'replication:check or fix replication state'
  'reportMissingRegionsInMeta:report missing regions'
  'scheduleRecoveries:schedule region recoveries'
  'setRegionState:set the state of a region'
  'setTableState:set the state of a table'
  'unassigns:queue Unassign procedures for regions'
  'version:show HBCK2 version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-p --hbase.zookeeper.property.clientPort)'{-p,--hbase.zookeeper.property.clientPort=}'[ZK client port]:port:' \
  '(-q --hbase.zookeeper.quorum)'{-q,--hbase.zookeeper.quorum=}'[ZK quorum hosts]:hosts:' \
  '(-s --skip)'{-s,--skip}'[skip HBase version check]' \
  '(-z --zookeeper.znode.parent)'{-z,--zookeeper.znode.parent=}'[ZK znode parent]:znode:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'hbck2 subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (assigns|unassigns)
        _arguments \
          '(-o --override)'{-o,--override}'[override running procedure]' \
          '(-i --inputFiles)'{-i,--inputFiles}'[args are file paths]' \
          '(-b --batchSize)'{-b,--batchSize=}'[batch size]:n:' \
          '*:region:' && ret=0
        ;;
      (bypass)
        _arguments \
          '(-o --override)'{-o,--override}'[override running procedure]' \
          '(-r --recursive)'{-r,--recursive}'[recursive bypass]' \
          '(-w --lockWait)'{-w,--lockWait=}'[lock wait ms]:ms:' \
          '(-i --inputFiles)'{-i,--inputFiles}'[args are file paths]' \
          '(-b --batchSize)'{-b,--batchSize=}'[batch size]:n:' \
          '*:pid:' && ret=0
        ;;
      (setRegionState)
        _arguments \
          '(-i --inputFiles)'{-i,--inputFiles}'[args are file paths]' \
          ':region:' \
          ':state:(OFFLINE OPENING OPEN CLOSING CLOSED SPLITTING SPLIT FAILED_OPEN FAILED_CLOSE MERGING MERGED SPLITTING_NEW MERGING_NEW ABNORMALLY_CLOSED)' && ret=0
        ;;
      (setTableState)
        _arguments \
          ':table:' \
          ':state:(ENABLED DISABLED DISABLING ENABLING)' && ret=0
        ;;
      (filesystem|replication)
        _arguments \
          '(-f --fix)'{-f,--fix}'[apply fixes]' \
          '(-i --inputFiles)'{-i,--inputFiles}'[args are file paths]' \
          '*:table:' && ret=0
        ;;
      (extraRegionsInMeta|reportMissingRegionsInMeta|addFsRegionsMissingInMeta)
        _arguments \
          '(-i --inputFiles)'{-i,--inputFiles}'[args are file paths]' \
          '(-o --outputFile)'{-o,--outputFile=}'[output file]:file:_files' \
          '(-n --numLines)'{-n,--numLines=}'[number of lines]:n:' \
          '(-f --fix)'{-f,--fix}'[apply fixes]' && ret=0
        ;;
      (regionInfoMismatch)
        _arguments \
          '(-f --fix)'{-f,--fix}'[apply fixes]' && ret=0
        ;;
      (scheduleRecoveries|recoverUnknown)
        _arguments \
          '(-i --inputFiles)'{-i,--inputFiles}'[args are file paths]' \
          '*:server:' && ret=0
        ;;
    esac
    ;;
esac

return ret
