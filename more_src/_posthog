#compdef posthog
# _posthog — PostHog posthog CLI launcher for the PostHog open-source product analytics session-replay feature-flags experimentation surveys platform managing projects events users cohorts dashboards insights actions feature-flags experiments surveys persons groups web-analytics product-analytics session-replays plugins (PostHog team, Python); click
# upstream: https://posthog.com/

_posthog() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'project:project operations'
        'event:event operations'
        'capture:capture an event'
        'person:person operations'
        'group:group operations'
        'cohort:cohort operations'
        'dashboard:dashboard operations'
        'insight:insight operations'
        'action:action operations'
        'feature-flag:feature flag operations'
        'experiment:experiment operations'
        'survey:survey operations'
        'plugin:plugin management'
        'session-replay:session replay operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--personal-api-key=+[key]:str:' \
        '--project-api-key=+[key]:str:' \
        '--project-id=+[id]:str:' \
        '--team-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'posthog subcommand' sub ;;
        args)
            case $words[1] in
                project|event|person|group|cohort|dashboard|insight|action|feature-flag|experiment|survey|plugin|session-replay) _arguments '1:op:(list get create update delete enable disable)' '*:id:' ;;
                capture) _arguments \
                    '--event=+[name]:str:' \
                    '--distinct-id=+[id]:str:' \
                    '--properties=+[json]:str:' ;;
            esac
            ;;
    esac
}

_posthog "$@"
