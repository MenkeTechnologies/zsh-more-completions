#compdef teectl
# Documentation: https://doc.traefik.io/traefik-enterprise/references/cli/teectl/
# Traefik Enterprise control CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'apply:apply configuration to a cluster'
  'get:get resources'
  'create:create resources'
  'delete:delete resources'
  'cluster:manage cluster contexts and configurations'
  'recover:recover a cluster that has lost quorum'
  'setup:setup a cluster to manage'
  'support-dump:gather diagnostic data from the cluster'
  'backup:back up the configuration of a running cluster'
  'restore:restore a previously backed up cluster configuration'
  'version:print version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--cluster=[name of the cluster]:cluster:' \
  '--socket=[path to the socket]:socket:_files' \
  '--timeout=[time to wait before giving up on a request]:duration:' \
  '--format=[output format]:format:(json yaml toml text)' \
  '--force[override or force operations]' \
  '--file=[configuration file path]:file:_files' \
  '--output=[destination path for generated files]:dir:_files -/' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'teectl command' commands && ret=0
    ;;
  args)
    case "$line[1]" in
      get)
        local -a resources=(
          'acme-certs:retrieve ACME certificates'
          'nodes:get the nodes of the cluster'
          'tls-certs:retrieve TLS certificates'
          'static-config:get the current static configuration'
          'traefikee-provider-config:retrieve provider configuration'
          'plugins:retrieve installed plugins'
        )
        _describe -t resources 'resource' resources && ret=0
        ;;
      cluster)
        local -a subs=(
          'use:set the cluster context to use'
          'get:get all clusters configured in teectl'
          'import:import a cluster configuration'
        )
        _describe -t subs 'cluster subcommand' subs && ret=0
        ;;
      *)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
