#compdef linmos
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/linmos.html
# MIRIAD: linear mosaicing of input cubes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input cubes to mosaic]:in:_files' \
  'out=[output cube]:out:_files' \
  'rms=[RMS noise level in inputs]:rms:' \
  'bw=[bandwidth in GHz]:bw:' \
  'cutoff=[primary beam cutoff level]:cutoff:' \
  'options=[taper,sensitivity,gain,frequency,alpha]:options:(taper sensitivity gain frequency alpha)' \
  '*:image:_files' && ret=0

return ret
