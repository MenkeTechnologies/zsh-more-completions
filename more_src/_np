#compdef np

# Completion for np - Better npm publish

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--any-branch[allow publishing from any branch]' \
  '--branch=[publish from specific branch]:branch name' \
  '--no-cleanup[skip cleanup]' \
  '--no-tests[skip tests]' \
  '--yolo[skip cleanup and tests]' \
  '--no-publish[skip publishing to npm]' \
  '--tag=[publish with npm dist-tag]:tag' \
  '--no-release-draft[skip creating GitHub release draft]' \
  '--release-draft-only[only create GitHub release draft]' \
  '--test-script=[custom test script name]:script name' \
  '--no-2fa[skip 2FA check]' \
  '--message=[commit and tag version message (%s for version)]:message' \
  '--preview[show tasks without executing]' \
  '--contents=[subdirectory to publish]:directory:_directories' \
  '1:version:(patch minor major premajor preminor prepatch prerelease)' && ret=0

return ret
