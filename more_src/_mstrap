local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# Dynamic Step subcommands from Step.all
# enumeration at cli.cr:110 + static project at
# cli.cr:130
local -a mstrap_subcmds=(
  'init:initialize the machine'
  'dependencies:install OS-level dependencies'
  'shell:configure shell environment'
  'services:set up local services'
  'projects:provision all configured projects'
  'runtimes:install language runtimes'
  'project:provision a single mstrap project'
)

_arguments -C \
  '(- *)'{-h,--help}'[display commander.cr auto-generated help]' \
  '(- *)'{-V,--version}'[prints version number]' \
  '(-c --config)'{-c+,--config=}'[path to configuration file (or HTTPS URL)]:config file:_files' \
  '(-v --verbose)'{-v,--verbose}'[run with verbose messaging]' \
  '(-f --force)'{-f,--force}'[force overwrite of existing config]' \
  '--email=[email address (default: config or prompt)]:email:' \
  '--github=[GitHub username (default: config or prompt)]:github username:' \
  '--name=[your name (default: config or prompt)]:name:' \
  '--skip-project-update[skip auto-update of projects]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'mstrap subcommand' mstrap_subcmds && ret=0
    ;;
  args)
    case $words[1] in
      project)
        # 6 project-specific flags from cli.cr:140-188
        _arguments -s -S \
          '--cname=[project canonical name (e.g. my_cool_app)]:cname:' \
          '--hostname=[project hostname (default: CNAME.localhost)]:hostname:' \
          '--name=[friendly project name]:name:' \
          '--port=[port number]:port:' \
          '--path=[project path]:path:_files -/' \
          '--repo=[git repository URL or GitHub path]:repo:' \
          '(-h --help)'{-h,--help}'[display project help]' \
          '1:CNAME:' && ret=0
        ;;
      init|dependencies|shell|services|projects|runtimes)
        # Step subcommands inherit persistent
        # global flags + step-specific flags
        # added via Step.setup_cmd!
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display step help]' \
          '*:arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
