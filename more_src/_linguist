#compdef Linguist
# Documentation: https://man.archlinux.org/search?q=Linguist
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-h[Show help]'
    '--help[Show help]'
    '-v[Show version]'
    '--version[Show version]'
    '-b[Show file breakdown]'
    '--breakdown[Show file breakdown]'
    '-j[Output as JSON]'
    '--json[Output as JSON]'
    '--commit[Specify commit]:commit'
    '*:path:_files'
)

_arguments -s -S $arguments
