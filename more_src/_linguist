#compdef github-linguist linguist
# Documentation: https://github.com/github-linguist/linguist/blob/main/exe/github-linguist
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: github-linguist (Ruby gem) is the canonical CLI; flags read from the
# OptionParser block in exe/github-linguist. The `linguist` alias is provided
# for the legacy invocation. The prior file fabricated --commit and --version;
# the real revision flag is -r/--rev REV.

local -a arguments

arguments=(
    '(-h --help)'{-h,--help}'[show usage summary]'
    '(-b --breakdown)'{-b,--breakdown}'[analyze repository and show file-by-file breakdown]'
    '(-s --strategies)'{-s,--strategies}'[show detection strategy used for each file]'
    '(-j --json)'{-j,--json}'[output results as JSON]'
    '(-r --rev)'{-r,--rev}'[analyze a specific git revision (defaults to HEAD)]:revision'
    '(-t --tree-size)'{-t,--tree-size}'=[maximum number of files scanned]:number'
    '*:path:_files'
)

_arguments -s -S $arguments
