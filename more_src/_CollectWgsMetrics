#compdef CollectWgsMetrics
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/analysis/CollectWgsMetrics.java
# Picard: collect whole-genome sequencing coverage and quality metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM file]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output metrics file]:file:_files' \
  '--INTERVALS=[interval list to restrict analysis]:file:_files' \
  '(-M --MINIMUM_MAPPING_QUALITY)'{-M,--MINIMUM_MAPPING_QUALITY}'=[min mapping quality to contribute coverage]:n:' \
  '(-Q --MINIMUM_BASE_QUALITY)'{-Q,--MINIMUM_BASE_QUALITY}'=[min base quality to contribute coverage]:n:' \
  '(-CAP --COVERAGE_CAP)'{-CAP,--COVERAGE_CAP}'=[cap positions exceeding this coverage]:n:' \
  '--LOCUS_ACCUMULATION_CAP=[ignore reads beyond this depth]:n:' \
  '--STOP_AFTER=[stop after this many genomic bases]:n:' \
  '--INCLUDE_BQ_HISTOGRAM=[include base quality histogram]:b:(true false)' \
  '--COUNT_UNPAIRED=[count unpaired and half-mapped reads]:b:(true false)' \
  '--SAMPLE_SIZE=[sample size for het sensitivity]:n:' \
  '--THEORETICAL_SENSITIVITY_OUTPUT=[theoretical sensitivity output file]:file:_files' \
  '*--ALLELE_FRACTION=[allele fraction for sensitivity]:f:' \
  '--USE_FAST_ALGORITHM=[use fast algorithm]:b:(true false)' \
  '--READ_LENGTH=[average read length]:n:' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
