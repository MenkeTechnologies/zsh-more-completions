#compdef victoria-logs
# Documentation: https://docs.victoriametrics.com/VictoriaLogs/
# Reference accessed: 2026-05-16
# Verified: upstream docs. Go flag package - single-dash long flags. Common
# subset shown; use `victoria-logs -help` for full list.

# victoria-logs: VictoriaMetrics logs storage and query engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-storageDataPath=[data directory (default victoria-logs-data)]:dir:_files -/' \
  '-retentionPeriod=[log retention (default 7d)]:duration:' \
  '-retention.maxDiskSpaceUsageBytes=[max disk usage bytes]:bytes:' \
  '-retention.maxDiskUsagePercent=[max disk usage percent]:percent:' \
  '-futureRetention=[future retention (default 2d)]:duration:' \
  '-maxBackfillAge=[max backfill age]:duration:' \
  '-httpListenAddr=[HTTP listen address]:addr:' \
  '-httpAuth.username=[HTTP basic auth username]:user:' \
  '-httpAuth.password=[HTTP basic auth password]:password:' \
  '-http.pathPrefix=[HTTP path prefix]:prefix:' \
  '-tls[enable TLS]' \
  '-tlsCertFile=[TLS certificate file]:file:_files' \
  '-tlsKeyFile=[TLS key file]:file:_files' \
  '-tlsMinVersion=[minimum TLS version]:version:' \
  '-search.maxConcurrentRequests=[max concurrent search requests]:n:' \
  '-search.maxQueryDuration=[max query duration (default 30s)]:duration:' \
  '-insert.maxFieldsPerLine=[max fields per line (default 1000)]:n:' \
  '-insert.maxLineSizeBytes=[max line size bytes (default 256KB)]:n:' \
  '-insert.concurrency=[insert concurrency]:n:' \
  '-maxConcurrentInserts=[max concurrent inserts]:n:' \
  '-memory.allowedPercent=[allowed memory percent (default 60)]:percent:' && ret=0
return ret
