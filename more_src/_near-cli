#compdef near-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--offline[operate in offline mode]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'account:manage accounts'
      'tokens:manage token assets'
      'staking:manage staking'
      'contract:manage smart contracts'
      'transaction:operate transactions'
      'config:manage connections'
    )
    _describe -t commands 'near-cli command' commands && ret=0
    ;;
  (args)
    local -a global_flags=(
      '--help[show help]'
      '--networkId=[NEAR network]:network:(mainnet testnet betanet localnet)'
      '--nodeUrl=[NEAR node URL]:url'
      '--offline[operate in offline mode]'
    )

    case ${words[1]} in
      (account)
        local -a account_cmds=(
          'view-account-summary:view account information'
          'import-account:import an existing account'
          'export-account:export account keys'
          'create-account:create a new account'
          'delete-account:delete an account'
          'list-keys:list access keys'
          'add-key:add an access key'
          'delete-key:delete an access key'
        )
        _arguments -s -S \
          $global_flags \
          '1:account command:_describe -t account-cmds "account command" account_cmds' \
          '*:arguments' && ret=0
        ;;
      (tokens)
        local -a token_cmds=(
          'send-near:send NEAR tokens'
          'send-ft:send fungible tokens'
          'send-nft:send NFT'
          'view-near-balance:view NEAR balance'
          'view-ft-balance:view FT balance'
          'view-nft-assets:view NFT assets'
        )
        _arguments -s -S \
          $global_flags \
          '1:token command:_describe -t token-cmds "token command" token_cmds' \
          '*:arguments' && ret=0
        ;;
      (staking)
        local -a staking_cmds=(
          'view-all-pools:view staking pools'
          'delegation:manage delegation'
          'validator:manage validator'
        )
        _arguments -s -S \
          $global_flags \
          '1:staking command:_describe -t staking-cmds "staking command" staking_cmds' \
          '*:arguments' && ret=0
        ;;
      (contract)
        local -a contract_cmds=(
          'call-function:call a contract function'
          'deploy:deploy a smart contract'
          'download-wasm:download contract code'
          'view-storage:view contract storage'
        )
        _arguments -s -S \
          $global_flags \
          '1:contract command:_describe -t contract-cmds "contract command" contract_cmds' \
          '*:arguments' && ret=0
        ;;
      (transaction)
        local -a tx_cmds=(
          'view-status:view transaction status'
          'reconstruct-transaction:reconstruct a transaction'
          'send-signed-transaction:send signed transaction'
        )
        _arguments -s -S \
          $global_flags \
          '1:transaction command:_describe -t tx-cmds "transaction command" tx_cmds' \
          '*:arguments' && ret=0
        ;;
      (config)
        local -a config_cmds=(
          'show-connections:show network connections'
          'add-connection:add a new connection'
          'delete-connection:delete a connection'
        )
        _arguments -s -S \
          $global_flags \
          '1:config command:_describe -t config-cmds "config command" config_cmds' \
          '*:arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
