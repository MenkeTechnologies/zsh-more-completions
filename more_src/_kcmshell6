#compdef kcmshell6
# _kcmshell6 — KDE Plasma 6 kcmshell6 CLI launching standalone KDE system settings KCM control modules outside the unified System Settings shell single-pane invocation by module name listing available modules with descriptions and category-grouped index (KDE team, C++); custom argparse
# upstream: https://invent.kde.org/plasma/systemsettings

_kcmshell6() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--list[list all KCMs]' \
        '--lang=+[lang]:str:' \
        '--icon=+[icon]:str:' \
        '--caption=+[caption]:str:' \
        '--args=+[args]:str:' \
        '--highlight=+[entry]:str:' \
        '*:KCM module:'
}

_kcmshell6 "$@"
