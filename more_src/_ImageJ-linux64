#compdef ImageJ-linux64
# Documentation: https://imagej.net/learn/launcher
# ImageJ: image processing launcher (Jaunch), linux64 build

local ret=1

_arguments -s \
  '--help[display supported options overview]' \
  '--mem=[set maximum heap size]:size:' \
  '--gc-g1[enable G1 garbage collector with optimized settings]' \
  '--default-gc[disable automatic G1 GC configuration]' \
  '--debug-gc[show detailed garbage collection information]' \
  '--python[launch in Python mode using PyImageJ]' \
  '--no-python[force JVM-only mode (disable Python)]' \
  '--info[enable informational logging]' \
  '--debug[enable debug logging]' \
  '--dry-run[show launch command without executing]' \
  '--jdb[launch within the Java debugger]' \
  '--debugger=[enable debugging agent on specified port]:port:' \
  '--no-splash[suppress the splash screen]' \
  '--headless[run in headless mode]' \
  '--plugins=[use custom plugins directory]:dir:_files -/' \
  '--update[launch the command-line Updater]' \
  '--run[run a specific plugin with optional arguments]:plugin: :argument:' \
  '--edit[open files in the Script Editor]:file:_files' \
  '--main-class=[run a custom main class instead of Fiji]:class:' \
  '*:file:_files' && ret=0

return ret
