#compdef criu-ns
# _criu-ns — CRIU criu-ns (helper wrapper around criu(8) that puts criu itself into a per-PID-namespace ahead of dump/restore so that nested containers can be checkpointed cleanly; same subcommand surface as criu)
# upstream: https://github.com/checkpoint-restore/criu (scripts/criu-ns)
# Argument shape forwarded to criu; see criu scripts/criu-ns on tip.

_criu-ns() {
    _arguments \
        '*::criu command:'
}

_criu-ns "$@"
