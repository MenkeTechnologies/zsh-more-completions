#compdef cuneiform
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/cuneiform.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy cuneiform(1) manpage. No --help/--version
# documented in the manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# cuneiform: multi-language OCR system
local curcontext="$curcontext" ret=1
_arguments -C \
  '--dotmatrix[recognition mode for dot-matrix text]' \
  '--fax[recognition mode for faxed text]' \
  '--singlecolumn[disable page layout analysis]' \
  '-f[output format]:format:(html hocr native rtf smarttext text)' \
  '-l[language]:lang:(eng bul cze dan dut eng-am est fra ger hrv hun ita lav lit pol por ron rum rus rus-eng slo slv spa srp swe tur ukr)' \
  '-o[output file]:file:_files' \
  '*:image file:_files' && ret=0
return ret
