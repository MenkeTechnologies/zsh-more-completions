#compdef greylist
# Documentation: https://manpages.debian.org/bookworm/greylistd/greylist.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add data to a list'
  'delete:remove data from all lists'
  'check:check current status without modifying'
  'update:check and update greylist data'
  'stats:print greylist utilisation statistics'
  'mrtg:print MRTG-format statistics'
  'list:print available data items'
  'save:force immediate write of greylist data'
  'reload:save data, then reload configuration'
  'clear:remove all items from list(s)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--white[operate on the whitelist]' \
  '--grey[operate on the greylist]' \
  '--black[operate on the blacklist]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'greylist command' commands && ret=0 ;;
esac

return ret
