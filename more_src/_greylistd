#compdef greylistd

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add to greylist'
  'remove:remove from greylist'
  'list:list greylist'
  'flush:flush list'
  'stats:show stats'
  'expire:expire old entries'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=+[config file]:file:_files' \
  '--socket=+[socket path]:file:_files' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'greylistd command' commands && ret=0 ;;
esac

return ret
