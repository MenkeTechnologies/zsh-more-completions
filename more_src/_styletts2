#compdef styletts2 styletts2-cli
# _styletts2 — yl4579 StyleTTS 2 expressive neural TTS CLI alias (Yinghao Aaron Li / yl4579, Python); custom argparse
# upstream: https://github.com/yl4579/StyleTTS2

_styletts2() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config yml]:file:_files -g "*.yml *.yaml"' \
        '-c+[config yml]:file:_files -g "*.yml *.yaml"' \
        '--checkpoint=+[checkpoint pth]:file:_files -g "*.pth"' \
        '-m+[checkpoint pth]:file:_files -g "*.pth"' \
        '--text=+[input text]:str:' \
        '-t+[input text]:str:' \
        '--reference_wav=+[reference wav]:file:_files -g "*.wav"' \
        '-r+[reference wav]:file:_files -g "*.wav"' \
        '--diffusion_steps=+[diffusion steps]:n:' \
        '--alpha=+[alpha]:f:' \
        '--beta=+[beta]:f:' \
        '--embedding_scale=+[embedding scale]:f:' \
        '--style_blend=+[style blend]:f:' \
        '--output=+[output wav]:file:_files -g "*.wav"' \
        '-o+[output wav]:file:_files -g "*.wav"' \
        '--device=+[device]:d:(cpu cuda mps)' \
        '--seed=+[seed]:n:' \
        '--server[run server]' \
        '*:arg:'
}

_styletts2 "$@"
