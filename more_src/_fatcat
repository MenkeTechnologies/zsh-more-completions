#compdef fatcat
# Documentation: https://github.com/Gregwar/fatcat
# FAT filesystem forensic explorer and manipulation tool

local ret=1

_arguments -s -S \
  '-i[display filesystem information and disk usage]' \
  '-O[filesystem byte offset for multi-partition device]:offset' \
  '-l[list directory at path]:path' \
  '-L[list contents using cluster number]:cluster' \
  '-d[include deleted files]' \
  '-r[read a file to stdout]:path' \
  '-R[read from cluster number (use -s for size)]:cluster' \
  '-x[extract filesystem to directory]:directory:_files -/' \
  '-c[cluster for extraction or entry modification]:cluster' \
  '-s[file size for reading or entry change]:size' \
  '-@[get cluster address and next cluster in FAT]:cluster' \
  '-b[backup FAT tables to file]:file:_files' \
  '-p[restore FAT tables from backup]:file:_files' \
  '-w[write cluster chain values]:cluster' \
  '-v[value to write]:value' \
  '-t[select FAT table (0=both,1=first,2=second)]:table:(0 1 2)' \
  '-2[compare the two FAT tables]' \
  '-m[merge divergent FAT tables]' \
  '-f[fix directory FAT chain issues]' \
  '-e[display entry information]:path' \
  '-k[search for cluster references]' \
  '-z[erase unallocated sectors with zeros]' \
  '-S[erase unallocated sectors with random data]' \
  '-o[find orphaned files and directories]' \
  '*:image:_files' && ret=0

return ret
