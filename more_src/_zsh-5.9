#compdef zsh-5.9
# Documentation: https://zsh.sourceforge.io/Doc/Release/Invocation.html
# Documentation: https://zsh.sourceforge.io/Doc/Release/Options.html
# Reference accessed: 2026-05-21
# Verified: zsh.sourceforge.io Invocation page (single-letter flags
# -c/-i/-l/-r/-s/-b + --emulate/--help/--version/-o/+o syntax) and
# Options page (single-letter -a..-y + -0..-9 letter table).
# Removed from prior file: '-d[run in mostly POSIX-compliant mode]'
# was a bash-ism; in zsh `+d` turns off GLOBAL_RCS, not "-d POSIX mode".

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help message and exit]' \
  '(- *)--version[show version and exit]' \
  '--emulate[specify emulation mode]:mode:(zsh sh ksh csh)' \
  '-b[end option processing, like --]' \
  '-c[take first argument as a command to execute]' \
  '*-o+[set an option by name]:option:_options' \
  '*+o+[unset an option by name]:option:_options' \
  '-i[force interactive mode]' \
  '-l[force login shell mode]' \
  '-r[restricted shell]' \
  '-s[read commands from standard input]' \
  '-x[trace command execution (xtrace)]' \
  '-v[print shell input lines as they are read]' \
  '-n[parse but do not execute (NO_EXEC)]' \
  '-f[do not source startup files (--no-rcs)]' \
  '-a[allexport: export all assigned parameters]' \
  '-e[errexit: exit on command failure]' \
  '-m[monitor: enable job control]' \
  '-p[privileged mode]' \
  '-u[error on expansion of unset parameters]' \
  '*:script:_files' && ret=0

return ret
