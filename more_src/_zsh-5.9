#compdef zsh-5.9

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-b[end option processing]' \
  '-c[take first argument as a command to execute]' \
  '*-o+[set an option by name]:option:' \
  '*+o+[unset an option by name]:option:' \
  '-d[run in mostly POSIX-compliant mode]' \
  '-i[interactive shell]' \
  '-l[login shell]' \
  '-r[restricted shell]' \
  '-s[read commands from standard input]' \
  '-x[trace command execution (xtrace)]' \
  '-v[print shell input lines as they are read]' \
  '-n[no execution]' \
  '*:script:_files' && ret=0

return ret
