#compdef tuigreet

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --cmd)'{-c,--cmd}'=[default command to run]:command:_command_names' \
  '--env=[set environment variable]:var=value' \
  '--sessions=[path to desktop sessions directory]:dir:_directories' \
  '--session-wrapper=[wrapper to run sessions in]:command:_command_names' \
  '(-g --greeting)'{-g,--greeting}'=[greeting message]:message' \
  '--asterisks[display asterisks for password input]' \
  '--asterisks-char=[character for password masking]:char' \
  '--container-padding=[padding inside container]:padding' \
  '--window-padding=[padding inside window]:padding' \
  '--width=[width of prompt container]:width' \
  '--issue[show /etc/issue]' \
  '--time[show current time]' \
  '--time-format=[time format string]:format' \
  '--user-menu[show user selection menu]' \
  '--user-menu-min-uid=[minimum UID for user menu]:uid' \
  '--user-menu-max-uid=[maximum UID for user menu]:uid' \
  '--theme=[theme string for colors]:theme' \
  '--remember[remember last logged-in user]' \
  '--remember-session[remember last session]' \
  '--remember-user-session[remember session per user]' \
  '--power-shutdown=[shutdown command]:command' \
  '--power-reboot=[reboot command]:command' \
  '--power-no-setsid[do not use setsid for power commands]' \
  '--kb-command=[key binding for command menu]:key' \
  '--kb-sessions=[key binding for sessions menu]:key' \
  '--kb-power=[key binding for power menu]:key'
