#compdef trans

# Zsh completion for translate-shell (trans) - command-line translator

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --brief)'{-b,--brief}'[brief mode]' \
  '(-d --dictionary)'{-d,--dictionary}'[dictionary mode]' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
  '(-I --input)'{-I,--input}'[input file]:file:_files' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-l --list)'{-l,--list}'[list supported languages]' \
  '(-R --reference)'{-R,--reference}'[print reference]' \
  '(-e --engine)'{-e,--engine}'[set translation engine]:engine:(google bing yandex apertium)' \
  '(-p --play)'{-p,--play}'[listen to translation]' \
  '(-S --list-engines)'{-S,--list-engines}'[list available engines]' \
  '(-s --source)'{-s,--source}'[source language]:language' \
  '(-t --target)'{-t,--target}'[target language]:language' \
  '--no-ansi[disable ANSI escape codes]' \
  '--no-autocorrect[disable autocorrection]' \
  '--no-bidi[disable bidirectional output]' \
  '--no-pager[disable pager]' \
  '--no-warn[disable warnings]' \
  '--download-audio[download pronunciation audio]' \
  '--download-audio-as[download audio as]:file:_files' \
  '--proxy[use proxy]:proxy' \
  '--theme[set color theme]:theme:(default none)' \
  '--user-agent[set user agent]:agent' \
  '--view[open URL in browser]' \
  '*:text to translate'
