#compdef CollectOxoGMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectOxoGMetrics
# Picard: collect metrics quantifying 8-oxoguanine (OxoG) oxidative artifacts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output metrics file]:file:_files' \
  {-R=,--REFERENCE_SEQUENCE=}'[reference sequence the BAM is aligned to]:fasta:_files -g "*.(fa|fasta)"' \
  '--INTERVALS=[optional interval list to restrict analysis to]:interval_list:_files -g "*.interval_list"' \
  '--DB_SNP=[dbSNP VCF used to exclude regions near known polymorphisms]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  '--MINIMUM_QUALITY_SCORE=[minimum base quality score for inclusion]:int:' \
  '--MINIMUM_MAPPING_QUALITY=[minimum mapping quality score for inclusion]:int:' \
  '--MINIMUM_INSERT_SIZE=[minimum insert size for read inclusion]:int:' \
  '--MAXIMUM_INSERT_SIZE=[maximum insert size for read inclusion]:int:' \
  '--INCLUDE_NON_PF_READS=[include non-PF reads]:bool:(true false)' \
  '--USE_OQ=[use original quality scores when available]:bool:(true false)' \
  '--CONTEXT_SIZE=[number of context bases on each side]:int:' \
  '*--CONTEXTS=[optional sequence contexts to restrict analysis]:context:' \
  '--STOP_AFTER=[stop after visiting this many covered sites]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
