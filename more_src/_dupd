#compdef dupd
# Documentation: https://github.com/jvirkki/dupd/blob/master/man/dupd.1
# dupd - CLI utility to find and report duplicate files

local ret=1

_arguments -s -S \
  '(-h)-h[show brief help summary]' \
  '-q[quiet, suppress all output]' \
  '-v[verbose mode (repeatable)]' \
  '(-V --verbose-level)'{-V,--verbose-level}'[set logging verbosity level]:level:' \
  '--db[override default database file location]:db:_files' \
  '(-C --cache)'{-C,--cache}'[override default hash cache database location]:cache:_files' \
  '(-F --hash)'{-F,--hash}'[specify hash function]:hash:(md5 sha1 sha512 xxhash)' \
  '(-p --path)'{-p,--path}'[recursively scan directory tree at path]:path:_files -/' \
  '(-m --minsize)'{-m,--minsize}'[minimum file size in bytes]:size:' \
  '--buflimit[limit read buffer size]:limit:' \
  '(-X --one-file-system)'{-X,--one-file-system}'[do not cross filesystem boundaries]' \
  '--hidden[include hidden files and directories]' \
  '(-I --hardlink-is-unique)'{-I,--hardlink-is-unique}'[consider hard links as unique]' \
  '--stats-file[create or append run stats to file]:file:_files' \
  '(-T --trace-mem)'{-T,--trace-mem}'[generate memory allocation trace file]:file:_files' \
  '--cut[remove prefix path segment from output]:pathseg:' \
  '--format[report output format]:format:(text csv json)' \
  '--file[file to check]:file:_files' \
  '--exclude-path[ignore duplicates under path]:path:_files -/' \
  '--link[create symlinks for deleted files]' \
  '--hardlink[create hard links for deleted files]' \
  '1:operation:(scan report file ls dups uniques refresh validate rmsh hash help usage man license version)' \
  '*::arg:_files' && ret=0

return ret
