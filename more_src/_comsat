#compdef comsat
# Documentation: man comsat(8)
# Source: GNU mailutils comsat/comsat.c — biff mail notification server (C, argp).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-t --test)'{-t,--test}'[run in test mode]' \
    '--foreground[remain in foreground]' \
    '(-i --inetd)'{-i,--inetd}'[run in inetd mode]' \
    '(-d --daemon)'{-d-,--daemon=-}'[run as daemon (optional max children)]::N:_default' \
    '(-f --file)'{-f+,--file=}'[read FILE instead of .biffrc]:file:_files' \
    '(-? --help)'{-\\?,--help}'[show help]' \
    '--usage[show usage]' \
    '(-V --version)'{-V,--version}'[show version]' \
    && ret=0

return ret
