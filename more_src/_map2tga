#compdef map2tga
# Documentation: https://healpix.sourceforge.io/doc/html/Healpix_cxx/facilities.html
# HEALPix C++: convert a HEALPix map to a TGA image

local ret=1

_arguments -s -S \
  '-sig[column number of the requested map]:signal' \
  '-pal[number of the color palette]:palette' \
  '-xsz[number of image pixels in x direction]:xsize' \
  '-lon[central longitude in degrees]:lon' \
  '-lat[central latitude in degrees]:lat' \
  '-mul[real multiplier applied to map values]:factor' \
  '-add[real offset added to map values]:offset' \
  '-min[minimum value for plotted signal]:minval' \
  '-max[maximum value for plotted signal]:maxval' \
  '-res[resolution in arcmin]:reso' \
  '-title[image title string]:title' \
  '-viewer[image viewer to launch]:viewer:_command_names' \
  '-bar[add a color bar to the image]' \
  '-log[display the logarithm of the map values]' \
  '-asinh[apply hyperbolic arc sine transform]' \
  '-flippal[flip the color palette]' \
  '-gnomonic[use gnomonic projection]' \
  '-interpol[enable interpolation]' \
  '-equalize[equalize the histogram]' \
  '*:file:_files' && ret=0

return ret
