#compdef circos
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/circos.1.html
# Circos - circular genome data visualization

local ret=1

_arguments -s \
  '(-help)-help[show brief usage synopsis]' \
  '(-man)-man[show the man page]' \
  '(-version)-version[show version]' \
  '-conf[specify configuration file]:file:_files' \
  '(-png -nopng)-png[create a PNG file]' \
  '(-png -nopng)-nopng[do not create a PNG file]' \
  '(-svg -nosvg)-svg[create a SVG file]' \
  '(-svg -nosvg)-nosvg[do not create a SVG file]' \
  '(-outputdir -dir)-outputdir[image output directory]:dir:_files -/' \
  '(-outputdir -dir)-dir[image output directory]:dir:_files -/' \
  '(-outputfile -file)-outputfile[output image filename]:file:_files' \
  '(-outputfile -file)-file[output image filename]:file:_files' \
  '*-param[override a configuration parameter]:param' \
  '-debug[turn on basic debugging output]' \
  '-debug_group[turn on debugging output for specific groups]:group' \
  '-silent[generate no reporting]' \
  '(-paranoid -noparanoid)-paranoid[run in paranoid mode]' \
  '(-paranoid -noparanoid)-noparanoid[disable paranoid mode]' \
  '(-warnings -nowarnings)-warnings[display warnings]' \
  '(-warnings -nowarnings)-nowarnings[do not display warnings]' \
  '-modules[diagnose required Perl modules]' \
  '-cdump[dump the internal configuration data structure]' \
  '-randomcolor[randomize the color of every element]' && ret=0

return ret
