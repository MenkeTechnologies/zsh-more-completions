#compdef chlen
# Documentation: https://www.atnf.csiro.au/computing/software/karma/user-manual/node13.html
# Karma tool to change the length of a dimension in a Karma file

local ret=1

_arguments -s \
  'resample_option=[how to resample the dimension]:option' \
  'option=[processing option]:option' \
  'num_coordinates=[new number of coordinates for the dimension]:count' \
  '*:file:_files' && ret=0

return ret
