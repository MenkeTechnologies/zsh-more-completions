#compdef forc
# Documentation: https://github.com/FuelLabs/sway/blob/master/forc/src/cli/mod.rs
# Documentation: https://github.com/FuelLabs/sway/tree/master/forc/src/cli/commands
# Documentation: https://github.com/FuelLabs/sway/tree/master/forc-plugins
# Reference accessed: 2026-05-27
# Verified: upstream FuelLabs/sway forc/src/cli/mod.rs Opt + Forc enum
#           and forc/src/cli/commands/mod.rs subcommand list

# Zsh completion for forc (Fuel Orchestrator, Sway language)

local curcontext="$curcontext" state line ret=1

local -a _forc_subcommands
_forc_subcommands=(
  'add:add dependencies to a Forc.toml manifest'
  'addr2line:show source location for a given bytecode address'
  'b:alias for build'
  'build:compile the current or target project'
  'check:type-check the current or target project'
  'clean:remove the target directory'
  'completions:generate shell completions'
  'contract-id:determine contract id for a contract project'
  'init:create a new Forc project in an existing directory'
  'new:create a new Forc project at the given path'
  'parse-bytecode:parse and print bytecode from a compiled contract'
  'plugins:list installed forc plugins'
  'predicate-root:determine predicate root for a predicate project'
  'remove:remove dependencies from a Forc.toml manifest'
  't:alias for test'
  'template:create a new Forc project from a template'
  'test:run Sway unit tests'
  'update:update dependencies in Forc.lock'
  'crypto:forc-crypto plugin (cryptography utilities)'
  'debug:forc-debug plugin (Sway debugger)'
  'deploy:forc-client deploy plugin'
  'doc:forc-doc plugin (Sway docs generator)'
  'fmt:forc-fmt plugin (Sway formatter)'
  'lsp:forc-lsp plugin (language server)'
  'migrate:forc-migrate plugin (Sway breaking change migrator)'
  'publish:forc-publish plugin (publish to forc.pub)'
  'run:forc-client run plugin'
  'tx:forc-tx plugin (transaction construction)'
  'wallet:forc-wallet plugin (key management)'
)

_arguments -C \
  '(-v --verbose)*'{-v,--verbose}'[use verbose output]' \
  '(-s --silent)'{-s,--silent}'[silence all output]' \
  '(-L --log-level)'{-L+,--log-level=}'[set the log level]:level:(off error warn info debug trace)' \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'forc subcommand' _forc_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      build|b)
        _arguments \
          '(-p --path)'{-p+,--path=}'[path to the project]:path:_files -/' \
          '--manifest-path=[path to Forc.toml]:file:_files -g "*.toml"' \
          '--offline[do not access the network when resolving dependencies]' \
          '--locked[require Forc.lock to be up to date]' \
          '--terse[terse output]' \
          '--output-bin=[write final bytecode to this file]:file:_files' \
          '--output-debug=[write debug info to this file]:file:_files' \
          '--build-profile=[build profile to use]:profile:(debug release)' \
          '--release[shortcut for --build-profile release]' \
          '--error-on-warnings[treat warnings as errors]' \
          '--time-phases[print the time elapsed in each phase]' \
          '--metrics-outfile=[output build metrics to file]:file:_files' \
          '--json-abi[output JSON ABI to stdout]' \
          '--json-storage-slots[output JSON storage slots to stdout]' \
          '--ipfs-node=[ipfs node to use]:node:' \
          '--tests[also build tests]' \
          '*: :_files' && ret=0
        ;;
      check)
        _arguments \
          '(-p --path)'{-p+,--path=}'[path to the project]:path:_files -/' \
          '--manifest-path=[path to Forc.toml]:file:_files' \
          '--offline[do not access the network]' \
          '--locked[require Forc.lock to be up to date]' \
          '--terse[terse output]' \
          '--disable-tests[do not type-check tests]' \
          '--ipfs-node=[ipfs node to use]:node:' \
          '*: :_files' && ret=0
        ;;
      clean)
        _arguments \
          '(-p --path)'{-p+,--path=}'[path to the project]:path:_files -/' \
          '--manifest-path=[path to Forc.toml]:file:_files' && ret=0
        ;;
      completions)
        _arguments \
          '(-t --target)'{-t+,--target=}'[shell target]:shell:(zsh bash fish powershell elvish)' && ret=0
        ;;
      new|init)
        _arguments \
          '--contract[create a contract project]' \
          '--script[create a script project]' \
          '--predicate[create a predicate project]' \
          '--library[create a library project]' \
          '--workspace[create a workspace]' \
          '--name=[project name]:name:' \
          '*:path:_files -/' && ret=0
        ;;
      template)
        _arguments \
          '(-u --url)'{-u+,--url=}'[template git URL]:url:' \
          '(-t --template-name)'{-t+,--template-name=}'[template name]:name:' \
          '--project-name=[project name]:name:' \
          '*:path:_files -/' && ret=0
        ;;
      test|t)
        _arguments \
          '(-p --path)'{-p+,--path=}'[path to the project]:path:_files -/' \
          '--manifest-path=[path to Forc.toml]:file:_files' \
          '--offline[do not access the network]' \
          '--locked[require Forc.lock to be up to date]' \
          '--terse[terse output]' \
          '--filter=[only run tests whose name contains this]:pattern:' \
          '--filter-exact[match filter as exact name]' \
          '--logs[print logs emitted by tests]' \
          '--pretty-print[pretty print results]' \
          '--release[build tests in release mode]' \
          '--test-threads=[number of test threads]:n:' \
          '*:pattern:' && ret=0
        ;;
      add|remove)
        _arguments \
          '(-p --path)'{-p+,--path=}'[path to the project]:path:_files -/' \
          '--manifest-path=[path to Forc.toml]:file:_files' \
          '--package=[package to modify]:name:' \
          '--dev[add as a dev-dependency]' \
          '--no-default-features[disable default features]' \
          '*:dependency:' && ret=0
        ;;
      update)
        _arguments \
          '(-p --path)'{-p+,--path=}'[path to the project]:path:_files -/' \
          '--manifest-path=[path to Forc.toml]:file:_files' \
          '(-d --dependency)'{-d+,--dependency=}'[only update this dependency]:name:' \
          '(-c --check)'{-c,--check}'[check for outdated deps without updating]' && ret=0
        ;;
      contract-id|predicate-root|parse-bytecode)
        _arguments \
          '(-p --path)'{-p+,--path=}'[path to the project]:path:_files -/' \
          '--manifest-path=[path to Forc.toml]:file:_files' \
          '*: :_files' && ret=0
        ;;
      addr2line)
        _arguments \
          '(-p --path)'{-p+,--path=}'[path to the project]:path:_files -/' \
          '(-g --debug)'{-g+,--debug=}'[debug info file]:file:_files' \
          '*:address:' && ret=0
        ;;
      fmt)
        _arguments \
          '(-c --check)'{-c,--check}'[check formatting, do not write]' \
          '(-p --path)'{-p+,--path=}'[path to project]:path:_files -/' \
          '--manifest-path=[path to Forc.toml]:file:_files' \
          '*: :_files' && ret=0
        ;;
      *)
        _arguments '*: :_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
