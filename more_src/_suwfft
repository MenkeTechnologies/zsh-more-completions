#compdef suwfft
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/suwfft.c
# Weighted amplitude FFT with spectrum flattening 0->Nyquist

local ret=1

_arguments -s -S \
  'w0=[w0]:w0:' \
  'w1=[w1]:w1:' \
  'w2=[w2]:w2:' \
  'f=[f]:f:' \
  'itmax=[itmax]:itmax:' \
  '*:file:_files' && ret=0

return ret
