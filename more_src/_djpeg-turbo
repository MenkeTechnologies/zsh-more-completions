#compdef djpeg-turbo

# djpeg-turbo: libjpeg-turbo'\''s JPEG decompressor
local curcontext="$curcontext" ret=1
_arguments -C \
  '-bmp[output BMP]' \
  '-fast[fast, lower-quality decompression]' \
  '-flip[flip output]:dir:(horizontal vertical)' \
  '-gif[output GIF]' \
  '-grayscale[grayscale output]' \
  '-map[output colourmap PPM]:file:_files' \
  '-maxmemory=[max in-memory work buffer (kB)]:n:' \
  '-nosmooth[no fancy pixel smoothing]' \
  '-onepass[one-pass quantization]' \
  '-os2[OS/2 BMP output]' \
  '-outfile[output file]:file:_files' \
  '-pnm[output PPM/PGM]' \
  '-rgb[force 24-bit RGB output]' \
  '-rgb565[output RGB565]' \
  '-scale[scale]:M/N:' \
  '-strict[reject corrupt input]' \
  '-targa[output Targa]' \
  '-version[show version]' \
  '*:JPEG file:_files -g "*.(jpg|jpeg)"' && ret=0
return ret
