#compdef djpeg-turbo

# djpeg-turbo: decode JPEG to image using libjpeg-turbo
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-bmp[output BMP]' \
  '-gif[output GIF]' \
  '-pnm[output PNM (default)]' \
  '-targa[output Targa]' \
  '-grayscale[force grayscale output]' \
  '-rgb[force RGB output]' \
  '-rgb565[output 16-bit RGB565]' \
  '-scale[scale M/N]:M/N:' \
  '-fast[fast decoding (lower quality)]' \
  '-nosmooth[disable IDCT smoothing]' \
  '-dct[DCT method]:method:(int fast float)' \
  '-dither[dither method]:method:(fs none ordered)' \
  '-maxmemory[max memory in kB]:n:' \
  '-outfile[output filename]:file:_files' \
  '*:input JPEG:_files -g "*.(jpg|jpeg|jpe|jfif|jif)"' && ret=0
return ret
