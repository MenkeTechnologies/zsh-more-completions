#compdef djpeg-turbo
# Documentation: https://manpages.debian.org/testing/libjpeg-turbo-progs/djpeg.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# djpeg-turbo: decode JPEG to image using libjpeg-turbo
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-bmp[output BMP (Windows)]' \
  '-os2[output BMP (OS/2)]' \
  '-gif[output GIF (LZW-compressed)]' \
  '-gif0[output GIF (uncompressed)]' \
  '-pnm[output PNM (default)]' \
  '-targa[output Targa]' \
  '-colors[reduce output to N colors]:n:' \
  '-quantize[alias for -colors]:n:' \
  '-grayscale[force grayscale output]' \
  '-rgb[force RGB output]' \
  '-scale[scale M/N]:M/N:' \
  '-fast[recommended low-quality processing]' \
  '-nosmooth[faster lower-quality upsampling]' \
  '-onepass[one-pass color quantization]' \
  '-dct[DCT method]:method:(int fast float)' \
  '-dither[dither method]:method:(fs ordered none)' \
  '-icc[extract ICC color profile to file]:file:_files' \
  '-map[quantize to colors from file]:file:_files' \
  '-maxmemory[max memory in kB]:n:' \
  '-maxscans[abort if image exceeds N scans]:n:' \
  '-outfile[output filename]:file:_files' \
  '-memsrc[load input into memory first]' \
  '-report[report decompression progress]' \
  '-skip[skip rows Y0,Y1]:Y0,Y1:' \
  '-crop[decompress subregion WxH+X+Y]:crop:' \
  '-strict[treat warnings as fatal]' \
  '-verbose[verbose debug output]' \
  '-debug[same as -verbose]' \
  '*:input JPEG:_files -g "*.(jpg|jpeg|jpe|jfif|jif)"' && ret=0
return ret
