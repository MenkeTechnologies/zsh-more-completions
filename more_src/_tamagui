#compdef tamagui

# Zsh completion for Tamagui CLI
# https://tamagui.dev

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:Pre-compile components'
  'generate-css:Generate static CSS'
  'generate-prompt:Generate LLM-friendly markdown'
  'check:Validate configuration'
  'add:Add fonts and icons'
)

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--debug[enable debug output]' \
  '--verbose[enable detailed debug output]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tamagui command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build)
        _arguments -s -S \
          '--target=[specify target platform]:target:(web native both)' \
          '--output=[output directory]:dir:_directories' \
          '--output-around[create platform-specific files next to source]' \
          '--include=[glob pattern for files to include]:pattern:' \
          '--exclude=[glob pattern for files to exclude]:pattern:' \
          '--dry-run[preview changes]' \
          '--expect-optimizations[fail if not optimized]' \
          '1:path:_files' && ret=0
        ;;
      (generate-css)
        _arguments -s -S \
          '--output=[output path]:file:_files' \
          '--config=[path to config file]:file:_files' && ret=0
        ;;
      (generate-prompt)
        _arguments -s -S \
          '--output=[output path]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
