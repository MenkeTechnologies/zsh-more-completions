#compdef ultra
# Documentation: https://github.com/folke/ultra-runner
# ultra - smart and fast npm/yarn script runner (ultra-runner)

local ret=1

_arguments -s -S \
  '--version[show version]' \
  '(-r --recursive)'{-r,--recursive}'[run command in all workspace packages]' \
  '--filter=[filter workspace packages by name or path]:pattern:' \
  '--root=[workspace root directory]:dir:_files -/' \
  '--concurrency=[number of concurrent processes]:n:' \
  '--info[show workspace info]' \
  '--list[list workspace packages]' \
  '--monitor[continuously monitor workspace]' \
  '--monitor-interval=[monitor refresh interval in seconds]:seconds:' \
  '(-b --build)'{-b,--build}'[build the current or selected package]' \
  '--rebuild[force rebuild ignoring caches]' \
  '--pretty[pretty formatted output]' \
  '--raw[raw unformatted output]' \
  '--silent[suppress output]' \
  '--color[force colored output]' \
  '(-d --dry-run)'{-d,--dry-run}'[show what would run without running]' \
  '*:script:' && ret=0

return ret
