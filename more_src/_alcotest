#compdef alcotest
# Documentation: https://github.com/mirage/alcotest/blob/main/src/alcotest-engine/cli.ml
# Reference accessed: 2026-05-27
# Verified: upstream src/alcotest-engine/cli.ml and config.ml (mirage/alcotest)

# Zsh completion for alcotest test runners (binaries built with the Alcotest library)

local curcontext="$curcontext" state line ret=1

local -a _alcotest_subcommands
_alcotest_subcommands=(
  'test:run a subset of the tests'
  'list:list all available tests'
)

local -a _alcotest_common
_alcotest_common=(
  '(-v --verbose)'{-v,--verbose}'[display the test outputs]'
  '(-c --compact)'{-c,--compact}'[compact the output of the tests]'
  '--bail[stop running tests after the first failure]'
  '--json[display JSON for the results, to be used by a script]'
  '(-e --show-errors)'{-e,--show-errors}'[display the test errors]'
  '(-q --quick-tests)'{-q,--quick-tests}'[run only the quick tests]'
  '--tail-errors=[show only the last N lines of output on error]:n:'
  '-o+[where to store the log files of the tests]:dir:_files -/'
  '--color=[colorize the output]:when:(auto always never)'
  '--help[show help]'
  '--help=[show help in format]:fmt:(auto pager groff plain)'
  '--version[print version]'
)

_arguments -C \
  $_alcotest_common \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'alcotest subcommand' _alcotest_subcommands && ret=0
    # Default command runs all tests with name_regex + testcases positionals
    _arguments \
      $_alcotest_common \
      '1:name-regex:' \
      '2:testcases:' && ret=0
    ;;
  args)
    case $line[1] in
      test)
        _arguments \
          $_alcotest_common \
          '1:name-regex:' \
          '2:testcases:' && ret=0
        ;;
      list)
        _arguments \
          '--color=[colorize the output]:when:(auto always never)' \
          '--help[show help]' && ret=0
        ;;
      *)
        _arguments $_alcotest_common && ret=0
        ;;
    esac
    ;;
esac

return ret
