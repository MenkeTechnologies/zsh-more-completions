#compdef gdal_rasterize
# Documentation: https://gdal.org/programs/gdal_rasterize.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '*-b+[band(s) to burn into]:band:' \
  '-i[invert rasterization]' \
  '-at[all touched pixels burned]' \
  '*-burn+[burn value]:value:' \
  '-a+[attribute name for burn value]:attribute:' \
  '-3d[burn Z value from feature]' \
  '-add[add to existing raster values]' \
  '*-l+[layer name]:layer:' \
  '-where+[SQL WHERE clause]:expression:' \
  '-sql+[SQL statement defining virtual layer]:query:' \
  '-dialect+[SQL dialect]:dialect:(OGRSQL SQLite)' \
  '-of+[output format]:format:' \
  '-a_srs+[assign output SRS]:srs:' \
  '*-to+[transformer option]:NAME=VALUE:' \
  '*-co+[creation option]:NAME=VALUE:' \
  '*-oo+[open option]:NAME=VALUE:' \
  '-a_nodata+[NoData value]:value:' \
  '-init+[initialization value]:value:' \
  '-te+[target extent: xmin ymin xmax ymax]:bounds:' \
  '-tr+[target resolution: xres yres]:resolution:' \
  '-tap[align extent to pixel size]' \
  '-ts+[output size: width height]:size:' \
  '-ot+[output data type]:type:(Byte Int8 UInt16 Int16 UInt32 Int32 UInt64 Int64 Float32 Float64 CInt16 CInt32 CFloat32 CFloat64)' \
  '-optim+[optimization mode]:mode:(AUTO VECTOR RASTER)' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '1:source vector file:_files' \
  '2:destination raster file:_files' && ret=0

return ret
