#compdef gdal_rasterize

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-b+[band(s) to burn into]:band:' \
  '-i[invert rasterization]' \
  '-at[all touched pixels burned]' \
  '-burn+[burn value]:value:' \
  '-a+[attribute name as burn value]:attribute:' \
  '-3d[indicate 3D burn from feature Z]' \
  '-add[add to existing raster values]' \
  '-l+[layer name]:layer:' \
  '-where+[SQL WHERE clause]:expression:' \
  '-sql+[SQL statement]:query:' \
  '-dialect+[SQL dialect]:dialect:(OGRSQL SQLite)' \
  '-of+[output format]:format:' \
  '-a_srs+[assign output SRS]:srs:' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-a_nodata+[NoData value]:value:' \
  '-init+[initialization value]:value:' \
  '-te+[target extent]:xmin ymin xmax ymax:' \
  '-tr+[target resolution]:xres yres:' \
  '-tap[align extent with multiples of pixel size]' \
  '-ts+[output size]:width height:' \
  '-ot+[output type]:type:(Byte Int8 UInt16 Int16 UInt32 Int32 UInt64 Int64 Float32 Float64 CInt16 CInt32 CFloat32 CFloat64)' \
  '-optim+[optimization mode]:mode:(AUTO VECTOR RASTER)' \
  '-q[quiet]' \
  '1:source vector file:_files' \
  '2:destination raster file:_files' && ret=0

return ret
