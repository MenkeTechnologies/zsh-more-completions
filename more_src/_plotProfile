#compdef plotProfile
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/plotProfile.html
# deepTools: create profile plots for scores over genomic regions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --matrixFile)'{-m,--matrixFile}'[matrix file from computeMatrix]:file:_files' \
  '(-o -out --outFileName)'{-o,-out,--outFileName}'[output image file]:file:_files' \
  '--outFileSortedRegions[sorted regions BED file]:file:_files' \
  '--outFileNameData[data table output file]:file:_files' \
  '--dpi[image resolution]:dpi:' \
  '--kmeans[number of k-means clusters]:n:' \
  '--hclust[number of hierarchical clusters]:n:' \
  '--silhouette[compute silhouette scores]' \
  '--version[show version]' \
  '--averageType[average statistic type]:type:(mean median min max std sum)' \
  '--plotHeight[plot height in cm]:cm:' \
  '--plotWidth[plot width in cm]:cm:' \
  '--plotType[plot type]:type:(lines fill se std overlapped_lines heatmap)' \
  '--colors[line colors]:colors:' \
  '--numPlotsPerRow[plots per row]:n:' \
  '--clusterUsingSamples[samples for clustering]:samples:' \
  '--startLabel[region start label]:label:' \
  '--endLabel[region end label]:label:' \
  '--refPointLabel[reference point label]:label:' \
  '--labelRotation[x-axis label rotation degrees]:deg:' \
  '(-z --regionsLabel)'{-z,--regionsLabel}'[region labels]:labels:' \
  '--samplesLabel[sample labels]:labels:' \
  '(-T --plotTitle)'{-T,--plotTitle}'[plot title]:title:' \
  '(-y --yAxisLabel)'{-y,--yAxisLabel}'[y-axis label]:label:' \
  '--yMin[y-axis minimum]:n:' \
  '--yMax[y-axis maximum]:n:' \
  '--legendLocation[legend location]:loc:(best upper-right upper-left upper-center lower-left lower-right lower-center center center-left center-right none)' \
  '--perGroup[plot samples by group]' \
  '--plotFileFormat[output file format]:format:(png pdf svg eps plotly)' \
  '--verbose[verbose output]' && ret=0

return ret
