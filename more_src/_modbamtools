#compdef modbamtools
# Documentation: https://rrazaghi.github.io/modbamtools/commands/
# modbamtools - manipulate and visualize modified base bam files

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)--help[show help]' \
  '1:command:((plot\:"plot single-read base modification data" calcMeth\:"calculate methylation statistics for bed regions"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      plot)
        _arguments -s \
          '(-r --region)'{-r,--region}'[region of interest e.g. chr21:1-1000]:region' \
          '(-br --batch)'{-br,--batch}'[bed file of regions for batch report]:bed:_files' \
          '(-g --gtf)'{-g,--gtf}'[tabix gtf for gene tracks]:gtf:_files' \
          '(-b --bed)'{-b,--bed}'[tabix bed for tracks]:bed:_files' \
          '(-bw --bigwig)'{-bw,--bigwig}'[bigwig file track]:bigwig:_files' \
          '(-bd --bedgraph)'{-bd,--bedgraph}'[bedgraph file track]:bedgraph:_files' \
          '(-s --samples)'{-s,--samples}'[sample names per bam input]:samples' \
          '(-tr --track-titles)'{-tr,--track-titles}'[titles of tracks in order]:titles' \
          '(-hp --hap)'{-hp,--hap}'[group reads by HP tag]' \
          '(-st --strands)'{-st,--strands}'[group reads by strand]' \
          '(-o --out)'{-o,--out}'[output path]:dir:_files -/' \
          '(-p --prefix)'{-p,--prefix}'[output file name]:prefix' \
          '(-f --fmt)'{-f,--fmt}'[output format]:fmt:(png html svg pdf)' \
          '(-u --can_prob)'{-u,--can_prob}'[probability threshold for canonical bases]:prob' \
          '(-m --mod_prob)'{-m,--mod_prob}'[probability threshold for modified bases]:prob' \
          '(-h --height)'{-h,--height}'[plot height in px]:px' \
          '(-w --width)'{-w,--width}'[plot width in px]:px' \
          '(-c --cluster)'{-c,--cluster}'[cluster reads by modification state]' \
          '--help[show help]' && ret=0
        ;;
      calcMeth)
        _arguments -s \
          '(-b --bed)'{-b,--bed}'[bed file of regions]:bed:_files' \
          '(-t --threads)'{-t,--threads}'[number of threads]:n' \
          '(-a --min_calls)'{-a,--min_calls}'[min calls per read]:n' \
          '(-s --min_cov)'{-s,--min_cov}'[min portion of region a read must span]:frac' \
          '(-hp --hap)'{-hp,--hap}'[group by HP tag]' \
          '(-o --out)'{-o,--out}'[output path]:file:_files' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
