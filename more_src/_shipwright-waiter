#compdef shipwright-waiter
# _shipwright-waiter — Shipwright Build sidecar gating helper (waits on a lockfile; start/done subcommands)
# upstream: https://github.com/shipwright-io/build
# Subcommands + flags from cmd/waiter/main.go + waiter.go on tip (cobra).

_shipwright-waiter() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--lock-file=[lock file full path]:file:_files' \
        '--timeout=[how long to wait until done]:duration:' \
        '1: :->cmd'
    case $state in
        cmd)
            local -a subs=(
                start:'block until the done signal arrives or timeout'
                done:'signal done to a waiting waiter (alias: stop)'
                stop:'signal done to a waiting waiter (alias of done)'
            )
            _describe -t commands 'shipwright-waiter subcommand' subs
            ;;
    esac
}

_shipwright-waiter "$@"
