#compdef CreateImage
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/CreateImage.cxx — create a new image from a reference or from explicit geometry (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '*:positional args (Usage 1: refImage out const [random]; Usage 2: out origin spacing size const [random]; Usage 3: out origin spacing size pixelValues):_files' \
    && ret=0

return ret
