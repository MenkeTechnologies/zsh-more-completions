#compdef capinfos-cli
# _capinfos-cli — Wireshark capinfos pcap file summary CLI alias (wireshark team, C); custom argparse
# upstream: https://gitlab.com/wireshark/wireshark

_capinfos-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-t[display capture type]' \
        '-E[display capture encapsulation]' \
        '-I[display capture interface info]' \
        '-F[display additional capture file info]' \
        '-H[generate SHA256 SHA1 RMD160 MD5 hashes of each file]' \
        '-k[display capture comment]' \
        '-c[display number of packets]' \
        '-s[display size of file in bytes]' \
        '-d[display total length of all packets in bytes]' \
        '-l[display packet size limit (snaplen)]' \
        '-u[display capture duration]' \
        '-a[display capture start time]' \
        '-e[display capture end time]' \
        '-o[display capture file chronological status]' \
        '-S[display secs format]' \
        '-y[display average data rate]' \
        '-i[display average data rate in bits/sec]' \
        '-z[display average packet size in bytes]' \
        '-x[display average packet rate]' \
        '-A[generate all info]' \
        '-T[generate table report]' \
        '-M[only display machine-readable values]' \
        '-R[only display raw and ASCII values]' \
        '-B[only display byte/sec values]' \
        '-r[do not generate header record]' \
        '-N[do not quote values]' \
        '-Q[only quote strings]' \
        '-q[always quote values]' \
        '-d+[delimiter character]:str:' \
        '-D+[delimiter character (alias)]:str:' \
        '-K[do not quote values]' \
        '-C+[character]:str:' \
        '*:files:_files -g "*.pcap*"'
}

_capinfos-cli "$@"
