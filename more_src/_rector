#compdef rector

# Zsh completion for Rector - PHP refactoring tool

local curcontext="$curcontext" state line ret=1

local -a rector_commands
rector_commands=(
  'process:run Rector on files'
  'list-rules:list available rules'
  'setup-ci:setup CI integration'
  'custom-rule:create a custom rule'
  'detect-node:detect AST node type'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c,--config}'=[path to config file]:config file:_files -g "*.php"' \
  '--dry-run[show diff without making changes]' \
  '--clear-cache[clear cache before running]' \
  '--debug[enable debug output]' \
  '--no-progress-bar[disable progress bar]' \
  '--xdebug[allow running with Xdebug enabled]' \
  '--autoload-file=[path to autoload file]:file:_files -g "*.php"' \
  '--output-format=[output format]:format:(json checkstyle console)' \
  '--no-diffs[hide diffs in output]' \
  '--memory-limit=[memory limit]:limit:' \
  '--parallel[run in parallel]' \
  '1:command:_describe -t commands command rector_commands' \
  '*:files or directories:_files' && ret=0

return ret
