#compdef pmh7tool
# Documentation: https://github.com/coreboot/coreboot/blob/master/util/pmh7tool/pmh7tool.c
# coreboot Lenovo PMH7 embedded controller register tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-d --dump)'{-d,--dump}'[print registers]' \
  '(-w --write)'{-w,--write}'[write to register]:addr:' \
  '(-r --read)'{-r,--read}'[read from register]:addr:' \
  '(-b --read-bit)'{-b,--read-bit}'[read bit]:addr:' \
  '(-c --clear-bit)'{-c,--clear-bit}'[clear bit]:addr:' \
  '(-s --set-bit)'{-s,--set-bit}'[set bit]:addr:' && ret=0

return ret
