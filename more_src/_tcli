autoload -U is-at-least

_tcli() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--keystore=[Path to tumpa keystore database. Defaults to ~/.tumpa/keys.db]:KEYSTORE:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tcli_commands" \
"*::: :->tcli" \
&& ret=0
    case $state in
    (tcli)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tcli-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
'--keystore=[Path to tumpa keystore database. Defaults to ~/.tumpa/keys.db]:KEYSTORE:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(import)
_arguments "${_arguments_options[@]}" : \
'--keystore=[Path to tumpa keystore database. Defaults to ~/.tumpa/keys.db]:KEYSTORE:_files' \
'-r[Recurse into subdirectories]' \
'--recursive[Recurse into subdirectories]' \
'-h[Print help]' \
'--help[Print help]' \
'*::files -- File or directory paths. Use `-` for stdin:_default' \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file. Defaults to stdout]:OUTPUT:_files' \
'--output=[Output file. Defaults to stdout]:OUTPUT:_files' \
'--keystore=[Path to tumpa keystore database. Defaults to ~/.tumpa/keys.db]:KEYSTORE:_files' \
'--binary[Export as binary OpenPGP packets instead of ASCII-armored]' \
'-h[Print help]' \
'--help[Print help]' \
':key_id -- Key fingerprint or key ID:_default' \
&& ret=0
;;
(describe)
_arguments "${_arguments_options[@]}" : \
'--keystore=[Path to tumpa keystore database. Defaults to ~/.tumpa/keys.db]:KEYSTORE:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
