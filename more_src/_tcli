&& ret=0
;;
(sign-inline)
_arguments "${_arguments_options[@]}" : \
'--signer=[Signer identifier\: fingerprint, key ID, or exact email]:FP|KEYID|EMAIL:_default' \
'-o+[Output file. Defaults to \`<FILE>.asc\`]:OUTPUT:_files' \
