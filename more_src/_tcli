&& ret=0
;;
(sign)
_arguments "${_arguments_options[@]}" : \
'--signer=[Signer identifier\: fingerprint, key ID, or exact email]:FP|KEYID|EMAIL:_default' \
'-o+[Output file. Defaults to \`<FILE>.asc\` (or \`<FILE>.sig\` with --binary)]:OUTPUT:_files' \
'--output=[Output file. Defaults to \`<FILE>.asc\` (or \`<FILE>.sig\` with --binary)]:OUTPUT:_files' \
'--keystore=[Path to tumpa keystore database. Defaults to ~/.tumpa/keys.db]:KEYSTORE:_files' \
'--binary[Binary signature instead of ASCII-armored]' \
