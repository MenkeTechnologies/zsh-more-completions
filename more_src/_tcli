;;
(fetch)
_arguments "${_arguments_options[@]}" : \
'--keystore=[Path to tumpa keystore database. Defaults to ~/.tumpa/keys.db]:KEYSTORE:_files' \
'--dry-run[Show key info but don'\''t import]' \
'-h[Print help]' \
'--help[Print help]' \
