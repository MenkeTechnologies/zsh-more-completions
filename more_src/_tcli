(( $+functions[_tcli_commands] )) ||
_tcli_commands() {
    local commands; commands=(
'list:List keys in the tumpa keystore (human-readable)' \
'import:Import keys from files or directories. Use \`-\` for stdin' \
'export:Export a key from the keystore (default\: ASCII-armored to stdout)' \
'describe:Show detailed information about a key' \
'delete:Delete a key from the keystore' \
'search:Search for keys in the keystore' \
'fetch:Fetch and import a key via WKD (Web Key Directory)' \
'sign:Create a detached signature for FILE (use \`-\` for stdin). Default output is \`<FILE>.asc\` (ASCII-armored)' \
'sign-inline:Create an inline (cleartext) signature. Software keys only' \
'verify:Verify a signature on FILE' \
'card:OpenPGP smart card operations' \
'cache:Manage the running agent'\''s in-memory credential cache' \
'socket:Print an agent socket path. Default \`gpg\`; pass \`ssh\` for the SSH socket' \
'agent:Run the agent daemon (GPG passphrase cache + optional SSH agent)' \
'ssh-agent:Run only the SSH agent daemon (no GPG passphrase cache socket)' \
'ssh-export:Export the SSH public key for a given OpenPGP key' \
'completions:Generate shell completions for tcli and print to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'tcli commands' commands "$@"
}
(( $+functions[_tcli__subcmd__agent_commands] )) ||
_tcli__subcmd__agent_commands() {
    local commands; commands=()
    _describe -t commands 'tcli agent commands' commands "$@"
}
