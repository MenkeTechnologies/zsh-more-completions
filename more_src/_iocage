#compdef iocage

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--force[skip prompts]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'activate:activate a zpool for iocage'
      'chroot:chroot into a jail'
      'clean:destroy all jails and templates'
      'clone:clone a jail'
      'console:login to a jail'
      'create:create a jail'
      'deactivate:deactivate a zpool for iocage'
      'debug:debug iocage'
      'destroy:destroy a jail'
      'df:show resource usage for all jails'
      'exec:execute a command inside a jail'
      'export:export a jail to a compressed file'
      'fetch:fetch a release for jail creation'
      'fstab:manage a jail fstab'
      'get:get a jail property'
      'import:import a jail from a compressed file'
      'list:list jails'
      'migrate:migrate jails to the latest format'
      'pkg:manage packages in a jail'
      'rename:rename a jail'
      'restart:restart a jail'
      'rollback:rollback a jail to a snapshot'
      'set:set a jail property'
      'snaplist:list snapshots of a jail'
      'snapremove:remove a snapshot'
      'snapshot:create a jail snapshot'
      'start:start a jail'
      'stop:stop a jail'
      'update:update a jail to the latest patch level'
      'upgrade:upgrade a jail to a newer release'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    local -a jails
    jails=(${(f)"$(iocage list -h 2>/dev/null | awk '{print $2}')"})
    case ${words[1]} in
      (console|start|stop|restart|destroy|clone|rename|export|exec|chroot|get|set|snapshot|snaplist|snapremove|rollback|fstab|pkg|update|upgrade|df)
        _arguments '1:jail:($jails)' '*:args:' && ret=0
        ;;
      (create)
        _arguments \
          '-r+[release to use]:release:' \
          '-n+[jail name]:name:' \
          '-p+[properties file]:file:_files' \
          '-b[create a basejail]' \
          '-e[create an empty jail]' \
          '-s[short UUID]' \
          '-t+[template to use]:template:' \
          '-c+[count of jails]:count:' \
          '*:properties (key=value):' && ret=0
        ;;
      (fetch)
        _arguments \
          '-r+[release to fetch]:release:' \
          '-s+[server to fetch from]:server:' \
          '-d+[root directory for download]:directory:_files -/' \
          '-f+[file to fetch]:filename:' && ret=0
        ;;
      (list)
        _arguments \
          '-l[long output]' \
          '-r[list releases]' \
          '-t[list templates]' \
          '-R[list remote releases]' \
          '-b[list basejails]' \
          '-h[no header]' \
          '-s+[sort by property]:property:' && ret=0
        ;;
    esac
    ;;
esac

return ret
