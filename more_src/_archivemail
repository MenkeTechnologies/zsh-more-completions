#compdef archivemail
# Documentation: man archivemail(1)
# Source: codemac/archivemail archivemail (master) — archive mail from mbox/maildir/MH (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --days -D --date)'{-d+,--days=}'[archive mail older than N days]:N:_default' \
    '(-d --days -D --date)'{-D+,--date=}'[archive mail older than date]:YYYY-MM-DD:_default' \
    '(-o --output-dir)'{-o+,--output-dir=}'[output directory]:dir:_files -/' \
    '(-S --suffix)'{-S+,--suffix=}'[archive name suffix]:suffix:_default' \
    '(-P --prefix)'{-P+,--prefix=}'[archive name prefix]:prefix:_default' \
    '(-a --archive-name)'{-a+,--archive-name=}'[archive name]:name:_default' \
    '(-F --filter-append)'{-F+,--filter-append=}'[append IMAP filter to search]:filter:_default' \
    '(-p --pwfile)'{-p+,--pwfile=}'[IMAP password file]:file:_files' \
    '-s+[archive size]:bytes:_default' \
    '(--delete --copy)--delete[delete original messages after archiving]' \
    '(--delete --copy)--copy[do not delete, just copy]' \
    '--include-flagged[include flagged messages]' \
    '--preserve-unread[do not archive unread mail]' \
    '--no-compress[do not compress archive]' \
    '--dont-mangle[do not mangle From_ lines]' \
    '--warn-duplicate[warn about duplicate messages]' \
    '--all[archive all messages]' \
    '(-n --dry-run)'{-n,--dry-run}'[do not modify mailboxes]' \
    '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '--debug-imap=[IMAP debug level]:level:_default' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-h --help -?)'{-h,--help,-\\?}'[show help]' \
    '*:mailbox:_files' \
    && ret=0

return ret
