#compdef rufo

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-c,--check}'[check formatting without modifying files]' \
  '--simple-exit[return 0 even if files need formatting]' \
  {-x,--include-hidden}'[include hidden files and directories]' \
  '--filename[filename to use for stdin]:filename:' \
  '*:file or directory:_files' && ret=0

return ret
