#compdef gotwebd
# Documentation: https://gameoftrees.org/gotwebd.8.html
# Game of Trees web server daemon

local ret=1

_arguments -s -S \
  '*-D[define macro to value, overriding config]:macro=value:' \
  '-d[do not daemonize, send log output to stderr]' \
  '-f[set path to the configuration file]:config file:_files' \
  '-n[parse configuration file, report errors, and exit]' \
  '*-v[verbose mode, repeat to increase verbosity]' && ret=0

return ret
