#compdef rethinkdb
# Documentation: https://rethinkdb.com/docs/
# RethinkDB distributed document database server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --directory)'{-d,--directory}'+[data and metadata directory]:path:_files -/' \
  '--io-threads=[concurrent I/O operations limit]:n:' \
  '--direct-io[enable direct I/O for file access]' \
  '--cache-size=[total cache size in MB or auto]:mb:' \
  '(-n --server-name)'{-n,--server-name}'+[name for this server]:name:' \
  '(-t --server-tag)'{-t,--server-tag}'+[a tag for this server]:tag:' \
  '*--bind=[address of a local interface to listen on]:addr:' \
  '--bind-http=[bind web UI port to address]:addr:' \
  '--bind-cluster=[bind cluster port to address]:addr:' \
  '--bind-driver=[bind client driver to address]:addr:' \
  '--no-default-bind[disable automatic loopback listening]' \
  '--cluster-port=[port for inter-node connections]:port:' \
  '--driver-port=[port for client drivers]:port:' \
  '(-o --port-offset)'{-o,--port-offset}'+[add value to all local ports]:offset:' \
  '*'{-j,--join}'+[host and port of a node to connect to]:host\:port:' \
  '--canonical-address=[address for cluster peer connections]:addr:' \
  '--cluster-reconnect-timeout=[reconnection attempt duration in seconds]:secs:' \
  '--http-port=[web console port]:port:' \
  '--no-http-admin[disable web administration]' \
  '(-c --cores)'{-c,--cores}'+[core count]:n:' \
  '--pid-file=[process ID file location]:path:_files' \
  '--daemon[daemonize the process]' \
  '--runuser=[execute as user]:user:_users' \
  '--rungroup=[execute as group]:group:_groups' \
  '--initial-password=[set admin password or auto]:password:' \
  '--log-file=[logging destination]:path:_files' \
  '--no-update-check[disable update checks]' \
  '--config-file=[load options from config file]:path:_files' \
  '*:command:(create serve proxy export import dump restore index-rebuild install-service remove-service)' && ret=0

return ret
