#compdef median_filter
# Documentation: https://healpix.sourceforge.io/html/fac_median_filter.htm
# HEALPix: apply a median filter to a map

local ret=1

_arguments -s -S \
  '(-d --double -s --single)'{-d,--double}'[use double precision]' \
  '(-d --double -s --single)'{-s,--single}'[use single precision (default)]' \
  '*:parameter file:_files' && ret=0

return ret
