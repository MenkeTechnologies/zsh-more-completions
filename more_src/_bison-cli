#compdef bison-cli yacc-cli byacc-cli
# _bison-cli — GNU bison parser generator CLI alias (GNU team, C); custom argparse
# upstream: https://www.gnu.org/software/bison/

_bison-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--print-localedir[print locale dir]' \
        '--print-datadir[print data dir]' \
        '-y[POSIX yacc compatibility]' \
        '--yacc[POSIX yacc compatibility]' \
        '-W[enable warnings]' \
        '--warnings=+[category]:c:(all none cex conflicts-sr conflicts-rr counterexamples dangling-alias deprecated empty-rule midrule-values precedence yacc no-error error error-rule no-error-rule)' \
        '-f+[diagnostic style]:s:(none caret fixit)' \
        '--feature=+[diagnostic style]:s:(none caret fixit)' \
        '--color=+[when]:w:(always never auto)' \
        '--style=+[style]:str:' \
        '--language=+[language]:l:(C C++ D Java)' \
        '-L+[language]:l:(C C++ D Java)' \
        '-S+[skeleton]:str:' \
        '--skeleton=+[skeleton]:str:' \
        '-t[instrument parser for tracing]' \
        '--debug[instrument parser for tracing]' \
        '--locations[enable locations]' \
        '-D+[define %define value]:str:' \
        '--define=+[define %define value]:str:' \
        '-F+[force-define %define value]:str:' \
        '--force-define=+[force-define %define value]:str:' \
        '-p+[symbol prefix]:str:' \
        '--name-prefix=+[symbol prefix]:str:' \
        '-l[no line directives]' \
        '--no-lines[no line directives]' \
        '-k[include token table]' \
        '--token-table[include token table]' \
        '--header=+[header file]:file:_files -g "*.h"' \
        '-d[generate header]' \
        '--defines=+[header file]:file:_files -g "*.h"' \
        '-r+[report]:r:(states itemsets lookaheads solved all none)' \
        '--report=+[report]:r:(states itemsets lookaheads solved all none)' \
        '--report-file=+[file]:file:_files' \
        '-v[verbose report]' \
        '--verbose[verbose report]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-g[output graph]' \
        '--graph=+[graph file]:file:_files' \
        '-x[output xml]' \
        '--xml=+[xml file]:file:_files' \
        '-M+[map]:str:' \
        '--file-prefix=+[prefix]:str:' \
        '-b+[file prefix]:str:' \
        '--no-link[no link]' \
        '*:grammar file:_files -g "*.{y,yy,ypp,y++}"'
}

_bison-cli "$@"
