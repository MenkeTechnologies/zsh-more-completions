#compdef holos
# Documentation: https://holos.run/docs/v1alpha5/tutorial/hello-holos/
# Holistic platform manager rendering Kubernetes manifests with the rendered manifests pattern

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:command:((
    render\:"render manifests for a platform or component"
    init\:"initialize a platform structure"
    show\:"show build plans and platform details"
  ))' && ret=0

return ret
