#compdef dotbare
# Documentation: https://github.com/kazhala/dotbare
# dotbare - manage dotfiles and any git directories interactively with fzf

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-v --version)'{-v,--version}'[show dotbare current version]' \
  '1:command:(fadd fbackup fcheckout fedit fgrep finit flog freset fstash fstat funtrack fupgrade)' \
  '*::arg:->args' && ret=0

return ret
