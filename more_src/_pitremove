#compdef pitremove PitRemove
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/PitRemove.html
# TauDEM: fill pits in a DEM so every cell drains

local ret=1

_arguments -s -S \
  '-z[input elevation grid (demfile)]:demfile:_files' \
  '-fel[output pit-filled elevation grid]:felfile:_files' \
  '-4way[fill using only 4-directional connectivity]' \
  '-depmask[depression mask grid; cells valued 1 are preserved]:depmaskfile:_files' \
  '*:file:_files' && ret=0

return ret
