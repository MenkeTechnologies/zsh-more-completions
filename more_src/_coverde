#compdef coverde
# Documentation: https://pub.dev/packages/coverde
# coverde - filter, check and report Dart/Flutter coverage trace files

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(-h --help)'{-h,--help}'[display help information]' \
  '--version[show version number]' \
  '1:command:(optimize-tests check filter transform report remove value)' \
  '*::args:' && ret=0

return ret
