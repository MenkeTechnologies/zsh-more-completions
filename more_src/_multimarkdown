#compdef multimarkdown
# Documentation: https://fletcher.github.io/MultiMarkdown-6/usage/index.html
# multimarkdown - MultiMarkdown lightweight markup processor

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-t --to)'{-t+,--to=}'[output format]:format:(html latex epub mmd fodt odt opml beamer memoir)' \
  '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
  '-b[batch mode for multiple files]' \
  '(-f --full)'{-f,--full}'[output complete document]' \
  '(-s --snippet)'{-s,--snippet}'[output snippet only]' \
  '(-c --compatibility)'{-c,--compatibility}'[Markdown compatibility mode]' \
  '--random[generate random footnote/citation anchors]' \
  '--unique[use random numbers for header labels]' \
  '--nolabels[disable automatic header labels]' \
  '--nosmart[disable smart typography]' \
  '--notransclude[disable file transclusion]' \
  '--opml[read OPML input]' \
  '--itmz[read iThoughts input]' \
  '(-m --metadata-keys)'{-m,--metadata-keys}'[list metadata keys]' \
  '(-e --extract)'{-e+,--extract=}'[extract metadata value for key]:key:' \
  '(-a --accept)'{-a,--accept}'[accept all CriticMarkup changes]' \
  '(-r --reject)'{-r,--reject}'[reject all CriticMarkup changes]' \
  '(-l --lang)'{-l+,--lang=}'[language for quotes]:lang:(en es de fr he nl sv)' \
  '*:file:_files' && ret=0

return ret
