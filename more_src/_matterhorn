#compdef matterhorn

_arguments -s \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '(-l --logs)'{-l,--logs}'=[log file]:file:_files' \
  '(-i --ignore-config)'{-i,--ignore-config}'[ignore config]' \
  '(-k --keybindings)'{-k,--keybindings}'[print keybindings]' \
  '(-m --commands)'{-m,--commands}'[print commands]' \
  '(-f --format)'{-f,--format}'=[output format]:format:(plain markdown)' \
  '--check-config[validate config and exit]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]'
