#compdef pmlogsummary
# _pmlogsummary — Performance Co-Pilot pmlogsummary (per-metric statistical summary (min/max/avg/sum/count/stddev) across a PCP archive; -B brief, -F first/last timestamps, -H header-only, -l metric labels, -I include instance ids, -N include metric name, -p print samples, -y derived calc, -S start, -T finish, positional archive + optional metric list)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmlogsummary/pmlogsummary.c on tip.

_pmlogsummary() {
    _arguments \
        '-B[brief]' \
        '-F[first/last timestamps]' \
        '-H[header only]' \
        '-l[metric labels]' \
        '-I[include instance ids]' \
        '-N[include metric name]' \
        '-p[print samples]' \
        '-y[derived calc]' \
        '-S+[start time]:time:' \
        '-T+[finish time]:time:' \
        '-x+[expr]:expr:' \
        '-z[archive timezone]' \
        '-Z+[timezone]:tz:' \
        '-n+[namespace]:file:_files' \
        '1:archive:_files' \
        '*:metric:'
}

_pmlogsummary "$@"
