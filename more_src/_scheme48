#compdef scheme48
# Documentation: https://man.archlinux.org/search?q=scheme48
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-i+[image file]:file:_files -g "*.image"' \
  '-h+[heap size]:n:' \
  '-s+[stack size]:n:' \
  '-a+[command-line args]:args:' \
  '-c+[command]:cmd:' \
  '-e+[expression]:expr:' \
  '-l+[load file]:file:_files' \
  '-d[debug mode]' \
  '*:scheme file:_files -g "*.scm"' && ret=0

return ret
