#compdef scheme48
# Documentation: https://s48.org/1.9/manual/manual-Z-H-3.html
# Reference accessed: 2026-05-21
# Verified: Scheme 48 1.9 manual section on command line options.
# Documented flags: -i (image), -h (heapsize), -a (image arguments),
# -I (combined image+args), -o (vm executable). Pre-existing -s, -c,
# -e, -l, -d flags were unverifiable and removed.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-i+[heap image file to resume]:file:_files -g "*.image"' \
  '-h+[heap size in words]:n:' \
  '-a+[arguments to image]:args:' \
  '-I+[combined image and arguments]:image:_files -g "*.image"' \
  '-o+[VM executable path]:file:_files' \
  '*:scheme file:_files -g "*.(scm|ss)"' && ret=0

return ret
