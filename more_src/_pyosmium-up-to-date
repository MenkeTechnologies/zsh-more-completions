#compdef pyosmium-up-to-date
# Documentation: https://docs.osmcode.org/pyosmium/latest/user_manual/10-Replication-Tools/
# Update an OSM file to the latest available data from a replication server.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*-v[increase verbosity (repeatable)]' \
  '(-o --outfile)'{-o+,--outfile=}'[output file (default overwrite input)]:file:_files' \
  '--format=[output data format]:format:_default' \
  '--server=[base URL of the replication server]:url:_urls' \
  '--diff-type=[replication server file format (default osc.gz)]:type:_default' \
  '(-s --size)'{-s+,--size=}'[max change size in MB]:mb:_default' \
  '--end-id=[last sequence ID to download]:id:_default' \
  '(-E --end-date)'{-E+,--end-date=}'[stop downloading diffs after date]:date:_default' \
  '--tmpdir=[directory for temporary files]:dir:_files -/' \
  '--ignore-osmosis-headers[ignore replication header info in input file]' \
  '(-b --wind-back)'{-b+,--wind-back=}'[minutes to backtrack before newest data]:minutes:_default' \
  '--force-update-of-old-planet[allow updates on very old input data]' \
  '--cookie=[Netscape-style cookie jar file]:file:_files' \
  '--socket-timeout=[timeout for file downloads]:seconds:_default' \
  '*:OSM file to update:_files -g "*.(osm|osm.pbf|osm.bz2|pbf)(-.)"' && ret=0

return ret
