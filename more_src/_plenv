#compdef plenv

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'local:set local Perl version'
  'global:set global Perl version'
  'shell:set shell-specific Perl version'
  'versions:list installed Perl versions'
  'version:show current Perl version'
  'install:install a Perl version'
  'install-cpanm:install cpanm into current Perl'
  'rehash:install shims for Perl executables'
  'which:show full path to executable'
  'whence:list versions with a given command'
  'migrate-modules:migrate modules between Perls'
  'exec:exec command using current Perl'
  'help:show help'
)

_arguments -C \
  '(- *)--version[show plenv version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'plenv subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (local|global|shell)
        _arguments \
          '--unset[clear the version]' \
          ':version:' && ret=0
        ;;
      (install)
        _arguments \
          '--list[list installable versions]' \
          '--as=[custom variant name]:name:' \
          '*-D[Perl Configure option]:option:' \
          ':version:' && ret=0
        ;;
    esac
    ;;
esac

return ret
