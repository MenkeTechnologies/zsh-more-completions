#compdef arachni_script
# Documentation: https://github.com/Arachni/arachni/wiki/Executables
# Arachni script runner under the Arachni library namespace

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[output this message]' \
  '--version[show version information]' \
  '*:script file:_files -g "*.rb"' && ret=0

return ret
