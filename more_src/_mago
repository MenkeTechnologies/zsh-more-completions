#compdef mago
# Documentation: https://man.archlinux.org/search?q=mago
# Reference accessed: 2026-05-16

# https://github.com/carthage-software/mago — src/commands/mod.rs

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--workspace=[project root]:directory:_files -/' \
  '--config=[mago.toml path]:file:_files' \
  '--php-version=[PHP version]:version:' \
  '--threads=[worker count]:threads:' \
  '--allow-unsupported-php-version[skip PHP support check]' \
  '--no-version-check[hide version drift warning]' \
  '--colors=[color policy]:policy:(auto always never)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a _mago_cmds
    _mago_cmds=(
      init:'create mago.toml'
      config:'print merged configuration'
      'list-files':'list PHP inputs'
      ast:'dump AST'
      lint:'run linters'
      analyze:'static analysis'
      guard:'architecture rules'
      format:'format PHP'
      'self-update':'upgrade mago'
      'generate-completions':'emit shell completions'
    )
    _describe -t commands 'mago command' _mago_cmds && ret=0
    ;;
esac

return ret
