#compdef pollen
# Documentation: https://man.archlinux.org/search?q=pollen
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'start:start project server'
  'render:render files'
  'publish:publish a project'
  'reset:reset cache'
  'setup:warm cache'
  'version:show version'
  'first:first run'
  'clone:clone project'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pollen command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '1:project dir:_files -/' \
          '2:port:' \
          '*::: :_files' && ret=0 ;;
      (render|publish|reset|setup)
        _arguments \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
