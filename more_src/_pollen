#compdef pollen
# Documentation: https://docs.racket-lang.org/pollen/raco-pollen.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Removed from prior file: fabricated "first" subcommand. Added: test
# and verbatim render/start/publish/setup flags from upstream.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'test:verify installation'
  'help:show help'
  'start:start project server'
  'render:render source files'
  'publish:copy project without source files'
  'reset:reset cache'
  'setup:compile sources into cache'
  'version:show version'
  'clone:alias for publish'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pollen command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '(-l --launch)'{-l,--launch}'[open dashboard in browser]' \
          '--local[restrict server to localhost only]' \
          '1:project dir:_files -/' \
          '2:port:' && ret=0 ;;
      (render)
        _arguments \
          '(-d --dry-run)'{-d,--dry-run}'[preview paths without rendering]' \
          '(-f --force)'{-f,--force}'[force fresh render]' \
          '(-n --null)'{-n,--null}'[render without writing files]' \
          '(-t --target)'{-t,--target}'+[render target]:target:' \
          '(-p --parallel)'{-p,--parallel}'[use all processor cores]' \
          '(-j --jobs)'{-j,--jobs}'+[parallel jobs count]:jobs:' \
          '(-s --subdir)'{-s,--subdir}'[include subdirectories]' \
          '(-r --recursive)'{-r,--recursive}'[treat subdirectories as independent projects]' \
          '*: :_files' && ret=0 ;;
      (publish|clone)
        _arguments \
          '(-d --dry-run)'{-d,--dry-run}'[show destination without publishing]' \
          '(-c --confirm)'{-c,--confirm}'[confirm if destination exists]' \
          '1:project dir:_files -/' \
          '2:dest dir:_files -/' && ret=0 ;;
      (setup)
        _arguments \
          '(-p --parallel)'{-p,--parallel}'[parallel compilation]' \
          '(-j --jobs)'{-j,--jobs}'+[parallel jobs count]:jobs:' \
          '(-d --dry-run)'{-d,--dry-run}'[show paths without compiling]' \
          '*: :_files -/' && ret=0 ;;
      (reset)
        _arguments \
          '*: :_files -/' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
