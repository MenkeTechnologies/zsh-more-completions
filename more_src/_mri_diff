#compdef mri_diff
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_diff
# Determine differences between two volumes

local ret=1

_arguments -s -S \
  '--allow-res[do not check for resolution diffs]' \
  '--allow-acq[do not check for acq param diffs]' \
  '--allow-geo[do not check for geometry diffs]' \
  '--allow-prec[do not check for precision diffs]' \
  '--allow-pix[do not check for pixel diffs]' \
  '--allow-ori[do not check for orientation diffs]' \
  '--qa[check res, acq, precision and orientation only]' \
  '--thresh[pix diffs must be greater than this]:thresh:' \
  '--log[store diff info in this file]:difffile:_files' \
  '--debug[turn on debugging]' \
  '--checkopts[check options and exit]' \
  '--help[print help]' \
  '--version[print version and exit]' \
  '*:volume:_files' && ret=0

return ret
