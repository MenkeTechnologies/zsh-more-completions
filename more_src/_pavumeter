#compdef pavumeter
# Documentation: https://manpages.debian.org/testing/pavumeter/pavumeter.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help summary]' \
  '(- *)--help-all[show all available options]' \
  '(- *)--help-gtk[show standard gtk options]' \
  '--record=[show recording levels for the named source]:source:' \
  '--display=[X display to use]:display:' \
  '*:sink:' && ret=0

return ret
