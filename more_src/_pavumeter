#compdef pavumeter
# Documentation: https://man.archlinux.org/search?q=pavumeter
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--source=+[source name]:src:' \
  '--sink=+[sink name]:sink:' \
  '--monitor[monitor sink output]' && ret=0

return ret
