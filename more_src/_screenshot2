#compdef screenshot2
# Documentation: https://man.archlinux.org/search?q=screenshot2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-d+[device serial]:serial:' \
  '-s[touch the device to take screenshot]' \
  '*:output file:_files -g "*.(png|jpg|jpeg)"' && ret=0

return ret
