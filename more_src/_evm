#compdef evm fetchpayload
# Documentation: upstream cmd/{evm,fetchpayload}/main.go at github.com/ethereum/go-ethereum
# Reference accessed: 2026-05-30
# Continuation of go-ethereum sister-binary R42. Both ship alongside
# the previously-covered _geth/_abigen/_clef/_devp2p/_ethkey/_rlpdump/
# _blsync/_era binaries.

local curcontext="$curcontext" state line ret=1

case $service in

  evm)
    # ethereum/go-ethereum evm — Ethereum Virtual Machine debugger
    # and state-transition test runner.
    local -a _subcmds
    _subcmds=(
      'run:execute EVM bytecode snippets'
      'blocktest:test block execution'
      'statetest:test state transitions'
      'transition:execute a full state transition'
      't8n:alias for transition'
      'transaction:perform transaction validation'
      't9n:alias for transaction'
      'block-builder:build a block'
      'b11r:alias for block-builder'
      'verkle:binary-trie helpers'
      'vkt:alias for verkle'
    )
    local -a _verkle_subcmds
    _verkle_subcmds=(
      'tree-keys:compute binary trie keys'
      'v:alias for tree-keys'
      'single-key:compute key for address/slot'
      'vk:alias for single-key'
      'code-chunk-key:compute key for address/chunk'
      'vck:alias for code-chunk-key'
      'chunkify-code:process bytecode for binary trie'
      'vcc:alias for chunkify-code'
      'state-root:compute state-root of binary trie'
      'vsr:alias for state-root'
    )
    _arguments -C -s -S \
      '--bench[run benchmark]' \
      '--fuzz[run fuzzing]' \
      '--witness.cross-check[cross-check witness data]' \
      '--dump[dump state after run]' \
      '--human-readable[human-readable output]' \
      '--statdump[dump execution statistics]' \
      '--trace[enable execution tracing]' \
      '--trace.format=[trace output format]:format:' \
      '--trace.nomemory[disable memory tracing]' \
      '--trace.nostack[disable stack tracing]' \
      '--trace.nostorage[disable storage tracing]' \
      '--trace.noreturndata[disable return-data tracing]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'evm subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          verkle|vkt)
            _arguments -C \
              '(-): :->verkle_sub' && ret=0
            case $state in
              verkle_sub)
                _describe -t commands 'evm verkle subcommand' _verkle_subcmds && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;

  fetchpayload)
    # ethereum/go-ethereum fetchpayload — fetch block + execution
    # witness from an Ethereum node via RPC, write combined payload
    # to disk.
    _arguments -s -S \
      '-rpc=[RPC endpoint URL (default http://localhost:8545)]:url:' \
      '-block=[block identifier (decimal, hex, or "latest")]:block:' \
      '-format=[output formats (comma-separated)]:formats:_values -s , "format" rlp hex json' \
      '-out=[output directory]:directory:_directories' \
      && ret=0
    ;;

esac

return ret
