#compdef markdown2pdf
# ============================================================================
# markdown2pdf - Markdown -> PDF transpiler in pure Rust (MIT)
#
# Author : Ismael Sh (theiskaa)
# Upstream: https://github.com/theiskaa/markdown2pdf
# crates : markdown2pdf
#
# markdown2pdf is a self-contained Rust CLI that takes Markdown input
# (file, string, or fetched URL via the `fetch` feature) and emits a
# spec-compliant PDF 1.7 document with a fully-styled rendering of the
# Markdown (headings, paragraphs, code blocks, blockquotes, lists,
# tables, inline code, images). The PDF emission lane is built on
# `printpdf` (fschutt/printpdf, 1000+ stars on github.com/fschutt/printpdf),
# the canonical Rust PDF builder library, plus `lopdf` (J-F-Liu/lopdf)
# for low-level object-graph work.
#
# Declared verbatim at upstream Cargo.toml:
#
#     printpdf = { version = "0.9", default-features = false, features = [
#         "png",
#         "jpeg",
#     ] }
#     lopdf = { version = "0.39", default-features = false }
#
# `printpdf` provides a typed builder API: `PdfDocument::new(title) ->
# PdfDocumentReference`, `add_page()`, then per-page layer APIs to
# add text (`use_text(...)`), shapes, images, fonts. The crate handles
# the PDF cross-reference table, content streams, font subsetting (via
# the `text_layout` feature), and the final `.save()` serialization to
# a writer. `lopdf` is the lower-level building block reading/writing
# the raw PDF object graph - dictionaries, indirect refs, content
# streams - and printpdf builds on it for the high-level surface.
#
# ----------------------------------------------------------------------------
# AXIS 198 :: PDF GENERATION (PDF 1.7 / ISO 32000-1)
# Round 1292 :: Rust slot 1 of 4 :: OPENS Axis 198
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : printpdf + lopdf                  (fschutt + J-F-Liu)
#   Go      : signintech/gopdf                  - PDF building (active fork of jung-kurt/gofpdf)
#   TS/Node : foliojs/pdfkit                    - PDF building, the dominant Node PDF lib
#
# All three are independent reimplementations of the PDF 1.7 (ISO 32000-1)
# document model and serializer. printpdf in Rust is the leading typed
# builder API; gopdf in Go is the modern maintained successor to the
# unmaintained jung-kurt/gofpdf line and ships ttf-font embedding plus
# CJK font support out of the box; pdfkit in Node is the longest-lived
# of the three (since 2012, 10k+ stars on github.com/foliojs/pdfkit),
# powering the entire JavaScript PDF-generation ecosystem - downstream
# wrappers include pdfmake, pdf-lib (for editing), Puppeteer's PDF
# emission lane, and most React/server-side rendering toolchains that
# emit PDFs.
#
# markdown2pdf is the Rust opener - a real downstream consumer
# (not just a "hello, world" PDF) with a working renderer pipeline
# turning the parsed Markdown AST into printpdf draw calls. It supports
# themes (default / github / academic / minimal / compact / modern),
# font subsetting, dimension-aware margins (mm/cm/in/pt), and TOML-driven
# style overrides via `-V KEY=VALUE` flags - exercising the full
# printpdf typed-builder surface rather than the trivial happy path.
# ============================================================================

_markdown2pdf() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-p --path)'{-p,--path}'[path to the markdown file]:markdown file:_files -g "*.(md|markdown)"' \
        '(-s --string)'{-s,--string}'[markdown content as a string]:markdown:' \
        '(-u --url)'{-u,--url}'[URL to fetch markdown content from (requires fetch feature)]:url:' \
        '(-o --output)'{-o,--output}'[output PDF file path (default ./output.pdf)]:pdf file:_files -g "*.pdf"' \
        '--default-font[default font family (e.g., Helvetica, Georgia)]:font name:' \
        '--code-font[font for code blocks (default Courier)]:font name:' \
        '(-v --verbose -q --quiet)'{-v,--verbose}'[detailed output with validation warnings and file size]' \
        '(-v --verbose -q --quiet)'{-q,--quiet}'[suppress all output except errors]' \
        '--dry-run[validate input without generating PDF]' \
        '(-c --config-path)'{-c,--config-path}'[path to markdown2pdf config.toml]:config file:_files -g "*.toml"' \
        '--theme[theme preset]:theme:(default github academic minimal compact modern)' \
        '--print-effective-config[print fully-resolved style as TOML and exit]' \
        '--title[document title (PDF metadata)]:title:' \
        '--author[document author (PDF metadata)]:author:' \
        '--font-size[base body font size (e.g., 11 or 11pt)]:size:' \
        '--margin[uniform page margin (e.g., 25, 25mm, 2.5cm, 1in)]:length:' \
        '--page-size[page size]:size:(A4 Letter Legal A3 A5)' \
        '--orientation[page orientation]:orientation:(portrait landscape)' \
        '--page-numbers[add "page / total" to footer center]' \
        '*'{-V,--var}'[TOML style override KEY=VALUE (dotted TOML schema keys)]:key=value:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]'
}

_markdown2pdf "$@"
