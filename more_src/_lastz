#compdef lastz
# Documentation: https://lastz.github.io/lastz/
# pairwise aligner for DNA sequences

local ret=1

_arguments -s -S \
  '--gfextend[enable gap-free extension of seeds to HSPs]' \
  '--nogfextend[skip gap-free extension stage]' \
  '--chain[perform HSP chaining with no penalties]' \
  '--nochain[skip the chaining stage]' \
  '--gapped[enable gapped extension of HSPs]' \
  '--nogapped[skip gapped extension stage]' \
  '--strand=[search strand]:strand:(both plus minus)' \
  '--step=[offset between successive target words]:offset:' \
  '--seed=[seed pattern]:seed:(12of19 14of22)' \
  '--notransition[disallow transitions in seeds]' \
  '--hspthresh=[HSP score threshold]:score:' \
  '--gappedthresh=[gapped alignment threshold]:score:' \
  '--identity=[filter by percent identity (min..max)]:range:' \
  '--coverage=[filter by sequence coverage (min..max)]:range:' \
  '--ambiguous=[treat Ns as ambiguous nucleotides]:value:(n iupac)' \
  '--format=[output format]:format:(lav axt maf sam general rdotplot text)' \
  '--output=[write alignments to file]:file:_files' \
  '*:sequence file:_files' && ret=0

return ret
