#compdef op-node
# Documentation: https://github.com/ethereum-optimism/optimism/blob/develop/op-node/flags/flags.go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '--network=[Named network preset]:network:' \
  '--l1=[L1 JSON-RPC endpoint]:url:' \
  '--l2=[L2 Engine/rollup endpoint]:url:' \
  '--l2.jwt-secret=[Path to JWT secret for Engine API]:file:_files' \
  '--l2.enginekind=[L2 engine kind]:kind:' \
  '--l2.engine-rpc-timeout=[L2 engine RPC timeout]:duration:' \
  '--l1.beacon=[L1 beacon endpoint]:url:' \
  '--l1.beacon-header=[L1 beacon HTTP header]:header:' \
  '--l1.beacon-fallbacks=[L1 beacon fallback endpoints]:urls:' \
  '--l1.beacon.ignore[ignore L1 beacon for blob retrieval]' \
  '--l1.beacon.fetch-all-sidecars[fetch all sidecars from L1 beacon]' \
  '--l1.trustrpc[trust the L1 RPC]' \
  '--l1.rpckind=[L1 RPC kind]:kind:' \
  '--l1.max-concurrency=[L1 RPC max concurrency]:n:' \
  '--l1.rpc-rate-limit=[L1 RPC rate limit]:rps:' \
  '--l1.rpc-max-batch-size=[L1 RPC max batch size]:n:' \
  '--l1.cache-size=[L1 cache size]:n:' \
  '--l1.http-poll-interval=[L1 HTTP poll interval]:duration:' \
  '--syncmode=[sync mode]:mode:' \
  '--sequencer.enabled[run as sequencer]' \
  '--sequencer.stopped[start sequencer in stopped state]' \
  '--sequencer.max-safe-lag=[sequencer max safe lag]:n:' \
  '--sequencer.l1-confs=[sequencer L1 confirmations]:n:' \
  '--sequencer.sealing-duration=[sequencer sealing duration]:duration:' \
  '--rollup.config=[Rollup configuration JSON]:file:_files' \
  '--rpc.addr=[HTTP server listen address]:addr:' \
  '--rpc.port=[HTTP server listen port]:port:' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '*::arguments: _default'
