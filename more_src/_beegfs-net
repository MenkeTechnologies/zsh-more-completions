#compdef beegfs-net
# Documentation: https://man.archlinux.org/search?q=beegfs-net
# Reference accessed: 2026-05-16

# beegfs-net: BeeGFS network connectivity diagnostics
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--check[check connection]' \
  '*::beegfs-net args:_files' && ret=0
return ret
