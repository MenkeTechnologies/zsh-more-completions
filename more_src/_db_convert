#compdef db_convert
# Documentation: https://man.archlinux.org/search?q=db_convert
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-b[do not display banner]' \
  '-l[list databases]' \
  '-V[print version]' \
  '-v[verbose]' \
  '-m+[message prefix]:prefix:' \
  '-h+[home directory]:dir:_files -/' \
  '-P+[password]:password:' \
  '-S+[verify subdb only]:vo:' \
  '*:database file:_files' && ret=0

return ret
