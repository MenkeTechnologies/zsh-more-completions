#compdef git-cliff

# Zsh completion for git-cliff - changelog generator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'[path to config file]:file:_files' \
  '(-w --workdir)'{-w,--workdir}'[working directory]:dir:_directories' \
  '(-r --repository)'{-r,--repository}'[path to git repository]:dir:_directories' \
  '*--include-path[include commits that modify matching paths]:pattern' \
  '*--exclude-path[exclude commits that modify matching paths]:pattern' \
  '(-t --tag)'{-t,--tag}'[set the tag for the latest version]:tag' \
  '--with-commit[additional commit to include]:commit' \
  '--with-tag-message[use tag message for the latest version]' \
  '(-b --body)'{-b,--body}'[set the template for the changelog body]:template' \
  '--init[create a cliff.toml in the current directory]' \
  '--latest[process only the latest tag]' \
  '--current[process commits from the latest tag to HEAD]' \
  '(-u --unreleased)'{-u,--unreleased}'[process only unreleased commits]' \
  '--topo-order[sort commits in topological order]' \
  '--context[print changelog context as JSON]' \
  '--strip[strip the given part from changelog]:part:(header footer all)' \
  '--sort[sort order for commits]:order:(oldest newest)' \
  '(-o --output)'{-o,--output}'[write output to file]:file:_files' \
  '(-p --prepend)'{-p,--prepend}'[prepend to the given file]:file:_files' \
  '--bump[automatically bump version]' \
  '--bumped-version[print bumped version]' \
  '--date-order[sort tags by date]' \
  '--no-exec[do not execute commands]' \
  '--github-token[set the GitHub API token]:token' \
  '--github-repo[set the GitHub repository]:owner/repo' \
  '--gitlab-token[set the GitLab API token]:token' \
  '--gitlab-repo[set the GitLab repository]:owner/repo' \
  '--gitea-token[set the Gitea API token]:token' \
  '--gitea-repo[set the Gitea repository]:owner/repo' \
  '--bitbucket-token[set the Bitbucket API token]:token' \
  '--bitbucket-repo[set the Bitbucket repository]:owner/repo' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:range' && ret=0

return ret
