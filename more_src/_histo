#compdef histo
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/histo.html
# MIRIAD: image statistics and histogram

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image]:in:_files' \
  'region=[region of interest]:region:' \
  'range=[pixel value interval]:range:' \
  'nbin=[number of histogram bins]:nbin:' \
  '*:image:_files' && ret=0

return ret
