#compdef yambar

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[config file]:config file:_files' \
  '-C[check config and exit]' \
  '-d[log level]:level:(info warning error none)' \
  '-b[run as daemon in the background]' && ret=0

return ret
