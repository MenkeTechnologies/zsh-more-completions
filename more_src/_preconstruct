#compdef preconstruct
# _preconstruct — Monorepo-friendly package build tool for npm
# upstream: https://github.com/preconstruct/preconstruct

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:Initialize preconstruct in a project'
  'build:Build packages for publishing'
  'watch:Watch and rebuild on changes'
  'dev:Create development links for packages'
  'validate:Validate package configuration'
  'fix:Fix common configuration issues'
)

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'preconstruct command' commands && ret=0
    ;;
  args)
    case $words[1] in
      init)
        _arguments -s -S \
          '(- *)--help[show help]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)--help[show help]' && ret=0
        ;;
      dev)
        _arguments -s -S \
          '(- *)--help[show help]' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '(- *)--help[show help]' && ret=0
        ;;
      fix)
        _arguments -s -S \
          '(- *)--help[show help]' && ret=0
        ;;
      watch)
        _arguments -s -S \
          '(- *)--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
