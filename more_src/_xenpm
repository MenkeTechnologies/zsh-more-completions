#compdef xenpm
# Documentation: https://github.com/xen-project/xen/blob/master/tools/misc/xenpm.c
# Reference accessed: 2026-05-21
# Verified: upstream xenpm.c show_help() in xen-project/xen master.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'get-cpuidle-states:list CPU idle info'
  'get-cpufreq-states:list CPU freq info'
  'get-cpufreq-average:average CPU frequency since last invocation'
  'get-cpufreq-para:list cpufreq parameters'
  'set-scaling-maxfreq:set max CPU frequency'
  'set-scaling-minfreq:set min CPU frequency'
  'set-scaling-speed:set scaling speed (userspace governor)'
  'set-scaling-governor:set scaling governor'
  'set-sampling-rate:set sampling rate (ondemand governor)'
  'set-up-threshold:set up threshold (ondemand governor)'
  'get-cpu-topology:get thread/core/socket topology'
  'set-sched-smt:enable/disable scheduler SMT power saving'
  'set-vcpu-migration-delay:set scheduler vcpu migration delay in us'
  'get-vcpu-migration-delay:get scheduler vcpu migration delay'
  'set-max-cstate:set C-State limitation'
  'set-cpufreq-cppc:set Hardware P-State (HWP) parameters'
  'get-core-temp:get CPU temperature (Intel only)'
  'start:start collecting Cx/Px statistics'
  'enable-turbo-mode:enable Turbo Mode'
  'disable-turbo-mode:disable Turbo Mode'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'xenpm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (set-scaling-governor)
        _values 'governor' userspace performance powersave ondemand && ret=0 ;;
      (set-sched-smt)
        _values 'smt' enable disable && ret=0 ;;
      (set-cpufreq-cppc)
        _values 'preset' balance performance powersave && ret=0 ;;
      (set-scaling-*|set-max-cstate|set-up-threshold|set-sampling-rate|set-vcpu-migration-delay)
        _message 'value' && ret=0 ;;
    esac ;;
esac

return ret
