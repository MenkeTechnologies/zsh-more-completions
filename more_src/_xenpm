#compdef xenpm

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'get-cpufreq-para:get cpufreq parameters'
  'set-scaling-maxfreq:set scaling max freq'
  'set-scaling-minfreq:set scaling min freq'
  'set-scaling-governor:set scaling governor'
  'set-scaling-speed:set scaling speed (userspace)'
  'set-sampling-rate:set sampling rate'
  'set-up-threshold:set up threshold (ondemand)'
  'get-cpu-topology:get cpu topology'
  'set-vcpu-migration-delay:set vcpu migration delay'
  'get-vcpu-migration-delay:get vcpu migration delay'
  'set-max-cstate:set max cstate'
  'set-cpufreq-hwp:configure HWP'
  'start:start collecting Cx/Px statistics'
  'enable-turbo-mode:enable turbo mode'
  'disable-turbo-mode:disable turbo mode'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'xenpm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (set-scaling-governor)
        _values 'governor' performance powersave userspace ondemand conservative schedutil && ret=0 ;;
      (set-scaling-*|set-max-cstate|set-up-threshold|set-sampling-rate|set-vcpu-migration-delay)
        _message 'value' && ret=0 ;;
    esac ;;
esac

return ret
