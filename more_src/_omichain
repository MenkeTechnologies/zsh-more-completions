#compdef omichain
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/omichain/node13.html
# Reduce OM IMAGING mode data (Optical Monitor imaging chain)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--outdirectory=[path/name of the output files directory]:dir:_files -/' \
  '--comment=[user comment to output]:comment' \
  '--filters=[list of OM filters to be processed]:filters' \
  '--exposures=[list of OM exposures to be processed]:exposures' \
  '--ommodmapnbox=[sliding box size in units of 8 pixels for ommodmap]:n' \
  '--ommodmapnsig=[significance level for sigma clipping in ommodmap]:value' \
  '--omdetectnsigma=[sigma above background for pixel source detection]:value' \
  '--omdetectdetectextended=[run extended-source detection]:bool:(yes no)' \
  '--omdetectminsignificance=[min source significance for source-list]:value' \
  '--usecat=[use USNO-SA 1 catalog to correct star positions]:bool:(yes no)' \
  '--catfile=[name of usno-catalogue fits file]:file:_files' \
  '--omattrotateimage=[create the rotated sky-image]:bool:(yes no)' \
  '--omsrclistcombnsigma=[sigma above which two sources are different]:value' \
  '--omsrclistcombusecat=[use USNO-SA 1 catalog in source list combination]:bool:(yes no)' \
  '--omsrclistcombalignaxes=[align all images to a common RA/DEC origin]:bool:(yes no)' \
  '--maxradecerr=[maximum allowed RA/dec error in astrometry fit]:value' \
  '--maxrmsres=[maximum allowed rms residual in astrometry fit]:value' \
  '--processmosaicedimages=[process the mosaiced sky-images]:bool:(yes no)' \
  '--ommergelistsregionfile=[region file name for ommergelists]:file:_files' \
  '--ommergelistsplotfile=[file name for ommergelists plot file]:file:_files' \
  '--ommergeliststolerance=[tolerance in arcsecs for source-matching]:value' \
  '--psfphotometryenabled=[enable PSF-photometry for close neighbours]:bool:(yes no)' \
  '--backgroundmethod=[point-source background method for omdetect]:method' \
  '--maxrawcountrate=[count-rate threshold limiting PSF-photometry]:value' \
  '--rawattitude=[usage of attitude data by omprep task]:value' \
  '*:param=value:_default' && ret=0

return ret
