#compdef aql
# ArangoDB shell query language client

local ret=1

_arguments -s -S \
  '--server.endpoint=[server endpoint]:endpoint:' \
  '--server.username=[username]:username:' \
  '--server.password=[password]:password:' \
  '--server.database=[database name]:database:' \
  '--server.authentication=[enable authentication]:boolean:(true false)' \
  '--console.colors=[enable colors]:boolean:(true false)' \
  '--console.pretty-print=[pretty print output]:boolean:(true false)' \
  '--console.pager=[enable pager]:boolean:(true false)' \
  '--console.auto-complete=[enable auto-complete]:boolean:(true false)' \
  '--javascript.execute=[execute JavaScript file]:file:_files -g "*.js"' \
  '--quiet[quiet mode]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
