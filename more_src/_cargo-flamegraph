#compdef cargo-flamegraph flamegraph
# Documentation: https://github.com/flamegraph-rs/flamegraph
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_cargo-flamegraph() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s -S \
        '--bench[profile a specific bench target]:bench:' \
        {-b,--bin}'[profile a specific binary]:binary:' \
        '--dev[compile using dev profile]' \
        '--deterministic[consistent function colors across runs]' \
        '--example[profile a specific example]:example:' \
        '--flamechart[produce a flamechart (time-ordered)]' \
        {-F,--freq}'[sampling frequency in Hz (default 997)]:frequency:' \
        {-c,--cmd}'[custom perf/dtrace command]:command:' \
        '--image-width[width of the generated image in pixels]:width:' \
        {-i,--inverted}'[upside-down flame graph]' \
        '--min-width[hide functions smaller than value (default 0.01)]:width:' \
        '--no-inline[disable function inlining]' \
        '--no-default-features[disable default features]' \
        '--notes[embed SVG notes]:notes:' \
        '--open[launch SVG in default program]' \
        {-o,--output}'[output filename (default flamegraph.svg)]:file:_files -g "*.svg"' \
        {-p,--package}'[package to profile]:package:' \
        '--palette[color palette]:palette:(hot mem io red green blue aqua yellow purple orange wakeup java perl js rust)' \
        '--pid[profile a running process by PID]:pid:' \
        '--post-process[custom stack-processing command]:command:' \
        {-r,--release}'[compatibility flag (no-op, release is default)]' \
        '--profile[use specified build profile]:profile:' \
        '--reverse[stack-reversed output]' \
        '--root[execute with sudo]' \
        '--ignore-status[ignore perf exit code]' \
        '*--skip-after[truncate stacks below function (repeatable)]:function:' \
        '--test[profile a specific test target]:test:' \
        '--unit-test=-[profile unit tests of the crate]::name:' \
        {-v,--verbose}'[extended debugging output]' \
        {-f,--features}'[enable build features]:features:' \
        '--manifest-path[path to Cargo.toml]:path:_files -g "*.toml"' \
        '--target[target triple]:target:' \
        '--target-dir[directory for build artifacts]:dir:_directories' \
        {-h,--help}'[print help]' \
        {-V,--version}'[print version]' \
        '*:binary arguments:' && ret=0

    return ret
}

_cargo-flamegraph "$@"
