#compdef cargo-flamegraph flamegraph

_cargo-flamegraph() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s -S \
        '--bench[Profile a specific bench target]:bench:' \
        '--bin[Profile a specific binary]:binary:' \
        '--completions[Generate shell completions]:shell:(bash zsh fish elvish powershell)' \
        '--dev[Build in dev mode (without optimizations)]' \
        '--deterministic[Generate deterministic output]' \
        '--example[Profile a specific example]:example:' \
        '--flamechart[Produce a flamechart (time-ordered)]' \
        '--freq[Sampling frequency in Hz]:frequency:' \
        '--image-width[Width of the generated image in pixels]:width:' \
        '--inverted[Produce an inverted (icicle) flamegraph]' \
        '--min-width[Minimum width of a frame in pixels]:width:' \
        '--no-inline[Disable inlining for better stack traces]' \
        '--no-default-features[Do not activate default features]' \
        '--notes[Set embedded notes in SVG]:notes:' \
        '--open[Open the flamegraph in the default viewer]' \
        {-o,--output}'[Output file]:file:_files -g "*.svg"' \
        {-p,--package}'[Package to profile]:package:' \
        '--palette[Color palette to use]:palette:(hot mem io red green blue aqua yellow purple orange wakeup java perl js rust)' \
        '--pid[Profile a running process by PID]:pid:' \
        '--post-process[Command to run on perf output before generating flamegraph]:command:' \
        '--release[Build in release mode (with optimizations)]' \
        '--reverse[Generate a reversed stack flamegraph]' \
        '--root[Run profiling command as root]' \
        '--sample-size[Number of samples to collect]:samples:' \
        '--skip-after[Cut off stacks below the specified function]:function:' \
        '--test[Profile a specific test target]:test:' \
        '--timestamp[Include timestamp in the filename]' \
        '--unit-test[Profile unit tests of the crate]' \
        {-v,--verbose}'[Print extra output to help debug problems]' \
        '--features[Comma-separated list of features to activate]:features:' \
        '--manifest-path[Path to Cargo.toml]:path:_files -g "*.toml"' \
        '--target[Target triple for which the code is compiled]:target:' \
        '--target-dir[Directory for build artifacts]:dir:_directories' \
        {-h,--help}'[Print help information]' \
        {-V,--version}'[Print version information]' \
        '*:binary arguments:' && ret=0

    return ret
}

_cargo-flamegraph "$@"
