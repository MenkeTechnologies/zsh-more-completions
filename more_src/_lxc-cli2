#compdef lxc-cli2 lxc2
# _lxc-cli2 — Canonical LXD lxc-cli2 CLI command-line frontend wrapping the LXC LXD next generation system container manager based on the LXC project but uses libxlc through liblxc and provides a REST API to manage containers VMs from a host or remotely open-source written in Go originally Canonical now Linux Containers project launch start stop restart pause delete copy move publish image config exec snapshot list info show network storage profile project cluster operation file shell init alias config-trust remote import export warning monitor query operation alias version (Canonical Linux Containers LXD team Stéphane Graber, Go); cobra
# upstream: https://linuxcontainers.org/

_lxc-cli2() {
    local -a sub=(
        'alias:CLI alias operations'
        'auth:auth operations'
        'cluster:cluster operations'
        'config:config operations'
        'console:open console'
        'copy:copy instance'
        'create:create instance'
        'delete:delete instance'
        'exec:exec a command'
        'export:export an instance'
        'file:file operations'
        'help:show help'
        'image:image operations'
        'import:import an instance'
        'info:show instance info'
        'init:initialize an instance'
        'launch:launch a new instance'
        'list:list instances'
        'monitor:monitor events'
        'move:move an instance'
        'network:network operations'
        'operation:operation ops'
        'pause:pause an instance'
        'profile:profile operations'
        'project:project operations'
        'publish:publish as image'
        'query:run a raw API query'
        'rebuild:rebuild instance'
        'remote:remote operations'
        'rename:rename an instance'
        'restart:restart an instance'
        'restore:restore from snapshot'
        'shell:open shell on instance'
        'snapshot:snapshot operations'
        'start:start an instance'
        'stop:stop an instance'
        'storage:storage operations'
        'version:show version'
        'warning:warning operations'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--all-projects[all projects]' \
        '-c+[columns]:str:' \
        '--columns=+[cols]:str:' \
        '-f+[format]:f:(csv json table yaml compact markdown)' \
        '--format=+[fmt]:f:(csv json table yaml compact markdown)' \
        '--force[force]' \
        '--force-color[force color]' \
        '--no-color[no color]' \
        '--vm[VM mode]' \
        '--type=+[t]:t:(container virtual-machine)' \
        '--ephemeral[ephemeral]' \
        '-e[ephemeral]' \
        '--config=+[k=v]:str:' \
        '*--config=+[k=v]:str:' \
        '-c+[config]:str:' \
        '--device=+[name,k=v]:str:' \
        '*--device=+[name,k=v]:str:' \
        '-d+[device]:str:' \
        '--profile=+[name]:str:' \
        '*--profile=+[name]:str:' \
        '-p+[profile]:str:' \
        '--no-profiles[no profiles]' \
        '--empty[empty instance]' \
        '--instance-only[instance only]' \
        '--mode=+[m]:m:(pull push relay)' \
        '--refresh[refresh image]' \
        '--target=+[name]:str:' \
        '--allow-inconsistent[allow inconsistent]' \
        '--no-image[no image]' \
        '--alias=+[name]:str:' \
        '*--alias=+[name]:str:' \
        '--public[public image]' \
        '--expire=+[d]:str:' \
        '--reuse[reuse]' \
        '--accept-server-certificate[accept server cert]' \
        '--password=+[password]:str:' \
        '--public-key=+[file]:file:_files -g "*.pub *.pem *.crt"' \
        '--no-recursive[no recursive]' \
        '--recursive[recursive]' \
        '-r[recursive]' \
        '--reuse[reuse]' \
        '--mode=+[mode]:str:' \
        '--target-project=+[name]:str:' \
        '--lines=+[N]:n:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--description=+[text]:str:' \
        '--rate-limit=+[N]:n:' \
        '-i[interactive shell]' \
        '-t[force interactive]' \
        '-T[force non-interactive]' \
        '--env=+[k=v]:str:' \
        '*--env=+[k=v]:str:' \
        '--cwd=+[dir]:str:' \
        '--user=+[uid]:n:' \
        '--group=+[gid]:n:' \
        '--disable-stdin[disable stdin]' \
        '--no-confirm[no confirm]' \
        '--no-snapshots[no snapshots]' \
        '--stateful[stateful snapshot]' \
        '--reuse[reuse]' \
        '--restore-snapshot[restore snapshot]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lxc subcommand' sub ;;
        args)
            case $words[1] in
                launch|init|start|stop|restart|pause|delete|exec|info|console|shell|file|copy|move|rename|publish|snapshot|export|import|restore) _arguments '*:instance:' ;;
                image|network|storage|profile|project|cluster|remote|config|alias) _arguments '1:op:(list get set create delete edit show copy import export move rename trust trust-add)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_lxc-cli2 "$@"
