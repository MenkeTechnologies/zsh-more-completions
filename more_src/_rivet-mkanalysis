#compdef rivet-mkanalysis
# Documentation: https://rivet.hepforge.org/
# rivet-mkanalysis - create a template Rivet analysis source tree

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--srcroot[install the templates into the Rivet source tree rooted at DIR]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[only write out warning and error messages]' \
  '(-v --verbose)'{-v,--verbose}'[provide extra debugging messages]' \
  '(-i --inline-info)'{-i,--inline-info}'[put analysis info into source file instead of separate data file]' \
  '*:analysis name:' && ret=0

return ret
