#compdef kraken2 kraken2-build
# Documentation: https://github.com/DerrickWood/kraken2
# Reference accessed: 2026-05-27
# Verified: upstream DerrickWood/kraken2 scripts/kraken2 and scripts/kraken2-build GetOptions blocks.

# Zsh completion for kraken2 (classifier) and kraken2-build (database builder).

local curcontext="$curcontext" ret=1

case $service in
  kraken2)
    _arguments -s \
      '--help[display usage information]' \
      '--version[print version]' \
      '--db=[Kraken 2 database name]:db:_files -/' \
      '--threads=[number of threads]:int:' \
      '--quick[use quick operation (first hit)]' \
      '--unclassified-out=[write unclassified reads to file]:file:_files' \
      '--classified-out=[write classified reads to file]:file:_files' \
      '--output=[output file (default stdout)]:file:_files' \
      '--confidence=[classification confidence threshold (0..1)]:float:' \
      '--memory-mapping[memory map database instead of loading into RAM]' \
      '--paired[paired-end input mode]' \
      '--use-names[print taxon names with IDs]' \
      '--gzip-compressed[input is gzip compressed]' \
      '--bzip2-compressed[input is bzip2 compressed]' \
      '--only-classified-output[suppress unclassified read output]' \
      '--minimum-base-quality=[base quality threshold for FASTQ]:int:' \
      '--report=[write classification report to file]:file:_files' \
      '--use-mpa-style[Kraken 1 mpa-report style format]' \
      '--report-zero-counts[include zero-count taxa in report]' \
      '--minimum-hit-groups=[minimum overlapping k-mer groups required]:int:' \
      '--report-minimizer-data[append distinct-minimizer counts to report]' \
      '*:fastq/fasta:_files' && ret=0
    ;;
  kraken2-build)
    _arguments -s \
      '--help[display usage information]' \
      '--version[print version]' \
      '--db=[database name]:db:_files -/' \
      '--threads=[number of threads]:int:' \
      '--kmer-len=[k-mer length]:int:' \
      '--minimizer-len=[minimizer length]:int:' \
      '--minimizer-spaces=[masked positions in minimizer]:int:' \
      '--protein[build protein database (translated search)]' \
      '--masking[enable low-complexity masking]' \
      '--no-masking[disable low-complexity masking]' \
      '--max-db-size=[hash table size limit in bytes]:int:' \
      '--use-ftp[use FTP instead of rsync for downloads]' \
      '--skip-maps[skip accession-to-taxid map downloads]' \
      '--load-factor=[hash table load factor]:float:' \
      '--fast-build[non-deterministic faster multi-threaded build]' \
      '--block-size=[hash table block size]:int:' \
      '--subblock-size=[hash table subblock size]:int:' \
      '--minimum-bits-for-taxid=[bits per taxid in hash table]:int:' \
      '--download-taxonomy[fetch NCBI taxonomy data]' \
      '--download-library=[download reference library]:type:(archaea bacteria plasmid viral human fungi plant protozoa nr nt UniVec UniVec_Core)' \
      '--add-to-library=[add sequence file to library]:file:_files' \
      '--build[build database from existing library]' \
      '--standard[build standard kraken2 database]' \
      '--clean[remove intermediate build files]' \
      '--special=[build special database]:type:(greengenes silva rdp)' && ret=0
    ;;
esac

return ret
