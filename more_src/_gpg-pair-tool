#compdef gpg-pair-tool
# Documentation: https://www.gnupg.org/documentation/manuals/gnupg/
# GnuPG: client to run the pairing protocol

local ret=1

_arguments -s -S \
  '--initiate[initiate a pairing request]' \
  '--respond[respond to a pairing request]' \
  '--get[return the keys]' \
  '--cleanup[remove expired states etc]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[be somewhat more quiet]' \
  '(-a --armor)'{-a,--armor}'[create ascii armored output]' \
  '--sas=[the SAS as shown by the peer]:sas' \
  '(-o --output)'{-o,--output}'=[write the request to FILE]:file:_files' \
  '--status-fd=[write status info to this FD]:fd' \
  '--version[print version information]' \
  '--help[show help]' \
  '*:arg:_default' && ret=0

return ret
