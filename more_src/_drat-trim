#compdef drat-trim
# Documentation: https://www.mankier.com/1/drat-trim
# DRAT proof checker for DIMACS proofs

local ret=1

_arguments -s -S \
  '-h[print command line option summary]' \
  '-c+[print unsatisfiable core to file (DIMACS format)]:core file:_files' \
  '-a+[print active clauses to file (DIMACS format)]:active file:_files' \
  '-l+[print core lemmas to file (DRAT format)]:lemmas file:_files' \
  '-L+[print core lemmas to file (LRAT format)]:lemmas file:_files' \
  '-r+[resolution graph to file (TRACECHECK format)]:trace file:_files' \
  '-t+[time limit in seconds (default 40000)]:limit:' \
  '-u[default unit propagation (no core-first)]' \
  '-f[forward mode for UNSAT]' \
  '-v[more verbose output]' \
  '-q[suppress all output]' \
  '-b[show progress bar]' \
  '-O[optimize proof till fixpoint by repeating verification]' \
  '-C[compress core lemmas (emit binary proof)]' \
  '-D[delete proof file after parsing]' \
  '-I[force ASCII proof parse mode]' \
  '-i[force binary proof parse mode]' \
  '-w[suppress warning messages]' \
  '-W[exit after first warning]' \
  '-p[run in plain mode (ignore deletion information)]' \
  '-R[turn off reduce mode]' \
  '-S[run in SAT check mode (forward checking)]' \
  '-U[only allow RUP additions]' \
  '1:input (DIMACS CNF):_files' \
  '2:proof (DRAT):_files' && ret=0

return ret
