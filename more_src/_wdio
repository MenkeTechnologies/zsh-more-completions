#compdef wdio
# Documentation: https://github.com/webdriverio/webdriverio/blob/main/packages/wdio-cli/src/commands/run.ts
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'config:interactive config helper'
  'run:run tests'
  'install:add reporter/service/framework/runner/plugin'
  'repl:interactive WebDriver REPL'
)

_arguments -C \
  '(- *)--version[show version]' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'wdio subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (config)
        _arguments \
          '--help[show help]' \
          '--yes[accept defaults (Mocha+Chrome+PageObject)]' \
          '--npm[force npm install]' \
          '--yarn[force yarn install]' \
          '--useTypeScript[use TypeScript]' && ret=0
        ;;
      (install)
        _arguments \
          '--help[show help]' \
          '--yarn[use yarn instead of npm]' \
          '--config=[WDIO config path]:file:_files' \
          ':type:(reporter service framework runner plugin)' \
          ':name:' && ret=0
        ;;
      (run)
        _arguments \
          '--help[show help]' \
          '--watch[run in watch mode]' \
          '(-h --hostname)'{-h,--hostname=}'[driver hostname]:host:_hosts' \
          '(-p --port)'{-p,--port=}'[driver port]:port:' \
          '--path=[WebDriver endpoint path]:path:' \
          '(-u --user)'{-u,--user=}'[cloud user]:user:' \
          '(-k --key)'{-k,--key=}'[cloud access key]:key:' \
          '(-l --logLevel)'{-l,--logLevel=}'[log level]:level:(trace debug info warn error silent)' \
          '--bail=[bail after N failures]:n:' \
          '--baseUrl=[base URL]:url:' \
          '(-w --waitforTimeout)'{-w,--waitforTimeout=}'[wait timeout ms]:ms:' \
          '(-s --updateSnapshots)'{-s,--updateSnapshots=}'[update snapshots]:mode:(new all none)' \
          '(-f --framework)'{-f,--framework=}'[test framework]:framework:(mocha jasmine cucumber)' \
          '*'{-r,--reporters=}'[reporter]:reporter:' \
          '*--suite=[run suite]:suite:' \
          '*--spec=[spec file]:file:_files' \
          '*--exclude=[exclude file]:file:_files' \
          '--repeat=[repeat specs N times]:n:' \
          '--coverage[enable coverage for browser runner]' \
          '--shard=[shard x/y]:shard:' \
          ':config:_files -g "*.(js|ts|mjs|cjs)"' && ret=0
        ;;
      (repl)
        _arguments \
          '(-p --port)'{-p,--port=}'[driver port]:port:' \
          ':browser:(chrome firefox safari edge)' && ret=0
        ;;
    esac
    ;;
esac

return ret
