#compdef oidc-keychain
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/oidc-keychain.1.html
# oidc-keychain - re-use oidc-agent across logins

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[give this help list]' \
  '--usage[give a short usage message]' \
  '(-V --version)'{-V,--version}'[print program version]' \
  '(-k --kill)'{-k,--kill}'[kill oidc-agent if it is running]' \
  '--accounts[load the given accounts if not already loaded]' \
  '*:account shortname:' && ret=0

return ret
