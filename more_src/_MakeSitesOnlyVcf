#compdef MakeSitesOnlyVcf
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/vcf/MakeSitesOnlyVcf.java
# Picard: write a VCF stripped of genotype (sample-level) information

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input VCF/BCF with genotypes]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[site-only output VCF/BCF]:file:_files' \
  '*'{-S,--SAMPLE}'=[sample(s) to include in output]:sample:' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
