#compdef sysdig

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)--version[show version]'
  '-A[show unprintable characters as hex]'
  {-b,--print-base64}'[print data in base64]'
  {-B,--buffer-size}'=[set capture buffer size in bytes]:bytes:'
  '-c[run chisel]:chisel:'
  '-C[file size in MB for file rotation]:size:'
  {-cl,--list-chisels}'[list available chisels]'
  {-d,--displayfilt}'=[set display filter]:filter:'
  {-D,--debug}'[turn on debug logging]'
  {-E,--exclude-users}'[exclude events from user processes]'
  '-e[capture N events and exit]:num:'
  {-F,--fatfile}'[enable fat file mode]'
  '-G[number of seconds for file rotation]:seconds:'
  {-H,--help-chisel}'=[show help for a chisel]:chisel:'
  {-i,--chisel-info}'=[show info for a chisel]:chisel:'
  {-j,--json}'[output in JSON format]'
  {-k,--kube-api-server}'=[Kubernetes API server URL]:url:'
  {-K,--kube-config}'=[Kubernetes config file]:file:_files'
  {-l,--list}'[list available fields]'
  {-L,--list-events}'[list available event types]'
  '-M[stop capturing after N seconds]:seconds:'
  {-N,--no-summary}'[do not print the summary at exit]'
  '-n[stop capturing after N events]:events:'
  {-p,--print}'=[output format]:format:'
  {-P,--progress}'[print progress]'
  {-pc,--print-container}'[print container info for each event]'
  {-pk,--print-kubernetes}'[print Kubernetes info for each event]'
  {-q,--quiet}'[quiet mode]'
  '-r[read events from file]:file:_files'
  {-R,--resolve-ports}'[resolve port numbers]'
  {-s,--snaplen}'=[capture snapshot length in bytes]:bytes:'
  {-S,--summary}'[print event summary at exit]'
  {-t,--timetype}'=[time format]:type:(h a r d D)'
  {-T,--force-tracers-capture}'[force tracers capture]'
  {-U,--suppress}'[suppress events]'
  {-v,--verbose}'[verbose output]'
  '-w[write events to file]:file:_files'
  {-x,--print-hex}'[print data in hex]'
  {-X,--print-hex-ascii}'[print data in hex and ASCII]'
  {-z,--compress}'[compress capture files]'
  '--cri=[CRI socket path]:socket:_files'
  '--unbuffered[disable buffering on output]'
  '--logfile=[log file path]:file:_files'
  '--filter=[event filter expression]:expression:'
  '*:filter expression:'
)

_arguments -s -S $arguments
