#compdef actionlint

# Zsh completion for actionlint - GitHub Actions workflow linter

_arguments -s -S \
  '-color[enable colorful output]' \
  '-no-color[disable colorful output]' \
  '-format=[set output format]:format:' \
  '-oneline[use one line per error]' \
  '-shellcheck=[path to shellcheck binary]:path:_files' \
  '-pyflakes=[path to pyflakes binary]:path:_files' \
  '-ignore=[pattern to ignore]:regex pattern:' \
  '-config-file=[path to config file]:config file:_files -g "*.{yaml,yml}"' \
  '-stdin-filename=[filename for stdin]:filename:' \
  '-verbose[enable verbose output]' \
  '-debug[enable debug output]' \
  '-version[show version]' \
  '(-h -help)'{-h,-help}'[show help]' \
  '*:workflow files:_files -g "*.{yaml,yml}"'
