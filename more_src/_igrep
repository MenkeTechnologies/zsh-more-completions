#compdef igrep

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--hidden[search hidden files and directories]' \
  '--no-ignore[do not respect ignore files]' \
  '*--type=[only search files matching type]:file type' \
  '*--type-not=[do not search files matching type]:file type' \
  '--type-list[list supported file types]' \
  '*--glob=[include or exclude files matching glob]:glob pattern' \
  '*--iglob=[like --glob but case insensitive]:glob pattern' \
  '(-i --ignore-case -S --smart-case)'{-S,--smart-case}'[smart case matching]' \
  '(-i --ignore-case -s --case-sensitive)'{-s,--case-sensitive}'[case sensitive matching]' \
  '(-s --case-sensitive -S --smart-case)'{-i,--ignore-case}'[case insensitive matching]' \
  {-w,--word-regexp}'[only show matches surrounded by word boundaries]' \
  {-F,--fixed-strings}'[treat pattern as a literal string]' \
  {-U,--multiline}'[enable multiline matching]' \
  {-C,--context}'[show NUM lines before and after each match]:lines' \
  {-m,--max-count}'[limit number of matches per file]:count' \
  '--max-depth=[limit directory traversal depth]:depth' \
  {-L,--follow}'[follow symbolic links]' \
  '--no-config[do not read configuration files]' \
  '--no-pcre2[do not use PCRE2 regex engine]' \
  '--pcre2[use PCRE2 regex engine]' \
  '--theme=[set color theme]:theme' \
  {-E,--encoding}'[specify file encoding]:encoding' \
  '--regex-size-limit=[upper size limit for compiled regex]:limit' \
  '--dfa-size-limit=[upper size limit for DFA]:limit' \
  '1:pattern:' \
  '*:path:_files' && ret=0

return ret
