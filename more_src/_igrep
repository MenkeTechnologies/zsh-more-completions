#compdef igrep ig
# Documentation: https://github.com/konradsz/igrep
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Zsh completion for igrep / ig - Interactive Grep TUI (konradsz/igrep)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help information]' \
  '(- *)'{-V,--version}'[print version information]' \
  '(-. --hidden)'{-.,--hidden}'[search hidden files and directories]' \
  '--editor=[text editor used to open selected match]:editor:' \
  '--context-viewer=[context viewer position at startup]:viewer:(none vertical horizontal)' \
  '--custom-command=[custom command with {file_name} and {line_number} tokens]:command:' \
  '*'{-g,--glob}'=[include files matching glob]:glob:' \
  '(-i --ignore-case)'{-i,--ignore-case}'[searches case insensitively]' \
  '(-L --follow)'{-L,--follow}'[follow symbolic links while traversing directories]' \
  '(-S --smart-case)'{-S,--smart-case}'[searches case insensitively if pattern is all lowercase]' \
  '*'{-t,--type}'=[only search files matching TYPE]:type:' \
  '*'{-T,--type-not}'=[do not search files matching TYPE]:type:' \
  '--theme=[UI color theme]:theme:(light dark)' \
  '--type-list[show all supported file types and their globs]' \
  '(-w --word-regexp)'{-w,--word-regexp}'[only show matches surrounded by word boundaries]' \
  '(-F --fixed-strings)'{-F,--fixed-strings}'[exact matches with no regex]' \
  '--sort=[sort results by]:by:(path modified accessed created)' \
  '--sortr=[sort results reverse by]:by:(path modified accessed created)' \
  '1:pattern:' \
  '*:path:_files' && ret=0

return ret
