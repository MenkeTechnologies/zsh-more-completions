#compdef nvidia-vbiosflash

# nvidia-vbiosflash: NVIDIA video BIOS flash utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-?[show help]' \
  '-r[read VBIOS to file]:file:_files' \
  '-w[write VBIOS from file]:file:_files' \
  '-v[verify VBIOS]:file:_files' \
  '-i[show adapter info]' \
  '--list[list adapters]' \
  '--device=[target device index]:n:' \
  '--force[force flash (bypass safety)]' \
  '*:VBIOS file:_files -g "*.rom"' && ret=0
return ret
