#compdef nvidia-vbiosflash
# Documentation: https://man.archlinux.org/search?q=nvidia-vbiosflash
# Reference accessed: 2026-05-16

# nvidia-vbiosflash: NVIDIA video BIOS flash utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-l[list adapters]' \
  '-i[display info]:adapter:' \
  '-b[backup VBIOS]:adapter file:' \
  '-r[read VBIOS]:adapter file:' \
  '-w[write VBIOS]:adapter file:' \
  '-p[program VBIOS]:adapter file:' \
  '-f[force]' \
  '-x[expert mode]' \
  '*::nvidia-vbiosflash args:_files' && ret=0
return ret
