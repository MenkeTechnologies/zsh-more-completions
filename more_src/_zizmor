#compdef zizmor
# Documentation: https://man.archlinux.org/search?q=zizmor
# Reference accessed: 2026-05-16

# Zsh completion for zizmor (zizmorcore/zizmor). Flags traced to crates/zizmor/src/main.rs.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help (more with --help)]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--collect=[input kinds, comma-separated]:mode:(all default workflows actions dependabot)' \
  '--strict-collection[fail on collect errors]' \
  '--fix=[auto-fix mode]:mode:(safe unsafe-only all)' \
  '--pedantic[alias for persona=pedantic]' \
  '--persona=[audit persona]:persona:(auditor pedantic regular)' \
  '--min-severity=[minimum severity]:level:(informational low medium high)' \
  '--min-confidence=[minimum confidence]:level:(low medium high)' \
  '--no-ignores[ignore ignore comments and rules]' \
  '--format=[output format]:format:(plain json json-v1 sarif github)' \
  '--no-progress[disable progress bars]' \
  '--color=[color output]:when:(auto always never)' \
  '--render-links=[OSC 8 hyperlinks]:when:(auto always never)' \
  '--show-audit-urls=[print audit URLs]:when:(auto always never)' \
  '--no-exit-codes[only success or tool failure exit codes]' \
  '--offline[disable network entirely]' \
  '--no-online-audits[disable audits that need network]' \
  '--gh-token=[GitHub API token]:token:' \
  '--github-token=[alias for gh-token]:token:' \
  '--zizmor-github-token=[alias for gh-token]:token:' \
  '--gh-hostname=[GitHub hostname]:host:' \
  '--cache-dir=[HTTP cache directory]:dir:_directories' \
  '(-c --config)'{-c,--config=}'[zizmor config file]:file:_files' \
  '--no-config[skip configuration files]' \
  '--completions=[print shell completions]:shell:(bash elvish fish nushell powershell zsh)' \
  '--thanks[print sponsor thanks]' \
  '--lsp[language server mode]' \
  '--stdio[VS Code LSP stub flag]' \
  '*:INPUT path repo slug or - for stdin:'
