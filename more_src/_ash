#compdef ash dash
# _ash — Almquist Shell (ash + dash, /bin/sh-compatible POSIX shell; -c run command string, -i interactive, -s read commands from stdin, -l login shell, -e exit on error, -x xtrace, -n no exec, -u unset is error, -v print input, -f no globbing, -a auto-export, -m job control)
# upstream: git://git.kernel.org/pub/scm/utils/dash/dash.git
# Flags from dash src/main.c on tip.

_ash() {
    _arguments \
        '--help[show help]' \
        '-c+[run command]:command:' \
        '-i[interactive]' \
        '-l[login shell]' \
        '-s[stdin]' \
        '-e[exit on error]' \
        '-x[xtrace]' \
        '-n[no exec]' \
        '-u[unset is error]' \
        '-v[print input lines]' \
        '-f[no globbing]' \
        '-a[auto-export modified]' \
        '-m[job control]' \
        '-h[hash commands]' \
        '-b[notify on bg job exit]' \
        '-C[no clobber]' \
        '*-o+[long option]:option:(allexport errexit ignoreeof monitor noclobber noexec noglob nolog notify nounset verbose vi xtrace pipefail)' \
        '*:script:_files'
}

_ash "$@"
