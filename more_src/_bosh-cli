#compdef bosh-cli
# Documentation: https://bosh.io/docs/cli-v2/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cloudfoundry/bosh-cli cmd/opts/opts.go — BoshOpts + go-flags commands
# https://github.com/cloudfoundry/bosh-cli

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'add-blob:add-blob'
  'alias-env:alias-env'
  'attach-disk:attach-disk'
  'blobs:blobs'
  'cancel-task:cancel-task'
  'cancel-tasks:cancel-tasks'
  'clean-up:clean-up'
  'cloud-check:cloud-check'
  'cloud-config:cloud-config'
  'completion:completion'
  'config:config'
  'configs:configs'
  'cpi-config:cpi-config'
  'create-env:create-env'
  'create-recovery-plan:create-recovery-plan'
  'create-release:create-release'
  'curl:curl'
  'delete-config:delete-config'
  'delete-deployment:delete-deployment'
  'delete-disk:delete-disk'
  'delete-env:delete-env'
  'delete-network:delete-network'
  'delete-release:delete-release'
  'delete-snapshot:delete-snapshot'
  'delete-snapshots:delete-snapshots'
  'delete-stemcell:delete-stemcell'
  'delete-vm:delete-vm'
  'deploy:deploy'
  'deployment:deployment'
  'deployments:deployments'
  'diff-config:diff-config'
  'disks:disks'
  'environment:environment'
  'environments:environments'
  'errands:errands'
  'event:event'
  'events:events'
  'export-release:export-release'
  'finalize-release:finalize-release'
  'generate-job:generate-job'
  'generate-package:generate-package'
  'help:help'
  'ignore:ignore'
  'init-release:init-release'
  'inspect-local-release:inspect-local-release'
  'inspect-local-stemcell:inspect-local-stemcell'
  'inspect-release:inspect-release'
  'instances:instances'
  'interpolate:interpolate'
  'locks:locks'
  'log-in:log-in'
  'log-out:log-out'
  'logs:logs'
  'manifest:manifest'
  'networks:networks'
  'orphan-disk:orphan-disk'
  'orphaned-vms:orphaned-vms'
  'pcap:pcap'
  'recover:recover'
  'recreate:recreate'
  'releases:releases'
  'remove-blob:remove-blob'
  'repack-stemcell:repack-stemcell'
  'reset-release:reset-release'
  'restart:restart'
  'run-errand:run-errand'
  'runtime-config:runtime-config'
  'scp:scp'
  'sha1ify-release:sha1ify-release'
  'sha2ify-release:sha2ify-release'
  'snapshots:snapshots'
  'ssh:ssh'
  'start:start'
  'start-env:start-env'
  'stemcells:stemcells'
  'stop:stop'
  'stop-env:stop-env'
  'sync-blobs:sync-blobs'
  'take-snapshot:take-snapshot'
  'task:task'
  'tasks:tasks'
  'unalias-env:unalias-env'
  'unignore:unignore'
  'update-cloud-config:update-cloud-config'
  'update-config:update-config'
  'update-cpi-config:update-cpi-config'
  'update-resurrection:update-resurrection'
  'update-runtime-config:update-runtime-config'
  'upload-blobs:upload-blobs'
  'upload-release:upload-release'
  'upload-stemcell:upload-stemcell'
  'variables:variables'
  'vendor-package:vendor-package'
  'vms:vms'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '(-e --environment)'{-e,--environment}'[director env name or URL]:env:' \
  '--config[config file]:file:_files' \
  '--ca-cert[CA cert path or value]:file:_files' \
  '--sha2[prefer SHA-256 checksums]' \
  '--parallel[parallelism]:count:' \
  '--client[username or UAA client id]:id:' \
  '--client-secret[password or client secret]:secret:' \
  '(-d --deployment)'{-d,--deployment}'[deployment name]:name:' \
  '--column[table column filter]:col:' \
  '--json[emit JSON]' \
  '--tty[force TTY output]' \
  '--no-color[disable color]' \
  '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'bosh-cli command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
