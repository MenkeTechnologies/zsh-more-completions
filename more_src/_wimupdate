#compdef wimupdate
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-update.1.html
# wimupdate — add, delete, or rename files in a WIM image

local ret=1

_arguments -s -S \
  '--dereference[apply dereferencing to all add commands]' \
  '--unix-data[apply UNIX data preservation to all add commands]' \
  '--no-acls[exclude ACLs from all add commands]' \
  '--strict-acls[enforce strict ACL handling for add commands]' \
  '--no-replace[prevent overwriting existing non-directory files]' \
  '--config=[capture configuration for add commands]:file:_files' \
  '--force[apply force mode to all delete commands]' \
  '--recursive[apply recursive deletion to all delete commands]' \
  '--check[verify WIM integrity and include integrity info]' \
  '--include-integrity[add integrity info without prior verification]' \
  '--threads=[thread count for compressing new files]:threads' \
  '--rebuild[rebuild entire WIM instead of appending updates]' \
  '--command=[execute a single update command from the command line]:command' \
  '--wimboot-config=[WIMBoot configuration file for the image]:file:_files' \
  '--unsafe-compact[compact WIM in-place by eliminating holes]' \
  '*:WIM file:_files' && ret=0

return ret
