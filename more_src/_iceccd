#compdef iceccd
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/iceccd.1.html
# iceccd - Icecream distributed compiler daemon

local ret=1

_arguments -s -S \
  '-n+[name of the icecream network to connect to]:netname' \
  '-m+[maximum number of parallel compile jobs]:max processes' \
  '--no-remote[prevent jobs from other nodes being scheduled here]' \
  '-w[watch]' \
  '(-d --daemonize)'{-d,--daemonize}'[detach daemon from shell]' \
  '-l+[file where log output is written]:logfile:_files' \
  '-s+[host running the scheduler]:scheduler host' \
  '*-v[increase verbosity; repeat for more]' \
  '(-r --run-as-user)'{-r,--run-as-user}'[force running the daemon with user rights]' \
  '-b+[base directory for storing compile environments]:env basedir:_files -/' \
  '(-u --nobody-uid)'{-u+,--nobody-uid+}'[id of user nobody for dropping privileges]:nobody uid' \
  '--cache-limit=[max cache size in MB for compile environments]:MB' \
  '-N+[name of the icecream host on the network]:hostname' \
  '(-i --interface)'{-i+,--interface+}'[bind to a specific network interface]:interface' \
  '(-p --port)'{-p+,--port+}'[daemon listening port]:port' && ret=0

return ret
