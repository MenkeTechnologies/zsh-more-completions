#compdef pockyt
# Documentation: https://github.com/achembarpu/pockyt
# Pocket API CLI client

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'get:retrieve items from Pocket'
      'put:add items to Pocket'
      'mod:modify items in Pocket'
    )
    _describe -t commands 'pockyt command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      get)
        _arguments -s -S \
          '-c[consumer key]:key:' \
          '-a[access token]:token:' \
          '-s[state of items]:state:(unread archive all)' \
          '-S[sort order]:sort:(newest oldest title site)' \
          '-t[filter by tag]:tag:' \
          '-T[content type]:type:(article video image)' \
          '-f[output format]:format:' \
          '-d[filter by domain]:domain:' \
          '-n[number of items to retrieve]:count:' \
          '-q[search query]:query:' \
          '-o[output file]:file:_files' \
          '-h[show help]' && ret=0
        ;;
      put)
        _arguments -s -S \
          '-c[consumer key]:key:' \
          '-a[access token]:token:' \
          '-i[input file or URL]:input:_files' \
          '-h[show help]' && ret=0
        ;;
      mod)
        _arguments -s -S \
          '-c[consumer key]:key:' \
          '-a[access token]:token:' \
          '-i[input file]:file:_files' \
          '-d[delete items]' \
          '-f[favorite items]' \
          '-u[unfavorite items]' \
          '-A[archive items]' \
          '-r[re-add items]' \
          '-h[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
