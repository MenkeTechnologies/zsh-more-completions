#compdef pow
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss159.html
# KAPPA: take a specified power of each pixel of an NDF

local ret=1

_arguments -s \
  'IN=[input NDF structure]:NDF:_files' \
  'OUT=[output NDF structure]:NDF:_files' \
  'POWER=[the power]:power' \
  'TITLE=[title for the output NDF]:title' \
  '*:NDF:_files' && ret=0

return ret
