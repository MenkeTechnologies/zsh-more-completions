#compdef aide-check
# Documentation: https://manpages.debian.org/testing/aide/aide.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# aide-check: check filesystem against the AIDE database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-B[config option (override)]:setting:' \
  '-l[limit to entries matching regex]:regex:' \
  '-V[verbosity level]:level:' \
  '*::aide-check args:_files' && ret=0
return ret
