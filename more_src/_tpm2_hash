#compdef tpm2_hash
# _tpm2_hash — tpm2-software tpm2_hash hash arbitrary data using the TPM2 with optional validation ticket (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_hash() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-C+[hierarchy]:h:(o p n e owner platform null endorsement)' \
        '--hierarchy=+[hierarchy]:h:(o p n e owner platform null endorsement)' \
        '-g+[hash algorithm]:a:(sha1 sha256 sha384 sha512 sm3_256)' \
        '--hash-algorithm=+[hash algorithm]:a:(sha1 sha256 sha384 sha512 sm3_256)' \
        '-o+[output digest]:file:_files' \
        '--output=+[output digest]:file:_files' \
        '-t+[output ticket]:file:_files' \
        '--ticket=+[output ticket]:file:_files' \
        '--hex[hex encode digest]' \
        '-Q[do not output anything]' \
        '*:input file:_files'
}

_tpm2_hash "$@"
