#compdef cargo-c cbuild cinstall ctest capi
# Documentation: https://github.com/lu-zero/cargo-c
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'cbuild:build C-API artifacts'
  'cinstall:install C-API artifacts'
  'ctest:test C-API'
  'capi:multiplexed build/install/test'
)

_arguments -C \
  '--destdir=[dest dir]:dir:_files -/' \
  '--prefix=[install prefix]:dir:_files -/' \
  '--libdir=[libdir]:dir:_files -/' \
  '--includedir=[includedir]:dir:_files -/' \
  '--bindir=[bindir]:dir:_files -/' \
  '--pkgconfigdir=[pkg-config dir]:dir:_files -/' \
  '--datarootdir=[dataroot dir]:dir:_files -/' \
  '--datadir=[data dir]:dir:_files -/' \
  '--crt-static[static CRT]' \
  '--meson-paths[Meson naming]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-v[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--color=[when]:when:(auto always never)' \
  '--frozen[frozen]' \
  '--locked[locked]' \
  '--offline[offline]' \
  '*--config=[KEY=VALUE]:setting:' \
  '*-Z[unstable]:flag:' \
  '(-j --jobs)'{-j,--jobs}'=[jobs]:n:' \
  '--keep-going[keep going]' \
  '--lib[lib only]' \
  '--bin=[bin]:name:' \
  '--bins[all bins]' \
  '--example=[example]:name:' \
  '--examples[all examples]' \
  '--test=[test]:name:' \
  '--tests[all tests]' \
  '--bench=[bench]:name:' \
  '--benches[all benches]' \
  '--all-targets[all targets]' \
  '*--library-type=[type]:type:(cdylib staticlib)' \
  '--profile=[profile]:profile:' \
  '*'{-F,--features}'=[features]:features:' \
  '--all-features[all features]' \
  '--no-default-features[no defaults]' \
  '--target=[triple]:triple:' \
  '--target-dir=[target dir]:dir:_files -/' \
  '--message-format=[format]:fmt:' \
  '--manifest-path=[manifest]:file:_files' \
  '--release[release]' \
  '--debug[debug]' \
  '*'{-p,--package}'=[package]:pkg:' \
  '--workspace[workspace]' \
  '*--exclude=[exclude]:pkg:' \
  '--no-run[no run]' \
  '--no-fail-fast[no fail fast]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'cargo-c subcommand' subcommands && ret=0 ;;
esac

return ret
