#compdef py2dsc-deb
# build a Debian binary package from a Python sdist (stdeb)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --dist-dir)'{-d,--dist-dir}'+[directory to put final built distributions in]:dir:_files -/' \
  '(-m --maintainer)'{-m,--maintainer}'+[maintainer name and email to use if not specified in .cfg]:maintainer' \
  '(-z --suite)'{-z,--suite}'+[distribution name to use if not specified in .cfg]:suite' \
  '(-p --patch-file)'{-p,--patch-file}'+[patch file applied before setup.py called]:file:_files' \
  '(-l --patch-level)'{-l,--patch-level}'+[patch level applied before setup.py called]:level' \
  '(-x --extra-cfg-file)'{-x,--extra-cfg-file}'+[additional .cfg file]:file:_files' \
  '(-r --remove-expanded-source-dir)'{-r,--remove-expanded-source-dir}'[remove the expanded source directory]' \
  '(-i --ignore-install-requires)'{-i,--ignore-install-requires}'[ignore requirements from requires.txt in egg-info]' \
  '(-a --patch-already-applied)'{-a,--patch-already-applied}'[patch was already applied]' \
  '(-q --patch-posix)'{-q,--patch-posix}'[apply the patch with --posix mode]' \
  '--guess-conflicts-provides-replaces[guess Conflicts/Provides/Replaces from apt-cache output]' \
  '--with-python2[build package for python 2]' \
  '--with-python3[build package for python 3]' \
  '--no-python2-scripts[do not install scripts for python 2]' \
  '--no-python3-scripts[do not install scripts for python 3]' \
  '--force-x-python3-version[override default minimum python3:any dependency]' \
  '--allow-virtualenv-install-location[allow installing into a virtualenv path]' \
  '*:distfile:_files -g "*.(zip|tar.gz)"' && ret=0

return ret
