#compdef coco_keyprovider
# _coco_keyprovider — CoCo container-image OCI key-provider gRPC server (used by skopeo/ocicrypt to encrypt images for CoCo)
# upstream: https://github.com/confidential-containers/guest-components
# Flags from attestation-agent/coco_keyprovider/src/main.rs Cli on tip (clap).

_coco_keyprovider() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-s --socket)'{-s,--socket}'=[address to listen on (IP:port)]:addr:' \
        '(-a --auth-private-key)'{-a,--auth-private-key}'=[private key signing the KBS resource-registration JWT]:file:_files' \
        '--kbs=[Key Broker Service address (enables auto-registration with --auth-private-key)]:url:_urls' \
        '(-d --daemon)'{-d,--daemon}'[daemonize (stdio + pid file under /run/confidential-containers)]'
}

_coco_keyprovider "$@"
