#compdef mp3gain
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mp3gain.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for MP3Gain (MP3 volume normalizer)

_mp3gain() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-g+[apply gain change in dB]:gain (dB):' \
    '-l+[apply gain to channel 0|1]:channel\:gain:' \
    '-r[apply Track gain automatically]' \
    '-a[apply Album gain automatically]' \
    '-c[ignore clipping warning]' \
    '-d+[modify suggested dB gain]:dB:' \
    '-e[skip Album analysis even if multiple files]' \
    '-f[assume MPEG 2 Layer III]' \
    '-k[automatically lower gain to prevent clipping]' \
    '-m+[modify suggested MP3 gain by integer]:modifier:' \
    '-o[database-friendly tab-delimited output]' \
    '-p[preserve original file timestamp]' \
    '-q[quiet mode]' \
    '-s+[stored tag info]:format:(c d i a s r)' \
    '-t[write to temp file then replace original]' \
    '-T[modify original file directly]' \
    '-u[undo changes made by mp3gain]' \
    '-v[show version number]' \
    '-w[wrap gain change if necessary]' \
    '-x[only find max amplitude of file]' \
    '(-? -h)'{'-?','-h'}'[display help]' \
    '*:MP3 files:_files -g "*.mp3"' \
    && ret=0

  return ret
}

_mp3gain "$@"
