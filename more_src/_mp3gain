#compdef mp3gain

# Zsh completion for MP3Gain (MP3 volume normalizer)

_mp3gain() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-g+[apply gain change in dB]:gain (dB):' \
    '-l+[apply gain change and specify lower limit]:limit:' \
    '-r[apply Track gain automatically]' \
    '-a[apply Album gain automatically]' \
    '-c[ignore clipping warning]' \
    '-d+[set target "normal" dB value]:target dB:' \
    '-e[skip analysis of files already analyzed]' \
    '-f[force recalculation]' \
    '-k[automatically lower Track/Album gain to not clip audio]' \
    '-m+[modify suggested MP3 gain by integer]:modifier:' \
    '-o[output is a database-friendly tab-delimited list]' \
    '-p[preserve original file timestamp]' \
    '-q[quiet mode]' \
    '-r[apply Track gain automatically]' \
    '-s+[choose stored tag format]:format:(c d i r s)' \
    '-t[writes modified data to temp file then deletes original]' \
    '-u[undo changes made by mp3gain]' \
    '-v[show version number]' \
    '-w[wrap gain change if necessary]' \
    '-x[only find max amplitude of file]' \
    '-T[use multiple threads]' \
    '(-? -h)'{'-?','-h'}'[display help]' \
    '*:MP3 files:_files -g "*.mp3"' \
    && ret=0

  return ret
}

_mp3gain "$@"
