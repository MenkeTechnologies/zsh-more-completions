#compdef git-trim
# Documentation: https://github.com/foriequal0/git-trim
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git trim (trim merged branches)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-d --delete)'{-d,--delete}'[delete merged branches]' \
  '(-n --dry-run)'{-n,--dry-run}'[show what would be deleted without doing it]' \
  '--no-update[do not update remotes before trimming]' \
  '--protected[pattern for protected branches]:pattern:' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
