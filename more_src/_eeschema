#compdef eeschema
# Documentation: https://docs.kicad.org/8.0/en/eeschema/eeschema.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (eeschema is the KiCad Schematic Editor GUI;
# CLI flags are not documented beyond accepting a schematic file argument — use kicad-cli sch
# for scripted operations).

# KiCad eeschema: schematic capture (GUI; accepts a schematic file argument)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:KiCad schematic file:_files -g "*.(sch|kicad_sch)"' && ret=0
return ret
