#compdef eeschema
# Documentation: https://man.archlinux.org/search?q=eeschema
# Reference accessed: 2026-05-16

# KiCad eeschema: schematic capture
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:KiCad schematic file:_files -g "*.(sch|kicad_sch)"' && ret=0
return ret
