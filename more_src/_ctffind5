#compdef ctffind5
# Documentation: https://grigoriefflab.umassmed.edu/ctffind4
# ctffind5 - CTF estimation with tilt and thickness (Grigorieff lab / cisTEM)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--old-school-input[use CTFFIND3-style input order]' \
  '--old-school-input-ctffind4[use CTFFIND4 old-school input]' \
  '--amplitude-spectrum-input[input is an amplitude spectrum, not a micrograph]' \
  '--filtered-amplitude-spectrum-input[input is a pre-filtered amplitude spectrum]' \
  '--fast[skip extra diagnostic statistics for speed]' \
  '--omp-num-threads=[max number of OpenMP threads]:threads' \
  '*:micrograph:_files' && ret=0

return ret
