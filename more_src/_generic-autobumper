#compdef generic-autobumper
# _generic-autobumper — Prow autobumper that opens PRs to bump versions (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/generic-autobumper/main.go (flag).

_generic-autobumper() {
    _arguments \
        '-config=[autobumper config file]:file:_files' \
        '*-labels-override=[labels to add to PR (repeat or comma-sep)]:labels:' \
        '-skip-pullrequest[do not open a pull request]' \
        '-signoff[signoff commits]' \
        '-skip-if-no-oncall[skip if no oncall discovered]' \
        '-pr-source-mode=[how to push PR source]:mode:(fork branch)' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls' \
        '-github-app-id=[GitHub App ID]:id:' \
        '-github-app-private-key-path=[GitHub App private key]:file:_files'
}

_generic-autobumper "$@"
