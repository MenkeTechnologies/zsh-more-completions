#compdef jac
# Documentation: https://github.com/cubicap/Jaculus-tools
# jac - Jaculus tools CLI for controlling Jaculus (JavaScript) devices

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--port=[serial port of device]:port:_files -g "/dev/tty* /dev/cu*"' \
  '--socket=[connect over socket host:port]:socket:' \
  '1:command:(install version list-ports serial-socket build flash start stop status monitor help)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      install)
        _arguments -s \
          '--package=[firmware package to install]:package:_files -g "*.tar.gz"' \
          '--port=[serial port of device]:port:_files -g "/dev/tty* /dev/cu*"' \
          '--info[view package info]' && ret=0
        ;;
      flash)
        _arguments -s \
          '--from=[path to compiled program to flash]:path:_files' && ret=0
        ;;
      serial-socket)
        _arguments -s \
          '--port=[serial port]:port:_files -g "/dev/tty* /dev/cu*"' \
          '--socket=[socket port]:socket:' && ret=0
        ;;
      start)
        _arguments '*:path:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
