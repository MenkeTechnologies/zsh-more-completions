#compdef 3dMSE
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dMSE.html
# Compute multiscale entropy of voxel time series

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-polort[eliminate polynomial trends (order -1 to 3)]:m:' \
  '-autoclip[remove low-intensity regions]' \
  '-automask[restrict analysis to high-intensity voxels]' \
  '-mask[apply a mask to define brain voxels]:dataset:_files' \
  '-prefix[output dataset prefix]:prefix:' \
  '-scales[number of scales for calculation]:n:' \
  '-entwin[window size during computation]:w:' \
  '-rthresh[radius threshold as fraction of stddev]:r:' \
  '*:dataset:_files' && ret=0

return ret
