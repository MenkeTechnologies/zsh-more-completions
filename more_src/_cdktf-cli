#compdef cdktf

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'completion:print shell completion script'
  'convert:convert HCL to CDK code'
  'debug:debug environment'
  'deploy:deploy stacks'
  'destroy:destroy stacks'
  'diff:show plan diff'
  'force-unlock:force unlock state'
  'get:fetch and generate provider/module bindings'
  'init:initialize a new project'
  'list:list stacks'
  'login:authenticate with HCP/Terraform Cloud'
  'logout:logout'
  'output:show stack outputs'
  'plugin:plugin commands'
  'provider:manage providers'
  'synth:synthesize Terraform JSON'
  'watch:watch and deploy'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--disable-logging=[disable file logging]:b:(true false)' \
  '*--disable-plugin-cache-env=[disable plugin cache env]:b:(true false)' \
  '*--log-level=[log level]:l:(off all error warn info debug trace)' \
  '*-l+[log level]:l:(off all error warn info debug trace)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cdktf command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy)
        _arguments \
          '(--auto-approve)--auto-approve[auto approve]' \
          '(--no-color)--no-color[no color]' \
          '(--ci)--ci[CI mode]' \
          '(--ignore-missing-stack-dependencies)--ignore-missing-stack-dependencies[ignore missing deps]' \
          '(--parallelism)--parallelism=[parallelism]:n:' \
          '(--terraform-parallelism)--terraform-parallelism=[tf parallelism]:n:' \
          '(--refresh-only)--refresh-only[refresh only]' \
          '(--skip-synth)--skip-synth[skip synth]' \
          '(--migrate-state)--migrate-state[migrate state]' \
          '(-a --app)'{-a+,--app=}'[app cmd]:c:' \
          '(-o --output)'{-o+,--output=}'[output dir]:dir:_files -/' \
          '(--var)*--var=[var k=v]:v:' \
          '(--var-file)*--var-file=[var file]:file:_files -g "*.tfvars *.tfvars.json"' \
          '(--include-sensitive-outputs)--include-sensitive-outputs[show sensitive outputs]' \
          '(--outputs-file)--outputs-file=[outputs file]:file:_files' \
          '(--outputs-file-include-sensitive-outputs)--outputs-file-include-sensitive-outputs[include sensitive in outputs file]' \
          '*:stack:' && ret=0 ;;
      (destroy)
        _arguments \
          '(--auto-approve)--auto-approve[auto approve]' \
          '(--no-color)--no-color[no color]' \
          '(--ci)--ci[CI mode]' \
          '(--ignore-missing-stack-dependencies)--ignore-missing-stack-dependencies[ignore missing deps]' \
          '(--parallelism)--parallelism=[parallelism]:n:' \
          '(--terraform-parallelism)--terraform-parallelism=[tf parallelism]:n:' \
          '(-a --app)'{-a+,--app=}'[app cmd]:c:' \
          '(-o --output)'{-o+,--output=}'[output dir]:dir:_files -/' \
          '(--var)*--var=[var k=v]:v:' \
          '(--var-file)*--var-file=[var file]:file:_files' \
          '*:stack:' && ret=0 ;;
      (diff|plan)
        _arguments \
          '(--no-color)--no-color[no color]' \
          '(--migrate-state)--migrate-state[migrate state]' \
          '(--refresh-only)--refresh-only[refresh only]' \
          '(--terraform-parallelism)--terraform-parallelism=[tf parallelism]:n:' \
          '(-a --app)'{-a+,--app=}'[app cmd]:c:' \
          '(-o --output)'{-o+,--output=}'[output dir]:dir:_files -/' \
          '(--var)*--var=[var k=v]:v:' \
          '(--var-file)*--var-file=[var file]:file:_files' \
          '*:stack:' && ret=0 ;;
      (synth)
        _arguments \
          '(--check-code-maker-output)--check-code-maker-output[check codemaker output]' \
          '(-a --app)'{-a+,--app=}'[app cmd]:c:' \
          '(-o --output)'{-o+,--output=}'[output dir]:dir:_files -/' \
          '*:stack:' && ret=0 ;;
      (init)
        _arguments \
          '(--template)--template=[template]:t:(typescript python java csharp go)' \
          '(--project-name)--project-name=[project name]:n:' \
          '(--project-description)--project-description=[project description]:d:' \
          '(--cdktf-version)--cdktf-version=[cdktf version]:v:' \
          '(--dist)--dist=[dist dir]:dir:_files -/' \
          '(--local)--local[local backend]' \
          '(--http)--http[HTTP backend]' \
          '(--enable-crash-reporting)--enable-crash-reporting[enable crash reports]' \
          '(--from-terraform-project)--from-terraform-project=[from existing TF]:dir:_files -/' \
          '(--providers)*--providers=[provider]:p:' \
          '*: :' && ret=0 ;;
      (get)
        _arguments \
          '(--output)--output=[output dir]:dir:_files -/' \
          '(--language)--language=[language]:l:(typescript python java csharp go)' \
          '(--parallelism)--parallelism=[parallelism]:n:' \
          '(--force-local)--force-local[force local provider]' \
          '*: :' && ret=0 ;;
      (provider)
        _arguments \
          '1:subcommand:(add list remove)' \
          '*: :' && ret=0 ;;
      (output)
        _arguments \
          '(--no-color)--no-color[no color]' \
          '(-a --app)'{-a+,--app=}'[app cmd]:c:' \
          '(-o --output)'{-o+,--output=}'[output dir]:dir:_files -/' \
          '(--include-sensitive-outputs)--include-sensitive-outputs[include sensitive]' \
          '(--outputs-file)--outputs-file=[outputs file]:file:_files' \
          '*:stack:' && ret=0 ;;
      (watch)
        _arguments \
          '(--auto-approve)--auto-approve[auto approve]' \
          '(--no-color)--no-color[no color]' \
          '(--ci)--ci[CI mode]' \
          '*:stack:' && ret=0 ;;
      (convert)
        _arguments \
          '(--language)--language=[language]:l:(typescript python java csharp go)' \
          '(--provider)*--provider=[provider]:p:' \
          '(--stdin)--stdin[read from stdin]' \
          '*: :_files -g "*.tf *.hcl"' && ret=0 ;;
      (force-unlock)
        _arguments \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0 ;;
      (debug)
        _arguments '*: :' && ret=0 ;;
      (plugin)
        _arguments \
          '1:subcommand:(install list remove)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
