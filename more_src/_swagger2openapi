#compdef swagger2openapi
# Documentation: https://github.com/Mermade/oas-kit/blob/main/packages/swagger2openapi/README.md
# Convert Swagger 2.0 definitions to OpenAPI 3.0.x

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version number]' \
  '--refSiblings=[mode to handle $ref siblings]:mode:(remove preserve allOf)' \
  '--resolveInternal[resolve internal references also]' \
  '--warnProperty=[property name to use for warning extensions]:name' \
  '(-c --components)'{-c,--components}'[output information to unresolve a definition]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode, adds specification-extensions]' \
  '(-e --encoding)'{-e,--encoding}'=[encoding for input/output files]:encoding' \
  '(-f --fatal)'{-f,--fatal}'[make resolution errors fatal]' \
  '(-i --indent)'{-i,--indent}'=[JSON indent to use]:indent' \
  '(-o --outfile)'{-o,--outfile}'=[output file to write to]:file:_files' \
  '(-p --patch)'{-p,--patch}'[fix up small errors in the source definition]' \
  '(-r --resolve)'{-r,--resolve}'[resolve external references]' \
  '(-t --targetVersion)'{-t,--targetVersion}'=[override default target version]:version' \
  '(-u --url)'{-u,--url}'=[url of original spec, creates x-origin entry]:url' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-w --warnOnly)'{-w,--warnOnly}'[do not throw on non-patchable errors]' \
  '(-y --yaml)'{-y,--yaml}'[write YAML, default JSON]' \
  '(-b --rbname)'{-b,--rbname}'=[extension to preserve body parameter names]:name' \
  '*:spec:_files' && ret=0

return ret
