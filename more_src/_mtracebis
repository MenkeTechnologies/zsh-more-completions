#compdef mtracebis
# Documentation: https://manpages.debian.org/unstable/frr/mtracebis.8.en.html
# Initiate multicast traceroute (mtrace) queries

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-v[display version information]' \
  '1:multicast source:_hosts' \
  '2:multicast group:_hosts' && ret=0

return ret
