#compdef dtools
# Documentation: https://github.com/Pavdig/dtools
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--dry-run[preview actions without executing]' \
  '--cron[cron mode (disable colors, adjust logging)]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a commands
    commands=(
      'update:update specific or all apps'
      'update-unused:remove unused docker images'
      '--quick-backup:backup specific volumes'
      '-qb:backup specific volumes'
    )
    _describe -t commands 'dtools command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (update)
        _arguments \
          '--all[update all apps]' \
          '--dry-run[preview only]' \
          '*:app:_files -/' && ret=0
        ;;
      (--quick-backup|-qb)
        _alternative \
          'volumes:docker volume:( )' \
          'files:backup path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
