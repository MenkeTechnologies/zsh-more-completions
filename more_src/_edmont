#compdef edmont
# Documentation: https://bio3d.colorado.edu/imod/doc/man/edmont.html
# Edit, split, or combine montage image stacks

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-imin -ImageInputFile)'{-imin,-ImageInputFile}'[Montaged image input file. If there is more than one no]:file:_files' \
  '(-plin -PieceListInput)'{-plin,-PieceListInput}'[File with list of piece coordinates for image input fil]:file:_files' \
  '(-imout -ImageOutputFile)'{-imout,-ImageOutputFile}'[Output file for montaged images. If there are any non-o]:file:_files' \
  '(-plout -PieceListOutput)'{-plout,-PieceListOutput}'[File for list of coordinates of pieces in output image ]:file:_files' \
  '(-mdoc -UseMdocFiles)'{-mdoc,-UseMdocFiles}'[This option allows data about each image section in met]' \
  '(-secs -SectionsToRead)'{-secs,-SectionsToRead}'[List of sections to read from an input file, numbered f]:value:' \
  '(-fromone -NumberedFromOne)'{-fromone,-NumberedFromOne}'[With this option section numbers entered with the -secs]' \
  '(-numout -NumberToOutput)'{-numout,-NumberToOutput}'[Number of sections to write to each output file, when t]:value:' \
  '(-mode -ModeToOutput)'{-mode,-ModeToOutput}'[The storage mode of the output file; 0 for byte, 1 for ]:value:' \
  '(-xminmax -XMinAndMax)'{-xminmax,-XMinAndMax}'[Minimum and maximum X coordinates to include in output.]:value:' \
  '(-yminmax -YMinAndMax)'{-yminmax,-YMinAndMax}'[Minimum and maximum Y coordinates to include in output.]:value:' \
  '(-xframes -XFrameMinAndMax)'{-xframes,-XFrameMinAndMax}'[Starting and ending frames in X to include in the outpu]:value:' \
  '(-yframes -YFrameMinAndMax)'{-yframes,-YFrameMinAndMax}'[Starting and ending frames in Y to include in the outpu]:value:' \
  '(-float -FloatDensities)'{-float,-FloatDensities}'[Adjust densities of sections individually or together. ]:value:' \
  '(-bin -BinByFactor)'{-bin,-BinByFactor}'[Use binning to reduce images in size by the given facto]:value:' \
  '(-exclude -ExclusionModel)'{-exclude,-ExclusionModel}'[Model file with points on pieces to exclude from output]:file:_files' \
  '(-renumber -RenumberZFromZero)'{-renumber,-RenumberZFromZero}'[Renumber Z values to be sequential and start at zero. T]' \
  '(-shift -ShiftXYToZero)'{-shift,-ShiftXYToZero}'[Adjust X and Y piece coordinates to start at zero. If t]' \
  '(-param -ParameterFile)'{-param,-ParameterFile}'[Read parameter entries as keyword-value pairs from a pa]:file:_files' \
  '-StandardInput[Read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
