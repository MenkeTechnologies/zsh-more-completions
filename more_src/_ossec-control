#compdef ossec-control

# ossec-control: control script for OSSEC daemons
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-j[output JSON]' \
  '1:action:(start stop status restart reload enable disable info help lock unlock)' \
  '*::ossec-control args:_files' && ret=0
return ret
