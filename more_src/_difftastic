#compdef difft

# Zsh completion for difftastic (structural diff tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--background[set terminal background color]:background:(dark light)' \
  '--byte-limit[set byte limit for files]:bytes' \
  '--check-only[report whether files differ without showing diff]' \
  '--color[when to use color]:color:(auto always never)' \
  '--context[number of context lines to show]:lines' \
  '--display[display mode]:mode:(side-by-side side-by-side-show-both inline)' \
  '--exit-code[set exit code to 1 if files differ]' \
  '--graph-limit[set graph node limit]:nodes' \
  '--ignore-comments[ignore comments when diffing]' \
  '--language[override language detection]:language' \
  '--list-languages[list supported languages]' \
  '--missing-as-empty[treat missing files as empty]' \
  '--override[override language detection for files]:glob-pattern\\=language' \
  '--parse-error-limit[set max parse errors before falling back]:count' \
  '--skip-unchanged[skip unchanged files in directory diff]' \
  '--sort-paths[sort file paths in directory diff]' \
  '--strip-cr[strip carriage return characters]' \
  '--syntax-highlight[when to syntax highlight]:mode:(on off)' \
  '--tab-width[set tab display width]:width' \
  '--width[set terminal display width]:columns' \
  '--dump-syntax[dump syntax tree for debugging]:file:_files' \
  '--dump-ts[dump tree-sitter tree for debugging]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:old file or directory:_files' \
  '2:new file or directory:_files' && ret=0

return ret
