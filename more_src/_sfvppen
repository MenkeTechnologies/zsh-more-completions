#compdef sfvppen
# Documentation: http://www.ahay.org/RSF/sfvppen.html
# Madagascar: vplot pen filter to combine and lay out vplot files

local ret=1

_arguments -s \
  'gridnum=[grid the screen into parts]:gridnum' \
  'gridsize=[grid dimensions xwidth,ywidth]:gridsize' \
  'dumb=[if y, output only vectors, erases, color changes]:flag:(y n)' \
  'blast=[if y, do not try to compact the output]:flag:(y n)' \
  'bit=[if >0, bit raster is used with bit the color]:bit' \
  'grid=[draw a grid with the specified fatness]:grid' \
  'xsize=[scale vplot image to fit within given width]:xsize' \
  'ysize=[scale vplot image to fit within given height]:ysize' \
  'big=[if y, expand the size of the device screen]:flag:(y n)' \
  'vpstyle=[if n, omit declaring absolute style]:flag:(y n)' \
  'mono=[no color mode]:flag:(y n)' \
  'stat=[if y print statistics, if l insert spaces]:flag:(y n l)' \
  'scale=[overall scale factor]:scale' \
  'xscale=[x-axis scale factor]:xscale' \
  'yscale=[y-axis scale factor]:yscale' \
  'rotate=[rotation angle in degrees]:rotate' \
  'fat=[base line fatness]:fat' \
  '*:vpl file:_files' && ret=0

return ret
