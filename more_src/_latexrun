#compdef latexrun
# Documentation: https://github.com/aclements/latexrun
# 21st century LaTeX wrapper: runs latex the right number of times, filters output

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o+[output file name]:output file:_files' \
  '--latex-cmd=[latex command (default pdflatex)]:command:_command_names' \
  '--latex-args=[additional command-line arguments for latex]:args:' \
  '--bibtex-cmd=[bibtex command (default bibtex)]:command:_command_names' \
  '--bibtex-args=[additional command-line arguments for bibtex]:args:' \
  '--max-iterations=[max times to run latex before giving up (default 10)]:n:' \
  '*-W+[enable/disable warning from CLASS (package, font, underfull, overfull, all)]:class:' \
  '-O+[directory for intermediate files and control database (default latex.out)]:directory:_files -/' \
  '--color=[when to colorize messages]:when:(auto always never)' \
  '--verbose-cmds[print commands as they are executed]' \
  '--debug[enable detailed debug output]' \
  '--clean-all[delete output files]' \
  '*:tex file:_files -g "*.tex"' && ret=0

return ret
