#compdef mycelium
# Documentation: https://github.com/threefoldtech/mycelium/blob/master/README.md
# mycelium - end-to-end encrypted IPv6 overlay network

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-k --key-file)'{-k,--key-file}'=[path to the private key file]:file:_files' \
  '(-c --config-file)'{-c,--config-file}'=[path to the configuration file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '--silent[disable all logging]' \
  '--log-format=[set the logging format]:format:(compact logfmt plain)' \
  '*--peers=[add static peers to connect to]:peer:' \
  '(-t --tcp-listen-port)'{-t,--tcp-listen-port}'=[TCP port to listen on]:port:' \
  '--disable-quic[disable the QUIC transport]' \
  '(-q --quic-listen-port)'{-q,--quic-listen-port}'=[QUIC port to listen on]:port:' \
  '--peer-discovery-port=[port used for local peer discovery]:port:' \
  '--disable-peer-discovery[disable local peer discovery]' \
  '--peer-discovery-interface=[interface to use for local peer discovery]:iface:_net_interfaces' \
  '--api-addr=[HTTP API listening address]:addr:' \
  '--jsonrpc-addr=[JSON-RPC API listening address]:addr:' \
  '--no-tun[run without creating a TUN interface]' \
  '--tun-name=[name of the TUN interface]:name:' \
  '--metrics-api-address=[address to expose Prometheus metrics on]:addr:' \
  '--firewall-mark=[firewall mark to apply to outgoing packets]:mark:' \
  '--update-workers=[number of route update workers]:n:' \
  '--topic-config=[path to topic configuration file]:file:_files' \
  '--cdn-cache=[path to the CDN cache directory]:dir:_files -/' \
  '--vsock-listen-port=[vsock port to listen on]:port:' \
  '--enable-dns[enable the embedded DNS resolver]' \
  '1:command:(inspect generate-keys message peers routes proxy stats)' \
  '*::arg:->args' && ret=0

return ret
