#compdef tsscan
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsscan.cpp
# tsscan - scan a DTV network and report frequencies and services

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*--delivery-system=[delivery system to use]:system:' \
  '(-n --nit-scan)'{-n,--nit-scan}'[perform a full network scan from a reference TS]' \
  '(-u --uhf-band)'{-u,--uhf-band}'[complete UHF-band scanning]' \
  '(-v --vhf-band)'{-v,--vhf-band}'[complete VHF-band scanning]' \
  '--best-strength[use offset with best signal strength per channel]' \
  '--first-channel=[first channel to scan in UHF/VHF band]:n:' \
  '--first-offset=[first offset to scan on each channel]:n:' \
  '(-g --global-service-list)'{-g,--global-service-list}'[display global services list at scan end]' \
  '--last-channel=[last channel to scan in UHF/VHF band]:n:' \
  '--last-offset=[last offset to scan on each channel]:n:' \
  '--min-strength=[minimum signal strength threshold]:n:' \
  '--no-offset[scan only central frequency of each channel]' \
  '--use-offsets[scan frequencies with offsets around channels]' \
  '--psi-timeout=[timeout (ms) for PSI/SI table collection]:ms:' \
  '(-l --service-list)'{-l,--service-list}'[read SDT and display services per channel]' \
  '--show-modulation[display modulation parameters when available]' \
  '--save-channels=[save channel descriptions to XML file]:file:_files' \
  '--update-channels=[update channel descriptions in XML file]:file:_files' && ret=0

return ret
