#compdef redo

# Zsh completion for redo - a djb-style incremental build system

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-j+[run N jobs in parallel]:jobs:' \
  '--jobs=[run N jobs in parallel]:jobs:' \
  '-d[print extra debug messages]' \
  '--debug[print extra debug messages]' \
  '-v[print commands as they are run]' \
  '--verbose[print commands as they are run]' \
  '-x[print commands and output as they are run]' \
  '--xtrace[print commands and output as they are run]' \
  '-k[keep going after errors]' \
  '--keep-going[keep going after errors]' \
  '--shuffle[randomize the build order]' \
  '--no-log[do not capture build logs]' \
  '--no-details[do not show details of failed targets]' \
  '--no-color[do not colorize output]' \
  '--color[force colorized output]' \
  '*:target:_files' && ret=0

return ret
