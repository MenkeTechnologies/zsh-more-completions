#compdef redo
# Documentation: https://redo.readthedocs.io/en/latest/redo/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for redo - a djb-style incremental build system (apenwarr/redo)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-j --jobs)'{-j+,--jobs=}'[execute at most N .do scripts in parallel]:jobs:' \
  '(-d --debug)'{-d,--debug}'[display dependency checks as they occur]' \
  '(-v --verbose)'{-v,--verbose}'[pass -v to /bin/sh when executing scripts]' \
  '(-x --xtrace)'{-x,--xtrace}'[pass -x to /bin/sh when executing scripts]' \
  '(-k --keep-going)'{-k,--keep-going}'[keep going after errors]' \
  '--debug-locks[show lock acquisition and wait messages]' \
  '--debug-pids[include process IDs in output messages]' \
  '--shuffle[randomize target build order]' \
  '--no-log[do not capture build script stderr messages]' \
  '--no-details[show only redo messages, suppress build script output]' \
  '--no-status[disable running build status line]' \
  '--no-pretty[show raw log lines instead of human-readable format]' \
  '--no-color[do not colorize output]' \
  '--color[force colorized output]' \
  '*:target:_files' && ret=0

return ret
