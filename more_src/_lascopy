#compdef lascopy
# LAStools: copy attributes from one LAS/LAZ file to matching points of another

local ret=1

_arguments -s -S \
  '-help[show help information]' \
  '-version[display version number]' \
  '-gui[launch GUI interface]' \
  '-demo[run in demo mode]' \
  '-verbose[enable verbose output]' \
  '-match_gps_time[match points by GPS time (default)]' \
  '-match_return_number[match by return number (default)]' \
  '-match_number_of_returns[match by number of returns]' \
  '-match_classification[match by classification value]' \
  '-match_intensity[match by intensity]' \
  '-match_point_source_id[match by point source ID]' \
  '-match_scanner_channel[match by scanner channel]' \
  '-match_scan_angle[match by scan angle]' \
  '-match_edge_of_flightline[match by edge of flightline flag]' \
  '-match_scan_direction[match by scan direction flag]' \
  '-match_user_data[match by user data]' \
  '-match_xy+[match points within x-y distance]:distance' \
  '-match_xyz+[match points within spherical/box distance]:distance' \
  '-copy_attribute+[copy attribute by index]:n' \
  '-copy_classification[copy classification (default)]' \
  '-copy_elevation[copy z-values]' \
  '-copy_intensity[copy intensity values]' \
  '-copy_keypoint_flag[copy keypoint flag]' \
  '-copy_overlap_flag[copy overlap flag]' \
  '-copy_synthetic_flag[copy synthetic flag]' \
  '-copy_withheld_flag[copy withheld flag]' \
  '-copy_rgb[copy RGB color data]' \
  '-copy_user_data[copy user data]' \
  '-copy_return_number[copy return number]' \
  '-copy_number_of_returns[copy number of returns]' \
  '-zero[set unmatched attributes to 0]' \
  '-unmatched[copy by point order instead of matching]' \
  '*-i+[input file(s)]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
