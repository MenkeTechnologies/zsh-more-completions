#compdef captcp captcp.py
# Documentation: http://research.protocollabs.com/captcp/
# Open source program for TCP analysis of PCAP files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:subcommand:((
    statistic\:"show statistics about all connections and flows"
    throughput\:"graph the throughput over time"
    show\:"tcpdump/tshark like mode"
    spacing\:"time between packets and acks"
    timesequence\:"plot a time-sequence graph"
    geoip\:"show country/location information about peers"
    inflight\:"visualize all packets in flight and not ACKed"
    connection\:"visualize all communicating peers"
    stacktrace\:"hook into kernel to trace cwnd and ssthresh"
    flowgraph\:"graph a TCP flow/sequence graph"
    payloadtimeport\:"payload over time per port"
    template\:"generate template output"
    sound\:"sonify packet stream"
  ))' \
  '*::args:_files' && ret=0

return ret
