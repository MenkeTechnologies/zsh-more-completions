#compdef dbscope
# Source: cargo binstall dbscope@0.2.2
# Probed via: completions zsh
# Repository: https://github.com/jayvenn21/dbscope

autoload -U is-at-least

_dbscope() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_dbscope_commands" \
"*::: :->dbscope" \
&& ret=0
    case $state in
    (dbscope)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dbscope-command-$line[1]:"
        case $line[1] in
            (analyze)
_arguments "${_arguments_options[@]}" : \
'--schema=[Database connection URI (e.g. postgres\://user\:pass@localhost/dbname)]:SCHEMA:_default' \
'-o+[Output directory for report files (default\: current directory)]:OUTPUT:_files' \
'--output=[Output directory for report files (default\: current directory)]:OUTPUT:_files' \
'--query-log=[Path to query log file (one SQL statement per line) for cold/hot tables, index suggestions]:QUERY_LOG:_files' \
'--format=[Report formats to generate (comma-separated\: md,html,json,dot). Default\: all]:FORMAT:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(impact)
_arguments "${_arguments_options[@]}" : \
'--schema=[Database connection URI]:SCHEMA:_default' \
'--query-log=[Query log file to count affected queries]:QUERY_LOG:_files' \
'--json[Output as JSON instead of human-readable text]' \
'-h[Print help]' \
'--help[Print help]' \
':target -- Target\: table (e.g. users), table.column (e.g. users.email), or schema.table.column:_default' \
&& ret=0
;;
(ci)
_arguments "${_arguments_options[@]}" : \
'--schema=[Database connection URI]:SCHEMA:_default' \
'--migration=[Migration file to simulate (DDL\: DROP TABLE, CREATE TABLE, ALTER ADD FK)]:MIGRATION:_files' \
'--policy=[Policy file (YAML\: max_table_risk, no_cycles, no_orphans, max_blast_radius_percent). Overrides --threshold when set]:POLICY:_files' \
'--threshold=[Fail if any table risk score exceeds this (0-1). Default 0.5. Ignored if --policy is set]:THRESHOLD:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(plan)
_arguments "${_arguments_options[@]}" : \
'--schema=[]:SCHEMA:_default' \
'--json[Output as JSON instead of human-readable text]' \
'-h[Print help]' \
'--help[Print help]' \
':action -- Subcommand\: drop:_default' \
':target -- Target table (e.g. users or public.users):_default' \
&& ret=0
;;
(preview)
_arguments "${_arguments_options[@]}" : \
'--schema=[Database connection URI]:SCHEMA:_default' \
'--query-log=[Query log file to count broken queries]:QUERY_LOG:_files' \
'--policy=[Policy file (YAML). If absent, only reports; with policy, exits 1 on violation]:POLICY:_files' \
'-h[Print help]' \
'--help[Print help]' \
':migration -- Migration file (DDL) to simulate:_files' \
&& ret=0
;;
(summarize)
_arguments "${_arguments_options[@]}" : \
'--schema=[]:SCHEMA:_default' \
'--query-log=[]:QUERY_LOG:_files' \
'--json[Output as JSON instead of human-readable text]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(explain)
_arguments "${_arguments_options[@]}" : \
'--schema=[]:SCHEMA:_default' \
'--query-log=[]:QUERY_LOG:_files' \
'--json[Output as JSON instead of human-readable text]' \
'-h[Print help]' \
'--help[Print help]' \
':kind -- What to explain\: "risk" or "index-suggestion":_default' \
':target -- For risk\: table name (e.g. public.users). For index-suggestion\: qualified table (e.g. public.posts):_default' \
'::column -- For index-suggestion only\: column name (e.g. user_id):_default' \
&& ret=0
;;
(demo)
_arguments "${_arguments_options[@]}" : \
'-o+[Output directory for demo reports (default\: current directory)]:OUTPUT:_files' \
'--output=[Output directory for demo reports (default\: current directory)]:OUTPUT:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(snapshot)
_arguments "${_arguments_options[@]}" : \
'--schema=[Database connection URI]:SCHEMA:_default' \
'-o+[Output file path (e.g. schema-2024-01-15.json)]:OUTPUT:_files' \
'--output=[Output file path (e.g. schema-2024-01-15.json)]:OUTPUT:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(diff)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON instead of human-readable text]' \
'-h[Print help]' \
'--help[Print help]' \
':before -- Path to the "before" snapshot JSON file:_files' \
':after -- Path to "after" snapshot file OR a database connection URI:_default' \
&& ret=0
;;
(lint)
_arguments "${_arguments_options[@]}" : \
'--schema=[Database connection URI]:SCHEMA:_default' \
'--json[Output as JSON instead of human-readable text]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(deps)
_arguments "${_arguments_options[@]}" : \
'--schema=[Database connection URI]:SCHEMA:_default' \
'--json[Output as JSON instead of human-readable text]' \
'-h[Print help]' \
'--help[Print help]' \
':target -- Target table (e.g. users or public.users):_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(mcp)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_dbscope__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dbscope-help-command-$line[1]:"
        case $line[1] in
            (analyze)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(impact)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(ci)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(plan)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(preview)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(summarize)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(explain)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(demo)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(snapshot)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(diff)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(lint)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(deps)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(mcp)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_dbscope_commands] )) ||
_dbscope_commands() {
    local commands; commands=(
'analyze:Analyze schema\: extract from DB, build graph, compute metrics, emit reports' \
'impact:Blast radius\: what is affected by changing a table or column (FK downstream, indexes, queries)' \
'ci:CI mode\: check schema (and optional migration) risk; exit 1 if above threshold' \
'plan:Safe refactor plan\: steps to drop a table (remove FKs first, then drop)' \
'preview:Preview migration impact\: structural delta, risk delta, blast radius, policy check' \
'summarize:Summarize architecture\: table count, risk overview, orphans, cycles, cold/hot (if query log)' \
'explain:Explain risk or index suggestion in plain language' \
'demo:Run a demo analysis on an embedded e-commerce schema (no database required)' \
'snapshot:Save current schema to a JSON snapshot file for offline diffing and auditing' \
'diff:Compare two schema snapshots or a snapshot vs. live database. Shows structural delta' \
'lint:Detect schema anti-patterns\: missing PKs, wide tables, missing FK indexes, naming issues' \
'deps:Show the full dependency tree for a table (upstream and downstream FK chains)' \
'completions:Generate shell completions for bash, zsh, fish, or powershell' \
'mcp:Run as an MCP (Model Context Protocol) server over stdio for AI assistants' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'dbscope commands' commands "$@"
}
