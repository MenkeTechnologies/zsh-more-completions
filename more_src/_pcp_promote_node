#compdef pcp_promote_node
# Documentation: https://man.archlinux.org/search?q=pcp_promote_node
# Reference accessed: 2026-05-16

# pcp_promote_node: promote a Pgpool standby to primary
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "(- *)-V[show version]" \
  "--version[show version]" \
  "-w[no password prompt]" \
  "--no-password[no password prompt]" \
  "-W[force password prompt]" \
  "--password[force password prompt]" \
  "-d[debug]" \
  "--debug[debug]" \
  "-v[verbose]" \
  "--verbose[verbose]" \
  "-U[username]:user:_users" \
  "--username=[username]:user:_users" \
  "-H[pgpool host]:host:_hosts" \
  "--host=[pgpool host]:host:_hosts" \
  "-p[pcp port]:port:" \
  "--port=[pcp port]:port:" \
  "-s[scope]:scope:" \
  "--scope=[scope]:scope:" \
  "-n[node id]:n:" "--node-id=[node id]:n:" "-g[promote gracefully]" "--gracefully[promote gracefully]" \
  '*::pcp_promote_node args:_files' && ret=0
return ret
