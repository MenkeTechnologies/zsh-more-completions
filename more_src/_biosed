#compdef biosed
# Documentation: https://man.archlinux.org/search?q=biosed
# Reference accessed: 2026-05-16

# EMBOSS biosed: replace base/residue strings inside sequences (sed-like)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-target=[target string to find]:string:' \
  '-replace=[replacement string]:string:' \
  '-position=[position to replace at (0=all)]:pos:' \
  '-delete[delete the target instead of replace]' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output format]:format:(fasta embl genbank swiss gcg pir raw msf text)' \
  '*:sequence USA:_files' && ret=0
return ret
