#compdef lens
# _lens — Lens Kubernetes IDE CLI (lensapp/lens)
# upstream: https://github.com/lensapp/lens

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--disable-gpu[disable GPU acceleration]' \
  '--disable-lcd-text[disable LCD text rendering]' \
  '--force-renderer-accessibility[force accessibility in renderer]' \
  '--no-sandbox[disable sandbox]' \
  '--inspect=[open DevTools on port]:port:' \
  '--remote-debugging-port=[port for remote debugging]:port:' \
  '*:file:_files'
