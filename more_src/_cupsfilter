#compdef cupsfilter
# Documentation: cupsfilter --help (CUPS 26)
# Source: convert a file via the CUPS filter chain into PDF, raster, etc.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--list-filters[list filters that will be used]' \
    '-D[remove the input file when finished]' \
    '-P+[PPD file]:ppd:_files -g "*.ppd"' \
    '-U+[username]:user:_users' \
    '-c+[cups-files.conf to use]:file:_files' \
    '-d+[destination printer]:printer:' \
    '-e[use every filter from the PPD]' \
    '-i+[input MIME type]:mime type:' \
    '-j+[filter file N from the specified job (job-id[,N])]:job:' \
    '-m+[output MIME type (default application/pdf)]:mime type:' \
    '-n+[number of copies]:copies:' \
    '*-o+[option name=value]:option:' \
    '-p+[PPD file]:ppd:_files -g "*.ppd"' \
    '-t+[title]:title:' \
    '-u[remove the PPD file when finished]' \
    '1:input file:_files' \
    && ret=0

return ret
