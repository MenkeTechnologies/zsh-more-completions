#compdef zabbix-server zabbix_server
# Documentation: https://manpages.debian.org/bookworm/zabbix-server-mysql/zabbix_server.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm zabbix_server(8) manpage.

# zabbix-server: Zabbix monitoring server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[alternate config file]:file:_files' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-R --runtime-control)'{-R,--runtime-control=}'[runtime option]:opt:(config_cache_reload snmp_cache_reload housekeeper_execute diaginfo prof_enable prof_disable log_level_increase log_level_decrease ha_status ha_remove_node ha_set_failover_delay secrets_reload trigger_housekeeper_execute)' && ret=0
return ret
