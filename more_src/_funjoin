#compdef funjoin
# Documentation: https://linux.die.net/man/1/funjoin
# funjoin - join two or more FITS binary tables on specified columns

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a[columns to activate in all files]:cols' \
  '-b[blank values for common columns in all files]:blanks' \
  '-j[column to join in all files]:col' \
  '-m[minimum matches to output a row]:min' \
  '-M[maximum matches to output a row]:max' \
  '-s[add jfiles status column]' \
  '-S[add named status column]:col' \
  '-t[tolerance for joining numeric cols]:tol' \
  '*:fits table:_files' && ret=0

return ret
