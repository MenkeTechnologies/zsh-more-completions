#compdef probe-run

_arguments -s \
  '--chip=[target chip]:chip:' \
  '--probe=[probe selector VID:PID[:SERIAL]]:probe:' \
  '--list-chips[list supported chips]' \
  '--list-probes[list connected probes]' \
  '--backtrace=[backtrace policy]:policy:(always never auto)' \
  '--backtrace-limit=[max backtrace frames]:n:' \
  '--force-backtrace[force backtrace at exit]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  ':elf:_files'
