#compdef cifuzz

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(--help)--help[show help]' \
  '(--verbose)--verbose[enable verbose output]' \
  '(--json)--json[output as JSON]' \
  '(--no-notifications)--no-notifications[disable notifications]' \
  '1:command:->commands' \
  '*::arg:->args' \
  && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize a project for fuzz testing'
      'create:create a new fuzz test'
      'run:run a fuzz test'
      'coverage:generate coverage report'
      'finding:manage findings'
      'bundle:bundle fuzz tests'
      'remote-run:run fuzz tests remotely'
      'login:authenticate with CI Fuzz server'
    )
    _describe -t commands 'cifuzz command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments \
          '--project-dir[project directory]:directory:_directories' \
          '--type[project type]:type:(cmake maven gradle bazel other)' \
          '--help[show help]' \
          && ret=0
        ;;
      create)
        _arguments \
          '--output[output file path]:file:_files' \
          '--type[fuzz test type]:type:(cpp java kotlin)' \
          '--help[show help]' \
          && ret=0
        ;;
      run)
        _arguments \
          '--build-only[only build, do not run]' \
          '--seed-corpus[seed corpus directory]:directory:_directories' \
          '--timeout[timeout duration]:timeout' \
          '--use-sandbox[run in sandbox]' \
          '--engine[fuzzing engine]:engine:(libfuzzer jazzer)' \
          '--dict[dictionary file]:file:_files' \
          '--help[show help]' \
          '*:fuzz test' \
          && ret=0
        ;;
      coverage)
        _arguments \
          '--help[show help]' \
          '*:fuzz test' \
          && ret=0
        ;;
      finding)
        _arguments \
          '--help[show help]' \
          && ret=0
        ;;
      bundle)
        _arguments \
          '--help[show help]' \
          '*:fuzz test' \
          && ret=0
        ;;
      remote-run)
        _arguments \
          '--help[show help]' \
          '*:fuzz test' \
          && ret=0
        ;;
      login)
        _arguments \
          '--help[show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
