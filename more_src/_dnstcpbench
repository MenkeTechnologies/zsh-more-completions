#compdef dnstcpbench
# Documentation: https://doc.powerdns.com/authoritative/manpages/dnstcpbench.1.html
# Send DNS queries in parallel to a nameserver over TCP, with optional UDP fallback

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '(-f --file)'{-f,--file}'[read queries from file instead of stdin]:file:_files' \
  '--timeout-msec[timeout in ms waiting on responses]:msec:' \
  '(-u --udp-first)'{-u,--udp-first}'[try UDP first, fall back to TCP if truncated]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--workers[number of parallel worker threads]:num:' \
  '1:remote-address:_hosts' \
  '2:remote-port:_ports' && ret=0

return ret
