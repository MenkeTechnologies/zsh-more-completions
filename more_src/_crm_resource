#compdef crm_resource
# Documentation: https://www.mankier.com/8/crm_resource
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crm_resource: Pacemaker resource administration
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-output[show output help]' \
  '(- *)--help-queries[show query help]' \
  '(- *)--help-commands[show command help]' \
  '(- *)--help-locations[show location help]' \
  '(- *)--help-advanced[show advanced option help]' \
  '(- *)--help-additional[show additional options]' \
  '(- *)'{-\$,--version}'[display software version]' \
  '*'{-V,--verbose}'[increase debug output]' \
  '(-Q --quiet)'{-Q,--quiet}'[be less descriptive in output]' \
  '--output-as=[output format]:fmt:(text xml)' \
  '--output-to=[output file (- for stdout)]:file:_files' \
  '(-L --list)'{-L,--list}'[list all cluster resources with status]' \
  '(-l --list-raw)'{-l,--list-raw}'[list IDs of all instantiated resources]' \
  '(-O --list-operations)'{-O,--list-operations}'[list active resource operations]' \
  '(-o --list-all-operations)'{-o,--list-all-operations}'[list all resource operations]' \
  '--list-options=[list available options]:type:(cluster)' \
  '--list-standards[list supported standards]' \
  '--list-ocf-providers[list available OCF providers]' \
  '--list-agents=[list agents for standard/provider]:spec:' \
  '--list-ocf-alternatives=[list providers for named OCF agent]:agent:' \
  '--show-metadata=[show metadata for class:provider:agent]:spec:' \
  '(-q --query-xml)'{-q,--query-xml}'[show XML config (after template expansion)]' \
  '(-w --query-xml-raw)'{-w,--query-xml-raw}'[show XML config (before template expansion)]' \
  '(-g --get-parameter)'{-g+,--get-parameter=}'[display named parameter]:name:' \
  '(-W --locate)'{-W,--locate}'[show nodes currently running resource]' \
  '(-a --constraints)'{-a,--constraints}'[display location/colocation constraints]' \
  '(-A --stack)'{-A,--stack}'[equivalent to --constraints --recursive]' \
  '(-Y --why)'{-Y,--why}'[show why resources are not running]' \
  '--validate=[validate config by calling agent validate-all]:level:' \
  '(-C --cleanup)'{-C,--cleanup}'[clear resource history and fail count]' \
  '(-R --refresh)'{-R,--refresh}'[delete resource history to recheck state]' \
  '(-p --set-parameter)'{-p+,--set-parameter=}'[set named parameter (requires -v)]:name:' \
  '(-d --delete-parameter)'{-d+,--delete-parameter=}'[delete named parameter]:name:' \
  '(-M --move)'{-M,--move}'[create constraint to move resource]' \
  '(-B --ban)'{-B,--ban}'[create constraint to keep resource off node]' \
  '(-U --clear)'{-U,--clear}'[remove constraints from --ban or --move]' \
  '(-e --expired)'{-e,--expired}'[modify --clear to remove expired constraints]' \
  '(-u --lifetime)'{-u+,--lifetime=}'[lifetime of created constraints (ISO 8601)]:duration:' \
  '--promoted[limit scope to promoted role]' \
  '--master[deprecated: use --promoted]' \
  '(-D --delete)'{-D,--delete}'[delete a resource from the CIB]' \
  '(-F --fail)'{-F,--fail}'[tell cluster this resource has failed]' \
  '--restart[restart resource and dependencies]' \
  '--wait[wait until cluster settles]' \
  '--digests[show parameter hashes Pacemaker uses]' \
  '--force-demote[bypass cluster and demote on local node]' \
  '--force-stop[bypass cluster and stop on local node]' \
  '--force-start[bypass cluster and start on local node]' \
  '--force-promote[bypass cluster and promote on local node]' \
  '--force-check=[bypass cluster and check resource]:level:' \
  '(-N --node)'{-N+,--node=}'[node name]:node:' \
  '--recursive[follow colocation chains]' \
  '(-t --resource-type)'{-t+,--resource-type=}'[resource XML element]:type:(primitive group clone master bundle)' \
  '(-v --parameter-value)'{-v+,--parameter-value=}'[value for -p]:value:' \
  '(-m --meta)'{-m,--meta}'[use resource meta-attribute]' \
  '(-z --utilization)'{-z,--utilization}'[use resource utilization attribute]' \
  '--element[use resource element attribute]' \
  '(-n --operation)'{-n+,--operation=}'[operation to clear]:op:(monitor start stop promote demote migrate_to migrate_from notify)' \
  '(-I --interval)'{-I+,--interval=}'[interval of operation to clear]:interval:' \
  '--class=[standard the agent conforms to]:class:' \
  '--agent=[agent to use]:agent:' \
  '--provider=[vendor supplying the agent]:provider:' \
  '*--option=[device configuration parameter NAME=VALUE]:param:' \
  '(-s --set-name)'{-s+,--set-name=}'[XML ID of attributes element]:id:' \
  '(-i --nvpair)'{-i+,--nvpair=}'[XML ID of nvpair element]:id:' \
  '(-T --timeout)'{-T+,--timeout=}'[abort if command not finished in this time]:n:' \
  '--all[list all options including advanced/deprecated]' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '(-r --resource)'{-r+,--resource=}'[resource ID]:resource:' && ret=0
return ret
