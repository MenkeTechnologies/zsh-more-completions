#compdef crm_resource

# Pacemaker crm_resource: manage cluster resources
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-Q --quiet)'{-Q,--quiet}'[quiet]' \
  '(-L --list)'{-L,--list}'[list resources]' \
  '(-O --list-operations)'{-O,--list-operations}'[list active resource operations]' \
  '(-o --list-all-operations)'{-o,--list-all-operations}'[list all operations]' \
  '(-l --list-instances)'{-l,--list-instances}'[list instances]' \
  '(-W --locate)'{-W,--locate}'[show where the resource is running]' \
  '(-A --constraints)'{-A,--constraints}'[show constraints involving resource]' \
  '(-Y --why)'{-Y,--why}'[show why resource is not running]' \
  '(-q --query-xml)'{-q,--query-xml}'[show resource XML]' \
  '(-w --query-xml-raw)'{-w,--query-xml-raw}'[show raw resource XML]' \
  '(-c --cleanup)'{-c,--cleanup}'[clean up resource state]' \
  '(-C --refresh)'{-C,--refresh}'[refresh resource state on all nodes]' \
  '(-D --delete)'{-D,--delete}'[delete resource from CIB]' \
  '(-r --resource)'{-r,--resource=}'[resource id]:resource:' \
  '(-N --node)'{-N,--node=}'[node name]:node:' \
  '(-t --resource-type)'{-t,--resource-type=}'[resource type filter]:type:' \
  '(-T --target-role)'{-T,--target-role=}'[set target role]:role:(Started Stopped Promoted Demoted Master Slave)' \
  '(-B --ban)'{-B,--ban}'[ban from node]' \
  '(-U --clear)'{-U,--clear}'[clear bans/moves]' \
  '(-M --move)'{-M,--move}'[move resource to a node]' \
  '(-R --restart)'{-R,--restart}'[restart resource]' \
  '(-p --parameter)'{-p,--parameter=}'[parameter name]:name:' \
  '(-v --parameter-value)'{-v,--parameter-value=}'[parameter value]:val:' \
  '(-d --delete-parameter)'{-d,--delete-parameter=}'[delete parameter]:name:' \
  '(-g --get-parameter)'{-g,--get-parameter=}'[get parameter]:name:' \
  '(-e --meta)'{-e,--meta}'[use meta-attribute instead of parameter]' \
  '(-z --utilization)'{-z,--utilization}'[use utilization attribute]' \
  '(-s --set-name)'{-s,--set-name=}'[set name]:set:' \
  '(-i --id)'{-i,--id=}'[XML id]:id:' \
  '(-S --class)'{-S,--class=}'[resource class]:class:' \
  '(-P --provider)'{-P,--provider=}'[resource provider]:provider:' \
  '(-x --xml-file)'{-x,--xml-file=}'[XML file]:file:_files' \
  '(-X --interval)'{-X,--interval=}'[operation interval (msec)]:msec:' \
  '*::crm_resource args:_files' && ret=0
return ret
