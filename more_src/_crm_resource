#compdef crm_resource
# Documentation: https://man.archlinux.org/search?q=crm_resource
# Reference accessed: 2026-05-16

# crm_resource: pacemaker resource administration
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '-Q[quiet]' \
  '--quiet[quiet]' \
  '-L[list known resources]' \
  '--list[list known resources]' \
  '-l[list resource raw]' \
  '--list-raw[list resource raw]' \
  '-O[list operations history]' \
  '--list-operations[list operations history]' \
  '-o[list orphaned operations]' \
  '--list-all-operations[list orphaned operations]' \
  '-q[query resource definition]' \
  '--query-xml[query resource definition]' \
  '-w[query raw definition]' \
  '--query-xml-raw[query raw definition]' \
  '-W[locate resource on nodes]' \
  '--locate[locate resource on nodes]' \
  '-A[show resource constraint info]' \
  '--constraints[show resource constraint info]' \
  '-Y[stack of resources containing this one]' \
  '--stack[stack of resources containing this one]' \
  '-c[clear failure counters]' \
  '--cleanup[clear failure counters]' \
  '-C[clear failures]' \
  '--refresh[refresh state]' \
  '-r[resource name]:resource:' \
  '--resource=[resource name]:resource:' \
  '-N[node name]:node:' \
  '--node=[node name]:node:' \
  '-t[resource type]:type:(primitive group clone master bundle)' \
  '--resource-type=[resource type]:type:(primitive group clone master bundle)' \
  '-v[parameter value]:value:' \
  '--set-parameter=[parameter name]:name:' \
  '--get-parameter=[parameter name]:name:' \
  '--delete-parameter=[parameter name]:name:' \
  '-M[move resource (preferred node)]' \
  '--move[move resource (preferred node)]' \
  '-B[ban resource from node]' \
  '--ban[ban resource from node]' \
  '-U[clear move/ban constraints]' \
  '--clear[clear move/ban constraints]' \
  '-T[migration timeout]:seconds:' \
  '--timeout=[migration timeout]:seconds:' \
  '-d[delete resource]' \
  '--delete[delete resource]' \
  '-f[force operation]' \
  '--force[force operation]' \
  '--force-start[force start without normal precondition checks]' \
  '--force-stop[force stop without normal precondition checks]' \
  '--force-check[force check]' \
  '--force-promote[force promote]' \
  '--force-demote[force demote]' \
  '--restart[restart resource]' \
  '--wait[wait for operation to complete]' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '*::crm_resource args:_files' && ret=0
return ret
