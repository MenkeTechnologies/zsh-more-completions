#compdef bcoin bcoin-cli bcoin-wallet bwallet bwallet-cli
# Documentation: https://github.com/bcoin-org/bcoin/blob/master/bin/bcoin
# Documentation: https://github.com/bcoin-org/bcoin/blob/master/bin/bcoin-cli
# Documentation: https://github.com/bcoin-org/bcoin/blob/master/lib/node/node.js
# Documentation: https://github.com/bcoin-org/bcoin/blob/master/lib/node/fullnode.js
# Documentation: https://bcoin.io/docs
# Reference accessed: 2026-05-27
# Verified: upstream bcoin-org/bcoin bin/ launchers and lib/node/{node,fullnode}.js config keys

# Zsh completion for bcoin (Node.js Bitcoin implementation),
# bcoin-cli (node REST client) and bcoin-wallet (wallet REST client).

local curcontext="$curcontext" state line ret=1

local -a _bcoin_subcommands
_bcoin_subcommands=(
  'cli:dispatch to bcoin-cli'
  'wallet:dispatch to bcoin-cli wallet subcommand'
  'rpc:dispatch to bcoin-cli rpc subcommand'
)

local -a _bcoin_cli_methods
_bcoin_cli_methods=(
  'info:get node info'
  'broadcast:broadcast a raw transaction'
  'mempool:get current mempool snapshot or tx list'
  'tx:lookup transaction by hash or address'
  'coin:lookup unspent coins by hash or address'
  'block:lookup block by hash or height'
  'header:lookup block header by hash or height'
  'filter:lookup compact block filter'
  'fee:estimate fee for n blocks'
  'reset:reset the chain to a given height'
  'rpc:invoke an arbitrary RPC method'
)

local -a _bwallet_cli_methods
_bwallet_cli_methods=(
  'mkwallet:create a new wallet'
  'account:wallet account operations'
  'address:create a new receiving address'
  'change:create a new change address'
  'shared:add a shared key to a multisig wallet'
  'balance:get wallet balance'
  'history:get wallet transaction history'
  'pending:get pending wallet transactions'
  'view:view a specific transaction'
  'master:get master HD key'
  'mkauth:generate a wallet token'
  'mktoken:generate a new token'
  'send:send to address'
  'mktx:create an unsigned transaction'
  'sign:sign an unsigned transaction'
  'fill:fill a transaction with coins'
  'zap:zap stale transactions'
  'unlock:unlock the wallet'
  'lock:lock the wallet'
  'resend:resend pending transactions'
  'rpc:invoke an arbitrary wallet RPC'
)

case "$service" in
  bcoin-cli|cli)
    _arguments -s -S \
      '(-n --network)'{-n+,--network=}'[bitcoin network]:net:(main testnet regtest simnet)' \
      '(-u --url --uri)'{-u+,--url=,--uri=}'[node URL]:url:' \
      '(-k --api-key)'{-k+,--api-key=}'[api key]:key:' \
      '(-s --ssl)'{-s,--ssl}'[use ssl]' \
      '(-h --httphost)'{-h+,--httphost=}'[http host]:host:' \
      '(-p --httpport)'{-p+,--httpport=}'[http port]:port:' \
      '--timeout=[request timeout in ms]:ms:' \
      '1: :->cmd' \
      '*:: :->args' && ret=0

    case $state in
      cmd) _describe -t commands 'bcoin-cli method' _bcoin_cli_methods && ret=0 ;;
      args) _arguments '*: :' && ret=0 ;;
    esac
    return ret
    ;;
  bcoin-wallet|bwallet-cli|bwallet)
    _arguments -s -S \
      '(-n --network)'{-n+,--network=}'[bitcoin network]:net:(main testnet regtest simnet)' \
      '(-u --url --uri)'{-u+,--url=,--uri=}'[wallet URL]:url:' \
      '(-k --api-key)'{-k+,--api-key=}'[api key]:key:' \
      '(-t --token)'{-t+,--token=}'[wallet token]:token:' \
      '(-s --ssl)'{-s,--ssl}'[use ssl]' \
      '(-h --httphost)'{-h+,--httphost=}'[http host]:host:' \
      '(-p --httpport)'{-p+,--httpport=}'[http port]:port:' \
      '(-i --id)'{-i+,--id=}'[wallet id]:id:' \
      '(-a --account)'{-a+,--account=}'[wallet account]:account:' \
      '--timeout=[request timeout in ms]:ms:' \
      '1: :->cmd' \
      '*:: :->args' && ret=0

    case $state in
      cmd) _describe -t commands 'bcoin-wallet method' _bwallet_cli_methods && ret=0 ;;
      args) _arguments '*: :' && ret=0 ;;
    esac
    return ret
    ;;
esac

# bcoin (full node / spvnode) launcher options. The launcher dispatches `cli`,
# `wallet`, and `rpc` to bcoin-cli; all other args flow through to the node
# (FullNode or SPVNode) via bcfg argv parsing.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '--daemon[run node in background as a daemon]' \
  '--spv[run as SPV node instead of full node]' \
  '(-n --network)'{-n+,--network=}'[bitcoin network]:net:(main testnet regtest simnet)' \
  '--prefix=[data directory prefix]:dir:_files -/' \
  '--config=[config file path]:file:_files' \
  '--memory=[run in-memory (no on-disk databases)]:bool:(true false)' \
  '--workers=[enable worker processes]:bool:(true false)' \
  '--workers-size=[number of worker processes]:n:' \
  '--workers-timeout=[worker process timeout in ms]:ms:' \
  '--worker-file=[path to worker bootstrap file]:file:_files' \
  '--log-level=[log level]:level:(none error warning info debug spam)' \
  '--log-console=[log to console]:bool:(true false)' \
  '--log-file=[log to file]:bool:(true false)' \
  '--log-shrink=[truncate log files on startup]:bool:(true false)' \
  '--log-max-files=[max log files to retain]:n:' \
  '--log-max-file-size=[max log file size in MB]:mb:' \
  '--prune[prune the blockchain]' \
  '--checkpoints=[use embedded checkpoints during sync]:bool:(true false)' \
  '--index-tx[index full transaction set]' \
  '--index-address[index transactions by address]' \
  '--index-filter[index compact block filters (BIP157)]' \
  '--max-files=[max open chain files]:n:' \
  '--cache-size=[chain cache size in MB]:mb:' \
  '--entry-cache=[chain entry cache size]:n:' \
  '--block-cache-size=[block cache size in MB]:mb:' \
  '--mempool-size=[max mempool size in MB]:mb:' \
  '--persistent-mempool=[persist mempool across restarts]:bool:(true false)' \
  '--limit-free=[limit free transactions]:bool:(true false)' \
  '--limit-free-relay=[free transactions to relay per block]:n:' \
  '--require-standard=[only accept standard transactions]:bool:(true false)' \
  '--reject-absurd-fees=[reject txs with absurd fees]:bool:(true false)' \
  '--replace-by-fee=[allow BIP125 RBF]:bool:(true false)' \
  '--bip37=[advertise BIP37 bloom filter support]:bool:(true false)' \
  '--bip91=[enforce BIP91 segwit signaling]:bool:(true false)' \
  '--bip148=[enforce BIP148 UASF rules]:bool:(true false)' \
  '--bip157=[serve BIP157 compact filters]:bool:(true false)' \
  '--compact=[serve as a compact-block relay]:bool:(true false)' \
  '--listen=[listen for incoming peer connections]:bool:(true false)' \
  '--host=[host to bind p2p socket]:host:' \
  '--port=[p2p listen port]:port:' \
  '--public-host=[advertised public host]:host:' \
  '--public-port=[advertised public port]:port:' \
  '--max-inbound=[max inbound peers]:n:' \
  '--max-outbound=[max outbound peers]:n:' \
  '*--nodes=[manually specified peer addresses]:host\:port:' \
  '*--only=[connect only to these peers]:host\:port:' \
  '*--seeds=[DNS seed hosts]:host:' \
  '--proxy=[SOCKS5 proxy]:host\:port:' \
  '--onion=[allow connections to Tor onion peers]:bool:(true false)' \
  '--upnp=[use UPnP to forward p2p port]:bool:(true false)' \
  '--preverify=[preverify peer signatures]:bool:(true false)' \
  '--selfish=[run as a selfish miner peer]:bool:(true false)' \
  '--force-flags=[force script verification flags]:bool:(true false)' \
  '--coinbase-flags=[coinbase script flags]:str:' \
  '*--coinbase-address=[coinbase payout addresses]:address:' \
  '--max-txs=[max txs returned by indexer queries]:n:' \
  '--max-weight=[max template weight]:n:' \
  '--reserved-sigops=[reserved sigops for miner]:n:' \
  '--reserved-weight=[reserved weight for miner]:n:' \
  '--http-host=[HTTP server bind host]:host:' \
  '--http-port=[HTTP server bind port]:port:' \
  '--ssl=[enable HTTP TLS]:bool:(true false)' \
  '--ssl-cert=[TLS cert file]:file:_files' \
  '--ssl-key=[TLS key file]:file:_files' \
  '--cors=[enable HTTP CORS]:bool:(true false)' \
  '--api-key=[HTTP API key]:key:' \
  '--no-auth=[disable HTTP basic auth]:bool:(true false)' \
  '--index-prefix=[prefix directory for indexers]:dir:_files -/' \
  '--no-wallet[disable bundled wallet plugin]' \
  '--plugins=[comma separated list of plugin modules]:plugins:' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'bcoin subcommand' _bcoin_subcommands && ret=0 ;;
  args) _arguments '*: :' && ret=0 ;;
esac

return ret
