# impacket-goldenpac: PAC exploit (MS14-068 forged Kerberos ticket).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-c[upload file for later execution]:file:_files' \
  '-w[write golden ticket to CCache file]:file:_files' \
  '-dc-ip[domain controller IP]:ip:' \
  '-target-ip[target host IP]:ip:' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '*::positional:_files' && ret=0
return ret
