#compdef impacket-goldenpac

# Impacket goldenPac.py: MS14-068 exploit (golden PAC ticket)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-target[target FQDN]:target:' \
  '-target-ip[target IP]:ip:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-command[command to run]:cmd:' \
  '-codec[encoding]:codec:' \
  '*:domain/user[:password]:' && ret=0
return ret
