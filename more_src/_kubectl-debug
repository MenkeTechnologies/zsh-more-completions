#compdef kubectl-debug

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--image[container image for the debug container]:image:' \
  '--target[target container to debug]:container:' \
  '--set-image[set container images]:container=image:' \
  '--copy-to[create a copy of the target pod]:name:' \
  '--replace[kill the target pod and replace with the debug pod]' \
  '--same-node[schedule copy pod on same node as target]' \
  '--share-processes[enable process namespace sharing in the copy]' \
  '--env[set environment variables]:key=value:' \
  '-i[keep stdin open]' \
  '-t[allocate a TTY]' \
  '--attach[attach to the debug container]' \
  '--container[debug container name]:name:' \
  '-n[namespace]:namespace:' \
  '--profile[debugging profile]:profile:(general baseline netadmin restricted)' \
  '--custom[path to custom profile JSON]:file:_files -g "*.json"' \
  '--quiet[suppress informational messages]' \
  '1:pod name:' && ret=0

return ret
