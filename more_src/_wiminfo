#compdef wiminfo
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-info.1.html
# wiminfo — display or change information about a WIM file or image

local ret=1

_arguments -s -S \
  '--boot[mark the specified image as bootable]' \
  '--check[verify WIM integrity and add integrity info if modifying]' \
  '--nocheck[remove extra integrity info when modifying]' \
  '--include-integrity[add integrity info without prior verification]' \
  '*--image-property=[assign arbitrary XML property to an image]:name=value' \
  '--header[display detailed WIM header information]' \
  '--blobs[list all unique file data in the WIM]' \
  '--extract-xml=[save the WIM XML document to a file]:file:_files' \
  '--xml[output the WIM raw XML document to stdout]' \
  '*:WIM file:_files' && ret=0

return ret
