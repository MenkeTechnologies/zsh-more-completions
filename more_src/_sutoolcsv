#compdef sutoolcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/sutoolcsv.c
# SUTOOLCSV - tools for comma separated values and fixed text files

local ret=1

_arguments -s -S \
  'rfile=[read input text file]:f:_files' \
  'wfile=[write output text file]:f:_files' \
  'rtype=[record type to read]:r:' \
  'rdelim=[record field delimiter]:r:' \
  'wtype=[record type to write]:w:' \
  'names=[list of field names]:n:' \
  'forms=[output field formats]:f:' \
  'width=[output field widths]:w:' \
  'match=[key names to match]:m:' \
  'process=[processing action]:p:' \
  'outid=[output record identifier]:o:' \
  'setid=[record identifier value]:s:' \
  'maxrecords=[maximum records to read]:m:' \
  'nicerecord=[record number to print nicely]:n:' \
  'scalco=[coordinate scale factor]:s:' \
  'scalel=[elevation scale factor]:s:' \
  'unrepeat=[unrepeat field values]:u:' \
  '*:SU file:_files' && ret=0

return ret
