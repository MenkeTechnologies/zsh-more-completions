#   `slowtec/tokio-modbus` is **THE canonical Rust Modbus
#   library** — Markus Kohlhase's reference Rust implementation
#   of the Modbus Application Protocol (both Modbus TCP and
#   Modbus RTU framing) on the Tokio async runtime, the de-
#   facto Rust Modbus dependency on crates.io with 500+ ★ on
#   GitHub and 800,000+ all-time downloads on crates.io.  It
#   exposes:
#
#     • Typed `tokio_modbus::client::tcp::connect(socket_addr)`
#       /  `tcp::connect_slave(socket_addr, slave)` /
#       `tcp::connect_with_timeout(socket_addr, timeout)` typed
#       TCP-transport client builders (RFC-compliant Modbus
#       TCP with the typed MBAP transaction-ID handling)
#     • Typed `tokio_modbus::client::rtu::attach(serial)` /
#       `rtu::attach_slave(serial, slave)` typed RTU-transport
#       client builders (typed inter-frame silence + CRC-16
#       handling)
#     • Typed `Client` trait with `client.read_coils(addr,
#       quantity)` (function code 0x01) /  `client.read_discrete_inputs
#       (addr, quantity)` (0x02) /  `client.read_holding_registers
#       (addr, quantity)` (0x03) /  `client.read_input_registers
#       (addr, quantity)` (0x04) /  `client.write_single_coil
#       (addr, val)` (0x05) /  `client.write_single_register
#       (addr, val)` (0x06) /  `client.read_exception_status()`
#       (0x07) /  `client.diagnostics(subfn, data)` (0x08) /
#       `client.write_multiple_coils(addr, vals)` (0x0F) /
#       `client.write_multiple_registers(addr, vals)` (0x10) /
#       `client.report_server_id()` (0x11) /
#       `client.mask_write_register(addr, and_mask, or_mask)`
#       (0x16) /  `client.read_write_multiple_registers(read_addr,
#       read_qty, write_addr, write_vals)` (0x17) /
#       `client.read_fifo_queue(addr)` (0x18) /
#       `client.encapsulated_interface_transport(mei_type, data)`
#       (0x2B) /  `client.custom(function, data)` typed function-
#       code dispatchers
#     • Typed `Slave(u8)` (RTU device address) /
#       `SlaveContext` typed slave-addressing primitives
#     • Typed `tokio_modbus::server::tcp::Server` /
#       `server::rtu::Server` /  `server::Service` typed
