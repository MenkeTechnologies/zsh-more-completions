_modbus_proxy() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '(-p --proxy-port)'{-p,--proxy-port}'=[proxy TCP port listening for clients (default 502)]:port:' \
        '(-b --proxy-addr)'{-b,--proxy-addr}'=[local IP address of proxy (binds all interfaces if omitted)]:ip:' \
        '(-t --request-delay)'{-t,--request-delay}'=[minimum ms delay between requests to upstream]:ms:' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _mp_cmds=(
                'tcp:forward to an upstream Modbus TCP server'
                'rtu:forward to an upstream Modbus RTU device on a local serial port'
            )
            _describe -t commands 'modbus_proxy transport' _mp_cmds && ret=0
            ;;
        args)
            case $words[1] in
                tcp)
                    _arguments \
                        '1:upstream Modbus TCP server IP:' \
                        '--server-port=[upstream Modbus TCP port (default 502)]:port:' && ret=0
                    ;;
                rtu)
                    _arguments \
                        '1:serial device:_files -g "/dev/tty*"' \
                        '(-s --serial-speed)'{-s,--serial-speed}'=[serial speed (bps)]:bps:(1200 2400 4800 9600 19200 38400 57600 115200)' \
                        '(-o --odd-parity)'{-o,--odd-parity}'[select odd parity]' \
                        '(-e --even-parity)'{-e,--even-parity}'[select even parity (conflicts with --odd-parity)]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_modbus_proxy "$@"
