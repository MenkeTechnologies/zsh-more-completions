#compdef bonnie++

# Zsh completion for bonnie++ (filesystem benchmark)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d[directory for test files]:directory:_files -/' \
  '-s[size of test file in MiB]:size' \
  '-n[number of files for file creation test]:num\:max\:min\:num_dirs' \
  '-m[machine name]:machine name' \
  '-r[RAM size in MiB]:MiB' \
  '-x[number of test runs]:count' \
  '-u[user to run as]:user:_users' \
  '-g[group to run as]:group:_groups' \
  '-q[quiet mode]' \
  '-f[fast mode (skip per-char I/O tests)]' \
  '-b[no write buffering]' \
  '-D[use direct I/O]' \
  '-p[number of processes for semaphore test]:processes' \
  '-y[perform sync before each test]:sync:(s n)' \
  '-z[seed random number generator]:seed' \
  '-Z[enable zero-fill for read test]' \
  '-h[show help]' \
  '-V[show version]' && ret=0

return ret
