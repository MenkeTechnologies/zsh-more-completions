#compdef zenoh-bridge-ros2dds
# Documentation: https://github.com/eclipse-zenoh/zenoh-plugin-ros2dds
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (only -c, -e, -h, --rest-http-port
# are explicitly enumerated by the README; remaining flags are inherited from
# the shared zenoh-bridge skeleton).

# Zenoh ROS 2 DDS bridge: bridge ROS 2 DDS to Zenoh
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files -g "*.json5"' \
  '(-m --mode)'{-m,--mode=}'[session mode]:mode:(peer client)' \
  '*'{-l,--listen=}'[listen endpoint locator]:endpoint:' \
  '*'{-e,--peer=}'[peer locator to connect to]:endpoint:' \
  '--no-multicast-scouting[disable automatic peer/router discovery]' \
  '(-i --id)'{-i,--id=}'[unique zenoh ID hex]:hex:' \
  '--rest-http-port=[REST API HTTP port]:port:' && ret=0
return ret
