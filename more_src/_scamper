#compdef scamper

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help information]' \
  '(- *)--version[show version information]' \
  '-c[command to execute]:command:(trace ping dealias tbit sting sniff host neighbourdisc tracelb)' \
  '-p[packets per second rate limit]:pps:' \
  '-w[probe window size]:window:' \
  '-M[monitor name]:name:' \
  '-l[list name]:name:' \
  '-L[list ID]:id:' \
  '-C[cycle ID]:id:' \
  '-o[output file]:output file:_files' \
  '-O[output format options]:format:(text warts json)' \
  '-i[target IP address]:address:_hosts' \
  '-I[input address list file]:input file:_files' \
  '-f[firewall rule management]:firewall:' \
  '-d[debug level]:level:' \
  '-e[run command for each result]:command:_command_names' \
  '-D[daemonize]' \
  '-P[port to listen on]:port:' \
  '-R[Unix domain socket path]:socket:_files' \
  '*:target address:_hosts' && ret=0

return ret
