autoload -U is-at-least

_kabu() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_kabu_commands" \
"*::: :->kabu" \
&& ret=0
    case $state in
    (kabu)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kabu-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
'--on-conflict=[How to handle conflicts\: abort, skip, overwrite, backup]:MODE:_default' \
'-b+[Create a new branch <name> starting at <commitish>]:name:_default' \
'-B+[Create or reset branch <name> to <commitish>]:name:_default' \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'-i[Interactive mode\: select branch and path interactively]' \
'--interactive[Interactive mode\: select branch and path interactively]' \
'--dry-run[Preview actions without executing]' \
'--no-setup[Skip config file setup, run worktree/workspace add only]' \
'-f[Force creation even if branch is checked out elsewhere]' \
'--force[Force creation even if branch is checked out elsewhere]' \
'-d[Detach HEAD in the new worktree/workspace]' \
'--detach[Detach HEAD in the new worktree/workspace]' \
'--no-checkout[Do not checkout after creation]' \
'--lock[Lock the worktree after creation (git only)]' \
'--track[Set up tracking for the branch]' \
'--no-track[Do not set up tracking]' \
'--guess-remote[Guess remote for tracking]' \
'--no-guess-remote[Do not guess remote]' \
'-q[Suppress output]' \
'--quiet[Suppress output]' \
'--no-color[Disable colored output (equivalent to --color=never)]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Path for the new worktree/workspace (required unless --interactive, or path_template + branch):_files' \
'::commitish -- Branch or commit to checkout (git) / revision (jj):_default' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'-i[Interactive mode\: select worktrees/workspaces to remove]' \
'--interactive[Interactive mode\: select worktrees/workspaces to remove]' \
'-c[Remove the worktree/workspace containing the current directory]' \
'--current[Remove the worktree/workspace containing the current directory]' \
'--dry-run[Preview actions without executing]' \
'-f[Force removal even if worktree/workspace is dirty or locked]' \
'--force[Force removal even if worktree/workspace is dirty or locked]' \
'-q[Suppress output]' \
'--quiet[Suppress output]' \
'--no-color[Disable colored output (equivalent to --color=never)]' \
'-h[Print help]' \
'--help[Print help]' \
'*::paths -- Worktree/workspace paths to remove (required unless --interactive or --current):_files' \
&& ret=0
;;
(rm)
_arguments "${_arguments_options[@]}" : \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'-i[Interactive mode\: select worktrees/workspaces to remove]' \
'--interactive[Interactive mode\: select worktrees/workspaces to remove]' \
'-c[Remove the worktree/workspace containing the current directory]' \
'--current[Remove the worktree/workspace containing the current directory]' \
'--dry-run[Preview actions without executing]' \
'-f[Force removal even if worktree/workspace is dirty or locked]' \
'--force[Force removal even if worktree/workspace is dirty or locked]' \
'-q[Suppress output]' \
'--quiet[Suppress output]' \
'--no-color[Disable colored output (equivalent to --color=never)]' \
'-h[Print help]' \
'--help[Print help]' \
'*::paths -- Worktree/workspace paths to remove (required unless --interactive or --current):_files' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'-p[Show only worktree/workspace paths]' \
'--path-only[Show only worktree/workspace paths]' \
'--header[Show header row]' \
'--no-color[Disable colored output (equivalent to --color=never)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ls)
_arguments "${_arguments_options[@]}" : \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'-p[Show only worktree/workspace paths]' \
'--path-only[Show only worktree/workspace paths]' \
'--header[Show header row]' \
'--no-color[Disable colored output (equivalent to --color=never)]' \
