&& ret=0

    case $state in
    (config)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kabu-config-command-$line[1]:"
        case $line[1] in
            (validate)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(schema)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
'-f+[Config file format\: yaml or toml (default\: yaml)]:FORMAT:_default' \
'--format=[Config file format\: yaml or toml (default\: yaml)]:FORMAT:_default' \
'-p+[Custom path for the config file]:PATH:_files' \
'--path=[Custom path for the config file]:PATH:_files' \
'-g[Create global config at\:   - \$XDG_CONFIG_HOME/kabu/config.{yaml,toml} (if XDG_CONFIG_HOME is set)   - ~/.config/kabu/config.{yaml,toml} (Linux)   - ~/Library/Application Support/kabu/config.{yaml,toml} (macOS)   - %APPDATA%\\kabu\\config.{yaml,toml} (Windows)]' \
'--global[Create global config at\:   - \$XDG_CONFIG_HOME/kabu/config.{yaml,toml} (if XDG_CONFIG_HOME is set)   - ~/.config/kabu/config.{yaml,toml} (Linux)   - ~/Library/Application Support/kabu/config.{yaml,toml} (macOS)   - %APPDATA%\\kabu\\config.{yaml,toml} (Windows)]' \
'-O[Overwrite existing config file]' \
'--override[Overwrite existing config file]' \
'--with-gitignore[Create .kabu/.gitignore to exclude config from git]' \
'(--with-gitignore)--without-gitignore[Do not create .kabu/.gitignore (skip prompt)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(get)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':key -- Configuration key (e.g., auto_cd.after_remove):_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_kabu__config__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kabu-config-help-command-$line[1]:"
        case $line[1] in
            (validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(schema)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(get)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(trust)
_arguments "${_arguments_options[@]}" : \
'(--no-color)--color=[When to use colored output (always, auto, never)]:WHEN:(auto always never)' \
'-y[Trust without confirmation prompt]' \
'--yes[Trust without confirmation prompt]' \
'--show[Show trusted hooks without trusting]' \
'(--show)--check[Check trust status (exit 0 if trusted, 1 if untrusted)]' \
