(( $+functions[_kabu_commands] )) ||
_kabu_commands() {
    local commands; commands=(
'add:Add a new worktree/workspace with setup' \
'remove:Remove worktrees/workspaces with safety checks' \
'rm:Remove worktrees/workspaces with safety checks' \
'list:List all worktrees/workspaces' \
'ls:List all worktrees/workspaces' \
'path:Select a worktree/workspace and print its path' \
'cd:Change directory to a selected worktree/workspace (requires shell integration)' \
'config:Manage configuration (.kabu/config.yaml or .kabu/config.toml)' \
'trust:Trust hooks in config file for the current repository' \
'untrust:Revoke trust for hooks in config file' \
'completions:Generate shell completion script' \
'init:Print shell init script (completions + trust warning hook)' \
'man:Generate man page' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'kabu commands' commands "$@"
}
