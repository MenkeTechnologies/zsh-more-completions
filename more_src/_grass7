#compdef grass7
# Documentation: https://github.com/OSGeo/grass/blob/releasebranch_7_8/lib/init/grass.py
# Reference accessed: 2026-05-27
# Verified: upstream lib/init/grass.py parse_cmdline / help_message on releasebranch_7_8

# Zsh completion for GRASS GIS 7.x launcher

_arguments -s -S \
  '(- *)'{-h,-help,--help,--h}'[show help message with usage details]' \
  '(- *)'{-v,--version}'[display GRASS GIS version and license information]' \
  '--text[use text-based interface (skip graphical welcome)]' \
  '--gtext[use text-based interface with graphical welcome screen]' \
  '--gui[launch default graphical user interface]' \
  '(-wxpython -wx --wxpython --wx)'{-wxpython,-wx,--wxpython,--wx}'[explicitly use the wxPython GUI]' \
  '-c[create new database, location or mapset if it does not exist]:CRS (EPSG\:code | geofile | XY):' \
  '-e[exit after location/mapset creation (requires -c)]' \
  '-f[force removal of .gislock file (text mode only, use with caution)]' \
  '--config[print GRASS configuration parameter(s)]:param:(arch build compiler date path revision svn_revision version)' \
  '--tmp-location=[create a temporary location for batch execution]:CRS (EPSG\:code | geofile | XY):' \
  '--exec[execute a GRASS module or script with the remaining arguments]:executable:_files' \
  '*:GISDBASE/LOCATION/MAPSET or geofile:_files'
