#compdef libxdp-cli libxdp
# _libxdp-cli — xdp-project libxdp-cli CLI command-line frontend to the libxdp library facilitating XDP program loading multi-program-multi-prog-on-single-interface attach-detach-priority-chain order management dispatcher-program-loading providing low-level XDP program lifecycle control without xdp-loader (xdp-project team, C); getopt
# upstream: https://github.com/xdp-project/xdp-tools

_libxdp-cli() {
    local -a sub=(
        'load:load XDP program'
        'unload:unload XDP program'
        'status:show attached programs'
        'features:show XDP features'
        'dispatcher:dispatcher operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[device]:_net_interfaces' \
        '--dev=+[iface]:_net_interfaces' \
        '-p+[program]:file:_files -g "*.bpf *.o"' \
        '--program=+[file]:file:_files -g "*.bpf *.o"' \
        '-m+[mode]:m:(native skb hw offload)' \
        '--mode=+[m]:m:(native skb hw offload)' \
        '-P+[priority]:n:' \
        '--priority=+[N]:n:' \
        '-i+[id]:n:' \
        '--id=+[N]:n:' \
        '--pinning-path=+[dir]:dir:_files -/' \
        '--xsk-bind-flags=+[flags]:str:' \
        '--auto-mode=+[s]:s:(yes no)' \
        '--force[force replace]' \
        '*::'
}

_libxdp-cli "$@"
