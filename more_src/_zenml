#compdef zenml

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'artifact:manage artifacts'
      'clean:clean ZenML'
      'connect:connect to a ZenML server'
      'dashboard:open the ZenML dashboard'
      'disconnect:disconnect from ZenML server'
      'down:shut down ZenML server'
      'experiment-tracker:manage experiment trackers'
      'init:initialize a ZenML repository'
      'integration:manage integrations'
      'login:log in to ZenML'
      'logout:log out of ZenML'
      'model:manage models'
      'pipeline:manage pipelines'
      'secret:manage secrets'
      'server:manage ZenML server'
      'service-connector:manage service connectors'
      'stack:manage stacks'
      'status:show status'
      'up:start ZenML server'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '(-p --path)'{-p,--path}'[path to initialize]:path:_directories' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      up)
        _arguments -s -S \
          '--port=[port]:port' \
          '--ip-address=[IP address]:address' \
          '--blocking[block the terminal]' \
          '--docker[run in Docker]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      stack)
        _arguments -s -S \
          '1:action:(copy create delete describe export get import list register remove-component rename set update)' && ret=0
        ;;
      pipeline)
        _arguments -s -S \
          '1:action:(build delete list logs register run runs)' && ret=0
        ;;
      integration)
        _arguments -s -S \
          '1:action:(export-requirements install list pull-recipe)' && ret=0
        ;;
    esac
    ;;
esac

return ret
