#compdef infoalign

# EMBOSS infoalign: display basic information about a sequence alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[aligned sequences]:alignment USA:_files' \
  '-refseq=[reference sequence (default 1)]:index/name:' \
  '-matrix=[scoring matrix]:matrix:_files' \
  '-html[output HTML formatted table]' \
  '-only[only show columns named with -name etc.]' \
  '-heading[show column headings]' \
  '-usa[show sequence USA]' \
  '-name[show sequence name]' \
  '-seqlength[show sequence length]' \
  '-alignlength[show alignment length]' \
  '-gaps[show number of gaps]' \
  '-gapcount[show count of gaps]' \
  '-idcount[show count of identities to refseq]' \
  '-simcount[show count of similarities to refseq]' \
  '-diffcount[show count of differences to refseq]' \
  '-change[show percent change from refseq]' \
  '-weight[show sequence weight]' \
  '-description[show sequence description]' \
  '-outfile=[output file]:file:_files' \
  '*:alignment USA:_files' && ret=0
return ret
