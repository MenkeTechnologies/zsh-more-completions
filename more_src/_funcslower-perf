#compdef funcslower-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/funcslower.8
# trace kernel functions slower than a threshold in microseconds (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-a[all info, same as -HPt]' \
  '-C[measure on-CPU time only]' \
  '-d+[trace duration in seconds, use buffers]:secs' \
  '-H[include column headers]' \
  '-p+[trace when this PID is on-CPU]:pid:_pids' \
  '-L+[trace when this thread is on-CPU]:tid' \
  '-P[show process names and PIDs]' \
  '-t[show timestamps]' \
  '1:kernel function:' \
  '2:latency threshold us:' && ret=0

return ret
