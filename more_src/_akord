#compdef akord
# Documentation: https://man.archlinux.org/search?q=akord
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:login (and import wallet)'
  'signup:create account and generate wallet'
  'logout:clear stored credentials'
  'vault\:create:create a vault'
  'vault\:rename:rename a vault'
  'vault\:archive:archive a vault'
  'vault\:restore:restore an archived vault'
  'vault\:get:get a vault by id'
  'vault\:list:list vaults'
  'stack\:create:create a stack from a file'
  'stack\:import:import a stack from a file txId'
  'stack\:rename:rename a stack'
  'stack\:upload-revision:upload a new revision'
  'stack\:move:move a stack'
  'stack\:revoke:revoke a stack'
  'stack\:restore:restore a revoked stack'
  'stack\:delete:delete a stack'
  'stack\:download:download a stack'
  'stack\:list:list stacks in a vault'
  'folder\:create:create a folder'
  'folder\:move:move a folder'
  'folder\:rename:rename a folder'
  'folder\:revoke:revoke a folder'
  'folder\:restore:restore a folder'
  'folder\:delete:delete a folder'
  'folder\:list:list folders in a vault'
  'memo\:create:post a memo'
  'membership\:invite:invite a member'
  'membership\:accept:accept invitation'
  'membership\:reject:reject invitation'
  'membership\:revoke:revoke a membership'
  'membership\:list:list memberships in a vault'
  'sync:sync between source and target URI'
  'diff:diff between source and target URI'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*::sub:->cmd' && ret=0

case $state in
  (cmd) _describe -t cmds 'akord command' commands && ret=0 ;;
esac

return ret
