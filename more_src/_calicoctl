#compdef calicoctl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-l --log-level)'{-l,--log-level}'[log level]:level:(panic fatal error warn info debug)' \
  '--context=[kubectl context]:context' \
  '--allow-version-mismatch[allow version mismatch]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'apply:apply a resource'
      'create:create a resource'
      'delete:delete a resource'
      'get:get a resource'
      'ipam:IP address management'
      'label:manage labels'
      'node:manage nodes'
      'patch:patch a resource'
      'replace:replace a resource'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      get|delete|create|apply|replace|patch)
        _arguments -s -S \
          '(-f --filename)'{-f,--filename}'[file]:file:_files -g "*.{yaml,yml,json}"' \
          '(-o --output)'{-o,--output}'[output format]:format:(yaml json ps wide)' \
          '--name=[resource name]:name' \
          '-n[namespace]:namespace' \
          '-A[all namespaces]' \
          '1:resource:(bgpConfiguration bgpPeer felixConfiguration globalNetworkPolicy globalNetworkSet hostEndpoint ipPool ipReservation networkPolicy networkSet node profile workloadEndpoint)' && ret=0
        ;;
      node)
        _arguments '1:action:(status run checksystem diags)' && ret=0
        ;;
      ipam)
        _arguments '1:action:(check configure release show split)' && ret=0
        ;;
    esac
    ;;
esac

return ret
