#compdef AmcacheParser
# Documentation: https://github.com/EricZimmerman/AmcacheParser
# Parses Amcache.hve files

local ret=1

_arguments -s -S \
  '-f[Amcache.hve file to parse]:file:_files' \
  '-i[include file entries for Programs entries]' \
  '-b[path to file with SHA-1 hashes to include]:file:_files' \
  '-w[path to file with SHA-1 hashes to exclude]:file:_files' \
  '--csv[directory where CSV results are saved]:directory:_files -/' \
  '--csvf[filename for CSV results]:filename' \
  '--dt[custom date/time format]:format' \
  '--mp[display higher precision for timestamps]' \
  '--nl[ignore transaction log files for dirty hives]' \
  '--debug[show debug information]' \
  '--trace[show trace information]' && ret=0

return ret
