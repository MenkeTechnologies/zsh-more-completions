#compdef sfwexmig
# Documentation: https://raw.githubusercontent.com/ahay/src/master/user/cwp/Mwexmig.c
# Madagascar: 3D modeling/migration with extended split-step Fourier

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'feic=[extended imaging condition (y/n)]:flag:(y n)' \
  'fdrv=[derivative (y/n)]:flag:(y n)' \
  'fnew=[new option (y/n)]:flag:(y n)' \
  'verb=[verbosity flag (y/n)]:flag:(y n)' \
  'eps=[stability parameter]:eps:' \
  'nrmax=[maximum reference velocities]:n:' \
  'dtmax=[time error tolerance]:d:' \
  'pmx=[padding in x (k domain)]:n:' \
  'pmy=[padding in y (k domain)]:n:' \
  'tmx=[boundary taper size in x]:n:' \
  'tmy=[boundary taper size in y]:n:' \
  'nhx=[half samples in x]:n:' \
  'nhy=[half samples in y]:n:' \
  'nhz=[half samples in z]:n:' \
  'nht=[half samples in t]:n:' \
  'dht=[t sampling]:d:' \
  '*:RSF file:_files' && ret=0

return ret
