#compdef holmes holmesgpt
# Documentation: https://man.archlinux.org/search?q=holmes
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'ask:ask HolmesGPT a question'
  'investigate:investigate alerts and tickets from external sources'
  'toolset:manage toolsets'
  'checks:run health checks'
  'generate:developer testing utilities'
  'version:show version'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file path]:file:_files -g "*.yaml"' \
  '--model=[LLM provider/model]:model:' \
  '--fast-model=[optional summarization model]:model:' \
  '--api-key=[LLM API key]:key:' \
  '*'{-t+,--custom-toolsets=}'[custom toolset path]:file:_files' \
  '*'{-r+,--custom-runbooks=}'[custom runbook path]:file:_files' \
  '--max-steps=[max LLM iterations]:n:' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--log-costs[display LLM cost info]' \
  '--trace=[tracing backend]:backend:(braintrust)' \
  '--destination=[output destination]:dest:(CLI slack)' \
  '--slack-token=[Slack API token]:token:' \
  '--slack-channel=[Slack channel]:channel:' \
  '--json-output-file=[save results as JSON]:file:_files' \
  '--echo[echo user input]' \
  '--no-echo[do not echo input]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'holmes command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (ask)
        _arguments \
          '(-pf --prompt-file)'{-pf+,--prompt-file=}'[prompt file]:file:_files' \
          '(-i --interactive)'{-i,--interactive}'[interactive REPL]' \
          '(-n --no-interactive)'{-n,--no-interactive}'[disable interactive mode]' \
          '--show-tool-output[display tool execution results]' \
          '*'{-f+,--file=}'[attach file to prompt]:file:_files' \
          '--refresh-toolsets[re-check toolset prerequisites]' \
          '--system-prompt-additions=[append to system prompt]:text:' \
          '*::prompt:' && ret=0 ;;
      (investigate)
        local -a inv_subs=(
          'alertmanager:investigate Prometheus AlertManager alerts'
          'pagerduty:investigate PagerDuty incidents'
          'opsgenie:investigate OpsGenie alerts'
          'jira:investigate Jira tickets'
          'github:investigate GitHub issues'
        )
        _describe -t icmds 'investigate source' inv_subs && ret=0
        _arguments \
          '--update[write findings back as comment/note]' \
          '--alertmanager-url=[AlertManager URL]:url:' \
          '--alertmanager-alertname=[regex filter alert name]:regex:' \
          '*--alertmanager-label=[filter label k=v]:kv:' \
          '--alertmanager-username=[basic-auth username]:user:' \
          '--alertmanager-password=[basic-auth password]:password:' \
          '--alertmanager-file=[load alerts from file]:file:_files' \
          '(-n --alertmanager-limit)'{-n+,--alertmanager-limit=}'[max alerts]:n:' \
          '--pagerduty-api-key=[PagerDuty API key]:key:' \
          '--pagerduty-user-email=[user email]:email:' \
          '--pagerduty-incident-key=[incident key]:key:' \
          '--opsgenie-api-key=[OpsGenie API key]:key:' \
          '--opsgenie-query=[OpsGenie alert query]:query:' \
          '--opsgenie-team-integration-key=[team integration key]:key:' \
          '--jira-url=[Jira instance URL]:url:' \
          '--jira-username=[Jira username]:user:' \
          '--jira-api-key=[Jira API key]:key:' \
          '--jira-query=[JQL filter]:jql:' \
          '--github-url=[GitHub URL]:url:' \
          '--github-owner=[repo owner]:owner:' \
          '--github-repository=[repo name]:repo:' \
          '--github-pat=[Personal Access Token]:token:' \
          '--github-query=[issue filter]:query:' && ret=0 ;;
      (toolset)
        local -a ts_subs=(
          'list:list all toolsets with status'
          'status:detailed info for one toolset'
          'config:interactive TUI for toolset configuration'
        )
        _describe -t tscmds 'toolset subcommand' ts_subs && ret=0
        _arguments '--refresh[refresh toolset prerequisites]' && ret=0 ;;
      (checks)
        _arguments '*::sub:(run list schedule)' && ret=0 ;;
      (generate)
        _arguments '*::sub:(issue)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
