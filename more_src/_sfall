#compdef sfall
# Documentation: https://www.ccp4.ac.uk/html/sfall.html
# sfall — structure factor calculation and atom map / gradient generation (CCP4)

local ret=1

_arguments -s -S \
  'XYZIN[input coordinates PDB]:file:_files -g "*.(pdb|ent)"' \
  'HKLIN[input reflection MTZ]:file:_files -g "*.mtz"' \
  'MAPIN[input electron density map]:file:_files -g "*.(map|ccp4)"' \
  'XYZOUT[output coordinates]:file:_files -g "*.(pdb|ent)"' \
  'HKLOUT[output reflection MTZ]:file:_files -g "*.mtz"' \
  'MAPOUT[output map]:file:_files -g "*.(map|ccp4)"' \
  'GRADMAT[output gradient matrix]:file:_files' \
  'ATOMSF[atomic scattering factor library]:file:_files' \
  'MODE[calculation type]:m:(ATMMAP SFCALC SFREF)' \
  'LABIN[input column assignments]:labels:' \
  'LABOUT[output column assignments]:labels:' \
  'RESOLUTION[resolution limits]:lim:' \
  'GRID[FFT grid dimensions]:grid:' \
  'SYMMETRY[spacegroup]:sg:' \
  'SFSGROUP[FFT spacegroup]:sg:' \
  'FORMFACTOR[atomic form factor]:opt:(NEUTRON NGAUSS)' \
  'BADD[added B-factor]:b:' \
  'VDWR[atomic radius cutoff]:r:' \
  'RSCB[scale/B refinement resolution]:lim:' \
  'CELL[cell parameters]:cell:' \
  'BINS[resolution bins]:n:' \
  'NAME[project/crystal/dataset name]:name:' \
  'TITLE[output title]:title:' \
  'END[terminate input]' \
  '*:argument:_files' && ret=0

return ret
