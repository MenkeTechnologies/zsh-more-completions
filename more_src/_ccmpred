#compdef ccmpred
# Documentation: https://github.com/soedinglab/CCMpred
# CCMpred protein residue-residue contact prediction by pseudo-likelihood maximization

local ret=1

_arguments -s -S \
  '(-h -?)'{-h,-\?}'[show help]' \
  '-r+[store raw prediction matrix in RAWFILE]:rawfile:_files' \
  '-i+[read initial weights from INIFILE]:inifile:_files' \
  '-n+[maximum number of iterations (default 50)]:numiter:' \
  '-w+[sequence reweighting identity threshold (default 0.8)]:idthres:' \
  '-k+[K parameter for convergence criterion (default 5)]:lastk:' \
  '-e+[convergence criterion epsilon (default 0.01)]:epsilon:' \
  '-l+[pairwise regularization coefficient multiplier (default 0.2)]:lfactor:' \
  '-A[disable average product correction]' \
  '-R[re-normalize output matrix to [0,1]]' \
  '-b+[store raw prediction in msgpack BRAWFILE]:brawfile:_files' \
  '-d+[CUDA device number (-1 for CPU, default 0)]:device:' \
  '-t+[number of CPU threads (default 1)]:threads:' \
  '*:alignment file:_files' && ret=0

return ret
