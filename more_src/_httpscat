#compdef httpscat
# _httpscat — fetch a star catalog from a remote scat server (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from httpscat.c.

_httpscat() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '1:server URL or host:_urls' \
        '*:scat arguments:'
}

_httpscat "$@"
