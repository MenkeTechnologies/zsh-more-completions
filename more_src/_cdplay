#compdef cdplay
# Documentation: man cdplay(1)
# Source: netbsd/src usr.bin/cdplay — control CD-ROM audio features (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[audio device for digital transfer]:audio device:_files' \
    '-f+[control device]:device:_files' \
    '1::command:(play next prev pause resume shuffle single skip stop eject close volume info status digital analog help reset set quit)' \
    '*::track, MSF address, or volume:_default' \
    && ret=0

return ret
