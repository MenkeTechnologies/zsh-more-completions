#compdef autoninja

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-C+[change to directory before building]:directory:_directories' \
  '-f+[specify build file]:build file:_files' \
  '-j+[number of parallel jobs]:jobs' \
  '-k+[keep going until N jobs fail]:count' \
  '-l+[do not start new jobs if load average is above]:load' \
  '-n[dry run]' \
  '-v[show command lines while building]' \
  '-d+[enable debugging]:mode:(stats explain keepdepfile keeprsp)' \
  '-t+[run a subtool]:tool:(browse clean commands deps graph query targets compdb recompact restat rules cleandead)' \
  '-w+[control warning behavior]:warning:(dupbuild=err dupbuild=warn phonycycle=err phonycycle=warn)' \
  '*:targets:' && ret=0

return ret
