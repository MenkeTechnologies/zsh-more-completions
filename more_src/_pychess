#compdef pychess

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l --log-viewer)'{-l,--log-viewer}'[show log viewer]' \
  '(-p --perspective)'{-p,--perspective}'+[start perspective]:persp:(welcome games fics database tactics learn)' \
  '(-c --chess960)'{-c,--chess960}'[start chess960 game]' \
  '*:file:_files -g "*.{pgn,epd,fen}"' && ret=0

return ret
