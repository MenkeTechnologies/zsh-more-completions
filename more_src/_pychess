#compdef pychess
# Documentation: https://github.com/pychess/pychess/blob/master/pychess
# Reference accessed: 2026-05-20
# Verified: upstream script source at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--version[show version]' \
  '--log-debug[change logging level from INFO to DEBUG]' \
  '--no-gettext[disable locale translations]' \
  '--log-viewer[enable Log Viewer menu]' \
  '--purge-recent[clear the recent games menu]' \
  '--ics-host=[Internet Chess Server host]:host:_hosts' \
  '--ics-port=[Internet Chess Server port]:port' \
  '--no-version-check[disable online version checking]' \
  '*:file:_files -g "*.(pgn|epd|fen|html)"' && ret=0

return ret
