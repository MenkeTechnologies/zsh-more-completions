#compdef fjord

# Zsh completion for fjord (Rust shell)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --command)'{-c,--command}'[execute a command string]:command string' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-l --login)'{-l,--login}'[start as login shell]' \
  '--norc[do not read config file]' \
  '*:script file:_files' && ret=0

return ret
