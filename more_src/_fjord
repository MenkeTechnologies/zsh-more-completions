#compdef fjord
# Documentation: https://github.com/fjord-framework/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fjord: CLI to deploy the Fjord framework and manage AWS infrastructure.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'setup:initialize a Fjord project (creates FjordSettings.json)'
  'deploy:deploy infrastructure to AWS (produces outputs.json)'
  'destroy:remove Fjord infrastructure from AWS'
  'endpoints:display deployment endpoints (NAT IPs, LB URL)'
  'help:list available commands'
)

_arguments -C \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'fjord command' commands && ret=0 ;;
  (args)
    case ${words[1]} in
      (setup)    _message 'optional APPNAME (ECS cluster name)' && ret=0 ;;
      (destroy)  _message 'optional STACKNAME' && ret=0 ;;
    esac
    ;;
esac

return ret
