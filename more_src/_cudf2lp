#compdef cudf2lp
# Documentation: cudf2lp --help
# Source: convert CUDF problem to ASP (clingo/clasp) input.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(-c --criteria)'{-c+,--criteria=}'[optimisation criteria]:criteria:(none paranoid trendy)' \
    '(-a --addall)'{-a,--addall}'[disable preprocessing, add all packages]' \
    '1:cudf file:_files -g "*.cudf"' \
    && ret=0

return ret
