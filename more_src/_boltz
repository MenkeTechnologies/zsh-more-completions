#compdef boltz
# Documentation: https://github.com/jwohlwend/boltz/blob/main/docs/prediction.md
# Boltz biomolecular structure and affinity prediction

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(predict)' \
  '*::args:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '--out_dir=[path where to save the predictions]:dir:_files -/' \
      '--cache=[directory for downloading data and models]:dir:_files -/' \
      '--checkpoint=[optional model checkpoint]:file:_files' \
      '--devices=[number of devices to use for prediction]:n:' \
      '--accelerator=[hardware accelerator type]:type:(gpu cpu tpu)' \
      '--recycling_steps=[number of recycling steps]:n:' \
      '--sampling_steps=[number of sampling steps]:n:' \
      '--diffusion_samples=[number of diffusion samples]:n:' \
      '--max_parallel_samples=[maximum samples to predict simultaneously]:n:' \
      '--step_scale=[diffusion temperature, range 1-2]:val:' \
      '--output_format=[format for output structure files]:fmt:(pdb mmcif)' \
      '--num_workers=[number of dataloader workers]:n:' \
      '--method=[prediction method selection]:method:' \
      '--preprocessing-threads=[threads for data preprocessing]:n:' \
      '--affinity_mw_correction[apply molecular weight correction to affinity]' \
      '--sampling_steps_affinity=[sampling iterations for affinity]:n:' \
      '--diffusion_samples_affinity=[diffusion samples for affinity]:n:' \
      '--affinity_checkpoint=[custom affinity model checkpoint]:file:_files' \
      '--max_msa_seqs=[maximum number of MSA sequences]:n:' \
      '--subsample_msa[enable MSA subsampling]' \
      '--num_subsampled_msa=[sequences to retain after subsampling]:n:' \
      '--no_kernels[disable trifast kernels for triangular updates]' \
      '--override[override existing predictions if found]' \
      '--use_msa_server[use the MSA server to generate MSAs]' \
      '--msa_server_url=[MSA server endpoint URL]:url:' \
      '--msa_server_username=[username for MSA server auth]:user:' \
      '--msa_server_password=[password for MSA server auth]:pass:' \
      '--msa_pairing_strategy=[strategy for sequence alignment pairing]:strategy:(greedy complete)' \
      '--api_key_header=[header name for API key authentication]:header:' \
      '--api_key_value=[API key value for server authentication]:key:' \
      '--use_potentials[run Boltz-2 with inference time potentials]' \
      '--write_full_pae[export complete PAE matrix as separate file]' \
      '--write_full_pde[export complete PDE matrix as separate file]' \
      '1:input path:_files' && ret=0
    ;;
esac

return ret
