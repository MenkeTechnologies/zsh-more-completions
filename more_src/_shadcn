#compdef shadcn
# Documentation: https://man.archlinux.org/search?q=shadcn
# Reference accessed: 2026-05-16

# Zsh completion for shadcn component CLI

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values -s 'shadcn' \
      init apply add diff docs view search migrate info build mcp preset registry && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
