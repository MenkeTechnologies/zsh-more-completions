#compdef 3dDetrend
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dDetrend.html
# AFNI remove specified components from each voxel time series

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-prefix[output dataset prefix]:prefix' \
  '-session[output session directory]:dir:_files -/' \
  '-verb[verbose output]' \
  '-replace[replace voxel data with fitted time series]' \
  '-normalize[normalize each output to unit sum-of-squares]' \
  '-byslice[treat input vectors as interlaced across slices]' \
  '*-vector[remove components from columns of 1D file]:file:_files' \
  '*-expr[remove components matching expression]:expression' \
  '-polort[add Legendre polynomials up to order]:order' \
  '-del[stepsize for expression-based components]:ddd' \
  '*:dataset:_files' && ret=0

return ret
