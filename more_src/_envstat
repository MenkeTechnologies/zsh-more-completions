#compdef envstat
# Documentation: man envstat(8)
# Source: netbsd/src usr.sbin/envstat — envsys environmental sensors utility (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[sensor properties configuration file]:config file:_files' \
    '-D[list registered devices with properties]' \
    '-d+[show sensors for device only]:device:_default' \
    '-f[temperatures in Fahrenheit]' \
    '-I[skip sensors with invalid state]' \
    '-i+[repeat display every N seconds]:interval (seconds):_default' \
    '-j[JSON output]' \
    '-k[temperatures in Kelvin]' \
    '-l[list all supported sensor names]' \
    '-n[print current values only, no headers]' \
    '-r[compatibility flag (no effect)]' \
    '-S[restore default settings for all devices]' \
    '-s+[restrict to device:sensor list]:device\:sensor,...:_default' \
    '-T[show statistics (max, min, average)]' \
    '-t[include timestamp]' \
    '-W[historical flag (no effect)]' \
    '-w+[column width]:width:_default' \
    '-x[print raw XML property list]' \
    '*::property (with -x):_default' \
    && ret=0

return ret
