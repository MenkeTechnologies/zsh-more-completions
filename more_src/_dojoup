#compdef dojoup
# Documentation: https://github.com/dojoengine/dojo/tree/main/dojoup
# Source: https://github.com/dojoengine/dojo/blob/main/dojoup/dojoup
# Reference accessed: 2026-06-01
# Dojo toolchain installer (manages sozo, katana, torii binaries).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _du_cmds
_du_cmds=(
    'component:manage individual Dojo components'
    'default:switch to a specific installed version'
    'install:install a Dojo toolchain'
    'list:list all installed versions'
    'show:display the default Dojo version'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'dojoup command' _du_cmds && ret=0
        ;;
    args)
        case $line[1] in
            component)
                _arguments -s -S \
                    '1:subcommand:(add help)' \
                    '*::component arg:_default' \
                    && ret=0
                ;;
            default)
                _arguments -s -S '1:version:_default' && ret=0
                ;;
            install)
                _arguments -s -S \
                    '*:install args:_default' && ret=0
                ;;
        esac
        ;;
esac

return ret
