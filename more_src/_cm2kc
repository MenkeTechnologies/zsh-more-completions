#compdef cm2kc
# _cm2kc — convert a Prow cluster map file to a kubeconfig (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/cm2kc/main.go (pflag).

_cm2kc() {
    _arguments \
        '(-i --input)'{-i+,--input=}'[input cluster map file]:file:_files' \
        '(-o --output)'{-o+,--output=}'[output kubeconfig file]:file:_files'
}

_cm2kc "$@"
