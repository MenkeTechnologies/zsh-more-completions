#compdef moosh
# Documentation: https://github.com/tmuras/moosh/blob/master/moosh.php
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# moosh - Moodle Shell. Global option set from moosh.php OptionCollection.
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show global help]' \
  '(-p --moodle-path)'{-p+,--moodle-path=}'[Moodle directory]:dir:_files -/' \
  '(-u --user)'{-u+,--user=}'[Moodle user (default ADMIN)]:user' \
  '(-n --no-user-check)'{-n,--no-user-check}'[skip Moodle data ownership check]' \
  '(-l --no-login)'{-l,--no-login}'[do not log in as admin]' \
  '*'{-o+,--options=}'[override CFG setting (key=value)]:override' \
  '(-t --performance)'{-t,--performance}'[show performance information]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '--list-commands[show all possible commands]' \
  '*::moosh_command:' && ret=0

return ret
