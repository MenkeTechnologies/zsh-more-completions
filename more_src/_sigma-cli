#compdef sigma sigma-cli
# Documentation: https://man.archlinux.org/search?q=sigma
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'check:check rules for issues'
  'convert:convert rules to backend format'
  'list:list available pipelines/backends/formats'
  'plugin:manage plugins'
  'analyze:analyze rule taxonomy'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sigma command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (convert)
        _arguments \
          '(-t --target)'{-t+,--target=}'[backend]:target:(splunk elasticsearch crowdstrike sentinel kusto carbon-black qradar logpoint chronicle eql lucene es-rule pysigma graylog opensearch)' \
          '(-p --pipeline)*'{-p+,--pipeline=}'[pipeline]:p:' \
          '(-f --format)'{-f+,--format=}'[output format]:fmt:(default json yaml)' \
          '(-O --backend-option)*'{-O+,--backend-option=}'[backend option]:opt:' \
          '(-s --skip-unsupported)'{-s,--skip-unsupported}'[skip unsupported]' \
          '(-S --without-postprocessing)'{-S,--without-postprocessing}'[no postprocess]' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '(-d --validate)'{-d,--validate}'[validate]' \
          '(-j --filter)*'{-j+,--filter=}'[filter file]:file:_files' \
          '*: :_files -g "*.yml *.yaml"' && ret=0 ;;
      (check)
        _arguments \
          '(-V --validation-config)'{-V+,--validation-config=}'[config]:file:_files' \
          '(--validators)--validators=[validators csv]:list:' \
          '(--validation-disable-rule-error)--validation-disable-rule-error[disable rule errors]' \
          '*: :_files -g "*.yml *.yaml"' && ret=0 ;;
      (list)
        _arguments \
          '1:type:(targets pipelines formats validators)' \
          '*: :' && ret=0 ;;
      (plugin)
        _arguments \
          '1:subcommand:(list install uninstall search show)' \
          '*: :' && ret=0 ;;
      (analyze)
        _arguments \
          '*: :_files -g "*.yml *.yaml"' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
