#compdef mccabe python-mccabe
# Documentation: https://man.archlinux.org/search?q=mccabe
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-m+[minimum complexity threshold]:threshold' \
  '--min=[minimum complexity threshold]:threshold' \
  '-d[output dot graph]' \
  '1:python file:_files -g "*.py(-.)"' && return 0
