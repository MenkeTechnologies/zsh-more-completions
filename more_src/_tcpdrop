#compdef tcpdrop tcpdrop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/tcpdrop.py argparse)
# Reference accessed: 2026-05-29
# tcpdrop — trace kernel-based TCP packet drops with stack traces (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[trace IPv4 family only]' \
  '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[trace IPv6 family only]' \
  '--netns-id=[netns ID to filter by (default 0)]:id:' \
  '--pid-netns=[the PID whose netns to filter by (default 0)]:pid:_pids' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
