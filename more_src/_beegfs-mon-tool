#compdef beegfs-mon-tool
# Documentation: https://man.archlinux.org/search?q=beegfs-mon-tool
# Reference accessed: 2026-05-16

# beegfs-mon-tool: BeeGFS monitoring CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-H[host]:host:_hosts' \
  '-p[port]:port:' \
  '-v[verbose]' \
  '-c[config file]:file:_files' \
  '*::beegfs-mon-tool args:_files' && ret=0
return ret
