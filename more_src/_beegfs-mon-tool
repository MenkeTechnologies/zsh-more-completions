#compdef beegfs-mon-tool
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# beegfs-mon-tool: BeeGFS monitoring CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-H[host]:host:_hosts' \
  '-p[port]:port:' \
  '-v[verbose]' \
  '-c[config file]:file:_files' \
  '*::beegfs-mon-tool args:_files' && ret=0
return ret
