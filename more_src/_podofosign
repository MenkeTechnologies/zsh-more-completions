#compdef podofosign
# Documentation: https://github.com/podofo/podofo/blob/master/tools/podofosign/podofosign.cpp
# podofosign - digitally sign a PDF document

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-in[input PDF file]:file:_files -g "*.pdf"' \
  '-out[output signed PDF file]:file:_files -g "*.pdf"' \
  '-cert[certificate file (PEM)]:file:_files' \
  '-pkey[private key file (PEM)]:file:_files' \
  '-password[password to unlock the private key]:password' \
  '-reason[UTF-8 reason of the signature]:reason' \
  '-sigsize[bytes to allocate for the signature]:bytes' \
  '-field-name[signature field name to use]:name' \
  '-field-use-existing[use existing signature field if named field exists]' \
  '-annot-units[units for annotation dimensions]:units:(mm inch)' \
  '-annot-position[annotation position (page,left,top,width,height)]:position' \
  '-annot-print[set print flag on the annotation]' \
  '-annot-font[annotation font (size,r,g,b)]:font' \
  '-annot-text[annotation visible text]:text' \
  '-annot-image[annotation background image]:file:_files' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
