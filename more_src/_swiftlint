#compdef swiftlint

# Zsh completion for swiftlint - SwiftLint Swift linter

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_swiftlint_reporters=(xcode json csv checkstyle codeclimate junit html emoji sonarqube markdown github-actions-logging summary relative-path)

_arguments -s -S -C \
  '--config=[configuration file to use]:config file:_files' \
  '--quiet[suppress non-error output]' \
  '(-h --help)'{-h,--help}'[show help information]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'lint:Lint Swift files'
      'analyze:Analyze Swift files using the compiler log'
      'rules:List available linting rules'
      'version:Display the current version'
      'generate-docs:Generate documentation for rules'
      'reporters:List available reporters'
      'baseline:Generate or compare against a baseline'
    )
    _describe -t commands 'swiftlint commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      lint)
        _arguments -s -S \
          '--config=[configuration file to use]:config file:_files' \
          '--quiet[suppress non-error output]' \
          '--path=[path to lint]:path:_files -/' \
          '--reporter=[report format]:reporter:('${(j: :)_swiftlint_reporters}')' \
          '--strict[treat warnings as errors]' \
          '--lenient[treat errors as warnings]' \
          '--force-exclude[force exclude paths in config]' \
          '--enable-all-rules[enable all rules]' \
          '--output=[output file path]:output file:_files' \
          '--progress[show progress]' \
          '--cache-path=[directory for cache]:cache dir:_files -/' \
          '--no-cache[disable caching]' \
          '--compiler-log-path=[path to compiler log]:log file:_files' \
          '--use-alternative-excluding[use alternative path exclusion]' && ret=0
        ;;
      analyze)
        _arguments -s -S \
          '--config=[configuration file to use]:config file:_files' \
          '--quiet[suppress non-error output]' \
          '--path=[path to analyze]:path:_files -/' \
          '--reporter=[report format]:reporter:('${(j: :)_swiftlint_reporters}')' \
          '--compiler-log-path=[path to compiler log]:log file:_files' && ret=0
        ;;
      rules)
        _arguments -s -S \
          '--config=[configuration file to use]:config file:_files' && ret=0
        ;;
      baseline)
        _arguments -s -S \
          '--config=[configuration file to use]:config file:_files' \
          '--path=[path to lint]:path:_files -/' \
          '--reporter=[report format]:reporter:('${(j: :)_swiftlint_reporters}')' && ret=0
        ;;
      reporters|version|generate-docs)
        ;;
    esac
    ;;
esac

return ret
