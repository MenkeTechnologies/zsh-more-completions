#compdef glab-repo
# _glab-repo — GitLab glab repo subcommand alias (GitLab Inc., Go); spf13/cobra
# upstream: https://gitlab.com/gitlab-org/cli

_glab-repo() {
    local -a sub=(
        'archive:archive a repo'
        'clone:clone a repo'
        'contributors:list contributors'
        'create:create a new repo'
        'delete:delete a repo'
        'fork:fork a repo'
        'list:list repos'
        'mirror:mirror a repo'
        'search:search repos'
        'transfer:transfer a repo'
        'view:view a repo'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'glab-repo subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--description=+[description]:str:' \
                    '-d+[description]:str:' \
                    '--internal[internal]' \
                    '-I[internal]' \
                    '--public[public]' \
                    '-p[public]' \
                    '--private[private]' \
                    '-P[private]' \
                    '--namespace=+[namespace]:str:' \
                    '-n+[namespace]:str:' \
                    '--group=+[group]:str:' \
                    '-g+[group]:str:' \
                    '--defaultBranch=+[default branch]:str:' \
                    '--readme[init with README]' \
                    '-r[init with README]' \
                    '--remote=+[remote name]:str:' \
                    '*:repo:' ;;
                clone) _arguments \
                    '--archived[include archived]' \
                    '--group=+[group]:str:' \
                    '-g+[group]:str:' \
                    '--per-page=+[per page]:n:' \
                    '-p+[per page]:n:' \
                    '--page=+[page]:n:' \
                    '--paginate[paginate]' \
                    '--user=+[user]:str:_users' \
                    '-u+[user]:str:_users' \
                    '--preserve-namespace[preserve namespace]' \
                    '*:repo:' ;;
                list) _arguments \
                    '--archived[archived only]' \
                    '-a[archived only]' \
                    '--group=+[group]:str:' \
                    '-g+[group]:str:' \
                    '--mine[mine]' \
                    '-m[mine]' \
                    '--include-subgroups[include subgroups]' \
                    '--member[member]' \
                    '--order=+[order]:o:(id name path created_at updated_at last_activity_at)' \
                    '--per-page=+[per page]:n:' \
                    '-P+[per page]:n:' \
                    '--starred[starred]' \
                    '-s[starred]' \
                    '--visibility=+[visibility]:v:(public internal private)' ;;
                view|fork|delete|archive|transfer) _arguments \
                    '--web[open in browser]' \
                    '-w[open in browser]' \
                    '*:repo:' ;;
                mirror) _arguments \
                    '--direction=+[direction]:d:(pull push)' \
                    '--enabled=+[enabled]:b:(true false)' \
                    '--url=+[mirror URL]:url:_urls' \
                    '--protected-branches=+[protected branches only]:b:(true false)' ;;
                search) _arguments \
                    '--search-namespaces[search namespaces]' \
                    '--per-page=+[per page]:n:' \
                    '*:query:' ;;
                contributors) _arguments \
                    '--order-by=+[order by]:o:(name email commits)' \
                    '--sort=+[sort]:s:(asc desc)' ;;
            esac
            ;;
    esac
}

_glab-repo "$@"
