#compdef afl-plot
# Documentation: https://github.com/AFLplusplus/AFLplusplus/blob/stable/afl-plot
# AFL++ generate gnuplot graphs from an afl-fuzz state directory

local ret=1

_arguments -s -S \
  '(-g --graphical)'{-g,--graphical}'[display plots in a graphical window via afl-plot-ui]' \
  '*:afl state dir or graph output dir:_files -/' && ret=0

return ret
