#compdef v-cli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build a V program'
  'check:check syntax of source files'
  'clean:remove temp files'
  'complete:print shell completions'
  'doc:generate docs'
  'doctor:show V env info'
  'fmt:format V source'
  'help:show help'
  'init:initialize V module'
  'install:install module'
  'list:list installed modules'
  'missdoc:show undocumented functions'
  'new:create new V project'
  'remove:remove module'
  'repl:start REPL'
  'retry:retry failed install'
  'run:run a V program'
  'search:search modules'
  'setup-freetype:install freetype'
  'shader:compile shader'
  'show:show module info'
  'symlink:symlink V binary'
  'test:test files'
  'test-all:run all tests'
  'test-cleancode:test clean code'
  'test-self:test V itself'
  'tracev:trace V'
  'translate:translate C to V'
  'up:upgrade V itself'
  'update:update modules'
  'vet:lint V code'
  'version:show version'
  'wipe-cache:wipe cache'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*-cc+[C compiler]:cc:_command_names -e' \
  '*-cflags+[C flags]:f:' \
  '*-d+[define flag]:flag:' \
  '*-e+[code to evaluate]:code:' \
  '*-g[debug info]' \
  '*-cg[debug C source]' \
  '*-os+[target OS]:os:(linux mac windows freebsd openbsd netbsd solaris haiku android)' \
  '*-arch+[target arch]:a:(amd64 arm64 i386 arm32 rv64 rv32)' \
  '*-no-prod-options[skip prod opts]' \
  '*-prod[production build]' \
  '*-prof[profile]' \
  '*-stats[stats]' \
  '*-shared[shared library]' \
  '*-skip-unused[skip unused]' \
  '*-keepc[keep C source]' \
  '*-skip-running[skip running]' \
  '*-cleantmp[clean tmp]' \
  '*-w[no warnings]' \
  '*-error-limit+[error limit]:n:' \
  '*-sourcemap[sourcemap]' \
  '*-sourcemap-format+[sourcemap format]:f:(default)' \
  '*-color[color]' \
  '*-no-color[no color]' \
  '*-version[show version]' \
  '*-show-c-cmd[show C cmd]' \
  '*-show-timings[show timings]' \
  '*-V[verbose]' \
  '*-verbose[verbose]' \
  '*-v[verbose]' \
  '*-stats[stats]' \
  '*-cstrict[strict C check]' \
  '*-thirdparty-option+[3rd party opt]:o:' \
  '*-cmain+[C main fn]:n:' \
  '*-no-bounds-checking[no bounds check]' \
  '*-printfn+[print fn]:n:' \
  '*-print_v_files[print v files]' \
  '*-trace-calls[trace calls]' \
  '*-translated[mark translated]' \
  '*-no-skip-unused[no skip unused]' \
  '*-musl[link musl]' \
  '*-show-build-cmd[show build cmd]' \
  '*-watch[watch mode]' \
  '*-ldflags+[ld flags]:f:' \
  '*-linker[which linker]' \
  '*-prealloc[preallocate]' \
  '*-no-prealloc[no preallocate]' \
  '*-gc+[GC]:gc:(boehm boehm-leak boehm-incr boehm-incr-leak none)' \
  '*-no-gc[no GC]' \
  '*-autofree[autofree]' \
  '*-watch-files=[watch files csv]:list:' \
  '*-no-bounds-checking[no bounds check]' \
  '*-skip-test-runner[skip test runner]' \
  '*-cache-dir=[cache dir]:dir:_files -/' \
  '*-nocache[no cache]' \
  '*-show-prefer-d[show prefer d]' \
  '*-skip-not-modified[skip if not modified]' \
  '*-fno-pic[no PIC]' \
  '*-pic[PIC]' \
  '*-prealloc-block-size=[block size]:n:' \
  '*-show-c-cmd[show C cmd]' \
  '*-stress[stress]' \
  '*-trace[trace]' \
  '*-fast-math[fast math]' \
  '*-march=[march]:m:' \
  '*-mtune=[mtune]:m:' \
  '*-mfpmath=[mfpmath]:m:' \
  '*-msse[sse]' \
  '*-msse2[sse2]' \
  '*-msse3[sse3]' \
  '*-mfpu=[mfpu]:m:' \
  '*-mfloat-abi=[float abi]:a:(soft hard softfp)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _alternative \
      'commands:command:_describe -t cmds "v command" commands' \
      'files:file:_files -g "*.v *.vsh"' && ret=0 ;;
  (args)
    case $line[1] in
      (run|test|build|check|fmt|vet)
        _arguments '*: :_files -g "*.v"' && ret=0 ;;
      (install|search|remove|show)
        _arguments '*:module:' && ret=0 ;;
      (complete)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
