#compdef portage-cli emerge-cli
# _portage-cli — Gentoo Portage emerge package manager CLI alias (Gentoo Foundation, Python); custom argparse
# upstream: https://gitweb.gentoo.org/proj/portage.git/

_portage-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--ask[ask before install]' \
        '-a[ask before install]' \
        '--alphabetical[alphabetical order]' \
        '--autounmask[autounmask]' \
        '--backtrack=+[backtrack]:n:' \
        '--buildpkg[build binpkg]' \
        '-b[build binpkg]' \
        '--buildpkg-exclude=+[buildpkg exclude]:list:' \
        '--changed-use[changed USE flags]' \
        '-U[changed USE flags]' \
        '--clean[clean]' \
        '-c[clean]' \
        '--complete-graph[complete graph]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--deep[deep]' \
        '-D[deep]' \
        '--depclean[depclean]' \
        '--emptytree[empty tree]' \
        '-e[empty tree]' \
        '--fail-clean[fail clean]' \
        '--fetchonly[fetch only]' \
        '-f[fetch only]' \
        '--fetch-all-uri[fetch all uri]' \
        '-F[fetch all uri]' \
        '--getbinpkg[get binpkg]' \
        '-g[get binpkg]' \
        '--getbinpkgonly[get binpkg only]' \
        '-G[get binpkg only]' \
        '--ignore-default-opts[ignore default opts]' \
        '--info[show info]' \
        '--jobs=+[jobs]:n:' \
        '-j+[jobs]:n:' \
        '--keep-going[keep going]' \
        '--load-average=+[load average]:f:' \
        '--newuse[new USE]' \
        '-N[new USE]' \
        '--noconfmem[no confmem]' \
        '--nodeps[no deps]' \
        '-O[no deps]' \
        '--noreplace[no replace]' \
        '-n[no replace]' \
        '--nospinner[no spinner]' \
        '--onlydeps[only deps]' \
        '-o[only deps]' \
        '--oneshot[one shot]' \
        '-1[one shot]' \
        '--pretend[pretend]' \
        '-p[pretend]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--quiet-build[quiet build]' \
        '--quiet-fail[quiet fail]' \
        '--rebuild[rebuild]' \
        '--regex-search-auto[regex search auto]' \
        '--reinstall=+[reinstall]:r:(changed-use)' \
        '--root=+[ROOT]:dir:_files -/' \
        '--root-deps=+[root deps]:r:(rdeps)' \
        '--search[search]' \
        '-s[search]' \
        '--searchdesc[search description]' \
        '-S[search description]' \
        '--select[select]' \
        '-w[select]' \
        '--skipfirst[skip first]' \
        '--sync[sync]' \
        '--tree[tree]' \
        '-t[tree]' \
        '--unmerge[unmerge]' \
        '-C[unmerge]' \
        '--update[update]' \
        '-u[update]' \
        '--upgradeonly[upgrade only]' \
        '--usepkg[use binpkg]' \
        '-k[use binpkg]' \
        '--usepkgonly[use binpkg only]' \
        '-K[use binpkg only]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--verbose-conflicts[verbose conflicts]' \
        '--with-bdeps=+[with bdeps]:b:(y n)' \
        '--with-bdeps-auto=+[with bdeps auto]:b:(y n)' \
        '*:atom:'
}

_portage-cli "$@"
