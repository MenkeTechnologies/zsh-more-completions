#compdef regal

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'lint:lint Rego files'
      'fix:fix Rego files'
      'test:run Regal tests'
      'new:create new rule from template'
      'parse:parse Rego file and print AST'
      'completion:generate shell completion'
      'config:manage Regal configuration'
    )
    _describe -t commands 'regal command' commands && ret=0
    ;;
  args)
    case $line[1] in
      lint)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config-file=[path to configuration file]:config file:_files' \
          '--debug[enable debug mode]' \
          '--disable-all[disable all rules]' \
          '--disable-category=[disable category]:category:' \
          '--enable-all[enable all rules]' \
          '--enable=[enable specific rule]:rule:' \
          '--format=[output format]:format:(pretty compact json github sarif)' \
          '--ignore-files=[files to ignore]:pattern:' \
          '--metrics[enable metrics collection]' \
          '--no-color[disable color output]' \
          '--output-file=[write output to file]:file:_files' \
          '--profile[enable profiling]' \
          '--rules=[custom rules directory]:directory:_directories' \
          '--timeout=[timeout for evaluation]:duration:' \
          '-e+[set exit behavior on violations]:exit:(non-zero zero)' \
          '*:rego files or directories:_files' && ret=0
        ;;
      fix)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config-file=[path to configuration file]:config file:_files' \
          '--force[fix without confirmation]' \
          '--format=[output format]:format:(pretty compact json)' \
          '--no-color[disable color output]' \
          '*:rego files or directories:_files' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-v[verbose output]' \
          '--verbose[verbose output]' \
          '--timeout=[timeout]:duration:' \
          '*:test files or directories:_files' && ret=0
        ;;
      new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--category=[rule category]:category:' \
          '--output=[output directory]:directory:_directories' \
          '1:rule name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
