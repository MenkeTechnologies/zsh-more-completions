#compdef jaeger-agent
# _jaeger-agent — Jaeger Agent local UDP daemon forwarder (Jaeger team, Go); spf13/cobra (deprecated as of v1.42 in favor of otelcol receivers)
# upstream: https://github.com/jaegertracing/jaeger

_jaeger-agent() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config-file=+[config file]:file:_files -g "*.yaml *.yml"' \
        '--processor.jaeger-binary.server-host-port=+[binary thrift host:port]:hostport:' \
        '--processor.jaeger-binary.server-max-packet-size=+[max packet size]:n:' \
        '--processor.jaeger-binary.server-queue-size=+[queue size]:n:' \
        '--processor.jaeger-binary.server-socket-buffer-size=+[socket buffer]:n:' \
        '--processor.jaeger-binary.workers=+[workers]:n:' \
        '--processor.jaeger-compact.server-host-port=+[compact thrift host:port]:hostport:' \
        '--processor.jaeger-compact.workers=+[workers]:n:' \
        '--processor.zipkin-compact.server-host-port=+[zipkin compact host:port]:hostport:' \
        '--reporter.grpc.discovery.min-peers=+[grpc min peers]:n:' \
        '--reporter.grpc.host-port=+[collector grpc host:port]:hostport:' \
        '--reporter.grpc.retry.max=+[max grpc retry]:n:' \
        '--reporter.grpc.tls.enabled[enable tls]' \
        '--reporter.grpc.tls.ca=+[grpc tls CA]:file:_files' \
        '--reporter.grpc.tls.cert=+[grpc tls cert]:file:_files' \
        '--reporter.grpc.tls.key=+[grpc tls key]:file:_files' \
        '--reporter.grpc.tls.server-name=+[tls server name]:host:_hosts' \
        '--reporter.grpc.tls.skip-host-verify[skip tls host verify]' \
        '--admin.http.host-port=+[admin http host:port]:hostport:' \
        '--http-server.host-port=+[http host:port]:hostport:' \
        '--metrics-backend=+[metrics backend]:b:(prometheus none expvar)' \
        '--metrics-http-route=+[metrics http route]:str:' \
        '--log-level=+[log level]:level:(debug info warn error)' \
        '--log-encoding=+[log encoding]:enc:(console json)' \
        '*:arg:'
}

_jaeger-agent "$@"
