#compdef kivaloo-s3
# _kivaloo-s3 — kivaloo request-batching proxy to Amazon S3 (Tarsnap/kivaloo)
# upstream: https://github.com/Tarsnap/kivaloo
# Flags from s3/main.c (libcperciva GETOPT).

_kivaloo-s3() {
    _arguments \
        '(- *)--version[print version]' \
        '-s+[S3 daemon listen socket]:socket:' \
        '-r+[S3 region]:region:' \
        '-k+[AWS keyfile]:file:_files' \
        '-l+[logfile]:file:_files' \
        '-n+[max simultaneous S3 connections]:n:' \
        '-1[run one request at a time]' \
        '-p+[pidfile]:file:_files'
}

_kivaloo-s3 "$@"
