#compdef caddy
# _caddy-bin — Caddy modern web server with automatic HTTPS (Matt Holt, Stack Holdings); Go-based config-driven server
# upstream: https://github.com/caddyserver/caddy

_caddy-bin() {
    local -a sub=(
        'add-package:add a Go package to caddy build'
        'admin:admin API helpers'
        'adapt:adapt a Caddyfile to JSON'
        'build-info:print build info'
        'completion:print shell completion'
        'environ:print environment'
        'fmt:format a Caddyfile'
        'file-server:run a static file server'
        'hash-password:hash a password'
        'help:show help'
        'json-to-caddyfile:convert JSON config to Caddyfile'
        'list-modules:list compiled modules'
        'manpage:render manpage'
        'remove-package:remove Go package'
        'reload:graceful config reload'
        'respond:run respond demo server'
        'reverse-proxy:run a reverse proxy'
        'run:run caddy with config'
        'start:start caddy in background'
        'stop:stop caddy'
        'storage:storage operations'
        'untrust:remove trusted root cert'
        'trust:trust the local CA'
        'upgrade:upgrade caddy itself'
        'validate:validate a config file'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'caddy subcommand' sub ;;
        args)
            case $words[1] in
                run|start|validate|reload) _arguments \
                    '--config+[config file]:file:_files' \
                    '--adapter+[adapter]:adapter:(caddyfile json json-array yaml toml)' \
                    '--envfile+[env file]:file:_files' \
                    '--environ[print env first]' \
                    '--resume[resume from autosave]' \
                    '--watch[watch + auto reload]' \
                    '--pingback+[ping back addr]:addr:' \
                    '--pidfile+[pid file]:file:_files' \
                    '--force[force action]' \
                    '--address+[admin API addr]:addr:' ;;
                file-server) _arguments \
                    '--root+[root dir]:dir:_files -/' \
                    '--listen+[listen addr]:addr:' \
                    '--domain+[domain]:host:_hosts' \
                    '--browse[directory listing]' \
                    '--access-log[enable access log]' \
                    '--debug[debug log]' \
                    '--no-compress[disable compression]' \
                    '--precompressed+[precompressed formats]:fmt:(gzip br zstd)' \
                    '--templates[enable templates]' ;;
                reverse-proxy) _arguments \
                    '--from+[from addr]:addr:' \
                    '--to+[to addr]:addr:' \
                    '--change-host-header[change host header]' \
                    '--insecure[skip cert verify]' \
                    '--internal-certs[use internal CA]' \
                    '--debug[debug log]' \
                    '--disable-redirects[disable HTTP->HTTPS redirects]' \
                    '--access-log[enable access log]' ;;
                fmt|adapt|json-to-caddyfile) _arguments '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_caddy-bin "$@"
