#compdef tippecanoe

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-o+[output file]:output file:_files -g "*.mbtiles"' \
  '--output=[output file]:output file:_files -g "*.mbtiles"' \
  '-e+[output directory for tiles]:directory:_directories' \
  '--output-to-directory=[output directory for tiles]:directory:_directories' \
  '-f[force overwrite of existing file]' \
  '--force[force overwrite of existing file]' \
  '-F[check features against the schema]' \
  '-z+[maximum zoom level]:zoom level (0-14)' \
  '--maximum-zoom=[maximum zoom level]:zoom level' \
  '-Z+[minimum zoom level]:zoom level (0-14)' \
  '--minimum-zoom=[minimum zoom level]:zoom level' \
  '-zg[guess a maxzoom]' \
  '-r+[drop rate]:rate' \
  '--drop-rate=[drop rate]:rate' \
  '-rg[guess a drop rate]' \
  '-B+[base zoom for drop rate]:zoom level' \
  '--base-zoom=[base zoom for drop rate]:zoom level' \
  '-d+[detail at max zoom]:detail' \
  '--full-detail=[detail at max zoom]:detail' \
  '-D+[detail at lower zoom]:detail' \
  '--low-detail=[detail at lower zoom]:detail' \
  '-m+[minimum detail]:detail' \
  '--minimum-detail=[minimum detail]:detail' \
  '-l+[layer name]:layer name' \
  '--layer=[layer name]:layer name' \
  '-L+[named layer with source]:layer spec' \
  '--named-layer=[named layer with source]:layer spec' \
  '-n+[human-readable name]:name' \
  '--name=[human-readable name]:name' \
  '-N+[description]:description' \
  '--description=[description]:description' \
  '-A+[attribution]:attribution' \
  '--attribution=[attribution]:attribution' \
  '-s+[projection]:projection:(EPSG\:4326 EPSG\:3857)' \
  '--projection=[projection]:projection:(EPSG\:4326 EPSG\:3857)' \
  '-S+[buffer size]:buffer size' \
  '--buffer=[buffer size]:buffer size' \
  '-t+[temporary directory]:directory:_directories' \
  '--temporary-directory=[temporary directory]:directory:_directories' \
  '-P[read input in parallel]' \
  '--read-parallel[read input in parallel]' \
  '-p+[additional properties]:properties' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '--no-feature-limit[do not limit tile feature count]' \
  '--no-tile-size-limit[do not limit tile size]' \
  '--no-tile-compression[do not compress tiles]' \
  '--no-line-simplification[do not simplify lines]' \
  '--simplification=[simplification level]:level' \
  '--no-tiny-polygon-reduction[do not reduce tiny polygons]' \
  '--no-clipping[do not clip features]' \
  '--no-duplication[do not duplicate features across tiles]' \
  '--cluster-distance=[cluster distance]:distance' \
  '--cluster-maxzoom=[maximum zoom for clustering]:zoom' \
  '-g+[calculate gamma]:gamma' \
  '--gamma=[calculate gamma]:gamma' \
  '-ag[automatically choose gamma]' \
  '-aL[automatically choose names for layers]' \
  '-aC[automatically choose coalescing]' \
  '-aD[automatically choose drop densest as needed]' \
  '-aS[automatically choose drop smallest as needed]' \
  '-as[drop a fraction of features]' \
  '-ad[dynamically drop some features]' \
  '-an[drop a fixed fraction of features]' \
  '-ap[spread features across zoom levels]' \
  '-aN[drop features by zoom-level]' \
  '-x+[exclude property]:property name' \
  '--exclude=[exclude property]:property name' \
  '-y+[include only specified property]:property name' \
  '--include=[include only specified property]:property name' \
  '-X[exclude all properties]' \
  '--exclude-all[exclude all properties]' \
  '-T+[coerce property type]:type spec' \
  '--attribute-type=[coerce property type]:type spec' \
  '-j+[filter expression]:filter' \
  '--feature-filter=[filter expression]:filter' \
  '-J+[filter expression file]:filter file:_files' \
  '--feature-filter-file=[filter expression file]:filter file:_files' \
  '-pk[no tile size limit]' \
  '-pf[no feature limit]' \
  '-pC[do not compress tile data]' \
  '-ps[do not simplify lines]' \
  '-pt[do not reduce tiny polygons]' \
  '-pc[do not clip features]' \
  '-pD[do not duplicate features]' \
  '-pi[preserve input order]' \
  '-pp[do not split complex polygons]' \
  '-pr[reverse winding order]' \
  '-pn[do not generate a top-level name]' \
  '*:input file:_files -g "*(geojson|json|csv|tsv|pbf|mbtiles)(-.)"'
