#compdef quiche-client quiche-server
# Documentation: https://github.com/cloudflare/quiche/blob/master/apps/src/args.rs
# Reference accessed: 2026-05-27
# Verified: upstream apps/src/args.rs ClientArgs and ServerArgs (cloudflare/quiche)

local curcontext="$curcontext" state line ret=1

_quiche_client() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '--method=[HTTP request method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
    '--body=[request body file]:file:_files' \
    '--max-data=[connection flow control limit in bytes]:bytes:' \
    '--max-window=[connection receive window in bytes]:bytes:' \
    '--max-stream-data=[per-stream flow control limit in bytes]:bytes:' \
    '--max-stream-window=[per-stream receive window in bytes]:bytes:' \
    '--max-streams-bidi=[max concurrent bidi streams]:count:' \
    '--max-streams-uni=[max concurrent uni streams]:count:' \
    '--idle-timeout=[idle timeout in milliseconds]:milliseconds:' \
    '--wire-version=[QUIC wire version (hex)]:version:' \
    '--http-version=[HTTP version]:version:(http/0.9 h3 all)' \
    '--early-data[attempt 0-RTT early data]' \
    '--dgram-proto=[DATAGRAM protocol]:protocol:(none oneway)' \
    '--dgram-count=[number of DATAGRAMs to send]:count:' \
    '--dgram-data=[DATAGRAM payload]:data:' \
    '--dump-packets=[dump received packets to PATH]:path:_files -/' \
    '--dump-responses=[dump received responses to PATH]:path:_files -/' \
    '--dump-json[dump responses as JSON]' \
    '--max-json-payload=[max bytes captured per JSON payload]:bytes:' \
    '--connect-to=[override connect address]:address:' \
    '--no-verify[skip server certificate verification]' \
    '--trust-origin-ca-pem=[trust origin CA from PEM file]:file:_files' \
    '--no-grease[disable GREASE]' \
    '--cc-algorithm=[congestion control algorithm]:name:(cubic reno bbr bbr2)' \
    '--disable-hystart[disable HyStart++]' \
    '--max-active-cids=[max active connection IDs]:count:' \
    '--enable-active-migration[enable active connection migration]' \
    '--perform-migration[perform active connection migration]' \
    \*{-H+,--header=}'[add HTTP header]:header:' \
    '(-n --requests)'{-n+,--requests=}'[number of requests]:count:' \
    '--send-priority-update[send PRIORITY_UPDATE frames]' \
    '--max-field-section-size=[max HTTP header section size in bytes]:bytes:' \
    '--qpack-max-table-capacity=[QPACK dynamic table capacity in bytes]:bytes:' \
    '--qpack-blocked-streams=[QPACK max blocked streams]:count:' \
    '--session-file=[TLS session ticket file]:file:_files' \
    '--source-port=[local source UDP port]:port:' \
    '--initial-rtt=[initial RTT in milliseconds]:milliseconds:' \
    '--initial-cwnd-packets=[initial congestion window in packets]:packets:' \
    '*:url:_urls' && ret=0
}

_quiche_server() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '--listen=[listen address]:addr\:port:' \
    '--cert=[TLS certificate file]:file:_files' \
    '--key=[TLS private key file]:file:_files' \
    '--root=[document root directory]:directory:_files -/' \
    '--index=[index file name]:name:' \
    '--name=[server hostname]:name:' \
    '--max-data=[connection flow control limit in bytes]:bytes:' \
    '--max-window=[connection receive window in bytes]:bytes:' \
    '--max-stream-data=[per-stream flow control limit in bytes]:bytes:' \
    '--max-stream-window=[per-stream receive window in bytes]:bytes:' \
    '--max-streams-bidi=[max concurrent bidi streams]:count:' \
    '--max-streams-uni=[max concurrent uni streams]:count:' \
    '--idle-timeout=[idle timeout in milliseconds]:milliseconds:' \
    '--dump-packets=[dump received packets to PATH]:path:_files -/' \
    '--early-data[accept 0-RTT early data]' \
    '--no-retry[disable stateless retry]' \
    '--no-grease[disable GREASE]' \
    '--http-version=[HTTP version]:version:(http/0.9 h3 all)' \
    '--dgram-proto=[DATAGRAM protocol]:protocol:(none oneway)' \
    '--dgram-count=[number of DATAGRAMs to send]:count:' \
    '--dgram-data=[DATAGRAM payload]:data:' \
    '--cc-algorithm=[congestion control algorithm]:name:(cubic reno bbr bbr2)' \
    '--disable-hystart[disable HyStart++]' \
    '--max-active-cids=[max active connection IDs]:count:' \
    '--enable-active-migration[enable active connection migration]' \
    '--max-field-section-size=[max HTTP header section size in bytes]:bytes:' \
    '--qpack-max-table-capacity=[QPACK dynamic table capacity in bytes]:bytes:' \
    '--qpack-blocked-streams=[QPACK max blocked streams]:count:' \
    '--disable-gso[disable UDP GSO]' \
    '--disable-pacing[disable packet pacing]' \
    '--initial-rtt=[initial RTT in milliseconds]:milliseconds:' \
    '--initial-cwnd-packets=[initial congestion window in packets]:packets:' && ret=0
}

case $service in
  quiche-client)
    _quiche_client
    ;;
  quiche-server)
    _quiche_server
    ;;
esac

return ret
