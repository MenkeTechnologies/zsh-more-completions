#compdef CompareMetrics
# Documentation: https://github.com/broadinstitute/picard/blob/master/src/main/java/picard/analysis/CompareMetrics.java
# Compare two metrics files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{--INPUT,-I}'=[input metrics files to compare]:value:_files' \
  '(--OUTPUT -O)'{--OUTPUT,-O}'=[output file for comparison results]:value:_files' \
  '--OUTPUT_TABLE=[output table file]:value:_files' \
  '*'{--METRICS_TO_IGNORE,-MI}'=[metric field to ignore]:value:' \
  '*'{--METRICS_NOT_REQUIRED,-MNR}'=[metric field not required to match]:value:' \
  '(--METRIC_ALLOWABLE_RELATIVE_CHANGE -MARC)'{--METRIC_ALLOWABLE_RELATIVE_CHANGE,-MARC}'=[allowable relative change for a metric]:value:' \
  '(--IGNORE_HISTOGRAM_DIFFERENCES -IHD)'{--IGNORE_HISTOGRAM_DIFFERENCES,-IHD}'=[ignore histogram differences]:value:(true false)' \
  '--KEY=[key field for comparison]:value:' \
  '*:argument:_files' && ret=0

return ret
