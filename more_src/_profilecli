#compdef profilecli
# Documentation: https://man.archlinux.org/search?q=profilecli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'query:query profile data from Parca server'
      'label:print label names'
      'symbols:resolve debug symbols'
    )
    _describe -t commands 'profilecli command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '--grpc-address=[Parca gRPC address]:addr' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
