#compdef brlman
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=brlman&sektion=1
# BRL-CAD man page viewer

local ret=1

_arguments -s -S \
  '-h[print help]' \
  '-g[use graphical man page viewer]' \
  '--no-gui[do not use graphical viewer]' \
  '-L[language for selecting man pages]:language' \
  '-S[man page section]:section:(1 3 5 n)' \
  '*:man page:_default' && ret=0

return ret
