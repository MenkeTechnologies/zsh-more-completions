#compdef poledit
# Documentation: https://starlink.eao.hawaii.edu/docs/sun223.htx/sun223ss4.html
# POLPACK: change the values in a vector catalogue.

local ret=1

_arguments -s -S \
  'IN=[input catalogue]:cat:_files' \
  'OUT=[output catalogue]:cat:_files' \
  'NDF=[input NDF for value sourcing]:ndf:_files' \
  'MODE=[edit type]:mode:(AddColumn ChangeColVals Debias Recalc)' \
  'COL=[column to modify or add]:col:' \
  'COL1=[column for first coordinate]:col:' \
  'COL2=[column for second coordinate]:col:' \
  'COMMENT=[comment for new column]:comment:' \
  'UNITS=[units string for new column]:units:' \
  'DEBIASTYPE=[bias estimator type]:type:(AS MAS None)' \
  'MASKCOL=[use NDF as mask]:flag:(TRUE FALSE)' \
  'METHOD=[interpolation scheme]:method:(Nearest Bilinear Sinc SincSinc SincCos SincGauss Somb SombCos Gauss)' \
  'PARAMS=[interpolation parameters]:params:' \
  '*:cat:_files' && ret=0

return ret
