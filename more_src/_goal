#compdef goal
# Documentation: https://developer.algorand.org/docs/clis/goal/goal/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above. `goal` is the Algorand CLI.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'account:control and manage accounts'
  'app:manage applications (smart contracts)'
  'asset:manage assets'
  'clerk:transaction tools'
  'completion:shell completion helper'
  'kmd:interact with key management daemon'
  'ledger:access ledger details'
  'license:show license'
  'logging:logging configuration'
  'network:network operations'
  'node:manage algorand node'
  'protocol:protocol operations'
  'report:reporting tools'
  'wallet:wallet operations'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --datadir)'{-d+,--datadir=}'[data directory]:dir:_files -/' \
  '(-k --kmddir)'{-k+,--kmddir=}'[kmd directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'goal command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (account) _values 'subcommand' 'addpartkey' 'asset' 'balance' 'changeonlinestatus' 'delete' 'deletepartkey' 'dump' 'export' 'import' 'importrootkey' 'info' 'installpartkey' 'list' 'listpartkeys' 'multisig' 'new' 'partkeyinfo' 'rename' 'renewpartkey' 'rewards' 'taxes' && ret=0 ;;
      (app) _values 'subcommand' 'create' 'delete' 'method' 'optin' 'closeout' 'clear' 'call' 'info' 'read' 'update' 'compile' 'sources' && ret=0 ;;
      (asset) _values 'subcommand' 'create' 'destroy' 'config' 'send' 'freeze' 'info' 'optin' && ret=0 ;;
      (clerk) _values 'subcommand' 'compile' 'dryrun' 'dryrun-remote' 'group' 'inspect' 'multisig' 'rawsend' 'send' 'sign' 'simulate' 'split' 'tealsign' && ret=0 ;;
      (node) _values 'subcommand' 'catchup' 'cleanup' 'create' 'generatetoken' 'lastround' 'pendingtxns' 'restart' 'start' 'status' 'stop' 'wait' && ret=0 ;;
      (wallet) _values 'subcommand' 'list' 'new' && ret=0 ;;
    esac ;;
esac

return ret
