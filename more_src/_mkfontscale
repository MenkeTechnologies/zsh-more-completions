#compdef mkfontscale mkfontdir
# _mkfontscale — X11 mkfontscale / mkfontdir (build the fonts.scale and fonts.dir indexes in a font directory; -b adds bitmap fonts to scale list, -s scale-only, -u skip scale, -o output filename, -a encodings, -e encodings dir, positional dir argument)
# upstream: https://gitlab.freedesktop.org/xorg/app/mkfontscale
# Flags from mkfontscale src/mkfontscale.c on tip.

_mkfontscale() {
    _arguments \
        '-b[include bitmap fonts]' \
        '-s[scalable only]' \
        '-u[skip scalable fonts]' \
        '-r[do not reset symlinks]' \
        '-x+[extension to exclude]:ext:' \
        '-o+[output filename]:file:_files' \
        '-a+[additional encodings file]:file:_files' \
        '-e+[encodings dir]:dir:_files -/' \
        '-l[skip latin1 default]' \
        '-n[do not write fonts.dir]' \
        '-v[verbose]' \
        '*:font dir:_files -/'
}

_mkfontscale "$@"
