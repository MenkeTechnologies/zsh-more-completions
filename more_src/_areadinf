#compdef areadinf AreaDinf
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/DInfinityContributingArea.html
# TauDEM: compute D-infinity contributing area

local ret=1

_arguments -s -S \
  '-ang[input Dinf flow directions grid]:angfile:_files' \
  '-sca[output Dinf contributing area grid]:scafile:_files' \
  '-o[input outlets file (OGR readable dataset)]:outletfile:_files' \
  '-wg[input weight grid]:wgfile:_files' \
  '-nc[disable edge contamination checking]' \
  '(-lyrno)-lyrname[OGR layer name for outlets]:layer name:' \
  '(-lyrname)-lyrno[OGR layer number for outlets]:layer number:' \
  '*:file:_files' && ret=0

return ret
