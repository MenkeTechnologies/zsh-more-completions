#compdef rustbuster
# Documentation: https://github.com/phra/rustbuster
# DirBuster for rust: directory, DNS, vhost, IIS tilde and custom fuzzing modes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '(-t --threads)'{-t,--threads}'+[sets the amount of concurrent requests]:n' \
  '(-o --output)'{-o,--output}'+[saves the results in the specified file]:file:_files' \
  '(-u --url)'{-u,--url}'+[sets the target URL]:url:_urls' \
  '*'{-w,--wordlist}'+[sets the wordlist]:file:_files' \
  '(-a --user-agent)'{-a,--user-agent}'+[uses the specified User-Agent]:ua' \
  '(-X --http-method)'{-X,--http-method}'+[uses the specified HTTP method]:method' \
  '*'{-H,--http-header}'+[appends the specified HTTP header]:header' \
  '(-b --http-body)'{-b,--http-body}'+[uses the specified HTTP body]:body' \
  '(-s --include-status-codes)'{-s,--include-status-codes}'+[sets status codes to include]:codes' \
  '(-S --ignore-status-codes)'{-S,--ignore-status-codes}'+[sets status codes to ignore]:codes' \
  '(-K --exit-on-error)'{-K,--exit-on-error}'[exits on connection errors]' \
  '(-k --ignore-certificate)'{-k,--ignore-certificate}'[disables TLS certificate validation]' \
  '(-v --verbose)'{-v,--verbose}'[sets the level of verbosity]' \
  '--no-banner[skips initial banner]' \
  '--no-progress-bar[disables the progress bar]' \
  '1:mode:((dir\:"directories and files enumeration" dns\:"A/AAAA entries enumeration" fuzz\:"custom fuzzing enumeration" vhost\:"virtual hosts enumeration" tilde\:"IIS 8.3 shortname enumeration"))' && ret=0

return ret
