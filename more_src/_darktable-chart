#compdef darktable-chart
# Documentation: https://man.archlinux.org/search?q=darktable-chart
# Reference accessed: 2026-05-16

# darktable-chart: builds .dtstyle from IT8/ColorChecker reference + measurements
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)-h[show help]' \
  '--version[show version]' \
  '*:chart files:_files -g "*.(it8|cht|cie|csv|dtstyle|tiff|tif|jpg|jpeg|png|cr2|nef|raf|arw|orf|dng)"' && ret=0
return ret
