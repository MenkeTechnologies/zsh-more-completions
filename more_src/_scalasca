#compdef scalasca
# _scalasca — Scalasca HPC scalable performance analyzer (Jülich); wraps Score-P measurement + cube postproc for MPI app analysis
# upstream: https://www.scalasca.org

_scalasca() {
    local -a sub=(
        'analyze:analyze an experiment archive'
        'examine:open experiment archive in cube'
        'instrument:instrument application via Score-P'
        'show:print experiment summary'
        'archive:archive an experiment'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scalasca subcommand' sub ;;
        args)
            case $words[1] in
                analyze|examine|show|archive) _arguments '*:experiment:_files -/' ;;
                instrument) _arguments '*::command:_command_names -e' ;;
            esac
            ;;
    esac
}

_scalasca "$@"
