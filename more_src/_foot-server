#compdef foot-server footserver

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c[config file]:config:_files' \
  '-C[check config and exit]' \
  '-o[override config option]:key=value:' \
  '-f[font specification]:font:' \
  '-t[terminal type]:TERM:' \
  '-T[window title]:title:' \
  '-a[app-id]:app id:' \
  '-L[log level]:level:(info warning error none)' \
  '-l[log file]:file:_files' \
  '-s[socket path]:socket:_files' \
  '-d[print PID of server process]' \
  '-D[enable log colorization]:when:(auto always never)' \
  '--print-pid[print PID to file]:file:_files' && ret=0

return ret
