#compdef consul-replicate
# Documentation: https://github.com/hashicorp/consul-replicate
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# consul-replicate: replicate Consul KV across DCs.
# Flags below confirmed from README and equivalent fields in config.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-config=[config file or directory]:file:_files' \
  '-consul=[Consul HTTP addr]:addr:' \
  '-token=[ACL token]:token:' \
  '-prefix=[prefix to replicate (src@dc:dest)]:prefix:' \
  '-exclude=[exclude key path from replication]:path:' \
  '-once[run once then exit]' \
  '-status-dir=[status directory in Consul KV]:dir:' \
  '-auth=[Consul HTTP basic auth user:pass]:auth:' \
  '-ssl[use HTTPS for Consul]' \
  '-ssl-verify[verify SSL]' \
  '-ssl-ca-cert=[CA cert file]:file:_files' \
  '-ssl-cert=[client cert file]:file:_files' \
  '-max-stale=[max staleness for stale reads]:duration:' \
  '-retry=[retry interval]:duration:' \
  '-log-level=[log level]:level:(trace debug info warn err)' \
  '-syslog[log to syslog]' \
  '-syslog-facility=[syslog facility]:facility:' \
  '-pid-file=[PID file]:file:_files' \
  '-wait=[min:max wait before replicating]:wait:' && ret=0

return ret
