#compdef cargo-flash
# Documentation: https://probe.rs/docs/tools/cargo-flash/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# CLI mirrors probe-rs cargo_flash CliOptions + flattened ProbeOptions,
# BinaryDownloadOptions, FormatOptions, CargoOptions in probe-rs-tools.

_arguments -s \
  '--reset-halt[reset and halt the core after flashing]' \
  '--log=[set log level]:level:(off error warn info debug trace)' \
  '--path=[path to file to flash (overrides cargo build)]:file:_files' \
  '--work-dir=[cargo working directory]:dir:_files -/' \
  '--preset=[configuration preset]:name:' \
  '--host=[remote server URL]:url:' \
  '--token=[remote server token]:token:' \
  '--chip=[target chip]:chip:' \
  '--chip-description-path=[chip description YAML]:file:_files -g "*.yaml"' \
  '--protocol=[wire protocol]:proto:(swd jtag)' \
  '--cycle-power[cycle power before connecting]' \
  '--non-interactive[disable interactive prompts]' \
  '--probe=[probe selector VID:PID[:SERIAL]]:probe:' \
  '--speed=[protocol speed in kHz]:khz:' \
  '--connect-under-reset[assert reset during attach]' \
  '--dry-run[do not actually flash]' \
  '--allow-erase-all[allow chip-erase commands]' \
  '--disable-progressbars[disable progress bars]' \
  '--disable-double-buffering[disable double buffering]' \
  '--restore-unwritten[preserve sector-erase bytes]' \
  '--flash-layout=[write flash layout to file]:file:_files' \
  '--preverify[skip writes when content matches]' \
  '--verify[verify after flashing]' \
  '--chip-erase[perform chip erase before flashing]' \
  '--read-flasher-rtt[capture RTT output from flasher]' \
  '*--prefer-flash-algorithm=[preferred flash algorithm name]:name:' \
  '--bin=[build binary]:name:' \
  '--example=[build example]:name:' \
  '(-p --package)'{-p+,--package=}'[package]:name:' \
  '--release[build in release mode]' \
  '--target=[Rust target triple]:target:' \
  '--manifest-path=[Cargo.toml path]:file:_files -g "Cargo.toml"' \
  '--no-default-features[disable default features]' \
  '--all-features[enable all features]' \
  '*--features=[features]:features:' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]'
