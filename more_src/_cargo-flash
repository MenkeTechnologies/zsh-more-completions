#compdef cargo-flash

_arguments -s \
  '--chip=[target chip]:chip:' \
  '(-c --chip-description-path)'{-c,--chip-description-path=}'[chip description YAML]:file:_files -g "*.yaml"' \
  '--probe=[probe selector VID:PID[:SERIAL]]:probe:' \
  '--probe-index=[Nth probe]:n:' \
  '--protocol=[wire protocol]:proto:(swd jtag)' \
  '--speed=[protocol speed kHz]:khz:' \
  '--connect-under-reset[assert reset during attach]' \
  '--elf=[ELF to flash]:file:_files' \
  '--work-dir=[cargo working directory]:dir:_files -/' \
  '--list-chips[list supported chips]' \
  '--list-probes[list connected probes]' \
  '--restore-unwritten[preserve sector-erase bytes]' \
  '--reset-halt[reset and halt after flashing]' \
  '--read-flasher-rtt[capture RTT output]' \
  '--preset=[probe-rs config preset]:name:' \
  '--log=[log level]:level:(off error warn info debug trace)' \
  '--host=[remote server URL]:url:' \
  '--token=[remote server token]:token:' \
  '--release[release profile]' \
  '--target=[Rust target]:target:' \
  '--example=[run example]:name:' \
  '--bin=[build binary]:name:' \
  '--package=[package]:name:' \
  '--features=[features]:feats:' \
  '--all-features[enable all features]' \
  '--no-default-features[disable default features]' \
  '--profile=[profile]:profile:' \
  '--manifest-path=[Cargo.toml]:file:_files -g "Cargo.toml"' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]'
