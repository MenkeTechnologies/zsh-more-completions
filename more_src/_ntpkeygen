#compdef ntpkeygen

# ntpkeygen: generate NTP authentication keys and certificates
local curcontext="$curcontext" ret=1
_arguments -C \
  '-c[cipher type]:cipher:(RSA-MD2 RSA-MD5 RSA-MDC2 RSA-SHA RSA-SHA1 RSA-RIPEMD160 DSA-SHA DSA-SHA1)' \
  '-d[debug verbosity]:level:' \
  '-e[write identity keys (Schnorr/GQ/IFF/MV)]:keys:' \
  '-g[generate Guillou-Quisquater encryption keys]' \
  '-H[generate host keys]' \
  '-I[generate IFF keys]' \
  '-i[set certificate subject (issuer)]:string:' \
  '-l[set certificate lifetime in days]:n:' \
  '-M[generate MD5 keys]' \
  '-m[set key length in bits]:n:' \
  '-p[password for encrypted keys]:password:' \
  '-q[password for encrypted keys to read]:password:' \
  '-S[generate Schnorr identity keys]' \
  '-s[set certificate subject name]:name:' \
  '-T[generate certificate trust]' \
  '-V[set MV identity scheme]:val:' \
  '-v[verbose mode]' \
  '*::ntpkeygen args:_files' && ret=0
return ret
