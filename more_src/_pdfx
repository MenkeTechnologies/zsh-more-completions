#compdef pdfx
# Documentation: https://github.com/metachris/pdfx/blob/master/pdfx/cli.py
# Extract text, metadata and references (url, doi, arxiv) from PDF

local ret=1

_arguments -s -S \
  '(- :)--version[show version and exit]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --download-pdfs)'{-d,--download-pdfs}'=[download all referenced PDFs into directory]:directory:_files -/' \
  '(-c --check-links)'{-c,--check-links}'[check for broken links]' \
  '(-j --json)'{-j,--json}'[output infos as JSON instead of plain text]' \
  '(-v --verbose)'{-v,--verbose}'[print all references instead of only PDFs]' \
  '(-t --text)'{-t,--text}'[only extract text, no metadata or references]' \
  '(-o --output-file)'{-o,--output-file}'=[output to file instead of console]:file:_files' \
  '1:PDF file or URL:_files -g "*.pdf"' && ret=0

return ret
