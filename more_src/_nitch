#compdef nitch

# Zsh completion for nitch - minimalist system fetch written in Rust/Zig

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-v --version)'{-v,--version}'[show nitch version]'
  '--no-logo[do not display the ASCII logo]'
  '--no-color[disable colored output]'
  '--config[path to config file]:file:_files'
)

_arguments -s $arguments
