#compdef nitch
# Documentation: https://github.com/ssleert/nitch
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nitch - minimalist system fetch written in Nim.
# Per upstream README, nitch only accepts -f/--fetch, -h/--help, -v/--version.
# All other customization is done by editing src/funcs/drawing.nim and recompiling.

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-v --version)'{-v,--version}'[show nitch version]'
  '(-f --fetch)'{-f,--fetch}'[return system fetch information]'
)

_arguments -s $arguments
