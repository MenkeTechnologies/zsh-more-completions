#compdef statsnoop statsnoop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/statsnoop.py argparse)
# Reference accessed: 2026-05-29
# statsnoop — trace stat() syscalls (BCC/eBPF). Useful for spotting stat-heavy workloads.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-t --timestamp)'{-t,--timestamp}'[include timestamp on output]' \
  '(-s --sysname)'{-s,--sysname}'[include syscall name on output]' \
  '(-x --failed)'{-x,--failed}'[only show failed stats]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
