#compdef yunikorn-scheduler scheduler k8s_yunikorn_scheduler
# _yunikorn-scheduler — Apache YuniKorn k8s shim (resource scheduler with queue-based gang scheduling)
# upstream: https://github.com/apache/yunikorn-k8shim
# Source: pkg/cmd/shim/main.go on tip; no CLI flags — runtime config via ConfigMaps + env vars (NAMESPACE, KUBE_CONFIG, OPERATOR_SERVICE_ACCOUNT, etc.).

_yunikorn-scheduler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_yunikorn-scheduler "$@"
