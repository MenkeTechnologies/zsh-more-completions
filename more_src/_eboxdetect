#compdef eboxdetect
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/eboxdetect/node4.html
# XMM-Newton SAS: sliding box EPIC source searching (local or global background)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--imagesets=[names of EPIC fits images]:files:_files' \
  '--boxlistset=[name of output source list]:file:_files' \
  '--bkgimagesets=[names of spline background maps]:files:_files' \
  '--expimagesets=[names of exposure images]:files:_files' \
  '--detmasksets=[name of detection mask]:file:_files' \
  '--mergedlistset=[name of merged source list]:file:_files' \
  '--usemap=[map mode (true) or local mode (false)]:flag:(yes no)' \
  '--usematchedfilter=[matched filter flag]:flag:(yes no)' \
  '--withdetmask=[detection mask activation flag]:flag:(yes no)' \
  '--withexpimage=[exposure image activation flag]:flag:(yes no)' \
  '--boxsize=[size of detection box (3x3 or 5x5)]:size:(3 5)' \
  '--nruns=[number of detection runs]:n:' \
  '--likemin=[minimum detection likelihood]:like:' \
  '--ecf=[energy conversion factors]:ecf:' \
  '--hrdef=[energy bands for hardness ratio]:bands:' \
  '--pimin=[lower PI channel limits (eV)]:ev:' \
  '--pimax=[upper PI channel limits (eV)]:ev:' \
  '--imagebuffersize=[memory for mosaic images]:size:' \
  '--withimagebuffersize=[allow user-defined imagebuffersize]:flag:(yes no)' \
  '--obsmode=[observation mode of input data]:mode:(pointing slew)' \
  '*:file:_files' && ret=0

return ret
