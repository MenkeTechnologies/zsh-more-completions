#compdef fdump
# Convert the contents of a FITS table to ASCII format

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "outfile=[output ASCII file]:file:_files" \
  "columns=[columns to dump]:" \
  "rows=[rows to dump]:" \
  "fldsep=[field separator character]:" \
  "pagewidth=[page width in characters]:" \
  "prhead=[print header keywords]:bool:(yes no)" \
  "prdata=[print table data]:bool:(yes no)" \
  "showcol=[print column names]:bool:(yes no)" \
  "showunit=[print column units]:bool:(yes no)" \
  "showrow=[print row numbers]:bool:(yes no)" \
  "showscale=[apply scaling]:bool:(yes no)" \
  "align=[align columns]:bool:(yes no)" \
  "wrap=[wrap wide tables]:bool:(yes no)" \
  "page=[paginate output]:bool:(yes no)" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "sensecase=[case sensitive column names]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
