#compdef dusage
# Documentation: https://man.archlinux.org/search?q=dusage
# Reference accessed: 2026-05-16

# Zsh completion for dusage (mihaigalos/dusage, manual clap builder).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[print internal state]' \
  '(-i --inodes)'{-i,--inodes}'[show inode info]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-c --copy-friendly)'{-c,--copy-friendly}'[plain background for copy-paste]'
