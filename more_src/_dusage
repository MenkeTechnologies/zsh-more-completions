#compdef dusage
# Documentation: https://github.com/mihaigalos/dusage
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dusage - disk usage tool (Rust, clap)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[print internal state]' \
  '(-i --inodes)'{-i,--inodes}'[show inode info]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-c --copy-friendly)'{-c,--copy-friendly}'[plain background for copy-paste]'
