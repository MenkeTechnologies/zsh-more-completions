#compdef gen-linkml
# _gen-linkml — canonicalize / materialize a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/linkmlgen.py (click).

_gen-linkml() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.(yaml|yml)"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(yaml json)'
        '--materialize[materialize inferred schema elements]'
        '--no-materialize[do not materialize inferred schema elements]'
        '--materialize-attributes[materialize attributes induced through inheritance]'
        '--no-materialize-attributes[leave attributes implicit]'
        '--materialize-patterns[expand regex pattern macros]'
        '--no-materialize-patterns[leave pattern macros unexpanded]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-linkml "$@"
