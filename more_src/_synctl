#compdef synctl
# Documentation: https://element-hq.github.io/synapse/latest/setup/installation.html
# Reference accessed: 2026-05-21
# Verified: upstream synctl.py source in element-hq/synapse and Ubuntu manpage.
# synctl: start/stop/restart Synapse homeserver and workers.

local curcontext="$curcontext" ret=1

_arguments -s -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-w --worker)'{-w,--worker}'[start/stop a single worker process]:workerconfig:_files' \
  '(-a --all-processes)'{-a,--all-processes}'[start/stop all workers in directory plus main process]:workerconfigdir:_files -/' \
  '--no-daemonize[run synapse in the foreground (do not daemonize)]' \
  '1:action:(start stop restart)' \
  '2:configfile:_files' && ret=0

return ret
