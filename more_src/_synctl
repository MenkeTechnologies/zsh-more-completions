#compdef synctl
# Documentation: https://man.archlinux.org/search?q=synctl
# Reference accessed: 2026-05-16

_arguments -s \
  '(-w --worker)'{-w,--worker}'=[worker config]:file:_files' \
  '(-a --all-processes)'{-a,--all-processes}'=[worker config dir]:dir:_files -/' \
  '--no-daemonize[run in foreground]' \
  '1:action:(start stop restart)' \
  '2:configfile:_files'
