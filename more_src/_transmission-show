#compdef transmission-show
# Documentation: https://manpages.debian.org/bookworm/transmission-cli/transmission-show.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show a short help page]' \
  '(-m --magnet)'{-m,--magnet}'[show the magnet link for the torrent]' \
  '(-s --scrape)'{-s,--scrape}'[scrape the tracker for seed/peer counts]' \
  '1:torrent file:_files -g "*.torrent"' && ret=0

return ret
