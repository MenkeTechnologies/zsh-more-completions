#compdef transmission-show

# Zsh completion for transmission-show - display torrent file information

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-m --magnet)'{-m,--magnet}'[show the magnet link for the torrent]' \
  '(-s --scrape)'{-s,--scrape}'[scrape the tracker for seed/peer counts]' \
  '(-u --unsorted)'{-u,--unsorted}'[do not sort file list]' \
  '(-V --version)'{-V,--version}'[show version number]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:torrent file:_files -g "*.torrent"' && ret=0

return ret
