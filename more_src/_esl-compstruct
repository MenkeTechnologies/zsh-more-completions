#compdef esl-compstruct

# Easel esl-compstruct: compare two RNA secondary-structure alignments
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-m[only report mean accuracy]' \
  '-q[quiet output]' \
  '--informat[input format]:fmt:(stockholm pfam a2m afa)' \
  '*:two alignment files:_files' && ret=0
return ret
