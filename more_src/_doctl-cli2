#compdef doctl-cli2
# Documentation: https://docs.digitalocean.com/reference/doctl/reference/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  '1-click:1-click apps'
  'account:account commands'
  'apps:DigitalOcean Apps Platform'
  'auth:authentication'
  'balance:account balance'
  'billing-history:billing history'
  'compute:compute resources'
  'databases:managed databases'
  'genai:GenAI services'
  'invoice:invoice commands'
  'kubernetes:kubernetes clusters'
  'monitoring:monitoring commands'
  'projects:projects'
  'registry:container registry'
  'serverless:serverless functions'
  'spaces:Spaces object storage'
  'storage:Spaces (alias)'
  'tags:tag management'
  'vpcs:VPCs'
  'completion:print shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--access-token=[OAuth token]:t:' \
  '*-t+[OAuth token]:t:' \
  '*--api-url=[API URL]:url:' \
  '*-u+[API URL]:url:' \
  '*--config=[config file]:file:_files -g "*.yaml *.yml"' \
  '*-c+[config file]:file:_files' \
  '*--context=[auth context]:c:' \
  '*--http-retry-max=[max retries]:n:' \
  '*--http-retry-wait-max=[max wait s]:s:' \
  '*--http-retry-wait-min=[min wait s]:s:' \
  '*--interactive[interactive]' \
  '*-o+[output format]:f:(json text)' \
  '*--output=[output format]:f:(json text)' \
  '*--trace[trace HTTP]' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'doctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (auth)
        _arguments \
          '1:subcommand:(init list remove switch)' \
          '*: :' && ret=0 ;;
      (compute)
        _arguments \
          '1:subcommand:(action cdn certificate domain droplet droplet-action firewall floating-ip image load-balancer reserved-ip reserved-ip-action region size snapshot ssh ssh-key tag volume volume-action)' \
          '*: :' && ret=0 ;;
      (kubernetes)
        _arguments \
          '1:subcommand:(1-click cluster options)' \
          '*: :' && ret=0 ;;
      (apps)
        _arguments \
          '1:subcommand:(create create-deployment delete dev get get-deployment list list-alerts list-buildpacks list-deployments list-instance-sizes list-regions list-tiers logs propose restart spec tier update update-alert-destinations upgrade-buildpack)' \
          '*: :' && ret=0 ;;
      (databases)
        _arguments \
          '1:subcommand:(backups certificate cluster connection create delete events firewall fork get list maintenance-window options pool replica resize sql-mode user user-list)' \
          '*: :' && ret=0 ;;
      (registry)
        _arguments \
          '1:subcommand:(create delete docker-config garbage-collection get kubernetes-manifest login logout repository)' \
          '*: :' && ret=0 ;;
      (serverless)
        _arguments \
          '1:subcommand:(activations connect deploy functions init install namespaces status triggers undeploy uninstall)' \
          '*: :' && ret=0 ;;
      (vpcs)
        _arguments \
          '1:subcommand:(create delete get list members update)' \
          '*: :' && ret=0 ;;
      (projects)
        _arguments \
          '1:subcommand:(create delete get list resources update)' \
          '*: :' && ret=0 ;;
      (tags)
        _arguments \
          '1:subcommand:(create delete get list)' \
          '*: :' && ret=0 ;;
      (monitoring)
        _arguments \
          '1:subcommand:(alert)' \
          '*: :' && ret=0 ;;
      (account)
        _arguments \
          '1:subcommand:(get ratelimit)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
