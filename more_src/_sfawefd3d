#compdef sfawefd3d
# Documentation: https://raw.githubusercontent.com/ahay/src/master/user/cwp/Mawefd3d.c
# Madagascar: 3D acoustic time-domain finite-difference modeling

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'verb=[verbosity flag (y/n)]:flag:(y n)' \
  'snap=[wavefield snapshots (y/n)]:flag:(y n)' \
  'expl=[explosion source (y/n)]:flag:(y n)' \
  'dabc=[absorbing boundary condition (y/n)]:flag:(y n)' \
  'cden=[constant density (y/n)]:flag:(y n)' \
  'adj=[adjoint flag (y/n)]:flag:(y n)' \
  'free=[free surface (y/n)]:flag:(y n)' \
  'fsrf=[free surface (y/n)]:flag:(y n)' \
  'optfd=[optimized FD scheme (y/n)]:flag:(y n)' \
  'fdorder=[finite-difference spatial order]:order:' \
  'hybridbc=[hybrid one-way absorbing BC (y/n)]:flag:(y n)' \
  'sinc=[sinc interpolation (y/n)]:flag:(y n)' \
  'jsnap=[snapshot interval]:interval:' \
  'jdata=[data interval]:interval:' \
  'nqz=[depth samples in output]:n:' \
  'nqx=[x samples in output]:n:' \
  'nqy=[y samples in output]:n:' \
  'oqz=[depth origin of output]:o:' \
  'oqx=[x origin of output]:o:' \
  'oqy=[y origin of output]:o:' \
  'dqz=[depth sampling of output]:d:' \
  'dqx=[x sampling of output]:d:' \
  'dqy=[y sampling of output]:d:' \
  'nb=[absorbing boundary thickness]:n:' \
  'den=[density file]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
