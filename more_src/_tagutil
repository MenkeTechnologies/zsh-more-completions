#compdef tagutil
# Documentation: https://github.com/kaworu/tagutil
# tagutil - scriptable music files tags tool and editor

local ret=1

_arguments -s \
  '-h[show help]' \
  '-p[create destination directories if needed]' \
  '-F+[output format for print/edit/load actions]:format:(yml json)' \
  '-Y[answer yes to all questions]' \
  '-N[answer no to all questions]' \
  '*::action:->actions' && ret=0

case $state in
  actions)
    local -a acts
    acts=(
      'print:display file tags'
      'backend:show which tag backend is used'
      'clear\::remove all instances of a tag (or all tags)'
      'add\::add a tag-value pair (add:TAG=VALUE)'
      'set\::set a tag to a value (set:TAG=VALUE)'
      'edit:open tags in configured editor'
      'load\::import tags from a YAML file (load:PATH)'
      'rename\::rename files based on a pattern'
    )
    _describe -t actions 'action' acts || _files
    ;;
esac

return ret
