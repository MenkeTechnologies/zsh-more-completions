#compdef sunull
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/synthetics_waveforms_testpatterns/sunull.c
# create null (all zeroes) traces

local ret=1

_arguments -s -S \
  'nt=[number of samples per trace]:nt' \
  'ntr=[number of null traces to create]:ntr' \
  'dt=[time sampling interval]:dt' \
  '*:file:_files' && ret=0


return ret
