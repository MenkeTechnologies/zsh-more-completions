#compdef tile38-cli
# Documentation: https://man.archlinux.org/search?q=tile38-cli
# Reference accessed: 2026-05-16

# tile38-cli: CLI client for Tile38
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '-h[server host]:host:_hosts' \
  '-p[server port]:port:' \
  '-a[auth password]:pass:' \
  '-e[command to execute]:cmd:' \
  '-i[interactive]' \
  '--raw[raw output]' \
  '--no-auth-warning[suppress no-auth warning]' \
  '*::tile38-cli args:_files' && ret=0
return ret
