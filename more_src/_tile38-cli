#compdef tile38-cli
# Documentation: https://github.com/tidwall/tile38/blob/master/cmd/tile38-cli/main.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tile38-cli: CLI client for Tile38
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '-h[server host]:host:_hosts' \
  '-p[server port]:port:' \
  '-x[read final arg from STDIN]' \
  '--raw[raw output]' \
  '--noprompt[suppress prompt]' \
  '--resp[RESP output formatting]' \
  '--json[JSON output formatting]' \
  '--tty[TTY mode]' \
  '*::tile38-cli args:_files' && ret=0
return ret
