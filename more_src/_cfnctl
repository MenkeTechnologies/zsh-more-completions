#compdef cfnctl

# rogerwelin/cfnctl (cobra); Homebrew: Formula/c/cfnctl.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '--region=[AWS region]:region:' \
  '--profile=[AWS profile]:profile:' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'cfnctl command' compadd -- plan apply destroy output graph version init completion
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
