#compdef cfnctl
# Documentation: https://github.com/rogerwelin/cfnctl
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local -a cmds=(
    'apply:create or update infrastructure'
    'plan:show changes required by the current configuration'
    'destroy:destroy previously-created infrastructure'
    'output:show all exported output values for the stack'
    'validate:check whether the configuration is valid'
    'version:show the current cfnctl version'
    'help:show help for a command'
  )
  _describe -t commands 'cfnctl command' cmds && ret=0
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
