#compdef tsv-pretty
# Documentation: https://github.com/eBay/tsv-utils/blob/master/docs/tool_reference/tsv-pretty.md
# tsv-pretty - print TSV data aligned for easier reading

local ret=1

_arguments -s -S \
  '(--help --help-verbose)--help[print help]' \
  '(--help --help-verbose)--help-verbose[print full help]' \
  '(-H --header -x --no-header)'{-H,--header}'[treat first line of each file as a header]' \
  '(-H --header -x --no-header)'{-x,--no-header}'[assume no header; turn off automatic header detection]' \
  '(-l --lookahead)'{-l,--lookahead}'=[lines to read before generating output (default: 1000)]:num:' \
  '(-r --repeat-header)'{-r,--repeat-header}'=[lines to print before repeating the header]:num:' \
  '(-u --underline-header)'{-u,--underline-header}'[underline the header]' \
  '(-f --format-floats)'{-f,--format-floats}'[format floats for better readability]' \
  '(-p --precision)'{-p,--precision}'=[max floating point precision (default: 9)]:num:' \
  '(-e --replace-empty -E --empty-replacement)'{-e,--replace-empty}'[replace empty fields with --]' \
  '(-e --replace-empty -E --empty-replacement)'{-E,--empty-replacement}'=[replace empty fields with the given string]:string:' \
  '(-d --delimiter)'{-d,--delimiter}'=[field delimiter (default: TAB)]:delimiter char:' \
  '(-s --space-between-fields)'{-s,--space-between-fields}'=[spaces between fields (default: 2)]:num:' \
  '(-m --max-text-width)'{-m,--max-text-width}'=[max width for text fields (default: 40)]:num:' \
  '(-a --auto-preamble -b --preamble)'{-a,--auto-preamble}'[treat initial lines without delimiters as preamble]' \
  '(-a --auto-preamble -b --preamble)'{-b,--preamble}'=[treat the first NUM lines as preamble]:num:' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '*:file:_files' && ret=0

return ret
