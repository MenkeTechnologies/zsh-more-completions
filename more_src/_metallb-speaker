#compdef metallb-speaker speaker
# _metallb-speaker — MetalLB per-node speaker (announces LoadBalancer IPs via L2/ARP or BGP)
# upstream: https://github.com/metallb/metallb
# Flags from speaker/main.go on tip.

_metallb-speaker() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-port=[HTTPS metrics port]:port:' \
        '-bgp-debounce-timeout=[BGP session debounce timeout]:dur:' \
        '-namespace=[config + speakers namespace]:ns:' \
        '-ml-bindaddr=[MemberList bind address]:addr:' \
        '-ml-bindport=[MemberList bind port]:port:' \
        '-ml-labels=[label selector to match speakers for MemberList]:selector:' \
        '-ml-secret-key-path=[path to MemberList secret key file]:path:_files' \
        '-ml-wan-config[use WAN MemberList preset]' \
        '-node-name=[name of this Kubernetes node (spec.nodeName)]:name:' \
        '-pod-name=[name of this speaker pod]:name:' \
        '-log-level=[log level]:level:(all debug info warn error none)' \
        '-pprof-bind-address=[pprof endpoint bind addr (empty=off)]:addr:' \
        '-health-probe-port=[health probe port]:port:' \
        '-lb-class=[only handle services with this spec.loadBalancerClass]:class:' \
        '-ignore-exclude-lb[ignore node.kubernetes.io/exclude-from-external-load-balancers label]' \
        '-frrk8s-namespace=[namespace where frr-k8s is deployed]:ns:' \
        '-tls-min-version=[minimum TLS version]:ver:(VersionTLS12 VersionTLS13)' \
        '-tls-cipher-suites=[comma-separated TLS 1.2 cipher suites]:list:' \
        '-tls-curve-preferences=[comma-separated CurveID values]:list:' \
        '-metrics-cert-dir=[directory with tls.crt/tls.key for metrics TLS]:dir:_files -/'
}

_metallb-speaker "$@"
