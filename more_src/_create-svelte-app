#compdef create-svelte-app
# Documentation: https://www.npmjs.com/package/create-svelte-app
# Reference accessed: 2026-05-23
# Verified: npx create-svelte-app --help.

# Zsh completion for create-svelte-app - Svelte app scaffolder

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'serve:serve a project or single .svelte file'
  'create:create a new project'
  'build:build a project'
  'help:display command help'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-V --version)'{-V,--version}'[show version]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'create-svelte-app command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
