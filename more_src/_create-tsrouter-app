#compdef create-tsrouter-app
# Documentation: https://www.npmjs.com/package/create-tsrouter-app
# Reference accessed: 2026-05-23
# Verified: npx create-tsrouter-app --help.

# Zsh completion for create-tsrouter-app - TanStack Router app scaffolder

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new project'
  'add:add add-ons to an existing project'
  'migrate:migrate an existing project'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--framework=[project framework]:framework:(React Solid)' \
  '--template=[template URL or built-in id]:template:' \
  '--template-id=[built-in template id]:id:' \
  '--no-install[skip installing dependencies]' \
  '--package-manager=[package manager]:manager:(npm yarn pnpm bun deno)' \
  '--dev-watch=[watch framework directory]:path:_directories' \
  '--run-dev[run dev server alongside dev-watch]' \
  '--router-only[file-based routing without TanStack Start]' \
  '--examples[include demo pages]' \
  '--no-examples[exclude demo pages]' \
  '--deployment=[deployment adapter]:adapter:(cloudflare netlify nitro railway)' \
  '--toolchain=[toolchain]:toolchain:(biome eslint)' \
  '--no-toolchain[skip toolchain selection]' \
  '--interactive[interactive mode]' \
  '--non-interactive[skip prompts]' \
  '(-y --yes)'{-y,--yes}'[accept defaults]' \
  '--add-ons=[add-ons to install]:addons:' \
  '--list-add-ons[list available add-ons]' \
  '--addon-details=[add-on details]:addon:' \
  '--json[output JSON]' \
  '--git[create git repository]' \
  '--no-git[do not create git repository]' \
  '--intent[set up TanStack Intent skill mappings]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'create-tsrouter-app command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
