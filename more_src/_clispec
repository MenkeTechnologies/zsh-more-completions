#compdef clispec
# Documentation: https://github.com/rvben/clispec-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Generated via: clispec completions zsh (clap-built completion).

autoload -U is-at-least

_clispec() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_clispec_commands" \
"*::: :->clispec" \
&& ret=0
    case $state in
    (clispec)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:clispec-command-$line[1]:"
        case $line[1] in
            (score)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
':binary -- Binary name or path to score:_default' \
'*::subcommand -- Subcommand to test with (optional):_default' \
&& ret=0
;;
(schema)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_clispec__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:clispec-help-command-$line[1]:"
        case $line[1] in
            (score)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(schema)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_clispec_commands] )) ||
_clispec_commands() {
    local commands; commands=(
'score:Score a CLI tool against The CLI Spec' \
'schema:Output JSON schema for agent integration' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'clispec commands' commands "$@"
}
(( $+functions[_clispec__completions_commands] )) ||
_clispec__completions_commands() {
    local commands; commands=()
    _describe -t commands 'clispec completions commands' commands "$@"
}
(( $+functions[_clispec__help_commands] )) ||
_clispec__help_commands() {
    local commands; commands=(
'score:Score a CLI tool against The CLI Spec' \
