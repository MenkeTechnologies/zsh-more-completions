#compdef grd2cpt
# Documentation: https://docs.generic-mapping-tools.org/latest/grd2cpt.html
# Source: GenericMappingTools/gmt classic-mode grd2cpt — build a CPT (color palette) from a grid's data distribution.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[constant transparency (0-100)]:pct:_default' \
    '-C+[input CPT / color list]:cpt:_default' \
    '-D+[match back/foreground to extremes]:opts:_default' \
    '-E+[linear table + resample levels]:opts:_default' \
    '-F+[output CPT format]:format:(R r h c gray hsv)' \
    '-G+[truncate CPT z-range]:opts:_default' \
    '-H[write CPT to stdout (modern mode)]' \
    '-I[reverse color progression or z signs]' \
    '-L+[restrict range + CDF limits]:opts:_default' \
    '-M[override master colors via gmt.conf]' \
    '-N[omit back/fore/NaN entries]' \
    '-Q[logarithmic interpolation]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S[symmetrical color table around zero]' \
    '-T+[CPT entry intervals / point count]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[disable interpolation / cyclic palette]:opts:_default' \
    '-Z[continuous CPT format]' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
