#compdef qping
# Documentation: https://docs.open-mpi.org/en/main/
# Grid Engine: check the status of the qmaster or execd communication daemon

local ret=1

_arguments -s \
  '-help[print a list of all options]' \
  '-noalias[bypass the host aliases file]' \
  '-ssl[use SSL configuration to connect to SSL-enabled services]' \
  '-tcp[select TCP/IP as the connection protocol]' \
  '-i+[set the qping interval time in seconds]:interval' \
  '-info[show full status information and exit]' \
  '-f[show full status information on each ping interval]' \
  '-dump[observe the communication protocol data flow]' \
  '-dump_tag+[debug level and message types for dump output]:tag:(ALL APP MSG)' \
  '-nonewline[dump output without linebreaks and without unpacking binary messages]' \
  ':host:_hosts' \
  ':port' \
  ':endpoint name:(qmaster execd)' \
  ':endpoint id' && ret=0

return ret
