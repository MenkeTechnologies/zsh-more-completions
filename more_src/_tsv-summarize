#compdef tsv-summarize
# Documentation: https://man.archlinux.org/search?q=tsv-summarize
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-g+[group by fields]:fields' \
  '--group-by=[group by fields]:fields' \
  '-d+[delimiter]:delimiter' \
  '--delimiter=[delimiter]:delimiter' \
  '--header[input has header]' \
  '--count[add count column]' \
  '--sum=[sum field]:FIELD' \
  '--mean=[mean of field]:FIELD' \
  '--median=[median of field]:FIELD' \
  '--min=[minimum of field]:FIELD' \
  '--max=[maximum of field]:FIELD' \
  '--range=[range of field]:FIELD' \
  '--mode=[mode of field]:FIELD' \
  '--unique=[count unique values]:FIELD' \
  '--values=[list unique values]:FIELD' \
  '*:file:_files' && return 0
