#compdef get_hkl
# Documentation: https://www.desy.de/~twhite/crystfel/manual-get_hkl.html
# Manipulate and convert reflection lists (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-i --input)'{-i+,--input=}'[input reflection list]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output reflection list]:file:_files' \
  '(-p --pdb)'{-p+,--pdb=}'[unit cell file]:file:_files' \
  '(-y --symmetry)'{-y+,--symmetry=}'[override input symmetry]:pg:' \
  '(-e --expand)'{-e+,--expand=}'[expand to asymmetric unit]:pointgroup:' \
  '(-w --twin)'{-w+,--twin=}'[reduce to higher symmetry]:pointgroup:' \
  '(-t --template)'{-t+,--template=}'[restrict to template reflections]:file:_files' \
  '--no-need-all-parts[output twins even if mates missing]' \
  '--output-format=[output format]:format:(mtz mtz-bij xds)' \
  '--poisson[generate Poisson noise]' \
  '--noise[add 10% flat random noise]' \
  '--adu-per-photon=[conversion factor for Poisson noise]:n:' \
  '--trim-centrics[remove duplicated reflections]' \
  '--multiplicity[multiply by symmetric multiplicities]' \
  '--cutoff-angstroms=[remove reflections below resolution]:n:' \
  '--highres=[synonym for cutoff-angstroms]:n:' \
  '--lowres=[remove reflections above resolution]:n:' \
  '--reindex=[reindex with transformation]:op:' && ret=0

return ret
