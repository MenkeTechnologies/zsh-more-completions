#compdef exrpptm
# Documentation: https://linux.die.net/man/1/exrpptm
# exrtools: photoreceptor physiology tone mapping for OpenEXR images

local ret=1

_arguments -s -S \
  '-f[image intensity, range -8 to 8 (default 0)]:intensity' \
  '-m[image contrast, range 0.3 to 1.0 (default auto)]:contrast' \
  '-c[chromatic adaptation amount, range 0 to 1 (default 0)]:chromatic' \
  '-a[light adaptation control, range 0 to 1 (default 1)]:light' \
  '1:input.exr:_files -g "*.exr"' \
  '2:output.exr:_files -g "*.exr"' && ret=0

return ret
