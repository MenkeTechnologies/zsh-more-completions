#compdef datadog-static-analyzer
# Documentation: https://github.com/DataDog/datadog-static-analyzer
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Datadog static analysis CLI

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-i --directory)'{-i+,--directory=}'[directory to analyze]:dir:_directories' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(csv sarif json)' \
  '(-r --rules)'{-r+,--rules=}'[rules file]:file:_files' \
  '(-c --cpus)'{-c+,--cpus=}'[number of cpu cores]:n:' \
  '*'{-p+,--ignore-path=}'[exclude path glob]:pattern:' \
  '(-x --performance-statistics)'{-x,--performance-statistics}'[show performance metrics]' \
  '(-g --add-git-info)'{-g,--add-git-info}'[include git info in SARIF]' \
  '(-w --diff-aware)'{-w,--diff-aware}'[enable diff-aware scanning]' \
  '--fail-on-any-violation=[fail severities csv]:csv:' \
  '--debug=[debug mode]:bool:(true false)' \
  '*::args:_default' && return 0
