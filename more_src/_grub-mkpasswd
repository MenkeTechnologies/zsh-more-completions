#compdef grub-mkpasswd grub2-mkpasswd
# _grub-mkpasswd — GRUB grub-mkpasswd (interactive helper that hashes a password for grub.cfg using the legacy MD5-crypt scheme; --help/--version; modern installs prefer the PBKDF2 variant via grub-mkpasswd-pbkdf2)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Behavior from grub util/grub-mkpasswd.in on tip.

_grub-mkpasswd() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_grub-mkpasswd "$@"
