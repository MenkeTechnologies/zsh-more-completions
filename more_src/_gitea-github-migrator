#compdef gitea-github-migrator
# Documentation: https://git.jonasfranz.software/JonasFranzDEV/gitea-github-migrator
# gitea-github-migrator - migrate GitHub repositories to Gitea including issues

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:(migrate migrate-all)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      migrate)
        _arguments -s -S \
          '--gh-repo=[GitHub repository in owner/reponame format]:repo:' \
          '--gh-token=[GitHub authentication token]:token:' \
          '--url=[Gitea instance URL]:url:' \
          '--token=[Gitea authentication token]:token:' \
          '--owner=[owner id in Gitea]:owner:' && ret=0
        ;;
      migrate-all)
        _arguments -s -S \
          '--gh-user=[GitHub username]:user:' \
          '--gh-token=[GitHub authentication token]:token:' \
          '--url=[Gitea instance URL]:url:' \
          '--token=[Gitea authentication token]:token:' \
          '--owner=[owner id in Gitea]:owner:' && ret=0
        ;;
    esac
    ;;
esac

return ret
