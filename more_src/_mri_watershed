#compdef mri_watershed
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_watershed
# FreeSurfer skull-stripping via watershed algorithm

local ret=1

_arguments -s -S \
  '-w[preweight input using atlas information]:weight:' \
  '-no_wta[do not use preweighting for template deformation]' \
  '-b[basins merging using atlas information]:proba_merging:' \
  '-copy[just copy input to output, ignore other options]' \
  '-atlas[use atlas information to correct segmentation]' \
  '-surf[save the BEM surfaces]:surfname:' \
  '-useSRAS[use surface RAS coordinates]' \
  '-noT1[do not do T1 analysis]' \
  '-less[shrink the surface]' \
  '-more[expand the surface]' \
  '-wat[use only the watershed algorithm]' \
  '-T1[T1 input volume (grey value=110)]' \
  '-wat+temp[watershed algo and first template smoothing]' \
  '-first_temp[first template smoothing + local matching]' \
  '-surf_debug[visualize surfaces onto output volume]' \
  '-brainsurf[save the brain surface]:surfname:' \
  '-shk_br_surf[save brain surface shrunk inward]:int_h surfname:' \
  '-s[add a seed point i j k]:seed:' \
  '-c[center of brain in voxel unit i j k]:center:' \
  '-r[radius of brain in voxel unit]:int_r:' \
  '-t[threshold in watershed analyze process]:int_threshold:' \
  '-h[preflooding height in percent]:int_hpf:' \
  '-n[do not use watershed analyze process]' \
  '-LABEL[labelize output into scalp/skull/csf/gray/white]' \
  '-man[change csf_max transition GM intensities]:man:' \
  '-mask[mask a volume with the brain mask]' \
  '--help[show usage message]' \
  '--version[show current version]' \
  '*:volume:_files' && ret=0

return ret
