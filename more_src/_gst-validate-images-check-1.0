#compdef gst-validate-images-check-1.0
# Documentation: https://man.archlinux.org/search?q=gst-validate-images-check-1.0
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-c+[reference image]:file:_files -g "*.(png|jpg|jpeg|tiff)"' \
  '-q+[image quality threshold]:n:' \
  '-o+[output result image]:file:_files' \
  '-v[verbose]' \
  '*:image file:_files -g "*.(png|jpg|jpeg|tiff)"' && ret=0

return ret
