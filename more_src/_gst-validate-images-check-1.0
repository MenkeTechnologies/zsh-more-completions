#compdef gst-validate-images-check-1.0
# Documentation: https://gstreamer.freedesktop.org/documentation/gst-devtools/index.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gst-validate-images-check-1.0: GStreamer Validate image comparison utility.
# Source: https://github.com/GStreamer/gst-devtools/tree/master/validate/tools
local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '*:image file:_files -g "*.(png|jpg|jpeg|tiff)"' && ret=0

return ret
