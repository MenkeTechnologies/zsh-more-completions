#compdef git-credential-netrc
# Documentation: git contrib/credential/netrc
# Source: git/git contrib/credential/netrc/git-credential-netrc.perl (master) — netrc/authinfo credential helper (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-d --debug)'{-d,--debug}'[debug output]' \
    '(-k --insecure)'{-k,--insecure}'[also use plain text netrc/authinfo]' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '*'{-f+,--file=}'[netrc-style file]:file:_files' \
    '(-g --gpg)'{-g+,--gpg=}'[GPG program]::cmd:_command_names -e' \
    '1::action:(get store erase)' \
    && ret=0

return ret
