#compdef linear-cli linear
# Documentation: https://man.archlinux.org/search?q=linear-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:authentication management'
  'issue:issue management'
  'i:alias for issue'
  'notification:notification management'
  'org:organization info'
  'me:current user info'
  'team:team management'
  'project:project management'
  'cycle:cycle management'
  'label:label management'
  'state:workflow state management'
  'comment:comment management'
  'user:user management'
  'template:template viewing'
  'initiative:initiative management'
  'view:custom view management'
  'search:full-text search'
  'doc:document management'
  'attachment:attachment management'
  'config:CLI config helpers'
  'completion:generate shell completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--json[output JSON]' \
  '--api-key=[Linear API key (env: LINEAR_API_KEY)]:key:' \
  '--workspace=[active workspace]:workspace:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'linear-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (issue|i)
        local -a issue_subs=(
          'list:list issues'
          'show:show an issue'
          'create:create an issue'
          'update:update an issue'
          'batch-update:update many issues'
          'delete:delete an issue'
          'start:start working on an issue (set state)'
          'comment:add a comment'
          'attach:attach a file/link'
          'open:open the issue in browser'
        )
        _describe -t icmds 'issue subcommand' issue_subs && ret=0
        _arguments \
          '--mine[only my issues]' \
          '--my[only my issues]' \
          '--team=[filter by team]:team:' \
          '--state=[filter by state]:state:' \
          '--priority=[priority filter]:priority:' \
          '--priority-gte=[priority >= n]:n:' \
          '--priority-lte=[priority <= n]:n:' \
          '--label=[label filter]:label:' \
          '--assignee=[assignee filter]:user:' \
          '--no-assignee[only unassigned]' \
          '--project=[project filter]:project:' \
          '--cycle=[cycle filter]:cycle:' \
          '--created-after=[issues created after]:date:' \
          '--created-before=[issues created before]:date:' \
          '--due-before=[issues due before]:date:' \
          '--add-label=[add label]:label:' \
          '--remove-label=[remove label]:label:' && ret=0 ;;
      (notification)
        _arguments '*::sub:(list read archive unarchive)' && ret=0 ;;
      (team)
        _arguments '*::sub:(list show member member-add member-remove)' && ret=0 ;;
      (project)
        _arguments '*::sub:(list show create update delete issues updates milestones)' && ret=0 ;;
      (cycle)
        _arguments '*::sub:(list show active)' && ret=0 ;;
      (label)
        _arguments '*::sub:(list create update delete)' && ret=0 ;;
      (state)
        _arguments '*::sub:(list)' && ret=0 ;;
      (comment)
        _arguments '*::sub:(list create update delete)' && ret=0 ;;
      (user)
        _arguments '*::sub:(list show)' && ret=0 ;;
      (template|initiative|doc|attachment)
        _arguments '*::sub:(list show create update delete)' && ret=0 ;;
      (view)
        _arguments '*::sub:(list show issues)' && ret=0 ;;
      (auth)
        _arguments '*::sub:(login logout status)' && ret=0 ;;
      (config)
        _arguments '*::sub:(show get set workspace-add workspace-list workspace-switch)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
