#compdef amadmin
# Documentation: https://man.archlinux.org/search?q=amadmin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'version:show current version'
  'estimate:server estimates'
  'force-bump:force bump to new level'
  'force-no-bump:force no bump'
  'unforce-bump:undo bump force'
  'force:force level-0 backup'
  'force-level-1:force level-1 backup'
  'unforce:undo force'
  'retention:print tape retention'
  'reuse:mark tapes for reuse'
  'no-reuse:mark tapes not for reuse'
  'due:show next full dump due'
  'find:list backups on tape/holding'
  'holding:manage holding files'
  'delete:delete disks from DB'
  'tape:tapes for next run'
  'bumpsize:show bump thresholds'
  'balance:full backup distribution'
  'export:export DB records'
  'import:import DB records'
  'config:dump config'
  'disklist:display disklist'
  'hosts:list distinct hosts'
  'dles:list distinct DLEs'
  'info:show DB record per disk'
)

_arguments -C \
  '(- *)--version[show version]' \
  '--no-default[no defaults]' \
  '--print-source[print source]' \
  '--exact-match[exact host/disk match]' \
  '*-o+[config override]:option:' \
  '1:config:' \
  '2: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'amadmin subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[2] in
      (find)
        _arguments '--sort=[sort flags]:sort:' && ret=0
        ;;
      (holding)
        _values 'holding action' 'list' 'delete' && ret=0
        ;;
      (tape|balance)
        _arguments '--days=[days]:n:' && ret=0
        ;;
    esac
    ;;
esac

return ret
