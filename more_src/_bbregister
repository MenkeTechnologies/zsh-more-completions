#compdef bbregister
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/bbregister
# bbregister - boundary-based registration of a volume to a FreeSurfer subject

local ret=1

_arguments -s -S \
  '--s[FreeSurfer subject name]:subject:' \
  '--mov[movable volume (template for cross-modal registration)]:file:_files' \
  '--reg[output registration file (tkregister or LTA)]:file:_files' \
  '--t1[assume T1 contrast (white matter brighter)]' \
  '--t2[assume T2 contrast (gray matter brighter)]' \
  '--bold[same as --t2]' \
  '--dti[same as --t2]' \
  '--init-coreg[initialize with mri_coreg (default)]' \
  '--init-header[initialize using geometry information]' \
  '--init-reg[supply initial registration matrix]:file:_files' \
  '--init-fsl[initialize using FSL FLIRT]' \
  '--init-spm[initialize using SPM spm_coreg]' \
  '--init-rr[initialize using mri_robust_register NMI]' \
  '--int[intermediate volume for partial FOV registration]:file:_files' \
  '--mid-frame[register to middle frame]' \
  '--frame[register to specific frame number]:n:' \
  '--template-out[save template volume]:file:_files' \
  '--o[resample and save movable volume]:file:_files' \
  '--lta[output LTA registration matrix]:file:_files' \
  '--fslmat[output FSL FLIRT matrix]:file:_files' \
  '--vsm[B0 distortion correction using voxel shift map]:file:_files' \
  '--rms[output RMS change in cortical surface position]:file:_files' \
  '--lh-only[use only left hemisphere]' \
  '--rh-only[use only right hemisphere]' \
  '--tol1d[second stage 1D tolerance]:tol:' \
  '--tol[second stage loop tolerance]:tol:' \
  '--nmax[maximum number of iterations]:n:' \
  '--gm-proj-abs[absolute gray matter projection distance]:mm:' \
  '--wm-proj-abs[white matter projection distance]:mm:' \
  '--proj-abs[absolute projections for both GM and WM]:mm:' \
  '--subsamp[second stage vertex subsampling]:n:' \
  '--nearest[use nearest neighbor interpolation]' \
  '--epi-mask[mask brain edge and B0 regions]' \
  '--no-cortex-label[do not use cortex.label masking]' \
  '--label[use specific label file for masking]:file:_files' \
  '--no-pass1[disable pass 1]' \
  '--no-brute2[disable brute force search on pass 2]' \
  '--surf[change surface from default white matter]:surf:' \
  '--6[use 6 degrees of freedom (default)]' \
  '--9[use 9 degrees of freedom]' \
  '--12[use 12 degrees of freedom]' \
  '--feat[FSL FEAT directory mode]:dir:_files -/' \
  '--tmp[specify temporary directory]:dir:_files -/' \
  '--nocleanup[retain temporary files]' \
  '--version[print version and exit]' \
  '(-h --help)'{-h,--help}'[print help and exit]' && ret=0

return ret
