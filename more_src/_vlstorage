#compdef vlstorage
# _vlstorage — VictoriaLogs cluster storage node (per-shard log-storage daemon receiving inserts from vlinsert and serving selects to vlselect)
# upstream: https://github.com/VictoriaMetrics/VictoriaLogs
# Flags from app/vlstorage/main.go on tip + shared lib (httpserver, logger, retention, envflag); all flags also bindable via VL_<flag> env.

_vlstorage() {
    _arguments \
        '(- *)'{-h,-help,--help}'[show help]' \
        '-storageDataPath=[on-disk data directory]:dir:_files -/' \
        '-defaultParallelReaders=[default parallel readers per query]:n:' \
        '-retention.maxDiskUsagePercent=[max filesystem usage % before dropping old partitions]:n:' \
        '-retention.maxDiskSpaceUsageBytes=[max bytes used before dropping old partitions]:size:' \
        '-retentionPeriod=[per-day partition retention]:dur:' \
        '-inmemoryDataFlushInterval=[guaranteed flush interval for in-memory data]:dur:' \
        '-logNewStreams[log every new stream creation]' \
        '-logIngestedRows[log every ingested log entry]' \
        '-insert.concurrency=[avg concurrent ingest requests per storage node]:n:' \
        '-insert.disableCompression[disable compression for inserts]' \
        '-select.disableCompression[disable compression for selects]' \
        '-httpListenAddr=[HTTP listen address]:addr:' \
        '-tls[enable TLS for HTTP listener]' \
        '-tlsCertFile=[TLS cert file]:file:_files' \
        '-tlsKeyFile=[TLS key file]:file:_files' \
        '-loggerLevel=[log level]:level:(INFO WARN ERROR FATAL)' \
        '-loggerFormat=[log format]:fmt:(default json)' \
        '-loggerOutput=[log output destination]:dest:(stderr stdout)' \
        '-version[show version and exit]'
}

_vlstorage "$@"
