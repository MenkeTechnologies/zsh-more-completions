#compdef kwatch

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-n --namespace)'{-n,--namespace}'=[Namespace]:namespace:' \
  '(-k --kubeconfig)'{-k,--kubeconfig}'=[Kubeconfig path]:file:_files' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[Watch all namespaces]' \
  '--context=[Kube context]:context:' \
  '*::resource or args: _default'
