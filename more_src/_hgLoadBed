#compdef hgLoadBed
# UCSC kent: load a generic BED file into the database

local ret=1

_arguments -s -S \
  '-noSort[do not sort (sort before this yourself)]' \
  '-noBin[suppress bin field]' \
  '-oldTable[add to existing table]' \
  '-onServer[speed up when mysql server can access the directory]' \
  '-sqlTable=[create table from .sql file]:file:_files -g "*.sql"' \
  '-renameSqlTable[rename table created with -sqlTable to match track]' \
  '-trimSqlTable[only load as many rows as the input has]' \
  '-type=[specify BED format bedN[+[P]]]:type' \
  '-as=[definition file for extra bedPlus fields]:file:_files -g "*.as"' \
  '-chromInfo=[chromInfo file to validate chrom names and sizes]:file:_files' \
  '-tab[separate by tabs rather than space]' \
  '-hasBin[input bed file starts with a bin field]' \
  '-noLoad[do not load database and do not clean up tab files]' \
  '-noHistory[do not add history table comments]' \
  '-notItemRgb[do not parse column nine as r,g,b]' \
  '-bedGraph=[wiggle graph column N of input as float dataValue]:n' \
  '-bedDetail[bedDetail format with id and text for hgc clicks]' \
  '-maxChromNameLength=[limit chromosome name length]:n' \
  '-tmpDir=[directory for temporary .tab file creation]:dir:_files -/' \
  '-noNameIx[no index for the name column]' \
  '-ignoreEmpty[no error on empty input file]' \
  '-noStrict[do not perform coord sanity checks]' \
  '-allowStartEqualEnd[allow chromStart==chromEnd (zero-length)]' \
  '-allowNegativeScores[score column is int, not unsigned]' \
  '-customTrackLoader[enable permissive flags with timeout]' \
  '-fillInScore=[use this column to fill score when all scores are zero]:colName' \
  '-minScore=[minimum score for -fillInScore (default 100)]:n' \
  '-verbose=[verbose level for extra information]:n' \
  '-dotIsNull=[replace a . in the specified field with -1]:n' \
  '1:database:' \
  '2:track:' \
  '*:bed file:_files -g "*.bed"' && ret=0

return ret
