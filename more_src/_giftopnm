#compdef giftopnm
# Documentation: man giftopnm (Netpbm)
# Source: convert a GIF image (or multi-image stream) to PNM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--alphaout=[alpha output file (- for stdout)]:file:_files' \
    '-verbose[verbose output]' \
    '-comments[print GIF comments to stderr]' \
    '-image=[image to extract (N or all)]:image:' \
    '-repair[repair corrupted images]' \
    '-quitearly[stop after first image]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:gif file:_files -g "*.gif"' \
    && ret=0

return ret
