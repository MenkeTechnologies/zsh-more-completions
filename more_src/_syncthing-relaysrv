#compdef syncthing-relaysrv strelaysrv
# Documentation: https://docs.syncthing.net/users/strelaysrv.html
# Reference accessed: 2026-05-16
# Verified: upstream Syncthing strelaysrv documentation. Single-dash Go
# flag style.
# Removed from prior file: fabricated -h/--help/-V long flags and bogus
# man.archlinux.org search URL.

# syncthing-relaysrv (strelaysrv): Syncthing TCP relay server
local curcontext="$curcontext" ret=1
_arguments -C \
  '-debug[enable debug output]' \
  '-ext-address[externally reachable address]:addr:' \
  '-global-rate[global rate limit bytes/sec]:bytes/s:' \
  '-keys[keys directory (default .)]:dir:_files -/' \
  '-listen[listen address (default :22067)]:addr:' \
  '-message-timeout[message timeout (default 1m0s)]:duration:' \
  '-nat[enable NAT traversal]' \
  '-nat-lease[NAT lease duration (default 60)]:duration:' \
  '-nat-renewal[NAT renewal interval (default 30)]:duration:' \
  '-nat-timeout[NAT timeout (default 10)]:duration:' \
  '-network-timeout[network timeout]:duration:' \
  '-per-session-rate[per-session rate bytes/sec]:bytes/s:' \
  '-ping-interval[ping interval (default 1m0s)]:duration:' \
  '-pools[pool URLs to register with]:addrs:' \
  '-pprof[enable pprof endpoint]' \
  '-protocol[network protocol]:proto:(tcp tcp4 tcp6)' \
  '-provided-by[provider name]:string:' \
  '-status-srv[status HTTP listen addr (default :22070)]:addr:' \
  '-token[shared secret token]:string:' \
  '-version[show version]' && ret=0
return ret
