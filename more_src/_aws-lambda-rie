#compdef aws-lambda-rie
# Documentation: upstream internal/lambda/rie/run.go options struct at
# github.com/aws/aws-lambda-runtime-interface-emulator
# Reference accessed: 2026-05-30 via gh api inspection of every
# `long:` tag in the jessevdk/go-flags options struct.
# AWS Lambda RIE R95 — Lambda Runtime Interface Emulator. Tiny
# single-binary CLI used in container images to make Lambda
# functions invokable locally via the HTTP endpoint
# /2015-03-31/functions/function/invocations.
# NOTE: at startup main.go checks for the AWS_LAMBDA_MAX_CONCURRENCY
# env var to decide between the "run" mode and the standard "rie"
# mode; the flags below apply to the rie.Run() code path.

local -a _log_levels
_log_levels=( panic fatal error warn info debug trace )

_arguments -s -S \
  '--log-level=[RIE log level (default info; also LOG_LEVEL env)]:level:($_log_levels)' \
  '--enable-init-caching[enable Init Caching support]' \
  '--runtime-api-address=[address of the AWS Lambda Runtime API]:host\:port:' \
  '--runtime-interface-emulator-address=[address RIE listens on (default 0.0.0.0\:8080)]:host\:port:' \
  '(- *)'{-h,--help}'[show help]' \
  '*:bootstrap or handler:_files'
