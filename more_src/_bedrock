#compdef bedrock
# Documentation: https://www.npmjs.com/package/bedrock-cli
# Reference accessed: 2026-05-23
# Verified: npx bedrock-cli --help.

# Zsh completion for bedrock - Bedrock static site generator CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize Bedrock with optional base'
  'upgrade:upgrade Bedrock install'
  'migrate-to-pug:migrate Jade files to Pug'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show version]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'bedrock command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
