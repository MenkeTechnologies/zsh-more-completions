#compdef clusternet-controller-manager
# _clusternet-controller-manager — Clusternet hub controller manager (clusternet/clusternet)
# upstream: https://github.com/clusternet/clusternet
# Flags from pkg/controllermanager/options/options.go (pflag).

_clusternet-controller-manager() {
    _arguments \
        '--anonymous-auth-supported=[allow anonymous access on core kubernetes server]:val:(true false)' \
        '--reserved-namespace=[default namespace for Manifests]:ns:' \
        '--threadiness=[number of controller workers]:n:' \
        '--cluster-api-kubeconfig=[Cluster API management cluster kubeconfig]:file:_files' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--master=[Kubernetes API server address]:url:_urls'
}

_clusternet-controller-manager "$@"
