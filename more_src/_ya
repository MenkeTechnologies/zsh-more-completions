#compdef ya
# Documentation: https://github.com/sxyazi/yazi (yazi-cli/src/args.rs)
# Reference accessed: 2026-05-21
# Verified: upstream args.rs subcommand and flag definitions.

# ya: command-line companion for the yazi file manager. Sends IPC messages
# and manages packages.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    local -a subcmds=(
      'emit:emit action to current instance'
      'emit-to:emit action to specified instance'
      'exec:execute action on current instance'
      'pub:publish message to current instance'
      'pub-to:publish message to specified instance'
      'pub-static:publish a static (persisted) message'
      'sub:subscribe to messages from all remote instances'
      'pkg:manage packages'
      'help:show help'
    )
    _describe -t subcmds 'ya command' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      pub|pub-to)
        _arguments -s -S \
          '--str=[send the message with a string body]:body:' \
          '--json=[send the message with a JSON body]:body:' \
          '--list[send the message as a list of strings]' \
          '*: :_default' && ret=0
        ;;
      pkg)
        _arguments \
          '1:action:(add delete install list upgrade)' \
          '--discard[discard pending changes]' \
          '*: :_default' && ret=0
        ;;
      *)
        _arguments '*: :_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
