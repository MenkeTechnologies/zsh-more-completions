#compdef secrets-store-csi-driver
# _secrets-store-csi-driver — Kubernetes Secrets Store CSI driver
# upstream: https://github.com/kubernetes-sigs/secrets-store-csi-driver
# Flags from cmd/secrets-store-csi-driver/main.go on tip.

_secrets-store-csi-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--endpoint=[CSI endpoint (unix sock or tcp host\:port)]:endpoint:' \
        '--drivername=[CSI driver name]:name:' \
        '--nodeid=[node ID]:id:' \
        '--log-format-json=[emit logs in JSON format]:bool:(true false)' \
        '--provider-volume=[provider socket volume path]:dir:_files -/' \
        '--additional-provider-volume-paths=[csv of extra provider paths]:csv:' \
        '--metrics-addr=[metrics bind host\:port]:host\:port:' \
        '--enable-secret-rotation=[enable secret rotation [alpha]]:bool:(true false)' \
        '--rotation-poll-interval=[secret rotation poll interval]:dur:' \
        '--enable-pprof=[enable pprof profiling]:bool:(true false)' \
        '--pprof-port=[pprof port]:port:' \
        '--max-call-recv-msg-size=[max gRPC response bytes from plugins]:n:' \
        '--version[print version and exit]' \
        '--provider-health-check=[enable provider health checks]:bool:(true false)' \
        '--provider-health-check-interval=[provider health-check interval]:dur:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_secrets-store-csi-driver "$@"
