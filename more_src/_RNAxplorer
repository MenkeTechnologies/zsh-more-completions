#compdef RNAxplorer
# RNAxplorer — sampling and clustering methods to explore RNA energy landscapes (ViennaRNA)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--detailed-help[print help with all details and hidden options]' \
  '--full-help[print help including hidden options]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '--sequence=[RNA sequence]:string' \
  '--penalize-structures[penalize already visited structures]' \
  '--struc1=[first reference structure]:string' \
  '--struc2=[second reference structure]:string' \
  '--granularity=[granularity for repulsive sampling]:int' \
  '(-n --num-samples)'{-n,--num-samples}'=[number of samples]:int' \
  '(-f --exploration-factor)'{-f,--exploration-factor}'=[exploration factor]:float' \
  '--min-exploration-percent=[minimum exploration percent]:float' \
  '--cluster[cluster the sampled structures]' \
  '--lmin-file=[local minima output file]:file:_files' \
  '--TwoD-file=[2D output file]:file:_files' \
  '--nonred[use non-redundant sampling]' \
  '--nonred-file=[non-redundant sampling output file]:file:_files' \
  '(-2 --explore-two-neighborhood)'{-2,--explore-two-neighborhood}'[explore the two-neighborhood]' \
  '--post-filter-two[post-filter the two-neighborhood]' \
  '--ediff-penalty[use energy difference penalty]' \
  '--mu=[mu parameter]:float' \
  '(-M --method)'{-M,--method}'=[exploration method]:method:(GW MC MC-SA DB-MFE TRATES SM RS RSH RL)' \
  '--betaScale=[scaling of Boltzmann factors]:double' \
  '(-e --extended_opt)'{-e,--extended_opt}'=[extended options string]:string' \
  '(-i --iterations)'{-i,--iterations}'=[number of iterations]:int' \
  '(-m --maxKeep)'{-m,--maxKeep}'=[maximum structures to keep per step]:int' \
  '(-s --maxStore)'{-s,--maxStore}'=[maximum structures to store]:int' \
  '(-r --remember)'{-r,--remember}'=[number of structures to remember]:int' \
  '(-c --circ)'{-c,--circ}'[assume circular RNA molecule]' \
  '--cooling-rate=[simulated annealing cooling rate]:float' \
  '--tstart=[simulated annealing start temperature]:float' \
  '--tstop=[simulated annealing stop temperature]:float' \
  '--penalizeBackWalks[penalize back walks]' \
  '--basinStructure[output basin structure]' \
  '(-D --maxD)'{-D,--maxD}'=[maximum distance]:int' \
  '--maxD1=[maximum distance to first reference]:int' \
  '--maxD2=[maximum distance to second reference]:int' \
  '(-T --temp)'{-T,--temp}'=[rescale energy parameters to temperature in C]:double' \
  '--p0=[initial population]:string' \
  '--shift_moves[allow shift moves in gradient walk]' \
  '(-P --parameter_file)'{-P,--parameter_file}'=[read energy parameters from file]:file:_files' && ret=0

return ret
