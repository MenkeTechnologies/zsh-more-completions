#compdef gcsfuse

# Zsh completion for gcsfuse - mount Google Cloud Storage buckets

_arguments -s -S \
  '--app-name[application name for GCS requests]:name:' \
  '--billing-project[project to use for billing]:project:' \
  '--cache-dir[directory for local file cache]:directory:_files -/' \
  '--config-file[path to config file]:file:_files' \
  '--custom-endpoint[custom GCS endpoint]:url:' \
  '--debug_fuse[enable fuse debug logging]' \
  '--debug_gcs[enable GCS debug logging]' \
  '--debug_http[dump HTTP requests and responses]' \
  '--debug_invariants[panic when invariants are violated]' \
  '--debug_mutex[print mutex debug info]' \
  '--dir-mode[permissions for directories]:mode:(0755 0700 0777)' \
  '--enable-nonexistent-type-cache[enable caching of non-existent types]' \
  '--experimental-enable-json-read[use JSON API for reading files]' \
  '--experimental-grpc[use gRPC API]' \
  '--file-cache-cache-file-for-range-read[cache file for range reads]' \
  '--file-cache-download-chunk-size-mb[chunk size for downloads]:megabytes:' \
  '--file-cache-enable-crc[enable CRC checking for cached files]' \
  '--file-cache-enable-parallel-downloads[enable parallel downloads]' \
  '--file-cache-max-parallel-downloads[max parallel downloads]:count:' \
  '--file-cache-max-size-mb[max size of file cache]:megabytes:' \
  '--file-cache-parallel-downloads-per-file[parallel downloads per file]:count:' \
  '--file-mode[permissions for files]:mode:(0644 0600 0666)' \
  '--foreground[stay in the foreground after mounting]' \
  '--gid[GID owner of all inodes]:gid:' \
  '--help[show help]' \
  '--http-client-timeout[timeout for HTTP requests]:duration:' \
  '--ignore-interrupts[ignore interrupt signals]' \
  '--implicit-dirs[implicitly define directories]' \
  '--kernel-list-cache-ttl-secs[kernel directory listing cache TTL]:seconds:' \
  '--key-file[path to JSON key file]:file:_files -g "*.json"' \
  '--limit-bytes-per-sec[bandwidth limit]:bytes per second:' \
  '--limit-ops-per-sec[operations per second limit]:ops:' \
  '--log-file[log file path]:file:_files' \
  '--log-format[log format]:format:(json text)' \
  '--log-rotate-backup-file-count[number of rotated log files]:count:' \
  '--log-rotate-compress[compress rotated log files]' \
  '--log-rotate-max-file-size-mb[max log file size]:megabytes:' \
  '--log-severity[log severity]:severity:(TRACE DEBUG INFO WARNING ERROR)' \
  '--max-conns-per-host[max connections per host]:count:' \
  '--max-idle-conns-per-host[max idle connections per host]:count:' \
  '--max-retry-sleep[max retry backoff duration]:duration:' \
  '--metadata-cache-negative-ttl-secs[negative metadata cache TTL]:seconds:' \
  '--metadata-cache-ttl-secs[metadata cache TTL]:seconds:' \
  '--only-dir[mount only a specific directory]:directory:' \
  '-o[additional mount options]:options:' \
  '--rename-dir-limit[allow renaming directories up to this limit]:limit:' \
  '--retry-multiplier[retry backoff multiplier]:multiplier:' \
  '--sequential-read-size-mb[sequential read size]:megabytes:' \
  '--stackdriver-export-interval[metrics export interval]:duration:' \
  '--stat-cache-capacity[stat cache capacity]:entries:' \
  '--stat-cache-max-size-mb[max stat cache size]:megabytes:' \
  '--stat-cache-ttl[stat cache TTL]:duration:' \
  '--temp-dir[temp directory for writing]:directory:_files -/' \
  '--token-url[custom OAuth2 token URL]:url:' \
  '--type-cache-max-size-mb[max type cache size]:megabytes:' \
  '--type-cache-ttl[type cache TTL]:duration:' \
  '--uid[UID owner of all inodes]:uid:' \
  '1:bucket name:' \
  '2:mount point:_files -/' && return 0
