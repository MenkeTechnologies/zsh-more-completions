#compdef lazymake
# Documentation: https://man.archlinux.org/search?q=lazymake
# Reference accessed: 2026-05-16

# Zsh completion for lazymake — Makefile TUI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-f --file)'{-f,--file}'[Makefile]:file:_files' && ret=0

return ret
