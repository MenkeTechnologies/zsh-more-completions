#compdef samba-dcerpcd

# samba-dcerpcd: Samba DCERPC daemon (handles RPC services)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-?[show help]' \
  '--usage[short usage]' \
  '-d[debug level]:n:' \
  '--debuglevel=[debug level]:n:' \
  '--debug-stdout[log to stdout]' \
  '-s[config file]:file:_files' \
  '--configfile=[config file]:file:_files' \
  '-l[log directory]:dir:_files -/' \
  '--log-basename=[log basename]:name:' \
  '--option=[set smb.conf option]:opt:' \
  '-F[run in foreground]' \
  '--foreground[run in foreground]' \
  '--no-process-group[do not become process group leader]' \
  '-i[allow interactive output]' \
  '--interactive[allow interactive output]' \
  '--np-helpers[launch named-pipe helper daemons]' \
  '--ready-signal-fd=[fd to write ready signal]:n:' \
  '*::samba-dcerpcd args:_files' && ret=0
return ret
