#compdef uplink
# Documentation: https://storj.dev/dcs/api-reference/uplink-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'access:manage access grants'
  'import:import access grant into config'
  'cp:copy file to/from Storj bucket'
  'ls:list objects, prefixes, buckets'
  'mb:make bucket'
  'meta:metadata-related commands'
  'mv:move/rename a Storj object'
  'rb:remove a bucket'
  'rm:remove a file from a bucket'
  'setup:create uplink config file'
  'share:share restricted access'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--summary[summary of available commands]' \
  '--advanced[show advanced help]' \
  '--config-dir=[config directory]:dir:_files -/' \
  '--interactive[allow interactive input]' \
  '--legacy-config-dir=[legacy config dir]:dir:_files -/' \
  '--trace-id=[trace id]:id:' \
  '--trace-sample=[trace sample fraction]:fraction:' \
  '--trace-verbose[print trace ID]' \
  '--trace-addr=[trace destination]:addr:' \
  '--trace-tags=[trace tags]:tags:' \
  '--events-addr=[events destination]:addr:' \
  '--debug-pprof=[pprof file]:file:_files' \
  '--debug-monkit-trace=[Monkit trace file]:file:_files' \
  '--debug-monkit-stats=[Monkit stats file]:file:_files' \
  '--analytics[send usage info]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'uplink subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (access)
        _values 'access action' 'list' 'create' 'register' 'revoke' 'inspect' 'use' && ret=0
        ;;
      (meta)
        _values 'meta action' 'get' 'list' && ret=0
        ;;
    esac
    ;;
esac

return ret
