#compdef pod2onepage pod2onepage-j pod2onepage-js pod2onepage-m

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--out=[output file]:file:_files -g "*.html"' \
  '--exclude=[exclude pattern]:pattern:' \
  '--source-url=[source URL prefix]:url:' \
  '*:POD source file:_files -g "*.(pod|pm|pl)"' && ret=0

return ret
