#compdef minijinja-cli minijinja

_minijinja() {
  _arguments \
    '(-f --format)'{-f,--format}'=[input data format]:format:(json yaml toml querystring ini)' \
    '(-a --autoescape)'{-a,--autoescape}'=[auto-escaping mode]:mode:(none html)' \
    '--strict[strict undefined behavior]' \
    '(-D --define)'{-D,--define}'=[define a variable]:var=value' \
    '(-e --expr)'{-e,--expr}'=[evaluate expression]:expression' \
    '--env[pass environment variables]' \
    '--trim-blocks[trim newline after block tags]' \
    '--lstrip-blocks[strip leading whitespace from block tags]' \
    '--no-newline[do not output trailing newline]' \
    '--syntax=[set custom syntax delimiters]:syntax' \
    '(-o --output)'{-o,--output}'=[output file]:file:_files' \
    '--select=[select a block to render]:block' \
    '(-s --stdin)'{-s,--stdin}'[read template from stdin]' \
    '--dump=[dump internals]:what:(tokens ast instructions)' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '1:template:_files' \
    '2:data file:_files'
}

_minijinja "$@"
