#compdef minijinja-cli minijinja
# Documentation: https://github.com/mitsuhiko/minijinja/blob/main/minijinja-cli/src/command.rs
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above.
# Removed invented --env / --stdin / --select=BLOCK semantics; added
# --no-include, --safe-path, --fuel, --py-compat, --expr-out, --repl,
# --print-config, --long-help, --syntax-help, --generate-completion,
# --config-file.

_minijinja() {
  _arguments \
    '(-f --format)'{-f,--format=}'[input data format]:format:(json json5 yaml yml toml querystring ini cbor)' \
    '(-a --autoescape)'{-a,--autoescape=}'[auto-escaping mode]:mode:(auto html json yaml none)' \
    '--strict[strict undefined behavior]' \
    '*'{-D,--define=}'[define a variable]:var=value' \
    '(-E --expr)'{-E,--expr=}'[evaluate expression]:expression' \
    '--expr-out=[expression output mode]:mode:(print json json-pretty status)' \
    '--trim-blocks[trim newline after block tags]' \
    '--lstrip-blocks[strip leading whitespace from block tags]' \
    '--no-newline[do not output trailing newline]' \
    '--no-include[disable {% include %} for security]' \
    '*--safe-path=[allow includes only from these paths]:path:_files -/' \
    '--fuel=[evaluation fuel limit]:n' \
    '--py-compat[Python compatibility mode]' \
    '--syntax=[set custom syntax delimiters]:syntax' \
    '(-o --output)'{-o,--output=}'[output file]:file:_files' \
    '--select=[select sub-portion of input data]:expression' \
    '--repl[interactive REPL]' \
    '--dump=[dump internals]:what:(tokens ast instructions)' \
    '--print-config[print resolved config as TOML]' \
    '--config-file=[path to custom config file]:file:_files' \
    '--generate-completion=[print shell completion script]:shell:(bash zsh fish elvish powershell)' \
    '--syntax-help[show syntax help]' \
    '--long-help[show long help]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '1:template:_files' \
    '2:data file:_files'
}

_minijinja "$@"
