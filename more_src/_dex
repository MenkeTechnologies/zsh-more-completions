#compdef dex

# Zsh completion for dex - OpenID Connect (OIDC) identity provider

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'serve:launch the dex server'
  'version:print the version'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '1:subcommand:->subcommand' \
  '*:argument:->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'dex subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments \
          '(- *)--help[show help]' \
          '1:config file:_files'
        ;;
    esac
    ;;
esac

return ret
