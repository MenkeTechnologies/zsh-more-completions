#compdef love
# Documentation: https://love2d.org/wiki/Command_Line_Arguments
# Reference accessed: 2026-05-16

# LÖVE: 2D Lua game framework
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--version[show version]' \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--console[open a console (Windows)]' \
  '--display=[which monitor to use]:n:' \
  '--fused[treat as fused (no game folder lookup)]' \
  '--debug[enable debug mode]' \
  '--lua-version=[Lua version]:ver:' \
  '--renderers=[list of renderers]:list:(opengl opengles vulkan metal)' \
  '--logfile=[log file]:file:_files' \
  '--profile[profile mode]' \
  '--gammacorrect[gamma correct]' \
  '*:.love file or game dir:_files -g "*.love"' && ret=0
return ret
