#compdef eza
# _eza — modern Rust `ls` replacement (eza-community fork of exa; icons, tree view, git status, hyperlinks)
# upstream: https://github.com/eza-community/eza
# Flags from man/eza.1.md on tip.

_eza() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-1 --oneline)'{-1,--oneline}'[one entry per line]' \
        '--absolute=[show absolute paths]:when:(on follow off)' \
        '(-F --classify)'{-F,--classify=}'[file kind indicators]:when:(always auto never)' \
        '(-G --grid)'{-G,--grid}'[display as a grid (default)]' \
        '(-l --long)'{-l,--long}'[long format with metadata]' \
        '(-R --recurse)'{-R,--recurse}'[recurse into directories]' \
        '(-T --tree)'{-T,--tree}'[recurse as tree]' \
        '--follow-symlinks[drill into symlinks to directories]' \
        '(-X --dereference)'{-X,--dereference}'[dereference symbolic links]' \
        '(-x --across)'{-x,--across}'[sort grid across instead of down]' \
        '--color=[when to use color]:when:(always auto never)' \
        '--colour=[when to use color]:when:(always auto never)' \
        '--color-scale=[highlight field levels distinctly]:fields:' \
        '--color-scale-mode=[gradient vs fixed color scale]:mode:(fixed gradient)' \
        '--icons=[when to show file-type icons]:when:(always auto never)' \
        '--no-quotes[do not quote names with spaces]' \
        '--hyperlink=[emit OSC 8 hyperlinks]:when:(always auto never)' \
        '(-w --width)'{-w+,--width=}'[screen width in cols]:cols:' \
        '(-a --all)'{-a,--all}'[show hidden + dot files (twice = also . and ..)]' \
        '(-A --almost-all)'{-A,--almost-all}'[show hidden but not . and ..]' \
        '(-d --treat-dirs-as-files)'{-d,--treat-dirs-as-files}'[list directory entries themselves]' \
        '--only-dirs[only show directories]' \
        '(-D)-D[only show directories]' \
        '(-L --level)'{-L+,--level=}'[max recursion depth]:n:' \
        '(-r --reverse)'{-r,--reverse}'[reverse sort order]' \
        '(-s --sort)'{-s+,--sort=}'[sort field]:field:(name Name extension Extension size time created modified changed accessed inode none)' \
        '*'{-I+,--ignore-glob=}'[glob pattern to ignore (repeatable)]:glob:' \
        '--git-ignore[respect .gitignore]' \
        '--group-directories-first[list directories before files]' \
        '--group-directories-last[list directories after files]' \
        '(-f --only-files)'{-f,--only-files}'[only show files]' \
        '--show-symlinks[show symlinks even without -l]' \
        '--no-symlinks[do not show symlinks]' \
        '(-b --binary)'{-b,--binary}'[use binary (base-2) sizes (e.g. KiB)]' \
        '(-B --bytes)'{-B,--bytes}'[show sizes in raw bytes]' \
        '--changed[use ctime for sort/display]' \
        '(-g --group)'{-g,--group}'[show group ownership]' \
        '--smart-group[show group only if it differs from current user]' \
        '(-h --header)'{-h,--header}'[show table header in long view]' \
        '(-H --links)'{-H,--links}'[show hard link count]' \
        '(-i --inode)'{-i,--inode}'[show inode number]' \
        '(-m --modified)'{-m,--modified}'[show mtime]' \
        '(-M --mounts)'{-M,--mounts}'[show mount info]' \
        '(-n --numeric)'{-n,--numeric}'[show numeric uid/gid]' \
        '(-O --flags)'{-O,--flags}'[show file attribute flags (chflags)]' \
        '(-S --blocksize)'{-S,--blocksize}'[show file blocksize]' \
        '(-t --time)'{-t+,--time=}'[timestamp field to display]:field:(modified changed accessed created)' \
        '--time-style=[timestamp format]:style:(default iso long-iso full-iso relative +FORMAT)' \
        '--total-size[show recursive directory sizes]' \
        '(-u --accessed)'{-u,--accessed}'[show atime]' \
        '(-U --created)'{-U,--created}'[show btime/creation time]' \
        '--no-permissions[suppress permission column]' \
        '(-o --octal-permissions)'{-o,--octal-permissions}'[show octal permissions]' \
        '--no-filesize[suppress filesize column]' \
        '--no-user[suppress user column]' \
        '--no-time[suppress time column]' \
        '--stdin[read file list from stdin]' \
        '(-@ --extended)'{-@,--extended}'[show extended attributes]' \
        '(-Z --context)'{-Z,--context}'[show SELinux context]' \
        '--git[show per-file git status]' \
        '--git-repos[show per-repo git status]' \
        '--git-repos-no-status[show repos without per-file status]' \
        '--no-git[disable git integration]' \
        '*:file:_files'
}

_eza "$@"
