#compdef cloudmapper

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'collect:collect AWS metadata'
  'audit:audit AWS environment for security issues'
  'prepare:prepare collected data for visualization'
  'webserver:start web visualization server'
  'report:generate HTML report'
  'find-admins:find admin IAM principals'
  'find-unused:find unused resources'
  'iam-report:IAM access report'
  'public:find public resources'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'cloudmapper command' commands && ret=0
    ;;
  args)
    case $line[1] in
      collect)
        _arguments -s -S \
          '--account[AWS account ID]:account:' \
          '--profile[AWS profile name]:profile:' \
          '--regions[AWS regions to collect]:regions:' \
          '--config[config file]:file:_files' \
          '--help[show help]' && ret=0
        ;;
      audit)
        _arguments -s -S \
          '--account[AWS account ID]:account:' \
          '--config[config file]:file:_files' \
          '--json[JSON output]' \
          '--help[show help]' && ret=0
        ;;
      prepare|webserver)
        _arguments -s -S \
          '--account[AWS account ID]:account:' \
          '--config[config file]:file:_files' \
          '--internal-edges[show internal edges]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
