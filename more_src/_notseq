#compdef notseq
# Documentation: https://man.archlinux.org/search?q=notseq
# Reference accessed: 2026-05-16

# EMBOSS notseq: write all sequences from a set excluding named entries
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-exclude=[wildcard names of sequences to exclude]:patterns:' \
  '-junkout=[output file for excluded sequences]:file:_files' \
  '-outseq=[output sequence file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
