#compdef notseq
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/notseq.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# EMBOSS notseq: write all sequences from a set excluding named entries
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-exclude=[wildcard names of sequences to exclude]:patterns:' \
  '-junkoutseq=[output file for excluded sequences]:file:_files' \
  '-outseq=[output sequence file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
