#compdef flux-stats
# Documentation: https://fluxcd.io/flux/cmd/flux_stats/
# FluxCD stats: report on Flux custom resources and storage usage

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[display statistics across all namespaces]' \
  '--context=[kubeconfig context to use]:context:' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--timeout=[timeout for this operation]:duration:' \
  '--verbose[print generated objects]' && ret=0

return ret
