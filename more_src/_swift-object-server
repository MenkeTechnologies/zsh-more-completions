#compdef swift-object-server
# Documentation: https://man.archlinux.org/search?q=swift-object-server
# Reference accessed: 2026-05-16

# Swift object server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '*:swift config file:_files -g "*.conf"' && ret=0
return ret
