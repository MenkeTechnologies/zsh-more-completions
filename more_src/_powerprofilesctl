#compdef powerprofilesctl

# Zsh completion for powerprofilesctl - power profiles control

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list available power profiles'
  'get:get the active power profile'
  'set:set the active power profile'
  'list-holds:list current profile holds'
  'launch:launch a command with a given power profile'
  'version:print version'
  'help:show help'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'powerprofilesctl command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (set)
        _arguments '1:profile:(power-saver balanced performance)' && ret=0
        ;;
      (launch)
        _arguments \
          '(-p --profile)'{-p,--profile}'[specify power profile]:profile:(power-saver balanced performance)' \
          '(-r --reason)'{-r,--reason}'[specify reason for hold]:reason' \
          '1:command:_command_names -e' \
          '*::arguments:_normal' && ret=0
        ;;
    esac
    ;;
esac

return ret
