#compdef powerprofilesctl
# Documentation: https://manpages.debian.org/testing/power-profiles-daemon/powerprofilesctl.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for powerprofilesctl - power profiles control

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list available power profiles'
  'list-holds:list current power profile holds'
  'list-actions:list available power profile actions'
  'get:print the currently active power profile'
  'set:set the active power profile'
  'configure-action:configure an action'
  'configure-battery-aware:configure battery-aware behavior'
  'query-battery-aware:query battery-aware status'
  'launch:launch a command while holding a power profile'
  'version:print version'
  'help:show help'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'powerprofilesctl command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (set)
        _arguments '1:profile:(power-saver balanced performance)' && ret=0
        ;;
      (launch)
        _arguments \
          '(-p --profile)'{-p,--profile}'[specify power profile]:profile:(power-saver balanced performance)' \
          '(-r --reason)'{-r,--reason}'[specify reason for hold]:reason' \
          '(-i --appid)'{-i,--appid}'[application identifier]:appid' \
          '1:command:_command_names -e' \
          '*::arguments:_normal' && ret=0
        ;;
    esac
    ;;
esac

return ret
