#compdef libsql
# Documentation: https://man.archlinux.org/search?q=libsql
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--auth=[authentication token (Turso/sqld)]:token:' \
  '--proxy=[HTTP/HTTPS proxy URL]:url:' \
  '--exec=[execute SQL string then exit]:sql:' \
  '--quiet[quiet mode (no banner)]' \
  '-q[quiet mode]' \
  '*::dburl_or_file:_files' && ret=0

return ret
