#compdef apycula apicula gowin_pack gowin_unpack gowin_bba gowin_bsram

local curcontext="$curcontext" ret=1

case $service in
  (gowin_pack)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-d --device)'{-d,--device}'+[device name]:device:' \
      '(-o --output)'{-o,--output}'+[output bitstream]:file:_files' \
      '(-c --compress)'{-c,--compress}'[compress bitstream]' \
      '(--png)--png=+[output PNG]:file:_files -g "*.png"' \
      '(--family)--family=+[chip family]:family:(GW1N GW2A GW5A)' \
      '(--allow-pinless-io)--allow-pinless-io[allow pinless IO]' \
      '*:file:_files -g "*.json"' && ret=0 ;;
  (gowin_unpack)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-d --device)'{-d,--device}'+[device]:device:' \
      '(-o --output)'{-o,--output}'+[output JSON]:file:_files -g "*.json"' \
      '*:file:_files -g "*.fs"' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '*:arg:' && ret=0 ;;
esac

return ret
