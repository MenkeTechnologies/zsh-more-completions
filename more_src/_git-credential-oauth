#compdef git-credential-oauth
# Documentation: https://github.com/hickford/git-credential-oauth
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git-credential-oauth - OAuth credential helper for git

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-verbose[enable detailed debugging output]' \
  '-device[use OAuth device flow for browserless systems]' \
  '1:command:(configure unconfigure get store erase)' && ret=0

return ret
