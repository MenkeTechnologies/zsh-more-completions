#compdef usbguard
# Documentation: https://github.com/usbguard/usbguard/blob/main/src/CLI/usbguard.cpp
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for usbguard - USB device authorization policy framework

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'allow-device:authorize a device'
  'block-device:deauthorize a device'
  'reject-device:reject and remove a device'
  'list-devices:list USB devices'
  'list-rules:list active rules'
  'append-rule:append a rule'
  'remove-rule:remove a rule'
  'generate-policy:generate policy from connected devices'
  'watch:watch for device and policy changes'
  'read-descriptor:read USB descriptor'
  'add-user:add IPC access for user or group'
  'remove-user:remove IPC access for user or group'
  'get-parameter:get runtime parameter'
  'set-parameter:set runtime parameter'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      allow-device|block-device|reject-device)
        _arguments \
          '(-p --permanent)'{-p,--permanent}'[make the decision permanent]' \
          ':device id or rule:' && ret=0
        ;;
      list-devices)
        _arguments \
          '(-a --allowed)'{-a,--allowed}'[list allowed devices]' \
          '(-b --blocked)'{-b,--blocked}'[list blocked devices]' \
          '(-t --tree)'{-t,--tree}'[show devices in a tree]' && ret=0
        ;;
      list-rules)
        _arguments \
          '(-d --show-devices)'{-d,--show-devices}'[show devices affected by each rule]' \
          '(-l --label)'{-l,--label}'[filter rules by label]:label:' && ret=0
        ;;
      append-rule)
        _arguments \
          '(-a --after)'{-a,--after}'[append after rule ID]:rule id:' \
          '(-t --temporary)'{-t,--temporary}'[set temporary flag]' \
          ':rule:' && ret=0
        ;;
      remove-rule)
        _arguments ':rule id:' && ret=0
        ;;
      generate-policy)
        _arguments \
          '(-p --with-ports)'{-p,--with-ports}'[generate port-specific rules]' \
          '(-P --no-ports-sn)'{-P,--no-ports-sn}'[skip port-specific rules for devices without serial]' \
          '(-d --devpath)'{-d,--devpath}'[generate rule for device at /sys path]:devpath:' \
          '(-t --target)'{-t,--target}'[target policy]:target:(allow block reject)' \
          '(-X --no-hashes)'{-X,--no-hashes}'[do not generate hash attributes]' \
          '(-H --hash-only)'{-H,--hash-only}'[generate hash-only policy]' \
          '(-L --ldif)'{-L,--ldif}'[generate LDIF policy]' \
          '(-b --usbguardbase)'{-b,--usbguardbase}'[LDAP base for LDIF]:base:' \
          '(-o --objectclass)'{-o,--objectclass}'[LDAP objectClass]:class:' \
          '(-n --name-prefix)'{-n,--name-prefix}'[LDAP name prefix]:prefix:' && ret=0
        ;;
      watch)
        _arguments \
          '(-w --wait)'{-w,--wait}'[wait for IPC availability]' \
          '(-o --once)'{-o,--once}'[wait only at startup]' \
          '(-e --exec)'{-e,--exec}'[execute file on each event]:file:_files' && ret=0
        ;;
      add-user)
        _arguments \
          '(-u --user)'{-u,--user}'[treat name as user/UID]' \
          '(-g --group)'{-g,--group}'[treat name as group/GID]' \
          '(-p --policy)'{-p,--policy}'[policy privileges]:privileges:' \
          '(-d --devices)'{-d,--devices}'[device privileges]:privileges:' \
          '(-e --exceptions)'{-e,--exceptions}'[exception privileges]:privileges:' \
          '(-P --parameters)'{-P,--parameters}'[parameter privileges]:privileges:' \
          ':name:' && ret=0
        ;;
      remove-user)
        _arguments \
          '(-u --user)'{-u,--user}'[treat name as user/UID]' \
          '(-g --group)'{-g,--group}'[treat name as group/GID]' \
          ':name:' && ret=0
        ;;
      get-parameter)
        _arguments ':parameter:' && ret=0
        ;;
      set-parameter)
        _arguments \
          '(-v --verbose)'{-v,--verbose}'[show previous and new values]' \
          ':parameter:' \
          ':value:' && ret=0
        ;;
    esac
    ;;
esac

return ret
