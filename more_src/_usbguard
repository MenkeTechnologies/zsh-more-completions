#compdef usbguard

# Zsh completion for usbguard - USB device authorization policy framework

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'allow-device:authorize a device'
  'block-device:deauthorize a device'
  'reject-device:reject and remove a device'
  'list-devices:list USB devices'
  'list-rules:list active rules'
  'append-rule:append a rule'
  'remove-rule:remove a rule'
  'generate-policy:generate policy from connected devices'
  'watch:watch for device and policy changes'
  'read-descriptor:read USB descriptor'
  'add-user:add IPC access for user or group'
  'remove-user:remove IPC access for user or group'
  'get-parameter:get runtime parameter'
  'set-parameter:set runtime parameter'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      allow-device|block-device|reject-device)
        _arguments \
          '-p[make the decision permanent]' \
          '--permanent[make the decision permanent]' \
          ':device id:' && ret=0
        ;;
      list-devices)
        _arguments \
          '-a[list allowed devices]' \
          '-b[list blocked devices]' && ret=0
        ;;
      list-rules)
        _arguments \
          '-l[label to filter by]:label:' && ret=0
        ;;
      append-rule)
        _arguments \
          '-a[append after rule ID]:rule id:' \
          '-t[set temporary flag]' \
          ':rule:' && ret=0
        ;;
      remove-rule)
        _arguments ':rule id:' && ret=0
        ;;
      generate-policy)
        _arguments \
          '-p[generate for present devices only]' \
          '-t[target policy]:target:(allow block reject)' \
          '-X[do not generate hash attributes]' \
          '-H[generate hash-only policy]' \
          '-P[generate with ports]' \
          '-d[device specific attributes]' && ret=0
        ;;
      add-user|remove-user)
        _arguments \
          '-u[user name]:user:_users' \
          '-g[group name]:group:_groups' \
          '-p[set policy privileges]:privileges:(list modify)' \
          '-d[set device privileges]:privileges:(list modify listen)' \
          '-e[set exception privileges]:privileges:(listen)' \
          '-P[set parameter privileges]:privileges:(list modify)' && ret=0
        ;;
      get-parameter|set-parameter)
        _arguments ':parameter:(InsertedDevicePolicy ImplicitPolicyTarget)' && ret=0
        ;;
    esac
    ;;
esac

return ret
