#compdef candle
# _candle — Hugging Face Candle ML framework example CLI (huggingface, Rust); clap-rs (binaries under candle-examples)
# upstream: https://github.com/huggingface/candle

_candle() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--cpu[force CPU]' \
        '--tracing[enable tracing]' \
        '--model-id=+[model id]:str:' \
        '--revision=+[revision]:str:' \
        '--tokenizer-file=+[tokenizer file]:file:_files' \
        '--weight-file=+[weight file]:file:_files' \
        '--prompt=+[prompt]:str:' \
        '--seed=+[seed]:n:' \
        '--temperature=+[temperature]:f:' \
        '--top-p=+[top p]:f:' \
        '--top-k=+[top k]:n:' \
        '--repeat-penalty=+[repeat penalty]:f:' \
        '--repeat-last-n=+[repeat last n]:n:' \
        '--sample-len=+[sample length]:n:' \
        '--max-len=+[max length]:n:' \
        '--use-flash-attn[use flash attention]' \
        '--dtype=+[dtype]:dtype:(f16 bf16 f32)' \
        '--quantized[load quantized weights]' \
        '*:arg:'
}

_candle "$@"
