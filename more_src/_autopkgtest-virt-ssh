#compdef autopkgtest-virt-ssh
# _autopkgtest-virt-ssh — SSH virtualisation backend for autopkgtest
# upstream: https://salsa.debian.org/ci-team/autopkgtest
# Flags from autopkgtest-virt-ssh(1) man page.

_autopkgtest-virt-ssh() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[enable debugging output]' \
        '(-H --hostname)'{-H+,--hostname=}'[remote host or IP]:host:_hosts' \
        '(-l --login)'{-l+,--login=}'[remote login user]:user:_users' \
        '(-i --identity)'{-i+,--identity=}'[private key file]:file:_files' \
        '(-P --password)'{-P+,--password=}'[sudo password (or file)]:password:' \
        '(-p --port)'{-p+,--port=}'[ssh port]:port:' \
        '*'{-o+,--options=}'[verbatim ssh options]:opt:' \
        '(-r --reboot)'{-r,--reboot}'[reboot is supported on testbed]' \
        '*--capability=[advertise capability]:cap:' \
        '(-s --setup-script)'{-s+,--setup-script=}'[setup script]:file:_files' \
        '--timeout-ssh=[ssh connection timeout (seconds)]:seconds:'
}

_autopkgtest-virt-ssh "$@"
