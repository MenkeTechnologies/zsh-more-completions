#compdef mp3splt

_arguments -s \
  '-w[wrap mode]' \
  '-l[list wrapped tracks]' \
  '-e[sync-error split]' \
  '-A[Audacity labels]:file:_files' \
  '-t[fixed time]:time:' \
  '-S[split count]:n:' \
  '-r[trim by silence]' \
  '-s[silence detect]' \
  '-c[CDDB source]:source:' \
  '-a[auto-adjust]' \
  '-p[silence params]:params:' \
  '-f[frame mode]' \
  '-b[bit-reservoir gapless]' \
  '-k[non-seekable input]' \
  '-M[MD5 in STREAMINFO]' \
  '-O[overlap time]:time:' \
  '-o[output format]:fmt:' \
  '-d[output dir]:dir:_files -/' \
  '-n[no tags]' \
  '-x[no Xing header]' \
  '-T[tags version]:ver:(1 2 12)' \
  '-C[ID3v2 encoding]:encoding:(1 8 16)' \
  '-I[input encoding]:encoding:(1 8 16)' \
  '-K[preserve original tags]' \
  '-g[custom tags]:tags:' \
  '-G[regex tag]:regex:' \
  '-N[no log]' \
  '-m[M3U file]:file:_files' \
  '-E[CUE export]:file:_files' \
  '-F[silence log]:file:_files' \
  '-P[pretend]' \
  '-q[quiet]' \
  '-Q[very quiet]' \
  '-D[debug]' \
  '-v[show version]' \
  '-h[show help]' \
  '*:file:_files'
