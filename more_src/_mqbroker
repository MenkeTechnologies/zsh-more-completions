#compdef mqbroker
# Documentation: https://rocketmq.apache.org/docs/4.x/deployment/01deploy/
# Apache RocketMQ broker startup

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-n --namesrvAddr)'{-n,--namesrvAddr}'=[name server address list, eg: 192.168.0.1:9876;192.168.0.2:9876]:addr' \
  '(-c --configFile)'{-c,--configFile}'=[broker config properties file]:file:_files' \
  '(-p --printConfigItem)'{-p,--printConfigItem}'[print all config item]' \
  '(-m --printImportantConfig)'{-m,--printImportantConfig}'[print important config item]' && ret=0

return ret
