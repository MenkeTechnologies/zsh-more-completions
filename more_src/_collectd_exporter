#compdef collectd_exporter
# Documentation: https://github.com/prometheus/collectd_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--collectd.listen-address=[address on which to accept collectd binary network packets]:address:' \
  '--collectd.security-level=[minimum security level for accepted packets]:level:(None Sign Encrypt)' \
  '--collectd.auth-file=[file mapping user names to pre-shared keys]:file:_files' \
  '--collectd.typesdb-path=[path to collectd types.db file]:file:_files' \
  '--web.collectd-push-path=[path accepting collectd POST requests]:path:' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:address:' \
  '--web.telemetry-path=[path under which to expose metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' && ret=0

return ret
