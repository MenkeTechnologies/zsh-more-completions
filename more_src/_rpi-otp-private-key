#compdef rpi-otp-private-key
# Documentation: https://github.com/raspberrypi/rpi-eeprom/blob/master/tools/rpi-otp-private-key
# Read or write the OTP private key on a Raspberry Pi

local ret=1

_arguments -s \
  '(-h)-h[display usage information]' \
  '(-b)-b[output the key in binary format]' \
  '(-c)-c[read key and exit 1 if it is all zeros (not set)]' \
  '(-f)-f[force write even if OTP is non-zero]' \
  '(-y)-y[skip the confirmation prompt when writing]' \
  '-w[write the new key to OTP memory]:key (hex):' \
  '-l[key length in words (default 8 words / 32 bytes)]:words:' \
  '-o[offset into the keystore (0-7 Pi 4, 0-15 Pi 5)]:offset:' && ret=0

return ret
