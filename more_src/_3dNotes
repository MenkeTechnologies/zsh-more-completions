#compdef 3dNotes
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dNotes.html
# AFNI add, delete and show notes for AFNI datasets

local ret=1

_arguments -s -S \
  '-help[display the help screen]' \
  '-a[add string to the notes list]:str:' \
  '(-HH)-h[append string to dataset history]:str:' \
  '(-h)-HH[replace existing history note]:str:' \
  '-d[delete note number num]:num:' \
  '-ses[output expanded notes to stdout]' \
  '*:dataset:_files' && ret=0

return ret
