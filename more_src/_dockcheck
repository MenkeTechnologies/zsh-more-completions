#compdef dockcheck

# mag37/dockcheck dockcheck.sh — Homebrew renames to `dockcheck` (Formula/d/dockcheck.rb)

local ret=1
_arguments -s \
  '(-a -y)'{-a,-y}'[automatic updates without prompts]' \
  '-b+[keep image backups N days]:days:' \
  '-B[list backups and exit]' \
  '-c+[Prometheus textfile collector dir]:dir:_files -/' \
  '-d+[only update images older than N days]:days:' \
  '-e+[exclude containers (comma list)]:list:' \
  '-f[force stop+start compose stack after update]' \
  '-F[compose up only affected service]' \
  '(-h)'{-h}'[help]' \
  '-i[send notification]' \
  '-I[print custom releasenote URLs in output]' \
  '-l[only labelled containers]' \
  '-m[monochrome, no progress bar]' \
  '-M[markdown releasenote URLs]' \
  '-n[check only, no updates]' \
  '-o[hide no-updates message; show only updateable]' \
  '-p[auto-prune dangling images]' \
  '-r[include docker run images]' \
  '-R[skip container recreation after pull]' \
  '-s[include stopped containers]' \
  '-t+[per-container registry timeout seconds]:seconds:' \
  '-u[self-update script from GitHub]' \
  '-v[print script version]' \
  '-x+[max async subprocesses]:count:' \
  '*::include containers (comma names):_default' && ret=0
return ret
