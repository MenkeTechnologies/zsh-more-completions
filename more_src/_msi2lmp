#compdef msi2lmp
# Documentation: https://www.mankier.com/1/msi2lmp
# Convert BIOVIA Materials Studio .car/.mdf files to LAMMPS data files

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print detailed help message and stop]' \
  '(-c -class)'{-c,-class}'[select force field class: I/1, II/2, or O/0]:class:(I 1 II 2 O 0)' \
  '(-f -frc)'{-f,-frc}'[specify force field parameter file]:frc file:_files' \
  '(-p -print)'{-p,-print}'[set log level for conversion messages]:level:(0 1 2 3)' \
  '(-i -ignore)'{-i,-ignore}'[ignore missing parameters and use 0.0 for force constants]' \
  '(-n -nocenter)'{-n,-nocenter}'[disable recentering; use origin instead of atomic center]' \
  '(-o -oldstyle)'{-o,-oldstyle}'[write data file without style hint comments]' \
  '(-s -shift)'{-s,-shift}'[shift the system by a vector]:x:_message x:y:_message y:z:_message z' \
  '1:rootname:_files' && ret=0

return ret
