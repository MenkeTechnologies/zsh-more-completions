#compdef consolechars
# _consolechars — console-tools consolechars (load console font/screen-font-map/unicode-mapping for Linux text VTs; legacy precursor to kbd setfont; -f loads PSF/PSF2/RAW, -d/-D set scancode/character maps)
# upstream: https://www.kraxel.org/blog/linux-tools/ (Debian console-tools)
# Flags from console-tools consolechars.8 on tip.

_consolechars() {
    _arguments \
        '-f+[font file]:file:_files -g "*.psf*"' \
        '-d+[screen-font map]:file:_files' \
        '-m+[application-charset map]:file:_files' \
        '-h+[font height]:rows:' \
        '-w+[font width]:cols:' \
        '-v[verbose]' \
        '--reset-font[reset to kernel default]' \
        '--list-fonts[list available fonts]'
}

_consolechars "$@"
