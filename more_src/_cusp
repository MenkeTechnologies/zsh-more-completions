#compdef cusp

# EMBOSS cusp: build a codon-usage table from coding-sequence input
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input CDS sequence(s)]:CDS USA:_files' \
  '-outfile=[codon usage table output file]:file:_files' \
  '*:CDS USA:_files' && ret=0
return ret
