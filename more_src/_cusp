#compdef cusp
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/cusp.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS cusp: build a codon-usage table from coding-sequence input.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' \
  '-auto[no prompts]' \
  '-stdout[write to stdout]' \
  '-filter[read stdin, write stdout]' \
  '-options[prompt for additional values]' \
  '-debug[enable debug output]' \
  '-verbose[verbose]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[show version]' \
  '-sequence=[input CDS sequence(s)]:CDS USA:_files' \
  '-outfile=[codon usage table output file]:file:_files' \
  '-sbegin1=[start position of each sequence]:pos:' \
  '-send1=[end position of each sequence]:pos:' \
  '-sreverse1[reverse sequence]' \
  '-snucleotide1[sequence is nucleotide]' \
  '-sprotein1[sequence is protein]' \
  '-slower1[lowercase]' \
  '-supper1[uppercase]' \
  '-scircular1[sequence is circular]' \
  '-sformat1=[input sequence format]:format:' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '*:CDS USA:_files' && ret=0

return ret
