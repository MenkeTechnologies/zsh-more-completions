#compdef mender-cli

# https://github.com/mendersoftware/mender-cli — cobra (v2.0.x)

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'login:authenticate to Mender server'
  'artifacts:artifact operations'
  'devices:device inventory/actions'
  'terminal:remote terminal'
  'port-forward:port forwarding'
  'file-transfer:transfer files with device'
)

_arguments -s -S \
  '(--server)'--server='[Mender server URL]:url:' \
  '(-k --skip-verify)'{-k,--skip-verify}'[skip TLS cert checks]' \
  '--token=[JWT token file path]:file:_files' \
  '--token-value=[JWT / API token string]:token:' \
  '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
  '--version[print version]' \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'mender-cli command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
