#compdef aapt
# Documentation: https://elinux.org/Android_aapt
# Source: Android SDK — legacy Android Asset Packaging Tool (predecessor of aapt2; still ships in build-tools).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'l:list contents of Zip-compatible archive'
            'list:list contents of Zip-compatible archive'
            'd:dump label/badging/permissions/resources/configurations/xmltree/xmlstrings of an APK'
            'dump:dump label/badging/permissions/resources/configurations/xmltree/xmlstrings of an APK'
            'p:package resources into AndroidManifest.xml / R.java / resources.arsc'
            'package:package resources into AndroidManifest.xml / R.java / resources.arsc'
            'r:remove file(s) from a Zip-compatible archive'
            'remove:remove file(s) from a Zip-compatible archive'
            'a:add file(s) to a Zip-compatible archive'
            'add:add file(s) to a Zip-compatible archive'
            'c:compile resources'
            'crunch:do PNG preprocessing without packaging'
            's:do single-file PNG preprocessing'
            'singleCrunch:do single-file PNG preprocessing'
            'v:print aapt version'
            'version:print aapt version'
        )
        _describe -t subcmds 'aapt command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            d|dump)
                local -a dump_targets=(
                    'badging:print package, permissions, application label, icon, version info'
                    'permissions:print declared permissions'
                    'resources:print resource table'
                    'configurations:print resource configurations'
                    'xmltree:print XML tree of an asset'
                    'xmlstrings:print XML string table of an asset'
                    'strings:print string table'
                    'styleparents:print style parent chain'
                )
                _describe -t targets 'dump target' dump_targets && ret=0
                ;;
            p|package)
                _arguments \
                    '-f[force overwrite of existing files]' \
                    '-v[verbose output]' \
                    '-x[non-constant resource IDs]' \
                    '-m[generate dependencies for the output]' \
                    '-u[update existing packages]' \
                    '-z[require localization of strings marked translatable=true]' \
                    '-M[AndroidManifest.xml path]:file:_files' \
                    '-S[resources directory]:dir:_directories' \
                    '-A[assets directory]:dir:_directories' \
                    '-I[base APK(s) to include]:apk:_files -g "*.apk"' \
                    '-F[output APK file]:file:_files' \
                    '-J[directory for R.java]:dir:_directories' \
                    '-G[output ProGuard rules]:file:_files' \
                    '--min-sdk-version[min SDK version]:v:' \
                    '--target-sdk-version[target SDK version]:v:' \
                    '--max-sdk-version[max SDK version]:v:' \
                    '--version-code[manifest versionCode]:v:' \
                    '--version-name[manifest versionName]:v:' \
                    '--rename-manifest-package[rename manifest package]:pkg:' \
                    '--rename-instrumentation-target-package[rename instrumentation target package]:pkg:' \
                    '--utf16[force UTF-16 string output]' \
                    '--debug-mode[force android:debuggable="true"]' \
                    '--auto-add-overlay[auto-add resources in overlay]' \
                    '--non-constant-id[generate R.java with non-final IDs]' \
                    '--shared-lib[generate as a shared Android runtime library]' \
                    '--app-as-shared-lib[allow app to behave as a shared library]' \
                    '--app-version[application version (manifest android:versionName)]:v:' \
                    '*:additional args:_files' \
                    && ret=0
                ;;
            *)
                _files
                ;;
        esac
        ;;
esac

return ret
