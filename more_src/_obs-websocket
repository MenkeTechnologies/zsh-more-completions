#compdef obs-websocket
# Documentation: https://github.com/obsproject/obs-websocket
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# obs-websocket: OBS Studio plugin command/utility (varies by distro)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-p[port to use]:port:' \
  '-a[password]:pass:' \
  '*::obs-websocket args:_files' && ret=0
return ret
