#compdef obs-websocket
# Documentation: https://github.com/obsproject/obs-websocket
# Reference accessed: 2026-05-19
# Verified: obs-websocket is an OBS Studio plugin, NOT a CLI
# binary. Flags --websocket_port, --websocket_password,
# --websocket_debug are passed to the obs executable itself.
# STUB: provided for completeness if a user wraps these via a
# shell function or alias.

local curcontext="$curcontext" ret=1
_arguments -C \
  '--websocket_port=[obs-websocket port]:port:' \
  '--websocket_password=[obs-websocket password]:password:' \
  '--websocket_debug[enable debug logging]' \
  '*: :_files' && ret=0
return ret
