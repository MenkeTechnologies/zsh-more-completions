#compdef obs-websocket
# Documentation: https://man.archlinux.org/search?q=obs-websocket
# Reference accessed: 2026-05-16

# obs-websocket: OBS Studio plugin command/utility (varies by distro)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-p[port to use]:port:' \
  '-a[password]:pass:' \
  '*::obs-websocket args:_files' && ret=0
return ret
