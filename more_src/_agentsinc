#compdef agentsinc
# Documentation: https://github.com/agents-inc/cli
# Reference accessed: 2026-05-22
# Verified: README commands reference and package.json oclif bin.

# Zsh completion for agentsinc - Agents Inc skills and subagents for Claude Code

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'agentsinc command' \
      'init[interactive setup wizard]' \
      'edit[modify skill selection]' \
      'compile[recompile subagents]' \
      'update[pull latest skills]' \
      'search[search skills]' \
      'eject[export agent partials templates or skills]' \
      'import[import skill from GitHub]' \
      'build[build marketplace or plugins]' \
      'doctor[diagnose setup issues]' \
      'list[show installed skills and agents]' \
      'validate[validate config and skills]' \
      'uninstall[remove Agents Inc from project]' && ret=0
    ;;
  args)
    case $line[1] in
      eject)
        _arguments \
          '1:target:(agent-partials templates skills all)' \
          '*:name:' && ret=0
        ;;
      import)
        _arguments '1:import type:(skill)' && ret=0
        ;;
      build)
        _arguments '1:build target:(marketplace plugins)' && ret=0
        ;;
      search) _arguments '*:query:' && ret=0 ;;
    esac
    ;;
esac

return ret
