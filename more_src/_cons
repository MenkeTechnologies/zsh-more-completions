#compdef cons

# EMBOSS cons: extract consensus from a multiple alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[aligned sequence(s)]:alignment USA:_files' \
  '-datafile=[scoring matrix]:matrix:_files' \
  '-plurality=[plurality (threshold for consensus)]:n:' \
  '-identity=[minimum identity %]:pct:' \
  '-setcase=[uppercase threshold (positive=match, negative=mismatch)]:n:' \
  '-name=[output sequence name]:name:' \
  '-outseq=[output consensus sequence file]:file:_files' \
  '-osformat=[output format]:format:(fasta embl genbank swiss gcg pir raw msf text)' \
  '*:alignment USA:_files' && ret=0
return ret
