#compdef adonis-cli adonis
# _adonis-cli — AdonisJS Node.js MVC framework CLI alias (AdonisJS Team / Harminder Virk, TypeScript); commander
# upstream: https://github.com/adonisjs/core

_adonis-cli() {
    local -a sub=(
        'new:scaffold project'
        'serve:start dev server'
        'build:build for production'
        'test:run tests'
        'generate:run code generation'
        'make:make resource (controller/model/middleware/exception/etc.)'
        'list:list available commands'
        'configure:configure a package'
        'eject:eject stubs'
        'env:print env info'
        'list-routes:show routes'
        'inspect-rcfile:inspect adonisrc'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--ansi[force ansi]' \
        '--no-ansi[no ansi]' \
        '--interactive[interactive]' \
        '--no-interactive[no interactive]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'adonis subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:project-name:' \
                    '--kit=+[starter kit]:k:(web api slim inertia)' \
                    '--git-init[init git]' \
                    '--package-manager=+[package manager]:pm:(npm pnpm yarn bun)' \
                    '--auth-guard=+[auth guard]:g:(session basic_auth access_tokens)' \
                    '--db=+[database]:db:(sqlite postgres mysql mssql)' ;;
                serve) _arguments \
                    '--watch[watch files]' \
                    '-w[watch files]' \
                    '--clear[clear screen]' \
                    '--poll[use polling]' \
                    '--dry-run[dry run]' \
                    '--inspect[node inspect]' \
                    '--no-clear[no clear]' \
                    '--assets[build assets]' \
                    '--no-assets[no assets]' \
                    '--node-args=+[node args]:str:' \
                    '--assets-args=+[assets args]:str:' ;;
                build) _arguments \
                    '--ignore-ts-errors[ignore TS errors]' \
                    '--assets[build assets]' \
                    '--no-assets[no assets]' \
                    '--package-manager=+[package manager]:pm:(npm pnpm yarn bun)' \
                    '--meta-files=+[meta files glob]:str:' \
                    '--debug[debug]' ;;
                make) _arguments \
                    '1:type:(controller middleware exception listener provider validator command policy model migration mailer mailer_template seeder factory event preload-file test-suite view test)' \
                    '*:name:' ;;
                test) _arguments \
                    '--watch[watch files]' \
                    '-w[watch files]' \
                    '--clear[clear screen]' \
                    '--no-clear[no clear]' \
                    '--tags=+[tag filter]:list:' \
                    '--ignore-tags=+[ignore tags]:list:' \
                    '--files=+[file filter]:list:' \
                    '--groups=+[group filter]:list:' \
                    '--tests=+[test title filter]:list:' \
                    '--reporters=+[reporters]:list:(spec ndjson dot)' \
                    '--retries=+[retries]:n:' \
                    '--timeout=+[timeout ms]:n:' \
                    '--force-exit[force exit]' ;;
                configure) _arguments \
                    '*:package:' ;;
                list-routes) _arguments \
                    '--methods=+[methods filter]:list:(GET POST PUT PATCH DELETE)' \
                    '--names=+[names filter]:list:' \
                    '--patterns=+[patterns filter]:list:' \
                    '--middleware=+[middleware filter]:list:' \
                    '--ignore-middleware=+[ignore middleware]:list:' \
                    '--table[table format]' \
                    '--json[json format]' ;;
                inspect-rcfile) _arguments '*:arg:' ;;
                generate|env|eject) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_adonis-cli "$@"
