#compdef ctlptl

# Zsh completion for ctlptl (local Kubernetes cluster manager)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'apply:apply a cluster or registry config'
      'completion:generate shell completion script'
      'create:create a resource'
      'delete:delete a resource'
      'docker-desktop:manage Docker Desktop settings'
      'get:display resources'
      'socat:start socat for docker-in-docker registry'
    )
    _describe -t commands 'ctlptl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      apply)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[config file]:file:_files' \
          '--filename=[config file]:file:_files' && ret=0
        ;;
      create)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:resource:(cluster registry)' \
          '--product=[cluster product]:product:(kind minikube k3d docker-desktop microk8s krucible)' \
          '--name=[resource name]:name' \
          '--port=[registry port]:port' \
          '--kubernetes-version=[Kubernetes version]:version' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[config file]:file:_files' \
          '--filename=[config file]:file:_files' \
          '--cascade[also delete dependent resources]' \
          '1:resource:(cluster registry)' \
          '2:name' && ret=0
        ;;
      get)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o+[output format]:format:(yaml json)' \
          '--output=[output format]:format:(yaml json)' \
          '1:resource:(clusters registries)' && ret=0
        ;;
    esac
    ;;
esac

return ret
