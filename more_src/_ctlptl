#compdef ctlptl
# Documentation: https://github.com/tilt-dev/ctlptl
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Local Kubernetes cluster manager from tilt-dev.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'apply:apply a cluster or registry config'
      'completion:generate shell completion script'
      'create:create a resource'
      'delete:delete a resource'
      'docker-desktop:manage Docker Desktop settings'
      'get:display resources'
      'socat:start socat for docker-in-docker registry'
    )
    _describe -t commands 'ctlptl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      apply)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[config file]:file:_files' \
          '--filename=[config file]:file:_files' && ret=0
        ;;
      create)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:resource:(cluster registry)' \
          '--product=[cluster product]:product:(docker-desktop kind minikube k3d microk8s)' \
          '--name=[resource name]:name' \
          '--port=[registry port]:port' \
          '--registry=[registry name to use]:registry' \
          '--min-cpus=[minimum CPUs]:cpus' \
          '--kubernetes-version=[Kubernetes version]:version' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[config file]:file:_files' \
          '--filename=[config file]:file:_files' \
          '--cascade[also delete dependent resources]' \
          '--ignore-not-found[do not error if resource missing]' \
          '1:resource:(cluster registry)' \
          '2:name' && ret=0
        ;;
      get)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o+[output format]:format:(yaml json wide name template)' \
          '--output=[output format]:format:(yaml json wide name template)' \
          '--template=[Go template for output]:template' \
          '--field-selector=[filter by field]:selector' \
          '1:resource:(clusters registries)' && ret=0
        ;;
    esac
    ;;
esac

return ret
