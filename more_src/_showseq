#compdef showseq
# showseq - Display sequences with features in pretty format

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequence[input nucleotide sequence(s)]:file:_files' \
  '-format[display format (0-8)]:format:' \
  '-things[elements to display]:things:' \
  '-outfile[output file name]:file:_files' \
  '-translate[regions for forward translation]:regions:' \
  '-revtranslate[regions for reverse complement translation]:regions:' \
  '-uppercase[regions to display in uppercase]:regions:' \
  '-highlight[regions to mark with HTML colors]:regions:' \
  '-annotation[text labels for regions]:annotation:' \
  '-enzymes[restriction enzymes to analyze]:enzymes:' \
  '-table[genetic code table (0-23)]:table:' \
  '-sourcematch[filter features by source name]:source:' \
  '-typematch[filter features by type]:type:' \
  '-sensematch[filter features by strand]:sense:' \
  '-minscore[minimum feature score]:score:' \
  '-maxscore[maximum feature score]:score:' \
  '-tagmatch[filter features by tag type]:tag:' \
  '-valuematch[filter features by tag values]:value:' \
  '-stricttags[require exact tag/value matching]' \
  '-mfile[restriction enzyme methylation data file]:file:_files' \
  '-mincuts[minimum enzyme cut frequency]:cuts:' \
  '-maxcuts[maximum enzyme cut frequency]:cuts:' \
  '-sitelen[minimum recognition site length]:len:' \
  '-single[force single cut enzymes only]' \
  '-blunt[include blunt-cutting enzymes]' \
  '-sticky[include sticky-cutting enzymes]' \
  '-ambiguity[include ambiguous pattern enzymes]' \
  '-plasmid[allow circular sequence wrapping]' \
  '-commercial[limit to commercially available enzymes]' \
  '-limit[report prototype enzymes only]' \
  '-orfminsize[minimum open reading frame size]:size:' \
  '-threeletter[display proteins in three-letter code]' \
  '-number[add sequence numbering]' \
  '-width[display line width]:width:' \
  '-length[page line length]:length:' \
  '-margin[margin width for numbering]:margin:' \
  '-name[display sequence ID]' \
  '-description[display sequence description]' \
  '-offset[starting position for numbering]:offset:' \
  '-html[enable HTML formatting]' \
  '-auto[turn off prompts]' \
  '-version[display version number]' \
  '*:sequence file:_files' && ret=0

return ret
