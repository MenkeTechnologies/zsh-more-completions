#compdef impos
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/impos.html
# MIRIAD: convert image coordinates between systems

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image or visibility dataset]:in:_files' \
  'coord=[coordinate per axis]:coord:' \
  'type=[input coordinate system]:type:(hms dms arcsec absdeg reldeg abspix relpix absghz relghz abskms relkms abslin rellin)' \
  'stype=[velocity convention]:stype:(radio optical relativistic VRAD VOPT VELO)' \
  'options=[altprj,altspc]:options:(altprj altspc)' \
  '*:image:_files' && ret=0

return ret
