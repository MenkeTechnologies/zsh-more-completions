#compdef ripgrep

# Zsh completion for ripgrep binary when installed as 'ripgrep' rather than 'rg'

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --count)'{-c,--count}'[show count of matches per file]' \
  '--count-matches[show count of individual matches]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case insensitive search]' \
  '(-s --case-sensitive)'{-s,--case-sensitive}'[case sensitive search]' \
  '(-S --smart-case)'{-S,--smart-case}'[smart case search]' \
  '(-v --invert-match)'{-v,--invert-match}'[invert match]' \
  '(-w --word-regexp)'{-w,--word-regexp}'[match whole words]' \
  '(-x --line-regexp)'{-x,--line-regexp}'[match whole lines]' \
  '(-F --fixed-strings)'{-F,--fixed-strings}'[treat pattern as literal string]' \
  '(-e --regexp)'{-e,--regexp}'[pattern to search for]:pattern' \
  '(-f --file)'{-f,--file}'[file containing patterns]:file:_files' \
  '(-l --files-with-matches)'{-l,--files-with-matches}'[show only filenames with matches]' \
  '--files-without-match[show filenames without matches]' \
  '(-m --max-count)'{-m,--max-count}'[limit matches per file]:count' \
  '--max-depth=[max directory depth]:depth' \
  '(-n --line-number)'{-n,--line-number}'[show line numbers]' \
  '(-N --no-line-number)'{-N,--no-line-number}'[suppress line numbers]' \
  '(-H --with-filename)'{-H,--with-filename}'[show filename]' \
  '--no-filename[suppress filename]' \
  '(-o --only-matching)'{-o,--only-matching}'[show only matching parts]' \
  '(-r --replace)'{-r,--replace}'[replace matches]:replacement' \
  '--passthru[show all lines]' \
  '(-A --after-context)'{-A,--after-context}'[lines after match]:lines' \
  '(-B --before-context)'{-B,--before-context}'[lines before match]:lines' \
  '(-C --context)'{-C,--context}'[lines around match]:lines' \
  '--color=[when to use colors]:when:(auto always never)' \
  '--colors=[set color specification]:spec' \
  '--column[show column number]' \
  '--heading[show filename above matches]' \
  '--no-heading[show filename on each line]' \
  '(-p --pretty)'{-p,--pretty}'[alias for --color always --heading --line-number]' \
  '(-g --glob)'{-g,--glob}'[include or exclude files]:glob' \
  '--iglob=[glob pattern case insensitively]:glob' \
  '(-t --type)'{-t,--type}'[only search files of type]:type' \
  '(-T --type-not)'{-T,--type-not}'[exclude files of type]:type' \
  '--type-list[show type list]' \
  '--type-add=[add type definition]:type definition' \
  '--type-clear=[clear type definition]:type' \
  '-z[search in compressed files]' \
  '--search-zip[search in compressed files]' \
  '(-a --text)'{-a,--text}'[treat binary files as text]' \
  '--binary[search binary files]' \
  '(-L --follow)'{-L,--follow}'[follow symlinks]' \
  '--hidden[search hidden files]' \
  '(-u --unrestricted)'{-u,--unrestricted}'[reduce filtering]' \
  '--no-ignore[do not respect ignore files]' \
  '--no-ignore-vcs[do not respect VCS ignore files]' \
  '--no-ignore-global[do not respect global ignore files]' \
  '--no-ignore-parent[do not respect parent ignore files]' \
  '--no-ignore-dot[do not respect .ignore files]' \
  '--no-ignore-exclude[do not respect local exclude files]' \
  '-E[specify encoding]:encoding' \
  '--encoding=[specify encoding]:encoding' \
  '--engine=[regex engine]:engine:(default pcre2)' \
  '--pcre2[use PCRE2 regex engine]' \
  '--auto-hybrid-regex[dynamically use PCRE2]' \
  '--crlf[treat CRLF as line terminator]' \
  '--mmap[use memory maps]' \
  '--no-mmap[do not use memory maps]' \
  '--multiline[enable multiline matching]' \
  '--multiline-dotall[dot matches newline in multiline]' \
  '--null-data[use NUL as line terminator]' \
  '-0[use NUL as line terminator for filenames]' \
  '--null[use NUL as line terminator for filenames]' \
  '--one-file-system[do not cross filesystem boundaries]' \
  '--trim[trim whitespace prefix]' \
  '-j[number of threads]:threads' \
  '--threads=[number of threads]:threads' \
  '--sort=[sort results]:key:(none path modified accessed created)' \
  '--sortr=[sort results in reverse]:key:(none path modified accessed created)' \
  '--stats[print statistics]' \
  '--vimgrep[output in vimgrep format]' \
  '--json[output in JSON format]' \
  '--no-unicode[disable Unicode support]' \
  '--pre=[preprocessor command]:command:_command_names' \
  '--pre-glob=[preprocessor glob]:glob' \
  '--debug[show debug messages]' \
  '--trace[show trace messages]' \
  '--generate=[generate man page or completions]:type:(man complete-bash complete-zsh complete-fish complete-powershell)' \
  '1:pattern' \
  '*:files or directories:_files' && ret=0

return ret
