#compdef bauh
# _bauh — Vinicius Moreira bauh CLI for the Linux multi-format application manager managing AppImage Flatpak Snap Web Apps Arch Debian-package and gem providing search install update remove disable backup tray and theme switcher (vinifmor team, Python/Qt); argparse
# upstream: https://github.com/vinifmor/bauh

_bauh() {
    local -a sub=(
        'gem:gem operations'
        'pkg-installed:list installed packages'
        'reset:reset bauh config'
        'tray:launch tray icon'
        'cache-clean:clean cache'
        'cache-export:export cache'
        'cache-import:import cache'
        'cache-list:list cached'
        'config:show config'
        'theme:theme management'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--logs-dir=+[dir]:dir:_files -/' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--style=+[Qt style]:s:(fusion windows windowsvista gtk2 macintosh)' \
        '--no-color[no color]' \
        '--logs[show logs]' \
        '--logs-tray[logs from tray]' \
        '--reset[reset to defaults]' \
        '--settings[open settings]' \
        '--show-panel[show panel]' \
        '--clean-config[clean config]' \
        '--profile=+[profile name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bauh subcommand' sub ;;
        args)
            case $words[1] in
                gem) _arguments \
                    '1:action:(list enable disable info)' \
                    '*:gem name:(arch flatpak snap appimage web debian)' ;;
                theme) _arguments \
                    '1:action:(set list current)' \
                    '*:theme name:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_bauh "$@"
