# ---------------------------------------------------------------------------
# autosaved — autosave daemon for Git projects, non-interfering snapshots (Go, 330★)
#
# upstream: https://github.com/nikochiko/autosaved
# author : Kaustubh Maske Patil  (nikochiko)
# license: MIT
#
# Source-direct completion: every subcommand and every flag below is verbatim
# from cmd/root.go (rootCmd init() + AddCommand calls + persistent flag
# bindings) and cmd/{save,start,list,restore}.go on the autosaved tip.
#
# Direct deps from go.mod:
#   github.com/go-git/go-git/v5 v5.4.2          ← canonical pure-Go Git library
#                                                 (this axis) — the source{d}
#                                                 successor of go-git/v4,
#                                                 maintained by the go-git org
#   github.com/spf13/cobra
#   github.com/spf13/viper
#
# autosaved creates snapshot commits on a parallel ref namespace without
# touching HEAD, the staging index, or push-bound branches — so it can
# autosave aggressively without polluting your normal Git workflow.
#
# === AXIS 158 CONTINUES — pure-language Git library ecosystem ===
# Axis position: Go=213 continues Axis 158 (slot 2/0/0).  Canonical pure-Go
# Git library is `go-git/go-git` originally by source{d} (the company),
# now maintained by the community-led go-git GitHub org — a pure-Go reimpl
# of Git plumbing (no libgit2 cgo) used by Argo CD, Flux CD, Drone CI,
# Terraform Cloud Operator, Crossplane, gitea, Mattermost — and the v5
# major version that established the "/v5" module path convention.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=213   _xvc                 ← previous round (axis 158 OPENS at 1/0/0)
#   Go=213     ← THIS FILE          (axis 158 continues, slot 2/0/0)
#   TS-Node=213 ← next round        (axis 158 CLOSES at triple-213, slot 1/1/1)
# ---------------------------------------------------------------------------

_autosaved() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'save:save the current state of a repository (snapshot commit)'
        'start:start the autosave daemon'
        'stop:stop the autosave daemon'
        'watch:add a repository to the daemon watch list'
        'unwatch:remove a repository from the daemon watch list'
        'list:list the last N commits and their related autosaves'
        'restore:restore the repository state to a previous checkpoint (commit hash)'
        'help:help about any command'
    )

    _arguments -C \
        '--config=[config file (default $XDG_CONFIG_HOME/.autosaved.yaml or $HOME/.autosaved.yaml)]:config:_files -g "*.(yaml|yml)"' \
        '--after_minutes=[minutes to wait, at minimum, before next autosave (default 2)]:n:' \
        '--after_seconds=[seconds to wait, at minimum, before next autosave (default 0)]:n:' \
        '--lockfilePath=[lockfile path for the daemon]:lockfile:_files' \
        '(- *)'{-h,--help}'[help for autosaved]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'autosaved command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                save)
                    _arguments \
                        '(-m --message)'{-m,--message=}'[commit message (default "manual save")]:message:' \
                        '(-h --help)'{-h,--help}'[help for save]' \
                        '1:path-to-repo:_files -/' && ret=0
                    ;;
                list)
                    _arguments \
                        '--autosaves=[maximum number of autosaves to display per commit]:n:' \
                        '(-h --help)'{-h,--help}'[help for list]' \
                        '1:N (number of commits, default 10):' && ret=0
                    ;;
                restore)
                    _arguments \
                        '(-h --help)'{-h,--help}'[help for restore]' \
                        '1:commit hash:' && ret=0
                    ;;
                start|stop|watch|unwatch)
                    _arguments \
                        '(-h --help)'{-h,--help}'[help for this command]' && ret=0
                    ;;
                help)
                    _describe -t commands 'autosaved command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_autosaved "$@"
