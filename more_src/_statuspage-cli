#compdef statuspage-cli statuspage
# _statuspage-cli — Atlassian Statuspage statuspage-cli CLI command-line frontend wrapping the Statuspage public status page communication platform REST API providing incident component group metric subscriber page user template scheduled maintenance impact-status incident-update status-page-customization sub-component-relationships notification-policies (Atlassian Statuspage team, Go); cobra
# upstream: https://www.atlassian.com/software/statuspage

_statuspage-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'page:page operations'
        'incident:incident operations'
        'component:component operations'
        'component-group:component group operations'
        'metric:metric operations'
        'metric-provider:metric provider operations'
        'subscriber:subscriber operations'
        'user:user operations'
        'template:template operations'
        'scheduled-maintenance:scheduled maintenance ops'
        'incident-update:incident update operations'
        'organization:organization operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--page-id=+[id]:str:' \
        '-p+[page]:str:' \
        '--organization-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'statuspage subcommand' sub ;;
        args)
            case $words[1] in
                page|incident|component|component-group|metric|metric-provider|subscriber|user|template|scheduled-maintenance|incident-update|organization) _arguments '1:op:(list get create update delete resolve postmortem upload)' '*:id:' ;;
            esac
            ;;
    esac
}

_statuspage-cli "$@"
