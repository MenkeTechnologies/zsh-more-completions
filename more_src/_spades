#compdef spades spades.py

# SPAdes: de novo genome / transcriptome assembler
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '-o[output directory]:dir:_files -/' \
  '(-1)-1[forward reads file]:file:_files -g "*.(fq|fastq|gz|bz2)"' \
  '(-2)-2[reverse reads file]:file:_files -g "*.(fq|fastq|gz|bz2)"' \
  '(-s)-s[unpaired reads]:file:_files' \
  '--pe-1[forward reads for paired library N]:file:_files' \
  '--pe-2[reverse reads for paired library N]:file:_files' \
  '--pe-s[unpaired reads for paired library N]:file:_files' \
  '--pe-12[interlaced paired reads for library N]:file:_files' \
  '--pe-m[merged reads for library N]:file:_files' \
  '--pe-or[paired library N orientation]:orient:(fr rf ff)' \
  '--mp-1[mate-pair forward reads N]:file:_files' \
  '--mp-2[mate-pair reverse reads N]:file:_files' \
  '--hqmp-1[high-quality mate-pair forward N]:file:_files' \
  '--hqmp-2[high-quality mate-pair reverse N]:file:_files' \
  '--nanopore[Nanopore long reads]:file:_files' \
  '--pacbio[PacBio long reads]:file:_files' \
  '--sanger[Sanger reads]:file:_files' \
  '--trusted-contigs[trusted assembled contigs]:file:_files' \
  '--untrusted-contigs[untrusted contigs]:file:_files' \
  '--only-error-correction[run only error correction]' \
  '--only-assembler[run only assembly]' \
  '--careful[careful mode (slower, fewer mismatches)]' \
  '--checkpoints[save checkpoint after each k]' \
  '--continue[continue from last checkpoint]' \
  '--restart-from=[restart from stage]:stage:(ec as k mc last)' \
  '--disable-gzip-output[do not gzip outputs]' \
  '-k[k-mer sizes (comma list)]:k:' \
  '--cov-cutoff=[coverage cutoff]:val:' \
  '--phred-offset=[FASTQ Phred offset]:offset:(33 64)' \
  '-t[number of threads]:n:' \
  '-m[memory limit (GB)]:GB:' \
  '--meta[metagenomic SPAdes]' \
  '--plasmid[plasmid SPAdes]' \
  '--rna[RNA-Seq mode]' \
  '--iontorrent[IonTorrent read mode]' \
  '--biosyntheticspades[biosynthetic gene cluster mode]' \
  '--corona[coronaSPAdes mode]' \
  '--rnaviral[RNA virus mode]' \
  '--isolate[isolate genome mode]' \
  '--sc[single-cell mode]' \
  '--dataset[YAML dataset description]:file:_files' \
  '*:input reads:_files' && ret=0
return ret
