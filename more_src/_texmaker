#compdef texmaker
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/texmaker.1.html
# Reference accessed: 2026-05-21
# Verified: upstream Ubuntu manpage at the URL above. Manpage documents
# only -master and -line.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-master[set the document as a master document]' \
  '-line[ask to jump to line N after loading]:n:' \
  '*:tex_file:_files -g "*.{tex,bib,sty,cls}"' && ret=0

return ret
