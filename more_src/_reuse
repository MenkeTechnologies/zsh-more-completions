#compdef reuse

# Zsh completion for reuse - FSFE REUSE compliance helper

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'addheader:add copyright and licensing headers to files'
  'annotate:add copyright and licensing headers to files'
  'convert-dep5:convert .reuse/dep5 to REUSE.toml'
  'download:download a license into the LICENSES directory'
  'init:initialize REUSE in a project'
  'lint:verify the project for REUSE compliance'
  'spdx:create an SPDX bill of materials'
  'supported-licenses:list supported SPDX licenses'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug logging]' \
  '--root=[root of the project]:directory:_directories' \
  '--no-multiprocessing[disable multiprocessing]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'reuse command' commands && ret=0
    ;;
  args)
    case $words[1] in
      addheader|annotate)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--copyright=[copyright string]:copyright' \
          '--license=[SPDX license identifier]:license' \
          '--year=[year of copyright]:year' \
          '--style=[comment style]:style:(c python tex)' \
          '--template=[template for header]:template' \
          '--exclude-year[do not include the year]' \
          '--merge-copyrights[merge copyright lines]' \
          '--single-line[force single-line comment style]' \
          '--multi-line[force multi-line comment style]' \
          '--force-dot-license[force .license file creation]' \
          '--recursive[recurse into directories]' \
          '--skip-unrecognised[skip unrecognised files]' \
          '--skip-existing[skip files that already have headers]' \
          '*:file:_files' && ret=0
        ;;
      download)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--all[download all missing licenses]' \
          '--output=[output file path]:file:_files' \
          '--source=[source of license]:url' \
          '*:license:' && ret=0
        ;;
      init)
        _arguments \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      lint)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--quiet[do not print anything to stdout]' \
          '--json[output as JSON]' \
          '--lines[output one file per line]' && ret=0
        ;;
      spdx)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--output=[output file]:file:_files' \
          '--creator=[creator of the SPDX document]:creator' && ret=0
        ;;
      convert-dep5)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--no-delete[do not delete .reuse/dep5 after conversion]' && ret=0
        ;;
      *)
        _arguments \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
