#compdef crystal17 crystal23 Pcrystal MPPcrystal Pproperties properties
# _crystal17 — Roberto Dovesi CRYSTAL17 CRYSTAL23 ab initio quantum chemistry for periodic systems using Gaussian-type orbital basis sets (crystalcode team, Fortran); custom argparse
# upstream: https://www.crystal.unito.it

_crystal17() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i+[input file]:file:_files -g "*.d12 *.d3 *.crystal *.inp"' \
        '--input=+[input file]:file:_files -g "*.d12 *.d3 *.crystal *.inp"' \
        '-o+[output file]:file:_files -g "*.out *.log"' \
        '--output=+[output file]:file:_files -g "*.out *.log"' \
        '-r+[restart file]:file:_files -g "*.f9 *.f80 *.RESTART"' \
        '--restart=+[restart file]:file:_files -g "*.f9 *.f80 *.RESTART"' \
        '-w+[wavefunction file]:file:_files -g "*.f98"' \
        '-d+[density matrix file]:file:_files -g "*.f9"' \
        '-n+[number of CPUs]:n:' \
        '--nproc=+[number of CPUs]:n:' \
        '-p+[parallel mode]:m:(serial parallel hybrid)' \
        '--mode=+[parallel mode]:m:(serial parallel hybrid)' \
        '-m+[memory MB]:n:' \
        '--memory=+[memory MB]:n:' \
        '-s+[scratch dir]:dir:_files -/' \
        '--scratch=+[scratch dir]:dir:_files -/' \
        '-l[run on local node]' \
        '--local[run on local node]' \
        '-property[run properties calculation]' \
        '-runtime+[seconds]:n:' \
        '--runtime=+[seconds]:n:' \
        '-keep[keep scratch files]' \
        '*:input file:_files -g "*.d12 *.d3 *.crystal *.inp"'
}

_crystal17 "$@"
