#compdef mosh-server
# Documentation: https://github.com/mobile-shell/mosh/blob/master/man/mosh-server.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mosh-server: server helper for mosh sessions. Flags from man/mosh-server.1.
local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-s[bind to local interface used by incoming SSH connection]' \
  '*-v[print debugging information; repeat for more verbosity]' \
  '-i+[IP address of local interface to bind (multihomed hosts)]:ip' \
  '-p+[UDP port or PORT:PORT2 range (0 = OS-chosen)]:port' \
  '-c+[number of colors to advertise via TERM]:colors:(8 256)' \
  '*-l+[locale-related fallback variable NAME=VALUE]:locale assignment' \
  '1:mode:(new)' \
  '*::command:_command_names -e' && ret=0

return ret
