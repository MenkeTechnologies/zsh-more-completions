#compdef mosh-server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--verbose[verbose output]' \
  '--server-log=[server log file]:file:_files' \
  '-c[set color support]:colors:(8 256)' \
  '-s[bind to specific IP]:address' \
  '-p[UDP port range]:port range' \
  '-i[bind to specific IP]:address' \
  '-l[locale]:locale' && ret=0

return ret
