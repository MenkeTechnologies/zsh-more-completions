#compdef 3dLME
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dLME.html
# AFNI: voxel-wise linear mixed-effects modeling

local ret=1

_arguments -s -S \
  '-bounds[remove outliers within lower/upper bounds]:lower:' \
  '-cio[use AFNI C IO functions (default)]' \
  '-corStr[correlation structure of residuals]:struct:' \
  '-cutoff[threshold for logistic regression accuracy]:value:' \
  '-dataTable[data structure long format with header]:table:' \
  '-dbgArgs[save parameters for debugging]' \
  '-glfCode[general linear F-test code]:code:' \
  '-glfLabel[label for general linear F-test]:label:' \
  '-gltCode[general linear t-test code]:code:' \
  '-gltLabel[label for general linear t-test]:label:' \
  '-help[display help]' \
  '-ICC[voxel-wise intra-class correlation]' \
  '-ICCb[ICC with Bayesian approach]' \
  '-jobs[number of processors]:n:' \
  '-LOGIT[voxel-wise logistic regression]' \
  '-logLik[include log likelihood in output]' \
  '-mask[process voxels within mask only]:mask:_files' \
  '-ML[use Maximum Likelihood instead of REML]' \
  '-model[fixed effects formula]:formula:' \
  '-num_glf[number of general linear F-tests]:n:' \
  '-num_glt[number of general linear t-tests]:n:' \
  '-prefix[output filename]:prefix:' \
  '-qVarCenters[centering values for quantitative vars]:values:' \
  '-qVars[quantitative variables/covariates]:vars:' \
  '-ranEff[random effects structure]:formula:' \
  '-RE[variables whose random effects are saved]:vars:' \
  '-REprefix[output filename for random effects]:prefix:' \
  '-resid[output filename for residuals]:prefix:' \
  '-Rio[use R IO functions]' \
  '-show_allowed_options[list all allowed options]' \
  '-SS_type[sum of squares type]:type:' \
  '-vVarCenters[centering values for voxel-wise covariates]:values:' \
  '-vVars[voxel-wise covariates]:vars:' \
  '*:dataset:_files' && ret=0

return ret
