#compdef taskpaper
# Documentation: https://man.archlinux.org/search?q=taskpaper
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:taskpaper_file:_files -g "*.taskpaper"' && ret=0

return ret
