#compdef solara

_solara() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_solara_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run|server)
                    _arguments \
                        '--host[host to bind to]:host:_hosts' \
                        '--port[port to listen on]:port:' \
                        '--open[open browser on start]' \
                        '--no-open[do not open browser on start]' \
                        '--production[run in production mode]' \
                        '--theme-variant[theme variant]:variant:(light dark)' \
                        '--theme-loader[show theme loader]' \
                        '--dev[run in development mode]' \
                        '(- *)'{-h,--help}'[show help]' \
                        '*:app module or script:_files -g "*.py"' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_solara_commands] )) ||
_solara_commands() {
    local -a commands
    commands=(
        'run:run a Solara app'
        'server:run the Solara server'
    )
    _describe -t commands 'solara command' commands
}

_solara "$@"
