#compdef cordenex
# Documentation: https://github.com/Cortiqaai/Cordenex
# Reference accessed: 2026-05-22
# Verified: README.md command table (@cortiqa/cordenex).

# Zsh completion for cordenex - autonomous AI software engineer CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'cordenex command' \
      'chat[interactive engineering session]' \
      'ask[one-shot autonomous task]' \
      'init[create CORDENEX.md project memory]' \
      'config[view or edit settings]' \
      'models[list available AI models]' && ret=0
    ;;
  args)
    case $line[1] in
      ask)
        _arguments '*:task:' && ret=0
        ;;
      config)
        _arguments \
          '1:action:(list set)' \
          '2:setting key:keys:' \
          '3:value:' && ret=0
        ;;
    esac
    ;;
esac

return ret
