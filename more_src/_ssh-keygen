#compdef ssh-keygen
# _ssh-keygen — OpenSSH ssh-keygen (authentication key management: -t generate, -p change passphrase, -y print public from private, -l print fingerprint, -R remove from known_hosts, -F find in known_hosts, -s/-h sign a key as CA, -L print certificate info, -A generate host keys)
# upstream: https://github.com/openssh/openssh-portable
# Flags from openssh-portable ssh-keygen.c on tip.

_ssh-keygen() {
    _arguments \
        '-A[generate all missing host keys]' \
        '-B[show bubblebabble digest]' \
        '-c[change comment]' \
        '-e[export to RFC4716/PEM/PKCS8]' \
        '-f+[key file]:file:_files' \
        '-F+[find host in known_hosts]:host:_hosts' \
        '-g[use generic file format with -r/-e]' \
        '-H[hash known_hosts]' \
        '-i[import key in -m format]' \
        '-K[download FIDO keys from token]' \
        '-k[generate KRL]' \
        '-L[print certificate contents]' \
        '-l[show fingerprint]' \
        '-m+[key format]:format:(PEM PKCS8 RFC4716 OpenSSH)' \
        '-N+[new passphrase]:passphrase:' \
        '-O+[option]:option:(application clear device no-touch-required resident user verify-required write-attestation)' \
        '-P+[old passphrase]:passphrase:' \
        '-p[change passphrase]' \
        '-Q[test KRL against keys]' \
        '-R+[remove host from known_hosts]:host:_hosts' \
        '-r+[print SSHFP DNS record]:hostname:' \
        '-s+[sign keys as CA]:ca_key:_files' \
        '-h[generate host certificate]' \
        '-I+[key identity]:identity:' \
        '-n+[principals]:principals:' \
        '-V+[validity interval]:interval:' \
        '-t+[key type]:type:(dsa ecdsa ecdsa-sk ed25519 ed25519-sk rsa rsa-sha2-256 rsa-sha2-512)' \
        '-a+[KDF rounds]:rounds:' \
        '-b+[bits]:bits:' \
        '-C+[comment]:comment:' \
        '-D+[PKCS#11 provider]:provider:' \
        '-v[verbose]' \
        '-w+[FIDO middleware]:lib:' \
        '-y[print public key from private]' \
        '-Y+[sign/verify/check-novalidate/match-principals]:mode:(sign verify check-novalidate match-principals find-principals)' \
        '*:host:_hosts'
}

_ssh-keygen "$@"
