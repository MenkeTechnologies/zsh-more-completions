#compdef viewnior
# Documentation: https://man.archlinux.org/search?q=viewnior
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '--help-all[all help options]' \
  '--help-gtk[GTK help options]' \
  '--version[show version]' \
  '--slideshow[start in slideshow mode]' \
  '--fullscreen[start fullscreen]' \
  '*:image or folder:_files' && ret=0

return ret
