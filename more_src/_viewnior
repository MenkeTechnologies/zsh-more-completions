#compdef viewnior
# Documentation: https://github.com/hellosiyan/Viewnior (src/main.c GOptionEntry)
# Reference accessed: 2026-05-21
# Verified: upstream source GOptionEntry array: --version, --slideshow,
# --fullscreen, plus G_OPTION_REMAINING for [FILE].
# Removed from prior file: --help-all and --help-gtk (these are GLib
# auto-generated options and are not explicitly registered).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help options]' \
  '--version[display version information]' \
  '--slideshow[enables slideshow mode at startup]' \
  '--fullscreen[launch in fullscreen mode]' \
  '*:image or folder:_files' && ret=0

return ret
