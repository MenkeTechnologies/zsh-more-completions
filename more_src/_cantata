#compdef cantata
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/cantata.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Cantata: Qt graphical MPD client (CDrummond/cantata, development ceased after v2.5.0)

_arguments -s \
  '(- *)--help[display help about options]' \
  '--help-qt[show Qt-specific options]' \
  '--help-kde[show KDE-specific options]' \
  '--help-all[show all options]' \
  '--author[display author information]' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '--license[display license information]' \
  '--caption=[set titlebar name]:caption:' \
  '--icon=[set application icon]:icon:' \
  '--config=[use alternative configuration file]:file:_files' \
  '--nocrashhandler[disable crash handler]' \
  '--waitforwm[wait for WM_NET compatible window manager]' \
  '--style=[set GUI style]:style:' \
  '--geometry=[main widget dimensions/position]:geom:' \
  '--nofork[run in foreground]' \
  '--display=[X display]:display:' \
  '*:url:_files'
