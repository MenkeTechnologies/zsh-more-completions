#compdef cantata
# Documentation: https://man.archlinux.org/search?q=cantata
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '--help-qt[show Qt help]' \
  '--help-kde[show KDE help]' \
  '--help-all[show all help]' \
  '--author[show author]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--license[show license]' \
  '--caption=[caption]:caption:' \
  '--icon=[icon]:icon:' \
  '--config=[config file]:file:_files' \
  '--nocrashhandler[no crash handler]' \
  '--style=[style]:style:' \
  '--geometry=[WxH+X+Y]:geom:' \
  '--display=[display]:display:' \
  '--inputstyle=[input style]:style:(onthespot overthespot offthespot root)' \
  '--graphicssystem=[graphics]:system:(raster opengl)' \
  '*:url:_files'
