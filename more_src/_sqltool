#compdef sqltool
# Documentation: https://man.archlinux.org/search?q=sqltool
# Reference accessed: 2026-05-16

_arguments -s \
  '--help[show help]' \
  '--sql=[SQL command]:sql:' \
  '--autoCommit[auto commit]' \
  '--noinput[no stdin input]' \
  '--stdinput[force read stdin]' \
  '--rcFile=[rc file]:file:_files' \
  '--inlineRc=[inline rc params]:params:' \
  '--driver=[JDBC driver class]:class:' \
  '--noAutoFile[do not auto-load auto.sql]' \
  '--debug[debug]' \
  '*-P=[set variable]:VAR=VAL:' \
  '--setVar=[set variable]:VAR=VAL:' \
  '*:urlid:'
