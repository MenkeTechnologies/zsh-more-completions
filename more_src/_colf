#compdef colf
# Documentation: https://github.com/pascaldekloe/colfer
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for colf Colfer compiler (pascaldekloe/colfer, Go flag)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-b[base directory for generated code]:directory:_directories' \
  '-p[package prefix]' \
  '-f[normalize schema formatting]' \
  '-v[verbose on stderr]' \
  '-s+[ColferSizeMax expression]' \
  '-l+[ColferListMax expression]' \
  '-x+[super class name]' \
  '-i+[comma-separated interfaces]' \
  '-t+[comma-separated tag files]:files' \
  '-c+[snippet file]:snippet:_files' \
  '-h[print manual]' \
  '1:language:(c go java javascript js ecmascript)' \
  '*:Colfer schema:_files -g "*.colfer"' && ret=0

return ret
