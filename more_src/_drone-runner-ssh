#compdef drone-runner-ssh
# _drone-runner-ssh — Drone CI SSH pipeline runner (drone-runners/drone-runner-ssh)
# upstream: https://github.com/drone-runners/drone-runner-ssh
# Subcommands from command/command.go (kingpin) on tip.

_drone-runner-ssh() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                daemon:'run the runner daemon (reads .env / envfile)'
                exec:'execute a pipeline locally'
                compile:'compile a pipeline YAML and print the intermediate'
            )
            _describe -t commands 'drone-runner-ssh command' cmds
            ;;
        args)
            case $words[1] in
                daemon)
                    _arguments ':envfile:_files'
                    ;;
                exec)
                    _arguments \
                        '--clone=[enable cloning]:bool:(true false)' \
                        '*--secrets=[secret param key=value]:secret:' \
                        '*--include=[include pipeline step]:step:' \
                        '*--exclude=[exclude pipeline step]:step:' \
                        '*--environ=[set environment variable]:var:' \
                        '--host=[target SSH host]:host:_hosts' \
                        '--user=[SSH user]:user:_users' \
                        '--password=[SSH password]:password:' \
                        '--private-key-file=[SSH private key file]:file:_files' \
                        '--debug[enable debug logging]' \
                        '--trace[enable trace logging]' \
                        '--dump[dump pipeline state to stdout]' \
                        ':source-file:_files'
                    ;;
                compile)
                    _arguments \
                        '--source=[source file location]:file:_files' \
                        '--clone=[enable cloning]:bool:(true false)' \
                        '*--secrets=[secret param key=value]:secret:' \
                        '*--environ=[set environment variable]:var:'
                    ;;
            esac
            ;;
    esac
}

_drone-runner-ssh "$@"
