#compdef wl-randr wlr-randr
# _wl-randr — Patrick Steinhardt wlr-randr xrandr equivalent for wlroots-based Wayland compositors (emersion team, C); custom argparse
# upstream: https://gitlab.freedesktop.org/emersion/wlr-randr

_wl-randr() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--json[json output]' \
        '--dryrun[dry run]' \
        '--output=+[output name]:str:' \
        '--on[turn output on]' \
        '--off[turn output off]' \
        '--toggle[toggle output]' \
        '--mode=+[WxH@Rate]:mode:' \
        '--preferred[use preferred mode]' \
        '--custom-mode=+[WxH@Rate]:str:' \
        '--pos=+[x,y position]:pos:' \
        '--transform=+[transform]:t:(normal 90 180 270 flipped flipped-90 flipped-180 flipped-270)' \
        '--scale=+[scale factor]:f:' \
        '--scale-filter=+[filter]:f:(nearest linear)' \
        '--adaptive-sync=+[mode]:m:(enabled disabled)'
}

_wl-randr "$@"
