#compdef krabby
# Documentation: https://man.archlinux.org/search?q=krabby
# Reference accessed: 2026-05-16

# yuk1ty/krabby — Chromium-driven automation CLI (`krabby --help` lists crawl/fetch/login verbs).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'crawl:headless crawl URLs'
  'fetch:download rendered HTML/assets'
  'login:authenticate persistent profile'
  'config:manage configuration file'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'krabby' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
