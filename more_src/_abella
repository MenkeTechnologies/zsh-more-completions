#compdef abella abella_dep
# Documentation: https://abella-prover.org/reference-guide.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (abella)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-v[show version]' \
      '--version[show version]' \
      '-i[interactive mode]' \
      '-q[quiet mode]' \
      '-n[no compile]' \
      '-o+[output file]:file:_files -g "*.thc *.thm"' \
      '-a+[annotate output]:f:(json html)' \
      '*-I+[search path]:dir:_files -/' \
      '-M+[map file]:file:_files' \
      '*: :_files -g "*.thm *.sig *.mod"' && ret=0 ;;
  (abella_dep)
    _arguments -C \
      '-h[help]' \
      '*-I+[search path]:dir:_files -/' \
      '-M+[map file]:file:_files' \
      '*: :_files -g "*.thm"' && ret=0 ;;
esac

return ret
