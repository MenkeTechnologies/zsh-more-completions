#compdef prettylogs
# Documentation: https://github.com/mrfoh/pretty-logs
# prettylogs - pretty print JSON log files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-F --formatTemplateFile)'{-F+,--formatTemplateFile=}'[custom template file for log formatting]:file:_files' \
  '(-f --timestampFormat)'{-f+,--timestampFormat=}'[timestamp format]:format' \
  '(-L --levelKey)'{-L+,--levelKey=}'[level key (default level)]:key' \
  '(-t --timeKey)'{-t+,--timeKey=}'[time key (default time)]:key' \
  '(-p --pidKey)'{-p+,--pidKey=}'[pid key (default pid)]:key' \
  '(-n --nameKey)'{-n+,--nameKey=}'[name key (default name)]:key' \
  '(-c --contextKey)'{-c+,--contextKey=}'[context key (default context)]:key' \
  '(-m --msgKey)'{-m+,--msgKey=}'[message key (default msg)]:key' \
  '(-k --errorLikeObjectKeys)'{-k+,--errorLikeObjectKeys=}'[error object keys (default err,error)]:keys' \
  '(-H --hostnameKey)'{-H+,--hostnameKey=}'[hostname key (default hostname)]:key' \
  '(-r --requestKey)'{-r+,--requestKey=}'[request key (default req)]:key' \
  '(-R --responseKey)'{-R+,--responseKey=}'[response key (default res)]:key' \
  '(-a --additionalKeys)'{-a+,--additionalKeys=}'[additional keys (comma-separated)]:keys' \
  '*:log file:_files' && ret=0

return ret
