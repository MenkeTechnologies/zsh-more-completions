#compdef dials.check_indexing_symmetry
# Documentation: https://dials.github.io/documentation/programs/dials_check_indexing_symmetry.html
# DIALS: check correlations between symmetry-related reflections

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--show-config[show full list of parameters]' \
  '--phil=[read parameters from phil file]:phil file:_files' \
  'd_min=[high resolution limit for analysis]:d_min' \
  'd_max=[low resolution limit for analysis]:d_max' \
  'symop_threshold=[threshold for true symmetry operator (~95% conf)]:threshold' \
  'grid=[search scope for testing misindexing on h,k,l]:n' \
  'grid_h=[search scope for testing misindexing on h]:n' \
  'grid_k=[search scope for testing misindexing on k]:n' \
  'grid_l=[search scope for testing misindexing on l]:n' \
  'asu=[search comparing within ASU]:bool:(True False)' \
  'normalise=[normalise intensities before correlation]:bool:(True False)' \
  'normalise_bins=[number of resolution bins for normalisation]:n' \
  'reference=[correctly indexed reference set]:file:_files' \
  'output.log=[log file name]:file:_files' \
  '*:file:_files' && ret=0

return ret
