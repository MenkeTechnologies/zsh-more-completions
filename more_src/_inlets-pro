#compdef inlets-pro
# Documentation: https://github.com/inlets/inlets-pro/blob/master/docs/cli-reference.md
# Secure HTTP and TCP tunnels (inlets Pro)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--url=[connect to remote tunnel server (wss://...)]:url' \
  '--token=[authentication token]:token' \
  '--token-from=[read token from file]:file:_files' \
  '--token-env=[read token from environment variable]:var' \
  '--upstream=[map domains to local services]:upstream' \
  '--port=[expose port on tunnel server]:port' \
  '--ports=[expose ports on tunnel server]:ports' \
  '--tcp-ports=[comma-separated list of TCP ports]:ports' \
  '--license=[literal license value]:license' \
  '--license-file=[path to license file]:file:_files' \
  '--auto-tls[enable automatic TLS for control plane]' \
  '--auto-tls-san=[subject-alternative-name for TLS certificate]:san' \
  '--control-port=[control plane port]:port' \
  '--tls-key=[path to TLS key file]:file:_files' \
  '--tls-cert=[path to TLS certificate file]:file:_files' \
  '--letsencrypt-domain=[obtain TLS from Lets Encrypt for domain]:domain' \
  '--letsencrypt-email=[email for Lets Encrypt registration]:email' \
  '--letsencrypt-issuer=[Lets Encrypt issuer (prod or staging)]:issuer:(prod staging)' \
  '--generate=[generate connection instructions (e.g. systemd)]:format:(systemd k8s_yaml)' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'inlets-pro command' \
      'http[HTTP layer 7 tunnel (client/server)]' \
      'tcp[TCP layer 4 tunnel (client/server)]' \
      'client[run a tunnel client]' \
      'server[run a tunnel server]' \
      'status[show tunnel connections]' \
      'version[show version]' && ret=0
    ;;
esac

return ret
