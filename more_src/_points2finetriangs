#compdef points2finetriangs
# Documentation: https://manpages.debian.org/experimental/topcom/topcom.7.en.html
# TOPCOM: enumerate fine (using all points) triangulations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print a usage message]' \
  '-I+[read input from filename instead of stdin]:file:_files' \
  '-d[debug mode]' \
  '-v[verbose]' \
  '--checktriang[check seed triangulation]' \
  '--regular[search for regular triangulations only]' \
  '--nonregular[output non-regular triangulations only]' \
  '--unimodular[output unimodular triangulations only]' \
  '--heights[output a height vector for every regular triangulation]' \
  '--flips[output all flips in terms of IDs of adjacent triangulations]' \
  '--noinsertion[never flip-in a point unused in the seed triangulation]' \
  '--reducepoints[greedily minimize the number of vertices used while flipping]' \
  '--keepcard[never change the cardinality of triangulations by flipping]' \
  '--cardinality=[count/output only triangulations with exactly k simplices]:k:' \
  '--maxcardinality=[limit output to triangulations with at most k simplices]:k:' \
  '--memopt[save memory by using caching techniques]' \
  '--soplex[use soplex for regularity checks]' \
  '--qsopt_ex[use QSopt_ex for regularity checks]' \
  '--threads=[use n threads if possible]:n:' \
  '--parallelenumeration[use multiple threads for enumeration]' \
  '--dump[write intermediate results into a file]' \
  '--dumpfile=[specify dump file location]:file:_files' \
  '--read[read intermediate results from a file]' \
  '*:file:_files' && ret=0

return ret
