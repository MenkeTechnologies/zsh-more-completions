#compdef sdcv

# Zsh completion for sdcv - StarDict Console Version

_arguments -s -S \
  '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive mode]' \
  '(-l --list-dicts)'{-l,--list-dicts}'[list installed dictionaries]' \
  '(-u --use-dict)'{-u+,--use-dict=}'[use specified dictionary]:dictionary name:' \
  '(-e --exact-search)'{-e,--exact-search}'[do not use fuzzy search]' \
  '(-f --fuzzy-search)'{-f,--fuzzy-search}'[use fuzzy search]' \
  '--data-dir=[use specified data directory]:directory:_files -/' \
  '(-0 --utf8-output)'{-0,--utf8-output}'[force UTF-8 output]' \
  '(-1 --utf8-input)'{-1,--utf8-input}'[force UTF-8 input]' \
  '(-2 --raw-dict-data)'{-2,--raw-dict-data}'[output raw dictionary data]' \
  '--json[output in JSON format]' \
  '--color[colorize output]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:word:'
