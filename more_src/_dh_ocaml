#compdef dh_ocaml
# _dh_ocaml — debhelper for OCaml libraries (Debian/dh-ocaml)
# upstream: https://salsa.debian.org/ocaml-team/dh-ocaml
# Flags from dh_ocaml(1) man page.

_dh_ocaml() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '--checksum=[checksum string for the interface]:str:' \
        '*--nodefined-map=[ignore unit of dev package]:dev:units:' \
        '*--runtime-map=[map dev->runtime[:checksum]]:pairs:' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-O+[option passed to the helper]:opt:'
}

_dh_ocaml "$@"
