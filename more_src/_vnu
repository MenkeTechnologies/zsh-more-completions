#compdef vnu
# Documentation: https://validator.github.io/validator/docs/vnu.1.html
# Reference accessed: 2026-05-30
# vnu — W3C Nu HTML / CSS / SVG validator (Java). Validates URLs/files/dirs
# against the W3C schema for HTML5+. Sister binaries vnu-server / vnu-client
# expose the same checker over HTTP; this completion covers the standalone
# vnu CLI only.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show usage information]' \
  '(- *)--version[show vnu version]' \
  '--asciiquotes[substitute ASCII quotes for smart quotes in messages]' \
  '(--skip-info-messages --errors-only)--skip-info-messages[report errors+warnings only (skip info)]' \
  '(--skip-info-messages --errors-only)--errors-only[report errors + non-document errors only]' \
  '--Werror[exit non-zero on any warning]' \
  '--exit-zero-always[exit zero even if errors are reported]' \
  '--stdout[write errors/warnings to stdout instead of stderr]' \
  '--filterfile=[file containing regex patterns to suppress matching messages]:file:_files' \
  '*--filterpattern=[regex to suppress matching messages (repeatable)]:regex:' \
  '--format=[output format]:fmt:(gnu xml json text)' \
  '(--skip-non-css --css)--skip-non-css[only check files with .css extension]' \
  '(--skip-non-css --css --skip-non-svg --svg --skip-non-html --html --xml)--css[force-treat every input as CSS]' \
  '(--skip-non-svg --svg)--skip-non-svg[only check files with .svg extension]' \
  '(--skip-non-css --css --skip-non-svg --svg --skip-non-html --html --xml)--svg[force-treat every input as SVG]' \
  '(--skip-non-html --html --xml)--skip-non-html[only check HTML/XHTML extensions]' \
  '(--skip-non-css --css --skip-non-svg --svg --skip-non-html --html --xml)--html[parse .xhtml/.xht with HTML parser]' \
  '(--skip-non-css --css --skip-non-svg --svg --skip-non-html --html --xml)--xml[parse .html with XML parser]' \
  '--also-check-css[also check CSS files when running on HTML]' \
  '--also-check-svg[also check SVG files when running on HTML]' \
  '--user-agent=[User-Agent header for HTTP/HTTPS fetches]:UA-string:' \
  '*--additional-request-header=[extra HTTP request header (HEADER: VALUE)]:header:' \
  '--no-langdetect[disable language detection + html[lang] checking]' \
  '--no-stream[force buffered parsing (no streaming)]' \
  '--verbose[show file names being checked]' \
  '*--entities=[supply extra entity definitions]:entities:' \
  '--schema=[non-default schema URL/file]:schema:_files' \
  '*:URL/file/directory:_files' \
  && ret=0

return ret
