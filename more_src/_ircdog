#compdef ircdog
# Documentation: https://github.com/ergochat/ircdog
# ircdog - tool for sending and receiving raw IRC protocol lines

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this screen]' \
  '--version[show version]' \
  '--tls[connect using TLS]' \
  '--tls-noverify[do not verify the provided TLS certificates]' \
  '--client-cert=[a file containing a TLS client cert & key, to use for TLS connections]:file:_files' \
  '--listen=[listen on an address like ":7778", pass through traffic]:address' \
  '--hide=[comma-separated list of commands/numerics to not print]:messages' \
  '--origin=[URL to send as the Origin header for a WebSocket connection]:url' \
  '(-r --raw)'{-r,--raw}'[do not interpret incoming formatting codes or outgoing escapes]' \
  '--transcript=[append a transcript of raw traffic to a file]:file:_files' \
  '--escape[display incoming lines with irc-go escapes]' \
  '--italics[enable ANSI italics codes (not widely supported)]' \
  '--color=[override detected color support]:mode:(none 16 256)' \
  '--no-readline[disable readline support]' \
  '--script=[read an initial list of commands to send from a file]:file:_files' \
  '--reconnect=[if disconnected unexpectedly, reconnect after a pause]:time' \
  '(-p --nopings)'{-p,--nopings}'[do not automatically respond to incoming pings]' \
  '(-v --verbose)'{-v,--verbose}'[output additional loglines]' \
  '*:host:_hosts' && ret=0

return ret
