#compdef sentryshot
# ============================================================================
# sentryshot - Network Video Recorder / Video Management System (Rust, GPL-2.0)
#
# Author : Curid (SentryShot org)
# Upstream: https://github.com/SentryShot/sentryshot
#
# sentryshot is a self-hosted NVR / VMS (Network Video Recorder /
# Video Management System) for IP security cameras: ingest RTSP /
# HLS / WebRTC feeds, time-shift them to disk in MP4 + HLS for
# live + playback streaming, run object-detection plugins on the
# frames (TFLite + ONNX), and expose a web UI for live viewing
# + clip browsing. Plugin-based architecture: auth, motion
# detection, MQTT publish, object detection (CPU + TFLite),
# thumbnail scaling - each plugin is a separate cdylib.
#
# The Argon2 password-hashing lane is built on `argon2` (workspace
# dep, declared in `plugins/auth_basic/Cargo.toml` HEAD), the
# canonical Rust Argon2 implementation by the RustCrypto org
# (github.com/RustCrypto/password-hashes, 890+ stars).
# `argon2` implements the RFC 9106 spec end-to-end: Argon2i,
# Argon2d, and Argon2id variants, parameterized memory cost (m),
# time cost (t), parallelism (p), and salt + secret + associated-
# data inputs. The library exposes both a low-level pure-bytes
# `Argon2::new(...)` API and the higher-level PHC string format
# (`$argon2id$v=19$m=...$<salt>$<hash>`) for direct DB-store
# compatibility with libsodium / passlib / other Argon2
# implementations.
#
# sentryshot's `auth_basic` plugin uses `argon2` to verify per-
# user passwords against PHC-string-formatted hashes stored in
# the configuration directory.
#
# ----------------------------------------------------------------------------
# AXIS 208 :: ARGON2 PASSWORD HASHING (RFC 9106)
# Round 1322 :: Rust slot 1 of 4 :: OPENS Axis 208
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : RustCrypto/password-hashes (argon2 crate)   - pure-Rust Argon2
#   Go      : golang.org/x/crypto/argon2                  - pure-Go Argon2 (stdlib-adjacent)
#   TS/Node : ranisalt/node-argon2                        - native-addon Argon2 (libargon2 C)
#
# All three are clean-room implementations of RFC 9106 (Argon2 -
# the Password Hashing Competition winner, 2015) with the three
# variants (Argon2i, Argon2d, Argon2id). The Rust + Go lanes are
# pure-language implementations; the Node lane historically wraps
# the reference C library via N-API. The PHC string format is
# the standard exchange surface so hashes generated by any lane's
# library can be verified by any other lane's.
#
# sentryshot is the Rust opener and represents a real-world use
# of Argon2 outside the canonical "user signup form" workflow:
# a long-running daemon validating per-camera-feed access tokens
# against a configuration-file-backed user database.
# ============================================================================

_sentryshot() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-V,--version}'[print version]' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :_sentryshot_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                run)      _arguments \
                              '--config[path to TOML config (default ./configs/sentryshot.toml)]:file:_files -g "*.toml"' \
                              '(- *)'{-h,--help}'[help]' ;;
                rec2mp4)  _arguments \
                              '(- *)'{-h,--help}'[help]' \
                              '1:recording file path:_files' ;;
                help)     _sentryshot_cmds ;;
            esac
            ;;
    esac

    return ret
}

_sentryshot_cmds() {
    local -a cmds
    cmds=(
        'run:Run the NVR daemon'
        'rec2mp4:Convert sentryshot recordings to MP4'
        'help:Print help for a subcommand'
    )
    _describe -t commands 'sentryshot command' cmds
}

_sentryshot "$@"
