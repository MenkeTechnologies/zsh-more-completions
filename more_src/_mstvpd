#compdef mstvpd
# Documentation: https://man.archlinux.org/search?q=mstvpd
# Reference accessed: 2026-05-16

# mstvpd: PCI VPD reader for Mellanox devices
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '*:PCI device:' && ret=0
return ret
