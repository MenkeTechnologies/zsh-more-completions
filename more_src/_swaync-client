#compdef swaync-client
# Documentation: https://github.com/ErikReider/SwayNotificationCenter/blob/main/src/client.vala
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for swaync-client - SwayNotificationCenter client

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-R --reload-config)'{-R,--reload-config}'[reload config file]' \
  '(-rs --reload-css)'{-rs,--reload-css}'[reload CSS file]' \
  '(-t --toggle-panel)'{-t,--toggle-panel}'[toggle notification panel]' \
  '(-op --open-panel)'{-op,--open-panel}'[open notification panel]' \
  '(-cp --close-panel)'{-cp,--close-panel}'[close notification panel]' \
  '(-d --toggle-dnd)'{-d,--toggle-dnd}'[toggle do not disturb mode]' \
  '(-D --get-dnd)'{-D,--get-dnd}'[get current DND state]' \
  '(-dn --dnd-on)'{-dn,--dnd-on}'[enable do not disturb]' \
  '(-df --dnd-off)'{-df,--dnd-off}'[disable do not disturb]' \
  '(-I --get-inhibited)'{-I,--get-inhibited}'[check if inhibited]' \
  '(-In --get-num-inhibitors)'{-In,--get-num-inhibitors}'[get inhibitor count]' \
  '(-Ia --inhibitor-add)'{-Ia,--inhibitor-add}'[add inhibitor]:app_id:' \
  '(-Ir --inhibitor-remove)'{-Ir,--inhibitor-remove}'[remove inhibitor]:app_id:' \
  '(-Ic --inhibitors-clear)'{-Ic,--inhibitors-clear}'[clear all inhibitors]' \
  '(-c --count)'{-c,--count}'[print notification count]' \
  '--hide-latest[hide latest notification]' \
  '--hide-all[hide all notifications]' \
  '--close-latest[close latest notification]' \
  '(-C --close-all)'{-C,--close-all}'[close all notifications]' \
  '(-a --action)'{-a,--action}'[invoke action]:action_index:' \
  '(-sw --skip-wait)'{-sw,--skip-wait}'[skip waiting for daemon]' \
  '(-s --subscribe)'{-s,--subscribe}'[subscribe to events]' \
  '(-swb --subscribe-waybar)'{-swb,--subscribe-waybar}'[subscribe with Waybar JSON output]' \
  '--change-cc-monitor[change control center monitor]:monitor:' \
  '--change-noti-monitor[change notification monitor]:monitor:'
