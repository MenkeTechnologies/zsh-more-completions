#compdef swaync-client

# Zsh completion for swaync-client - SwayNotificationCenter client

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-t --toggle-panel)'{-t,--toggle-panel}'[toggle notification panel]' \
  '(-op --open-panel)'{-op,--open-panel}'[open notification panel]' \
  '(-cp --close-panel)'{-cp,--close-panel}'[close notification panel]' \
  '(-d --toggle-dnd)'{-d,--toggle-dnd}'[toggle do not disturb mode]' \
  '(-D --get-dnd)'{-D,--get-dnd}'[get do not disturb state]' \
  '--dnd-on[turn on do not disturb]' \
  '--dnd-off[turn off do not disturb]' \
  '(-c --count)'{-c,--count}'[get notification count]' \
  '--hide-count[hide notification count]' \
  '--show-count[show notification count]' \
  '(-C --close-all)'{-C,--close-all}'[close all notifications]' \
  '(-cl --close-latest)'{-cl,--close-latest}'[close latest notification]' \
  '(-R --reload-config)'{-R,--reload-config}'[reload config]' \
  '(-rs --reload-css)'{-rs,--reload-css}'[reload CSS styles]' \
  '(-s --subscribe)'{-s,--subscribe}'[subscribe to notifications]' \
  '(-swb --subscribe-waybar)'{-swb,--subscribe-waybar}'[subscribe to waybar events]' \
  '(-I --inhibitor-add)'{-I,--inhibitor-add}'[add inhibitor]:app_id' \
  '(-Ir --inhibitor-remove)'{-Ir,--inhibitor-remove}'[remove inhibitor]:app_id' \
  '(-Is --inhibitor-status)'{-Is,--inhibitor-status}'[get inhibitor status]' \
  '--inhibitor-clear[clear all inhibitors]'
