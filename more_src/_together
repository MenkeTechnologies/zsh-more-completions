#compdef together

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--api-key[Together API key]:key:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'complete:run a text completion'
      'chat:run a chat completion'
      'images:generate images'
      'files:manage files'
      'fine-tuning:manage fine-tuning jobs'
      'models:manage models'
      'api-key:manage API key'
    )
    _describe -t commands 'together command' commands && ret=0
    ;;
  args)
    case $line[1] in
      complete|chat)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--model[model to use]:model:' \
          '--max-tokens[maximum tokens to generate]:tokens:' \
          '--temperature[sampling temperature]:temperature:' \
          '--top-p[top-p sampling]:value:' \
          '--stop[stop sequence]:sequence:' && ret=0
        ;;
      files)
        local -a file_commands
        file_commands=(
          'upload:upload a file'
          'list:list files'
          'delete:delete a file'
        )
        _describe -t commands 'files command' file_commands && ret=0
        ;;
      fine-tuning)
        local -a ft_commands
        ft_commands=(
          'create:create a fine-tuning job'
          'list:list fine-tuning jobs'
          'get:get fine-tuning job details'
          'cancel:cancel a fine-tuning job'
          'events:list fine-tuning events'
          'download:download fine-tuned model'
        )
        _describe -t commands 'fine-tuning command' ft_commands && ret=0
        ;;
      models)
        local -a model_commands
        model_commands=(
          'list:list available models'
        )
        _describe -t commands 'models command' model_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
