#compdef together
# Documentation: https://github.com/togethercomputer/together-python
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'completions:run a text completion'
      'chat.completions:run a chat completion'
      'images:generate images (subcommand: generate)'
      'files:manage uploaded files'
      'fine-tuning:manage fine-tuning jobs'
      'models:list available models'
    )
    _describe -t commands 'together command' commands && ret=0
    ;;
  args)
    case $line[1] in
      completions)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--model[model to use]:model:' \
          '--max-tokens[maximum tokens to generate]:tokens:' \
          '--stop[stop sequence]:sequence:' \
          '--no-stream[disable token streaming]' && ret=0
        ;;
      chat.completions)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--message[message text]:message:' \
          '--model[model to use]:model:' \
          '--no-stream[disable token streaming]' && ret=0
        ;;
      images)
        local -a image_commands
        image_commands=(
          'generate:generate images from a prompt'
        )
        _describe -t commands 'images command' image_commands && ret=0
        ;;
      files)
        local -a file_commands
        file_commands=(
          'check:validate a file before upload'
          'upload:upload a file'
          'list:list files'
          'retrieve:retrieve a file'
          'retrieve-content:download file contents'
          'delete:delete a file'
        )
        _describe -t commands 'files command' file_commands && ret=0
        ;;
      fine-tuning)
        local -a ft_commands
        ft_commands=(
          'create:create a fine-tuning job'
          'list:list fine-tuning jobs'
          'retrieve:retrieve fine-tuning job details'
          'list-events:list fine-tuning events'
          'cancel:cancel a fine-tuning job'
          'download:download fine-tuned model'
        )
        _describe -t commands 'fine-tuning command' ft_commands && ret=0
        ;;
      models)
        local -a model_commands
        model_commands=(
          'list:list available models'
        )
        _describe -t commands 'models command' model_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
