#compdef velvetg
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/velvetg.1.html
# Velvet de Bruijn graph construction, error removal and repeat resolution

local ret=1

_arguments -s -S \
  '-cov_cutoff+[remove low coverage nodes after tour bus]:cutoff' \
  '-ins_length+[expected distance between two paired end reads]:length' \
  '-read_trkg+[track short read positions in assembly]:yesno:(yes no)' \
  '-min_contig_lgth+[minimum contig length exported to contigs.fa]:length' \
  '-amos_file+[export assembly to AMOS file]:yesno:(yes no)' \
  '-exp_cov+[expected coverage of unique regions]:cov' \
  '-long_cov_cutoff+[remove nodes with low long-read coverage]:cutoff' \
  '-ins_length_long+[expected distance between paired long reads]:length' \
  '-ins_length_sd+[standard deviation of insert length]:sd' \
  '-scaffolding+[scaffolding of contigs using paired end info]:yesno:(yes no)' \
  '-max_branch_length+[maximum length in bp of bubble]:length' \
  '-max_divergence+[maximum divergence rate between branches in a bubble]:rate' \
  '-max_gap_count+[maximum number of gaps allowed in a bubble alignment]:count' \
  '-min_pair_count+[minimum paired end connections to justify scaffolding]:count' \
  '-max_coverage+[remove high-coverage nodes after tour bus]:cov' \
  '-coverage_mask+[minimum coverage for confident contig regions]:cov' \
  '-long_mult_cutoff+[minimum long reads required to merge contigs]:count' \
  '-unused_reads+[export unused reads in UnusedReads.fa]:yesno:(yes no)' \
  '-alignments+[export summary of contig alignment to reference]:yesno:(yes no)' \
  '-exportFiltered+[export long nodes eliminated by coverage filters]:yesno:(yes no)' \
  '-clean+[remove intermediary files useless for recalculation]:yesno:(yes no)' \
  '-very_clean+[remove all intermediary files]:yesno:(yes no)' \
  '-paired_exp_fraction+[eliminate paired-end connections below fraction]:fraction' \
  '-shortMatePaired+[mark mate-pair library contamination potential]:yesno:(yes no)' \
  '-conserveLong+[preserve sequences containing long reads]:yesno:(yes no)' \
  ':directory:_files -/' && ret=0

return ret
