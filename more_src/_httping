#compdef httping

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-u -g)'{-u,-g}'[URL to ping]:url' \
  '-p[port number]:port' \
  '-c[number of pings]:count' \
  '-i[interval between pings]:seconds' \
  '-t[timeout]:seconds' \
  '-G[use GET instead of HEAD]' \
  '-b[show transfer speed]' \
  '-S[split time into connect and transfer]' \
  '-s[show HTTP status codes]' \
  '-l[use SSL]' \
  '-f[flood mode]' \
  '-a[audible ping]' \
  '-o[start offset for byte range]:offset' \
  '-x[use proxy]:host\:port' \
  '-K[send cookie with request]:cookie' \
  '-A[set user agent]:useragent' \
  '-R[set referer]:referer' \
  '-I[read the full reply]' \
  '-Y[show colors]' \
  '-4[use IPv4]' \
  '-6[use IPv6]' \
  '-h[display help]' \
  '-V[display version]' && ret=0
return ret
