#compdef yppush
# _yppush — OpenBSD yppush (distribute a YP map from master to all slaves listed in the ypservers map; tells the master to reread its Berkeley-DB files from disk before propagating)
# upstream: https://github.com/openbsd/src (usr.sbin/ypserv)
# Flags from usr.sbin/ypserv/yppush/yppush.8 on tip.

_yppush() {
    _arguments \
        '-v[verbose]' \
        '-d+[domain]:domain:' \
        '-h+[host to push to]:host:_hosts' \
        '1:mapname:(passwd group hosts services networks protocols rpc netgroup aliases)'
}

_yppush "$@"
