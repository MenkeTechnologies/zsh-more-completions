#compdef findup
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: https://github.com/dmytro/zsh-compdef/blob/5b2c600c509cda1fb0a05a6055fdcb035c886616/_findup
# Repository: dmytro/zsh-compdef (_findup)
#
# For my version of finding files in a back-to-/ file path search
# (Amazon had a different implementation, and there are probably others
# out there).

local ret=1

_arguments -s -w \
  '-q[be quiet]' \
  '-H[abort search if reach HOME]' \
  '(-q -H)1:file:_files' \
  && ret=0

return $ret
