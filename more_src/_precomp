#compdef precomp
# _precomp — content-aware preprocessor for further compression (schnaader/precomp-cpp)
# upstream: https://github.com/schnaader/precomp-cpp
# Flags from precomp.cpp (custom argv switch on first char).

_precomp() {
    _arguments \
        '-h[show short help]' \
        '-longhelp[show long help]' \
        '-V[show version]' \
        '-r[restore (decompress) precomp file]' \
        '-d+[set max recursion depth]:n:' \
        '-s+[set min identical-byte size]:n:' \
        '-intense[enable intense mode]' \
        '-brute[enable brute mode]' \
        '-brunsli=[brunsli JPEG compression]:bool:(0 1)' \
        '-brotli=[brotli compression]:bool:(0 1)' \
        '-o+[output file]:file:_files' \
        '-c+[compression method]:method:(none gzip lzma)' \
        '-cn[disable on-the-fly compression]' \
        '-cl[on-the-fly LZMA]' \
        '-cg[on-the-fly gzip]' \
        '-lm+[LZMA max memory (MiB)]:n:' \
        '-lt+[LZMA thread count]:n:' \
        '-t+[disabled methods]:methods:' \
        '*--ignore=[byte position to ignore]:pos:' \
        '*:file:_files'
}

_precomp "$@"
