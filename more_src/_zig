#compdef zig

local -a _zig_cmds

_zig_cmds=(
  'build:build project from build.zig'
  'init:initialize a zig package in the current directory'
  'fetch:copy a package into the global cache'
  'build-exe:compile executable from source or object files'
  'build-lib:compile library from source or object files'
  'build-obj:compile source into an object file'
  'test:compile and run test suite'
  'run:compile and run'
  'ast-check:check for errors in Zig source code'
  'fmt:reformat Zig source code'
  'translate-c:translate C code to Zig'
  'ar:assemble archive'
  'cc:compile C/C++ code'
  'c++:compile C++ code'
  'dlltool:create import libraries for DLLs'
  'env:print the native zig environment'
  'help:print help'
  'libc:display native libc paths or manage cross-compilation libc'
  'objcopy:copy and transform object files'
  'ranlib:create an index for an archive'
  'rc:compile a Windows resource script'
  'targets:list all available native targets'
  'version:print version'
  'zen:print the Zen of Zig'
)

_arguments -s -S \
  '1:command:->cmds' \
  '*:: :->args'

case "$state" in
  cmds)
    _describe -t commands 'zig command' _zig_cmds
    ;;
  args)
    case $words[1] in
      build)
        _arguments \
          '-p[override the default install prefix]:prefix:_directories' \
          '--prefix[override the default install prefix]:prefix:_directories' \
          '--build-file[override path to build.zig]:build file:_files' \
          '--cache-dir[override path to local zig cache]:directory:_directories' \
          '--global-cache-dir[override path to global zig cache]:directory:_directories' \
          '--zig-lib-dir[override path to zig lib]:directory:_directories' \
          '-j[limit concurrent jobs]:jobs:' \
          '--release[request release mode builds]::mode:(fast safe small off)' \
          '--prominent-color[force colored output]:color:(auto off on)' \
          '--summary[print the build summary]:mode:(none failures new all)' \
          '--verbose[print verbose information]' \
          '-h[print help]' \
          '--help[print help]' \
          '*:build targets:'
        ;;
      fmt)
        _arguments \
          '--color[enable/disable colored output]:color:(auto off on)' \
          '--exclude[exclude directories/files from formatting]:path:_files' \
          '--check[check if input is well formatted]' \
          '--ast-check[check for compile errors in formatted code]' \
          '--stdin[read from stdin]' \
          '-h[print help]' \
          '*:files:_files -g "*.zig"'
        ;;
      build-exe|build-lib|build-obj)
        _arguments \
          '-target[set the compilation target]:target:' \
          '-O[set the optimization mode]:mode:(Debug ReleaseSafe ReleaseFast ReleaseSmall)' \
          '--name[override the output name]:name:' \
          '--main-mod-path[override the root module path]:path:_files' \
          '-lc[link against libc]' \
          '--strip[strip debug symbols]' \
          '--single-threaded[single-threaded mode]' \
          '-femit-bin[emit binary to specified path]:path:_files' \
          '-fno-emit-bin[do not emit binary]' \
          '-I[add include path for C imports]:directory:_directories' \
          '-L[add library search path]:directory:_directories' \
          '-l[link against a system library]:library:' \
          '-D[define a compile-time variable]:name=value:' \
          '--pkg-begin[begin a package scope]:name:' \
          '--pkg-end[end a package scope]' \
          '--dep[add a package dependency]:spec:' \
          '--mod[add a module]:spec:' \
          '*:source files:_files -g "*.zig"'
        ;;
      test)
        _arguments \
          '-target[set the compilation target]:target:' \
          '-O[set the optimization mode]:mode:(Debug ReleaseSafe ReleaseFast ReleaseSmall)' \
          '--test-filter[set the test filter]:filter:' \
          '--test-name-prefix[add prefix to every test name]:prefix:' \
          '--name[override the output name]:name:' \
          '--single-threaded[single-threaded mode]' \
          '-I[add include path for C imports]:directory:_directories' \
          '*:source files:_files -g "*.zig"'
        ;;
      run)
        _arguments \
          '-target[set the compilation target]:target:' \
          '-O[set the optimization mode]:mode:(Debug ReleaseSafe ReleaseFast ReleaseSmall)' \
          '--name[override the output name]:name:' \
          '-I[add include path for C imports]:directory:_directories' \
          '*:source files:_files -g "*.zig"'
        ;;
      translate-c)
        _arguments \
          '-target[set the compilation target]:target:' \
          '-I[add include path]:directory:_directories' \
          '-D[define a macro]:name=value:' \
          '*:source files:_files -g "*.{c,h}"'
        ;;
      cc|c++)
        _arguments \
          '-c[compile without linking]' \
          '-o[output file]:output file:_files' \
          '-O-[optimization level]:level:(0 1 2 3 s z g)' \
          '-g[generate debug info]' \
          '-I[add include path]:directory:_directories' \
          '-L[add library search path]:directory:_directories' \
          '-l[link against a library]:library:' \
          '-D[define a macro]:name=value:' \
          '-std=[set language standard]:standard:' \
          '-target[set the compilation target]:target:' \
          '-W-[warning flag]:flag:' \
          '-f-[feature flag]:flag:' \
          '*:source files:_files'
        ;;
      *)
        _arguments '*:files:_files'
        ;;
    esac
    ;;
esac
