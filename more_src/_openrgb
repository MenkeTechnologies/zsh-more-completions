#compdef openrgb
# Documentation: man 1 openrgb (manpages.debian.org/unstable/openrgb)
# Reference accessed: 2026-05-29
# OpenRGB — vendor-agnostic RGB lighting control for PC peripherals.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version and build information]' \
  '--gui[show the GUI]' \
  '--startminimized[start the GUI minimized to tray]' \
  '--client=[connect SDK client to host\:port (default port 6742)]:ip:port:' \
  '--server[start the SDK server]' \
  '--server-port=[SDK server port (1024-65535, default 6742)]:port:' \
  '(-l --list-devices)'{-l,--list-devices}'[list all compatible devices with their numbers]' \
  '*'{-d,--device=}'[select device by index 0-9 or name]:device:' \
  '*'{-z,--zone=}'[select zone 0-N to apply colors/sizes to]:zone:' \
  '*'{-c,--color=}'[set device colors (random or hex)]:color:' \
  '*'{-m,--mode=}'[set lighting mode]:mode:(static breathing rainbow spectrum-cycle off direct)' \
  '*'{-b,--brightness=}'[brightness 0-100 (when supported)]:percent:' \
  '*'{-s,--size=}'[set new size of specified zone]:size:' \
  '(-p --profile)'{-p,--profile=}'[load settings from profile file]:file:_files -g "*.orp"' \
  '(-sp --save-profile)'{-sp,--save-profile=}'[save current settings to profile file]:file:_files -g "*.orp"' \
  '--i2c-tools[open I2C/SMBus tools (hardware modification risk)]' \
  '--localconfig[use current directory for configuration]' \
  '--config=[custom configuration directory path]:dir:_directories' \
  '--nodetect[skip hardware detection on startup]' \
  '--noautoconnect[prevent automatic local server connection]' \
  '--loglevel=[set log level 0-6]:level:(0 1 2 3 4 5 6 fatal error warning info notice debug trace)' \
  '--print-source[include source file and line numbers in log output]' \
  '(-v --verbose -vv --very-verbose)'{-v,--verbose}'[output log messages to stdout]' \
  '(-v --verbose -vv --very-verbose)'{-vv,--very-verbose}'[output debug and log messages to stdout]' \
  '--autostart-check[check login startup status]' \
  '--autostart-disable[remove login autostart]' \
  '--autostart-enable=[enable autostart with specified arguments]:args:' && ret=0

return ret
