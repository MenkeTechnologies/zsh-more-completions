#     CAfile, cert, key, sni, verify, log-level)
#   src/emqtt_cli.erl line 95
#     (`-define(CONNECT_OPTS, ?CONN_SHORT_OPTS ++
#     ?HELP_OPT ++ ?CONN_LONG_OPTS)` â€” macro
#     CONCATENATION: connect inherits ALL short, help,
