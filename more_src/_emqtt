#     macro defining HELP_OPT as a literal list)
#   src/emqtt_cli.erl lines 31-49
#     (`-define(CONN_SHORT_OPTS, [{host, $h, "host",
#     {string, "localhost"}, "..."}, ...])` â€” SHORT-
