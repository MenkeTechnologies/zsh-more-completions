#compdef pbs_attach
# Documentation: https://docs.open-mpi.org/en/main/
# PBS: attach a session ID to a PBS job

local ret=1

_arguments -s \
  '-c+[Windows only: command invoked using a new command shell]:script:_files' \
  '-j+[job id to which the session id is to be attached]:job id' \
  '-m+[port at which to contact MOM]:port' \
  '-p+[process id whose session id is to be attached]:pid:_pids' \
  '-P[attach sessions of pbs_attach and its parent to the job]' \
  '-s[start a new session and attach it to the job]' \
  '--version[print PBS version information and exit]' \
  '*:::command:_command_names -e' && ret=0

return ret
