'--model=[Set the root-level model (provider\:model format, e.g., openrouter\:anthropic/claude-3.5-sonnet)]:MODEL:_default' \
'--api-key=[Set API key for a provider (format\: provider\:key, e.g., openrouter\:your-key)]:API_KEY:_default' \
'--log-level=[Set log level (none, info, debug)]:LOG_LEVEL:_default' \
'--mcp-providers=[Set MCP providers]:MCP_PROVIDERS:_default' \
'--mcp-server=[Add/configure MCP server (format\: name,url=X|command=Y,args=Z)]:MCP_SERVER:_default' \
'--system=[Set custom system prompt (or '\''default'\'' to reset to default)]:SYSTEM:_default' \
'--markdown-enable=[Enable markdown rendering for AI responses]:MARKDOWN_ENABLE:(true false)' \
'--markdown-theme=[Set markdown theme (default, dark, light, ocean, solarized, monokai)]:MARKDOWN_THEME:_default' \
'--list-themes[List all available markdown themes]' \
'--show[Show current configuration values with defaults]' \
'--validate[Validate configuration without making changes]' \
'--upgrade[Upgrade config file to latest version]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(run)
_arguments "${_arguments_options[@]}" : \
'-n+[Session name — creates a named session or resumes it if it already exists]:NAME:_default' \
'--name=[Session name — creates a named session or resumes it if it already exists]:NAME:_default' \
'-r+[Resume a specific session by name]:SESSION:_default' \
'--resume=[Resume a specific session by name]:SESSION:_default' \
'--format=[Output format\: plain or jsonl. When set, runs non-interactively (reads input from stdin)]:FORMAT:_default' \
'-m+[Override the model for this session (e.g. \`openrouter\:anthropic/claude-sonnet-4\`). Priority\: CLI --model > role.model > config.model]:MODEL:_default' \
'--model=[Override the model for this session (e.g. \`openrouter\:anthropic/claude-sonnet-4\`). Priority\: CLI --model > role.model > config.model]:MODEL:_default' \
'*--hook=[Activate a webhook hook by name (defined in \[\[hooks\]\] config). Can be specified multiple times for multiple hooks]:NAME:_default' \
'--resume-recent[Resume the most recent session for the current working directory]' \
'--daemon[Keep the session alive indefinitely, waiting for messages injected via \`octomind inject\`. Implies non-interactive mode (requires --format)]' \
'--sandbox[Restrict all filesystem writes to the current working directory]' \
'-h[Print help]' \
'--help[Print help]' \
'::tag -- Agent tag (e.g. `developer\:general`) or role name (e.g. `developer`). Omit to use the default role from config:_octomind_complete_run' \
&& ret=0
;;
(server)
_arguments "${_arguments_options[@]}" : \
'--host=[Host address to bind to]:HOST:_default' \
'-p+[Port to listen on]:PORT:_default' \
'--port=[Port to listen on]:PORT:_default' \
'--sandbox[Restrict all filesystem writes to the current working directory]' \
'-h[Print help]' \
'--help[Print help]' \
'::tag -- Agent tag (e.g. `developer\:general`) or role name (e.g. `developer`). Omit to use the default role from config:_default' \
&& ret=0
;;
(acp)
_arguments "${_arguments_options[@]}" : \
'-n+[Session name — used as the preferred name when the client creates a session]:NAME:_default' \
'--name=[Session name — used as the preferred name when the client creates a session]:NAME:_default' \
'-r+[Resume a specific session by name on the next client \`new_session\` request]:SESSION:_default' \
'--resume=[Resume a specific session by name on the next client \`new_session\` request]:SESSION:_default' \
'-m+[Override the model for sessions started by this ACP agent (e.g. \`openrouter\:anthropic/claude-sonnet-4\`). Priority\: CLI --model > role.model > config.model]:MODEL:_default' \
'--model=[Override the model for sessions started by this ACP agent (e.g. \`openrouter\:anthropic/claude-sonnet-4\`). Priority\: CLI --model > role.model > config.model]:MODEL:_default' \
'*--hook=[Activate a webhook hook by name (defined in \[\[hooks\]\] config). Can be specified multiple times for multiple hooks]:NAME:_default' \
'--resume-recent[Resume the most recent session for the current working directory on the next client \`new_session\` request]' \
'--sandbox[Restrict all filesystem writes to the current working directory]' \
'-h[Print help]' \
'--help[Print help]' \
'::tag -- Agent tag (e.g. `developer\:general`) or role name (e.g. `developer`). Omit to use the default role from config:_default' \
&& ret=0
;;
(tap)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::tap -- Tap to add in `user/repo` format. Omit to list all active taps:_default' \
'::local_path -- Local directory path for the tap (skips git clone):_default' \
&& ret=0
;;
(untap)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':name -- Tap name to remove in `user/repo` format:_default' \
&& ret=0
;;
(vars)
_arguments "${_arguments_options[@]}" : \
'-p[Show preview of placeholder values (3 lines)]' \
'--preview[Show preview of placeholder values (3 lines)]' \
'-e[Show full expanded values for placeholders]' \
'--expand[Show full expanded values for placeholders]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(send)
_arguments "${_arguments_options[@]}" : \
'-n+[Name of the running session to send to]:NAME:_default' \
'--name=[Name of the running session to send to]:NAME:_default' \
'-h[Print help]' \
'--help[Print help]' \
'::message -- Message to send. If omitted, reads from stdin:_default' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The shell to generate completion for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(complete)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':subcommand -- The subcommand to generate completions for (e.g. `run`):_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_octomind__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:octomind-help-command-$line[1]:"
        case $line[1] in
            (config)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(run)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(server)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(acp)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(tap)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(untap)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(vars)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(send)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(complete)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

