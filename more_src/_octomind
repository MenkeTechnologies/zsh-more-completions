'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_octomind_commands" \
"*::: :->octomind" \
&& ret=0
    case $state in
    (octomind)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:octomind-command-$line[1]:"
