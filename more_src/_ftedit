#compdef ftedit
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftedit.html
# Modify FITS image pixel or table cell values, singly or via template

local ret=1

_arguments -s -S \
  'infile=[input FITS file with optional extension]:infile:_files' \
  'column=[column name/number, or @templatefile]:column:' \
  'row=[row number containing the element]:row:' \
  'value=[new value for pixel or cell]:value:' \
  'element=[vector element to modify]:element:' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
