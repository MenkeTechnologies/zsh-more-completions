#compdef kube-burner
# Documentation: https://man.archlinux.org/search?q=kube-burner
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--log-level=[level]:level:(debug info warn error fatal)' \
  '1:command:(check-alerts completion destroy health-check import index init measure version)' \
  '*::args: _default'
