#compdef colabfold_search
# Documentation: https://github.com/sokrypton/ColabFold/blob/main/colabfold/mmseqs/search.py
# LocalColabFold MMseqs2-based local MSA / template search

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--prefilter-mode=[prefiltering algorithm]:mode:(0 1 2)' \
  '-s+[MMseqs2 sensitivity setting]:val:' \
  '--db1=[UniRef database]:db:' \
  '--db2=[templates database]:db:' \
  '--db3=[environmental database]:db:' \
  '--db4=[environmental pairing database]:db:' \
  '--use-env=[use environmental database]:val:(0 1)' \
  '--use-env-pairing=[use environmental pairing database]:val:(0 1)' \
  '--use-templates=[use templates database]:val:(0 1)' \
  '--filter=[filter MSA by predefined parameters]:val:(0 1 2)' \
  '--mmseqs=[location of mmseqs binary]:file:_files' \
  '--expand-eval=[E-value threshold for expandaln]:val:' \
  '--align-eval=[E-value threshold for align]:val:' \
  '--diff=[minimum sequences per MSA block]:n:' \
  '--qsc=[minimum score threshold for MSA diversity]:val:' \
  '--max-accept=[maximum accepted alignments before stopping]:n:' \
  '--pair-mode=[multimer MSA pairing mode]:mode:' \
  '--pairing_strategy=[pairing strategy for pairaln]:strategy:' \
  '--db-load-mode=[database preload mode]:mode:(0 1 2 3)' \
  '--unpack=[unpack results to files or keep as databases]:val:(0 1)' \
  '--threads=[number of threads]:n:' \
  '--gpu=[use GPU]:val:(0 1)' \
  '--gpu-server=[use GPU server]:val:(0 1)' \
  '--af3-json[generate AlphaFold3 input JSON]' \
  '--af3-msa-as-path[save MSA as file path in JSON]' \
  '1:query fasta:_files' \
  '2:dbbase:_files -/' \
  '3:results dir:_files -/' && ret=0

return ret
