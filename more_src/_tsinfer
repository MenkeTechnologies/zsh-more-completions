#compdef tsinfer
# Documentation: https://tskit.dev/tsinfer/docs/stable/cli.html
# tsinfer: infer tree sequences from genetic variation data. Subcommands and global flags from the CLI reference.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-v --verbosity)'{-v,--verbosity}'[increase verbosity]' \
  '--log-section=[filter log messages by module]:section:(tsinfer.inference tsinfer.formats tsinfer.threads)' \
  '1:command:((
    infer\:"run the complete inference process"
    generate-ancestors\:"build ancestor data from samples"
    ga\:"alias for generate-ancestors"
    match-ancestors\:"match ancestors against each other"
    ma\:"alias for match-ancestors"
    augment-ancestors\:"augment ancestors with sample haplotypes"
    aa\:"alias for augment-ancestors"
    match-samples\:"match samples against the ancestors tree sequence"
    ms\:"alias for match-samples"
    list\:"print a summary of a tsinfer file"
    ls\:"alias for list"
    verify\:"check inferred tree sequence against the input"
  ))' \
  '*::arg:_files' && ret=0

return ret
