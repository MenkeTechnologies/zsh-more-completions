#compdef vtcode
# Documentation: https://github.com/vinhnx/vtcode
# Reference accessed: 2026-05-17
# Verified: vinhnx/vtcode README + clap. Note: full per-subcommand
# flag table is not published upstream; this completion covers the
# top-level surface only.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated _files arg handler.

# vtcode: open-source Rust coding agent
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'ask:query mode (output to stdout)'
  'dependencies:install optional dependencies'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vtcode command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (dependencies) _values 'subcommand' 'install' && ret=0 ;;
      (ask) _message 'prompt' && ret=0 ;;
    esac
    ;;
esac
return ret
