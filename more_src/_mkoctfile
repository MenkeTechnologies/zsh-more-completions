#compdef mkoctfile
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mkoctfile.1.html
# compile Octave dynamically loadable .oct and .mex files

local ret=1

_arguments -s -S \
  '(-h -? --help)'{-h,--help}'[print help message]' \
  '*-I+[add include directory to compile commands]:dir:_directories' \
  '*-idirafter+[add include directory after -I search path]:dir:_directories' \
  '*-D+[add definition to compiler command]:def' \
  '*-l+[add library to link command]:lib' \
  '*-L+[add library directory to link command]:dir:_directories' \
  '*-R+[pass -Rdir to link command]:dir:_directories' \
  '-g[enable debugging option for all compilers]' \
  '-pthread[add -pthread to link command]' \
  '*-W+[pass flags to the compiler]:flag' \
  '-M[generate dependency files (.d)]' \
  '--depend[generate dependency files (.d)]' \
  '-c[compile but do not link]' \
  '--link-stand-alone[link a stand-alone executable file]' \
  '-s[strip the output file]' \
  '--strip[strip the output file]' \
  '--mex[create a MEX file (default extension .mex)]' \
  '(-o --output)'{-o,--output}'[output filename]:file:_files' \
  '(-p --print)'{-p,--print}'[print configuration variable]:var' \
  '(-v --verbose)'{-v,--verbose}'[echo commands as they are executed]' \
  '*:source file:_files -g "*.(cc|cpp|c|f|f90|o)"' && ret=0

return ret
