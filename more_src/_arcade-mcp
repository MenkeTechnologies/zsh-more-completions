#compdef arcade-mcp
# Documentation: https://github.com/ArcadeAI/arcade-ai
# Reference accessed: 2026-05-23
# Verified: arcade CLI (see also _arcade).

# Zsh completion for arcade-mcp - Arcade AI tools MCP CLI package stem

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'arcade command' \
      'login[log in]' \
      'logout[log out]' \
      'whoami[login status]' \
      'new[create server package]' \
      'mcp[run MCP servers]' \
      'show[show tools]' \
      'evals[run evaluations]' \
      'configure[client settings]' \
      'connect[connect client]' \
      'deploy[deploy to Arcade Cloud]' \
      'update[check for updates]' \
      'upgrade[upgrade CLI]' \
      'dashboard[open dashboard]' \
      'org[manage organizations]' \
      'project[manage projects]' && ret=0
    ;;
  args)
    case $line[1] in
      new)
        _arguments \
          '--dir[tools directory]:directory:_directories' \
          '1:server name:' && ret=0
        ;;
      mcp)
        if (( CURRENT == 3 )); then
          _values 'mcp transport' stdio sse http && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
