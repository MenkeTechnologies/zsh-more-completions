#compdef opennextjs-cloudflare
# Documentation: https://opennext.js.org/cloudflare/cli
# opennextjs-cloudflare - adapter to deploy Next.js apps to Cloudflare

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--skipNextBuild[skip the Next.js build step]' \
  '--skipWranglerConfigCheck[skip wrangler config check]' \
  '--noMinify[disable minification]' \
  '--minify[enable minification]' \
  '--config=[wrangler config file]:file:_files' \
  '--env=[wrangler environment]:env' \
  '1:command:(build preview deploy upload populateCache migrate)' \
  '*::arg:_files' && ret=0

return ret
