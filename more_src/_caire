#
# WHAT IS disintegration/imaging AND WHY IS IT THE 77TH Go CLI LIBRARY?
#
# disintegration/imaging is the canonical pure-Go image-
# processing library.  Distinct from Go's stdlib `image`
# package (which is low-level pixel access) and from h2non/
# bimg (libvips C library bindings).  imaging wraps stdlib
# `image` with higher-level operations that match what most
# CLIs need (resize, crop, rotate, adjust).
#
# Five distinguishing characteristics from image-rs/image
# (R677):
#
#   1. STDLIB IMAGE PACKAGE WRAPPER — imaging builds on Go's
#      stdlib `image` types (image.Image, image.NRGBA,
#      image.RGBA, etc.).  Distinct from image-rs/image which
#      defines its own DynamicImage + ImageBuffer types.
#
#   2. 5 RESAMPLING FILTERS — NearestNeighbor, Box, Linear,
#      MitchellNetravali, Lanczos.  Different naming + slightly
#      different set than image-rs/image's 4 filters.
#
#   3. ANCHOR-BASED CROPPING — CropAnchor with 9-position
#      anchor enum (TopLeft / Top / TopRight / Left / Center
#      / Right / BottomLeft / Bottom / BottomRight).  Distinct
#      from image-rs/image's rectangle-based cropping.
#
#   4. ARBITRARY-ANGLE ROTATION via Rotate(img, degrees, fill).
#      Distinct from image-rs/image which only provides 90/
#      180/270 rotations in imageops (arbitrary requires
#      separate crate).
#
#   5. GRIGORY-DRYAPAK SOLO-MAINTAINED — distinct from image-rs
#      working group + David Tolnay + Sean McArthur + Sindre
#      Sorhus.  Solo maintenance since 2014.
#
# -----------------------------------------------------------------------------
#
# THE caire CLI — stdlib flag + disintegration/imaging + pigo + Gio
#
# caire's CLI is in cmd/caire/main.go.  Uses Go stdlib `flag`
# package (no cobra / urfave/cli; minimal binary).
#
# Source:
#     var (
#         source         = flag.String("in", pipeName, "Source")
#         destination    = flag.String("out", pipeName, "Destination")
#         blurRadius     = flag.Int("blur", 4, "Blur radius")
#         sobelThreshold = flag.Int("sobel", 2, "Sobel threshold")
#         newWidth       = flag.Int("width", 0, "New width")
#         newHeight      = flag.Int("height", 0, "New height")
#         percentage     = flag.Bool("perc", false, "...")
#         square         = flag.Bool("square", false, "...")
#         debug          = flag.Bool("debug", false, "Show seams")
#         shapeType      = flag.String("shape", "circle", "...")
#         seamColor      = flag.String("color", "#ff0000", "...")
#         preview        = flag.Bool("preview", true, "GUI")
#         maskPath       = flag.String("mask", "", "Retain mask")
#         rMaskPath      = flag.String("rmask", "", "Remove mask")
#         faceDetect     = flag.Bool("face", false, "Face detect")
#         faceAngle      = flag.Float64("angle", 0.0, "Face angle")
#         workers        = flag.Int("conc", runtime.NumCPU(), "...")
#     )
#
# Flags (Go stdlib flag uses single-dash but accepts double):
#   -in FILE          input file (use "-" for stdin; default "-")
#   -out FILE         output file (use "-" for stdout; default "-")
#   -blur N           Gaussian blur radius (default 4)
#   -sobel N          Sobel threshold (default 2)
#   -width N          target width (pixels or percentage if -perc)
#   -height N         target height (pixels or percentage if -perc)
#   -perc             interpret -width/-height as percentages
#   -square           reduce to square dimensions
#   -debug            show seam paths on output
#   -shape SHAPE      seam debug shape: circle | line
#   -color HEX        seam color (default #ff0000)
#   -preview          show real-time GUI preview (default true)
#   -mask FILE        retain-area mask (white = keep)
#   -rmask FILE       remove-area mask (white = remove)
#   -face             enable face detection protection
#   -angle DEG        face rotation tolerance angle
#   -conc N           parallel worker count (default NumCPU)
#
# disintegration/imaging is used throughout caire's image-I/O
# layer for loading source images, color-space conversions,
# and writing output images (final encoded JPEG/PNG).  The
# seam-carving algorithm itself is implemented directly in
# carver.go (operating on stdlib image.Image types).
#
# Five-axis distinctness from image-rs/image (R677):
#
#   1. STDLIB IMAGE WRAPPER — builds on Go's `image` package
#      vs image-rs/image's own DynamicImage type.
#
#   2. 5 RESAMPLING FILTERS — NearestNeighbor/Box/Linear/
#      MitchellNetravali/Lanczos.
#
#   3. ANCHOR-BASED CROPPING — 9-position anchor enum.
#
#   4. ARBITRARY-ANGLE ROTATION — Rotate(img, deg, fill).
#
#   5. GRIGORY-DRYAPAK SOLO-MAINTAINED — distinct ecosystem.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/esimov/caire/blob/master/cmd/caire/main.go
# Go stdlib flag.String / Int / Bool / Float64 definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-in=[input file (use "-" for stdin)]:file:_files -g "*.(jpg|jpeg|png|gif|bmp)"' \
    '-out=[output file (use "-" for stdout)]:file:_files' \
    '-blur=[Gaussian blur radius (default 4)]:radius:_default' \
    '-sobel=[Sobel filter threshold (default 2)]:threshold:_default' \
    '-width=[new width in pixels (or % if -perc)]:width:_default' \
    '-height=[new height in pixels (or % if -perc)]:height:_default' \
    '-perc[interpret -width/-height as percentages]' \
    '-square[reduce image to square dimensions]' \
    '-debug[show seam paths on output]' \
    '-shape=[seam debug shape]:shape:(circle line)' \
    '-color=[seam color (hex)]:color:_default' \
    '-preview[show real-time GUI preview]' \
    '-mask=[retain-area mask file (white pixels = keep)]:file:_files -g "*.(jpg|jpeg|png)"' \
    '-rmask=[remove-area mask file (white pixels = remove)]:file:_files -g "*.(jpg|jpeg|png)"' \
    '-face[enable face detection protection]' \
    '-angle=[face rotation tolerance angle]:degrees:_default' \
    '-conc=[parallel worker count (default NumCPU)]:workers:_default' \
    && ret=0

return ret
