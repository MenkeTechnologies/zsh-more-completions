# Zsh completion for create-md-computer - shadcn-themed Vite scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--pm=[package manager]:manager:(pnpm npm yarn bun)' \
  '--no-install[skip dependency installation]' \
  '--no-git[skip git init and initial commit]' \
  '--preset=[shadcn theme preset id]:preset:' \
  '--template=[base template id]:template:' \
  '--force[overwrite existing target directory]' \
  '--yes[skip prompts]' \
  ':project name:' && ret=0

return ret
