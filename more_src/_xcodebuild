#compdef xcodebuild

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'build:build the target'
  'build-for-testing:build for testing without running tests'
  'test:run tests'
  'test-without-building:run previously built tests'
  'archive:create an archive build'
  'analyze:run the static analyzer'
  'clean:remove build products and intermediate files'
  'install:install the build product'
  'installsrc:copy source to install location'
  'docbuild:build documentation'
)

_arguments -C \
  '(- *)-version[show version]' \
  '(- *)-usage[show usage]' \
  '(- *)-license[show license]' \
  '(- *)-help[show help]' \
  '-project=[project file]:file:_files -g "*.xcodeproj"' \
  '-target=[target name]:target:' \
  '-alltargets[build all targets]' \
  '-workspace=[workspace file]:file:_files -g "*.xcworkspace"' \
  '-scheme=[scheme name]:scheme:' \
  '-configuration=[build configuration]:config:(Debug Release)' \
  '-destination=[destination]:dest:' \
  '-destination-timeout=[destination timeout]:secs:' \
  '-xctestrun=[xctestrun file]:file:_files' \
  '-testPlan=[test plan]:plan:' \
  '*-skip-testing=[tests to skip]:test:' \
  '*-only-testing=[only run these tests]:test:' \
  '-enableCodeCoverage=[enable code coverage]:flag:(YES NO)' \
  '-testLanguage=[test language]:lang:' \
  '-testRegion=[test region]:region:' \
  '-parallel-testing-enabled=[parallel testing]:flag:(YES NO)' \
  '-test-iterations=[test iterations]:n:' \
  '-retry-tests-on-failure[retry tests on failure]' \
  '-enumerate-tests[enumerate tests]' \
  '-enableAddressSanitizer=[enable ASan]:flag:(YES NO)' \
  '-enableThreadSanitizer=[enable TSan]:flag:(YES NO)' \
  '-enableUndefinedBehaviorSanitizer=[enable UBSan]:flag:(YES NO)' \
  '-sdk=[SDK name]:sdk:' \
  '-arch=[architecture]:arch:(x86_64 arm64 arm64e i386)' \
  '-xcconfig=[xcconfig file]:file:_files -g "*.xcconfig"' \
  '-toolchain=[toolchain]:toolchain:' \
  '-derivedDataPath=[derived data path]:dir:_files -/' \
  '-resultBundlePath=[result bundle path]:path:_files' \
  '-archivePath=[archive path]:path:_files' \
  '-exportArchive[export an archive]' \
  '-exportOptionsPlist=[export options plist]:file:_files -g "*.plist"' \
  '-exportPath=[export path]:dir:_files -/' \
  '-exportNotarizedApp[export notarized app]' \
  '-exportLocalizations[export localizations]' \
  '-importLocalizations[import localizations]' \
  '-localizationPath=[localization path]:dir:_files -/' \
  '-list[list targets, configurations, schemes]' \
  '-showBuildSettings[show resolved build settings]' \
  '-showsdks[show installed SDKs]' \
  '-showdestinations[show valid destinations]' \
  '-showTestPlans[show test plans]' \
  '-allowProvisioningUpdates[allow provisioning updates]' \
  '-allowProvisioningDeviceRegistration[allow device registration]' \
  '-authenticationKeyPath=[App Store Connect key path]:file:_files' \
  '-authenticationKeyID=[App Store Connect key ID]:id:' \
  '-authenticationKeyIssuerID=[App Store Connect issuer ID]:id:' \
  '-quiet[quiet output]' \
  '-verbose[verbose output]' \
  '-downloadAllPlatforms[download all platforms]' \
  '1: :->action' \
  '*::arg:->args' && ret=0

case $state in
  (action)
    _describe -t actions 'xcodebuild action' actions && ret=0
    ;;
esac

return ret
