#compdef patscc patsopt patsstrip patsfilter
# Documentation: https://man.archlinux.org/search?q=patscc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (patsopt)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '--depgen[generate dependencies]' \
      '--taggen[generate tags]' \
      '-tc[typecheck only]' \
      '--typecheck[typecheck only]' \
      '-cc[compile to C]' \
      '-tcats[typecheck ATS file]:file:_files -g "*.cats"' \
      '-tcsats[typecheck SATS file]:file:_files -g "*.sats"' \
      '-tcdats[typecheck DATS file]:file:_files -g "*.dats"' \
      '-ccats[compile CATS file]:file:_files -g "*.cats"' \
      '-ccsats[compile SATS file]:file:_files -g "*.sats"' \
      '-ccdats[compile DATS file]:file:_files -g "*.dats"' \
      '-s+[SATS file]:file:_files -g "*.sats"' \
      '-d+[DATS file]:file:_files -g "*.dats"' \
      '-c+[CATS file]:file:_files -g "*.cats"' \
      '-o+[output file]:file:_files' \
      '-IATS+[search path for ATS]:dir:_files -/' \
      '-DATS+[define ATS macro]:macro:' \
      '--posix-regex[POSIX regex]' \
      '--gline[generate line directives]' \
      '--debug[debug output]' \
      '*: :_files -g "*.dats *.sats *.cats"' && ret=0 ;;
  (patscc|patsstrip|patsfilter)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '-tc[typecheck]' \
      '-tcats[typecheck CATS]:file:_files' \
      '-cleanaft[clean intermediates after]' \
      '-o+[output file]:file:_files' \
      '*-IATS+[search path]:dir:_files -/' \
      '*-DATS+[define]:macro:' \
      '*-I+[C include]:dir:_files -/' \
      '*-L+[C lib path]:dir:_files -/' \
      '*-l+[C lib]:lib:' \
      '*-D+[C define]:macro:' \
      '-O+[optimize]:lvl:(0 1 2 3 s)' \
      '-g[debug info]' \
      '--gline[line markers]' \
      '-DATS_MEMALLOC_LIBC[use libc malloc]' \
      '-DATS_MEMALLOC_GCBDW[use Boehm GC]' \
      '-atsccomp+[compiler]:cc:_command_names -e' \
      '-atslib+[lib]:lib:' \
      '*: :_files -g "*.dats *.sats *.cats *.c *.o"' && ret=0 ;;
esac

return ret
