#compdef mris_curvature_stats
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_curvature_stats
# FreeSurfer compute curvature statistics on a surface

local ret=1

_arguments -s -S \
  '-a[average the curvature N times]:numberOfAverages:' \
  '-f[surface used to calculate curvature (wm, pial)]:surf_name:' \
  '-g[calculate Gaussian and Mean curvatures]' \
  '-l[constrain statistics to region in label file]:labelFileName:_files' \
  '-n[normalize curvature values before computation]' \
  '-m[output min/max for processed curvature]' \
  '-o[output file stem]:outputFileStem:' \
  '-s[write statistics per summary condition]:summaryCondition:' \
  '--writeCurvatureFiles[toggle saving curvature files]' \
  '-c[scale curvature values with factor]:scaleFactor:' \
  '-d[min curvature for scaling range]:minCurvature:' \
  '-e[max curvature for scaling range]:maxCurvature:' \
  '--postScale[set post-scaling factor]:postScale:' \
  '-b[histogram bin size]:binSize:' \
  '-h[prepare histogram with N buckets]:numberOfBins:' \
  '-i[histogram start curvature]:binStartCurvature:' \
  '-j[histogram end curvature]:binEndCurvature:' \
  '-p[histogram bins as percentage]:numberOfBins:' \
  '--highPassFilter[rectified high-pass filter]:highPassFilter:' \
  '--highPassFilterGaussian[Gaussian high-pass filter]:highPassFilterGaussian:' \
  '--lowPassFilter[rectified low-pass filter]:lowPassFilter:' \
  '--lowPassFilterGaussian[Gaussian low-pass filter]:lowPassFilterGaussian:' \
  '-u[print usage]' \
  '-V[print version number]' \
  '-q[rigorous floating-point comparison maxUlps]:maxUlps:' \
  '-z[set curvature at vertex index to zero]:vertexIndex:' \
  '*:surface:_files' && ret=0

return ret
