#compdef gen-sqlddl gen-sqltables
# _gen-sqlddl — generate SQL DDL / SQLAlchemy bindings from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/sqltablegen.py (click).

_gen-sqlddl() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.sql"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(sql)'
        '--dialect=[SQL dialect]:dialect:(sqlite postgresql mysql mariadb oracle mssql)'
        '--sqla-file=[output path for SQLAlchemy-generated Python module]:file:_files -g "*.py"'
        '--relmodel-output=[output path for the intermediate relational-model schema]:file:_files'
        '--python-import=[Python import header inserted into generated SQLAlchemy code]:import:'
        '--use-foreign-keys[emit foreign-key constraints]'
        '--no-use-foreign-keys[omit foreign-key constraints]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-sqlddl "$@"
