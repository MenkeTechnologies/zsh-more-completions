#compdef zfm
# Documentation: https://github.com/pabloariasal/zfm/blob/master/README.md
# zfm - zsh fuzzy marks, bookmark manager built on top of fzf

local ret=1

_arguments -s -S \
  '--files[restrict to just files]' \
  '--dirs[restrict to just dirs]' \
  '--multi[allow selecting multiple items]' \
  '1:command:(list add select query edit fix clear)' \
  '*::arg:_files' && ret=0

return ret
