#compdef pslSomeRecords
# UCSC kent: extract multiple psl records

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-not[include psl if name is NOT in list]' \
  '-tToo[list file is two column qName and tName]' \
  ':psl in:_files' \
  ':list file:_files' \
  ':psl out:_files' && ret=0

return ret
