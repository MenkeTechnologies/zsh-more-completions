#compdef chkbit
# Documentation: https://laktak.github.io/chkbit/usage/
# Reference accessed: 2026-05-17
# Verified: upstream usage docs at the URL above (laktak/chkbit).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize directory tree (split or atom mode)'
  'add:create hashes and add files to the index'
  'update:add files and verify existing hashes'
  'check:verify files without updating the index'
  'dedup:detect and run file deduplication'
  'fuse:merge split indexes into an atom'
  'tips:show status codes and ignore syntax'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--workers=[number of worker threads (use 1 on spinning disks)]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'chkbit command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
