#compdef chkbit

# Zsh completion for chkbit
# Upstream: Check your files for data corruption
# Conservative fallback — run `chkbit --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
