#compdef oggz
# Documentation: https://man.archlinux.org/search?q=oggz
# Reference accessed: 2026-05-16

# Zsh completion for oggz (oggz-tools)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'oggz' chop comment dump info known-codecs merge sort validate && ret=0
    ;;
  args) _files -g "*.(ogg|ogv|opus)" && ret=0 ;;
esac

return ret
