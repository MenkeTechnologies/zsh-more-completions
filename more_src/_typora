#compdef typora Typora
# Documentation: https://man.archlinux.org/search?q=typora
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*: :_files -g "*.md *.markdown *.mdown *.mkd *.txt"' && ret=0

return ret
