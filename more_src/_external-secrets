#compdef external-secrets
# Documentation: https://external-secrets.io/latest/introduction/getting-started/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# external-secrets: External Secrets Operator (sync secrets from cloud secret managers)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'controller:run controller'
  'webhook:run webhook'
  'cert-controller:run cert controller'
  'completion:emit shell completion'
  'help:show help'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--metrics-addr=[metrics bind address]:addr:' \
  '--health-probe-bind-address=[health probe bind address]:addr:' \
  '--enable-leader-election[enable leader election]' \
  '--leader-election-namespace=[leader election namespace]:ns:' \
  '--namespace=[namespace]:ns:' \
  '--concurrent=[concurrent reconciles]:n:' \
  '--store-requeue-interval=[store requeue interval]:duration:' \
  '--secret-requeue-interval=[secret requeue interval]:duration:' \
  '--cluster-secret-store-requeue-interval=[cluster secret store requeue]:duration:' \
  '--enable-cluster-store-reconciler=[enable cluster store reconciler]:bool:(true false)' \
  '--enable-cluster-external-secret-reconciler=[enable cluster external secret reconciler]:bool:(true false)' \
  '--enable-push-secret-reconciler=[enable push secret reconciler]:bool:(true false)' \
  '--loglevel=[log level]:level:(debug info warn error fatal panic)' \
  '--zap-time-encoding=[zap time encoding]:enc:(epoch iso8601 millis nanos rfc3339 rfc3339nano)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'external-secrets command' commands && ret=0 ;;
esac
return ret
