#compdef chicken-profile
# Documentation: https://manpages.debian.org/testing/chicken-bin/chicken-profile.1.en.html
# CHICKEN Scheme profiling-data display utility

local ret=1

_arguments -s -S \
  '(-help)-help[show usage and exit]' \
  '(-version)-version[show version and exit]' \
  '-decimals[set number of decimals for seconds, average and percent columns]:digits (default 333):' \
  '-no-unused[remove procedures that are never called]' \
  '-sort-by-avg[sort output by average procedure execution time]' \
  '-sort-by-calls[sort output by call frequency]' \
  '-sort-by-name[sort output alphabetically by procedure name]' \
  '-sort-by-time[sort output by procedure execution time]' \
  '-top[display only the top N entries]:count:' \
  '*:profile file:_files' && ret=0

return ret
