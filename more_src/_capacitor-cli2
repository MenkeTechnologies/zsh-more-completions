#compdef capacitor-cli2
# _capacitor-cli2 — Drifty Co Capacitor capacitor-cli2 CLI command-line frontend wrapping the Capacitor CLI tool for the Capacitor cross-platform native runtime for web apps open-source written in TypeScript Node Drifty Co's runtime for Ionic Apps deploy modern web-based apps natively to iOS Android Web add copy sync build run open update doctor migrate config init plugin generate generators ls open serve telemetry export-pinia transition android-studio webview android-debug livereload ios-trust-cert (Drifty Co Capacitor team Max Lynch, TypeScript); commander
# upstream: https://capacitorjs.com/

_capacitor-cli2() {
    local -a sub=(
        'add:add a platform'
        'build:build native app'
        'completion:generate shell completion'
        'config:show config'
        'copy:copy web assets'
        'doctor:diagnose project'
        'help:show help'
        'init:initialize project'
        'ls:list platforms and plugins'
        'list:list installed platforms'
        'migrate:migrate to latest'
        'open:open native IDE'
        'plugin:plugin operations'
        'plugin:generate:scaffold a plugin'
        'run:run app on device'
        'serve:serve web build'
        'sync:copy + update'
        'telemetry:telemetry config'
        'update:update native deps'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--no-color[no color]' \
        '--non-interactive[non interactive]' \
        '--config=+[file]:file:_files -g "capacitor.config.* *.ts *.js *.json"' \
        '-c+[config]:file:_files -g "capacitor.config.* *.ts *.js *.json"' \
        '--encoding=+[enc]:str:' \
        '--deployment[deployment build]' \
        '--inline[inline source maps]' \
        '--prod[production mode]' \
        '--external[external host]' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--host=+[host]:_hosts' \
        '--scheme=+[name]:str:' \
        '--keystorepath=+[file]:_files' \
        '--keystorepass=+[password]:str:' \
        '--keystorealias=+[name]:str:' \
        '--keystorealiaspass=+[password]:str:' \
        '--no-sync[no sync]' \
        '--no-livereload[no livereload]' \
        '--live-reload[livereload]' \
        '-l[livereload]' \
        '--list[list targets]' \
        '--target=+[name]:str:' \
        '-t+[target]:str:' \
        '--platform=+[p]:p:(ios android web)' \
        '--no-build[no build]' \
        '--for-server[for server]' \
        '--release=+[v]:v:(true false)' \
        '--forwardPorts=+[list]:str:' \
        '--public-host=+[host]:_hosts' \
        '--package-id=+[id]:str:' \
        '--web-dir=+[dir]:dir:_files -/' \
        '--app-id=+[id]:str:' \
        '--app-name=+[name]:str:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--inline-sourcemaps[inline source maps]' \
        '--skip-appdir-check[skip appdir check]' \
        '--xcconfig=+[file]:_files' \
        '--simulator-platform=+[p]:p:(iOS tvOS watchOS)' \
        '--deeplink-host=+[host]:_hosts' \
        '--from=+[v]:str:' \
        '--to=+[v]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'capacitor subcommand' sub ;;
        args)
            case $words[1] in
                add|build|copy|sync|open|update|run) _arguments '1:platform:(ios android web)' '*:arg:' ;;
                plugin) _arguments '1:op:(generate)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_capacitor-cli2 "$@"
