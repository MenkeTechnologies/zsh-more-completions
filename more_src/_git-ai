#compdef git-ai
# Documentation: https://www.npmjs.com/package/git-ai-cli
# Reference accessed: 2026-05-23
# Verified: npx git-ai-cli --help.

# Zsh completion for git-ai - AI commit message generation (git-ai-cli)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'gen:generate a commit message from staged changes'
  'config:configure LLM model and credentials'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug[enable debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'git-ai command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (gen|config)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
