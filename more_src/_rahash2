#compdef rahash2
# Documentation: https://github.com/radareorg/radare2/blob/master/man/rahash2.1
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '-B[per-block hash]' \
  '-e[swap endian]' \
  '-h[show help]' \
  '-j[JSON output]' \
  '-J[simplified JSON]' \
  '-k[ssh randomkey]' \
  '-L[list muta plugins]' \
  '-q[quiet]' \
  '-qq[hash only]' \
  '-r[r2 commands output]' \
  '-R[sdb commands output]' \
  '-v[show version]' \
  '-X[hexpairs output]' \
  '-a=[algorithms]:algos:(md5 sha1 sha256 sha384 sha512 crc32 crc16 entropy md4 xor adler32 fletcher32 luhn)' \
  '-b=[block size]:n:' \
  '-c=[compare hash]:hash:' \
  '-D=[decrypt algo]:algo:(aes-ecb aes-cbc rc4 blowfish ror rol)' \
  '-E=[encrypt algo]:algo:(aes-ecb aes-cbc rc4 blowfish ror rol)' \
  '-f=[start address]:addr:' \
  '-i=[iterations]:n:' \
  '-I=[IV]:iv:' \
  '-s=[hash string]:str:' \
  '-S=[seed/key]:seed:' \
  '-t=[stop address]:addr:' \
  '-x=[hexstr]:hex:' \
  '*:file:_files'
