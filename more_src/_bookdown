#compdef bookdown
# _bookdown — Yihui Xie bookdown R package CLI for authoring books and long-form articles from R Markdown rendering to HTML PDF EPUB and Word with cross-references citations and figures (rstudio team, R); R argparse
# upstream: https://github.com/rstudio/bookdown

_bookdown() {
    local -a sub=(
        'render:render book'
        'render-book:render book'
        'preview:preview chapter'
        'preview-chapter:preview chapter'
        'serve:serve preview'
        'serve-book:serve preview'
        'clean:clean output'
        'clean-book:clean output'
        'publish:publish to bookdown.org'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bookdown subcommand' sub ;;
        args)
            case $words[1] in
                render|render-book) _arguments \
                    '--input=+[file]:file:_files -g "*.Rmd *.rmd *.md"' \
                    '--output-format=+[fmt]:f:(bookdown::gitbook bookdown::pdf_book bookdown::epub_book bookdown::word_document2 bookdown::html_document2 bookdown::pdf_document2 bookdown::tufte_html_book bookdown::tufte_book2 all)' \
                    '--output-dir=+[dir]:dir:_files -/' \
                    '--output-file=+[file]:file:_files' \
                    '--config-file=+[file]:file:_files -g "_bookdown.yml _output.yml"' \
                    '--clean-envir[clean envir]' \
                    '--encoding=+[enc]:e:(UTF-8 latin1 ASCII)' \
                    '--new-session[new session]' \
                    '--preview[preview]' \
                    '--envir=+[envir]:str:' \
                    '*:files:_files -g "*.Rmd *.rmd *.md"' ;;
                serve|serve-book) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' \
                    '--dir=+[dir]:dir:_files -/' \
                    '--daemon[daemonize]' \
                    '--in-session[in-session]' ;;
                publish) _arguments \
                    '--name=+[name]:str:' \
                    '--account=+[account]:str:' \
                    '--server=+[server]:str:' \
                    '--render=+[mode]:m:(none local server)' ;;
                clean|clean-book) _arguments \
                    '--clean-envir[clean envir]' \
                    '--config-file=+[file]:file:_files' ;;
            esac
            ;;
    esac
}

_bookdown "$@"
