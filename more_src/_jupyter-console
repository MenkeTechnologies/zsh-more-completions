#compdef jupyter-console
# Documentation: https://man.archlinux.org/search?q=jupyter-console
# Reference accessed: 2026-05-16

# jupyter-console: terminal-based Jupyter frontend
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--help-all[show all options]' \
  '--version[show version]' \
  '--no-confirm-exit[no confirm exit]' \
  '--simple-prompt[simple prompt (no prompt_toolkit)]' \
  '--existing=[connect to existing kernel]:conn_file:' \
  '--kernel=[kernel name]:name:' \
  '--ssh=[SSH server]:user@host:' \
  '--ip=[IP]:ip:' \
  '--transport=[transport]:transport:(tcp ipc)' \
  '--debug[debug]' \
  '--show-banner=[show banner]:val:(True False)' \
  '--logfile=[log file]:file:_files' \
  '--config=[config file]:file:_files -g "*.py"' \
  '*::jupyter-console args:_files' && ret=0
return ret
