#compdef ghwdump
# Documentation: https://verilator.org/guide/latest/
# Dump the contents of a GHDL GHW waveform file

local ret=1

_arguments -s -S \
  '-t[display types]' \
  '-h[display hierarchy]' \
  '-T[display time]' \
  '-s[display signals (and time)]' \
  '-l[display list of sections]' \
  '-v[verbose]' \
  '*:GHW file:_files -g "*.ghw"' && ret=0

return ret
