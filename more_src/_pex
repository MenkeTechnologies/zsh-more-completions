#compdef pex

# Zsh completion for PEX (Python EXecutable builder)

_pex() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-o+[output PEX file]:output file:_files -g "*.pex"' \
    '--output-file=[output PEX file]:output file:_files -g "*.pex"' \
    '-p+[package to include]:package:' \
    '--package=[package to include]:package:' \
    '-r+[requirements file]:requirements file:_files -g "*.txt"' \
    '--requirement=[requirements file]:requirements file:_files -g "*.txt"' \
    '-c+[script console_scripts entry point]:entry point:' \
    '--script=[script console_scripts entry point]:entry point:' \
    '-m+[module entry point]:module:' \
    '--entry-point=[module entry point]:module:' \
    '-e+[module entry point]:module:' \
    '--exe=[module entry point]:module:' \
    '-D+[sources directory]:sources directory:_files -/' \
    '--sources-directory=[sources directory]:sources directory:_files -/' \
    '-R+[resources directory]:resources directory:_files -/' \
    '--resources-directory=[resources directory]:resources directory:_files -/' \
    '--python=[python interpreter]:interpreter:_files' \
    '--python-path=[colon-separated Python interpreter paths]:paths:' \
    '--interpreter-constraint=[constrain the selected interpreter]:constraint:' \
    '--platform=[target platform]:platform:' \
    '--complete-platform=[complete platform JSON file]:file:_files -g "*.json"' \
    '-f+[find links directory]:directory:_files -/' \
    '--find-links=[find links directory]:directory:_files -/' \
    '-i+[Python package index URL]:URL:' \
    '--index-url=[Python package index URL]:URL:' \
    '--extra-index-url=[extra package index URL]:URL:' \
    '--no-index[ignore package index]' \
    '--pre[include pre-release versions]' \
    '--no-pre[exclude pre-release versions]' \
    '--wheel[allow building wheels]' \
    '--no-wheel[do not allow building wheels]' \
    '--build[allow building source distributions]' \
    '--no-build[do not allow building source distributions]' \
    '--transitive[include transitive dependencies]' \
    '--no-transitive[do not include transitive dependencies]' \
    '--compile[compile .py files to .pyc]' \
    '--no-compile[do not compile .py files]' \
    '--use-system-time[use current system time in PEX]' \
    '--inherit-path=[inherit sys.path]:mode:(false fallback prefer)' \
    '--include-tools[include PEX tools in the PEX]' \
    '--zip-safe[mark PEX as zip-safe]' \
    '--not-zip-safe[mark PEX as not zip-safe]' \
    '--unzip[unzip PEX before running]' \
    '--venv[run PEX in venv mode]' \
    '--venv-copies[use copies instead of symlinks in venv]' \
    '--always-write-cache[always write to PEX cache]' \
    '--ignore-errors[ignore errors resolving distributions]' \
    '--seed=[seed the PEX]:mode:(none verbose)' \
    '--resolver-version=[resolver version]:version:(pip-2020-resolver pip-legacy-resolver)' \
    '--pip-version=[pip version]:version:' \
    '--pex-path=[additional PEX files to merge]:PEX files:_files -g "*.pex"' \
    '--runtime-pex-root=[set PEX_ROOT at runtime]:directory:_files -/' \
    '--strip-pex-env[strip PEX env vars before executing]' \
    '--no-strip-pex-env[do not strip PEX env vars]' \
    '-v[increase verbosity]' \
    '--verbose[increase verbosity]' \
    '-q[decrease verbosity]' \
    '--quiet[decrease verbosity]' \
    '--tmpdir=[set temp directory]:directory:_files -/' \
    '--pex-root=[set PEX root directory]:directory:_files -/' \
    '--disable-cache[disable caching]' \
    '--cache-dir=[set cache directory]:directory:_files -/' \
    '--cache-ttl=[cache time to live]:seconds:' \
    '--rc-file=[PEX runtime config]:config file:_files' \
    '--no-rc-file[do not use PEX runtime config]' \
    '--help[display help]' \
    '--version[print version]' \
    '*:requirements or packages:_files' \
    && ret=0

  return ret
}

_pex "$@"
