#compdef ethers
# Documentation: https://docs.ethers.org/v5/cli/ethers/
# ethers - ethers.js command-line tools to manage and debug Ethereum tasks

local ret=1

_arguments -s -S \
  '--help[show usage and exit]' \
  '--version[show version and exit]' \
  '*--account=[load account from file, key or mnemonic]:account:_files' \
  '*--account-void=[use an address or ENS name as a void signer]:address:' \
  '*--account-rpc=[add address or index from a JSON-RPC provider]:address:' \
  '--mnemonic-password[prompt for a password for mnemonics]' \
  '--xxx-mnemonic-password[prompt for an experimental hard password]' \
  '--alchemy[include Alchemy]' \
  '--etherscan[include Etherscan]' \
  '--infura[include INFURA]' \
  '--nodesmith[include nodesmith]' \
  '--rpc=[include a custom JSON-RPC]:url:' \
  '--offline[dump signed transactions without sending]' \
  '--network=[network to connect to]:network:' \
  '--gasPrice=[default gas price in wei]:gwei:' \
  '--gasLimit=[default gas limit for transactions]:gas:' \
  '--nonce=[initial nonce for the first transaction]:nonce:' \
  '--yes[always accept signing and sending]' \
  '--wait[wait until transactions are mined]' \
  '--debug[show stack traces for errors]' \
  '1:command:(sandbox init fund info send sweep sign-message eval run wait wrap-ether unwrap-ether send-token compile deploy)' \
  '*::args:_default' && ret=0

return ret
