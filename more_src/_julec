#compdef julec
# ============================================================================
# _julec — zsh completion for the Jule programming language compiler
#           driver — Jule is "simple and safe with first-class C/C++
#           interoperability" (164th programming language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/julelang/jule
#   Maintainer : The Jule Project Contributors (julelang)
#   License    : BSD-3-Clause
#   Stars      : 414
#   Language   : C++ (self-hosted — julec compiles Jule via Jule;
#                bootstrap stage is C++ for cross-compilation)
#   Module     : github.com/julelang/jule
#   Binary     : julec  (src/julec/main.jule entry point)
#   Source ext : .jule
#   Test ext   : *_test.jule
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   Jule is "a simple and safe programming language with first-class
#   C/C++ interoperability and powerful standard library" — a
#   statically typed, compiled language whose driver `julec` flows
#   Jule source through its own front-end and emits C++ IR that is
#   then compiled by Clang (default) or GCC.  The language supports
#   coroutines via a configurable `COMAXPROCS` scheduler, native
#   cross-target compilation with `<os>-<arch>` selectors
#   (`darwin-arm64`, `linux-amd64`, etc.), three optimization levels
#   (L0/L1/L2), and a module system (`jule.mod`) initialized by
#   `julec mod init`.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/julec/main.jule
#                       `HelpMap`, `processCommand`, and per-command
#                       help strings — julec uses a hand-rolled
#                       command dispatcher, not a third-party
#                       arg parser)
#   julec <SUBCOMMAND> [arguments...]
#
#   Subcommands:
#     help [<COMMAND>]              Show general help or per-command
#                                   info
#
#     build [arguments] <PATH>      Compile the main package at PATH
#     test [arguments] <PATH>       Compile a test program at PATH
#                                   (includes *_test.jule files,
#                                   implicit test entry point)
#       -t, --tranpile                Transpile-only (IR, no object)
#                                     (sic — upstream spelling
#                                     "tranpile")
#       -o, --out <PATH>              Output executable path
#                                     [default: main (.exe on
#                                     Windows)]
#       -p, --production              Production build (slower
#                                     compile, faster runtime)
#       --opt <LEVEL>                 Optimization level (L0|L1|L2)
#                                     [default: L0]
#       --compiler <BACKEND>          Back-end compiler (clang|gcc)
#                                     [default: clang]
#       --compiler-path <PATH>        Back-end compiler binary path
#                                     [default: clang++ for clang,
#                                     g++ for gcc]
#       --target <OS-ARCH>            Cross-target IR generation
#                                     selector (e.g.
#                                     darwin-arm64,
#                                     linux-amd64,
#                                     native-native)
#                                     [default: native-native]
#       --COMAXPROCS <N|default>      Max P-count for coroutine
#                                     scheduler
#
#     version                       Show julec, stdlib, API version
#
#     tool [<NAME>]                 Auxiliary tools dispatcher
#       julec tool targets            List supported <os-arch> pairs
#       julec tool distos             List supported OSes
#                                     (windows linux darwin)
#       julec tool distarch           List supported architectures
#                                     (amd64 i386 arm64)
#
#     env                           Print julec env (version, arch,
#                                   OS, default compiler, default
#                                   C++ standard)
#
#     mod <SUBCOMMAND>              Module management
#       julec mod init <NAME>         Initialize a new module
#                                     (writes jule.mod;  NAME must
#                                     match Jule identifier rules;
#                                     "std" is reserved)
#
# LANGUAGE-CORPUS POSITION
#   Jule is the 164th programming language entry in this completion
#   corpus, completing the 3+1 micro-cycle that began at R925
#   (_xlinectl / Xline-kv Rust=139 OPENS Axis 84 gRPC Framework
#   Library) and continued through R926 (_gripmock / bavix Go=139)
#   and R927 (_xucli / ExchangeUnion TS-Node=139 CLOSES Axis 84 at
#   1/1/1 three-language symmetry — triple-139 landmark and 77th
#   axis closed).  Jule joins Nevalang (R924 163rd), Corvid (R920
#   162nd — round-number R920 commit landmark), Soppo (R916 161st),
#   Cyrus (R912 160th — round-number language milestone), Lumina
#   (R908 159th), Penne (R904 158th), EndBASIC (R900 157th — R900
#   TRIPLE-9 commit landmark), goboscript (R896 156th), Alan (R892
#   155th), Mech (R888 154th — triple-8 landmark), Lisette (R884
#   153rd), Bril (R880 152nd), Vyxal (R876 151st), EYG (R872 150th —
#   round-number language milestone), Roto (R868 149th), Pipefish
#   (R864 148th), Mochi (R860 147th), Oden (R856 146th), Hop (R852
#   145th), Lustre via Kind 2 (R848 144th), Ravi (R844 143rd),
#   ZetZ (R840 142nd), Granule (R836 141st), Sixten (R832 140th),
#   Imba (R828 139th), Tao (R824 138th), Dada (R820 137th), Acton
#   (R816 136th), and Stanza (R812 135th).
#
#   No completion for `julec` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_julec() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '1: :_julec_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                help)
                    _arguments \
                        ':command:(help build test version tool env mod)' && ret=0 ;;
                build|test)
                    _arguments \
                        '(-t --tranpile)'{-t,--tranpile}'[transpile only (IR, no object file)]' \
                        '(-o --out)'{-o,--out}'=[output executable path]:out:_files' \
                        '(-p --production)'{-p,--production}'[production build]' \
                        '--opt=[optimization level]:level:(L0 L1 L2)' \
                        '--compiler=[back-end compiler]:backend:(clang gcc)' \
                        '--compiler-path=[back-end compiler binary path]:path:_files' \
                        '--target=[cross-target OS-ARCH selector]:target:(native-native darwin-amd64 darwin-arm64 linux-amd64 linux-arm64 linux-i386 windows-amd64 windows-arm64 windows-i386)' \
                        '--COMAXPROCS=[max P-count for coroutine scheduler]:n:' \
                        ':main package:_files -g "*.jule" -/' && ret=0 ;;
                version|env)
                    _arguments && ret=0 ;;
                tool)
                    _arguments \
                        ':tool:(targets distos distarch)' && ret=0 ;;
                mod)
                    _arguments \
                        '1:mod subcommand:(init)' \
                        '*:module name:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_julec_commands] )) ||
_julec_commands() {
    local -a commands
    commands=(
        'help:show information about julec tool and commands'
        'build:compile a Jule program'
        'test:compile a Jule test program'
        'version:show julec, stdlib, and API version'
        'tool:auxiliary tools (targets/distos/distarch)'
        'env:print julec environment information'
        'mod:module management (init)'
    )
    _describe -t commands 'julec command' commands
}

_julec "$@"
