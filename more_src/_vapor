#compdef vapor

_vapor_commands() {
    local -a commands
    commands=(
        'new:Generate a new Vapor project'
        'build:Build the current project'
        'run:Run the current project'
        'clean:Clean the build artifacts'
        'test:Run tests'
        'xcode:Generate an Xcode project'
        'heroku:Commands for deploying to Heroku'
        'supervisor:Commands for configuring Supervisor'
    )
    _describe -t commands 'vapor command' commands
}

_vapor() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '--verbose[Increase verbosity of informational output]' \
        '1:command:_vapor_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                new)
                    _arguments \
                        '(-n --name)'{-n,--name}'[Name of the project]:name:' \
                        '--template[Template to use]:template:' \
                        '--branch[Template branch to use]:branch:' \
                        '--no-commit[Do not create an initial commit]' \
                        '(-o --output)'{-o,--output}'[Output directory]:dir:_directories'
                    ;;
                build)
                    _arguments \
                        '--clean[Clean before building]' \
                        '(-c --configuration)'{-c,--configuration}'[Build configuration]:config:(debug release)' \
                        '--verbose[Show build output]'
                    ;;
                run)
                    _arguments \
                        '(-c --configuration)'{-c,--configuration}'[Build configuration]:config:(debug release)' \
                        '--hostname[Set the hostname]:hostname:_hosts' \
                        '--port[Set the port]:port:' \
                        '--bind[Convenience for hostname\:port]:bind:' \
                        '--env[Set the environment]:env:(production development testing)' \
                        '--log[Set the log level]:level:(trace debug info notice warning error critical)'
                    ;;
                test)
                    _arguments \
                        '--verbose[Show test output]'
                    ;;
                heroku)
                    _arguments \
                        '1:action:(init push)' \
                        '--app[Heroku app name]:app:'
                    ;;
            esac
            ;;
    esac
}

_vapor "$@"
