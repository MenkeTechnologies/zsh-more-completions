#compdef valet
# Documentation: https://laravel.com/docs/12.x/valet
# Laravel Valet - minimal macOS development environment for PHP/Laravel sites

local ret=1

local -a cmds
cmds=(
  'install:Install and configure Valet services'
  'status:Check Valet service health'
  'tld:Get or set the top-level domain'
  'loopback:Get or set the loopback address'
  'trust:Add Brew and Valet to the sudoers file'
  'on-latest-version:Check whether on the latest Valet version'
  'latest:Check whether on the latest Valet version'
  'directory-listing:Enable or disable directory listing'
  'uninstall:Uninstall Valet services'
  'park:Register the current working directory'
  'parked:List all parked paths'
  'forget:Remove the current directory from parked paths'
  'unpark:Remove the current directory from parked paths'
  'link:Link the current directory to a named site'
  'links:List all linked sites'
  'unlink:Remove a symbolic link'
  'which:Determine the driver for the current directory'
  'paths:List all registered paths'
  'open:Open the site in the browser'
  'secure:Secure a site with a TLS certificate'
  'unsecure:Stop serving a site over TLS'
  'secured:List all secured sites'
  'renew:Renew all TLS certificates'
  'proxy:Create an Nginx proxy for a site'
  'unproxy:Remove an Nginx proxy'
  'proxies:List all proxies'
  'share:Generate a publicly accessible URL for a site'
  'share-tool:Get or set the share tool'
  'fetch-share-url:Get the public URL of a shared tunnel'
  'set-ngrok-token:Set the ngrok auth token'
  'start:Start the Valet services'
  'restart:Restart the Valet services'
  'stop:Stop the Valet services'
  'use:Change the global PHP version'
  'isolate:Set the PHP version for the current site'
  'unisolate:Remove the isolated PHP version'
  'isolated:List all isolated sites'
  'which-php:Show the PHP executable for the current site'
  'php:Proxy PHP commands with the site PHP version'
  'composer:Proxy Composer commands with the site PHP version'
  'log:Tail Valet service logs'
  'diagnose:Output diagnostics for support'
)

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds) _describe -t commands 'valet command' cmds && ret=0 ;;
  args) _files && ret=0 ;;
esac

return ret
