#compdef kode-acp
# Documentation: https://github.com/shareAI-lab/kode
# Reference accessed: 2026-05-22
# Verified: package.json bin kode-acp and cli-acp.js wrapper.

# Zsh completion for kode-acp - Kode ACP protocol entrypoint

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:args:' && ret=0

return ret
