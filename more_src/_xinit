#compdef xinit
# _xinit — X11 xinit (low-level X startup: launches an X server then a client, joined by --; the more user-friendly startx wraps it; -- separates client args from server args)
# upstream: https://gitlab.freedesktop.org/xorg/app/xinit
# Argument shape from xinit.man on tip.

_xinit() {
    _arguments \
        '*::client+server:_files'
}

_xinit "$@"
