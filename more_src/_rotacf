#compdef rotacf gmx-rotacf
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-rotacf.html
# gmx rotacf: calculate the rotational correlation function for molecules

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-n[index file]:file:_files' \
  '-o[xvgr/xmgr file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[use frame when t MOD dt = first time]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-d[use index doublets for vectors instead of triplets]' \
  '-aver[average over molecules]' \
  '-acflen[length of ACF]:int:' \
  '-normalize[normalize ACF]' \
  '-P[order of Legendre polynomial]:order:(0 1 2 3)' \
  '-fitfn[fit function]:fn:(none exp aexp exp_exp exp5 exp7 exp9)' \
  '-beginfit[time to begin exponential fit]:real:' \
  '-endfit[time to end exponential fit]:real:' && ret=0

return ret
