#compdef webalizer
# Documentation: https://man.archlinux.org/search?q=webalizer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-c+[config file]:file:_files' \
  '-d[debug mode]' \
  '-F+[log format]:fmt:(clf ftp squid w3c)' \
  '-i[ignore history file]' \
  '-p[preserve state]' \
  '-q[quiet]' \
  '-Q[really quiet]' \
  '-v[verbose]' \
  '-n+[hostname]:host:' \
  '-N+[max DNS children]:n:' \
  '-l+[max log file lines]:n:' \
  '-o+[output directory]:dir:_files -/' \
  '-r+[hide referrer pattern]:pattern:' \
  '-s+[hide site pattern]:pattern:' \
  '-u+[hide URL pattern]:pattern:' \
  '-a+[hide agent pattern]:pattern:' \
  '-x+[output filename extension]:ext:' \
  '-D+[DNS cache file]:file:_files' \
  '-t+[report title]:title:' \
  '-T[time output (deprecated)]' \
  '-A+[max user agents]:n:' \
  '-C+[max country dimensions]:n:' \
  '-R+[max referrers]:n:' \
  '-S+[max sites]:n:' \
  '-U+[max URLs]:n:' \
  '-e+[max entry pages]:n:' \
  '-E+[max exit pages]:n:' \
  '-X[hide individual users]' \
  '-Z+[zip code (db file)]:file:_files' \
  '-Y[geolocate]' \
  '-G[disable graphs]' \
  '-H[disable history]' \
  '-I[disable index]' \
  '-K[keep min number of months]' \
  '-M+[max search keywords]:n:' \
  '-m[disable monthly]' \
  '-b[batch mode]' \
  '-B[backups - keep N]' \
  '-f+[search filter]:filter:' \
  '-g[group output]' \
  '-j[junk output]' \
  '-w[ignore window]' \
  '*:logfile:_files' && ret=0

return ret
