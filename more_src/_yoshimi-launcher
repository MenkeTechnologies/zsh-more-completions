#compdef yoshimi-launcher
# Documentation: https://man.archlinux.org/search?q=yoshimi-launcher
# Reference accessed: 2026-05-16

# yoshimi-launcher: yoshimi synth launcher with JACK/ALSA preset
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '*::yoshimi-launcher args:_files' && ret=0
return ret
