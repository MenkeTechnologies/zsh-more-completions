#compdef lektor

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:compile project into final output'
  'clean:remove build folder'
  'content-file-info:display info for lektor files'
  'deploy:publish website'
  'dev:development-related commands'
  'plugins:plugin management'
  'project-info:output details about project'
  'quickstart:create new empty project'
  'server:run local development server'
)

_arguments -C \
  '--project=[project path]:path:_files -/' \
  '--language=[UI language]:lang:(ca de en es fr it ja ko nl pl pt ru zh)' \
  '(- *)--version[show version]' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'lektor subcommand' subcommands && ret=0
    ;;
esac

return ret
