#compdef shell-genie
# Documentation: https://man.archlinux.org/search?q=shell-genie
# Reference accessed: 2026-05-16

_shell_genie() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '--version[Show the version and exit]'
        '--help[Show the help message and exit]'
    )

    subcmds=(
        'init:Initialize the tool and choose a backend'
        'ask:Ask for a shell command based on natural language'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'shell-genie commands' subcmds
            ;;
        args)
            case $line[1] in
                ask)
                    _arguments \
                        '--explain[Provide a detailed breakdown of the generated command]' \
                        '1:prompt:'
                    ;;
            esac
            ;;
    esac
}

_shell_genie "$@"
