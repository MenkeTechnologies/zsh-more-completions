#compdef netcoredbg
# Documentation: https://github.com/Samsung/netcoredbg/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for netcoredbg (.NET debugger with DAP/MI support)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(- *)--buildinfo[show build information]' \
  '--interpreter=[protocol mode]:protocol:(cli mi vscode)' \
  '--server=[listen on TCP port (default 4711)]:port:' \
  '--engineLogging=[log engine activity (vscode interpreter only)]:log file:_files' \
  '--attach=[attach to running process by PID]:pid:_pids' \
  '--run[run program without waiting for commands]' \
  '--command=[interpret commands file at start]:file:_files' \
  '-ex[command to run at startup]:command:' \
  '--log=[enable logging]:type:(file dlog)' \
  '*:program:_files' && ret=0

return ret
