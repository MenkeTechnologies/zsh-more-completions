#compdef netcoredbg

# Zsh completion for netcoredbg (.NET debugger with DAP/MI support)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--interpreter=[protocol mode]:protocol:(cli mi vscode)' \
  '--server=[run as TCP server on port]:port:' \
  '--engineLogging=[log file path]:log file:_files' \
  '--attach=[attach to running process by PID]:pid:_pids' \
  '--run=[run program and attach debugger]:program:_files' \
  '--pipe=[use named pipe]:pipe name:' \
  '--log=[log level]:level:(none error warning info)' \
  '*:program:_files' && ret=0

return ret
