#compdef mri_surf2surf
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_surf2surf
# mri_surf2surf - resample data from one surface onto another

local ret=1

_arguments -s -S \
  '--srcsubject[source subject name]:subject:' \
  '--srcsurfval[source surface data file]:file:_files' \
  '--trgsubject[target subject name]:subject:' \
  '--trgsurfval[target surface output file]:file:_files' \
  '--hemi[hemisphere (lh or rh)]:hemi:(lh rh)' \
  '--src_type[input file format type]:type:' \
  '--trg_type[output file format type]:type:' \
  '--trgicoorder[icosahedron order number]:order:' \
  '--surfreg[registration surface (default sphere.reg)]:surf:' \
  '--mapmethod[mapping method (nnfr or nnf)]:method:(nnfr nnf)' \
  '--nsmooth-in[input surface smoothing iterations]:n:' \
  '--nsmooth-out[output surface smoothing iterations]:n:' \
  '--smooth[smoothing iterations]:n:' \
  '--frame[frame number for paint/w output]:n:' \
  '--noreshape[disable output reshaping]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
