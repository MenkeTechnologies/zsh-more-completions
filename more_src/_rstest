#compdef rstest
# Documentation: https://rstest.rs
# Source: https://github.com/web-infra-dev/rstest/blob/main/packages/core/src/cli/commands.ts
# Reference accessed: 2026-06-01
# Rsbuild/Rspack-based testing framework, Jest-compatible API.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _rt_cmds
_rt_cmds=(
    'run:run tests once (default)'
    'watch:run tests in watch mode'
    'list:list discovered tests'
    'init:initialize an rstest config in the current project'
    'merge-reports:merge blob coverage reports from sharded runs'
)

# Runtime flags shared by run/watch/list (subset; full list at upstream commands.ts)
local _rt_runtime=(
    '(-c --config)'{-c+,--config=}'[config file path]:file:_files'
    '--config-loader=[config loader]:loader:(auto jiti native)'
    '(-r --root)'{-r+,--root=}'[project root directory]:dir:_files -/'
    '--related[treat positional args as source paths; run only related tests]'
    '--findRelatedTests[alias for --related (Jest compat)]'
    '--changed=[run tests for files changed since commit]:commit:_default'
    '--globals[provide global APIs]'
    '--isolate[run tests in isolated environment]'
    '--include=[match test files]:glob:_default'
    '--exclude=[exclude files from test]:glob:_default'
    '(-u --update)'{-u,--update}'[update snapshot files]'
    '--coverage[enable code coverage collection]'
    '--coverage.provider=[coverage provider]:provider:(istanbul v8)'
    '*--coverage.reporters=[coverage reporter (repeatable)]:reporter:_default'
    '--coverage.changed=[coverage only for files changed since commit]:commit:_default'
    '--coverage.include=[coverage include pattern]:glob:_default'
    '--coverage.exclude=[coverage exclude pattern]:glob:_default'
    '--coverage.reportsDirectory=[coverage report dir]:dir:_files -/'
    '--coverage.reportOnFailure[generate reports even when tests fail]'
    '--coverage.clean[clean coverage dir before running]'
    '--coverage.allowExternal[cover files outside project root]'
    '--project=[run only matching projects]:name:_default'
    '--passWithNoTests[allow pass when no tests found]'
    '--silent=[silence console (true/false/passed-only)]:mode:(true false passed-only)'
    '--printConsoleTrace[print console traces]'
    '--disableConsoleIntercept[disable console intercept]'
    '--logHeapUsage[log heap usage after each test]'
    '--detectAsyncLeaks[detect async leaks]'
    '--trace[dump Perfetto-compatible performance trace]'
    '--slowTestThreshold=[ms threshold for slow tests]:ms:_default'
    '--reporters=[reporter(s)]:reporter:_default'
    '--reporter=[reporter(s) (alias)]:reporter:_default'
    '(-t --testNamePattern)'{-t+,--testNamePattern=}'[regex match for test names]:regex:_default'
    '--testEnvironment=[test environment]:env:_default'
    '--testTimeout=[test timeout ms]:ms:_default'
    '--hookTimeout=[hook timeout ms]:ms:_default'
    '--hideSkippedTests[hide skipped tests]'
    '--hideSkippedTestFiles[hide skipped test files]'
    '--retry=[retry count on failure]:n:_default'
    '--bail=[stop after n failures]:n:_default'
    '--shard=[index/count]:shard:_default'
    '--maxConcurrency=[max concurrent tests]:n:_default'
    '--clearMocks[clear mocks before each test]'
    '--resetMocks[reset mock state before each test]'
    '--restoreMocks[restore mocks before each test]'
    '--browser[run tests in browser mode]'
    '--browser.name=[browser]:browser:(chromium firefox webkit)'
    '--browser.headless[headless mode]'
    '--browser.port=[browser dev server port]:port:_default'
    '--browser.strictPort[exit if port in use]'
    '--unstubGlobals[restore stubGlobal before each test]'
    '--unstubEnvs[restore stubEnv before each test]'
    '--includeTaskLocation[collect test/suite locations]'
    '--pool=[shorthand for --pool.type]:type:(forks threads)'
    '--pool.type=[test pool type]:type:(forks threads)'
    '--pool.maxWorkers=[max workers (count or %)]:n:_default'
    '--pool.minWorkers=[min workers (count or %)]:n:_default'
    '*--pool.execArgv=[Node.js execArgv for workers]:arg:_default'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'rstest command' _rt_cmds && ret=0
        ;;
    args)
        case $line[1] in
            run|watch)
                _arguments -s -S $_rt_runtime '*:test files:_default' && ret=0
                ;;
            list)
                _arguments -s -S $_rt_runtime \
                    '--filesOnly[only list test files]' \
                    '--json=[print JSON or write to file]:path:_files' \
                    '--includeSuites[include suites]' \
                    '--printLocation[print test case location]' \
                    '--summary[print summary]' \
                    '*:test files:_default' && ret=0
                ;;
            merge-reports)
                _arguments -s -S \
                    '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
                    '--config-loader=[config loader]:loader:(auto jiti native)' \
                    '(-r --root)'{-r+,--root=}'[project root]:dir:_files -/' \
                    '--coverage[enable coverage collection]' \
                    '--reporters=[reporter]:reporter:_default' \
                    '--cleanup[remove blob reports dir after merging]' && ret=0
                ;;
            init)
                ret=0
                ;;
        esac
        ;;
esac

return ret
