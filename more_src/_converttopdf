#compdef converttopdf
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input directory:_files -/' \
  '2::substring (omit to bundle all files):' \
  '3:output PDF:_files -g "*.pdf"' && ret=0

return ret
