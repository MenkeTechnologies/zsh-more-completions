#compdef converttopdf
# Documentation: https://man.archlinux.org/search?q=converttopdf
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input directory:_files -/' \
  '2::substring (omit to bundle all files):' \
  '3:output PDF:_files -g "*.pdf"' && ret=0

return ret
