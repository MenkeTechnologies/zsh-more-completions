#compdef hcl2json
# Documentation: https://man.archlinux.org/search?q=hcl2json
# Reference accessed: 2026-05-16

# Zsh completion for hcl2json - HCL to JSON converter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--reverse[convert JSON to HCL]' \
  '--simplify[simplify JSON output]' \
  '*:HCL file:_files -g "*.{hcl,tf}"'
