#compdef hcl2json
# Documentation: https://github.com/tmccombs/hcl2json
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for hcl2json - HCL to JSON converter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--reverse[convert JSON to HCL]' \
  '--simplify[simplify JSON output]' \
  '*:HCL file:_files -g "*.{hcl,tf}"'
