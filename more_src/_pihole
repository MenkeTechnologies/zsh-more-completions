#compdef pihole

# Zsh completion for pihole (Pi-hole DNS sinkhole CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'status:Display Pi-hole status'
      'enable:Enable Pi-hole blocking'
      'disable:Disable Pi-hole blocking'
      'restartdns:Restart Pi-hole DNS service'
      'logging:Configure query logging'
      'flush:Flush the Pi-hole log'
      'arpflush:Flush the network table'
      'updatePihole:Update Pi-hole subsystems'
      'reconfigure:Reconfigure or repair Pi-hole'
      'uninstall:Uninstall Pi-hole'
      'version:Show version information'
      'checkout:Switch Pi-hole branch'
      'chronometer:Real-time stats display'
      'query:Search adlists for a domain'
      'updateGravity:Update gravity list (block lists)'
      '-w:Whitelist a domain'
      'whitelist:Whitelist a domain'
      '-b:Blacklist a domain'
      'blacklist:Blacklist a domain'
      '--wild:Wildcard blacklist a domain'
      '--regex:Regex blacklist a domain'
      '-t:Tail the Pi-hole log in real time'
      'tail:Tail the Pi-hole log in real time'
      '-a:Admin console commands'
      'admin:Admin console commands'
      '-c:Display real-time stats'
      '-g:Update gravity'
      '-q:Query adlists'
      '-l:Control logging'
      '-up:Update Pi-hole'
      '-r:Reconfigure or repair'
      '-h:Show help'
      'help:Show help'
    )
    _describe -t commands 'pihole command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      disable)
        _arguments \
          '1:duration (seconds or permanently):(permanently 10s 30s 5m)' && ret=0
        ;;
      -a|admin)
        local -a admin_cmds=(
          '-p:Set admin password'
          '-c:Set temperature unit'
          '-e:Email address for BLOCK page'
          'interface:Set listening interface'
          'teleporter:Export/import settings'
        )
        _describe -t admin-commands 'admin command' admin_cmds && ret=0
        ;;
      logging)
        _arguments \
          '1:action:(on off)' && ret=0
        ;;
      checkout)
        _arguments \
          '1:component:(core web ftl)' \
          '2:branch:' && ret=0
        ;;
      -w|whitelist|-b|blacklist)
        _arguments \
          '-d[Remove domain from list]' \
          '-l[List all entries]' \
          '-nr[Do not reload DNS after change]' \
          '-q[Quiet mode]' \
          '*:domain:' && ret=0
        ;;
      query|-q)
        _arguments \
          '-exact[Search for exact match]' \
          '-all[Show all results]' \
          '-adlist[Search adlists only]' \
          '*:domain:' && ret=0
        ;;
      version)
        _arguments \
          '-p[Show Pi-hole version only]' \
          '-a[Show AdminLTE version only]' \
          '-f[Show FTL version only]' \
          '-c[Show current versions]' \
          '-l[Show latest versions]' \
          '--hash[Show git hash]' && ret=0
        ;;
    esac
    ;;
esac

return ret
