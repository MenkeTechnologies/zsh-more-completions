#compdef hxtback
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/hxtback.txt
# Reads a HEXTE science or housekeeping FITS file and creates new files by cluster position

local ret=1

_arguments -s \
  '-i[input HEXTE science or housekeeping FITS file]:input file:_files' \
  '-b[consolidate all background data into a single output file]' \
  '-h[display help text]' \
  '*:file:_files' && ret=0

return ret
