#compdef ripgen
# Documentation: https://github.com/resyncgg/ripgen
# Rust-based high performance domain permutation generator

local ret=1

_arguments -s -S \
  '(-d --domains)'{-d,--domains}'[file containing domains to permute (default: stdin)]:domains file:_files' \
  '(-w --wordlist)'{-w,--wordlist}'[supplementary wordlist file to include]:wordlist:_files' \
  '(-l --len)'{-l,--len}'[minimum length for a word to be considered important]:length' \
  '(-f --fast)'{-f,--fast}'[use the most likely words only in permutations]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
