#compdef PrintReads
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/PrintReads.java
# Print reads in the SAM/BAM/CRAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'[Write output to this file]:value:_files' \
  '*:argument:_files' && ret=0

return ret
