#compdef rbdock
# Documentation: https://rdock.github.io/documentation/html_docs/reference-guide/programs.html
# rbdock - rDock docking engine.

local ret=1

_arguments -s -S \
  '-i+[input ligand MDL SD file]:file:_files' \
  '-o+[output MDL SD file]:file:_files' \
  '-r+[system definition .prm file]:file:_files' \
  '-p+[docking protocol .prm file]:file:_files' \
  '-n+[number of docking runs per ligand]:n:' \
  '-s+[random seed]:n:' \
  '-T+[debug trace level]:n:' \
  '-t+[SCORE.INTER threshold or filter file]:thresh:' \
  '-cont[threshold acts as output pose filter]' \
  '-ap[auto-protonate positive ionisable centres]' \
  '-an[auto-deprotonate negative ionisable centres]' \
  '-allH[disable removal of explicit non-polar hydrogens]' \
  '*:file:_files' && ret=0

return ret
