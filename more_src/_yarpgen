#compdef yarpgen
# Documentation: https://github.com/intel/yarpgen/blob/main/src/options.cpp
# Reference accessed: 2026-05-21
# Verified: upstream yarpgen source (src/options.cpp options_set table) at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[display help message]' \
  '(-v --version)'{-v,--version}'[print yarpgen version]' \
  '(-s --seed)'{-s+,--seed=}'[predefined seed (0 reserved for random)]:seed:' \
  '(-o --out-dir)'{-o+,--out-dir=}'[output directory]:dir:_files -/' \
  '--std=[language standard]:std:(c c++ ispc sycl)' \
  '--check-algo=[check algorithm]:algo:(hash asserts)' \
  '--inp-as-args=[pass inputs as args]:level:(none some all)' \
  '--emit-align-attr=[emit aligned attribute]:level:(none some all)' \
  '--unique-align-size[use unique align size for all attributes]' \
  '--align-size=[align attribute size]:size:(16 32 64)' \
  '--allow-dead-data=[allow dead data]:bool:(true false)' \
  '--emit-pragmas=[emit pragmas]:level:(none some all)' \
  '--param-shuffle=[shuffle parameters]:bool:(true false)' \
  '--expl-loop-param=[emit explicit loop parameters]:bool:(true false)' \
  '--mutate=[test mutation type]:kind:(none exprs all)' \
  '--mutation-seed=[mutation seed (0 reserved for random)]:seed:' \
  '--allow-ub-in-dc=[allow UB in dead code]:level:(none some all)' && ret=0

return ret
