#compdef lzop
# _lzop-bin — lzop LZO-based compressor (Markus Oberhumer); extremely fast (de)compression for backups
# upstream: https://www.lzop.org

_lzop-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --decompress)'{-d,--decompress}'[decompress]' \
        '(-x --extract)'{-x,--extract}'[extract (same as -d -P)]' \
        '(-t --test)'{-t,--test}'[test integrity]' \
        '(-l --list)'{-l,--list}'[list]' \
        '(-c --stdout)'{-c,--stdout}'[stdout]' \
        '(-k --keep)'{-k,--keep}'[keep input]' \
        '(-f --force)'{-f,--force}'[force overwrite]' \
        '(-N --name)'{-N,--name}'[restore original name/time]' \
        '(-n --no-name)'{-n,--no-name}'[do not restore name/time]' \
        '(-p --path)'{-p,--path}'+[output dir]:dir:_files -/' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-S --suffix)'{-S,--suffix}'+[suffix]:str:' \
        '(-1)-1[fast]' \
        '(-2)-2[lvl 2]' \
        '(-3)-3[lvl 3]' \
        '(-4)-4[lvl 4]' \
        '(-5)-5[lvl 5]' \
        '(-6)-6[lvl 6 default]' \
        '(-7)-7[lvl 7]' \
        '(-8)-8[lvl 8]' \
        '(-9)-9[best (LZO1X-999)]' \
        '(--best)--best[lvl 9]' \
        '(--fast)--fast[lvl 1]' \
        '--crc32[add CRC32 check]' \
        '--no-checksum[skip checksum]' \
        '--no-mode[do not save file mode]' \
        '--no-time[do not save mtime]' \
        '*:file:_files'
}

_lzop-bin "$@"
