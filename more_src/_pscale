#compdef pscale

# Zsh completion for PlanetScale CLI

local curcontext="$curcontext" state line ret=1

local -a pscale_commands
pscale_commands=(
  'api:make authenticated API requests'
  'audit-log:list audit logs'
  'auth:login and logout via the PlanetScale API'
  'backup:manage backups of branches'
  'branch:manage branches of a database'
  'completion:generate shell completion scripts'
  'connect:create a secure connection to a branch'
  'data-imports:manage data imports'
  'database:manage databases'
  'deploy-request:manage deploy requests'
  'help:help about any command'
  'keyspace:manage keyspaces'
  'org:manage PlanetScale organizations'
  'password:manage passwords for a branch'
  'region:list available regions'
  'service-token:manage access service tokens'
  'shell:open a MySQL shell to a branch'
  'signup:sign up for a PlanetScale account'
)

local -a pscale_global_flags
pscale_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--api-token=[PlanetScale API token]:token:'
  '--api-url=[PlanetScale API URL]:url:'
  '--config=[config file]:file:_files'
  '--debug[enable debug mode]'
  '-f=[output format]:format:(human json csv)' \
  '--format=[output format]:format:(human json csv)'
  '--no-color[disable terminal colors]'
  '--org=[organization to use]:org:'
  '--service-token=[PlanetScale service token]:token:'
  '--service-token-id=[PlanetScale service token ID]:token id:'
  '--version[show version]'
)

_arguments -s -S \
  $pscale_global_flags \
  '1:command:_describe -t commands command pscale_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      auth)
        local -a auth_commands
        auth_commands=(
          'login:authenticate with PlanetScale'
          'logout:log out of PlanetScale'
        )
        _arguments -s -S \
          $pscale_global_flags \
          '1:auth command:_describe -t commands command auth_commands' \
          '*::auth args:' && ret=0
        ;;
      database)
        local -a database_commands
        database_commands=(
          'create:create a database'
          'delete:delete a database'
          'dump:dump a database'
          'list:list databases'
          'restore-dump:restore a dump to a branch'
          'show:show a database'
        )
        _arguments -s -S \
          $pscale_global_flags \
          '1:database command:_describe -t commands command database_commands' \
          '*::database args:->database_args' && ret=0
        case "$state" in
          database_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--cluster-size=[cluster size]:size:(PS-10 PS-20 PS-40 PS-80 PS-160 PS-320 PS-400)' \
                  '--default-branch=[default branch name]:branch:' \
                  '--plan=[database plan]:plan:(hobby scaler scaler_pro enterprise)' \
                  '--region=[region for the database]:region:' \
                  '1:database name:' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--force[skip confirmation]' \
                  '1:database name:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $pscale_global_flags && ret=0
                ;;
              show)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--web[open in the web browser]' \
                  '1:database name:' && ret=0
                ;;
              dump)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--local-addr=[local address to bind]:address:' \
                  '--output=[output directory]:directory:_directories' \
                  '--tables=[comma-separated list of tables to dump]:tables:' \
                  '--where=[WHERE clause to filter rows]:where clause:' \
                  '1:database name:' \
                  '2:branch name:' && ret=0
                ;;
              restore-dump)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--dir=[directory with dump files]:directory:_directories' \
                  '--local-addr=[local address to bind]:address:' \
                  '--overwrite-tables[overwrite existing tables]' \
                  '1:database name:' \
                  '2:branch name:' && ret=0
                ;;
              *)
                _arguments -s -S $pscale_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      branch)
        local -a branch_commands
        branch_commands=(
          'create:create a new branch'
          'delete:delete a branch'
          'diff:show the schema diff between branches'
          'keyspaces:manage branch keyspaces'
          'lint:lint a branch schema'
          'list:list branches'
          'promote:promote a branch to production'
          'refresh-schema:refresh the schema for a branch'
          'safe-migrations:manage safe migrations for a branch'
          'schema:show the schema for a branch'
          'show:show a branch'
          'switch:switch to a different branch'
          'vschema:show or update the VSchema for a branch'
        )
        _arguments -s -S \
          $pscale_global_flags \
          '1:branch command:_describe -t commands command branch_commands' \
          '*::branch args:->branch_args' && ret=0
        case "$state" in
          branch_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--backup-id=[backup to restore from]:backup id:' \
                  '--from=[parent branch]:parent branch:' \
                  '--region=[region for the branch]:region:' \
                  '--restore=[timestamp to restore from]:timestamp:' \
                  '--seed-data=[seed data from parent branch]:bool:(true false)' \
                  '--wait[wait for the branch to be ready]' \
                  '1:database name:' \
                  '2:branch name:' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--force[skip confirmation]' \
                  '1:database name:' \
                  '2:branch name:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--web[open in the web browser]' \
                  '1:database name:' && ret=0
                ;;
              show)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--web[open in the web browser]' \
                  '1:database name:' \
                  '2:branch name:' && ret=0
                ;;
              diff)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--web[open in the web browser]' \
                  '1:database name:' \
                  '2:branch name:' && ret=0
                ;;
              schema)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--keyspace=[keyspace name]:keyspace:' \
                  '1:database name:' \
                  '2:branch name:' && ret=0
                ;;
              promote)
                _arguments -s -S \
                  $pscale_global_flags \
                  '1:database name:' \
                  '2:branch name:' && ret=0
                ;;
              switch)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--create[create branch if it does not exist]' \
                  '--parent-branch=[parent branch when creating]:branch:' \
                  '--wait[wait for the branch to be ready]' \
                  '1:database name:' \
                  '2:branch name:' && ret=0
                ;;
              safe-migrations)
                local -a safe_commands
                safe_commands=(
                  'disable:disable safe migrations'
                  'enable:enable safe migrations'
                )
                _arguments -s -S \
                  $pscale_global_flags \
                  '1:safe-migrations command:_describe -t commands command safe_commands' \
                  '2:database name:' \
                  '3:branch name:' && ret=0
                ;;
              *)
                _arguments -s -S $pscale_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      deploy-request)
        local -a dr_commands
        dr_commands=(
          'close:close a deploy request'
          'create:create a deploy request'
          'deploy:deploy a deploy request'
          'diff:show the diff for a deploy request'
          'edit:edit a deploy request'
          'list:list deploy requests'
          'review:review a deploy request'
          'revert:revert a deploy request'
          'show:show a deploy request'
          'skip-revert-period:skip the revert period'
        )
        _arguments -s -S \
          $pscale_global_flags \
          '1:deploy-request command:_describe -t commands command dr_commands' \
          '*::dr args:->dr_args' && ret=0
        case "$state" in
          dr_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--branch=[branch name]:branch:' \
                  '--into=[target branch]:branch:' \
                  '--notes=[deploy request notes]:notes:' \
                  '1:database name:' && ret=0
                ;;
              deploy|close|show|diff|revert|skip-revert-period)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--wait[wait for deploy to complete]' \
                  '1:database name:' \
                  '2:deploy request number:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--web[open in the web browser]' \
                  '1:database name:' && ret=0
                ;;
              review)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--approve[approve the deploy request]' \
                  '--comment=[review comment]:comment:' \
                  '--reject[reject the deploy request]' \
                  '1:database name:' \
                  '2:deploy request number:' && ret=0
                ;;
              *)
                _arguments -s -S $pscale_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      connect)
        _arguments -s -S \
          $pscale_global_flags \
          '--execute=[execute a command after connecting]:command:' \
          '--execute-env-url=[env var name for the connection URL]:env var:' \
          '--execute-protocol=[protocol for the connection URL]:protocol:(mysql2 mysql)' \
          '--host=[local address to bind]:host:' \
          '--port=[local port to bind]:port:' \
          '--remote-addr=[remote address for the connection]:address:' \
          '--role=[database role]:role:(reader writer readwriter admin)' \
          '1:database name:' \
          '2:branch name:' && ret=0
        ;;
      shell)
        _arguments -s -S \
          $pscale_global_flags \
          '--local-addr=[local address to bind]:address:' \
          '--role=[database role]:role:(reader writer readwriter admin)' \
          '1:database name:' \
          '2:branch name:' && ret=0
        ;;
      password)
        local -a password_commands
        password_commands=(
          'create:create a password for a branch'
          'delete:delete a password'
          'list:list passwords for a branch'
          'renew:renew a password'
        )
        _arguments -s -S \
          $pscale_global_flags \
          '1:password command:_describe -t commands command password_commands' \
          '*::password args:->password_args' && ret=0
        case "$state" in
          password_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--branch=[branch name]:branch:' \
                  '--replica[create on a read-only replica]' \
                  '--role=[database role]:role:(reader writer readwriter admin)' \
                  '--ttl=[time to live]:ttl:' \
                  '1:database name:' \
                  '2:password name:' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--branch=[branch name]:branch:' \
                  '--force[skip confirmation]' \
                  '1:database name:' \
                  '2:password ID:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $pscale_global_flags \
                  '--branch=[branch name]:branch:' \
                  '1:database name:' && ret=0
                ;;
              *)
                _arguments -s -S $pscale_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      backup)
        local -a backup_commands
        backup_commands=(
          'create:create a backup of a branch'
          'delete:delete a backup'
          'list:list backups for a branch'
          'restore:restore a backup to a new branch'
          'show:show a backup'
        )
        _arguments -s -S \
          $pscale_global_flags \
          '1:backup command:_describe -t commands command backup_commands' \
          '*::backup args:' && ret=0
        ;;
      org)
        local -a org_commands
        org_commands=(
          'list:list organizations'
          'show:show an organization'
          'switch:switch to a different organization'
        )
        _arguments -s -S \
          $pscale_global_flags \
          '1:org command:_describe -t commands command org_commands' \
          '*::org args:' && ret=0
        ;;
      service-token)
        local -a st_commands
        st_commands=(
          'add-access:grant access to a service token'
          'create:create a service token'
          'delete:delete a service token'
          'delete-access:revoke access from a service token'
          'list:list service tokens'
          'show-access:show access for a service token'
        )
        _arguments -s -S \
          $pscale_global_flags \
          '1:service-token command:_describe -t commands command st_commands' \
          '*::st args:' && ret=0
        ;;
      region)
        local -a region_commands
        region_commands=(
          'list:list available regions'
        )
        _arguments -s -S \
          $pscale_global_flags \
          '1:region command:_describe -t commands command region_commands' \
          '*::region args:' && ret=0
        ;;
      completion)
        _arguments -s -S \
          $pscale_global_flags \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S $pscale_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
