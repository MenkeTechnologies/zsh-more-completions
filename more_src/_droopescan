#compdef droopescan

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '--debug[enable debug output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'scan:scan a CMS installation'
      'stats:show plugin/theme stats'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (scan)
        _arguments \
          '(-u --url)'{-u,--url}'=[target URL]:url:' \
          '(-U --url-file)'{-U,--url-file}'=[file with URLs]:file:_files' \
          '(-e --enumerate)'{-e,--enumerate}'=[enumerate]:what:(p t v i)' \
          '(-t --threads)'{-t,--threads}'=[number of threads]:threads:' \
          '(-n --number)'{-n,--number}'=[number of plugins to enumerate]:number:' \
          '--timeout-host=[host timeout in seconds]:seconds:' \
          '--timeout=[request timeout in seconds]:seconds:' \
          '--no-update[do not update plugin lists]' \
          '--error-log=[error log file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output format]:format:(standard json)' \
          '1:CMS type:(drupal joomla wordpress silverstripe moodle)' && ret=0
        ;;
      (stats)
        _arguments \
          '1:CMS type:(drupal joomla wordpress silverstripe moodle)' && ret=0
        ;;
    esac
    ;;
esac

return ret
