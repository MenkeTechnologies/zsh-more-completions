#compdef zap zap.sh zaproxy
# Documentation: https://www.zaproxy.org/docs/desktop/cmdline/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org search URL.
# Removed unverified flags: -quickurl, -quickout, -quickprogress, -certload,
# -certpubdump, -certfulldump, -lang, -suppressinfo (variant), -host.
# Added verified: -loglevel, -suppinfo, -sbomzip, -addonlist.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-cmd[inline mode - exits when options complete]' \
  '-daemon[daemon mode - no UI]' \
  '-config+[override configuration with key=value]:cfg:' \
  '-configfile+[properties config file]:file:_files' \
  '-dir+[ZAP home directory]:dir:_files -/' \
  '-installdir+[override install dir]:dir:_files -/' \
  '-newsession+[new session file]:file:_files' \
  '-session+[existing session file]:file:_files' \
  '-silent[prevent unsolicited requests]' \
  '-nostdout[disable stdout logging]' \
  '-suppinfo[output support/troubleshooting details]' \
  '-loglevel+[log level]:level:(OFF FATAL ERROR WARN INFO DEBUG TRACE ALL)' \
  '-sbomzip+[generate SBOM zip file]:file:_files' \
  '-script+[run script]:file:_files' \
  '-addoninstall+[install add-on by id]:addon:' \
  '-addoninstallall[install all marketplace add-ons]' \
  '-addonuninstall+[uninstall add-on by id]:addon:' \
  '-addonupdate[update all changed add-ons]' \
  '-addonlist[list installed add-ons]' \
  '-lowmem[prioritize database over memory]' \
  '-experimentaldb[use experimental database code]' \
  '*: :_files' && ret=0

return ret
