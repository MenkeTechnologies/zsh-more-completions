#compdef zap zap.sh zaproxy zap-cli
# Documentation: https://man.archlinux.org/search?q=zap
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-cmd[command-line mode no UI]' \
  '-daemon[daemon mode]' \
  '-port+[listen port]:port:' \
  '-host+[listen host]:host:_hosts' \
  '-config+[config k=v]:cfg:' \
  '-configfile+[config file]:file:_files' \
  '-dir+[ZAP home dir]:dir:_files -/' \
  '-installdir+[install dir]:dir:_files -/' \
  '-newsession+[new session file]:file:_files' \
  '-session+[session file]:file:_files' \
  '-suppressinfo[suppress info]' \
  '-silent[silent mode]' \
  '-nostdout[no stdout]' \
  '-quickurl+[quickly scan URL]:url:_urls' \
  '-quickout+[output report]:file:_files' \
  '-quickprogress[show quick progress]' \
  '-script+[run script]:file:_files' \
  '-addoninstall+[install add-on]:addon:' \
  '-addoninstallall[install all add-ons]' \
  '-addonuninstall+[uninstall add-on]:addon:' \
  '-addonupdate[update add-ons]' \
  '-certload+[load cert]:file:_files -g "*.cer *.pem"' \
  '-certpubdump+[dump public cert]:file:_files' \
  '-certfulldump+[dump full cert]:file:_files' \
  '-lowmem[low memory]' \
  '-lang+[language]:lang:(en de fr ja zh)' \
  '-experimentaldb[experimental DB]' \
  '*: :_files' && ret=0

return ret
