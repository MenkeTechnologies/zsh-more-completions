#compdef macmon
# Documentation: https://man.archlinux.org/search?q=macmon
# Reference accessed: 2026-05-16

_arguments \
  '-i[update interval in milliseconds]:ms' \
  '--interval[update interval in milliseconds]:ms' \
  '--color[color theme]:theme:(default dark light)' \
  '-h[display help]' \
  '--help[display help]' \
  '-V[display version]' \
  '--version[display version]'
