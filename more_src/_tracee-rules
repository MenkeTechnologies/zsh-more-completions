#compdef tracee-rules
# _tracee-rules — Aqua Tracee Rego/Go rules engine (Aqua Security, Go); urfave/cli (deprecated, folded into tracee)
# upstream: https://github.com/aquasecurity/tracee

_tracee-rules() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--rules=+[rules to enable]:list:' \
        '--rules-dir=+[rules dir]:dir:_files -/' \
        '--input-tracee=+[tracee input]:str:' \
        '--list[list available rules]' \
        '--list-events[list events]' \
        '--webhook=+[webhook url]:url:_urls' \
        '--webhook-template=+[webhook template]:file:_files' \
        '--webhook-content-type=+[webhook content type]:type:(application/json text/plain)' \
        '--output-template=+[output template]:file:_files' \
        '--pprof[enable pprof]' \
        '--pprof-addr=+[pprof addr]:addr:' \
        '--metrics[enable metrics]' \
        '--metrics-addr=+[metrics addr]:addr:' \
        '--rego-runtime-target=+[rego runtime target]:t:(rego wasm)' \
        '--rego-partial-eval[rego partial eval]' \
        '--rego-aio[rego all-in-one bundle]' \
        '*:arg:'
}

_tracee-rules "$@"
