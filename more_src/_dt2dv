#compdef dt2dv dv2dt
# Documentation: TeX dt2dv / dv2dt usage (TeX Live 2026)
# Source: TeX dt2dv / dv2dt — DTL <-> DVI converters.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-debug[print debug info]' \
    '-group[parenthesize DTL groups]' \
    '-octal[print numbers in octal]' \
    '-only-pages=[only process N pages]:n:' \
    '-page-start=[start at page spec]:spec:' \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '1:DTL/DVI input file:_files -g "*.{dtl,dvi}"' \
    '2:output file:_files' \
    && ret=0

return ret
