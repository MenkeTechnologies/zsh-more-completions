#compdef cf-monitord
# Documentation: https://docs.cfengine.com/docs/master/reference-components-cf-monitord.html
# Source: cfengine/core cf-monitord/cf-monitord.c — CFEngine resource monitor daemon.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-d --debug)'{-d,--debug}'[enable debugging output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-n --dry-run)'{-n,--dry-run}'[dry-run, no changes]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-K --no-lock)'{-K,--no-lock}'[ignore system lock]' \
    '(-f --file)'{-f+,--file=}'[alternative input file]:file:_files' \
    '(-g --log-level)'{-g+,--log-level=}'[log level]:level:(error warning notice info verbose debug)' \
    '(-I --inform)'{-I,--inform}'[print basic info about system changes]' \
    '(-x --diagnostic)'{-x,--diagnostic}'[internal diagnostics (devs)]' \
    '(-F --no-fork)'{-F,--no-fork}'[run in foreground]' \
    '(-H --histograms)'{-H,--histograms}'[ignored, backward compatibility]' \
    '(-T --tcpdump)'{-T,--tcpdump}'[interface with tcpdump for network data]' \
    '(-C --color)'{-C+,--color=}'[colorized output]:when:(always auto never)' \
    '(-l --timestamp)'{-l,--timestamp}'[log timestamps]' \
    '--ignore-preferred-augments[skip def_preferred.json]' \
    && ret=0

return ret
