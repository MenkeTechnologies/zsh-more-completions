#compdef huggingface-cli2 huggingface-hub-cli
# _huggingface-cli2 — Hugging Face huggingface-cli2 CLI command-line frontend wrapping the huggingface_hub library managing repositories models datasets spaces login logout whoami repo files upload download lfs-enable-large-files tag delete-repo commit-create branch tags pull-request scan-cache delete-cache (Hugging Face team, Python); click
# upstream: https://huggingface.co/

_huggingface-cli2() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show current user'
        'token:token operations'
        'repo:repository operations'
        'lfs-enable-largefiles:enable LFS for large files'
        'upload:upload a file or folder'
        'download:download a file or folder'
        'scan-cache:scan local cache'
        'delete-cache:delete cache entries'
        'tag:tag operations'
        'env:environment info'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--token=+[token]:str:' \
        '--repo-id=+[id]:str:' \
        '--repo-type=+[t]:t:(model dataset space)' \
        '--organization=+[name]:str:' \
        '--from-pretrained[from pretrained]' \
        '--branch=+[name]:str:' \
        '--revision=+[ref]:str:' \
        '--commit-message=+[text]:str:' \
        '--commit-description=+[text]:str:' \
        '--include=+[pattern]:str:' \
        '--exclude=+[pattern]:str:' \
        '--local-dir=+[dir]:dir:_files -/' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--force-download[force redownload]' \
        '--resume-download[resume download]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'huggingface-cli2 subcommand' sub ;;
        args)
            case $words[1] in
                repo) _arguments '1:op:(create ls-remote ls clone delete)' '*:repo:' ;;
                upload|download) _arguments '*:repo or path:_files' ;;
                tag) _arguments '*:tag:' ;;
            esac
            ;;
    esac
}

_huggingface-cli2 "$@"
