#compdef erg

# Zsh completion for erg (Erg programming language)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--opt-level[optimization level]:level:(0 1 2 3)' \
  '--python-version[target Python version]:version' \
  '--server[start language server]' \
  '--no-std[do not load the standard library]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'lex:tokenize a file'
      'parse:parse a file'
      'desugar:desugar a file'
      'typecheck:type-check a file'
      'compile:compile a file'
      'transpile:transpile to Python'
      'run:run a script'
      'server:start language server'
      'help:show help for a subcommand'
    )
    _describe -t commands 'erg subcommand' subcmds && ret=0
    ;;
  args)
    _files -g '*.er' && ret=0
    ;;
esac

return ret
