#compdef snyk-test
# _snyk-test — Snyk Open Source vulnerability test subcommand alias (Snyk, TypeScript); commander
# upstream: https://github.com/snyk/cli

_snyk-test() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--json[json output]' \
        '--json-file-output=+[json file output]:file:_files' \
        '--sarif[sarif output]' \
        '--sarif-file-output=+[sarif file output]:file:_files' \
        '--severity-threshold=+[severity threshold]:t:(low medium high critical)' \
        '--fail-on=+[fail on]:t:(all upgradable patchable)' \
        '--all-projects[all projects]' \
        '--detection-depth=+[detection depth]:n:' \
        '--exclude=+[exclude]:list:' \
        '--prune-repeated-subdependencies[prune repeated subdeps]' \
        '-p[prune repeated subdeps]' \
        '--print-deps[print deps]' \
        '--print-graph[print graph]' \
        '--remote-repo-url=+[remote repo url]:url:_urls' \
        '--dev[include dev deps]' \
        '--org=+[organization]:org:' \
        '--file=+[manifest file]:file:_files' \
        '--package-manager=+[package manager]:pm:(npm yarn pnpm pip pipenv poetry maven gradle composer nuget paket dotnet rubygems sbt golangdep govendor gomodules cocoapods swift hex helm cargo)' \
        '--unmanaged[unmanaged deps]' \
        '--scan-all-unmanaged[scan all unmanaged deps]' \
        '--skip-unresolved[skip unresolved deps]' \
        '--strict-out-of-sync=+[strict out of sync]:b:(true false)' \
        '--ignore-policy[ignore policy]' \
        '--trust-policies[trust policies]' \
        '--show-vulnerable-paths=+[show vulnerable paths]:t:(none some all)' \
        '--project-name=+[project name]:str:' \
        '--target-name=+[target name]:str:' \
        '--target-reference=+[target reference]:str:' \
        '--target-platform=+[target platform]:str:' \
        '--policy-path=+[policy path]:file:_files' \
        '--reachable[reachable deps]' \
        '--reachable-vulns[reachable vulns]' \
        '--reachable-timeout=+[reachable timeout]:n:' \
        '--init-script=+[init script]:file:_files' \
        '--maven-aggregate-project[maven aggregate project]' \
        '--print-tree[print tree]' \
        '--scan-unmanaged[scan unmanaged]' \
        '*:path:_files'
}

_snyk-test "$@"
