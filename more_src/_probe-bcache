#compdef probe-bcache
# Documentation: https://github.com/g2p/bcache-tools (probe-bcache.c)
# Reference accessed: 2026-05-30
# probe-bcache — print bcache superblock UUID/TYPE for a block device. Used
# by udev rules to autostart bcache once both cache + backing devices show up.
# Single getopt option (-o udev) controls output format; everything else is
# positional block-device names.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-o+[output format (only "udev" is recognized)]:format:(udev)' \
  '*:block device:_files -g "/dev/*"' \
  && ret=0

return ret
