#compdef pslMap
# UCSC kent: map PSLs through a PSL or chain mapping file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-chainMapFile[mapping file is a chain file]' \
  '-swapMap[swap query and target in mapping file]' \
  '-swapIn[swap query and target in input file]' \
  '-suffix=[add suffix to mapped query name]:suffix:' \
  '-keepTranslated[keep translated alignment status]' \
  '-mapFileWithInQName[mapping file qNames match input qNames]' \
  '-check[validate output PSLs]' \
  '-mapInfo=[write mapping info to file]:file:_files' \
  '-mappingPsls=[write mapping PSLs to file]:file:_files' \
  '-simplifyMappingIds[simplify mapping ids]' \
  '-inType=[type of input PSL]:type:(prot_prot prot_na na_na)' \
  '-mapType=[type of mapping PSL]:type:(prot_prot prot_na na_na)' \
  '-tsv[output TSV header]' \
  ':input psl:_files' \
  ':map file:_files' \
  ':output psl:_files' && ret=0

return ret
