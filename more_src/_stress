#compdef stress

# Zsh completion for stress (system stress tester)

_arguments -s -S \
  '(- *)--help[show help message]' \
  '(- *)--version[show version information]' \
  {-c,--cpu}'[spawn N CPU workers spinning on sqrt()]:workers:' \
  {-i,--io}'[spawn N IO workers spinning on sync()]:workers:' \
  {-m,--vm}'[spawn N VM workers spinning on malloc()/free()]:workers:' \
  '--vm-bytes[allocate N bytes per VM worker]:bytes:' \
  '--vm-stride[touch a byte every N bytes]:bytes:' \
  '--vm-hang[sleep N seconds before freeing memory]:seconds:' \
  '--vm-keep[redirty memory instead of freeing and reallocating]' \
  {-d,--hdd}'[spawn N HDD workers spinning on write()/unlink()]:workers:' \
  '--hdd-bytes[write N bytes per HDD worker]:bytes:' \
  {-t,--timeout}'[timeout after N seconds]:seconds:' \
  '--backoff[wait N microseconds before work starts]:microseconds:' \
  {-n,--dry-run}'[show what would have been done]' \
  {-q,--quiet}'[be quiet]' \
  {-v,--verbose}'[be verbose]'
