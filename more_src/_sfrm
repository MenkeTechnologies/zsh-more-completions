#compdef sfrm
# Documentation: https://raw.githubusercontent.com/ahay/src/master/system/main/rm.c
# Madagascar: remove RSF files together with their data

local ret=1

_arguments -s \
  '-f[force removal without confirmation]' \
  '-v[verbose output]' \
  '-i[inquire/prompt before deletion]' \
  '*:RSF file:_files -g "*.rsf"' && ret=0

return ret
