#compdef crlrefresh
# Documentation: https://keith.github.io/xcode-man-pages/crlrefresh.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'r:refresh CRLs'
  'f:fetch a CRL from a URI'
  'F:fetch a certificate from a URI'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'crlrefresh command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (f|F)
        _arguments \
          '1:URI:' \
          'F=-[output file name]:file:_files' \
          'n[do not write to cache after fetch]' \
          'k=-[CRL cache keychain path]:file:_files' \
          'v[verbose output]' && ret=0
        ;;
      (r)
        _arguments \
          's=-[stale period in days]:days:' \
          'o=-[expire overlap in seconds]:seconds:' \
          'p[purge all entries, ensuring refresh with fresh CRLs]' \
          'f[full crypto CRL verification]' \
          'k=-[CRL cache keychain path]:file:_files' \
          'v[verbose output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
