#compdef pkg-delete pkg_delete
# _pkg-delete — OpenBSD pkg_delete remove installed package CLI alias (OpenBSD project, Perl); custom argparse
# upstream: https://github.com/openbsd/src/tree/master/usr.sbin/pkg_delete

_pkg-delete() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[remove all autoinstalled]' \
        '-B+[chroot]:dir:_files -/' \
        '-c[clean cache]' \
        '-D+[debug]:str:' \
        '-F+[force option]:list:(baddepend nonroot scripts)' \
        '-i[interactive]' \
        '-I[no interaction]' \
        '-n[dry run]' \
        '-P+[path]:dir:_files -/' \
        '-q[quiet]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-x[allow patterns]' \
        '-X[no extra warnings]' \
        '-z[interactive]' \
        '*:package:'
}

_pkg-delete "$@"
