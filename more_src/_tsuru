#compdef tsuru
# _tsuru — tsuru PaaS command-line client
# upstream: https://github.com/tsuru/tsuru-client

_tsuru() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-t --target)'{-t,--target=}'[tsuru server URL]:url:_urls' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'app-create:create a new app'
                'app-deploy:deploy to an app'
                'app-info:show app information'
                'app-list:list your apps'
                'app-log:show app logs'
                'app-remove:remove an app'
                'app-restart:restart an app'
                'app-run:run a command in app units'
                'app-start:start an app'
                'app-stop:stop an app'
                'app-update:update app attributes'
                'env-get:show environment variables'
                'env-set:set environment variables'
                'env-unset:unset environment variables'
                'login:authenticate with the server'
                'logout:clear authentication credentials'
                'node-add:add a node to a pool'
                'node-list:list cluster nodes'
                'node-remove:remove a node'
                'plan-list:list available plans'
                'platform-list:list available platforms'
                'pool-list:list available pools'
                'service-add:create a service instance'
                'service-bind:bind a service to an app'
                'service-info:show service instance info'
                'service-list:list service instances'
                'service-remove:remove a service instance'
                'service-unbind:unbind a service from an app'
                'target-add:add a new tsuru server target'
                'target-list:list registered targets'
                'target-set:set the current target'
                'team-create:create a new team'
                'team-list:list teams'
                'token-create:create an API token'
                'unit-add:add units to an app'
                'unit-remove:remove units from an app'
                'version:show version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                app-create)
                    _arguments \
                        '(-p --plan)'{-p,--plan=}'[app plan]:plan:' \
                        '(-o --pool)'{-o,--pool=}'[app pool]:pool:' \
                        '(-t --team)'{-t,--team=}'[team owner]:team:' \
                        '--platform=[platform]:platform:' \
                        '--description=[app description]:description:' \
                        '--router=[router]:router:' \
                        '1:app name:'
                    ;;
                app-deploy)
                    _arguments \
                        '(-i --image)'{-i,--image=}'[deploy from Docker image]:image:' \
                        '--new-version[create a new version]' \
                        '--override-old-versions[replace all existing versions]' \
                        '(-a --app)'{-a,--app=}'[app name]:app:' \
                        '*:files or directories:_files'
                    ;;
                app-log)
                    _arguments \
                        '(-a --app)'{-a,--app=}'[app name]:app:' \
                        '(-l --lines)'{-l,--lines=}'[number of lines]:lines:' \
                        '(-f --follow)'{-f,--follow}'[follow log output]' \
                        '--source=[log source]:source:'
                    ;;
                app-info|app-remove|app-restart|app-start|app-stop)
                    _arguments \
                        '(-a --app)'{-a,--app=}'[app name]:app:'
                    ;;
                env-set)
                    _arguments \
                        '(-a --app)'{-a,--app=}'[app name]:app:' \
                        '--private[set as private]' \
                        '--no-restart[do not restart the app]' \
                        '*:KEY=VALUE pairs:'
                    ;;
                env-get|env-unset)
                    _arguments \
                        '(-a --app)'{-a,--app=}'[app name]:app:' \
                        '*:variable names:'
                    ;;
            esac
            ;;
    esac
}

_tsuru "$@"
