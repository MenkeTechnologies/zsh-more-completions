#compdef alpaca-cli alpaca
# _alpaca-cli — Alpaca alpaca-cli CLI command-line frontend wrapping the Alpaca commission-free stock and crypto trading REST WebSocket API managing accounts assets orders positions trades portfolio history clock calendar watchlists activities corporate-actions news subscriptions market-data IEX SIP OPRA bars trades quotes (Alpaca team, Go); cobra
# upstream: https://alpaca.markets/

_alpaca-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'asset:asset operations'
        'order:order operations'
        'position:position operations'
        'portfolio:portfolio operations'
        'trade:trade operations'
        'history:history operations'
        'clock:show clock'
        'calendar:calendar operations'
        'watchlist:watchlist operations'
        'activity:activity operations'
        'corporate-action:corporate actions'
        'news:news operations'
        'market-data:market data'
        'bars:bar data'
        'quotes:quote data'
        'trades:trade tick data'
        'crypto:crypto operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--api-url=+[url]:str:' \
        '--data-url=+[url]:str:' \
        '--environment=+[e]:e:(paper live)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'alpaca-cli subcommand' sub ;;
        args)
            case $words[1] in
                account|asset|order|position|portfolio|trade|history|watchlist|activity|corporate-action|news) _arguments '1:op:(list get create update delete cancel submit close)' '*:id:' ;;
                bars|quotes|trades|market-data) _arguments \
                    '--symbol=+[ticker]:str:' \
                    '--start=+[time]:str:' \
                    '--end=+[time]:str:' \
                    '--limit=+[N]:n:' \
                    '--timeframe=+[t]:t:(1Min 5Min 15Min 30Min 1Hour 1Day)' ;;
            esac
            ;;
    esac
}

_alpaca-cli "$@"
