#compdef seqcount
# Documentation: https://man.archlinux.org/search?q=seqcount
# Reference accessed: 2026-05-16

# EMBOSS seqcount: count the number of sequences in an input USA
# without writing them out. Fast summary statistic.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequences=[sequences to count]:sequence USA:_files' \
  '-outfile=[output file (default seqcount.out)]:file:_files' \
  '*:sequence USA:_files' && ret=0

return ret
