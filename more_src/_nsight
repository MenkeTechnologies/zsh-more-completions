#compdef nsight nsight-graphics nsight-deep-learning-designer
# _nsight — NVIDIA Nsight unified profiling and debugging launcher for GPU code on Linux Windows macOS (NVIDIA team, C++); custom argparse
# upstream: https://developer.nvidia.com/nsight-tools

_nsight() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--mode=+[mode]:m:(launch attach replay debug profile)' \
        '--project=+[project file]:file:_files -g "*.nproj *.nsight"' \
        '-p+[project file]:file:_files -g "*.nproj *.nsight"' \
        '--target=+[target executable]:file:_files' \
        '-t+[target executable]:file:_files' \
        '--target-arguments=+[args]:str:' \
        '--working-directory=+[work dir]:dir:_files -/' \
        '--remote=+[remote target spec]:str:' \
        '-r+[remote target spec]:str:' \
        '--remote-host=+[host]:host:_hosts' \
        '--remote-user=+[user]:user:_users' \
        '--remote-port=+[port]:port:_ports' \
        '--remote-password=+[password]:str:' \
        '--ssh-key=+[private key]:file:_files' \
        '--ssh-key-passphrase=+[passphrase]:str:' \
        '--env=+[KEY=VAL]:str:' \
        '--cuda-graphs-trace=+[mode]:m:(graph node)' \
        '--cuda-memory-usage=+[bool]:b:(true false)' \
        '--cuda-um-cpu-page-faults=+[bool]:b:(true false)' \
        '--cuda-um-gpu-page-faults=+[bool]:b:(true false)' \
        '--sample=+[mode]:m:(none cpu process-tree system-wide)' \
        '--export=+[format]:f:(sqlite text json csv arrow protobuf)' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--force-overwrite=+[bool]:b:(true false)' \
        '--gui[open in GUI]' \
        '--no-gui[no GUI]' \
        '--lic-server=+[license server]:host:_hosts' \
        '*:executable:_files'
}

_nsight "$@"
