#compdef shntool
# Documentation: https://man.archlinux.org/search?q=shntool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'cat:concatenate WAVE files'
  'cmp:compare WAVE files'
  'conv:convert format'
  'cue:generate CUE'
  'fix:fix break points'
  'gen:generate silence'
  'hash:checksum'
  'info:show info'
  'join:join files'
  'len:show lengths'
  'md5:MD5 sums'
  'pad:pad files'
  'split:split by CUE'
  'strip:strip extra chunks'
  'trim:trim silence'
)

_arguments -C \
  '-m[list mode modules]' \
  '-f[list format modules]' \
  '-a[show default args]' \
  '-v[show version]' \
  '-h[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'shntool subcommand' subcommands && ret=0 ;;
  (args)
    _arguments -s \
      '-D[debug]' \
      '-F[input filenames file]:file:_files' \
      '-H[h:mm:ss times]' \
      '-P[progress]:type:(pct dot spin face none)' \
      '-h[mode help]' \
      '-i[input decoder]:decoder:' \
      '-q[quiet]' \
      '-r[reorder]:mode:(ask ascii natural none)' \
      '-v[version]' \
      '-w[suppress warnings]' \
      '-O[overwrite]:mode:(ask always never)' \
      '-a[output prefix]:prefix:' \
      '-d[output dir]:dir:_files -/' \
      '-o[output format]:fmt:' \
      '-z[output postfix]:postfix:' \
      '*:file:_files' && ret=0 ;;
esac

return ret
