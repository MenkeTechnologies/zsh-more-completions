#compdef starship-cli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:print init script for shell'
  'prompt:print full prompt'
  'module:print specific module'
  'config:edit/show config'
  'bug-report:create bug report'
  'time:print current time in milliseconds'
  'explain:explain prompt module info'
  'timings:show prompt module timings'
  'completions:print shell completions'
  'session:print session unique id'
  'preset:apply or list presets'
  'toggle:toggle a module'
  'print-schema:print JSON schema for config'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--log-level=[log level]:l:(trace debug info warn error)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'starship command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '(--print-full-init)--print-full-init[print full init script]' \
          '1:shell:(bash zsh fish powershell pwsh ion elvish tcsh nu xonsh)' \
          '*: :' && ret=0 ;;
      (prompt)
        _arguments \
          '(-r --right)'{-r,--right}'[print right prompt]' \
          '(--profile)--profile=[profile]:p:' \
          '(-c --continuation)'{-c,--continuation}'[continuation prompt]' \
          '(-s --status)'{-s+,--status=}'[status code]:n:' \
          '(-p --pipestatus)*'{-p+,--pipestatus=}'[pipe statuses]:n:' \
          '(-d --cmd-duration)'{-d+,--cmd-duration=}'[cmd duration ms]:ms:' \
          '(-k --keymap)'{-k+,--keymap=}'[keymap]:k:' \
          '(-j --jobs)'{-j+,--jobs=}'[jobs count]:n:' \
          '(-t --terminal-width)'{-t+,--terminal-width=}'[terminal width]:n:' \
          '(-w --logical-path)'{-w+,--logical-path=}'[logical path]:p:' \
          '(--path)--path=[path]:p:' \
          '*: :' && ret=0 ;;
      (module)
        _arguments \
          '(--list)--list[list available modules]' \
          '(-r --right)'{-r,--right}'[right side]' \
          '(-s --status)'{-s+,--status=}'[status]:n:' \
          '(-p --pipestatus)*'{-p+,--pipestatus=}'[pipe statuses]:n:' \
          '(-d --cmd-duration)'{-d+,--cmd-duration=}'[duration]:ms:' \
          '(-k --keymap)'{-k+,--keymap=}'[keymap]:k:' \
          '(-j --jobs)'{-j+,--jobs=}'[jobs]:n:' \
          '(-t --terminal-width)'{-t+,--terminal-width=}'[width]:n:' \
          '(-w --logical-path)'{-w+,--logical-path=}'[logical path]:p:' \
          '*:module:' && ret=0 ;;
      (config)
        _arguments \
          '(--name)--name=[set config item]:k:' \
          '(--value)--value=[value]:v:' \
          '*: :' && ret=0 ;;
      (toggle)
        _arguments \
          '*:module:' && ret=0 ;;
      (preset)
        _arguments \
          '(-l --list)'{-l,--list}'[list presets]' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '*:preset:' && ret=0 ;;
      (explain|timings|bug-report|time|session)
        _arguments '*: :' && ret=0 ;;
      (completions)
        _arguments '1:shell:(bash zsh fish elvish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
