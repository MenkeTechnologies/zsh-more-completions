#compdef komiser
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'start:start the komiser dashboard'
  'version:show version information'
  'help:show help for a command'
)
_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0
case $state in
  command)
    _describe -t commands 'komiser command' commands && ret=0
    ;;
  args)
    case $line[1] in
      start)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--port=[port to listen on]:port:' \
          '--config=[path to config file]:config file:_files' \
          '--regions=[comma-separated list of regions]:regions:' \
          '--multiple[enable multi-cloud support]' \
          '--analytics[enable analytics]' \
          '--telemetry[enable telemetry]' && ret=0
        ;;
      version)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      help)
        _arguments -s -S \
          '1:command:(start version)' && ret=0
        ;;
    esac
    ;;
esac
return ret
