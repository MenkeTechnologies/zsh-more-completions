#compdef prismic
# _prismic — Prismic.io headless CMS CLI (arnaudlewis/prismic-cli)
# upstream: https://github.com/arnaudlewis/prismic-cli
# Subcommands from lib/prismic.js.

_prismic() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '--email=[account email]:email:' \
        '--password=[account password]:password:' \
        '--folder=[target folder]:dir:_files -/' \
        '--template=[project template]:template:(NodeJS ReactJS AngularJS Express)' \
        '--noconfirm[non-interactive mode]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'quickstart:create a NodeJS quickstart project'
                'init:initialize project for existing repository'
                'new:create project with new repository'
                'theme:initialize project from theme'
                'login:login to prismic.io account'
                'logout:logout from prismic.io account'
                'signup:create new prismic.io account'
                'list:list available code templates'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                init|new) _arguments '1:domain:' ;;
                theme) _arguments '1:theme URL or zip:' ;;
            esac
            ;;
    esac
}

_prismic "$@"
