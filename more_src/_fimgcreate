#compdef fimgcreate
# Create a FITS primary array image from an ASCII template file

local ret=1

_arguments -s \
  "bitpix=[data type bits per pixel]:bitpix:(8 16 32 -32 -64)" \
  "naxes=[image dimensions]:" \
  "datafile=[ASCII data file]:file:_files" \
  "outfile=[output FITS file]:file:_files" \
  "headfile=[optional header keyword file]:file:_files" \
  "nskip=[number of leading lines to skip]:" \
  "history=[add HISTORY keywords]:bool:(yes no)" \
  "nulltest=[test for null values]:bool:(yes no)" \
  "nullval=[null value]:" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:file:_files" && ret=0

return ret
