# Zsh completion for create-wdio - WebdriverIO project bootstrapper

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--dev[install all packages as devDependencies]' \
  '--no-dev[do not force devDependencies]' \
  '--yes[use config defaults without prompting]' \
  '--npm-tag=[NPM tag for @wdio/cli package]:tag:' \
  ':target directory:_directories' && ret=0

return ret
