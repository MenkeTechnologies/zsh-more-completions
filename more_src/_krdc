#compdef krdc
# Documentation: https://docs.kde.org/stable5/en/krdc/krdc/index.html
# Reference accessed: 2026-05-17
# Verified: KDE krdc/main.cpp upstream — `krdc --help` is canonical
# (no manpage). KRDC-specific flags: --fullscreen, --window,
# --high-quality, --medium-quality, --low-quality. Plus standard
# KDE/Qt switches (--help, --help-all, --help-qt, --help-kde,
# -v/--version, --author, --license, --style, --platform).
# Removed from prior file: bogus man.archlinux.org search URL.

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-qt[show Qt options]' \
  '(- *)--help-kde[show KDE options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)--author[show author info]' \
  '(- *)--license[show license info]' \
  '--fullscreen[start fullscreen (single URL only)]' \
  '--window[start windowed]' \
  '--high-quality[VNC high-quality preset]' \
  '--medium-quality[VNC medium-quality preset]' \
  '--low-quality[VNC low-quality preset]' \
  '--style=[Qt GUI style]:style:' \
  '--platform=[Qt platform plugin]:platform:' \
  '*:URL (vnc://host[:port] or rdp://host[:port]):' && ret=0
return ret
