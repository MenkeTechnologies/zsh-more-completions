#compdef krdc

# KRDC: KDE remote desktop client (RDP/VNC)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--fullscreen[start fullscreen]' \
  '--window[start windowed]' \
  '*:URL (vnc://host:port or rdp://user@host):' && ret=0
return ret
