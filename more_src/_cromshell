#compdef cromshell
# Documentation: https://github.com/broadinstitute/cromshell
# CLI for submitting and monitoring workflows on a Cromwell server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-t+[set curl connection timeout in seconds]:seconds' \
  '1:command:((
    submit\:"submit a workflow to the Cromwell server"
    abort\:"abort a running workflow"
    alias\:"assign an alias to a workflow"
    status\:"check the status of a workflow"
    metadata\:"get the full metadata of a workflow"
    slim-metadata\:"get a slim subset of workflow metadata"
    execution-status-count\:"get a count of task execution statuses"
    counts\:"get a count of task execution statuses"
    timing\:"open the Cromwell timing diagram in a browser"
    logs\:"list the log files of a workflow"
    fetch-logs\:"download the log files of a workflow"
    list-outputs\:"list the output files of a workflow"
    fetch-all\:"download all output and log files of a workflow"
    notify\:"notify when a workflow completes"
    list\:"list workflows submitted via cromshell"
    cleanup\:"clean up cromshell tracking files"
    update-server\:"change the Cromwell server URL"
    cost\:"get the cost of a workflow"
    cost-detailed\:"get a detailed cost breakdown of a workflow"
    version\:"show version"
  ))' \
  '*::arg:_files' && ret=0

return ret
