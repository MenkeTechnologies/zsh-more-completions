#compdef msgpack2json
# Documentation: https://github.com/ludocode/msgpack-tools/blob/develop/docs/msgpack2json.md
# msgpack2json - convert MessagePack to JSON

local ret=1

_arguments -s -S \
  '-h[print usage]' \
  '-i[read from the given file instead of standard input]:in-file:_files' \
  '-o[write to the given file instead of standard output]:out-file:_files' \
  '-d[debug mode: convert non-JSON-compatible objects to pseudo-JSON instead of failing]' \
  '-p[pretty-print JSON output]' \
  '-b[convert bin objects to base64 strings with a base64: prefix]' \
  '-B[convert bin objects to base64 strings with no prefix]' \
  '-c[continuous mode: multiple top-level objects, newline separated]' \
  '-C[continuous mode with comma delimiters between objects]' && ret=0

return ret
