#compdef ferrocene criticalup
# _ferrocene — Ferrous Systems Ferrocene qualified Rust toolchain via criticalup CLI (ferrocene team, Rust); clap-derive
# upstream: https://github.com/ferrocene/ferrocene

_ferrocene() {
    local -a sub=(
        'install:install toolchain'
        'archive:archive toolchain'
        'remove:remove toolchain'
        'verify:verify toolchain'
        'list:list installations'
        'auth:authentication subcommands'
        'which:show binary path'
        'run:run a tool from toolchain'
        'init:create criticalup.toml'
        'clean:clean unused installations'
        'doc:open docs'
        'self:self-management'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--log-level=+[level]:l:(error warn info debug trace)' \
        '--root=+[root dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ferrocene subcommand' sub ;;
        args)
            case $words[1] in
                install|verify|remove|archive) _arguments \
                    '--project=+[project file]:file:_files' \
                    '--offline[offline]' \
                    '*:product:' ;;
                auth) _arguments '1:auth cmd:(set remove show)' ;;
                run) _arguments \
                    '--project=+[project file]:file:_files' \
                    '*:tool:_command_names' ;;
                self) _arguments '1:self cmd:(update uninstall)' ;;
                which) _arguments \
                    '--project=+[project file]:file:_files' \
                    '*:tool:' ;;
            esac
            ;;
    esac
}

_ferrocene "$@"
