#compdef preflight
# Documentation: https://github.com/redhat-openshift-ecosystem/openshift-preflight
# Reference accessed: 2026-05-16
# Verified: redhat-openshift-ecosystem/openshift-preflight README +
# Cobra cmd tree.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --kubeconfig/--context (these are not on preflight; they
# are on kubectl plugins — preflight uses its own auth flags).

# preflight: Red Hat OpenShift container certification preflight check
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'check:run a certification check (container|operator)'
  'completion:generate shell completion'
  'runtime-assets:show runtime assets'
  'support:create a support package'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'preflight command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (check)
        _arguments \
          '1:type:(container operator)' \
          '--pyxis-api-token=[Pyxis API token]:token:' \
          '--certification-component-id=[component id]:id:' \
          '--docker-config=[docker config (or env PFTL_DOCKERCONFIG)]:file:_files' && ret=0
        ;;
      (completion) _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0 ;;
    esac
    ;;
esac
return ret
