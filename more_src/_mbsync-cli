#compdef mbsync-cli mbsync isync-cli
# _mbsync-cli — Oswald Buddenhagen mbsync IMAP4 mailbox synchronizer (isync) CLI alias (mbsync team, C); custom argparse
# upstream: https://sourceforge.net/projects/isync/

_mbsync-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g ".mbsyncrc"' \
        '--config=+[config file]:file:_files -g ".mbsyncrc"' \
        '-a[sync all channels]' \
        '--all[sync all channels]' \
        '-l[list mailboxes only]' \
        '--list[list mailboxes only]' \
        '-n[sync new messages]' \
        '--new[sync new messages]' \
        '-d[propagate deletions]' \
        '--delete[propagate deletions]' \
        '-f[flags only]' \
        '--flags[flags only]' \
        '-N[no expunge]' \
        '--noop[no expunge]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-X[debug all]' \
        '--debug[debug all]' \
        '-D+[debug categories]:str:' \
        '--debug-mail=+[categories]:str:' \
        '-J[journal warnings only]' \
        '--journal-warnings[journal warnings only]' \
        '-O[old style]' \
        '--old[old style]' \
        '-Y[zero filter delete]' \
        '--zero-filter-delete[zero filter delete]' \
        '*:channels:'
}

_mbsync-cli "$@"
