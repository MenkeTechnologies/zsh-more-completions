#compdef antigen

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'bundle:install a bundle'
      'bundles:list installed bundles'
      'update:update all bundles'
      'revert:revert to previous state'
      'list:list installed bundles'
      'cleanup:remove unused bundles'
      'use:load a zsh framework'
      'theme:set a zsh theme'
      'apply:apply changes'
      'snapshot:create a snapshot'
      'restore:restore from a snapshot'
      'purge:remove a bundle'
      'reset:clear antigen cache'
      'init:initialize antigen'
      'selfupdate:update antigen itself'
      'help:show help'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (bundle)
        _arguments \
          '--branch=[branch to use]:branch:' \
          '--no-local-clone[do not clone locally]' \
          '--loc=[subdirectory]:subdirectory:' \
          '--btype=[bundle type]:type:(plugin theme)' \
          '1:repository:' && ret=0
        ;;
      (use)
        _arguments '1:framework:(oh-my-zsh prezto)' && ret=0
        ;;
      (theme)
        _arguments '1:theme name:' && ret=0
        ;;
      (purge)
        _arguments '1:bundle name:' && ret=0
        ;;
      (snapshot)
        _arguments '1:snapshot file:_files' && ret=0
        ;;
      (restore)
        _arguments '1:snapshot file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
