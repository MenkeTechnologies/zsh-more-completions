#compdef hhblits
# Documentation: https://github.com/soedinglab/hh-suite/wiki
# HHblits: iterative HMM-HMM search to build alignments from a sequence database

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i+[input/query single sequence or MSA]:input file:_files' \
  '*-d+[database name]:database:_files' \
  '-n+[number of iterations 1..8]:iterations' \
  '-e+[E-value cutoff for inclusion in result alignment]:evalue' \
  '-M+[input alignment format: a2m/first/percentage]:mode' \
  '-tags[neutralize His/C-myc/FLAG tags]' \
  '-notags[do not neutralize tags]' \
  '-o+[write results in standard format to file]:output:_files' \
  '-oa3m+[write result MSA in a3m format]:a3m file:_files' \
  '-opsi+[write result MSA in PSI-BLAST format]:psi file:_files' \
  '-ohhm+[write HHM file for result MSA]:hhm file:_files' \
  '-oalis+[write MSAs in A3M after each iteration]:name:_files' \
  '-blasttab+[write result in tabular BLAST format]:name:_files' \
  '-add_cons[generate consensus sequence as master sequence]' \
  '-hide_cons[do not show consensus sequence in alignments]' \
  '-hide_pred[do not show predicted secondary structure]' \
  '-hide_dssp[do not show DSSP secondary structure]' \
  '-show_ssconf[show confidences for predicted secondary structure]' \
  '-seq+[max query/template sequences displayed]:int' \
  '-aliw+[columns per line in alignment list]:int' \
  '-p+[minimum probability in summary and alignment list]:prob' \
  '-E+[maximum E-value in summary and alignment list]:evalue' \
  '-Z+[maximum lines in summary hit list]:int' \
  '-z+[minimum lines in summary hit list]:int' \
  '-B+[maximum alignments in alignment list]:int' \
  '-b+[minimum alignments in alignment list]:int' \
  '-noprefilt[disable all filter steps]' \
  '-noaddfilter[disable all filter steps except fast prefiltering]' \
  '-maxfilt+[max hits allowed to pass 2nd prefilter]:int' \
  '-min_prefilter_hits+[min hits to pass prefilter]:int' \
  '-all[show all sequences in result MSA; do not filter]' \
  '-interim_filter+[NONE or FULL]:mode:(NONE FULL)' \
  '-id+[maximum pairwise sequence identity]:int' \
  '-diff+[filter MSAs by selecting most diverse set]:int' \
  '-cov+[minimum coverage with master sequence]:int' \
  '-qid+[minimum sequence identity with master sequence]:int' \
  '-qsc+[minimum score per column with master sequence]:num' \
  '-neff+[target diversity of MSA]:num' \
  '-norealign[do not realign displayed hits with MAC algorithm]' \
  '-realign[realign displayed hits with max accuracy MAC algorithm]' \
  '-realign_old_hits[realign hits from previous iterations]' \
  '-mact+[posterior prob threshold for MAC realignment]:num' \
  '-glob[use global alignment mode]' \
  '-loc[use local alignment mode]' \
  '-realign_max+[realign max int hits]:int' \
  '-premerge+[merge int hits to query MSA before aligning]:int' \
  '-neffmax+[skip further iterations when diversity Neff reached]:num' \
  '-wg[use global sequence weighting for realignment]' \
  '-nocontxt[use substitution-matrix instead of context-specific pseudocounts]' \
  '-contxt+[context file for context-specific pseudocounts]:file:_files' \
  '-v+[verbose mode]:level:(0 1 2)' \
  '-cpu+[number of CPUs to use]:int' \
  '-scores+[write scores for all pairwise comparisons to file]:file:_files' \
  '-atab+[write all alignments in tabular layout to file]:file:_files' \
  '-maxseq+[max number of input rows]:int' \
  '-maxres+[max number of HMM columns]:int' \
  '-maxmem+[limit memory for realignment in GB]:num' && ret=0

return ret
