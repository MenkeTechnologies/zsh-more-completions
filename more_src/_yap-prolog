#compdef yap
# Documentation: https://man.archlinux.org/search?q=yap
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-?[show help]' \
  '-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-q[quiet]' \
  '-s+[stack KB]:n:' \
  '-h+[heap KB]:n:' \
  '-t+[trail KB]:n:' \
  '-A+[atom table KB]:n:' \
  '-l+[load file]:file:_files -g "*.pl *.yap"' \
  '-L+[script file]:file:_files -g "*.pl"' \
  '-g+[goal at startup]:goal:' \
  '-z+[goal at startup]:goal:' \
  '-b+[bootstrap file]:file:_files' \
  '-B[bootstrap mode]' \
  '-c+[chinese hash]:n:' \
  '-D+[debug flag]:flag:' \
  '-f+[init file]:file:_files' \
  '-i[force interactive]' \
  '-m[multitenant]' \
  '-n[no init file]' \
  '-x+[binary boot]:file:_files' \
  '-J+[JIT flags]:f:' \
  '-X[no signals]' \
  '*: :_files -g "*.pl *.yap"' && ret=0

return ret
