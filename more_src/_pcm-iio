#compdef pcm-iio

# Intel Performance Counter Monitor pcm-iio: monitor iio counters
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-csv[CSV output]' \
  '-csv=[CSV output to file]:file:_files' \
  '-i[number of iterations]:n:' \
  '-r[reset all counters before exit]' \
  '-silent[suppress info messages]' \
  '-color[color console output]' \
  '-nc[no consume on read]' \
  '-batch[batch mode (timestamped lines)]' \
  '-debug[debug output]:level:' \
  '*:delay seconds:' && ret=0
return ret
