#compdef pcm-iio

# pcm-iio: Intel PCM I/O event monitor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-csv-[CSV output to file]:file:_files' \
  '-csv[CSV output to stdout]' \
  '-json-[JSON output to file]:file:_files' \
  '-json[JSON output to stdout]' \
  '-i[count of samples]:n:' \
  '-s[delay between samples]:seconds:' \
  '-c[show core stats]' \
  '-C[show counter info]' \
  '-f[force MSR access if no permission]' \
  '-r[reset PMU before run]' \
  '-silent[silent mode]' \
  '-nc[no core stats]' \
  '-x[show extended events]' \
  '-pid[restrict to PID]:pid:' \
  '-tid[restrict to TID]:tid:' \
  '-out[output file]:file:_files' \
  '*::pcm-iio args:_files' && ret=0
return ret
