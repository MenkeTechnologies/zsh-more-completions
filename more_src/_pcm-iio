#compdef pcm-iio
# Documentation: https://github.com/intel/pcm/blob/master/src/pcm-iio.cpp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcm-iio: Intel PCM I/O event monitor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-silent[suppress informational output]' \
  '-csv[CSV output to stdout]' \
  '-csv=-[CSV output to file]:file:_files' \
  '-csv-delimiter=[CSV delimiter character]:delim:' \
  '-human-readable[human-readable CSV output]' \
  '-list[list platform topology]' \
  '--list[list platform topology]' \
  '-root-port[include root port devices]' \
  '-i=-[number of iterations]:n:' \
  '*::pcm-iio args:_files' && ret=0
return ret
