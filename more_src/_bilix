#compdef bilix
# Documentation: https://github.com/HFrost0/bilix
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# HFrost0/bilix — bilibili downloader (Click-based CLI)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[show version]' \
  '-d+[download directory]:dir:_files -/' \
  '-q+[video quality (0 = highest)]:quality' \
  '-vc+[max concurrent video downloads]:n' \
  '-pc+[segment concurrency per media]:n' \
  '--cookie=[SESSDATA cookie for premium content]:cookie' \
  '-n+[number of uploads to download]:n' \
  '--order=[sort method]:order:(pubdate click scores stow dm)' \
  '--keyword=[search filter keyword]:keyword' \
  '-p+[episode range]:range' \
  '-sl+[max download speed]:speed' \
  '--image[also download cover image]' \
  '--subtitle[also download subtitles]' \
  '--dm[also download danmaku]' \
  '-oa[audio only]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'bilix command' compadd -- \
    v get_video s get_series up get_up cate get_cate fav get_favour col get_collect info
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
