#compdef bilix
# Documentation: https://man.archlinux.org/search?q=bilix
# Reference accessed: 2026-05-16

# HFrost0/bilix (typer); Homebrew: Formula/b/bilix.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'bilix command' compadd -- download get_video get_series info
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
