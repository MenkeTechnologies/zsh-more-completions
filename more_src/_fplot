#compdef fplot
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fplot.txt
# Plots columns from a FITS file using QDP/PLT Plot Package

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "xparm=[column for the x axis]:" \
  "yparm=[columns for the y axis]:" \
  "rows=[range of rows to plot]:" \
  "device=[PGPLOT graphics device]:" \
  "pltcmd=[PLT commands to execute]:" \
  "offset=[offset value]:" \
  "maxpts=[maximum number of points]:" \
  "binmode=[binning mode]:" \
  "sensecase=[case sensitive column names]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
