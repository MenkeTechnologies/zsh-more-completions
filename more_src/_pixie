#compdef px

# Zsh completion for Pixie (px CLI) - Kubernetes observability

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'auth:manage authentication'
      'collect-logs:collect Pixie logs'
      'create-cloud-certs:create cloud certificates'
      'debug:debug Pixie on a cluster'
      'delete:delete Pixie from a cluster'
      'demo:manage demo applications'
      'deploy:deploy Pixie to a cluster'
      'deploy-key:manage deploy keys'
      'get:get resources'
      'live:interactive Pixie UI'
      'run:run a PxL script'
      'script:manage PxL scripts'
      'update:update Pixie on a cluster'
      'version:show version'
    )
    _describe -t commands 'px command' commands && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(login logout)' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--deploy-key=[deploy key]:key' \
          '--cluster-name=[cluster name]:name' \
          '--namespace=[namespace]:namespace' \
          '--pem-memory-limit=[PEM memory limit]:limit' \
          '--use-etcd-operator[use etcd operator]' \
          '-y[assume yes]' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[PxL file]:file:_files -g "*.pxl"' \
          '--file=[PxL file]:file:_files -g "*.pxl"' \
          '-c+[cluster]:cluster' \
          '--cluster=[cluster]:cluster' \
          '-o+[output format]:format:(json table)' \
          '--output=[output format]:format:(json table)' \
          '*:script name' && ret=0
        ;;
      live)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[cluster]:cluster' \
          '--cluster=[cluster]:cluster' \
          '*:script name' && ret=0
        ;;
    esac
    ;;
esac

return ret
