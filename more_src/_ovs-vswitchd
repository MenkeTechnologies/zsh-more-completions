#compdef ovs-vswitchd
# _ovs-vswitchd — Open vSwitch userspace daemon CLI (OVS team, C); custom argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-vswitchd() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--dpdk[init DPDK]' \
        '--mlockall[lock memory]' \
        '--monitor[monitor mode]' \
        '--no-chdir[no chdir]' \
        '--no-self-confinement[no self confinement]' \
        '--detach[detach]' \
        '--pidfile=+[pid file]:file:_files' \
        '--no-pidfile[no pid file]' \
        '--user=+[run as user]:str:_users' \
        '-p+[ssl private key]:file:_files' \
        '--private-key=+[ssl private key]:file:_files' \
        '-c+[ssl certificate]:file:_files' \
        '--certificate=+[ssl certificate]:file:_files' \
        '-C+[ssl ca cert]:file:_files' \
        '--ca-cert=+[ssl ca cert]:file:_files' \
        '--bootstrap-ca-cert=+[bootstrap ca cert]:file:_files' \
        '--peer-ca-cert=+[peer ca cert]:file:_files' \
        '--ssl-protocols=+[ssl protocols]:str:' \
        '--ssl-ciphers=+[ssl ciphers]:str:' \
        '-v+[verbosity]:str:' \
        '--verbose=+[verbosity]:str:' \
        '--log-file=+[log file]:file:_files' \
        '--syslog-target=+[syslog target]:str:' \
        '--syslog-method=+[syslog method]:m:(libc unix udp null)' \
        '--unixctl=+[unixctl socket]:file:_files' \
        '*:database:'
}

_ovs-vswitchd "$@"
