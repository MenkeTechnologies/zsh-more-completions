#compdef jsctags
# Documentation: https://github.com/sergioramos/jsctags
# ctags-compatible code indexing for JavaScript using tern

local ret=1

_arguments -s \
  '(-h)-h[show help]' \
  '-f+[output exuberant ctags file (- for stdout; default JSON)]:tags file:_files' \
  '*:file:_files' && ret=0

return ret
