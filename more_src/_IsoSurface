#compdef IsoSurface
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/IsoSurface.html
# AFNI/SUMA isosurface extraction from a volume

local ret=1

_arguments -s -S \
  '-input[input volume for isosurface extraction]:dataset:_files' \
  '-shape[built-in shape (0-9) with grid size]:s:' \
  '-isoval[isosurface at specific volume value]:v:' \
  '-isorange[isosurface within value range]:v0:' \
  '-isocmask[isosurface based on mask condition]:mask:' \
  '-isorois[isosurface for each unique ROI value]' \
  '-isorois+dsets[isosurfaces and write labeled datasets]' \
  '-mergerois[combine all ROI surfaces into one]:lab_out:' \
  '-mergerois+dset[merge ROI surfaces with automatic naming]' \
  '-o_TYPE[output format and prefix]:prefix:' \
  '-Tsmooth[Taubin smoothing KPB NITER]:kpb:' \
  '-autocrop[crop input volume before extraction]' \
  '-remesh[remesh surface to edge fraction]:frac:' \
  '-xform[apply transformation]:xform:(mask shift none)' \
  '-debug[set debug level 0-3]:dbg:' \
  '(-novolreg -noxform)-novolreg[ignore volume transformations]' \
  '(-novolreg -noxform)-noxform[ignore volume transformations]' \
  '-setenv[set environment variable]:env:' \
  '*:dataset:_files' && ret=0

return ret
