#compdef grdfill
# Documentation: https://docs.generic-mapping-tools.org/latest/grdfill.html
# Source: GenericMappingTools/gmt classic-mode grdfill — fill NaN holes in a grid.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[fill algorithm]:algo:(c g n s)' \
    '-G+[output grid file]:file:_files' \
    '-L+[list hole bounding boxes (append p for polygons)]:opts:_default' \
    '-N+[node value identifying holes (default NaN)]:value:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
