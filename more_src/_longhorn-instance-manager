#compdef longhorn-instance-manager
# _longhorn-instance-manager — Longhorn per-node engine/replica process manager (longhorn/longhorn-instance-manager)
# upstream: https://github.com/longhorn/longhorn-instance-manager
# Flags from main.go + app/cmd/start.go (urfave/cli v1) on tip.

_longhorn-instance-manager() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version and exit]' \
        '--url=[instance-manager URL]:url:_urls' \
        '--tls-dir=[TLS cert/key directory]:dir:_files -/' \
        '--debug[enable debug logging]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                daemon:'run the instance-manager daemon'
                process:'manage tracked processes'
                version:'print version information'
            )
            _describe -t commands 'longhorn-instance-manager command' cmds
            ;;
        args)
            case $words[1] in
                daemon)
                    _arguments \
                        '--listen=[gRPC listen address]:host\:port:' \
                        '--logs-dir=[per-process logs directory]:dir:_files -/' \
                        '--port-range=[allowed engine/replica port range]:range:' \
                        '--spdk-port-range=[allowed SPDK port range]:range:' \
                        '--spdk-enabled[enable SPDK data engine]'
                    ;;
            esac
            ;;
    esac
}

_longhorn-instance-manager "$@"
