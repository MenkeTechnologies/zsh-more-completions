#compdef git-pile
# Documentation: https://github.com/git-pile/git-pile
# git pile — manage a pile of patches on top of a git branch via a separate pile branch.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:(init setup genpatches genbranch genlinear-branch format-patch am baseline destroy reset)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      format-patch)
        _arguments -s \
          '(-o --output-directory)'{-o+,--output-directory=}'[output directory for patches]:dir:_files -/' \
          '*::arg:_files' && ret=0
        ;;
      *)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '*::arg:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
