#compdef aws-vault

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add credentials to keyring'
  'clear:clear all temp creds'
  'completion:generate completion'
  'edit:edit AWS config'
  'exec:execute command with creds'
  'export:export creds'
  'help:show help'
  'list:list profiles'
  'login:open AWS console'
  'remove:remove credentials'
  'rotate:rotate credentials'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--debug[debug]' \
  '*--keychain=[keychain]:k:' \
  '*--backend=[backend]:b:(file keychain kwallet pass secret-service wincred)' \
  '*--prompt=[prompt driver]:p:(terminal pinentry osascript zenity ykman ykchalresp)' \
  '*--pass-cmd=[pass command]:c:' \
  '*--pass-dir=[pass dir]:d:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'aws-vault command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (exec)
        _arguments \
          '(-d --duration)'{-d+,--duration=}'[session duration]:t:' \
          '(--assume-role-duration)--assume-role-duration=[role dur]:t:' \
          '(--mfa-token)--mfa-token=[MFA token]:t:' \
          '(--no-session)--no-session[no session]' \
          '(--region)--region=[region]:r:' \
          '(--server)--server[start metadata server]' \
          '(--ec2-server)--ec2-server[EC2 metadata server]' \
          '(--ecs-server)--ecs-server[ECS metadata server]' \
          '(--no-server)--no-server[no server]' \
          '(--lazy)--lazy[lazy]' \
          '(--json)--json[output JSON]' \
          '*: :' && ret=0 ;;
      (export)
        _arguments \
          '(--format)--format=[format]:f:(json env exports ini powershell)' \
          '(-d --duration)'{-d+,--duration=}'[duration]:t:' \
          '(--mfa-token)--mfa-token=[MFA token]:t:' \
          '(--no-session)--no-session[no session]' \
          '*: :' && ret=0 ;;
      (login)
        _arguments \
          '(-d --duration)'{-d+,--duration=}'[duration]:t:' \
          '(--mfa-token)--mfa-token=[MFA token]:t:' \
          '(--region)--region=[region]:r:' \
          '(--path)--path=[console path]:p:' \
          '(--federation-token-name)--federation-token-name=[federation token name]:n:' \
          '(--stdout)--stdout[print URL only]' \
          '*: :' && ret=0 ;;
      (rotate)
        _arguments \
          '(--no-session)--no-session[no session]' \
          '(--mfa-token)--mfa-token=[MFA token]:t:' \
          '*: :' && ret=0 ;;
      (add|edit|list|remove|clear)
        _arguments '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
