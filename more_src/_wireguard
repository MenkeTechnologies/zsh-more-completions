#compdef wg

# WireGuard tools completion

_wg_interfaces() {
  local -a interfaces
  interfaces=(${(f)"$(command wg show interfaces 2>/dev/null)"})
  _describe -t interfaces 'WireGuard interface' interfaces
}

_wg_subcommands() {
  local -a subcmds=(
    'show:Show interface information'
    'showconf:Show running configuration'
    'set:Set interface configuration'
    'setconf:Set configuration from file'
    'addconf:Add configuration from file'
    'syncconf:Sync configuration from file'
    'genkey:Generate a private key'
    'genpsk:Generate a preshared key'
    'pubkey:Derive a public key from a private key'
    'strip:Strip comments and normalize config'
  )
  _describe -t commands 'wg subcommand' subcmds
}

_wg() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_wg_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        show)
          _arguments \
            '1:interface:_wg_interfaces' \
            '2:property:(all interfaces latest-handshakes endpoints allowed-ips fwmark listen-port peers preshared-keys public-key private-key transfer persistent-keepalive dump)'
          ;;
        showconf)
          _arguments \
            '1:interface:_wg_interfaces'
          ;;
        set)
          _arguments \
            '1:interface:_wg_interfaces' \
            '--listen-port=[listen port]:port' \
            '--fwmark=[firewall mark]:fwmark' \
            '--private-key=[private key file]:file:_files' \
            '--peer=[peer public key]:public key' \
            '--remove[remove the peer]' \
            '--preshared-key=[preshared key file]:file:_files' \
            '--endpoint=[peer endpoint]:endpoint (host\:port)' \
            '--persistent-keepalive=[keepalive interval]:seconds' \
            '--allowed-ips=[allowed IP addresses]:CIDR list'
          ;;
        setconf|addconf|syncconf)
          _arguments \
            '1:interface:_wg_interfaces' \
            '2:config file:_files'
          ;;
        genkey|genpsk|pubkey)
          ;;
        strip)
          _arguments \
            '1:config file:_files'
          ;;
      esac
      ;;
  esac
}

_wg "$@"
