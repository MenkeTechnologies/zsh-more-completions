#compdef antsSliceRegularizedRegistration
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsSliceRegularizedRegistration.cxx — per-slice 2D registration with polynomial regularization (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '*'{-m+,--metric=}'[similarity metric per stage]:spec:_default' \
    '(-x --mask)'{-x+,--mask=}'[mask in fixed-image space]:file:_files -g "*.{nii,nii.gz}"' \
    '(-n --interpolation)'{-n+,--interpolation=}'[interpolation]:method:(Linear NearestNeighbor MultiLabel Gaussian BSpline CosineWindowedSinc WelchWindowedSinc HammingWindowedSinc LanczosWindowedSinc)' \
    '*'{-t+,--transform=}'[transform spec per stage]:spec:_default' \
    '*'{-i+,--iterations=}'[per-stage iterations]:spec:_default' \
    '*'{-s+,--smoothingSigmas=}'[per-stage smoothing sigmas]:spec:_default' \
    '*'{-f+,--shrinkFactors=}'[per-stage shrink factors]:spec:_default' \
    '(-o --output)'{-o+,--output=}'[output spec]:spec:_default' \
    '(-p --polydegree)'{-p+,--polydegree=}'[polynomial degree for regularization]:n:_default' \
    '(- *)'{-v,--verbose}'[verbose]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
