#compdef sfill
# _sfill — van Hauser secure-delete sfill CLI for securely wiping free disk space on a filesystem by writing repeated random patterns Gutmann standard verifying after deletion preventing data recovery (THC team, C); getopt
# upstream: https://github.com/THC-OSS/secure-delete

_sfill() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-f[fast non-secure single pass]' \
        '-l[fewer passes]' \
        '-ll[less passes]' \
        '-z[zero last write]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-i[inode only]' \
        '*:directory:_files -/'
}

_sfill "$@"
