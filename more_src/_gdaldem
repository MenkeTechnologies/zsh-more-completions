#compdef gdaldem

local curcontext="$curcontext" state line ret=1
local -a modes

modes=(
  'hillshade:generate hillshade map'
  'slope:generate slope map'
  'aspect:generate aspect map'
  'color-relief:generate colored relief'
  'TRI:Terrain Ruggedness Index'
  'TPI:Topographic Position Index'
  'roughness:roughness'
)

_arguments -C -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-of+[output format]:format:' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-b+[band]:band:' \
  '-q[quiet]' \
  '-z+[vertical exaggeration]:factor:' \
  '-s+[scale]:scale:' \
  '-az+[azimuth]:angle:' \
  '-alt+[altitude]:angle:' \
  '-alg+[algorithm]:alg:(Horn ZevenbergenThorne)' \
  '-combined[combined hillshade]' \
  '-multidirectional[multidirectional hillshade]' \
  '-igor[igor mode hillshade]' \
  '-compute_edges[compute values at edges]' \
  '-trigonometric[trigonometric output]' \
  '-zero_for_flat[zero for flat areas]' \
  '-alpha[add alpha channel for color-relief]' \
  '-exact_color_entry[exact color entries only]' \
  '-nearest_color_entry[nearest color entry]' \
  '1: :->mode' \
  '*::arg:->args' && ret=0

case $state in
  (mode)
    _describe -t modes 'gdaldem mode' modes && ret=0
    ;;
  (args)
    _files && ret=0
    ;;
esac

return ret
