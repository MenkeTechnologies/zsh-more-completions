#compdef gdal_polygonize
# Documentation: https://man.archlinux.org/search?q=gdal_polygonize
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-8[use 8-connectedness]' \
  '-nomask[do not use default mask]' \
  '-mask+[mask file]:file:_files' \
  '-of+[output format]:format:' \
  '-b+[band number]:band:' \
  '-lco+[layer creation option]:NAME=VALUE:' \
  '-q[quiet]' \
  '-overwrite[overwrite output]' \
  '1:source raster:_files' \
  '2:dest vector:_files' \
  '3::layer name:' \
  '4::field name:' && ret=0

return ret
