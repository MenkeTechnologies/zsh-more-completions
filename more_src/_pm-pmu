#compdef pm-pmu
# Documentation: https://man.archlinux.org/search?q=pm-pmu
# Reference accessed: 2026-05-16

# pm-pmu: pm-utils PowerPC PMU command (kernel helper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '1:action:(set-server battery-status get-power-state suspend resume)' \
  '*::pm-pmu args:_files' && ret=0
return ret
