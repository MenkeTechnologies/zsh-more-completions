#compdef stride
# Documentation: https://webclu.bio.wzw.tum.de/stride/stride.doc
# STRIDE - protein secondary structure assignment from atomic coordinates

local ret=1

_arguments -s \
  '-h[report hydrogen bonds]' \
  '-o[report secondary structure summary only]' \
  '-f-[write output to file rather than stdout]:output file:_files' \
  '-r-[read only the given chain ids]:chain ids:' \
  '-c-[process only the given chain ids]:chain ids:' \
  '-m-[generate a Molscript file]:molscript file:_files' \
  '-q-[generate FASTA sequence file and exit]::fasta file:_files' \
  '*:PDB file:_files -g "*.(pdb|ent|PDB|ENT)"' && ret=0

return ret
