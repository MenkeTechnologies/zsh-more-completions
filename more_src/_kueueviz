#compdef kueueviz
# _kueueviz — Kueue dashboard backend (Gin HTTP + websocket API + bundled SPA in front of the Kueue control plane)
# upstream: https://github.com/kubernetes-sigs/kueue
# Source: cmd/kueueviz/backend/main.go on tip; no CLI flags — runtime config is driven by env vars (KUEUEVIZ_PORT, KUEUEVIZ_AUTH_MODE Disabled|TokenReview, KUEUEVIZ_AUTH_TOKEN_REVIEW_CACHE_TTL, KUEUEVIZ_AUTH_TOKEN_REVIEW_NEGATIVE_CACHE_TTL, KUEUEVIZ_AUTH_TOKEN_REVIEW_AUDIENCES, GIN_MODE).

_kueueviz() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_kueueviz "$@"
