#compdef create-playwright
# Documentation: https://www.npmjs.com/package/create-playwright
# Reference accessed: 2026-05-24
# Verified: npx create-playwright --help.

# Zsh completion for create-playwright - Playwright end-to-end test scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--browser=[browsers for default config]:browser:(chromium firefox webkit)' \
  '--no-browsers[do not download browsers]' \
  '--no-examples[do not create example test files]' \
  '--install-deps[install dependencies]' \
  '--next[install @next version of Playwright]' \
  '--beta[install @beta version of Playwright]' \
  '--ct[install Playwright Component testing]' \
  '--quiet[do not ask interactive prompts]' \
  '--gha[install GitHub Actions workflow]' \
  '--lang=[language]:lang:(js TypeScript)' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':root directory:_directories' && ret=0

return ret
