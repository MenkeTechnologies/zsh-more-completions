#compdef glftpd
# Documentation: https://man.archlinux.org/search?q=glftpd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[show version]' \
  '-d[debug]' \
  '-l+[loglevel]:n:' \
  '-c+[config file]:file:_files -g "*.conf"' \
  '-p+[port]:port:' && ret=0

return ret
