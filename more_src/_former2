#compdef former2

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'generate:generate CloudFormation from live AWS resources'
      'template:emit CloudFormation template to stdout'
    )
    _describe -t commands 'former2 command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      generate)
        _arguments -s -S \
          '(-r --region)'{-r,--region}'=[AWS region]:region' \
          '(-o --output)'{-o,--output}'=[output path]:path:_files' \
          '(-f --filter)'{-f,--filter}'=[resource type filter]:filter' \
          '*: : _default' \
          && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
