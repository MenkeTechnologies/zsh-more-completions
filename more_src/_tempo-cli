#compdef tempo-cli
# Documentation: https://man.archlinux.org/search?q=tempo-cli
# Reference accessed: 2026-05-16

# tempo-cli: Grafana Tempo CLI for trace ingestion/diagnostics
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'list:list blocks/objects'
  'list-blocks:list tenant blocks'
  'view:view a block'
  'analyze:analyze block contents'
  'rewrite-meta:rewrite block metadata'
  'gen:generate test traces'
  'migrate:migrate data'
  'compact:run compaction'
  'completion:emit shell completion'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config-file=[config file]:file:_files' \
  '--backend=[storage backend]:backend:(s3 gcs azure local)' \
  '--bucket=[bucket name]:bucket:' \
  '--tenant=[tenant id]:tenant:' \
  '--meta-version=[meta version]:ver:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'tempo-cli command' commands && ret=0 ;;
esac
return ret
