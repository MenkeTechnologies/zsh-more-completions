#compdef cfchecks
# Documentation: https://github.com/cedadev/cf-checker
# CF conventions compliance checker for NetCDF files (cfchecker)

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-a[path or URL to CF area types table]:area_types_xml:_files' \
  '-r[path or URL to CF region names table]:regions_xml:_files' \
  '-s[path or URL to CF standard names table]:std_names_xml:_files' \
  '-v[CF version to check against]:cf_version' \
  '-t[cache time in days]:cache_days' \
  '*:netcdf file:_files' && ret=0

return ret
