#compdef activemq

local -a subcommands
subcommands=(
    'start:Start the broker'
    'stop:Stop the broker'
    'restart:Restart the broker'
    'status:Check broker status'
    'create:Create a broker instance'
    'console:Start broker and open web console'
    'list:List all running brokers'
    'query:Display broker statistics'
    'browse:Browse messages in a destination'
    'bstat:Display broker statistics (short)'
    'dstat:Display destination statistics'
    'purge:Purge a destination'
    'encrypt:Encrypt values for config'
    'decrypt:Decrypt values from config'
    'producer:Send messages'
    'consumer:Receive messages'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'activemq subcommand' subcommands
        ;;
    args)
        case $words[1] in
            start|console)
                _arguments \
                    '--broker[Broker URI]:uri' \
                    '--pid[PID file location]:file:_files' \
                    '-Dactivemq.base=-[Set ActiveMQ base]:dir:_directories' \
                    '-Dactivemq.data=-[Set data directory]:dir:_directories' \
                    '-Dactivemq.conf=-[Set config directory]:dir:_directories'
                ;;
            create)
                _arguments \
                    '--amqconf[Config file]:file:_files' \
                    '--force[Overwrite existing]' \
                    '*:instance directory:_directories'
                ;;
            producer)
                _arguments \
                    '--brokerUrl[Broker URL]:url' \
                    '--user[Username]:user' \
                    '--password[Password]:pass' \
                    '--destination[Destination name]:dest' \
                    '--persistent[Use persistent delivery]' \
                    '--messageSize[Message size]:bytes' \
                    '--messageCount[Number of messages]:count' \
                    '--sleep[Sleep between sends (ms)]:ms' \
                    '--textMessageSize[Text message size]:bytes'
                ;;
            consumer)
                _arguments \
                    '--brokerUrl[Broker URL]:url' \
                    '--user[Username]:user' \
                    '--password[Password]:pass' \
                    '--destination[Destination name]:dest' \
                    '--messageCount[Number of messages]:count' \
                    '--sleep[Sleep between receives (ms)]:ms' \
                    '--ackMode[Acknowledgment mode]:mode:(AUTO_ACKNOWLEDGE CLIENT_ACKNOWLEDGE DUPS_OK_ACKNOWLEDGE SESSION_TRANSACTED)'
                ;;
            browse|purge)
                _arguments \
                    '--brokerUrl[Broker URL]:url' \
                    '--user[Username]:user' \
                    '--password[Password]:pass' \
                    '*:destination'
                ;;
            *)
                _arguments '*:arguments'
                ;;
        esac
        ;;
esac
