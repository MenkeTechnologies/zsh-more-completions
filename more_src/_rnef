#compdef rnef
# Documentation: https://www.rnef.dev/docs/cli
# React Native Enterprise Framework CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:((
    run\:ios\:"run iOS app on simulator or device"
    run\:android\:"run Android app on emulator or device"
    build\:ios\:"build iOS app"
    build\:android\:"build Android app"
    sign\:ios\:"sign iOS app"
    sign\:android\:"sign Android app with keystore"
    create-keystore\:"create an Android keystore"
    remote-cache\:"interact with the remote build cache"
  ))' \
  '*::args:_files' && ret=0

return ret
