#compdef diff-highlight

_diff-highlight() {
    local curcontext="$curcontext" state line ret=1

    # diff-highlight is a filter that reads diff output from stdin
    # and highlights changed words. It has no flags of its own.
    _arguments \
        '(- *)--help[show help message]' && ret=0

    return ret
}

_diff-highlight "$@"
