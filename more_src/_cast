#compdef cast

# Zsh completion for cast - Foundry's swiss army knife for Ethereum

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'abi-decode:decode ABI-encoded data'
  'abi-encode:ABI-encode arguments using a Solidity function signature'
  'access-list:create an access list for a transaction'
  'address-zero:print the zero address'
  'balance:get the balance of an account'
  'base-fee:get the basefee of a block'
  'block:get information about a block'
  'block-number:get the latest block number'
  'call:perform a call on an account without publishing a transaction'
  'calldata:ABI-encode a function with arguments'
  'calldata-decode:decode ABI-encoded calldata'
  'chain:get the symbolic name of the current chain'
  'chain-id:get the Ethereum chain ID'
  'client:get the current client version'
  'code:get the runtime bytecode of a contract'
  'completions:generate shell completions'
  'compute-address:compute the contract address from a given nonce and deployer address'
  'create2:generate deterministic contract addresses based on CREATE2'
  'decode-transaction:decode a serialized transaction'
  'estimate:estimate the gas cost of a transaction'
  'find-block:get the block number closest to the provided timestamp'
  'from-bin:convert binary data into hex data'
  'from-fix:convert a fixed point number into an integer'
  'from-rlp:decode RLP encoded data'
  'from-utf8:convert UTF8 to hex'
  'from-wei:convert wei into an ETH amount'
  'gas-price:get the current gas price'
  'generate-fig-spec:generate Fig autocompletion spec'
  'hash-zero:print the zero hash'
  'index:compute the storage slot for an entry in a mapping'
  'interface:generate a Solidity interface from a given ABI'
  'keccak:hash arbitrary data using keccak-256'
  'logs:get logs by signature or topic'
  'lookup-address:perform an ENS reverse lookup'
  'max-int:get the maximum value for the given integer type'
  'max-uint:get the maximum value for the given unsigned integer type'
  'min-int:get the minimum value for the given integer type'
  'mktx:build and sign a transaction'
  'namehash:calculate the ENS namehash of a name'
  'nonce:get the nonce for an account'
  'parse-bytes32-address:parses a checksummed address from bytes32'
  'parse-bytes32-string:parses a string from bytes32'
  'pretty-calldata:pretty print calldata'
  'proof:generate a storage proof for a given storage slot'
  'publish:publish a raw transaction to the network'
  'rpc:perform a raw JSON-RPC request'
  'receipt:get the transaction receipt'
  'resolve-name:perform an ENS lookup'
  'rlp:RLP encode hex data'
  'run:runs a published transaction in a local environment'
  'send:sign and publish a transaction'
  'shl:perform a left shift'
  'shr:perform a right shift'
  'sig:get the selector for a function'
  'sig-event:generate event signatures from event string'
  'storage:get the raw value of a contract storage slot'
  'to-ascii:convert hex data to an ASCII string'
  'to-base:convert a number to a different base'
  'to-bytes32:left-pads hex data to 32 bytes'
  'to-checksum-address:convert an address to a checksummed format'
  'to-dec:convert a number to decimal'
  'to-fix:convert an integer to a fixed point number'
  'to-hex:convert a number to hexadecimal'
  'to-hexdata:normalize hex data'
  'to-int256:convert a number to int256'
  'to-rlp:RLP encode hex data'
  'to-uint256:convert a number to uint256'
  'to-unit:convert an ETH amount into another unit'
  'to-utf8:convert hex data to a UTF8 string'
  'to-wei:convert an ETH amount into wei'
  'tx:get information about a transaction'
  'upload-signature:upload selectors to https://api.openchain.xyz'
  'wait-for-tx:wait for a transaction to be confirmed'
  'wallet:wallet management utilities'
  '4byte:get the function signatures for the given selector from openchain'
  '4byte-decode:decode ABI-encoded calldata using openchain.xyz'
  '4byte-event:get the event signature for a given topic 0 from openchain'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'cast subcommand' commands && ret=0
    ;;
  args)
    case $words[1] in
      send)
        _arguments \
          '--rpc-url[the RPC endpoint]:url:' \
          '--from[the sender account]:address:' \
          '(-i --interactive)'{-i,--interactive}'[interactive password input]' \
          '--private-key[private key]:key:' \
          '--mnemonic[mnemonic phrase]:mnemonic:' \
          '--mnemonic-passphrase[mnemonic passphrase]:passphrase:' \
          '--mnemonic-derivation-path[derivation path]:path:' \
          '--mnemonic-index[mnemonic index]:index:' \
          '--keystore[keystore file path]:file:_files' \
          '--password[keystore password]:password:' \
          '--ledger[use a Ledger hardware wallet]' \
          '--trezor[use a Trezor hardware wallet]' \
          '--gas-limit[gas limit]:limit:' \
          '--gas-price[gas price]:price:' \
          '--priority-gas-price[max priority fee per gas]:price:' \
          '--value[ether to send in the transaction]:amount:' \
          '--nonce[transaction nonce]:nonce:' \
          '--legacy[send a legacy transaction]' \
          '--create[create a contract instead of calling]:bytecode:' \
          '--unlocked[send via an unlocked account]' \
          '--confirmations[number of confirmations to wait for]:num:' \
          '--async[do not wait for receipt]' \
          '--chain[chain id or name]:chain:' \
          '*:args:' && ret=0
        ;;
      call)
        _arguments \
          '--rpc-url[the RPC endpoint]:url:' \
          '--from[the sender account]:address:' \
          '--block[block to use]:block:' \
          '--gas-limit[gas limit]:limit:' \
          '--value[ether to send]:amount:' \
          '--data[transaction data]:data:' \
          '--trace[print trace]' \
          '--debug[debug the call]' \
          '*:args:' && ret=0
        ;;
      balance)
        _arguments \
          '--rpc-url[the RPC endpoint]:url:' \
          '(-e --ether)'{-e,--ether}'[output in ETH instead of wei]' \
          '--block[block to use]:block:' \
          '1:address:' && ret=0
        ;;
      block|tx|receipt)
        _arguments \
          '--rpc-url[the RPC endpoint]:url:' \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '*:hash or number:' && ret=0
        ;;
      wallet)
        local -a wallet_commands=(
          'new:create a new keypair'
          'new-mnemonic:generate a new mnemonic'
          'vanity:generate a vanity address'
          'address:get the wallet address'
          'sign:sign a message'
          'verify:verify a signed message'
          'import:import a private key into the keystore'
          'list:list all the accounts in the keystore'
          'private-key:derive private key from mnemonic'
          'decrypt-keystore:decrypts a keystore file'
        )
        _describe -t wallet-commands 'wallet command' wallet_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
