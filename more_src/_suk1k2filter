#compdef suk1k2filter
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/suk1k2filter.c
# symmetric box-like K-domain filter defined by amps and wavenumbers

local ret=1

_arguments -s -S \
  'k1=[k1]:k1:' \
  'k2=[k2]:k2:' \
  'amps1=[amps1]:amps1:' \
  'amps2=[amps2]:amps2:' \
  'd1=[d1]:d1:' \
  'd2=[d2]:d2:' \
  'quad=[quad]:quad:' \
  'verbose=[verbose]:verbose:' \
  'tmpdir=[tmpdir]:tmpdir:' \
  '*:file:_files' && ret=0

return ret
