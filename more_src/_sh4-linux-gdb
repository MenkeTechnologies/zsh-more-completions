#compdef sh4-linux-gdb sh4-linux-gnu-gdb sh-linux-gdb
# _sh4-linux-gdb — GNU binutils-gdb sh4-linux-gdb CLI cross-debugger build for Hitachi Renesas SuperH SH-4 SH-3 SH-2A 32-bit Linux SEGA Dreamcast SH7785 SH7780 SH7750 routers HP-UX appliances supporting ELF DWARF Python scripting remote serial gdbserver QEMU TCG (GNU team, C); getopt
# upstream: https://www.gnu.org/software/gdb/

_sh4-linux-gdb() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--silent[silent]' \
        '-nx[do not read .gdbinit]' \
        '-nh[do not read ~/.gdbinit]' \
        '-batch[exit after running commands]' \
        '-batch-silent[batch silent]' \
        '-return-child-result[return child exit code]' \
        '-x+[command file]:file:_files -g "*.gdb *.py"' \
        '--command=+[file]:file:_files -g "*.gdb *.py"' \
        '-ex+[command]:str:' \
        '--eval-command=+[command]:str:' \
        '-iex+[init command]:str:' \
        '-ix+[init file]:file:_files' \
        '-p+[pid]:_pids' \
        '--pid=+[pid]:_pids' \
        '-c+[core file]:file:_files -g "core* *.core"' \
        '--core=+[file]:file:_files -g "core* *.core"' \
        '-s+[symbol file]:file:_files -g "*.elf *.axf *.out"' \
        '--symbols=+[file]:file:_files -g "*.elf *.axf *.out"' \
        '-e+[executable]:file:_files' \
        '--exec=+[file]:file:_files' \
        '-d+[directory]:dir:_files -/' \
        '--directory=+[dir]:dir:_files -/' \
        '--cd=+[dir]:dir:_files -/' \
        '--tui[text user interface]' \
        '-tui[text user interface]' \
        '--tty=+[device]:file:_files -g "/dev/tty* /dev/pts/*"' \
        '--interpreter=+[i]:i:(console mi mi2 mi3)' \
        '--write[open program for writing]' \
        '*:elf file:_files -g "*.elf *.axf *.out"'
}

_sh4-linux-gdb "$@"
