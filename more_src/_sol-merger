#compdef sol-merger
# Documentation: https://github.com/RyuuGan/sol-merger/blob/develop/README.md
# sol-merger - merges all imports into a single file for Solidity contracts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --append)'{-a,--append}'=[suffix to append to output files]:suffix:' \
  '*--export-plugin=[load a post-processing export plugin]:plugin:' \
  '*--additional-root=[additional root folder to search for contracts]:folder:_files -/' \
  '*:solidity glob or output dir:_files' && ret=0

return ret
