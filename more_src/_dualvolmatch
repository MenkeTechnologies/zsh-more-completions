#compdef dualvolmatch
# Documentation: https://bio3d.colorado.edu/imod/doc/man/dualvolmatch.html
# Find initial transformation between dual-axis volumes

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-name -n -RootName)'{-name,-n,-RootName}'[Root name of dataset, excluding a and b]:value' \
  '(-atob -a -MatchAtoB)'{-atob,-a,-MatchAtoB}'[Match A to B instead of B to A]' \
  '(-binning -b -BinningToApply)'{-binning,-b,-BinningToApply}'[Amount to bin reconstructions for reprojection and patch...]:value' \
  '(-tilt -ti -TiltAngleMaxAndStep)'{-tilt,-ti,-TiltAngleMaxAndStep}'[Maximum tilt angle to reproject and the increment between]:value' \
  '-refine[option.]' \
  '(-refine -r -RefineTiltAngles)'{-refine,-r,-RefineTiltAngles}'[Number of times to refine tilt angle estimates. On each...]:value' \
  '(-center -c -CenterShiftLimit)'{-center,-c,-CenterShiftLimit}'[Maximum shift in Z between tomograms at the patch nearest...]:value' \
  '(-maxresid -m -MaximumResidual)'{-maxresid,-m,-MaximumResidual}'[The limiting value for the mean residual from running...]:value' \
  '(-scan -sc -ScanRotationMaxAndStep)'{-scan,-sc,-ScanRotationMaxAndStep}'[Either the maximum angle and angular step size at which to...]:value' \
  '(-final -f -FinalOutputFile)'{-final,-f,-FinalOutputFile}'[Name for output file with final 3D transformation (default]:file:_files' \
  '(-style -st -NamingStyle)'{-style,-st,-NamingStyle}'[0 if image files have descriptive extensions like...]:value' \
  '(-test -te -TestMode)'{-test,-te,-TestMode}'[1 to print out all output from Matchrotpairs and Refine...]:value' \
  '-StandardInput[read parameters from standard input]' \
  '-usage[print usage]' \
  '*:file:_files' && ret=0

return ret
