#compdef ksysguardd
# Documentation: https://manpages.debian.org/jessie/ksysguardd/ksysguardd.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian jessie ksysguardd(1) manpage. Traditional getopt-
# style daemon (not KDE/Qt parser).
# Removed from prior file: fabricated --help/--version flags (uses -h
# only) and bogus man.archlinux.org search URL.

# ksysguardd: KSysguard data collection daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show usage]' \
  '-d[daemonize]' \
  '-i[bind to all interfaces]' \
  '-p[port to listen on]:port:' \
  '-f[configuration file]:file:_files' && ret=0
return ret
