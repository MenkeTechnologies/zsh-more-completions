#compdef candumpjs
# ============================================================================
#  _candumpjs — candumpjs: NMEA 2000 marine CAN bus traffic dumper (CanBoat)
#
#  Source-direct extraction from
#    https://github.com/canboat/canboatjs/blob/master/lib/bin/candumpjs.ts
#    https://github.com/minimistjs/minimist (the minimist library
#    by substack / James Halliday)
#
#  Maintained by CanBoat contributors (canboat/canboatjs).  117 GH
#  stars.  candumpjs dumps NMEA 2000 (N2K) marine CAN bus traffic to
#  stdout — used by boat/marine systems integrators for diagnosing
#  CAN-bus communication between marine electronics (Garmin, Raymarine,
#  Furuno, Lowrance chartplotters/radars/autopilots/depth sounders/
#  wind instruments).  Reads from a SocketCAN device, parses PGN
#  (Parameter Group Number) messages, and emits JSON / candump-format
#  output with field decoding via the canboat NMEA 2000 PGN database.
#  Part of the CanBoat ecosystem (the open-source NMEA 2000 toolkit).
#  Sister tools: canboat (C version of canboat parsers), SignalK (in
#  corpus — marine data exchange), candump (Linux SocketCAN dump, in
#  corpus), cansend (in corpus).
#
#  CLI library taxonomy update: 8th TypeScript-Node CLI library —
#  James Halliday's (substack) **minimist** (minimistjs/minimist).
#  TypeScript-Node ecosystem now has 8 documented CLI libraries
#  (R340 oclif + R341 yargs + R343 tj/commander.js + R393 meow +
#  R395 node:util.parseArgs + R396 sade + R400 cac + R402 minimist)
#  — TIED with Rust (9) and Go (9) — JUST ONE SHY of taking the TOP
#  SPOT at the most-documented CLI language tier.
#
#  minimist (minimistjs/minimist, originally substack/minimist) is
#  James "substack" Halliday's ORIGINAL Node.js arg parser — the
#  GRANDFATHER of all Node.js CLI libraries.  Created in 2013 as a
#  tiny ~1KB zero-dependency replacement for optimist (substack's
#  earlier parser).  Used by THOUSANDS of npm packages including
#  patch-package (IN CORPUS via _patch-package — 11194 stars), Bower
#  (legacy package manager), Colyseus (multiplayer game framework
#  6954 stars), AbacatePay MCP server, gramio bot framework, vexip-ui
#  Vue3 UI lib, EdgelessPE edgeless-bot, asaricorp mcp-shopify,
#  skychat-cli, andywer/puppet-run, RCVolus/lol-pick-ban-ui, antdpro/
#  create-antdp, mdmower/doi-resolver, ds300/patch-package, canboat/
#  canboatjs (candumpjs/canbridge/n2k-from-actisense/etc.), and
#  HUNDREDS of legacy Node.js tools.  minimist is one of the MOST-
#  INSTALLED npm packages of all time (billions of downloads since
#  2013).  Modern Node.js tools mostly prefer yargs/commander/cac/
#  sade/meow over minimist due to its lack of subcommand support
#  and help generation, but minimist remains widely deployed in
#  legacy codebases.
#
#  minimist API:
#    import minimist from 'minimist';
#    // or: const minimist = require('minimist');
#
#    const argv = minimist(process.argv.slice(2), {
#      // Short-to-long alias mapping
#      alias: {
#        h: 'help',
#        v: 'verbose',
#        o: 'output',
#      },
#
#      // Force these arg names to be parsed as strings
#      string: ['output', 'config', 'host'],
#
#      // Force these arg names to be parsed as booleans
#      boolean: ['help', 'verbose', 'force'],
#
#      // Default values
#      default: {
#        port: 8080,
#        host: 'localhost',
#      },
#
#      // Stop parsing at first non-option (for nested CLIs)
#      stopEarly: false,
#
#      // Handler for unknown flags (return false to ignore)
#      unknown: (arg) => {
#        console.error(`Unknown: ${arg}`);
#        return false;
#      },
#
#      // Treat -- as separator (args after -- go to argv['--'])
#      '--': true,
#    });
#
#    // argv._ = positional args array
#    // argv.foo = parsed flag value
#    // argv['--'] = args after `--` (when '--': true)
#
#  minimist distinctive features:
#    - TINY ~1KB MINIFIED — the ORIGINAL Node.js arg parser, ZERO
#      DEPENDENCIES; one of the smallest npm packages
#    - IMPERATIVE FUNCTION CALL — `minimist(args, opts)` returns parsed
#      object directly; no class instances, no fluent builder, no
#      command/subcommand structure
#    - SCHEMA-DRIVEN via 2nd OPTS arg — `{ alias, string, boolean,
#      default, stopEarly, unknown, '--' }` keys
#    - `alias: { h: 'help' }` — map SHORT char to LONG name; if `argv.h`
#      is set, `argv.help` is also set (and vice versa)
#    - `string: ['output']` — force flag names to STRING type (prevents
#      "1" from being parsed as number 1)
#    - `boolean: ['verbose']` — force flag names to BOOLEAN type
#      (avoids consuming next arg as value)
#    - `default: { port: 8080 }` — DEFAULT VALUES per flag name
#    - `stopEarly: true` — stop parsing at FIRST non-option arg
#      (useful for nested CLI dispatch like `npm run X`)
#    - `unknown: (arg) => boolean` — callback for unknown flags;
#      return false to ignore, true to include in result
#    - `'--': true` — treat `--` as SEPARATOR; args after `--` go
#      into `argv['--']` array (when this option is set)
#    - RESULT OBJECT:
#      * `argv._` — POSITIONAL args array (underscore-prefixed
#        property)
#      * `argv.NAME` — parsed flag value (string, boolean, or number
#        depending on type inference)
#      * `argv['--']` — args after `--` separator (when `'--': true`)
#    - AUTO TYPE INFERENCE — `--port=8080` → number 8080, `--name=foo`
#      → string "foo", `--verbose` → boolean true (unless schema
#      forces otherwise)
#    - KEBAB-TO-CAMEL-CASE: minimist DOES NOT auto-convert (vs meow/
#      cac which do); caller must access via `argv['no-enums']`
#      (bracket notation for hyphenated names)
#    - NO subcommand support — caller hand-rolls subcommand dispatch
#      (typically check `argv._[0]` and dispatch)
#    - NO automatic --help — caller writes help text manually
#    - NO automatic --version — caller writes manually
#    - NO type validation beyond string/boolean coercion
#    - NO multiple-value support (later occurrences OVERWRITE earlier)
#    - DEPRECATED FOR NEW CODE — modern Node tools prefer yargs/
#      commander/cac/sade/meow/node:util.parseArgs, but minimist
#      remains widely deployed in legacy npm packages
#    - HISTORICAL — created by substack (James Halliday) in 2013,
#      originally inspired by Python's argparse but radically
#      simplified; the foundation that yargs/yargs-parser was built
#      on top of
#  Distinct from R340 TypeScript-Node oclif (Salesforce's CLI
#  framework — much heavier framework), R341 TypeScript-Node yargs
#  (Node.js fluent builder — yargs is BUILT ON TOP of yargs-parser
#  which is a fork of minimist!), R343 TypeScript-Node tj/commander.js
#  (Node.js fluent builder by TJ Holowaychuk — fluent API vs
#  minimist's single function call), R393 TypeScript-Node meow
#  (Sindre Sorhus's CLI helper — flags schema with rich types vs
#  minimist's basic string/boolean), R395 node:util.parseArgs
#  (Node.js stdlib — much more powerful schema with multiple/short/
#  default), R396 TypeScript-Node sade (Luke Edwards's TINY commander
#  alternative with command/option/action), R400 TypeScript-Node cac
#  (EGOIST's "Command And Conquer" with subcommands and patterns).
#  minimist's approach: TINY (~1KB) ORIGINAL zero-dependency Node.js
#  arg parser + IMPERATIVE FUNCTION CALL `minimist(args, opts)`
#  returning parsed object directly + SCHEMA-DRIVEN via 2nd OPTS arg
#  with `alias`/`string`/`boolean`/`default`/`stopEarly`/`unknown`/`'--'`
#  keys + RESULT OBJECT with `argv._` positional / `argv.NAME` flags /
#  `argv['--']` after-`--` args + AUTO TYPE INFERENCE for numbers/
#  strings/booleans + KEBAB-CASE preserved (no camelCase conversion) +
#  NO subcommand support / NO automatic --help/--version / NO multi-
#  value support — corpus's **first documented tiny-original-single-
#  function-imperative Node.js CLI library** (the GRANDFATHER of
#  Node.js CLI libraries).  Brings cross-language CLI library
#  taxonomy variant count to 141; TypeScript-Node ecosystem now has
#  8 documented CLI libraries — JUST ONE SHY of tying Rust (9) and
#  Go (9) for FIRST-MOST-DOCUMENTED CLI LANGUAGE.
#
#  Surface (verbatim from `lib/bin/candumpjs.ts` minimist opts +
#  manual help text):
#
#  Output Format Options:
#        --format FORMAT            Output format: json | candump
#                                   (default: json)
#    -n                             Output null values
#        --no-enums                 Don't output enum values
#        --include-raw-data         Include raw data in output
#        --include-byte-mapping     Include byte-to-field mapping
#        --pretty                   Pretty-print JSON (2-space indent)
#        --js                       Output in JavaScript util.inspect
#                                   format
#        --js-colors                Output in JavaScript format with
#                                   ANSI colors
#        --camel                    Output field names in camelCase
#        --camel-compat             Output both camelCase and regular
#
#  Parse Options:
#    -c                             Don't check for invalid field values
#    -r                             Parse $MXPGN as little endian
#        --show-non-matches         Show PGN data without any matching
#                                   PGN definition
#
#  Filter Options:
#        --pgn NUMBER               Filter to a specific PGN number
#        --id CAMELCASEID           Filter to a specific PGN id
#        --src NUMBER               Filter to a specific source address
#        --dst NUMBER               Filter to a specific destination
#                                   address
#        --manufacturer STR         Filter to PGNs from a manufacturer
#        --filter JS_EXPR           Filter via arbitrary JavaScript
#                                   expression (evaluated against
#                                   each PGN object)
#
#  Help:
#    -h, --help                     Show usage and exit
#
#  Positional:
#    CANDEVICE                      SocketCAN device (e.g. can0, vcan0)
#                                   (REQUIRED)
#
#  Examples:
#    candumpjs can0                          # Dump as JSON
#    candumpjs --pretty can0                 # Pretty-print JSON
#    candumpjs --format candump can0         # Output candump format
#    candumpjs --pgn 127257 can0             # Filter to attitude PGN
#    candumpjs --src 42 can0                 # Filter to source 42
#    candumpjs --js --js-colors can0         # JS inspect with colors
#    candumpjs --filter 'pgn.pgn === 130306' can0
#                                            # JavaScript filter expr
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also minimist users):
#    - patch-package (IN CORPUS via _patch-package — ds300/patch-
#      package 11194 stars; uses minimist; already documented under
#      different attribution; flagship minimist use case)
#    - colyseus (IN CORPUS via _colyseus or future — 6954 stars
#      multiplayer game framework; uses minimist in build scripts
#      not main CLI)
#    - bower (legacy package manager, IN CORPUS via _bower — uses
#      minimist historically)
#    - create-antdp / create-vue-project / create-gramio (npm
#      scaffolders using minimist)
#    - colyseus build.ts / vexip-ui release.ts / tony19 logback-android
#      (build scripts using minimist but not user-facing CLIs)
# ============================================================================

_candumpjs() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--format=[output format]:format:(json candump)' \
    '-n[output null values]' \
    '--no-enums[do not output enum values]' \
    '--include-raw-data[include raw data in output]' \
    '--include-byte-mapping[include byte-to-field mapping]' \
    '--pretty[pretty-print JSON]' \
    '--js[output in JavaScript util.inspect format]' \
    '--js-colors[output in JavaScript format with ANSI colors]' \
    '--camel[output field names in camelCase]' \
    '--camel-compat[output both camelCase and regular]' \
    '-c[do not check for invalid field values]' \
    '-r[parse $MXPGN as little endian]' \
    '--show-non-matches[show PGN data without matching definition]' \
    '--pgn=[filter to specific PGN number]:pgn' \
    '--id=[filter to specific PGN id (camelCase)]:id' \
    '--src=[filter to specific source address]:address' \
    '--dst=[filter to specific destination address]:address' \
    '--manufacturer=[filter to PGNs from manufacturer]:manufacturer' \
    '--filter=[JavaScript expression filter]:expr' \
    '(-h --help)'{-h,--help}'[show usage]' \
    '1:SocketCAN device:(can0 can1 vcan0 vcan1)'
}

_candumpjs "$@"
