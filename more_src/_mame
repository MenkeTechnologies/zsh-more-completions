#compdef mame mame64 mame32 mamearcade
# Documentation: https://man.archlinux.org/search?q=mame
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-help[show help]' \
  '-validate[validate driver]' \
  '-listxml[list ROM info as XML]' \
  '-listfull[list ROMs full description]' \
  '-listsource[list source files]' \
  '-listclones[list clones]' \
  '-listbrothers[list brothers]' \
  '-listcrc[list CRC checksums]' \
  '-listroms[list ROM files]' \
  '-listsamples[list sample sets]' \
  '-verifyroms[verify ROMs]' \
  '-verifysamples[verify samples]' \
  '-romident=[identify a ROM]:file:_files' \
  '-listdevices[list devices]' \
  '-listslots[list slots]' \
  '-listmedia[list media]' \
  '-listsoftware[list software lists]' \
  '-verifysoftware[verify software lists]' \
  '-getsoftlist=[get software list]:list:' \
  '-readconfig[read config files]' \
  '-noreadconfig[do not read configs]' \
  '-rompath=[ROM search paths]:paths:' \
  '-samplepath=[sample search paths]:paths:' \
  '-cfg_directory=[config dir]:dir:_files -/' \
  '-nvram_directory=[NVRAM dir]:dir:_files -/' \
  '-input_directory=[input dir]:dir:_files -/' \
  '-state_directory=[state dir]:dir:_files -/' \
  '-snapshot_directory=[snap dir]:dir:_files -/' \
  '-diff_directory=[diff dir]:dir:_files -/' \
  '-comment_directory=[comment dir]:dir:_files -/' \
  '-share_directory=[share dir]:dir:_files -/' \
  '-autosave[auto save state]' \
  '-noautosave[no auto save]' \
  '-rewind[enable rewind]' \
  '-rewind_capacity=[rewind capacity MB]:mb:' \
  '-snapsize=[snapshot size WxH]:size:' \
  '-snapview=[snapshot view]:view:' \
  '-snapname=[snapshot name format]:fmt:' \
  '-uifont=[UI font]:font:' \
  '-skip_gameinfo[skip game info screen]' \
  '-skip_warnings[skip warnings]' \
  '-language=[UI language]:lang:' \
  '-window[windowed]' \
  '-fullscreen[fullscreen]' \
  '-keepaspect[keep aspect ratio]' \
  '-prescale=[prescale]:n:(1 2 3 4 5)' \
  '-filter[bilinear filter]' \
  '-syncrefresh[sync to refresh]' \
  '-waitvsync[wait vsync]' \
  '-refreshspeed[refresh speed]' \
  '-throttle[throttle to refresh]' \
  '-sleep[sleep when can]' \
  '-speed=[speed multiplier]:n:' \
  '-sound=[sound type]:t:(none auto sdl portaudio)' \
  '-volume=[volume db]:db:' \
  '-samplerate=[sample rate]:hz:' \
  '-cheat[enable cheats]' \
  '-nocheat[disable cheats]' \
  '-autoboot_command=[autoboot command]:cmd:' \
  '-autoboot_delay=[autoboot delay sec]:n:' \
  '-autoboot_script=[autoboot script]:file:_files' \
  '-state=[load state file]:file:_files' \
  '-resolution=[resolution WxHxbpp]:res:' \
  '-debug[enable debug]' \
  '-record=[record input file]:file:_files' \
  '-playback=[playback input file]:file:_files' \
  '-mngwrite=[record MNG]:file:_files' \
  '-aviwrite=[record AVI]:file:_files' \
  '-wavwrite=[record WAV]:file:_files' \
  '-numscreens=[screens]:n:' \
  '-screen=[default screen]:dev:' \
  '-aspect=[screen aspect]:asp:' \
  '*:system:' && ret=0

return ret
