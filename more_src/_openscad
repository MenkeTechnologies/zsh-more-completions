#compdef openscad

# Zsh completion for openscad - OpenSCAD 3D CAD modeler CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--info[show system info]' \
  '-o[output file]:output file:_files -g "*.{stl,off,amf,3mf,csg,dxf,svg,png,pdf,echo,ast,term,nef3,nefdbg}"' \
  '-d[generate dependency file]:dependency file:_files' \
  '-m[set make command]:command' \
  '-D[set variable]:var=value' \
  '-p[parameter file]:file:_files -g "*.json"' \
  '-P[parameter set name]:name' \
  '--export-format=[export format]:format:(asciistl binstl off amf 3mf csg dxf svg png pdf echo ast term nef3 nefdbg)' \
  '--render[force CGAL rendering for OpenCSG and throws]' \
  '--preview=[set preview mode]:mode:(throwntogether opencsg)' \
  '--animate=[number of animation frames]:frames' \
  '--view=[camera view]:view:(axes crosshairs edges scales wireframe)' \
  '--projection=[projection type]:projection:(o ortho p perspective)' \
  '--camera=[camera parameters]:x,y,z,tx,ty,tz,d' \
  '--autocenter[auto-center model]' \
  '--viewall[view all objects]' \
  '--imgsize=[image size]:WxH' \
  '--colorscheme=[color scheme]:scheme:(Cornfield Metallic Sunset Starnight BeforeDawn Nature DeepOcean Solarized Tomorrow "Tomorrow Night" Monotone)' \
  '--csglimit=[CSG render limit]:limit' \
  '--hardwarnings[treat warnings as errors]' \
  '--check-parameters=[check parameters]:check:(true false)' \
  '--check-parameter-ranges=[check parameter ranges]:check:(true false)' \
  '--enable=[enable experimental features]:feature:(lazy-union sort-stl roof textmetrics import-function predictible-output manifold fast-csg roof)' \
  '--quiet[suppress non-essential output]' \
  '-q[suppress non-essential output]' \
  '--debug=[enable debug output]:features' \
  '--trust=[trust security level]:level' \
  '*:file:_files -g "*.scad"' && ret=0

return ret
