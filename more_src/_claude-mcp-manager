#compdef claude-mcp-manager
# Documentation: https://github.com/BLTGV/claude-mcp-manager
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_claude_mcp_manager_profiles() {
  local -a profiles
  profiles=(${(f)"$(command claude-mcp-manager profile list 2>/dev/null | tail -n +2 | sed 's/^[[:space:]]*//')"})
  _describe -t profiles 'profile' profiles
}

_claude_mcp_manager_servers() {
  local -a servers
  servers=(${(f)"$(command claude-mcp-manager server list 2>/dev/null | tail -n +2 | sed 's/^[[:space:]]*//')"})
  _describe -t servers 'server' servers
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands
    commands=(
      'server:Manage MCP server definitions'
      'profile:Manage MCP profiles'
      'import:Import a config file'
      'export:Export a profile'
      'last:Restore the last loaded config'
      'uninstall:Uninstall claude-mcp-manager'
      'completion:Generate shell completion'
      'help:Show help'
    )
    _describe -t commands 'claude-mcp-manager command' commands && ret=0
    ;;
  args)
    case $line[1] in
      server)
        if (( CURRENT == 2 )); then
          _values 'server subcommand' list show add edit remove extract help && ret=0
        else
          case $line[2] in
            show|edit|remove) _claude_mcp_manager_servers && ret=0 ;;
            add)
              _arguments \
                '--file=[server definition file]:file:_files' \
                '--json=[server JSON definition]:json' \
                '1:server name' && ret=0
              ;;
            extract)
              _arguments \
                '--profile=[profile to create/update]:profile:_claude_mcp_manager_profiles' && ret=0
              ;;
          esac
        fi
        ;;
      profile)
        if (( CURRENT == 2 )); then
          _values 'profile subcommand' list show create copy edit add remove delete help && ret=0
        else
          case $line[2] in
            show|edit|delete) _claude_mcp_manager_profiles && ret=0 ;;
            copy) _claude_mcp_manager_profiles && ret=0 ;;
            add|remove)
              if (( CURRENT == 3 )); then
                _claude_mcp_manager_profiles && ret=0
              else
                _claude_mcp_manager_servers && ret=0
              fi
              ;;
          esac
        fi
        ;;
      import)
        _arguments \
          '--file=[config file to import]:file:_files' \
          '--create-profile[create a new profile]' \
          '--profile-name=[profile name]:name' && ret=0
        ;;
      export)
        if (( CURRENT == 2 )); then
          _claude_mcp_manager_profiles && ret=0
        else
          _arguments '--output=[output file]:file:_files' && ret=0
        fi
        ;;
      uninstall)
        _arguments \
          '--remove-config[also remove config directory]' \
          '--yes[skip confirmation]' && ret=0
        ;;
      completion)
        _values 'shell' bash zsh && ret=0
        ;;
      *)
        _claude_mcp_manager_profiles && ret=0
        ;;
    esac
    ;;
esac

return ret
