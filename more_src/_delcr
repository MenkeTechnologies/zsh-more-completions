#compdef delcr
# _delcr — DJB ucspi-tcp delcr (strip a trailing CR before every LF on stdin so internet CR LF input becomes UNIX LF on stdout; commonly paired with addcr in tcpclient pipelines)
# upstream: https://github.com/schmonz/ucspi-tcp
# Source: delcr.c on tip; no flags.

_delcr() {
    _arguments '(- *)-h[show help]'
}

_delcr "$@"
