#compdef llvm-ml
# _llvm-ml — LLVM Microsoft macro assembler (LLVM project, C++); MASM-compatible front-end for ml/ml64
# upstream: https://github.com/llvm/llvm-project

_llvm-ml() {
    _arguments \
        '/?[show help]' \
        '/help[show help]' \
        '--help[show help]' \
        '/version[show version]' \
        '--version[show version]' \
        '/m32[32-bit]' \
        '/m64[64-bit]' \
        '/c[assemble only]' \
        '/Fo+[output object]:file:_files' \
        '/D+[define]:def:' \
        '/I+[include path]:dir:_files -/' \
        '/W+[warning level]:n:(0 1 2 3)' \
        '/X[ignore INCLUDE env]' \
        '/nologo[no logo]' \
        '/Sa[full listing]' \
        '/safeseh[safe SEH]' \
        '/Sf[first pass]' \
        '/Sl+[line width]:n:' \
        '/Sn[no symbol table]' \
        '/Sp+[page size]:n:' \
        '/Ss+[subtitle]:str:' \
        '/St+[title]:str:' \
        '/Sx[show false conditionals]' \
        '/Cp[case preserve]' \
        '/Cu[uppercase]' \
        '/Cx[case ext preserve]' \
        '/Zd[line info]' \
        '/Zf[make symbols public]' \
        '/Zi[CodeView]' \
        '/Zp+[struct pack]:n:' \
        '/Zs[syntax check only]' \
        '*:file:_files -g "*.(asm|s)"'
}

_llvm-ml "$@"
