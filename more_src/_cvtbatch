#compdef cvtbatch
# Documentation: man cvtbatch(8)
# Source: InterNetNews/inn backends/cvtbatch.c — convert Usenet batch format (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# -w accepts a concatenation of field letters: b=bytes, t=time received,
# f=full path, m=message-id, n=newsgroup name.
_arguments -s \
    '-w+[field spec: b/t/f/m/n combinations]:fields:_default' \
    && ret=0

return ret
