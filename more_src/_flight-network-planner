#compdef flight-network-planner
# Source: cargo binstall flight-network-planner@1.2.15
# Probed via: completion zsh
# Repository: https://github.com/mrt-map/flight-network-planner

autoload -U is-at-least

_flight-network-planner() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_flight-network-planner_commands" \
"*::: :->flight-network-planner" \
&& ret=0
    case $state in
    (flight-network-planner)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:flight-network-planner-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
'-o+[The old output file (will be used to preserve original flight routes so it won'\''t duplicate so much)]:OLD:_default' \
'--old=[The old output file (will be used to preserve original flight routes so it won'\''t duplicate so much)]:OLD:_default' \
'-s[Whether to print statistics]' \
'--stats[Whether to print statistics]' \
'-r[Whether to replace the old file instead of printing to stdout]' \
'--replace[Whether to replace the old file instead of printing to stdout]' \
'-h[Print help]' \
'--help[Print help]' \
'::file -- The configuration YML file to read from:_default' \
&& ret=0
;;
(get-config)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(gate-keys)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':plan -- The flight-plan:_default' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The shell to generate for:(bash carapace elvish fig fish nushell powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_flight-network-planner__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:flight-network-planner-help-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(get-config)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(gate-keys)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_flight-network-planner_commands] )) ||
_flight-network-planner_commands() {
    local commands; commands=(
'run:Run the planner' \
'get-config:Gets the configuration for the planner' \
'gate-keys:Tool to format the output of \`run\` as a mapping of gates to destinations' \
'completion:Generate a completion file for your shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'flight-network-planner commands' commands "$@"
}
