#compdef secilc
# SELinux CIL policy compiler

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '-o[output file]:file:_files' \
  '-f[file contexts output]:file:_files' \
  '-M[MLS policy]' \
  '-G[disable writing generated policy to disk]' \
  '-N[disable neverallow checking]' \
  '-c[policy version]:version:' \
  '-d[disable syntax checking]' \
  '-O[optimize policy]' \
  '-P[preserve tunables]' \
  '-Q[qualified names]' \
  '*:CIL source file:_files -g "*.cil"' \
  && return 0
