#compdef rtkrcv
# Documentation: https://manpages.debian.org/bullseye/rtklib/rtkrcv.1.en.html
# RTKLIB real-time positioning server with console

local ret=1

_arguments -s \
  '-s[start RTK server on program startup]' \
  '-p[port number for telnet console]:port' \
  '-m[port number for monitor stream]:port' \
  '-d[terminal device for console]:dev:_files' \
  '-o[configuration file]:file:_files' \
  '-r[output solution status file]:level:(0 1 2)' \
  '-t[debug trace level]:level:(0 1 2 3 4 5)' && ret=0

return ret
