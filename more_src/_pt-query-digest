#compdef pt-query-digest

# Zsh completion for pt-query-digest - Percona toolkit query analysis

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--attribute-aliases=[list of attribute aliases]:aliases' \
  '--attribute-value-limit=[max attribute value length]:limit' \
  '--charset=[default character set]:charset' \
  '--config=[comma-separated list of config files]:files:_files' \
  '--[no-]continue-on-error[continue on error]' \
  '--create-history-table[create history table if it does not exist]' \
  '--create-review-table[create review table if it does not exist]' \
  '--daemonize[run in background]' \
  '--database=[connect to this database]:database' \
  '--defaults-file=[only read default options from file]:file:_files' \
  '--embedded-attributes=[two Perl regex to capture embedded attributes]:pattern' \
  '--expected-range=[expected range for explain output]:range' \
  '--explain=[run EXPLAIN and include in report]:dsn' \
  '--filter=[discard events not matching Perl expression]:expression' \
  '--group-by=[group events by this attribute]:attribute' \
  '--history=[save metrics to given table]:dsn' \
  '--host=[connect to host]:host' \
  '--ignore-attributes=[do not aggregate these attributes]:attributes' \
  '--inherit-attributes=[copy these attributes from parent]:attributes' \
  '--interval=[poll interval]:seconds' \
  '--iterations=[how many times to iterate]:count' \
  '--limit=[limit output percentage or count]:limit' \
  '--log=[print all output to this file]:file:_files' \
  '--max-hostname-length=[max hostname display length]:length' \
  '--max-line-length=[max output line length]:length' \
  '--order-by=[sort events by]:attribute' \
  '--outliers=[report outliers]:specification' \
  '--output=[output format]:format:(report slowlog json)' \
  '--password=[password to use]:password' \
  '--pid=[create the given PID file]:file:_files' \
  '--port=[port number to use]:port' \
  '--preserve-embedded-numbers[preserve numbers in fingerprints]' \
  '--processlist=[poll processlist for queries]:dsn' \
  '--progress=[print progress reports]:specification' \
  '--read-timeout=[wait time for input]:seconds' \
  '--[no-]report[print query analysis report]' \
  '--report-all[report all queries]' \
  '--report-format=[report format]:format:(rusage date hostname files header profile query prepared)' \
  '--report-histogram=[chart attribute distribution]:attribute' \
  '--resume=[resume parsing from offset]:file:_files' \
  '--review=[save queries for review to this table]:dsn' \
  '--run-time=[how long to run]:time' \
  '--run-time-mode=[what time to use]:mode:(clock event)' \
  '--sample=[filter down to N occurrences per query]:count' \
  '--set-vars=[set MySQL variables]:vars' \
  '--show-all=[show all values for these attributes]:attributes' \
  '--since=[parse events from this date]:date' \
  '--slave-password=[slave password]:password' \
  '--slave-user=[slave user]:user' \
  '--socket=[socket file for connection]:file:_files' \
  '--timeline=[show timeline by this attribute]:attribute' \
  '--type=[type of input to parse]:type:(slowlog genlog binlog tcpdump rawlog)' \
  '--until=[parse events until this date]:date' \
  '--user=[user for login]:user' \
  '--[no-]variation=[report query variation]' \
  '--[no-]vertical-format[use vertical output format]' \
  '--watch-server=[server to watch]:dsn' \
  '*:file:_files' \
  && return 0
