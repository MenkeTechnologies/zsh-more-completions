#compdef crane

# Zsh completion for Crane - tool for interacting with remote container registries

local curcontext="$curcontext" state line ret=1

_crane_commands() {
  local -a commands=(
    'append:append contents of a tarball to a remote image'
    'auth:log in or access credentials'
    'blob:read a blob from the registry'
    'catalog:list the repos in a registry'
    'completion:generate shell completion'
    'config:get the config of an image'
    'copy:copy images efficiently'
    'delete:delete an image reference'
    'digest:get the digest of an image'
    'export:export the contents of a remote image'
    'flatten:flatten an image to a single layer'
    'help:help about any command'
    'ls:list the tags for a repo'
    'manifest:get the manifest of an image'
    'mutate:mutate an image'
    'optimize:optimize a remote image for streaming'
    'pull:pull remote images by reference'
    'push:push local image contents to a remote registry'
    'rebase:rebase an image onto a new base'
    'registry:interact with registries'
    'tag:tag an existing remote image'
    'validate:validate a remote image'
    'version:print version'
  )
  _describe -t commands 'crane command' commands
}

_crane_global_flags() {
  _arguments -s -S \
    '--allow-nondistributable-artifacts[allow pushing non-distributable layers]' \
    '--insecure[allow insecure connections]' \
    '--platform[specifies platform]:platform:(all linux/amd64 linux/arm64 linux/arm/v7 linux/s390x linux/ppc64le)' \
    '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
    '(-h --help)'{-h,--help}'[show help]' \
    "$@"
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--insecure[allow insecure connections]' \
  '--platform[specifies platform]:platform:(all linux/amd64 linux/arm64 linux/arm/v7)' \
  '--allow-nondistributable-artifacts[allow pushing non-distributable layers]' \
  '1: :_crane_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      append)
        _crane_global_flags \
          '(-f --new_layer)'{-f,--new_layer}'[path to tarball to append]:file:_files' \
          '(-t --new_tag)'{-t,--new_tag}'[tag to apply to resulting image]:tag' \
          '(-b --base)'{-b,--base}'[base image]:image' \
          '--set-base-image-annotations[include base image annotations]' \
          '(-o --output)'{-o,--output}'[path to new tarball]:file:_files' \
          '--oci-empty-base[use empty OCI base]' && ret=0
        ;;
      auth)
        local -a auth_commands=(
          'get:get credentials for a registry'
          'login:log in to a registry'
          'logout:log out of a registry'
          'token:retrieve a token for an image'
        )
        _describe -t auth-commands 'auth command' auth_commands
        ;;
      blob)
        _crane_global_flags \
          '1:blob ref:' && ret=0
        ;;
      catalog)
        _crane_global_flags \
          '--full-ref[include full image reference]' \
          '1:registry:' && ret=0
        ;;
      config)
        _crane_global_flags \
          '1:image:' && ret=0
        ;;
      copy|cp)
        _crane_global_flags \
          '(-a --all-tags)'{-a,--all-tags}'[copy all tags from src to dst]' \
          '(-n --no-clobber)'{-n,--no-clobber}'[avoid overwriting existing tags]' \
          '--jobs[number of concurrent copies]:num' \
          '1:source:' '2:destination:' && ret=0
        ;;
      delete|rm)
        _crane_global_flags \
          '1:image:' && ret=0
        ;;
      digest)
        _crane_global_flags \
          '--full-ref[include full image reference]' \
          '--tarball[path to tarball]:file:_files' \
          '1:image:' && ret=0
        ;;
      export)
        _crane_global_flags \
          '1:image:' '2:tarball:_files' && ret=0
        ;;
      flatten)
        _crane_global_flags \
          '(-t --tag)'{-t,--tag}'[tag to apply to flattened image]:tag' \
          '1:image:' && ret=0
        ;;
      ls)
        _crane_global_flags \
          '--full-ref[include full image reference]' \
          '(-O --omit-digest-tags)'{-O,--omit-digest-tags}'[omit digest tags]' \
          '1:repository:' && ret=0
        ;;
      manifest)
        _crane_global_flags \
          '1:image:' && ret=0
        ;;
      mutate)
        _crane_global_flags \
          '(-a --annotation)'{-a,--annotation}'[set annotations]:key=value' \
          '--cmd[override CMD]:cmd' \
          '--entrypoint[override ENTRYPOINT]:entrypoint' \
          '(-e --env)'{-e,--env}'[set environment variables]:key=value' \
          '(-l --label)'{-l,--label}'[set labels]:key=value' \
          '(-o --output)'{-o,--output}'[path to new tarball]:file:_files' \
          '(-t --tag)'{-t,--tag}'[new tag reference to apply]:tag' \
          '(-u --user)'{-u,--user}'[new user to set]:user' \
          '(-w --workdir)'{-w,--workdir}'[new working directory to set]:dir' \
          '--exposed-ports[set exposed ports]:ports' \
          '--set-platform[set platform]:platform' \
          '1:image:' && ret=0
        ;;
      pull)
        _crane_global_flags \
          '--format[format to use]:format:(tarball legacy oci)' \
          '--annotate-ref[preserve tag/digest annotations]' \
          '(-o --output)'{-o,--output}'[output path]:file:_files' \
          '1:image:' && ret=0
        ;;
      push)
        _crane_global_flags \
          '--image-refs[write image refs to a file]:file:_files' \
          '--index[push an index instead of an image]' \
          '1:tarball:_files' '2:image:' && ret=0
        ;;
      rebase)
        _crane_global_flags \
          '--old_base[old base image to rebase from]:image' \
          '--new_base[new base image to rebase to]:image' \
          '(-t --tag)'{-t,--tag}'[tag of new rebased image]:tag' \
          '1:original:' && ret=0
        ;;
      registry)
        local -a registry_commands=(
          'serve:serve a local OCI registry'
        )
        _describe -t registry-commands 'registry command' registry_commands
        ;;
      tag)
        _crane_global_flags \
          '1:image:' '*:tag:' && ret=0
        ;;
      validate)
        _crane_global_flags \
          '--fast[only validate the manifest]' \
          '--remote[validate a remote image]:image' \
          '--tarball[validate an image tarball]:file:_files' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
