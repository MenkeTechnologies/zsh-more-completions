#compdef bitcoin-util
# Documentation: https://github.com/bitcoin/bitcoin (src/bitcoin-util.cpp SetupBitcoinUtilArgs)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'grind:perform proof of work on hex header string'
)

_arguments -C \
  '(- *)-version[print version and exit]' \
  '(- *)-help[show help]' \
  '-regtest[run on regtest]' \
  '-testnet[run on testnet]' \
  '-testnet4[run on testnet4]' \
  '-signet[run on signet]' \
  '-chain=-[chain name]:chain:(main test testnet4 signet regtest)' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'bitcoin-util command' _subcmds && ret=0
    ;;
esac

return ret
