#compdef assault-cube assaultcube
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man6/assaultcube.6.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy assaultcube(6) manpage OPTIONS section.
# Short flags take attached arg (no space).

# AssaultCube: Cube engine FPS
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[print version number]' \
  '--protocol[print protocol number]' \
  '-w-[screen width (default 1024)]:n:' \
  '-h-[screen height (default 768)]:n:' \
  '-t[windowed mode (-t1 forces fullscreen)]' \
  '-z-[z-buffer precision in bits]:n:' \
  '-b-[colour depth in bits per pixel]:n:' \
  '-s-[stencil buffer precision in bits]:n:' \
  '-a-[anti-aliasing samples]:n:' \
  '-v-[v-sync (>0 enables, -1 system default)]:n:' \
  '--loadmap=[load map on launch]:map:' \
  '--loaddemo=[playback demo on launch]:file:_files -g "*.dmo"' \
  '-e[execute command on launch]:command:' \
  '--init[execute init script before graphics/sound]' \
  '--mod=[add path to resource search dirs]:path:_files -/' \
  '--home=[AssaultCube home folder]:path:_files -/' \
  '-m-[alternate masterserver URL]:url:' \
  '-T[tag timestamp to each text line]' \
  '-d[run as server]' \
  '*::extra args:_files' && ret=0
return ret
