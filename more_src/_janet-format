#compdef janet-format
# ============================================================================
#  _janet-format — janet-format: the OFFICIAL Janet code formatter
#                  (`gofmt`/`rustfmt` for Janet) shipped in
#                  janet-lang/spork (Janet's official "Contrib"
#                  utility library)
#
#  Source-direct extraction from
#    https://github.com/janet-lang/spork/blob/master/bin/janet-format
#    https://github.com/janet-lang/spork/blob/master/spork/argparse.janet
#    (the spork/argparse module by Calvin "bakpakin" Rose — Janet
#    language creator)
#
#  Maintained by Calvin "bakpakin" Rose (Janet language creator)
#  and the janet-lang core team.  janet-lang/spork has 181 GH
#  stars (the broader Janet org has 4,269 stars on the main
#  compiler).  janet-format is Janet's official source-formatter —
#  reads Janet source files (.janet) and re-emits them in a
#  CANONICAL FORMAT (consistent indentation, spacing around forms,
#  alignment of pairs in let/def/binding forms, etc.) similar to
#  gofmt/rustfmt/black for Janet code.  Supports a `.janet-
#  format.jdn` config file (JDN = Janet Data Notation, similar to
#  EDN for Clojure) for project-specific style overrides.
#  Sister tools: janet (the Janet interpreter itself — IN CORPUS
#  via _janet), janet-netrepl (network REPL — shipped in spork
#  alongside janet-format), jpm (Janet Package Manager), gofmt (in
#  corpus via _gofmt + STOCK in Go), rustfmt (in corpus + STOCK in
#  Rust), black (in corpus — Python formatter), prettier (in corpus
#  — JS/TS formatter), zprint (Clojure formatter), cljfmt
#  (Clojure formatter — in corpus via _cljfmt).
#
#  CLI library taxonomy update: NEW LANGUAGE addition — JANET (a
#  dynamic Lisp-dialect VM by Calvin Rose).  Janet's stdlib /
#  official-contrib library spork ships an arg parser
#  **spork/argparse** that the Janet community uses as its de-facto
#  CLI library.  First-time documentation of a Janet CLI library
#  in the cross-language taxonomy — Janet joins the 30+ languages
#  already represented (Rust, Go, TypeScript-Node, Python, Ruby,
#  Perl, Haskell, OCaml, Elixir, R, Bash, Deno, Lua, Scheme,
#  Clojure, Common Lisp, Racket, Crystal, Nim, Zig, Odin, V,
#  Carbon-adjacent, Mojo, Roc, Hare, Standard ML, Erlang, Pony,
#  Prolog, Pike, Julia, F#, Haxe, etc.).  🎉 Cross-language CLI
#  library taxonomy now spans 32+ documented languages.
#
#  Janet is a DYNAMIC LISP-DIALECT scripting language with a
#  bytecode VM written in C, designed by Calvin "bakpakin" Rose
#  for EMBEDDING into other applications (similar in spirit to
#  Lua/Wren/Guile).  Distinctive features: HOMOICONIC syntax with
#  S-expressions + curly-brace tables + square-bracket arrays,
#  PEG (parser expression grammar) support built into the
#  standard library, GREEN THREADS via fibers, native C-extension
#  modules, fast startup, ~1MB compiled VM.  Used as the embedded
#  scripting layer in: andrewchambers/hermes (Hermes software
#  environment manager — Nix-like package manager 324 stars),
#  andrewchambers/hpkg (Hermes package definitions), bakpakin/
#  x43bot (IRC bot example), pepe/smw (Presentation SW), tw4452852/
#  MyConfig, llmII/jsec (Janet security tools), Bakpakin/temple,
#  and many other niche Janet projects.  The Janet community is
#  small but tight — most CLI tools written in Janet use spork/
#  argparse for argv parsing.
#
#  spork/argparse (janet-lang/spork) is the de-facto CLI library
#  for Janet — shipped in the OFFICIAL "Contrib" library `spork`
#  maintained by the janet-lang core team.  Written by Calvin
#  Rose (Janet creator).  Distinguishing features: TABLE-DRIVEN
#  declarative arg schema using Janet's table syntax (which is
#  Janet's primary structured-data type — analogous to JavaScript
#  objects or Python dicts).  API:
#    (use spork/argparse)
#
#    (def ap
#      (argparse/argparse
#        "Description of the CLI tool — shown in --help banner"
#
#        # POSITIONAL "default" key — accumulates positional args
#        :default
#        {:kind :accumulate            # accumulate values in array
#         :help "Files to format"}
#
#        # FLAG: -f / --files (boolean)
#        "files"
#        {:short "f"
#         :help "Format a list of source files"
#         :kind :flag}
#
#        # OPTION: -o FILE / --output FILE
#        "output"
#        {:short "o"
#         :kind :option
#         :help "Output file destination"}
#
#        # OPTION with default value
#        "config"
#        {:short "c"
#         :kind :option
#         :help "Configuration file"
#         :default ".janet-format.jdn"}))
#
#    # Returns nil if --help was printed (caller breaks out)
#    (unless ap (break))
#
#    # Access parsed values by long-flag name as STRING KEY
#    (def output-file (ap "output"))
#    (def config-file (ap "config"))
#    (def files-list (ap :default))    # positionals
#    (def use-files-flag (ap "files"))
#
#  spork/argparse distinctive features:
#    - TABLE-DRIVEN schema — args defined as ALTERNATING
#      `name {options...}` pairs passed to argparse/argparse
#      function; first arg is the --help description
#    - `:kind` types:
#      * `:flag` — boolean flag (presence = true)
#      * `:option` — value-bearing flag (--name VALUE)
#      * `:accumulate` — REPEATING value-bearing (each occurrence
#        appends to result array)
#      * `:multi` — explicitly array-valued
#    - `:short "X"` — single-char short flag alias for the long
#      name
#    - `:default VALUE` — default value if flag absent
#    - `:help "STR"` — per-flag help text (shown in auto-generated
#      --help)
#    - `:required true` — error if flag not provided
#    - `:default` KEY (the keyword :default itself) — special
#      handler for POSITIONALS (free args not matched to any flag)
#    - AUTO --help / -h generation — argparse/argparse PRINTS the
#      help text and returns nil if -h/--help is seen
#    - PARSED RESULT is a Janet table (hash-map) keyed by the
#      long-flag-name STRING; access via `(ap "output")` or
#      `(ap :default)` for positionals
#    - HYPHENS in flag names — spork/argparse preserves hyphens
#      verbatim (`"no-config"` flag is accessed via `(ap "no-config")`)
#    - INTEGRATES WITH Janet's REPL-friendly debugging — since
#      args are a table, can be `(pp ap)` printed for inspection
#    - INSPIRED BY Python's argparse (similar declarative-table
#      style, but in Janet's S-expression syntax instead of
#      Python's `add_argument()` calls)
#  spork/argparse is the FIRST DOCUMENTED Janet CLI library in the
#  corpus's cross-language taxonomy.  Janet joins the 31 other
#  documented languages (Rust, Go, TypeScript-Node, Python, Ruby,
#  Perl, Haskell, OCaml, Elixir, R, Bash, Deno, Lua, Scheme,
#  Clojure, Common Lisp, Racket, Crystal, Nim, Zig, Odin, V,
#  Mojo, Roc, Hare, Standard ML, Erlang, Pony, Prolog, Pike, F#)
#  as the 32nd represented language.  No prior Janet CLI tools
#  documented in the corpus's library variant tracking.  Brings
#  cross-language CLI library taxonomy variant count to 158
#  (157 + spork/argparse = 158).  Janet remains a relatively
#  small ecosystem — janet-lang/spork has 181 GH stars vs hundreds
#  of thousands for major language ecosystems — but spork/argparse
#  is the universal Janet community choice for CLI arg parsing.
#
#  Surface (verbatim from `bin/janet-format` argparse/argparse
#  schema):
#
#  Usage:
#    janet-format [options] [files...]
#
#  Description:
#    Format Janet source code in files and write output to those
#    files.
#
#  Options:
#    -f, --files                    Format a list of source files
#                                   (when set, positional args
#                                   are treated as filenames to
#                                   format-in-place rather than
#                                   inputs to write to --output;
#                                   equivalent to passing them
#                                   as positionals)
#    -o, --output <FILE>            Where to direct output to.  By
#                                   default, output goes to stdout
#                                   (or in-place when --files is
#                                   set)
#    -i, --input <FILE>             Read from an input file (default
#                                   is stdin when neither --files
#                                   nor --input is set)
#    -c, --config <FILE>            Which configuration file to
#                                   read (Default:
#                                   .janet-format.jdn).  The config
#                                   file is JDN (Janet Data
#                                   Notation) format and provides
#                                   user indentation overrides via
#                                   `*user-indent-2-forms*`
#    -n, --no-config                Avoid loading any configuration
#                                   file (skips even the default
#                                   .janet-format.jdn if present)
#        --help                     Show help (auto-generated by
#                                   spork/argparse)
#
#  Positional (accumulated when --files is set, OR by default
#  treated as files):
#    FILES...                       Janet source files (.janet) to
#                                   format in-place
#
#  Examples:
#    janet-format src/main.janet                            # Format file in-place
#    janet-format -f src/*.janet                            # Format multiple files
#    cat src/main.janet | janet-format                      # Format from stdin to stdout
#    janet-format -i src/main.janet                         # Format from file to stdout
#    janet-format -i src/main.janet -o out.janet            # Format from file to file
#    janet-format -c .my-style.jdn src/*.janet              # Custom config
#    janet-format -n src/main.janet                         # No config (use defaults)
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also spork/argparse users):
#    - hermes (IN CORPUS via _hermes — DIFFERENT `hermes` tool;
#      Andrew Chambers's andrewchambers/hermes 324 stars Hermes
#      software environment manager uses spork/argparse — but
#      corpus's existing _hermes is for a DIFFERENT hermes
#      binary)
#    - hpkg (andrewchambers/hpkg 7 stars too thin)
#    - speakeasy (IN CORPUS — different speakeasy tool;
#      swlkr/speakeasy 13 stars Janet static-site generator
#      conflicts with existing _speakeasy)
#    - x43bot (bakpakin/x43bot 4 stars IRC bot — too niche)
#    - smw (pepe/smw 8 stars presentation SW — too niche)
#    - janet (IN CORPUS via _janet — the Janet interpreter itself;
#      already documented but interpreter, not formatter)
#    - janet-netrepl (network REPL shipped in spork alongside
#      janet-format; FUTURE candidate)
# ============================================================================

_janet-format() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--help[show help]' \
    '(-f --files)'{-f,--files}'[format a list of source files]' \
    '(-o --output)'{-o,--output}'[output file destination (default: stdout)]:file:_files -g "*.janet"' \
    '(-i --input)'{-i,--input}'[read from input file (default: stdin)]:file:_files -g "*.janet"' \
    '(-c --config)'{-c,--config}'[configuration file]:file:_files -g "*.jdn"' \
    '(-n --no-config)'{-n,--no-config}'[avoid loading any configuration file]' \
    '*:file:_files -g "*.janet"'
}

_janet-format "$@"
