#compdef VCEEncC VCEEncC64
# Documentation: https://github.com/rigaya/VCEEnc/blob/master/VCEEncC_Options.en.md
# rigaya AMD VCE/AMF-based hardware video encoder

local ret=1

_arguments -s -S \
  '(-h -? --help)'{-h,-\?,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--option-list[list all available options]' \
  '--check-hw[verify device capability]' \
  '--check-features[display device feature information]' \
  '--check-codecs[show supported audio codecs]' \
  '(-i --input)'{-i,--input}'+[input file or pipe]:file:_files' \
  '(-o --output)'{-o,--output}'+[output file or pipe]:file:_files' \
  '(-d --device)'{-d,--device}'+[GPU device ID]:id:' \
  '(-c --codec)'{-c,--codec}'+[output codec]:codec:(h264 hevc av1 raw)' \
  '(-f --output-format)'{-f,--output-format}'+[force output container]:format:' \
  '--raw[treat input as raw YUV]' \
  '--y4m[read Y4M input]' \
  '--avi[use AVI reader]' \
  '--avs[Avisynth script reader]' \
  '--vpy[VapourSynth script reader]' \
  '--avsw=[software decode via libavcodec]:codec:' \
  '--avhw[hardware decode with GPU]' \
  '--cqp=[constant QP mode]:qp:' \
  '--cbr=[constant bitrate kbps]:kbps:' \
  '--vbr=[variable bitrate kbps]:kbps:' \
  '--qvbr=[quality-based VBR kbps]:kbps:' \
  '(-u --preset)'{-u,--preset}'+[quality preset]:preset:(balanced fast slow slower)' \
  '--profile=[video profile]:profile:' \
  '--level=[codec level]:level:' \
  '--output-depth=[output bit depth]:depth:(8 10)' \
  '--gop-len=[maximum GOP length]:len:' \
  '(-b --bframes)'{-b,--bframes}'+[consecutive B frames]:n:' \
  '--ref=[reference frame distance]:n:' \
  '--vbv-bufsize=[VBV buffer size KB]:kb:' \
  '--qp-min=[minimum QP value]:qp:' \
  '--qp-max=[maximum QP value]:qp:' \
  '--max-bitrate=[maximum bitrate constraint]:kbps:' \
  '--motion-est=[motion vector precision]:precision:' \
  '--vbaq[adaptive quantization]' \
  '--ltr=[long-term reference mode]:n:' \
  '--enforce-hrd[HRD bitstream compliance]' \
  '--audio-copy[copy audio tracks]' \
  '--audio-codec=[encode audio with codec]:codec:' \
  '--audio-bitrate=[audio bitrate kbps]:kbps:' \
  '--audio-samplerate=[audio sampling rate]:hz:' \
  '--vpp-resize=[resize video]:method:' \
  '--vpp-deinterlace[deinterlacing filters]' \
  '--vpp-colorspace[color space conversion]' \
  '--vpp-denoise-dct[DCT-based noise reduction]' && ret=0

return ret
