#compdef fairseq2
# Documentation: https://github.com/facebookresearch/fairseq2/wiki/Quick-Start
# FAIR Sequence Modeling Toolkit 2 recipe CLI for finetuning and generation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config[set configuration parameters key=value]:config:' \
  '--config-file=[load configuration from a file]:file:_files' \
  '--dump-config[print the resolved recipe configuration and exit]' \
  '--list-presets[list available configuration presets]' \
  '--no-sweep-dir[do not create a sweep subdirectory in the output dir]' \
  '1:group:(lm mt asr wav2vec2 assets)' \
  '*::arg:->args' && ret=0

return ret
