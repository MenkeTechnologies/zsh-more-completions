#compdef dnaclust
# Documentation: https://manpages.debian.org/testing/dnaclust/dnaclust.1.en.html
# DNACLUST - cluster large numbers of short DNA sequences

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display option summary]' \
  '(-v --version)'{-v,--version}'[show program version number]' \
  '(-i --input)'{-i,--input}'[input FASTA file to cluster]:input:_files' \
  '(-s --similarity)'{-s,--similarity}'[cluster radius threshold (0-1)]:threshold' \
  '(-m --multiple-alignment)'{-m,--multiple-alignment}'[output multiple sequence alignment of each cluster]' \
  '(-d --header)'{-d,--header}'[write program options to output]' \
  '(-l --left-gaps-allowed)'{-l,--left-gaps-allowed}'[allow gaps on both ends of the shorter sequence]' \
  '(-k --k-mer-length)'{-k,--k-mer-length}'[maximum k-mer length for filtering]:length' \
  '(-a --approximate-filter)'{-a,--approximate-filter}'[use faster heuristic filter instead of exact filter]' \
  '--no-k-mer-filter[disable k-mer filtering entirely]' \
  '*:file:_files' && ret=0

return ret
