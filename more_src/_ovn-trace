#compdef ovn-trace
# Documentation: https://man.archlinux.org/search?q=ovn-trace
# Reference accessed: 2026-05-16

_arguments -s \
  '--detailed[detailed output (default)]' \
  '--summary[summary output]' \
  '--minimal[minimal output]' \
  '--all[all output formats]' \
  '--ovs=[show OF flows]:remote:' \
  '--ct=[conntrack flags]:flags:(trk new est rel rpl inv dnat snat)' \
  '--lb-dst=[VIP destination]:ip\:port:' \
  '--select-id=[select-action id]:id:' \
  '--friendly-names[friendly names (default)]' \
  '--no-friendly-names[no friendly names]' \
  '--db=[OVSDB remote]:remote:' \
  '--pidfile=[pid file]:file:_files' \
  '--detach[detach to background]' \
  '*'{-v,--verbose=}'[verbosity]:spec:' \
  '--log-file=[log file]:file:_files' \
  '(-p --private-key)'{-p,--private-key=}'[private key]:file:_files' \
  '(-c --certificate)'{-c,--certificate=}'[certificate]:file:_files' \
  '(-C --ca-cert)'{-C,--ca-cert=}'[CA cert]:file:_files' \
  '--ssl-server-name=[SNI name]:name:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  ':datapath or microflow:' \
  ':microflow:'
