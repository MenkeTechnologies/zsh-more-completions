#compdef rosa
# Documentation: https://github.com/openshift/rosa
# Reference accessed: 2026-05-21
# Verified: upstream rosa source tree cmd/ subdirectories list the
# top-level subcommands. Red Hat OpenShift Service on AWS CLI.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'attach:Attach a resource to a cluster'
  'completion:Generate shell completion'
  'config:Manage rosa CLI configuration'
  'create:Create a resource from stdin'
  'describe:Show details of a specific resource'
  'detach:Detach a resource from a cluster'
  'dlt:Delete a resource (alias of delete)'
  'docs:Generate documentation for rosa'
  'download:Download tools or data'
  'edit:Edit a resource'
  'grant:Grant a role to a user'
  'hibernate:Hibernate a cluster'
  'initialize:Initialize AWS account and resources'
  'install:Install operator add-ons'
  'link:Link OCM and user roles'
  'list:List resources'
  'login:Log in to your Red Hat account'
  'logout:Log out of your Red Hat session'
  'logs:Show installation or uninstallation logs'
  'register:Register clusters'
  'resume:Resume a hibernated cluster'
  'revoke:Revoke a role from a user'
  'token:Show the current OCM access token'
  'uninstall:Uninstall operator add-ons'
  'unlink:Unlink OCM and user roles'
  'upgrade:Upgrade a resource'
  'verify:Verify resources are configured correctly'
  'version:Show the rosa client version'
  'whoami:Show currently logged-in user'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --v)'{-v,--v}'[Log verbosity level]:level' \
  '--debug[Enable debug mode]' \
  '--profile[AWS profile]:profile' \
  '--region[AWS region]:region' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'rosa command' commands && ret=0 ;;
esac

return ret
