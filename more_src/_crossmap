#compdef CrossMap CrossMap.py crossmap
# _crossmap — Liguo Wang CrossMap genome coordinate conversion tool for BAM SAM BED VCF GFF MAF BigWig (sufengniu/CrossMap team, Python); argparse subcommands
# upstream: https://github.com/liguowang/CrossMap

_crossmap() {
    local -a sub=(
        'bam:convert BAM/SAM files'
        'bed:convert BED files'
        'bigwig:convert bigWig files'
        'gff:convert GFF/GTF files'
        'maf:convert MAF files'
        'gvcf:convert gVCF files'
        'vcf:convert VCF files'
        'wig:convert Wiggle files'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'crossmap subcommand' sub ;;
        args)
            case $words[1] in
                bam) _arguments \
                    '-m+[insert size mean]:f:' \
                    '-s+[insert size stddev]:f:' \
                    '-t+[insert size truncation]:f:' \
                    '-a[append tags]' \
                    '*:chain bam in chrom-info out:_files -g "*.bam *.sam *.chain *.chain.gz *.over.chain"' ;;
                bed) _arguments \
                    '*:chain in_bed out_bed:_files -g "*.bed *.chain *.chain.gz *.over.chain"' ;;
                bigwig) _arguments \
                    '-c+[chrom sizes]:file:_files' \
                    '*:chain in_bw chrom_sizes_out_prefix:_files -g "*.bw *.bigwig *.chain"' ;;
                gff) _arguments '*:chain in_gff out_gff:_files -g "*.gff *.gff3 *.gtf *.chain"' ;;
                maf) _arguments '*:chain in_maf out_maf chrom_sizes_ref:_files -g "*.maf *.chain"' ;;
                gvcf) _arguments \
                    '--no-comp-alleles[no comp alleles]' \
                    '*:chain in_gvcf ref_genome out_gvcf:_files -g "*.gvcf *.gvcf.gz *.chain"' ;;
                vcf) _arguments \
                    '--chromid=+[mode]:m:(a s l)' \
                    '--no-comp-alleles[no comp alleles]' \
                    '--compress[gzip output]' \
                    '*:chain in_vcf ref_genome out_vcf:_files -g "*.vcf *.vcf.gz *.chain"' ;;
                wig) _arguments '*:chain in_wig out_wig:_files -g "*.wig *.bedgraph *.chain"' ;;
            esac
            ;;
    esac
}

_crossmap "$@"
