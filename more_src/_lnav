#compdef lnav

# Zsh completion for lnav - the log file navigator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)'{-V,-version}'[show version]' \
  '-a[load all of the most recent log file types]' \
  '-c[execute specified lnav command after startup]:command:' \
  '-d[write debug messages to file]:debug file:_files' \
  '-f[execute commands from file]:file:_files' \
  '-I[add configuration directory]:directory:_files -/' \
  '-i[install the given format files]:format file:_files' \
  '-n[run in headless mode]' \
  '-N[do not open the default syslog file]' \
  '-q[do not print additional information on stderr]' \
  '-r[recursively load files from directories]' \
  '-R[load older rotated log files]' \
  '-s[load the given timestamp in the log files]' \
  '-t[prepend timestamps to data piped from stdin]' \
  '-u[update installed format files]' \
  '-w[write the contents of stdin to this file]:file:_files' \
  '-W[print terminal output on exit]' \
  '*:log file:_files' && ret=0

return ret
