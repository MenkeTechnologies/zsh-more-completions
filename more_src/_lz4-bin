#compdef lz4 lz4c lz4cat unlz4
# _lz4-bin — LZ4 fast extreme-speed compression (Yann Collet); reference CLI for lz4 stream/frame compression
# upstream: https://github.com/lz4/lz4

_lz4-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-z[compress]' \
        '-d[decompress]' \
        '-t[test integrity]' \
        '-l[legacy format]' \
        '-A[adaptive mode]' \
        '-1[fast]' \
        '-2[lvl 2]' \
        '-3[lvl 3]' \
        '-4[lvl 4]' \
        '-5[lvl 5]' \
        '-6[lvl 6]' \
        '-7[lvl 7]' \
        '-8[lvl 8]' \
        '-9[best]' \
        '--fast=+[ultra-fast level]:n:' \
        '--best[best (lvl 9)]' \
        '--favor-decSpeed[favor decompress speed]' \
        '(-c --stdout)'{-c,--stdout}'[stdout]' \
        '(-k --keep)'{-k,--keep}'[keep input]' \
        '(-r --recursive)'{-r,--recursive}'[recurse dir]' \
        '(-f --force)'{-f,--force}'[force overwrite]' \
        '(-m --multiple)'{-m,--multiple}'[multiple input files]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--rm[remove input after success]' \
        '--no-frame-crc[no frame CRC]' \
        '--content-size[store decompressed size in frame]' \
        '--block-size=+[block size]:n:(64KB 256KB 1MB 4MB)' \
        '--block-independence[block independence]' \
        '--block-checksum[block-level CRC]' \
        '--sparse[sparse output]' \
        '--no-sparse[no sparse output]' \
        '-B+[block size 4-7]:n:' \
        '-D+[dictionary]:file:_files' \
        '*:file:_files'
}

_lz4-bin "$@"
