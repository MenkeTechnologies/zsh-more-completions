#compdef protolock
# Documentation: https://man.archlinux.org/search?q=protolock
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize proto.lock'
  'status:show changes vs lockfile'
  'commit:write current proto state to lockfile'
)

_arguments -C \
  '-lockdir=[directory containing proto.lock]:dir:_files -/' \
  '-protoroot=[directory containing proto files]:dir:_files -/' \
  '-ignore=[comma-list of ignored files]:list:' \
  '-uptodate[require lockfile up to date]' \
  '-plugins=[comma-list of plugins]:list:' \
  '-force[allow breaking changes]' \
  '-strict[strict mode]' \
  '-debug[debug logging]' \
  '1: :->subcommand' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'protolock subcommand' subcommands && ret=0
    ;;
esac

return ret
