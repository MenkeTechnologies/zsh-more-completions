#compdef bpcomp
# Documentation: https://github.com/bayesiancook/pbmpi/blob/master/sources/BPCompare.cpp
# PhyloBayes bpcomp: compares bipartition frequencies across chains. Flags mirror BPCompare.cpp.

local ret=1

_arguments -s -S \
  '-x[burn-in, then sampling every and upto]:burnin:' \
  '-c[posterior probability cutoff for consensus]:cutoff:' \
  '-o[output base name]:output:' \
  '-m[merge / majority-rule consensus]' \
  '-r[reroot output trees]' \
  '-ref[reference tree for comparison]:tree:_files' \
  '-v[verbose output]' \
  '*:chain name:' && ret=0

return ret
