#compdef hlint-cli
# _hlint-cli — Neil Mitchell HLint Haskell source code suggestions CLI alias (ndmitchell team, Haskell); CmdArgs
# upstream: https://github.com/ndmitchell/hlint

_hlint-cli() {
    _arguments \
        '--help[show help]' \
        '-?[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-r+[generate report]:file:_files' \
        '--report=+[generate report]:file:_files' \
        '-h+[hint file]:file:_files' \
        '--hint=+[hint file]:file:_files' \
        '-c[colorize]' \
        '--color=+[color]:c:(always never auto)' \
        '--colour=+[color]:c:(always never auto)' \
        '-i+[ignore pattern]:str:' \
        '--ignore=+[ignore pattern]:str:' \
        '-s[show summary]' \
        '--show[show all rules]' \
        '--with-group=+[group]:str:' \
        '--without-group=+[group]:str:' \
        '-d[display only fatal]' \
        '--default[print default hints]' \
        '-X+[language extension]:str:' \
        '--language=+[language extension]:str:' \
        '--cpp-define=+[CPP define]:str:' \
        '-D+[CPP define]:str:' \
        '--cpp-include=+[CPP include]:dir:_files -/' \
        '-I+[CPP include]:dir:_files -/' \
        '--cpp-simple[simple cpp]' \
        '--cpp-ansi[ansi cpp]' \
        '--cpp-file=+[cpp file]:file:_files' \
        '-j+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '-T[test mode]' \
        '--test[test mode]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--no-summary[no summary]' \
        '--no-exit-code[no exit code]' \
        '--git[apply to git tracked files]' \
        '--refactor[apply refactorings via apply-refact]' \
        '--refactor-options=+[options]:str:' \
        '--with-refactor=+[refactor binary]:file:_files' \
        '-f+[find hints from file]:file:_files' \
        '--find=+[find hints from file]:file:_files' \
        '--datadir=+[data dir]:dir:_files -/' \
        '--encoding=+[encoding]:e:(utf-8 iso-8859-1)' \
        '--cross[allow cross-module hints]' \
        '--no-cpp[do not run cpp]' \
        '--json[json output]' \
        '--sarif[sarif output]' \
        '--serialise[serialise output]' \
        '--ghc-option=+[ghc option]:str:' \
        '*:source files:_files -g "*.{hs,lhs}"'
}

_hlint-cli "$@"
