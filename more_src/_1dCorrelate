#compdef 1dCorrelate
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dCorrelate.html
# Correlation coefficient between each column pair with bootstrap CI

local ret=1

_arguments -s -S \
  '-Pearson[Pearson correlation (default)]' \
  '-Spearman[Spearman rank correlation]' \
  '-Quadrant[quadrant binarized correlation]' \
  '-Ktaub[Kendall tau_b correlation]' \
  '-nboot[number of bootstrap replicates (default 4000)]:B' \
  '-alpha[2-sided confidence interval width (default 5)]:A' \
  '-block[account for serial correlation via block resampling]' \
  '-blk[alternate flag for block resampling]' \
  '*:file:_files' && ret=0

return ret
