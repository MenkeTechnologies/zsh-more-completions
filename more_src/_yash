#compdef yash
# _yash — magicant/yash (POSIX-conformant shell with vi/emacs line editor + features beyond POSIX: -c command, -i interactive, -l login, -s read commands from stdin, -V/-v shell options short forms, --version; many --shell-option style long options enable features like glob-period, dot-globs, no-clobber)
# upstream: https://github.com/magicant/yash
# Flags from yash main.c on tip.

_yash() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-V[verbose execution trace]' \
        '-v[print input lines as read]' \
        '-c+[run command string]:command:' \
        '-i[force interactive]' \
        '-l[login shell]' \
        '-s[read commands from stdin]' \
        '-x[xtrace]' \
        '-n[no execute]' \
        '-e[exit on error]' \
        '-u[treat unset vars as errors]' \
        '-f[disable globbing]' \
        '-a[auto-export modifications]' \
        '-b[notify on background job complete]' \
        '-m[enable job control]' \
        '-T[stack trace]' \
        '*-o+[long option]:option:(verbose vi emacs noexec posixly_correct ignore_eof case_glob dot_glob fork_subshell glob_period unset hyphen_ok mark_dirs no_clobber trace_all)' \
        '*:script:_files'
}

_yash "$@"
