#compdef phantun_server
# Documentation: https://github.com/dndx/phantun
# phantun_server - transforms UDP datagrams into faux-TCP for transport over restrictive networks

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-l --local)'{-l,--local}'=[port where phantun server listens for incoming faux-TCP]:port' \
  '(-r --remote)'{-r,--remote}'=[address and port to forward decapsulated UDP datagrams to]:addr' \
  '--tun=[Tun interface name]:name' \
  '--tun-local=[Tun interface IPv4 local address]:addr' \
  '--tun-peer=[Tun interface IPv4 destination (peer) address]:addr' \
  '(-4 --ipv4-only)'{-4,--ipv4-only}'[only listen on IPv4 address]' \
  '--tun-local6=[Tun interface IPv6 local address]:addr' \
  '--tun-peer6=[Tun interface IPv6 destination (peer) address]:addr' \
  '--handshake-packet=[file whose content is sent as first data packet after handshake]:file:_files' && ret=0

return ret
