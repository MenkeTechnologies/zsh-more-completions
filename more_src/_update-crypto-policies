#compdef update-crypto-policies
# _update-crypto-policies — Red Hat update-crypto-policies Fedora/RHEL system-wide crypto-policies configuration tool for OpenSSL GnuTLS NSS Java krb5 ssh (Red Hat team, Python); argparse
# upstream: https://gitlab.com/redhat-crypto/fedora-crypto-policies

_update-crypto-policies() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--show[show current policy]' \
        '--set=+[set policy]:p:(DEFAULT LEGACY FUTURE FIPS NEXT TEST EMPTY)' \
        '--check[check current state]' \
        '--is-applied[check if policy applied]' \
        '--no-reload[do not reload services]' \
        '--no-bootcheck[no boot check]' \
        '--verbose[verbose]' \
        '-v[verbose]'
}

_update-crypto-policies "$@"
