#compdef forgit

# Zsh completion for forgit (git + fzf interactive tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:interactively select files to git add'
  'blame:interactively git blame'
  'branch_delete:interactively delete branches'
  'checkout_branch:interactively checkout branch'
  'checkout_commit:interactively checkout commit'
  'checkout_file:interactively checkout file'
  'checkout_tag:interactively checkout tag'
  'cherry_pick:interactively cherry-pick commits'
  'cherry_pick_from_branch:cherry-pick from branch'
  'clean:interactively clean untracked files'
  'diff:interactively show diff'
  'fixup:interactively fixup a commit'
  'ignore:interactively generate .gitignore'
  'log:interactively browse git log'
  'rebase:interactively rebase'
  'reset_head:interactively reset HEAD'
  'revert_commit:interactively revert commit'
  'stash_push:interactively stash changes'
  'stash_show:interactively show stash'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'forgit command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (add|diff|checkout_file)
        _files && ret=0
        ;;
      (checkout_branch|branch_delete)
        __git_branch_names && ret=0
        ;;
    esac
    ;;
esac

return ret
