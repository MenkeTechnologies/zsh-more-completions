#compdef liquidwar6
# Documentation: https://www.gnu.org/software/liquidwar6/manual/liquidwar6.html
# Reference accessed: 2026-05-16

# Liquid War 6: GNU 3D real-time strategy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--debug[debug mode]' \
  '--quick[quick start]' \
  '--demo[demo mode]' \
  '--check[run self-tests]' \
  '--defaults[reset to defaults]' \
  '--reset[reset config]' \
  '--list-categories[list option categories]' \
  '--list-modes[list display modes]' \
  '--list-paths[list config paths]' \
  '--list-input[list input devices]' \
  '--no-sound[disable sound]' \
  '--server[run as server]' \
  '--client[run as client]' \
  '*::liquidwar6 args:_files' && ret=0
return ret
