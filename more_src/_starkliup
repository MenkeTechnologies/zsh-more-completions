#compdef starkliup
# Documentation: https://book.starkli.rs/installation
# Source: https://raw.githubusercontent.com/xJonathanLEI/starkli/master/starkliup/starkliup
# Reference accessed: 2026-06-02
# Installer/updater shipped under ~/.starkli/bin/starkliup.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-v --version)'{-v+,--version=}'[install a specific release tag (eg v0.4.2)]:tag:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
