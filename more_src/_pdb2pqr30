#compdef pdb2pqr30
# Documentation: https://pdb2pqr.readthedocs.io/en/latest/using/index.html
# Prepare structures for electrostatics: add H, assign charges and radii

local ret=1

_arguments -s -S \
  '(- *)--help[show help and exit]' \
  '(- *)--version[show version and exit]' \
  '--log-level=[logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--ff=[forcefield to use]:ff:(AMBER CHARMM PARSE TYL06 PEOEPB SWANSON)' \
  '--userff=[user-created forcefield file]:file:_files' \
  '--usernames=[user-created names file]:file:_files' \
  '--ffout=[output naming scheme forcefield]:ff:(AMBER CHARMM PARSE TYL06 PEOEPB SWANSON)' \
  '--clean[no optimization or assignment; return aligned PDB]' \
  '--nodebump[do not perform the debumping operation]' \
  '--noopt[do not perform hydrogen optimization]' \
  '--keep-chain[keep chain ID in output PQR file]' \
  '--assign-only[only assign charges and radii]' \
  '--apbs-input=[write template APBS input file]:file:_files' \
  '--pdb-output=[write PDB file based on input]:file:_files' \
  '--ligand=[MOL2-format ligand file]:file:_files -g "*.mol2"' \
  '--whitespace[insert whitespace between fields in output]' \
  '--neutraln[make N-terminus neutral (requires PARSE)]' \
  '--neutralc[make C-terminus neutral (requires PARSE)]' \
  '--drop-water[drop waters before processing]' \
  '--include-header[include PDB header in PQR file]' \
  '--titration-state-method=[titration state calculation method]:method:(propka pkaani)' \
  '--with-ph=[pH value for titration state method]:ph' \
  '1:input PDB path or ID:_files -g "*.pdb"' \
  '2:output PQR path:_files -g "*.pqr"' && ret=0

return ret
