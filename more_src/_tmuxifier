#compdef tmuxifier
# Documentation: https://github.com/jimeh/tmuxifier
# tmuxifier - manage complex tmux sessions and windows with layout files

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'load-session:load the specified session layout'
      's:load the specified session layout'
      'load-window:load the specified window layout into current session'
      'w:load the specified window layout into current session'
      'new-session:create new session layout and open it with EDITOR'
      'ns:create new session layout and open it with EDITOR'
      'new-window:create new window layout and open it with EDITOR'
      'nw:create new window layout and open it with EDITOR'
      'edit-session:edit an existing session layout with EDITOR'
      'es:edit an existing session layout with EDITOR'
      'edit-window:edit an existing window layout with EDITOR'
      'ew:edit an existing window layout with EDITOR'
      'list:list all session and window layouts'
      'l:list all session and window layouts'
      'list-sessions:list session layouts'
      'ls:list session layouts'
      'list-windows:list window layouts'
      'lw:list window layouts'
      'init:initialize tmuxifier shell integration'
      'commands:list available commands'
      'completions:list completions for a command'
      'help:display help information'
    )
    _describe -t commands 'tmuxifier command' cmds && ret=0
    ;;
esac

return ret
