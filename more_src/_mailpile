#compdef mailpile
# Documentation: https://github.com/mailpile/Mailpile
# Reference accessed: 2026-05-16
# Verified: upstream repo (mailpile/Mailpile). Mailpile v1 is a Python 2
# web mail client; upstream development is halted pending a Python 3
# rewrite. No man page and no formal CLI flag specification is published.
# Operates primarily through a TCP web UI; CLI is an interactive `mp`
# command shell rather than a flag-driven utility. Falling back to a
# conservative stub.
# Removed from prior file: fabricated -h/-V flags and bogus
# man.archlinux.org search URL.

# mailpile: free, secure, web-based mail client
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
