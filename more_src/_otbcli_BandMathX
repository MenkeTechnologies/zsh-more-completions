#compdef otbcli_BandMathX
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_BandMathX.html
# Orfeo ToolBox: apply a mathematical expression over a list of multiband images

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-il[image list to perform computation on]:images:_files' \
  '-out[output image]:output:_files' \
  '-exp[mathematical expression to apply]:expression:' \
  '-incontext[context file with user-defined constants and expressions]:file:_files' \
  '-outcontext[file location to save constants and expressions]:file:_files' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
