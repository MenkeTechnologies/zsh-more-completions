#compdef pot

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'init:initialize the pot framework'
      'de-init:de-initialize the pot framework'
      'vnet-start:start the vnet configuration'
      'create:create a new pot'
      'clone:clone a pot'
      'rename:rename a pot'
      'destroy:destroy a pot'
      'copy-in:copy files into a pot'
      'copy-out:copy files out of a pot'
      'mount-in:mount a dataset into a pot'
      'mount-out:unmount from a pot'
      'start:start a pot'
      'stop:stop a pot'
      'restart:restart a pot'
      'term:terminate a pot'
      'snap:take a snapshot of a pot'
      'rollback:rollback a pot to a snapshot'
      'revert:revert a pot to its original state'
      'purge-snapshots:purge all snapshots'
      'set-attr:set a pot attribute'
      'get-attr:get a pot attribute'
      'export:export a pot'
      'import:import a pot'
      'prepare:prepare a pot image'
      'info:show pot information'
      'list:list pots'
      'show:show pot details'
      'top:show pot resource usage'
      'last-run-stats:show last run statistics'
      'set-cmd:set the pot command'
      'set-env:set a pot environment variable'
      'set-hosts:set pot /etc/hosts'
      'add-dep:add a pot dependency'
      'set-rss:set pot resource limits'
      'signal:send signal to a pot'
      'exec:execute a command in a pot'
      'update-config:update pot configuration'
      'help:show help'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (start|stop|restart|destroy|snap|rollback|term|revert|info|show|top|export|clone|rename|exec|set-attr|get-attr|set-cmd|set-env|set-hosts|add-dep|set-rss|signal|copy-in|copy-out|mount-in|mount-out|purge-snapshots)
        _arguments '-p+[pot name]:pot name:' '*:args:' && ret=0
        ;;
      (create)
        _arguments \
          '-p+[pot name]:name:' \
          '-N+[network type]:type:(inherit alias public-bridge private-bridge)' \
          '-i+[IP address]:IP:' \
          '-b+[base release]:release:' \
          '-t+[pot type]:type:(single multi)' \
          '-f+[flavour]:flavour:' \
          '-l+[level]:level:' \
          '-d+[DNS]:type:(inherit pot custom off)' \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
