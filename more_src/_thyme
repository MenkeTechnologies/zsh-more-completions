#compdef thyme
# Documentation: https://github.com/sourcegraph/thyme
# thyme - automatically track which applications you use and for how long

local ret=1

_arguments -C \
  '1:command:((
    track:"record which applications you use"
    show:"create charts showing application usage"
    list:"list tracked windows"
    dep:"display dependency installation instructions"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '-o[output file path]:file:_files' \
      '-i[input file path]:file:_files' \
      '-w[chart type to render]:widget:(stats timeline)' && ret=0
    ;;
esac

return ret
