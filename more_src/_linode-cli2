#compdef linode-cli2

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'account:account commands'
  'beta:beta features'
  'betas:beta opt-in'
  'configure:configure CLI'
  'databases:managed databases'
  'domains:DNS domains'
  'events:events'
  'firewalls:cloud firewalls'
  'images:custom images'
  'kernels:kernels'
  'lke:Linode Kubernetes Engine'
  'linodes:Linode instances'
  'login-sessions:login sessions'
  'longview:Longview agent'
  'managed:Linode Managed services'
  'monitor:monitor commands'
  'networking:networking'
  'nodebalancers:NodeBalancers'
  'object-storage:object storage'
  'placement:placement groups'
  'plugin:plugin commands'
  'profile:user profile'
  'regions:regions'
  'sshkeys:SSH keys'
  'stackscripts:StackScripts'
  'support:support tickets'
  'tags:tags'
  'tickets:support tickets'
  'token:token commands'
  'types:Linode types'
  'users:user accounts'
  'vlans:VLANs'
  'volumes:block storage'
  'vpcs:VPCs'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--token=[token]:t:' \
  '*--text[text output]' \
  '*--debug[debug]' \
  '*--no-defaults[no defaults]' \
  '*--no-truncation[no truncation]' \
  '*--all[show all columns]' \
  '*--format=[format columns csv]:list:' \
  '*--delimiter=[delimiter]:d:' \
  '*--json[JSON output]' \
  '*--pretty[pretty JSON]' \
  '*--ascii-table[ascii table]' \
  '*--no-headers[no table headers]' \
  '*--page=[page]:n:' \
  '*--page-size=[page size]:n:' \
  '*--all-rows[fetch all rows]' \
  '*--auth-context=[auth context]:c:' \
  '*--suppress-warnings[suppress warnings]' \
  '*--config[show config path]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'linode command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (linodes)
        _arguments \
          '1:subcommand:(boot clone configs-create configs-delete configs-list configs-update create delete disk-clone disk-create disk-delete disk-list disk-resize disk-update events-list firewalls-list ip-add ip-delete ip-update ips-list list mutate password-reset rebuild reboot rescue resize shutdown stats stats-month transfer types update view view-config volumes)' \
          '*: :' && ret=0 ;;
      (lke)
        _arguments \
          '1:subcommand:(cluster-create cluster-delete cluster-update clusters-list dashboard-url kubeconfig-delete kubeconfig-view node-pool-create node-pool-delete node-pool-recycle node-pool-update node-pool-view pools-list types-list versions-list)' \
          '*: :' && ret=0 ;;
      (volumes)
        _arguments \
          '1:subcommand:(attach clone create delete detach list resize update view)' \
          '*: :' && ret=0 ;;
      (domains)
        _arguments \
          '1:subcommand:(clone create delete import list records-create records-delete records-list records-update records-view update view)' \
          '*: :' && ret=0 ;;
      (object-storage)
        _arguments \
          '1:subcommand:(buckets-list cluster-list keys-create keys-delete keys-list keys-update keys-view obj transfers)' \
          '*: :' && ret=0 ;;
      (configure)
        _arguments \
          '--token=[token]:t:' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
