#compdef opusenc

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--quiet[quiet output]' \
  '--bitrate=[target bitrate kbit/s]:kbps:' \
  '--vbr[variable bitrate (default)]' \
  '--cvbr[constrained VBR]' \
  '--hard-cbr[hard CBR]' \
  '--music[tune for music (default)]' \
  '--speech[tune for speech]' \
  '--comp=[encoding complexity 0-10]:n:' \
  '--framesize=[frame size ms]:size:(2.5 5 10 20 40 60)' \
  '--expect-loss=[expected packet loss percent]:pct:' \
  '--downmix-mono[downmix to mono]' \
  '--downmix-stereo[downmix to stereo]' \
  '--max-delay=[max container delay ms]:ms:' \
  '--save-range=[save range coder data]:file:_files' \
  '--set-ctl-int=[low-level encoder control]:spec:' \
  '--uncoupled[disable channel coupling]' \
  '--no-phase-inv[disable phase inversion]' \
  '--serial=[output serial number]:n:' \
  '--title=[Title comment]:title:' \
  '--artist=[Artist comment]:artist:' \
  '--album=[Album comment]:album:' \
  '--tracknumber=[Track number]:n:' \
  '--date=[Date]:date:' \
  '--genre=[Genre]:genre:' \
  '*--comment=[NAME=VALUE comment]:comment:' \
  '*--picture=[picture spec]:spec:' \
  '--padding=[reserve N bytes header padding]:n:' \
  '--discard-comments[discard input comments]' \
  '--discard-pictures[discard input pictures]' \
  '--raw[input is raw PCM]' \
  '--raw-bits=[raw input bits]:n:' \
  '--raw-rate=[raw input sample rate]:n:' \
  '--raw-chan=[raw input channels]:n:' \
  '--raw-endianness=[raw input endianness]:e:(0 1)' \
  '*:input:_files'
