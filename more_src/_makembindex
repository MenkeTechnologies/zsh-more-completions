#compdef makembindex
# BLAST+ tool to build a MegaBLAST N-mer index for a database or FASTA file
# Flags from NCBI BLAST+ Command Line Applications User Manual (NBK279684)

local ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '-input=[input file name or BLAST database name]:input:' \
  '-output=[resulting index name]:name:' \
  '-iformat=[input format]:format:(fasta blastdb)' \
  '-legacy=[use legacy index style]:bool:(true false)' \
  '-old_style_index=[generate deprecated old-style index]:bool:(true false)' \
  '-db_mask=[exclude masked regions from the index]:int:' \
  '-nmer=[N-mer size for indexing]:int:' \
  '-ws_hint=[word size hint]:int:' \
  '-stride=[index every stride-th N-mer]:int:' \
  '-volsize=[target volume size in megabytes]:int:' \
  '-logfile=[file to which the program log is written]:file:_files' \
  '-verbosity=[verbosity level]:level:(quiet normal verbose)' && ret=0

return ret
