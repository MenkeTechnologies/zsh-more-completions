#compdef nmens gmx-nmens
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-nmens.html
# gmx nmens: generate an ensemble of structures from the normal modes

local ret=1

_arguments -s \
  '-v[full precision trajectory file (eigenvectors)]:file:_files' \
  '-e[xvgr/xmgr file containing eigenvalues]:file:_files' \
  '-s[structure file with mass information]:file:_files' \
  '-n[index file]:file:_files' \
  '-o[output trajectory file for ensemble structures]:file:_files' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-temp[temperature setting in Kelvin]:real:' \
  '-seed[random seed for reproducibility]:int:' \
  '-num[quantity of structures to generate]:int:' \
  '-first[initial eigenvector index]:int:' \
  '-last[final eigenvector index]:int:' && ret=0

return ret
