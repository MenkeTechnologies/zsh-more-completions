#compdef nvlink
# Documentation: https://docs.nvidia.com/cuda/cuda-compiler-driver-nvcc/index.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (section 4.2.9.3 NVLINK Options).

# nvlink: NVIDIA device-code linker (CUDA)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-w --disable-warnings)'{-w,--disable-warnings}'[disable warnings]' \
  '--preserve-relocs[preserve relocations in the linked output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-Werror --warning-as-error)'{-Werror,--warning-as-error}'[treat warnings as errors]' \
  '--suppress-arch-warning[suppress arch mismatch warnings]' \
  '--suppress-stack-size-warning[suppress stack size warnings]' \
  '--dump-callgraph[dump the call graph]' \
  '--dump-callgraph-no-demangle[dump call graph without demangling]' \
  '(-Xptxas --Xptxas)'{-Xptxas,--Xptxas}'[pass option directly to ptxas]:option:' \
  '--cpu-arch=[host CPU architecture]:arch:' \
  '--extra-warnings[enable extra warnings]' \
  '(-ghls --gen-host-linker-script)'{-ghls,--gen-host-linker-script}'[generate host linker script]' \
  '--ignore-host-info[ignore host info embedded in inputs]' \
  '--keep-system-libraries[keep system libraries in output]' \
  '--kernels-used=[list of kernels used]:kernels:' \
  '(-optf --options-file)'{-optf,--options-file}'[read options from file]:file:_files' \
  '--report-arch[report architecture of inputs]' \
  '--suppress-debug-info[suppress debug info]' \
  '--variables-used=[list of variables used]:variables:' \
  '--device-stack-protector=[enable device-side stack protector]:val:(true false)' \
  '*:input files:_files' && ret=0
return ret
