#compdef jack_session_notify
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/tools/session_notify.c
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above.
# Note: prior file invented -n/-s/--name/--server; the real usage is
# "jack_session_notify quit|save [path]" — positional only.

# jack_session_notify: send session notify (save/quit) to JACK clients
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:action:(quit save)' \
  '2:path:_files -/' && ret=0
return ret
