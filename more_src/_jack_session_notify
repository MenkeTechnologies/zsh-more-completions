#compdef jack_session_notify

# jack_session_notify: send session notify (save/quit) to JACK clients
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-n[JACK client name]:name:' \
  '--name=[JACK client name]:name:' \
  '-s[JACK server name]:name:' \
  '--server=[JACK server name]:name:' \
  '*::jack_session_notify args:_files' && ret=0
return ret
