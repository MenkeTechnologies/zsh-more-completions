#compdef np-audit
# Documentation: https://www.npmjs.com/package/np-audit
# Reference accessed: 2026-05-23
# Verified: npx np-audit --help.

# Zsh completion for np-audit - npm package install-script security auditor

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'alias:install shell hook to scan before npm install/ci'
  'ci:audit then run npm ci'
  'config:view or modify npa configuration'
  'c:alias for config'
  'install:audit then run npm install'
  'i:alias for install'
  'scan:scan only without invoking npm'
  's:alias for scan'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '--version[show version]'   '--review[interactive script review mode]'   '-r[interactive script review mode]'   '--json[JSON output]'   '--no-dev[skip devDependencies]'   '--verbose[verbose output]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'np-audit command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
