#compdef dumresp
# Documentation: https://doc.powerdns.com/authoritative/manpages/dumresp.1.html
# DNS packet echo tool that replies with the same query, setting the QR bit

local ret=1

_arguments -s -S \
  '1:local-address:_hosts' \
  '2:local-port:_ports' \
  '3:number-of-processes:' \
  '4:tcp:(tcp)' && ret=0

return ret
