#compdef fsort
# Sort the contents of a FITS table

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "columns=[columns to sort on]:" \
  "method=[sort method heap or insert]:method:(heap insert)" \
  "ascend=[sort in ascending order]:bool:(yes no)" \
  "unique=[remove duplicate rows]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
