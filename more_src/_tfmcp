#compdef tfmcp
# Documentation: https://github.com/nwiizo/tfmcp
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
local curcontext="$curcontext" state line ret=1

local -a _tfmcp_cmds
_tfmcp_cmds=(
  'mcp:run tfmcp as an MCP server over stdio'
  'analyze:analyze Terraform in the project directory'
)

_arguments -C -s -S \
  '(-c --config)'{-c,--config}'[path to configuration file]:file:_files' \
  '(-d --dir)'{-d,--dir}'[Terraform project directory]:directory:_files -/' \
  '(-V --version)'{-V,--version}'[print version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'tfmcp command' _tfmcp_cmds && ret=0
    ;;
  args)
    case $line[1] in
      mcp|analyze|help)
        _message -e arguments 'no further tfmcp subcommand flags'
        ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
