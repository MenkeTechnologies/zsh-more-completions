#compdef tfmcp
# Documentation: https://man.archlinux.org/search?q=tfmcp
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/tfmcp
local curcontext="$curcontext" state line ret=1

local -a _tfmcp_cmds
_tfmcp_cmds=(
  'mcp:run tfmcp as an MCP server over stdio'
  'analyze:analyze Terraform in the project directory'
)

_arguments -C -s -S \
  '(-c --config)'{-c,--config}'[path to configuration file]:file:_files' \
  '(-d --dir)'{-d,--dir}'[Terraform project directory]:directory:_files -/' \
  '(-V --version)'{-V,--version}'[print version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'tfmcp command' _tfmcp_cmds && ret=0
    ;;
  args)
    case $line[1] in
      mcp)
        _arguments -s -S \
          '*--toolsets[tool categories to enable]:categories' \
          '*--tools[specific tools to enable]:tools' \
          && ret=0
        ;;
      analyze)
        _message -e arguments 'no further tfmcp analyze flags'
        ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
