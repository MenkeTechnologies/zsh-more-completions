#compdef akumulid
# Documentation: https://docs.akumuli.org/getting-started
# akumulid - Akumuli time-series database server

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[print software version]' \
  '--config=[path to configuration file]:file:_files' \
  '--init[create default configuration file]' \
  '--init-expandable[create configuration for expandable storage]' \
  '--disable-wal[disable WAL in generated configuration]' \
  '--create[create database]' \
  '--allocate[preallocate disk space]' \
  '--delete[delete database files]' \
  '--CI[create database for CI environment]' \
  '--debug-dump=[create debug dump]:path:_files' \
  '--debug-recovery-dump=[create debug dump after crash recovery]:path:_files' && ret=0

return ret
