#compdef archwiki-rs
# _archwiki-rs — CLI tool to read pages from the ArchWiki (lucifayr/archwiki-rs)
# upstream: https://github.com/lucifayr/archwiki-rs
# Flags from src/args/cli.rs (clap).

_archwiki-rs() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'read-page:read a page from the ArchWiki'
                'search:search the ArchWiki for pages'
                'list-pages:list metadata of downloaded pages'
                'list-categories:list metadata of downloaded categories'
                'list-languages:list languages the ArchWiki supports'
                'sync-wiki:download page / category metadata'
                'local-wiki:download a copy of the ArchWiki'
                'info:retrieve info related to this tool'
                'completions:generate shell completion scripts'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                read-page)
                    _arguments \
                        '(-n --no-cache-write)'{-n,--no-cache-write}'[do not cache the read page]' \
                        '(-i --ignore-cache)'{-i,--ignore-cache}'[do not use cached page]' \
                        '(-d --disable-cache-invalidation)'{-d,--disable-cache-invalidation}'[never invalidate stale cache]' \
                        '(-s --show-urls)'{-s,--show-urls}'[show URLs in plain output]' \
                        '(-l --lang)'{-l+,--lang=}'[preferred page language]:lang:' \
                        '(-f --format)'{-f+,--format=}'[output format]:fmt:(plain-text markdown html)' \
                        '1:page:'
                    ;;
                search)
                    _arguments \
                        '(-l --lang)'{-l+,--lang=}'[preferred language]:lang:' \
                        '-L+[result limit]:n:' \
                        '(-t --text-search)'{-t,--text-search}'[search by text content]' \
                        '-H[do not highlight matches]' \
                        '-S+[snippet format for JSON]:fmt:(plain markdown html)' \
                        '(-j --json)'{-j,--json}'[pretty-printed JSON]' \
                        '(-J --json-raw)'{-J,--json-raw}'[raw JSON]' \
                        '1:query:'
                    ;;
                completions)
                    _arguments '1:shell:(bash zsh fish elvish powershell)'
                    ;;
            esac
            ;;
    esac
}

_archwiki-rs "$@"
