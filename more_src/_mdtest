#compdef mdtest
# Documentation: https://github.com/hpc/ior/blob/main/doc/mdtest.1
# File system metadata performance benchmark

local ret=1

_arguments -s \
  '-b[branching factor of the hierarchical directory structure]:factor:' \
  '-B[no barriers between phases (create/stat/remove)]' \
  '-c[use collective creates, task 0 does all creates]' \
  '-C[only perform the create phase of the tests]' \
  '-d[the directory in which the tests will run]:dir:_directories' \
  '-D[perform test on directories only (no files)]' \
  '-e[number of bytes to read from each file]:bytes:' \
  '-E[only perform the read phase of the tests]' \
  '-f[first number of tasks on which the test will run]:num:' \
  '-F[perform test on files only (no directories)]' \
  '-g[use global default directory layout (Lustre only)]' \
  '-h[display help message]' \
  '-i[number of iterations the test will run]:count:' \
  '-I[number of items per directory in the tree]:count:' \
  '-l[last number of tasks on which the test will run]:num:' \
  '-L[files/directories only created at the leaf level]' \
  '-n[every process creates/stats/removes this many dirs and files]:num:' \
  '-N[stride between neighbor tasks for stat (0=local)]:stride:' \
  '-p[pre-iteration delay in seconds]:seconds:' \
  '-P[print both the file creation rate and the elapsed time]' \
  '-r[only perform the remove phase of the tests]' \
  '-R-[randomly stat files (optional seed)]::seed:' \
  '-s[stride between the number of tasks for each test]:stride:' \
  '-S[shared file access (file only, no directories)]' \
  '-t[include unique working directory management overhead]' \
  '-T[only perform the stat phase of the tests]' \
  '-u[create a unique working directory for each task]' \
  '*-v[increase verbosity (each instance increments by one)]' \
  '-V[set verbosity value]:level:' \
  '-w[number of bytes to write to each file after creation]:bytes:' \
  '-W[specify the stonewall time in seconds]:seconds:' \
  '-x[filename for stonewall synchronization between processes]:file:_files' \
  '-Y[call sync after each phase, included in timing]' \
  '-z[depth of the hierarchical directory tree]:depth:' && ret=0

return ret
