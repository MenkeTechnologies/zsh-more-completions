#compdef sent
# Documentation: https://man.archlinux.org/search?q=sent
# Reference accessed: 2026-05-16

# Zsh completion for sent (suckless simple plaintext presentation tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[use specified colors]:foreground background' \
  '-f[use specified font]:font name' \
  '-i[reload on SIGHUP]' \
  '-v[show version]' \
  '1:presentation file:_files -g "*.txt(N)"' && ret=0

return ret
