#compdef jenkins-jobs
# Documentation: https://opendev.org/jjb/jenkins-job-builder/raw/branch/master/jenkins_jobs/cli/parser.py
# Reference accessed: 2026-05-19
# Verified: jjb/jenkins-job-builder cli/parser.py global arguments
# and subcommand namespace (update, test, delete, delete-all, list).

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'update:create or update jobs/views'
  'test:test job/view generation (no upload)'
  'delete:delete a job/view'
  'delete-all:delete *all* jobs/views from Jenkins'
  'list:list jobs in the Jenkins instance'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--conf=[configuration file]:file:_files' \
  '(-l --log_level)'{-l,--log_level}'[log level]:level:(debug info warning error critical)' \
  '--ignore-cache[ignore the cache and update jobs anyhow]' \
  '--flush-cache[flush all cache entries before updating]' \
  '--allow-empty-variables[replace undefined variables with empty strings]' \
  '(-s --server)'{-s,--server}'=[Jenkins server ini section]:section:' \
  '(-u --user)'{-u,--user}'=[Jenkins authentication user]:user:_users' \
  '(-p --password)'{-p,--password}'=[password or API token]:password:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'jenkins-jobs subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (update|test|delete)
        _arguments \
          '*:path:_files' && ret=0 ;;
    esac ;;
esac

return ret
