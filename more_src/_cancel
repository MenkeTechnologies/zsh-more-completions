#compdef cancel
# Documentation: https://manpages.debian.org/cancel
# Source: OpenPrinting/cups systemv/cancel.c — cancel CUPS print jobs (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[use encryption]' \
    '-U+[username for authentication]:user:_users' \
    '-a[cancel all jobs on destination(s)]' \
    '-h+[connect to CUPS server[:port]]:host:_hosts' \
    '-u+[user whose jobs to cancel]:user:_users' \
    '-x[purge jobs (remove from history)]' \
    '*:job ID or printer:_default' \
    && ret=0

return ret
