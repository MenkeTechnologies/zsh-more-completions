#compdef cyrus-smmapd
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/smmapd.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org smmapd(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-smmapd: Sendmail socket-map daemon for Cyrus
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-U[max process reuses before shutdown (default 250)]:n:' \
  '-T[idle timeout seconds before shutdown (default 60)]:seconds:' \
  '-D[run external debugger]' \
  '-p[skip plus addressing (strip + through @)]' && ret=0
return ret
