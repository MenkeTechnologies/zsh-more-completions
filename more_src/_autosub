#compdef autosub

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-C --concurrency)'{-C+,--concurrency=}'[number of concurrent API requests]:n:' \
  '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
  '(-F --format)'{-F+,--format=}'[output format]:format:(srt vtt sbv json raw)' \
  '(-S --src-language)'{-S+,--src-language=}'[source language code]:lang:' \
  '(-D --dst-language)'{-D+,--dst-language=}'[destination language code]:lang:' \
  '(-K --api-key)'{-K+,--api-key=}'[Google API key]:key:' \
  '--list-formats[list output formats]' \
  '--list-languages[list supported languages]' \
  '(-N --null-padding)'{-N,--null-padding}'[null pad subtitles]' \
  '*:video_file:_files' && ret=0

return ret
