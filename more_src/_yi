#compdef yi
# Documentation: https://man.archlinux.org/search?q=yi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --frontend)'{-f,--frontend}'+[frontend]:fe:(vty pango)' \
  '(-y --config)'{-y,--config}'+[config file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-l --line)'{-l,--line}'+[line number]:line:' \
  '(-p --plugin)'{-p,--plugin}'+[plugin]:plugin:' \
  '--ghc-option=+[ghc option]:opt:' \
  '--as=+[keymap]:keymap:(vim emacs cua)' \
  '*:file:_files' && ret=0

return ret
