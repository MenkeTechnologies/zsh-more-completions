#compdef gpcheckperf
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpcheckperf.html
# Verify the baseline hardware performance of Greenplum Database hosts

local ret=1

_arguments -s -S \
  '-?[display online help]' \
  '--version[display utility version]' \
  '*-d[file system directory for tests or temp directory]:dir:_files -/' \
  '-f[hostfile with one host per line]:file:_files' \
  '*-h[individual host name]:host:_hosts' \
  '-r[tests to run (d disk, s stream, n/N/M network)]:tests' \
  '-B[disk I/O block size]:block_size' \
  '-S[total file size for disk I/O test]:file_size' \
  '--buffer-size[send buffer size in kilobytes]:buffer_size' \
  '-D[report per-host results for disk I/O tests]' \
  '--duration[network test duration]:time' \
  '--netperf[use netperf binary instead of Greenplum network test]' \
  '-v[verbose mode showing progress and status]' \
  '-V[very verbose mode displaying all output]' && ret=0

return ret
