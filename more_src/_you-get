#compdef you-get

# Zsh completion for you-get - media downloader

_arguments -s -S \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-i --info)'{-i,--info}'[print extracted information]' \
  '(-u --url)'{-u,--url}'[print extracted URLs]' \
  '(-c --cookies)'{-c,--cookies}'[load cookies from file]:file:_files' \
  '(-f --force)'{-f,--force}'[force overwriting existing files]' \
  '--skip-existing-file-size-check[skip existing file size check]' \
  '(-F --format)'{-F,--format}'[set video format to stream id]:format:' \
  '(-O --output-filename)'{-O,--output-filename}'[set output filename]:filename:_files' \
  '(-o --output-dir)'{-o,--output-dir}'[set output directory]:directory:_files -/' \
  '(-p --player)'{-p,--player}'[stream extracted URL to a PLAYER]:player:' \
  '(-k --insecure)'{-k,--insecure}'[ignore ssl errors]' \
  '(-l --playlist)'{-l,--playlist}'[prefer to download a playlist]' \
  '(-a --auto-rename)'{-a,--auto-rename}'[auto rename same name different files]' \
  '-m+[HTTP referer]:referer:' \
  '-t+[set socket timeout (seconds)]:seconds:' \
  '(-d --debug)'{-d,--debug}'[show traceback and other debug info]' \
  '(-I --input-file)'{-I,--input-file}'[read non-playlist URLs from file]:file:_files' \
  '(-P --password)'{-P,--password}'[set password]:password:' \
  '(-e --extractor-proxy)'{-e,--extractor-proxy}'[use specific HTTP proxy for extractor]:proxy:' \
  '(-y --extractor-proxy)'{-y,--extractor-proxy}'[use specific HTTP proxy for extractor]:proxy:' \
  '(-s --socks-proxy)'{-s,--socks-proxy}'[use SOCKS5 proxy]:proxy:' \
  '(-x --http-proxy)'{-x,--http-proxy}'[use HTTP proxy]:proxy:' \
  '--no-proxy[do not use any proxy]' \
  '--no-caption[do not download captions]' \
  '--no-merge[do not merge video parts]' \
  '--json[print extracted URL metadata in JSON format]' \
  '*:URL:'
