#compdef argo-events-cli
# _argo-events-cli — Argo Events Kubernetes-native event-driven workflow framework CLI alias (argoproj team, Go); cobra
# upstream: https://github.com/argoproj/argo-events

_argo-events-cli() {
    local -a sub=(
        'eventbus:list:list event buses'
        'eventbus:get:get event bus'
        'eventbus:create:create event bus'
        'eventbus:delete:delete event bus'
        'eventsource:list:list event sources'
        'eventsource:get:get event source'
        'eventsource:create:create event source'
        'eventsource:delete:delete event source'
        'eventsource:lint:lint event source'
        'sensor:list:list sensors'
        'sensor:get:get sensor'
        'sensor:create:create sensor'
        'sensor:delete:delete sensor'
        'sensor:lint:lint sensor'
        'trigger:list:list triggers'
        'logs:show logs'
        'wait:wait for resource'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--namespace=+[namespace]:str:' \
        '-n+[namespace]:str:' \
        '--context=+[context]:str:' \
        '--kubeconfig=+[file]:file:_files' \
        '--cluster=+[cluster]:str:' \
        '--server=+[server]:str:' \
        '--token=+[token]:str:' \
        '--user=+[user]:_users' \
        '--insecure-skip-tls-verify[skip tls verify]' \
        '-o+[output]:f:(json yaml wide name)' \
        '--output=+[output]:f:(json yaml wide name)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'argo-events subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_argo-events-cli "$@"
