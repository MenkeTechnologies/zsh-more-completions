#compdef chgcentre
# Documentation: https://wsclean.readthedocs.io/en/latest/chgcentre.html
# Change the phase centre of a MeasurementSet, recomputing UVW and phase-rotating.

local ret=1

_arguments -s -S \
  '-geozenith[calculate RA,dec of zenith per timestep and move there]' \
  '-flipuvwsign[flip the UVW sign (necessary for LOFAR)]' \
  '-minw[shift to the direction giving minimum w-values for the array]' \
  '-zenith[shift to the average zenith value]' \
  '-only-uvw[only update UVW values, do not apply the phase shift]' \
  '-shiftback[project visibilities back to the old phase centre after rotation]' \
  '-f[force recalculation even if destination equals original direction]' \
  '-datacolumn[only phase-rotate visibilities in the given column]:column:' \
  '-from-ms[rotate to the direction specified in the provided measurement set]:ms:_files -/' \
  '*:measurement set:_files -/' && ret=0

return ret
