#compdef planetscale-cli2 pscale2
# _planetscale-cli2 — PlanetScale planetscale-cli2 CLI command-line frontend wrapping the PlanetScale CLI command-line interface for PlanetScale serverless MySQL platform built on Vitess open-source written in Go MySQL-compatible-serverless-database-platform branches deploy-requests audit-logs backups regions diagnostics queries database keyspaces schema-snippets connect shell connect login logout switch service-tokens regions auth orgs deploy-requests deploy-requests-cancel deploy-requests-show deploy-requests-update tables (PlanetScale team Sam Lambert Nick Van Wiggeren, Go); cobra
# upstream: https://planetscale.com/

_planetscale-cli2() {
    local -a sub=(
        'audit-logs:audit log operations'
        'auth:auth operations'
        'backup:backup operations'
        'branch:branch operations'
        'completion:generate shell completion'
        'connect:connect to a branch'
        'data-imports:data import operations'
        'database:database operations'
        'db:short for database'
        'deploy-request:deploy request operations'
        'dr:short for deploy-request'
        'diagnose:run diagnostics'
        'help:show help'
        'keyspace:keyspace operations'
        'login:authenticate'
        'logout:revoke session'
        'me:show identity'
        'org:organization operations'
        'password:database password ops'
        'ping:ping a branch'
        'project:project operations'
        'queries:queries operations'
        'region:region operations'
        'service-token:service token operations'
        'shell:open MySQL shell'
        'signup:sign up an account'
        'size:show usage'
        'switch:switch active org'
        'token:short for service-token'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--api-token=+[token]:str:' \
        '--api-host=+[host]:_hosts' \
        '--debug[debug]' \
        '--service-token=+[token]:str:' \
        '--service-token-id=+[id]:str:' \
        '--service-token-name=+[name]:str:' \
        '--org=+[name]:str:' \
        '--organization=+[name]:str:' \
        '-O+[org]:str:' \
        '--no-color[no color]' \
        '--format=+[fmt]:f:(json yaml table csv)' \
        '-f+[format]:f:(json yaml table csv)' \
        '--output=+[fmt]:f:(json yaml table csv)' \
        '--no-update-check[no update check]' \
        '--branch=+[name]:str:' \
        '-b+[branch]:str:' \
        '--from=+[name]:str:' \
        '--to=+[name]:str:' \
        '--into-keyspace=+[name]:str:' \
        '--cluster-size=+[s]:str:' \
        '--notes=+[text]:str:' \
        '--password=+[name]:str:' \
        '--port=+[port]:n:' \
        '--host=+[host]:_hosts' \
        '--region=+[name]:str:' \
        '--plan=+[name]:str:' \
        '--ttl=+[d]:str:' \
        '--role=+[r]:r:(reader writer admin readwriter)' \
        '--web[open in browser]' \
        '-w[web]' \
        '--force[force]' \
        '--execute=+[cmd]:str:' \
        '-e+[execute]:str:' \
        '--query=+[sql]:str:' \
        '--type=+[t]:str:' \
        '--protected=+[v]:v:(true false)' \
        '--production=+[v]:v:(true false)' \
        '--from-backup=+[id]:str:' \
        '--from-restored-backup=+[id]:str:' \
        '--include-data-only[include data only]' \
        '--access-host-key=+[name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pscale subcommand' sub ;;
        args)
            case $words[1] in
                database|db|branch|backup|deploy-request|dr|keyspace|org|region|service-token|token|password|audit-logs|queries|data-imports|project) _arguments '1:op:(list get create delete update show diff promote demote refresh-schema apply cancel close deploy revert keyspaces schema vt-gates lint enable disable add-grant remove-grant set-default)' '*:name:' ;;
                connect) _arguments '1:database:' '*:branch:' ;;
                shell) _arguments '1:database:' '*:branch:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_planetscale-cli2 "$@"
