#compdef rich

local -a arguments

arguments=(
  '(-p --print)'{-p,--print}'[print to console]'
  '(-j --json)'{-j,--json}'[print as formatted JSON]'
  '(-m --markdown)'{-m,--markdown}'[render as Markdown]'
  '(-rst --restructuredtext)'{-rst,--restructuredtext}'[render as reStructuredText]'
  '(-c --csv)'{-c,--csv}'[render as CSV table]'
  '(-t --text)'{-t,--text}'[treat as plain text]'
  '(-s --syntax)'{-s,--syntax}'[syntax highlight]'
  '--syntax-theme=[syntax theme]:theme:'
  '--theme=[rich theme]:theme:'
  '(-n --line-numbers)'{-n,--line-numbers}'[show line numbers]'
  '(-g --guides)'{-g,--guides}'[show indent guides]'
  '(-l --lexer)'{-l,--lexer}'=[pygments lexer]:lexer:'
  '(-r --rule)'{-r,--rule}'[render a horizontal rule]'
  '--head=[number of lines from start]:lines:'
  '--tail=[number of lines from end]:lines:'
  '(-e --emoji)'{-e,--emoji}'[enable emoji]'
  '(-w --width)'{-w,--width}'=[output width]:width:'
  '--soft-wrap[enable soft wrapping]'
  '--force-terminal[force terminal output]'
  '--no-wrap[disable word wrapping]'
  '--pager[output via pager]'
  '--hyperlinks[enable hyperlinks]'
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version]'
  '*:file:_files'
)

_arguments -s -S $arguments
