#compdef rich
# Documentation: https://github.com/Textualize/rich-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Textualize/rich-cli installs a binary called `rich`.

local -a arguments

arguments=(
  '(-p --print)'{-p,--print}'[treat input as console markup]'
  '(-J --json)'{-J,--json}'[render as JSON]'
  '(-m --markdown)'{-m,--markdown}'[render as Markdown]'
  '--ipynb[render Jupyter notebook]'
  '(-x --lexer)'{-x+,--lexer=}'[override lexer used for syntax highlighting]:lexer:'
  '(-n --line-number)'{-n,--line-number}'[show line numbers]'
  '(-g --guides)'{-g,--guides}'[show indentation guides]'
  '--theme=[syntax highlighting theme]:theme:'
  '--no-wrap[disable line wrapping]'
  '(-y --hyperlinks)'{-y,--hyperlinks}'[output hyperlinks instead of URLs]'
  '(-u --rule)'{-u,--rule}'[render a horizontal rule]'
  '--rule-style=[rule color/style]:style:'
  '--rule-char=[character(s) for rule line]:char:'
  '(-s --style)'{-s+,--style=}'[apply a style to the output]:style:'
  '(-l --left)'{-l,--left}'[left align content]'
  '(-c --center)'{-c,--center}'[center align content]'
  '(-r --right)'{-r,--right}'[right align content]'
  '(-w --width)'{-w+,--width=}'[set output width]:width:'
  '(-L --text-left)'{-L,--text-left}'[left justify text]'
  '(-R --text-right)'{-R,--text-right}'[right justify text]'
  '(-C --text-center)'{-C,--text-center}'[center justify text]'
  '(-F --text-full)'{-F,--text-full}'[full justify text]'
  '(-d --padding)'{-d+,--padding=}'[add padding around output]:padding:'
  '(-a --panel)'{-a+,--panel=}'[draw panel around content]:box style:(none rounded heavy double ascii square)'
  '--soft[enable soft word wrapping]'
  '--pager[display with built-in pager]'
  '(-o --export-html)'{-o+,--export-html=}'[export as HTML]:file:_files'
  '--force-terminal[keep ANSI codes in output]'
  '--help[show help]'
  '*:file:_files'
)

_arguments -s -S $arguments
