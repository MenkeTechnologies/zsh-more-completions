#compdef freecad-cmd
# Documentation: https://man.archlinux.org/search?q=freecad-cmd
# Reference accessed: 2026-05-16

# freecad-cmd: command-line FreeCAD (no GUI, alternative name)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --console)'{-c,--console}'[console mode]' \
  '(-t --run-test)'{-t,--run-test=}'[run unit test]:test:' \
  '(-M --module-path)'{-M,--module-path=}'[module path]:dir:_files -/' \
  '(-P --python-path)'{-P,--python-path=}'[Python path]:dir:_files -/' \
  '*:FreeCAD file or script:_files' && ret=0
return ret
