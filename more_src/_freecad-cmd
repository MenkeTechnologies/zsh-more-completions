#compdef freecad-cmd
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/freecad.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# freecad-cmd — command-line FreeCAD (alternative name for FreeCADCmd).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --console)'{-c,--console}'[run in console mode]' \
  '(-l --write-log)'{-l,--write-log}'[write log file]' \
  '(-t --run-test)'{-t+,--run-test=}'[run unit test]:test' \
  '(-M --module-path)'{-M+,--module-path=}'[additional module path]:dir:_files -/' \
  '(-P --python-path)'{-P+,--python-path=}'[additional Python path]:dir:_files -/' \
  '--response-file=[response file]:file:_files' \
  '*:FreeCAD file or script:_files' && ret=0
return ret
