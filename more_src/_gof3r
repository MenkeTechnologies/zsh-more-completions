#compdef gof3r
# Documentation: https://github.com/rlmcpherson/s3gof3r
# gof3r - fast, streaming, concurrent transfers to/from Amazon S3

local ret=1

_arguments -C -s \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-m --manpage)'{-m,--manpage}'[create gof3r.man man page in current directory]' \
  '(-i --writeini)'{-i,--writeini}'[write .gof3r.ini in current user home directory]' \
  '1:command:(get put cp rm)' \
  '*::args:->args' && ret=0

case $state in
  args)
    _arguments -s \
      '(-b --bucket)'{-b,--bucket=}'[S3 bucket]:bucket' \
      '(-k --key)'{-k,--key=}'[S3 object key]:key' \
      '(-p --path)'{-p,--path=}'[path to file. Defaults to standard input/output]:path:_files' \
      '(-m --header)'{-m,--header=}'[HTTP headers, set custom metadata or content-type]:header' \
      '--acl=[canned acl to apply to the object]:acl' \
      '--endpoint=[Amazon S3 endpoint]:endpoint' \
      '(-c --concurrency)'{-c,--concurrency=}'[concurrency of transfers]:concurrency' \
      '(-s --partsize)'{-s,--partsize=}'[initial size of concurrent parts, in bytes]:partsize' \
      '--no-md5[do not use md5 hash checking to ensure data integrity]' \
      '--no-ssl[do not use SSL for endpoint connection]' \
      '--retries=[number of attempts to try]:retries' \
      '--debug[enable debug logging]' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
