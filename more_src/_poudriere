#compdef poudriere

# Zsh completion for poudriere - FreeBSD ports build tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'bulk:generate packages for given ports'
  'jail:manage the jails used by poudriere'
  'ports:create, update or delete the ports tree'
  'testport:test a given port build'
  'options:configure port options'
  'distclean:remove old distfiles'
  'pkgclean:remove packages not in the specified list'
  'queue:queue a bulk build'
  'status:show the status of builds'
  'logclean:remove old log files'
  'image:build a system image'
  'foreachport:run a command for each port'
  'daemon:launch the poudriere daemon'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-e+[specify etc directory]:etc directory:_directories' \
  '-A[all targets]' \
  '-v[verbose output]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'poudriere command' commands && ret=0
    ;;
  args)
    case $words[1] in
      bulk)
        _arguments \
          '-a[build the whole ports tree]' \
          '-B+[specify what buildname to use]:build name' \
          '-c[clean all packages from the jail]' \
          '-C[clean only restricted packages]' \
          '-f+[file with list of ports]:port list:_files' \
          '-F[only fetch from original master sites]' \
          '-i[interactive mode]' \
          '-I[skip build and enter interactive mode]' \
          '-j+[which jail to use]:jail name' \
          '-J+[number of jobs]:jobs' \
          '-n[dry run]' \
          '-p+[which ports tree to use]:ports tree' \
          '-R[clean repos]' \
          '-r[recursively test all dependencies]' \
          '-t[test the specified port(s)]' \
          '-T[try to build broken ports]' \
          '-v[verbose output]' \
          '-w[save WRKDIR on build failure]' \
          '-z+[specify the set name]:set name' \
          '*:port origin:' && ret=0
        ;;
      jail)
        _arguments \
          '-c[create a jail]' \
          '-d[delete a jail]' \
          '-i[show information about a jail]' \
          '-k[kill a running jail]' \
          '-l[list all jails]' \
          '-r[rename a jail]' \
          '-s[start a jail]' \
          '-u[update a jail]' \
          '-j+[jail name]:jail name' \
          '-a+[architecture]:arch:(amd64 i386 arm64)' \
          '-f+[filesystem type]:filesystem:(none zfs)' \
          '-m+[fetch method]:method:(http ftp svn git url tar null)' \
          '-M+[mountpoint]:mountpoint:_directories' \
          '-v+[version of FreeBSD]:version' \
          '-z+[specify the set name]:set name' && ret=0
        ;;
      ports)
        _arguments \
          '-c[create a ports tree]' \
          '-d[delete a ports tree]' \
          '-l[list all ports trees]' \
          '-u[update a ports tree]' \
          '-p+[ports tree name]:ports tree name' \
          '-f+[filesystem type]:filesystem:(none zfs)' \
          '-F[fetch only]' \
          '-m+[fetch method]:method:(git null portsnap svn)' \
          '-M+[mountpoint]:mountpoint:_directories' \
          '-B+[branch name]:branch' && ret=0
        ;;
      testport)
        _arguments \
          '-B+[specify what buildname to use]:build name' \
          '-c[run make config for the port]' \
          '-i[interactive mode]' \
          '-I[enter interactive mode before build]' \
          '-j+[which jail to use]:jail name' \
          '-J+[number of jobs]:jobs' \
          '-n[dry run]' \
          '-p+[which ports tree to use]:ports tree' \
          '-v[verbose output]' \
          '-z+[specify the set name]:set name' \
          '1:port origin:' && ret=0
        ;;
      options)
        _arguments \
          '-c[use config target]' \
          '-C[use config-conditional target]' \
          '-f+[file with list of ports]:port list:_files' \
          '-j+[which jail to use]:jail name' \
          '-n[do not be recursive]' \
          '-p+[which ports tree to use]:ports tree' \
          '-r[remove port options]' \
          '-s[show options instead of configuring]' \
          '-z+[specify the set name]:set name' \
          '*:port origin:' && ret=0
        ;;
      distclean)
        _arguments \
          '-a[clean for all ports]' \
          '-f+[file with list of ports]:port list:_files' \
          '-J+[number of jobs]:jobs' \
          '-n[dry run]' \
          '-p+[which ports tree to use]:ports tree' \
          '-v[verbose output]' \
          '-y[assume yes]' \
          '*:port origin:' && ret=0
        ;;
      pkgclean)
        _arguments \
          '-a[clean all packages]' \
          '-A[operate on all sets]' \
          '-f+[file with list of ports]:port list:_files' \
          '-j+[which jail to use]:jail name' \
          '-J+[number of jobs]:jobs' \
          '-n[dry run]' \
          '-N[do not build the package repo]' \
          '-p+[which ports tree to use]:ports tree' \
          '-R[clean repos]' \
          '-v[verbose output]' \
          '-y[assume yes]' \
          '-z+[specify the set name]:set name' \
          '*:port origin:' && ret=0
        ;;
      status)
        _arguments \
          '-a[show all builds]' \
          '-B+[specify buildname]:build name' \
          '-f[show build results]' \
          '-H[do not print headers]' \
          '-j+[which jail to use]:jail name' \
          '-l[show latest build]' \
          '-p+[which ports tree to use]:ports tree' \
          '-r[show results]' \
          '-z+[specify the set name]:set name' && ret=0
        ;;
      logclean)
        _arguments \
          '-a[operate on all jails]' \
          '-B+[specify buildname]:build name' \
          '-j+[which jail to use]:jail name' \
          '-N+[number of log directories to keep]:count' \
          '-p+[which ports tree to use]:ports tree' \
          '-v[verbose output]' \
          '-y[assume yes]' \
          '-z+[specify the set name]:set name' && ret=0
        ;;
      image)
        _arguments \
          '-c+[overlay directory]:directory:_directories' \
          '-f+[package list file]:file:_files' \
          '-h+[image hostname]:hostname' \
          '-j+[which jail to use]:jail name' \
          '-m+[media type]:media:(rawdisk iso firmware rawfirmware embedded dump tar usb zrawdisk zsnapshot)' \
          '-n+[image name]:name' \
          '-o+[output directory]:directory:_directories' \
          '-p+[which ports tree to use]:ports tree' \
          '-s+[image size]:size' \
          '-z+[specify the set name]:set name' && ret=0
        ;;
      *)
        _arguments \
          '-v[verbose output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
