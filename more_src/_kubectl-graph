#compdef kubectl-graph

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-n --namespace)'{-n,--namespace}'=[Namespace]:namespace:' \
  '(-k --kubeconfig)'{-k,--kubeconfig}'=[Kubeconfig path]:file:_files' \
  '(-o --output)'{-o,--output}'=[Output format]:format:(dot json yaml)' \
  '*::resource or args: _default'
