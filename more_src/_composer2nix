#compdef composer2nix

# Zsh completion for composer2nix - convert PHP composer.json to Nix

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config-file[path to composer.json]:path:_files' \
  '--lock-file[path to composer.lock]:path:_files' \
  '--output[output path]:path:_files' \
  '--name[package name]:name' \
  '--no-dev[exclude dev dependencies]' \
  '--prefer-source[prefer source downloads]' \
  '--prefer-dist[prefer dist downloads]' \
  '--composition[include composition.nix]'
