#compdef create-spree-app
# Documentation: https://spreecommerce.org
# Reference accessed: 2026-05-24
# Verified: npm view create-spree-app bin; create-spree-app npm readme CLI Flags section.

# Zsh completion for create-spree-app - Spree Commerce project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--no-storefront[skip Next.js storefront setup]' \
  '--no-sample-data[skip loading sample products]' \
  '--no-start[do not start Docker services]' \
  '--port=[Spree backend port]:port:' \
  '--use-npm[use npm as package manager]' \
  '--use-yarn[use yarn as package manager]' \
  '--use-pnpm[use pnpm as package manager]' \
  ':store name:' && ret=0

return ret
