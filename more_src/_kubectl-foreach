#compdef kubectl-foreach
# run kubectl commands in all/some contexts in parallel

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-c+[limit parallel executions (0=unlimited)]:num' \
  '-I+[replace VAL in kubectl args with context name]:val' \
  '-q[disable and accept confirmation prompts]' \
  '*::kubectl args:_normal' && ret=0

return ret
