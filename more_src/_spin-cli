#compdef spin
# _spin-cli — Fermyon Spin Wasm microservice runtime (Rust); build + run WASI HTTP/Redis apps on wasmtime
# upstream: https://github.com/fermyon/spin

_spin-cli() {
    local -a sub=(
        'new:create a new app from template'
        'build:build the app'
        'up:run the app locally'
        'deploy:deploy app to Fermyon Cloud'
        'doctor:diagnose env'
        'login:authenticate to Fermyon Cloud'
        'logout:logout'
        'oci:OCI image push/pull'
        'plugin:plugin manager'
        'registry:OCI registry operations'
        'templates:manage templates'
        'watch:watch and rebuild'
        'cloud:cloud subcommands'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spin subcommand' sub ;;
        args)
            case $words[1] in
                up) _arguments \
                    '(-f --from)'{-f,--from}'+[manifest path or OCI ref]:path:_files' \
                    '(-L --listen)'{-L,--listen}'+[listen addr]:addr:' \
                    '(-e --env)'{-e,--env}'+[env var]:KEY=VAL:' \
                    '--direct-mounts[direct file mounts]' \
                    '--temp+[temp dir]:dir:_files -/' \
                    '--state-dir+[state dir]:dir:_files -/' \
                    '--allow-transient-write[allow transient writes]' \
                    '--key-value+[KV store]:str:' \
                    '--sqlite+[sqlite file]:file:_files' ;;
                build) _arguments \
                    '(-f --from)'{-f,--from}'+[manifest path]:file:_files' \
                    '(-u --up)'{-u,--up}'[run after build]' \
                    '--component-id+[component id]:id:' ;;
                new) _arguments \
                    '(-t --template)'{-t,--template}'+[template]:template:' \
                    '(-o --output)'{-o,--output}'+[output dir]:dir:_files -/' \
                    '1:app name:' ;;
                deploy) _arguments \
                    '(-f --from)'{-f,--from}'+[manifest path]:file:_files' \
                    '--registry+[registry]:url:_urls' ;;
                plugin) _arguments '1:plugin cmd:(install uninstall update list upgrade search show)' '*:args:' ;;
                templates) _arguments '1:template cmd:(install uninstall list upgrade)' '*:args:' ;;
            esac
            ;;
    esac
}

_spin-cli "$@"
