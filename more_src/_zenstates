#compdef zenstates zenstates.py
# _zenstates — dynamically edit AMD Ryzen P-States (r4m0n/ZenStates-Linux)
# upstream: https://github.com/r4m0n/ZenStates-Linux
# Flags from zenstates.py (argparse).

_zenstates() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-l --list)'{-l,--list}'[list all P-States]'
        '(-p --pstate)'{-p+,--pstate=}'[P-State index to modify]:state:(0 1 2 3 4 5 6 7)'
        '--enable[enable the selected P-State]'
        '--disable[disable the selected P-State]'
        '(-f --fid)'{-f+,--fid=}'[FID in hex]:fid:'
        '(-d --did)'{-d+,--did=}'[DID in hex]:did:'
        '(-v --vid)'{-v+,--vid=}'[VID in hex]:vid:'
        '--c6-enable[enable C-State C6]'
        '--c6-disable[disable C-State C6]'
    )
    _arguments -s $args
}

_zenstates "$@"
