#compdef ip-netconf
# Documentation: https://man.archlinux.org/man/ip-netconf.8.en
# ip netconf - display network parameters

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip netconf command' \
      'show[display network parameters]' \
      'dev[device to display parameters for]' && ret=0
    ;;
esac

return ret
