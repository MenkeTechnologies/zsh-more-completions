#compdef grav-cli
# _grav-cli — Andy Miller Grav flat-file PHP CMS CLI alias (getgrav team, PHP); symfony console
# upstream: https://github.com/getgrav/grav

_grav-cli() {
    local -a sub=(
        'backup:create grav backup'
        'cache:clear cache'
        'clean:clean dev files'
        'composer:run composer'
        'install:install dependencies'
        'logviewer:view logs'
        'newproject:create new grav site'
        'page-system-validator:validate pages'
        'sandbox:create sandbox install'
        'security:check security issues'
        'server:run dev server'
        'yamllinter:lint yaml files'
        'gpm:index:browse package index'
        'gpm:info:show package info'
        'gpm:install:install package'
        'gpm:uninstall:uninstall package'
        'gpm:update:update package'
        'gpm:version:show package version'
        'gpm:direct-install:install from path'
        'gpm:selfupgrade:upgrade grav'
        'plugin:list:list plugins'
        'completion:dump completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '--env-config=+[env config]:str:' \
        '--lang=+[language]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'grav subcommand' sub ;;
        args)
            case $words[1] in
                gpm:install|gpm:uninstall|gpm:update|gpm:info) _arguments \
                    '*:package:' \
                    '--destination=+[dest]:dir:_files -/' \
                    '-d+[dest]:dir:_files -/' \
                    '--force[force]' \
                    '-f[force]' ;;
                gpm:index) _arguments \
                    '--filter=+[filter]:str:' \
                    '--installed-only[only installed]' \
                    '-I[only installed]' \
                    '--updates-only[only updates]' \
                    '-U[only updates]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_grav-cli "$@"
