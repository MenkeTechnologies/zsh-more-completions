#compdef cmsearch
# Documentation: https://manpages.debian.org/testing/infernal/cmsearch.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Infernal cmsearch: search a CM against a sequence database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-g --glocal)'{-g,--glocal}'[force global alignment]' \
  '-Z[database size in megabases for E-value calibration]:Mb:' \
  '-o[redirect main output to file]:file:_files' \
  '-A[save alignment of significant hits]:file:_files' \
  '--tblout[parseable table of per-sequence hits]:file:_files' \
  '--fmt[output table format]:fmt:(1 2 3)' \
  '--acc[use accessions instead of names]' \
  '--noali[omit alignment section]' \
  '--notextw[unlimited line length in output]' \
  '--textw[output line length]:n:' \
  '--verbose[include filter statistics]' \
  '--nomiss[do not mark truncated hits as fragments]' \
  '--cpu[number of CPU threads]:n:' \
  '--mxsize[CM banded matrix memory cap (MB)]:MB:' \
  '-E[report hits <= this E-value]:Eval:' \
  '-T[report hits with bit score >= this]:bits:' \
  '--incE[include hits up to this E-value]:Eval:' \
  '--incT[include hits with bit score >= this]:bits:' \
  '--cut_ga[use CM GA cutoffs]' \
  '--cut_nc[use CM NC cutoffs]' \
  '--cut_tc[use CM TC cutoffs]' \
  '--max[maximum sensitivity (turn off filters)]' \
  '--nohmm[disable HMM filter]' \
  '--mid[apply mid filter]' \
  '--default[use default filters]' \
  '--rfam[Rfam pipeline mode]' \
  '--hmmonly[HMM-only mode]' \
  '--FZ[filter for Z Mb of sequence]:Mb:' \
  '--nonull3[disable bias composition corrections]' \
  '--cyk[use CYK scoring]' \
  '--acyk[use accelerated CYK scoring]' \
  '--anytrunc[allow truncated hits anywhere]' \
  '--notrunc[disallow truncated hits]' \
  '--toponly[only top strand]' \
  '--bottomonly[only bottom strand]' \
  '--seed[random seed]:n:' \
  '--tformat[sequence file format]:format:' \
  '--mpi[enable MPI parallelization]' \
  '*:CM file and sequence file:_files' && ret=0
return ret
