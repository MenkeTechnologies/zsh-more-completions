#compdef condor_reconfig
# Documentation: https://man.archlinux.org/search?q=condor_reconfig
# Reference accessed: 2026-05-16

# condor_reconfig: send reconfigure signal to a Condor daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-pool[pool]:pool:' \
  '-name[daemon]:name:' \
  '-addr[address]:sinful:' \
  '-debug[debug]' \
  '-master[master]' \
  '-startd[startd]' \
  '-schedd[schedd]' \
  '-collector[collector]' \
  '-negotiator[negotiator]' \
  '-daemon[daemon type]:type:' \
  '-full[full reconfig]' \
  '-all[all hosts]' \
  '-constraint[constraint]:expr:' \
  '*:host:_hosts' && ret=0
return ret
