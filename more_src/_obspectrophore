#compdef obspectrophore
# Documentation: https://openbabel.org/docs/Command-line_tools.html
# Open Babel: calculate Spectrophore(TM) descriptors for molecules

local ret=1

_arguments -s -S \
  '-h[display help]' \
  '-i+[input file from which Spectrophores are calculated]:input file:_files' \
  '-n+[normalization]:normalization:(No ZeroMean UnitStd ZeroMeanAndUnitStd)' \
  '-a+[accuracy expressed as the angular stepsize]:accuracy:(1 2 5 10 15 20 30 36 45 60)' \
  '-s+[stereo treatment in terms of cages used]:stereo:(No Unique Mirror All)' \
  '-r+[resolution expressed as a real positive number]:resolution' \
  '-u[display implementation details]' && ret=0

return ret
