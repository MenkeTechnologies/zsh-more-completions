#compdef devin-cli
# Documentation: https://cli.devin.ai/docs/reference/commands
# Reference accessed: 2026-05-23
# Verified: same commands as devin; see _devin.

# Zsh completion for devin-cli - Devin terminal agent (alternate binary name)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model[AI model for session]:model:' \
  '--permission-mode[permission mode]:(normal dangerous bypass)' \
  '--respect-workspace-trust[honor workspace trust settings]' \
  '(-c --continue)'{-c,--continue}'[resume most recent session]' \
  '(-r --resume)'{-r,--resume}'[resume session by ID]:id:' \
  '(-p --print)'{-p,--print}'[non-interactive mode]' \
  '--prompt-file[initial prompt file]:file:_files' \
  '--config[custom config path]:file:_files' \
  '--json[JSON output]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'devin-cli command' \
      'auth[manage authentication]' \
      'mcp[manage MCP servers]' \
      'rules[manage agent rules]' \
      'skills[manage custom skills]' \
      'list[list recent sessions]' \
      'ls[alias for list]' \
      'setup[interactive setup wizard]' \
      'shell[manage shell integration]' \
      'update[check for updates]' \
      'uninstall[uninstall Devin CLI]' \
      'version[show version]' \
      'acp[run ACP server on stdio]' && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        _values 'auth command' login logout status && ret=0
        ;;
      mcp)
        _values 'mcp command' add list get remove login logout && ret=0
        ;;
      rules)
        _values 'rules command' list show paths && ret=0
        ;;
      skills)
        _values 'skills command' list show paths && ret=0
        ;;
    esac
    ;;
esac

return ret
