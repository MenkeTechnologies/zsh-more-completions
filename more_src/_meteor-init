#compdef meteor-init
# _meteor-init — Meteor isomorphic JavaScript framework init CLI alias (meteor team, JavaScript); custom argparse
# upstream: https://github.com/meteor/meteor

_meteor-init() {
    local -a sub=(
        'create:create new meteor app'
        'run:run app'
        'debug:run with debugger'
        'update:update meteor packages'
        'add:add a package'
        'remove:remove a package'
        'list:list packages'
        'add-platform:add platform'
        'remove-platform:remove platform'
        'list-platforms:list platforms'
        'mongo:open mongo shell'
        'reset:reset app'
        'deploy:deploy app'
        'logs:show logs'
        'authorized:list authorized users'
        'login:login to meteor cloud'
        'logout:logout'
        'whoami:show current user'
        'test-packages:test packages'
        'admin:admin commands'
        'list-sites:list deployed sites'
        'publish:publish a package'
        'publish-for-arch:publish for arch'
        'publish-release:publish release'
        'search:search packages'
        'show:show package info'
        'lint:lint app'
        'shell:open shell into app'
        'help:show help'
        'version:show version'
        'node:run node command'
        'npm:run npm command'
        'create-package:create package scaffold'
        'create-app:create app scaffold'
        'build:build app'
        'meteor-server:start meteor server'
        'export-csv:export to CSV'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--release=+[release]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'meteor subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:app name:_files -/' \
                    '--bare[no boilerplate]' \
                    '--minimal[minimal scaffold]' \
                    '--full[full directory layout]' \
                    '--package[package scaffold]' \
                    '--typescript[typescript]' \
                    '--vue[Vue scaffold]' \
                    '--svelte[Svelte scaffold]' \
                    '--blaze[Blaze scaffold]' \
                    '--apollo[apollo scaffold]' \
                    '--react[react]' \
                    '--example=+[example]:str:' \
                    '--list[list examples]' \
                    '--from-app[from existing app]' ;;
                run) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--inspect=+[host:port]:str:' \
                    '--inspect-brk=+[host:port]:str:' \
                    '--mobile-server=+[url]:url:_urls' \
                    '--cordova-server-port=+[port]:port:' \
                    '--app-port=+[port]:port:' \
                    '--debug-port=+[port]:port:' \
                    '--production[production mode]' \
                    '--exclude-archs=+[archs]:str:' \
                    '--allow-incompatible-update[allow incompatible update]' \
                    '--once[once mode]' \
                    '--no-release-check[no release check]' \
                    '--extra-packages=+[packages]:str:' \
                    '--no-lint[no lint]' \
                    '--no-build[no build]' ;;
                deploy) _arguments \
                    '1:site name:' \
                    '--free[free tier]' \
                    '--container-size=+[size]:str:' \
                    '--no-wait[no wait]' \
                    '--settings=+[file]:file:_files' \
                    '--owner=+[owner]:str:' \
                    '--plan=+[plan]:str:' \
                    '--mongo[provision mongo]' \
                    '--delete[delete deployment]' \
                    '-D[delete deployment]' \
                    '--build-options=+[options]:str:' \
                    '--cache-build[cache build]' ;;
            esac
            ;;
    esac
}

_meteor-init "$@"
