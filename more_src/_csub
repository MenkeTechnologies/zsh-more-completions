#compdef csub
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss34.html
# KAPPA CSUB - subtract a scalar from an NDF data structure

local ret=1

_arguments -C \
  'IN=[input NDF from which the value is subtracted]:NDF file:_files' \
  'OUT=[output NDF data structure]:NDF file:_files' \
  'SCALAR=[value to be subtracted from the data array]:value:' \
  'TITLE=[title for the output NDF]:title:' \
  '*:NDF file:_files' && ret=0

return ret
