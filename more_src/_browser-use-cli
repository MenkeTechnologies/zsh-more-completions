#compdef browser-use-cli
# Documentation: https://github.com/browser-use/browser-use
# Reference accessed: 2026-05-22
# Verified: browser_use/skill_cli/main.py argparse subcommands.

# Zsh completion for browser-use-cli - fast browser automation CLI for AI agents

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--headed[show browser window]' \
  '--profile[use real Chrome profile]:profile:' \
  '--cdp-url[connect via CDP URL]:url:' \
  '--connect[deprecated: use browser-use connect]' \
  '--session[session name]:session:' \
  '--json[JSON output]' \
  '--mcp[run as MCP server]' \
  '--template[generate template file]:template:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'browser-use command' \
      'install[install Chromium and dependencies]' \
      'init[generate browser-use template]' \
      'setup[first-time configuration]' \
      'doctor[check installation]' \
      'connect[connect to running Chrome via CDP]' \
      'open[navigate to URL]' \
      'click[click element by index or coordinates]' \
      'dblclick[double-click element]' \
      'type[type text into element]' \
      'fill[clear and fill element]' \
      'input[clear-then-type into element]' \
      'scroll[scroll page up or down]' \
      'back[go back in history]' \
      'screenshot[take screenshot]' \
      'state[get browser state]' \
      'tab[tab management]' \
      'keys[send keyboard keys]' \
      'select[select dropdown option]' \
      'upload[upload file to input]' \
      'eval[execute JavaScript]' \
      'extract[extract data with LLM]' \
      'hover[hover element]' \
      'rightclick[right-click element]' \
      'record[record browser session video]' \
      'cookies[cookie operations]' \
      'wait[wait for conditions]' \
      'get[get page information]' \
      'python[execute Python in browser context]' \
      'tunnel[expose localhost via Cloudflare tunnel]' \
      'config[manage CLI configuration]' \
      'sessions[list active sessions]' \
      'close[close browser and stop daemon]' \
      'cloud[Browser Use Cloud API]' && ret=0
    ;;
  args)
    case $line[1] in
      open) _arguments '*:url:' && ret=0 ;;
      scroll)
        _arguments \
          '1:direction:(up down)' \
          '--amount[pixels to scroll]:n:' && ret=0
        ;;
      config)
        _arguments '1:config command:(set get list unset)' && ret=0
        ;;
      tab)
        _arguments '1:tab command:(list new switch close)' && ret=0
        ;;
      cookies)
        _arguments '1:cookies command:(get set clear export import)' && ret=0
        ;;
      wait)
        _arguments '1:wait command:(selector text)' && ret=0
        ;;
      get)
        _arguments '1:get command:(title html text value attributes bbox)' && ret=0
        ;;
      record)
        _arguments '1:record command:(start stop status)' && ret=0
        ;;
      close)
        _arguments '--all[close all sessions]' && ret=0
        ;;
    esac
    ;;
esac

return ret
