#compdef eda-tools edatools
# _eda-tools — eda-tools toolbox CLI dispatching to open-source Electronic Design Automation utilities Yosys nextpnr OpenROAD Verilator GHDL VTR FuseSoC SymbiFlow ABC for synthesis simulation place-route timing analysis (edaa team, Python); argparse
# upstream: https://github.com/edaa-org/edaa

_eda-tools() {
    local -a sub=(
        'install:install toolchain'
        'list:list installed tools'
        'update:update toolchain'
        'check:check installation health'
        'env:show environment for tools'
        'run:run a tool'
        'config:show or edit config'
        'cache:clean cache'
        'doctor:run diagnostics'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '--config=+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '-t+[tool]:t:(yosys nextpnr openroad verilator ghdl vtr fusesoc symbiflow abc iverilog gtkwave surfer trellis icestorm prjoxide colognechip nextpnr-ice40 nextpnr-ecp5 nextpnr-nexus nextpnr-himbaechel openfpgaloader xc3sprog tinyprog)' \
        '--tool=+[tool]:t:(yosys nextpnr openroad verilator ghdl vtr fusesoc symbiflow abc iverilog gtkwave surfer trellis icestorm)' \
        '-r+[repo url]:str:' \
        '--repo=+[repo url]:str:' \
        '--prefix=+[install prefix]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'eda-tools subcommand' sub ;;
        args)
            case $words[1] in
                install|update|run) _arguments \
                    '*:tool name:(yosys nextpnr openroad verilator ghdl vtr fusesoc symbiflow abc iverilog gtkwave surfer trellis icestorm)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_eda-tools "$@"
