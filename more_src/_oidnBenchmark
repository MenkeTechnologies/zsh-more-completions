#compdef oidnBenchmark
# Documentation: https://github.com/RenderKit/oidn/blob/master/apps/oidnBenchmark.cpp
# Intel Open Image Denoise: benchmark tool

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-d -dev -device)'{-d,-dev,-device}'+[device to use]:device:(default cpu sycl cuda hip metal)' \
  '(-r -run)'{-r,-run}'+[filter benchmarks by regex pattern]:pattern' \
  '-n+[number of times to execute each benchmark]:n' \
  '(-s -size)'{-s,-size}'+[image dimensions in pixels (width height)]:size' \
  '(-t -type)'{-t,-type}'+[data precision]:type:(float fp32 half fp16)' \
  '(-q -quality)'{-q,-quality}'+[filter quality mode]:quality:(default high balanced fast)' \
  '-threads+[number of processing threads]:n' \
  '-affinity+[enable or disable thread affinity]:affinity:(0 1)' \
  '(-maxmem -maxMemoryMB)'{-maxmem,-maxMemoryMB}'+[memory limit in megabytes]:mb' \
  '-inplace[use in-place processing for output]' \
  '-buffer+[storage mode]:mode:(host hostcopy device devicecopy managed managedcopy)' \
  '(-v -verbose)'{-v,-verbose}'+[verbosity level]:level:(0 1 2 3)' \
  '(-l -list)'{-l,-list}'[list all available benchmarks]' \
  '(-ld -list_devices)'{-ld,-list_devices}'[display available devices]' && ret=0

return ret
