#compdef apidog
# Documentation: https://docs.apidog.com/apidog-cli-options-609656m0
# apidog - Apidog CLI to run API test scenarios and test suites

local ret=1

_arguments -s -S \
  '--access-token[authentication token for online execution]:token:' \
  '(-t --test-scenario)'{-t,--test-scenario}'[test scenario ID to run]:id:' \
  '(-f --test-scenario-folder)'{-f,--test-scenario-folder}'[test scenario directory ID to run]:id:' \
  '--test-suite[test suite ID to run]:id:' \
  '--project[project ID]:id:' \
  '--branch[branch name]:name:' \
  '(-r --reporters)'{-r,--reporters}'[specify test report types]:reporters:(cli html json junit)' \
  '--out-dir[output directory for test reports]:dir:_files -/' \
  '--out-file[output filename without extension]:name:' \
  '--out-json-failures-separated[export failures as separate JSON file]:value:' \
  '(-e --environment)'{-e,--environment}'[runtime environment]:id:' \
  '(-n --iteration-count)'{-n,--iteration-count}'[number of iterations]:n:' \
  '(-d --iteration-data)'{-d,--iteration-data}'[data for iterations (JSON or CSV)]:file:_files' \
  '--on-error[error handling behavior]:behavior:(ignore continue end)' \
  '--variables[load variables from local file]:file:_files' \
  '*--global-var[set global variables key=value]:var:' \
  '*--env-var[set environment variables key=value]:var:' \
  '--notification[send notifications after run finishes]:ids:' \
  '--notification-failed-event[send notifications only on failure]:ids:' \
  '--external-program-path[external programs file path]:file:_files' \
  '--database-connection[database configuration file path]:file:_files' \
  '--ignore-redirects[prevent automatic redirects]' \
  '--silent[prevent console output]' \
  '--color[enable/disable colored console output]:value:(on off)' \
  '--delay-request[delay between requests in ms]:ms:' \
  '--timeout-request[request timeout in ms]:ms:' \
  '--timeout-script[script execution timeout in ms]:ms:' \
  '(-k --insecure)'{-k,--insecure}'[disable SSL verification]' \
  '--ssl-client-cert-list[client certificate config path]:file:_files' \
  '--ssl-client-cert[client certificate path PEM]:file:_files' \
  '--ssl-client-key[client certificate private key path]:file:_files' \
  '--ssl-client-passphrase[client certificate passphrase]:passphrase:' \
  '--ssl-extra-ca-certs[additional trusted CA certificates]:file:_files' \
  '(-b --bigint)'{-b,--bigint}'[enable bigint compatibility]' \
  '--upload-report[upload test report overview to cloud]:value:' \
  '--preferred-http-version[preferred HTTP protocol version]:version:' \
  '--verbose[display detailed request/response information]' \
  '--lang[CLI language]:lang:(en)' \
  '(-h --help)'{-h,--help}'[display help information]' \
  '*:command:(run)' && ret=0

return ret
