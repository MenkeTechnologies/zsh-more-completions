#compdef ato
# Documentation: https://docs.atopile.io/0.3/api/cli/
# atopile - design circuit boards with code

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--non-interactive[disable interactive prompts]' \
  '--debug[enable debug output]' \
  '--version[show version]' \
  '--semver[show semantic version]' \
  '1:command:((
    build:build\ your\ code\ to\ update\ your\ PCB
    inspect:inspect\ a\ build
    view:view\ a\ build
    sync:sync\ project\ state
    add:add\ a\ dependency
    remove:remove\ a\ dependency
    validate:validate\ a\ design
    create:create\ projects\ components\ or\ build-targets
    install:install\ and\ manage\ dependencies
    dependencies:manage\ dependencies
    serve:run\ a\ server
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      validate)
        _arguments '1:file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
