#compdef ect
# Documentation: https://github.com/fhanau/Efficient-Compression-Tool/blob/master/src/main.cpp
# Efficient Compression Tool: losslessly optimize GZIP, ZIP, JPEG and PNG files

local ret=1

_arguments -s -S \
  '-1[compression level 1 (fastest)]' \
  '-2[compression level 2]' \
  '-3[compression level 3 (default)]' \
  '-4[compression level 4]' \
  '-5[compression level 5]' \
  '-6[compression level 6]' \
  '-7[compression level 7]' \
  '-8[compression level 8]' \
  '-9[compression level 9 (best)]' \
  '-strip[strip metadata]' \
  '-progressive[use progressive encoding for JPEGs]' \
  '-autorotate[auto-rotate JPEGs when perfectly transformable]' \
  '-autorotate=force[auto-rotate JPEGs, dropping non-transformable edge blocks]' \
  '-recurse[recursively search directories]' \
  '-zip[compress files with ZIP algorithm]' \
  '-gzip[compress files with GZIP algorithm]' \
  '-quiet[print only error messages]' \
  '-keep[keep modification time]' \
  '-help[print help]' \
  '--disable-png[skip PNG optimization]' \
  '--disable-jpg[skip JPEG optimization]' \
  '--strict[strict losslessness validation]' \
  '--reuse[keep PNG filter and color type]' \
  '--allfilters[try all PNG filter modes]' \
  '--allfilters-b[try all PNG filters including brute-force]' \
  '--pal_sort=[try i palette filtering strategies]:count' \
  '--mt-deflate[multithreaded Deflate compression]' \
  '--mt-deflate=[multithreaded Deflate with i threads]:threads' \
  '--mt-file[per-file multithreading]' \
  '--mt-file=[per-file multithreading with i threads]:threads' \
  '*:file or folder:_files' && ret=0

return ret
