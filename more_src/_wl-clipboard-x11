#compdef wl-clipboard-x11
# Documentation: https://github.com/brunelli/wl-clipboard-x11
# Reference accessed: 2026-05-16
# Verified: bash wrapper that delegates to wl-copy/wl-paste. The wrapper does
# not define its own flags - it passes arguments through to the underlying
# wl-clipboard tool selected by the invocation name (xsel/xclip/wl-copy/wl-paste).

# wl-clipboard-x11: bridge wl-clipboard to X11 clipboard tools (xsel/xclip)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::wl-clipboard args:_files' && ret=0
return ret
