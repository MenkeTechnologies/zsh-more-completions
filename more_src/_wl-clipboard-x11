#compdef wl-clipboard-x11
# Documentation: https://github.com/brunelli/wl-clipboard-x11
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above describes a wrapper that maps
# X11 clipboard tool (xsel/xclip) invocations to wl-copy/wl-paste; the
# wrapper itself has no fixed flag set independent of its invocation name.

# wl-clipboard-x11: bridge wl-clipboard to X11 clipboard tools (xsel/xclip)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::passthrough args:_files' && ret=0
return ret
