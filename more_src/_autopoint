#compdef autopoint
# Documentation: autopoint --help (GNU gettext)
# Source: copy gettext infrastructure files into a source package.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(-f --force)'{-f,--force}'[overwrite existing files]' \
    '(-n --dry-run)'{-n,--dry-run}'[print modifications without performing them]' \
    && ret=0

return ret
