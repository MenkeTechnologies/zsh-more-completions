#compdef scantailor scantailor-cli scantailor-advanced

local curcontext="$curcontext" ret=1

case $service in
  (scantailor-cli)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '--layout=[page layout]:layout:(0 1 1.5 2)' \
      '--layout-direction=[layout direction]:dir:(lr rl)' \
      '--orientation=[orientation]:orient:(left right upsidedown)' \
      '--rotate=[rotate degrees]:deg:' \
      '--deskew=[deskew mode]:mode:(auto manual)' \
      '--content-detection=[content detection]:mode:(cautious normal aggressive)' \
      '--content-box=[content box X,Y,W,H]:box:' \
      '--margins=[margins (in mm)]:mm:' \
      '--alignment=[alignment]:align:' \
      '--dpi=[output DPI]:dpi:' \
      '--output-dpi=[output DPI]:dpi:' \
      '--color-mode=[color mode]:mode:(color grayscale bw mixed)' \
      '--white-margins=[white margins]:flag:(true false)' \
      '--normalize-illumination=[normalize illumination]:flag:(true false)' \
      '--threshold=[threshold]:val:' \
      '--tiff-compression=[TIFF compression]:method:(none lzw ccittfax4 deflate jpeg)' \
      '--despeckle=[despeckle level]:lvl:(off cautious normal aggressive)' \
      '--dewarping=[dewarping mode]:mode:(off auto marginal manual)' \
      '--depth-perception=[depth perception]:val:' \
      '--start-filter=[start filter]:filter:' \
      '--end-filter=[end filter]:filter:' \
      '*:input_dir output_dir:_files -/' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '*:project_file:_files -g "*.ScanTailor"' && ret=0 ;;
esac

return ret
