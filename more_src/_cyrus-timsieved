#compdef cyrus-timsieved
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/timsieved.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org timsieved(8) reference manpage. Only -C
# and -H are documented.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-timsieved: ManageSieve (RFC 5804) server process
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-H[expect HAProxy protocol header from sender]' && ret=0
return ret
