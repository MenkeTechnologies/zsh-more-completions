#compdef trace_processor trace_processor_shell
# Documentation: https://perfetto.dev/docs/analysis/trace-processor
# trace_processor - SQL-based analysis of Perfetto traces

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --query-file)'{-f,--query-file}'=[read SQL query from file]:file:_files' \
  '(-i --interactive)'{-i,--interactive}'[drop into interactive SQL REPL]' \
  '(-W --wide)'{-W,--wide}'[double-width column formatting]' \
  '(-d --httpd)'{-d,--httpd}'[start RPC HTTP server]' \
  '--http-port=[HTTP server port]:port:' \
  '--ip-address=[bind address for HTTP server]:ip:' \
  '(-e --export)'{-e,--export}'=[export trace to sqlite database file]:file:_files' \
  '--run-metrics=[run comma-separated metrics]:metrics:' \
  '--metrics-output=[metrics output format]:format:(text json binary)' \
  '--full-sort[force full sort ignoring windowing]' \
  '--no-ftrace-raw[do not ingest typed ftrace into raw table]' \
  '(-m --metatrace)'{-m,--metatrace}'=[enable metatracing to file]:file:_files' \
  '--add-sql-package=[register SQL files as a package]:path:_files' \
  '--perf-file=[write timing metrics to file]:file:_files' \
  '*:trace file:_files' && ret=0

return ret
