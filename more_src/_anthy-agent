# anthy-agent: Anthy Japanese input method agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '--version[show version]' \
  '--anonymous[run in anonymous mode]' \
  '--egg[invoke Emacs egg_main]' \
  '--personality=[personality string]:name:' \
  '--utf8[use UTF-8 encoding]' \
  '--dir=[Anthy directory]:dir:_files -/' \
  '--dic=[dictionary file]:file:_files' \
  '--conffile=[configuration file]:file:_files' && ret=0
return ret
