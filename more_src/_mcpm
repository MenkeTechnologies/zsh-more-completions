#compdef mcpm
# Documentation: https://github.com/pathintegral-institute/mcpm.sh
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:execute a server directly over stdio'
  'share:share a server through a secure tunnel'
  'profile:manage profiles (ls/create/rm/edit/run/share/inspect)'
  'client:list and edit MCP client configurations'
  'usage:display usage and analytics'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'mcpm command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac

return ret
