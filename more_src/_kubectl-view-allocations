#compdef kubectl-view-allocations
# Documentation: https://man.archlinux.org/search?q=kubectl-view-allocations
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-n+[namespace]:namespace:' \
  '--namespace=[namespace]:namespace:' \
  '-r+[resource filter]:resource:(cpu memory gpu)' \
  '--resource-name=[resource filter]:resource:(cpu memory gpu)' \
  '-g+[group by]:group:(resource node pod namespace)' \
  '--group-by=[group by]:group:(resource node pod namespace)' \
  '-o+[output format]:format:(table csv)' \
  '--output=[output format]:format:(table csv)' \
  '--node-label=[filter by node label]:label:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--context=[kubernetes context]:context:' && ret=0

return ret
