#compdef bumpver
# Documentation: https://github.com/mbarkhau/bumpver
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize bumpver configuration in pyproject.toml or setup.cfg'
  'show:show current version of project'
  'test:increment a version number for demonstration purposes'
  'update:apply increment to project files and (optionally) commit/tag/push'
  'grep:search file(s) for a version pattern'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version and exit]' \
  '--verbose[verbose output]' \
  '-v[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t cmds 'bumpver command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --dry)'{-d,--dry}'[dry run, do not write files]' && ret=0 ;;
      (show)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-n --no-fetch)'{-n,--no-fetch}'[do not fetch tags from remote]' \
          '(-f --fetch)'{-f,--fetch}'[fetch tags from remote]' \
          '--environ[output as POSIX environment variables]' && ret=0 ;;
      (test)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--major[increment major]' \
          '(-m --minor)'{-m,--minor}'[increment minor]' \
          '(-p --patch)'{-p,--patch}'[increment patch]' \
          '(-t --tag)'{-t+,--tag=}'[set release tag]:tag:(alpha beta dev rc post final)' \
          '--tag-num[increment release tag number]' \
          '--pin-date[leave date components unchanged]' \
          '--pin-increments[leave auto-increments unchanged]' \
          '--date=[set explicit date]:date (YYYY-0M-0D):' \
          '--set-version=[set version explicitly]:version:' \
          '--verbose[verbose regex info]' \
          '*: :' && ret=0 ;;
      (update)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --dry)'{-d,--dry}'[dry run, show diff without writing]' \
          '(-f --fetch -n --no-fetch)'{-f,--fetch}'[fetch tags from remote]' \
          '(-f --fetch -n --no-fetch)'{-n,--no-fetch}'[do not fetch tags from remote]' \
          '--allow-dirty[commit even with uncommitted changes]' \
          '--ignore-vcs-tag[ignore VCS tag invariant]' \
          '--set-version=[set version explicitly]:version:' \
          '--date=[set explicit date]:date (YYYY-0M-0D):' \
          '--pin-date[leave date components unchanged]' \
          '--pin-increments[leave auto-increments unchanged]' \
          '--tag-num[increment release tag number]' \
          '(-t --tag)'{-t+,--tag=}'[override release tag]:tag:(alpha beta dev rc post final)' \
          '(-p --patch)'{-p,--patch}'[increment PATCH]' \
          '(-m --minor)'{-m,--minor}'[increment MINOR]' \
          '--major[increment MAJOR]' \
          '(-c --commit-message)'{-c+,--commit-message=}'[commit message template]:tmpl:' \
          '--tag-message=[tag message template]:tmpl:' \
          '--commit[create a commit]' \
          '--no-commit[do not create a commit]' \
          '--tag-commit[tag the commit]' \
          '--no-tag-commit[do not tag the commit]' \
          '--push[push to remote]' \
          '--no-push[do not push]' \
          '--tag-scope=[tag scope]:scope:(default global branch)' \
          '--pre-commit-hook=[custom pre-commit script]:script:_files' \
          '--post-commit-hook=[custom post-commit script]:script:_files' \
          '--env=[load environment file]:env file:_files' && ret=0 ;;
      (grep)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--version-pattern=[version pattern]:pattern:' \
          '*: :_files' && ret=0 ;;
    esac ;;
esac

return ret
