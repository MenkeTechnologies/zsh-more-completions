#compdef aptos

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'account:account-related operations'
  'config:tool configuration'
  'genesis:genesis-related operations'
  'governance:governance proposals'
  'info:show build information'
  'init:initialize a profile'
  'key:key-related operations'
  'move:Move language tools'
  'multisig:multisig account operations'
  'node:node operations'
  'stake:staking operations'
  'update:update the CLI'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[config file]:file:_files' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'aptos command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments \
          '--network=[network to use]:network:(devnet testnet mainnet local custom)' \
          '--rest-url=[REST API URL]:url' \
          '--faucet-url=[faucet URL]:url' \
          '--private-key=[private key]:key' \
          '--profile=[profile name]:profile' \
          '--skip-faucet[skip funding from faucet]' \
          '--assume-yes[assume yes for all prompts]' && ret=0
        ;;
      (account)
        local -a account_cmds=(
          'create:create a new account'
          'fund-with-faucet:fund account from faucet'
          'list:list account resources and modules'
          'lookup-address:lookup account address'
          'transfer:transfer coins between accounts'
          'balance:show account balance'
          'create-resource-account:create a resource account'
        )
        _arguments \
          '1:account command:_describe -t account-cmds "account command" account_cmds' \
          '--profile=[profile name]:profile' \
          '--account=[account address]:address' \
          '--url=[REST API URL]:url' \
          '--assume-yes[assume yes for all prompts]' && ret=0
        ;;
      (move)
        local -a move_cmds=(
          'compile:compile a Move package'
          'init:initialize a Move package'
          'publish:publish a Move package'
          'run:run a Move function'
          'test:run Move unit tests'
          'prove:prove Move specifications'
          'clean:clean build artifacts'
          'download:download a package'
          'view:run a view function'
          'coverage:show test coverage'
          'document:generate documentation'
        )
        _arguments \
          '1:move command:_describe -t move-cmds "move command" move_cmds' \
          '--package-dir=[Move package directory]:directory:_directories' \
          '--named-addresses=[named address mapping]:addresses' \
          '--profile=[profile name]:profile' \
          '--url=[REST API URL]:url' \
          '--assume-yes[assume yes for all prompts]' && ret=0
        ;;
      (node)
        local -a node_cmds=(
          'run-local-testnet:run a local testnet'
          'show-epoch-info:show epoch information'
          'show-validator-config:show validator config'
          'show-validator-set:show validator set'
          'show-validator-stake:show validator stake'
          'check-network-connectivity:check connectivity'
          'get-stake-pool:get stake pool info'
          'analyze-validator-performance:analyze performance'
          'update-consensus-key:update consensus key'
          'bootstrap-db:bootstrap database from backup'
        )
        _arguments \
          '1:node command:_describe -t node-cmds "node command" node_cmds' \
          '--profile=[profile name]:profile' \
          '--url=[REST API URL]:url' && ret=0
        ;;
      (key)
        local -a key_cmds=(
          'generate:generate new key'
          'extract-peer:extract peer from key'
          'rotate:rotate authentication key'
        )
        _arguments \
          '1:key command:_describe -t key-cmds "key command" key_cmds' \
          '--key-type=[key type]:type:(ed25519 x25519 secp256k1-ecdsa)' \
          '--output-file=[output file]:file:_files' \
          '--assume-yes[assume yes for all prompts]' && ret=0
        ;;
      (config)
        local -a config_cmds=(
          'show-profiles:show available profiles'
          'show-global-config:show global config'
          'set-global-config:set global config values'
          'init:initialize configuration'
          'generate-shell-completions:generate shell completions'
        )
        _arguments \
          '1:config command:_describe -t config-cmds "config command" config_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
