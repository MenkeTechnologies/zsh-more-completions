#compdef americano
# _americano — keep a machine awake from the CLI (dptrebas/americano)
# upstream: https://github.com/dptrebas/americano
# Subcommands + flags from src/main.rs (clap).

_americano() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_americano_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                start)
                    _arguments \
                        '(-m --minutes)'{-m+,--minutes=}'[minutes to keep awake (0 = indefinite)]:minutes:' \
                        '(-d --display)'{-d,--display}'[also keep the display awake]' \
                        '(-r --reason)'{-r+,--reason=}'[reason shown in system tools]:reason:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_americano_commands] )) ||
_americano_commands() {
    local -a commands
    commands=(
        'start:start keeping the machine awake'
        'stop:stop any running Americano keep-awake session'
    )
    _describe -t commands 'americano command' commands
}

_americano "$@"
