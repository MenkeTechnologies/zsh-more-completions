#compdef acton
# ============================================================================
# _acton — zsh completion for The Acton Programming Language compiler driver
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/actonlang/acton
#   Homepage   : https://www.acton-lang.org
#   License    : BSD-3-Clause
#   Stars      : 180
#   Language   : Haskell (compiler) / Acton (standard library, .act files)
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   Acton is "The Acton Programming Language" — a statically-typed, garbage-
#   collected, Python-syntax-inspired actor-based programming language with
#   a strong concurrency story.  It descends from the actor model (Erlang /
#   Hewitt's actors / Pony) but exposes a Python-like surface syntax with
#   classes, protocols, decorators, and a Hindley-Milner-style type system
#   with inferred signatures.  The compiler is implemented in Haskell (via
#   optparse-applicative + Megaparsec) and emits C code that is then driven
#   through Zig as the C toolchain to produce static binaries for any
#   Zig-supported target triple.  Standard-library cargo: built-in actors
#   for HTTP, file IO, time, math, and zigzag-style sockets;  package
#   manager with both pure-Acton ("pkg") and Zig-native ("zig-pkg") deps.
#
# CLI ARGUMENT GRAMMAR  (verbatim from compiler/lib/src/Acton/CommandLineParser.hs)
#   acton [global options] <command> [command options]
#
#   Global options (apply to every command):
#     --color WHEN         colored output: auto, always, never  (default auto)
#     --quiet              suppress non-essential output
#     --no-progress        disable live progress UI
#     --timing             print timing information
#     --tty                act as if run from interactive TTY
#     --verbose            verbose output
#     --verbose-zig        verbose Zig (C toolchain) output
#     --jobs N             max parallel compiler jobs (0 = auto)
#
#   Commands:
#     new <PROJECTDIR>     Create a new Acton project
#     build [ACTONFILE…]   Build an Acton project (or specific .act files)
#     install <NAME>       Install an Acton application package
#                            --repo-url URL  --repo-ref REF
#                            --pkg-name NAME --github-token TOKEN
#     uninstall <NAME>     Uninstall an Acton application package
#     sig <TARGET>         Show inferred type signatures for module/name
#                            --always-build --ignore-compiler-version
#                            --syspath DIR  --searchpath DIR…  --dep NAME=PATH
#     test [MODE]          Build and run project tests; MODE = list|perf|stress
#                            --show-log --show-cached --no-cache --json --record
#                            (+ all build/compile flags)
#     fetch                Fetch project dependencies (offline prep)
#     pkg show|add|remove|upgrade|update|search
#       show               Show dependency tree with overrides
#       add <NAME>           --url URL --repo-url URL --repo-ref REF
#                            --pkg-name NAME --hash HASH --github-token TOKEN
#       remove <NAME>      Remove library package dependency
#       upgrade              --github-token TOKEN
#       update             Update package index
#       search <TERM…>     Regex search of package index (ANDed terms)
#     zig-pkg add|remove
#       add <URL> <NAME>     --artifact NAME…  (link with library artifact)
#       remove <NAME>      Remove Zig package dependency
#     spec dump|update
#       dump               Dump build spec as JSON to stdout
#       update <FILE>      Update Build.act using JSON file (overrides only)
#     cloud                Run an Acton project in the cloud
#                            --run --list --show --stop
#     doc [FILE]           Show type and docstring info
#                            -t/--terminal --md/--markdown --html
#                            -o/--output FILE
#     version              Show version
#
#   Compile options (shared by build/test/etc — `compileOptions` block):
#     --always-build              recompile even when fresh interfaces exist
#     --ignore-compiler-version   ignore acton version when checking .tydb freshness
#     --db                        enable DB backend
#     --parse                     show the result of parsing
#     --parse-ast                 show the raw AST (Haskell Show)
#     --kinds                     show result after kind-checking
#     --types                     show all inferred expression types
#     --sigs                      show inferred type signatures
#     --norm                      show result after syntactic normalization
#     --deact                     show result after deactorization
#     --cps                       show result after CPS conversion
#     --llift                     show result of lambda-lifting
#     --box                       show result of (un)boxing
#     --hgen                      show generated .h header
#     --cgen                      show generated .c code
#     --ccmd                      show CC / LD commands
#     --ty                        write .tydb directory next to src file
#     --cpedantic                 pedantic C compilation with -Werror
#     --dbg-no-lines              disable C #line directives (codegen debug)
#     --release[=safe|small|fast] release build (default fast)
#     --optimize MODE             Debug / Release / ReleaseFast /
#                                 ReleaseSafe / ReleaseSmall
#     --only-build                only final C build, skip .act compile
#     --skip-build                skip final C build
#     --watch                     rebuild on file changes
#     --no-threads                don't use threads
#     --parse-serial              serial whole-file parser
#     --root ROOTACTOR            set root actor
#     --tempdir TEMPDIR           build files directory
#     --syspath TARGETDIR         set syspath
#     --target TARGET             target triple (e.g. x86_64-linux-gnu.2.28)
#     --cpu CPU                   CPU (e.g. skylake)
#     --test                      build tests
#     --searchpath DIR            add search path (repeatable)
#     --dep NAME=PATH             override dependency NAME with local PATH
#
# LANGUAGE-CORPUS POSITION
#   Acton is the 136th programming language entry in this completion corpus,
#   closing the 3+1 micro-cycle that began at R813 (_whipinto/webrtc-rs
#   Rust=111 opens Axis 56) and continued through R814 (_weron/pion/webrtc
#   Go=111) and R815 (_webcat/simple-peer+wrtc TS-Node=111 CLOSES Axis 56
#   WebRTC Media Library at 1/1/1 + triple-111 landmark).  Acton joins the
#   roster of exotic languages already in the corpus including Rune, Egel,
#   Mlatu, Gwion, Silq (quantum), Mirth, Lawvere/bill, Cognac/Cognate,
#   Scrapscript, and Stanza (R812 135th entry).
#
#   No completion for `acton` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.  The
#   upstream repo only ships a bash-completion shim that delegates to
#   `acton --bash-completion-script` (no native zsh).
# ============================================================================

_acton() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        $(_acton_global_args) \
        '1: :_acton_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                new)        _acton_new        && ret=0 ;;
                build)      _acton_build      && ret=0 ;;
                install)    _acton_install    && ret=0 ;;
                uninstall)  _acton_uninstall  && ret=0 ;;
                sig)        _acton_sig        && ret=0 ;;
                test)       _acton_test       && ret=0 ;;
                fetch)      _acton_fetch      && ret=0 ;;
                pkg)        _acton_pkg        && ret=0 ;;
                zig-pkg)    _acton_zig_pkg    && ret=0 ;;
                spec)       _acton_spec       && ret=0 ;;
                cloud)      _acton_cloud      && ret=0 ;;
                doc)        _acton_doc        && ret=0 ;;
                version)    _acton_version    && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_acton_global_args() {
    print -- \
        '--color=[colored output]:when:(auto always never)' \
        '--quiet[suppress non-essential output]' \
        '--no-progress[disable live progress UI]' \
        '--timing[print timing information]' \
        '--tty[act as if run from interactive TTY]' \
        '--verbose[verbose output]' \
        '--verbose-zig[verbose Zig (C toolchain) output]' \
        '--jobs=[max parallel compiler jobs (0 = auto)]:N:' \
        '(- *)--help[show help]'
}

(( $+functions[_acton_commands] )) ||
_acton_commands() {
    local -a commands
    commands=(
        'new:create a new Acton project'
        'build:build an Acton project (or specific .act files)'
        'install:install an Acton application package'
        'uninstall:uninstall an Acton application package'
        'sig:show inferred type signatures'
        'test:build and run project tests'
        'fetch:fetch project dependencies (offline prep)'
        'pkg:library package/dependency commands'
        'zig-pkg:Zig package dependency commands'
        'spec:inspect or update build specification'
        'cloud:run an Acton project in the cloud'
        'doc:show type and docstring info'
        'version:show version'
    )
    _describe -t commands 'acton command' commands
}

# Compile flags shared by build / test / sig
_acton_compile_flags() {
    print -- \
        '--always-build[recompile even when fresh interfaces exist]' \
        '--ignore-compiler-version[ignore acton version when checking .tydb freshness]' \
        '--db[enable DB backend]' \
        '--parse[show the result of parsing]' \
        '--parse-ast[show the raw AST (Haskell Show)]' \
        '--kinds[show result after kind-checking]' \
        '--types[show all inferred expression types]' \
        '--sigs[show inferred type signatures]' \
        '--norm[show result after syntactic normalization]' \
        '--deact[show result after deactorization]' \
        '--cps[show result after CPS conversion]' \
        '--llift[show result of lambda-lifting]' \
        '--box[show result of (un)boxing]' \
        '--hgen[show generated .h header]' \
        '--cgen[show generated .c code]' \
        '--ccmd[show CC / LD commands]' \
        '--ty[write .tydb directory next to src file]' \
        '--cpedantic[pedantic C compilation with -Werror]' \
        '--dbg-no-lines[disable C #line directives (codegen debug)]' \
        '--release=-[release build (default fast)]::mode:(safe small fast)' \
        '--optimize=[optimization mode]:mode:(Debug Release ReleaseFast ReleaseSafe ReleaseSmall)' \
        '--only-build[only final C build, skip .act compile]' \
        '--skip-build[skip final C build]' \
        '--watch[rebuild on file changes]' \
        '--no-threads[don'"'"'t use threads]' \
        '--parse-serial[serial whole-file parser]' \
        '--root=[set root actor]:root actor:' \
        '--tempdir=[build files directory]:tempdir:_files -/' \
        '--syspath=[set syspath]:target dir:_files -/' \
        '--target=[target triple]:target:' \
        '--cpu=[CPU (e.g. skylake)]:cpu:' \
        '--test[build tests]' \
        '*--searchpath=[add search path]:dir:_files -/' \
        '*--dep=[override dependency NAME with local PATH]:NAME=PATH:'
}

(( $+functions[_acton_new] )) ||
_acton_new() {
    _arguments \
        ':project directory:_files -/' \
        '(- *)--help[show help for new]'
}

(( $+functions[_acton_build] )) ||
_acton_build() {
    _arguments \
        $(_acton_compile_flags) \
        '(- *)--help[show help for build]' \
        '*:acton source file:_files -g "*.act"'
}

(( $+functions[_acton_install] )) ||
_acton_install() {
    _arguments \
        '--repo-url=[Git repository URL of application package]:URL:_urls' \
        '--repo-ref=[Git ref (branch, tag or SHA)]:ref:' \
        '--pkg-name=[package name in index (defaults to NAME)]:name:' \
        '--github-token=[GitHub token (env GITHUB_TOKEN)]:token:' \
        '(- *)--help[show help for install]' \
        ':package name:'
}

(( $+functions[_acton_uninstall] )) ||
_acton_uninstall() {
    _arguments \
        '(- *)--help[show help for uninstall]' \
        ':package name:'
}

(( $+functions[_acton_sig] )) ||
_acton_sig() {
    _arguments \
        '--always-build[recompute signatures instead of reusing cached interfaces]' \
        '--ignore-compiler-version[ignore acton version when checking .tydb freshness]' \
        '--syspath=[set syspath]:target dir:_files -/' \
        '*--searchpath=[add search path]:dir:_files -/' \
        '*--dep=[override dependency NAME with local PATH]:NAME=PATH:' \
        '(- *)--help[show help for sig]' \
        ':module or module.name:'
}

(( $+functions[_acton_test] )) ||
_acton_test() {
    _arguments \
        $(_acton_compile_flags) \
        '--show-log[show test log output]' \
        '--show-cached[show cached test results]' \
        '--no-cache[always run tests instead of reusing cached results]' \
        '--json[output final test results as JSON]' \
        '--record[record test performance results]' \
        '(- *)--help[show help for test]' \
        ':mode:(list perf stress)'
}

(( $+functions[_acton_fetch] )) ||
_acton_fetch() {
    _arguments \
        '(- *)--help[show help for fetch]'
}

(( $+functions[_acton_pkg] )) ||
_acton_pkg() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1: :_acton_pkg_commands' \
        '*::arg:->pkgargs' && ret=0

    case $state in
        pkgargs)
            case $words[1] in
                show)     _acton_pkg_show     && ret=0 ;;
                add)      _acton_pkg_add      && ret=0 ;;
                remove)   _acton_pkg_remove   && ret=0 ;;
                upgrade)  _acton_pkg_upgrade  && ret=0 ;;
                update)   _acton_pkg_update   && ret=0 ;;
                search)   _acton_pkg_search   && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_acton_pkg_commands] )) ||
_acton_pkg_commands() {
    local -a commands
    commands=(
        'show:show dependency tree with overrides'
        'add:add library package dependency'
        'remove:remove library package dependency'
        'upgrade:upgrade (or downgrade) library package dependency'
        'update:update package index'
        'search:search library package index'
    )
    _describe -t commands 'acton pkg command' commands
}

(( $+functions[_acton_pkg_show] )) ||
_acton_pkg_show() {
    _arguments \
        '(- *)--help[show help for pkg show]'
}

(( $+functions[_acton_pkg_add] )) ||
_acton_pkg_add() {
    _arguments \
        '--url=[URL of dependency]:url:_urls' \
        '--repo-url=[Git repository URL of dependency]:url:_urls' \
        '--repo-ref=[Git ref (branch, tag or SHA)]:ref:' \
        '--pkg-name=[package name in index (defaults to NAME)]:name:' \
        '--hash=[hash of dependency]:hash:' \
        '--github-token=[GitHub token (env GITHUB_TOKEN)]:token:' \
        '(- *)--help[show help for pkg add]' \
        ':dependency name:'
}

(( $+functions[_acton_pkg_remove] )) ||
_acton_pkg_remove() {
    _arguments \
        '(- *)--help[show help for pkg remove]' \
        ':dependency name:'
}

(( $+functions[_acton_pkg_upgrade] )) ||
_acton_pkg_upgrade() {
    _arguments \
        '--github-token=[GitHub token (env GITHUB_TOKEN)]:token:' \
        '(- *)--help[show help for pkg upgrade]'
}

(( $+functions[_acton_pkg_update] )) ||
_acton_pkg_update() {
    _arguments \
        '(- *)--help[show help for pkg update]'
}

(( $+functions[_acton_pkg_search] )) ||
_acton_pkg_search() {
    _arguments \
        '(- *)--help[show help for pkg search]' \
        '*:search term (regex):'
}

(( $+functions[_acton_zig_pkg] )) ||
_acton_zig_pkg() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1: :_acton_zig_pkg_commands' \
        '*::arg:->zpargs' && ret=0

    case $state in
        zpargs)
            case $words[1] in
                add)     _acton_zig_pkg_add    && ret=0 ;;
                remove)  _acton_zig_pkg_remove && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_acton_zig_pkg_commands] )) ||
_acton_zig_pkg_commands() {
    local -a commands
    commands=(
        'add:add Zig package dependency'
        'remove:remove Zig package dependency'
    )
    _describe -t commands 'acton zig-pkg command' commands
}

(( $+functions[_acton_zig_pkg_add] )) ||
_acton_zig_pkg_add() {
    _arguments \
        '*--artifact=[library artifact to link with]:artifact:' \
        '(- *)--help[show help for zig-pkg add]' \
        ':zig pkg URL:_urls' \
        ':dependency name:'
}

(( $+functions[_acton_zig_pkg_remove] )) ||
_acton_zig_pkg_remove() {
    _arguments \
        '(- *)--help[show help for zig-pkg remove]' \
        ':dependency name:'
}

(( $+functions[_acton_spec] )) ||
_acton_spec() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1: :_acton_spec_commands' \
        '*::arg:->specargs' && ret=0

    case $state in
        specargs)
            case $words[1] in
                dump)    _arguments '(- *)--help[show help for spec dump]' && ret=0 ;;
                update)  _arguments '(- *)--help[show help for spec update]' ':JSON file:_files -g "*.json"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_acton_spec_commands] )) ||
_acton_spec_commands() {
    local -a commands
    commands=(
        'dump:dump build spec as JSON to stdout (from Build.act)'
        'update:update Build.act using JSON file; override entries only'
    )
    _describe -t commands 'acton spec command' commands
}

(( $+functions[_acton_cloud] )) ||
_acton_cloud() {
    _arguments \
        '--run[help run!]' \
        '--list[help list!]' \
        '--show[help show!]' \
        '--stop[help stop!]' \
        '(- *)--help[show help for cloud]'
}

(( $+functions[_acton_doc] )) ||
_acton_doc() {
    _arguments \
        '(-t --terminal --md --markdown --html)'{-t,--terminal}'[terminal output (ASCII format)]' \
        '(-t --terminal --md --markdown --html)--md[Markdown format]' \
        '(-t --terminal --md --markdown --html)--markdown[Markdown format]' \
        '(-t --terminal --md --markdown --html)--html[HTML format]' \
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:output file:_files' \
        '(- *)--help[show help for doc]' \
        ':input file:_files -g "*.(act|tydb)"'
}

(( $+functions[_acton_version] )) ||
_acton_version() {
    _arguments \
        '(- *)--help[show help for version]'
}

_acton "$@"
