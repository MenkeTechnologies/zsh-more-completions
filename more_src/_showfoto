#compdef showfoto

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[all help options]' \
  '--help-qt[Qt help]' \
  '--help-kde[KDE help]' \
  '--version[show version]' \
  '--display=[X display]:display:' \
  '*:image:_files -g "*.jpg *.jpeg *.png *.gif *.bmp *.tif *.tiff *.svg *.webp *.cr2 *.nef *.arw *.dng *.raw *.heic *.heif *.psd *.xcf"' && ret=0

return ret
