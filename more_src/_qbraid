#compdef qbraid qbraid-cli
# _qbraid — qBraid SDK official CLI for the qBraid Cloud platform device job credit management (qBraid team, Python); typer
# upstream: https://github.com/qBraid/qBraid

_qbraid() {
    local -a sub=(
        'configure:set up qBraid credentials'
        'devices:list available quantum devices'
        'jobs:job subcommands'
        'envs:environment subcommands'
        'kernels:kernel subcommands'
        'auth:authentication subcommands'
        'admin:admin subcommands'
        'credits:show available credits'
        'magic:list IPython magics'
        'pin:pin a kernel'
        'unpin:unpin a kernel'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--install-completion=+[shell]:s:(bash zsh fish powershell)' \
        '--show-completion=+[shell]:s:(bash zsh fish powershell)' \
        '--api-key=+[api key]:str:' \
        '--user=+[username]:user:_users' \
        '--profile=+[profile]:str:' \
        '--output=+[format]:f:(table json yaml)' \
        '-o+[format]:f:(table json yaml)' \
        '--no-color[disable color]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--debug[debug logs]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qbraid subcommand' sub ;;
        args)
            case $words[1] in
                devices) _arguments \
                    '--type=+[type]:t:(QPU SIMULATOR)' \
                    '--provider=+[provider]:p:(aws ibm google ionq rigetti quera oqc pasqal qbraid quantinuum)' \
                    '--status=+[status]:s:(ONLINE OFFLINE RETIRED PAUSED)' ;;
                jobs) _arguments '1:jobs cmd:(list show cancel results)' ;;
                envs) _arguments '1:envs cmd:(list create activate deactivate add-pkgs remove install pip search show update)' ;;
                kernels) _arguments '1:kernels cmd:(list add remove pin unpin show)' ;;
                auth) _arguments '1:auth cmd:(login logout status)' ;;
                admin) _arguments '1:admin cmd:(audit-log users credits)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_qbraid "$@"
