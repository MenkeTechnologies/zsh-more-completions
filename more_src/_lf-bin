#compdef lf
# _lf-bin — lf list files (Gokçehan Kara, Go); ranger-inspired terminal file manager in Go
# upstream: https://github.com/gokcehan/lf

_lf-bin() {
    _arguments \
        '-config+[config file]:file:_files' \
        '-command+[evaluate command at start]:cmd:' \
        '-cpuprofile+[CPU profile file]:file:_files' \
        '-doc[print scripting docs]' \
        '-help[show help]' \
        '-last-dir-path+[last dir path file]:file:_files' \
        '-log+[log file]:file:_files' \
        '-log-level+[log level]:level:(none info debug)' \
        '-memprofile+[mem profile file]:file:_files' \
        '-remote+[send remote command]:str:' \
        '-selection-path+[selection file]:file:_files' \
        '-server[run server only]' \
        '-single[single instance mode]' \
        '-version[show version]' \
        '*:dir:_files -/'
}

_lf-bin "$@"
