#compdef vcfhetcount
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfhetcount.md
# Count alternate alleles in heterozygous genotypes per individual

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
