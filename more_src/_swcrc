#compdef swcrc
# _swcrc — .swcrc config preview launcher (SWC project); dumps resolved SWC config for current dir
# upstream: https://github.com/swc-project/swc

_swcrc() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--cwd+[cwd]:dir:_files -/' \
        '--config-file+[swcrc path]:file:_files' \
        '*:file:_files'
}

_swcrc "$@"
