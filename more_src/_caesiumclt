#compdef caesiumclt
# Documentation: https://github.com/Lymphatus/caesium-clt/blob/main/docs/USAGE.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# caesium-clt: command-line image compressor (Lymphatus/caesium-clt).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--lossless[lossless compression]' \
  '(-q --quality)'{-q+,--quality=}'[lossy quality level]:n:' \
  '--max-size=[target maximum file size in bytes]:bytes:' \
  '--width=[resize to width in pixels]:px:' \
  '--height=[resize to height in pixels]:px:' \
  '--long-edge=[resize by longest edge]:px:' \
  '--short-edge=[resize by shortest edge]:px:' \
  '--format=[convert format]:format:(jpeg png webp tiff original)' \
  '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
  '-R[recurse into directories]' \
  '-S[preserve folder structure]' \
  '--suffix=[output filename suffix]:suffix:' \
  '--keep-dates[preserve file timestamps]' \
  '-e[preserve EXIF metadata]' \
  '--same-folder-as-input[write output beside input]' \
  '(-O --overwrite)'{-O+,--overwrite=}'[overwrite policy]:policy:(all never bigger)' \
  '--threads=[number of worker threads]:n:' \
  '--dry-run[do not write files]' \
  '--png-opt-level=[PNG optimization level]:n:(0 1 2 3 4 5 6)' \
  '--jpeg-chroma-subsampling=[JPEG chroma subsampling]:val:(auto 444 422 420 411)' \
  '--jpeg-baseline[force JPEG baseline encoding]' \
  '*:image file:_files'
