#compdef cdo
# Documentation: https://code.mpimet.mpg.de/projects/cdo/wiki/Cdo
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-a --absolute_taxis)'{-a,--absolute_taxis}'[absolute time axis]' \
  '--async_read=[async read]:bool:(true false)' \
  '-b[output precision]:precision:' \
  '(-C --color)'{-C,--color}'[colorized output]' \
  '(-c --check_data_range)'{-c,--check_data_range}'[overflow checks]' \
  '--chunksize=[NetCDF4 chunk size]:size:' \
  '--chunkspec=[chunking spec]:spec:' \
  '--cmor[CMOR-conform NetCDF]' \
  '--copy_chunkspec[copy chunk spec]' \
  '--double[double precision]' \
  '--eccodes[use ecCodes]' \
  '(-F --filter)'{-F,--filter}'=[NetCDF4 filter]:spec:' \
  '-f[output format]:fmt:(grb1 grb grb2 nc1 nc2 nc nc4 nc4c nc5 srv ext ieg)' \
  '--force[force process]' \
  '-g[default grid]:grid:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--nofile=[max files]:n:' \
  '--no_history[no history attr]' \
  '--netcdf_hdr_pad=[bytes]:n:' \
  '--hdr_pad=[bytes]:n:' \
  '-k[chunk type]:type:(auto grid lines)' \
  '-m[missing value]:val:' \
  '(-O --overwrite)'{-O,--overwrite}'[overwrite]' \
  '--operators[list operators]' \
  '-P[OpenMP threads]:n:' \
  '-p[async read]' \
  '--pedantic[warnings as errors]' \
  '--percentile=[method]:method:(nrank nist rtype8 linear lower higher nearest)' \
  '--precision=[float,double]:prec:' \
  '--query=[pre-select]:key:(group name cell layer step)' \
  '--reduce_dim[reduce dims]' \
  '(-R --regular)'{-R,--regular}'[regular Gaussian]' \
  '(-r --relative_taxis)'{-r,--relative_taxis}'[relative time axis]' \
  '(-S --diagnostic)'{-S,--diagnostic}'[diagnostic stream]' \
  '(-s --silent)'{-s,--silent}'[silent]' \
  '--shuffle[byte shuffle]' \
  '--single[single precision]' \
  '--sortname[alphanumeric sort]' \
  '-t[GRIB partab]:partab:(echam4 echam5 echam6 mpiom1 ecmwf remo)' \
  '--timestat_date=[target timestamp]:date:(first middle midhigh last)' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '-w[no warnings]' \
  '--worker=[workers]:n:' \
  '-z[compression]:type:(aec jpeg zip zstd zip_1 zip_2 zip_3 zip_4 zip_5 zip_6 zip_7 zip_8 zip_9 zstd_1 zstd_5 zstd_10 zstd_19)' \
  '*:file:_files'
