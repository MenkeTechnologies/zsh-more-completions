#compdef tract
# Documentation: https://man.archlinux.org/search?q=tract
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run inference on the model'
  'dump:inspect network structure (optionally with profiling)'
  'bench:run a simple benchmark'
  'criterion:run a benchmark using the criterion crate'
  'compare:compare against reference output'
  'compare-pbdir:compare with TensorFlow protobuf reference dir'
  'compare-npz:compare with numpy NPZ reference'
  'stream-check:check streaming model behavior'
  'optimize-check:check optimizer correctness'
  'cost:show cost analysis'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '-O[apply optimizer (recommended)]' \
  '*-i+[input fact]:input (e.g. 1,3,224,224,f32):' \
  '*--input=[input fact]:input:' \
  '--input-bundle=[NPZ input bundle]:file:_files -g "*.npz"' \
  '--input-facts-from-bundle=[input facts from NPZ]:file:_files -g "*.npz"' \
  '--const-input=[constant input]:input:' \
  '--output-node=[name of output node]:node:' \
  '--input-node=[name of input node]:node:' \
  '--nnef-tract-core[use NNEF tract-core extensions]' \
  '--onnx[force ONNX format]' \
  '--tf[force TensorFlow format]' \
  '--kaldi[force Kaldi format]' \
  '--nnef[force NNEF format]' \
  '--list-ops[list operators]' \
  '--declutter[decluttering pass]' \
  '--pass=[stop at network stage]:stage:(load analyse incorporate type declutter pulse-then-declutter type-then-declutter optimize codegen)' \
  '*-f+[set fact override]:fact:' \
  '*--fact=[set fact override]:fact:' \
  '--steps[show all steps]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tract command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--input-from-bundle=[NPZ input bundle]:file:_files -g "*.npz"' \
          '--assert-output=[expected output values]:values:' \
          '--assert-output-bundle=[expected output NPZ]:file:_files -g "*.npz"' \
          '--save-output=[save output to NPZ]:file:_files' \
          '--allow-random-input[generate random input]' \
          '--print-output[print output values]' \
          '--steps[show all steps]' \
          '*::file:_files' && ret=0 ;;
      (dump)
        _arguments \
          '--profile[show running time per operator]' \
          '--cost[show relative weight per operator]' \
          '--invariants[show invariants]' \
          '--axes[print axis tracking]' \
          '--nnef=[output NNEF directory]:dir:_files -/' \
          '--onnx=[output ONNX file]:file:_files' \
          '*::file:_files' && ret=0 ;;
      (bench|criterion)
        _arguments \
          '--max-iters=[max iterations]:n:' \
          '--max-time=[max benchmark time]:duration:' \
          '*::file:_files' && ret=0 ;;
      (compare|compare-pbdir|compare-npz)
        _arguments \
          '--cumulative[cumulative comparison]' \
          '*::file:_files' && ret=0 ;;
    esac ;;
esac

return ret
