#compdef tract
# Documentation: https://github.com/sonos/tract
# Reference accessed: 2026-05-21
# Verified: upstream cli/src/main.rs clap definitions.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run inference on the model'
  'dump:inspect network structure (optionally with profiling)'
  'bench:benchmark tract on randomly generated input'
  'criterion:run a benchmark using the criterion crate'
  'compare:compare against reference output'
  'list-ops:list ops in TF/ONNX frameworks'
  'list-runtimes:list runtimes'
  'kernels:print kernels for the current platform'
  'hwbench:print current hardware key metrics'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '-O[optimize before running]' \
  '*'{-i+,--input=}'[input fact]:input' \
  '--input-bundle=[NPZ input bundle]:file:_files -g "*.npz"' \
  '--input-facts-from-bundle=[input facts from NPZ]:file:_files -g "*.npz"' \
  '--onnx-test-data-set=[use ONNX test data-set as input]:dir:_files -/' \
  '*--input-node=[override input node name]:node' \
  '*--output-node=[output node name]:node' \
  '--nnef-tract-resource[allow tract-resource extension in NNEF]' \
  '--nnef-tract-onnx[allow tract-onnx extension in NNEF]' \
  '--nnef-tract-pulse[allow tract-pulse extension in NNEF]' \
  '--nnef-tract-extra[allow tract-extra extension in NNEF]' \
  '--nnef-tract-transformers[allow tract-transformers extension in NNEF]' \
  '--opl[activate all NNEF tract extensions]' \
  '-f+[format]:format' \
  '--pass=[pass to stop preprocessing after]:stage:(load analyse incorporate type declutter pulse pulse-to-type pulse-declutter set set-declutter nnef-cycle nnef-cycle-declutter)' \
  '--metal[convert supported operators to Metal GPU equivalent]' \
  '--cuda[convert supported operators to CUDA equivalent]' \
  '(-r --runtime)'{-r+,--runtime=}'[run on alternative runtime]:runtime' \
  '*'{-t+,--transform=}'[apply built-in transformation to the model]:transform' \
  '--threads=[setup a thread pool for computing (0=physical cores)]:n' \
  '--timeout=[kill the process after this many seconds]:seconds' \
  '--llm[shortcut: --opl --causal-llm-hints -t transformers_detect_all]' \
  '--readings[start readings instrumentation]' \
  '--machine-friendly[machine friendly output]' \
  '--determinize[enforce a seed in random operator]' \
  '--partial[before analyse, eliminate dead branches]' \
  '--recursive[apply to sub graphs]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tract command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--dump[show output]' \
          '--allow-random-input[generate random input]' \
          '*::file:_files' && ret=0 ;;
      (dump)
        _arguments \
          '--profile[show running time per operator]' \
          '--cost[show relative weight per operator]' \
          '--nnef=[output NNEF directory]:dir:_files -/' \
          '*::file:_files' && ret=0 ;;
      (bench|criterion)
        _arguments \
          '*::file:_files' && ret=0 ;;
      (compare)
        _arguments \
          '--npz=[NPZ file to compare against]:file:_files -g "*.npz"' \
          '*::file:_files' && ret=0 ;;
    esac ;;
esac

return ret
