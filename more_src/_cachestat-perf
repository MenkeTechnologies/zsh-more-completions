#compdef cachestat-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/cachestat.8
# show Linux page cache hit/miss statistics (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-D[print debug counters]' \
  '-t[include timestamp]' \
  '*:interval seconds:' && ret=0

return ret
