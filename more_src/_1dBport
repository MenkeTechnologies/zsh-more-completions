#compdef 1dBport
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dBport.html
# Create columns of sines and cosines for bandpassing via regression

local ret=1

_arguments -s -S \
  '*-band[lowest and highest frequencies in passband]:fbot:_message fbot' \
  '-invert[output all frequencies NOT selected by -band]' \
  '-nozero[do not generate the 0 frequency component]' \
  '-noconst[do not generate the 0 frequency component]' \
  '-quad[add regressors for linear and quadratic trends]' \
  '-input[specify number of time points using a dataset]:dataset:_files' \
  '-input1D[specify number of time points using a 1D file]:file:_files' \
  '-nodata[specify time series length without input data]:NT' \
  '-TR[set the time step value]:del' \
  '-concat[list of start indexes for concatenated runs]:file:_files' && ret=0

return ret
