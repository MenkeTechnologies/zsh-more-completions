#compdef openshift-install

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create:create part of an OpenShift Container Platform install'
  'destroy:destroy part of an OpenShift Container Platform install'
  'wait-for:wait for install to reach a milestone'
  'gather:gather installer data'
  'agent:agent-based install operations'
  'image-based:image-based install operations'
  'analyze:analyze installer assets/state'
  'coreos:CoreOS image utilities'
  'explain:explain configuration parameters'
  'graph:print installer graph'
  'version:show installer version'
  'completion:generate shell completion'
  'list-features:list installer features'
  'migrate:migrate operations'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--dir=[assets directory]:dir:_files -/' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'openshift-install subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create)
        _values 'create target' \
          'cluster' 'install-config' 'manifests' 'ignition-configs' \
          'single-node-ignition-config' 'agent-config-template' \
          'image-based-iso' 'image-based-config-template' \
          'permissions-policy' 'pxe-files' 'cluster-manifests' && ret=0
        ;;
      (destroy)
        _values 'destroy target' 'cluster' 'bootstrap' && ret=0
        ;;
      (wait-for)
        _values 'wait-for target' 'bootstrap-complete' 'install-complete' && ret=0
        ;;
      (gather)
        _values 'gather target' 'bootstrap' && ret=0
        ;;
      (agent)
        _values 'agent action' \
          'create' 'wait-for' && ret=0
        ;;
      (image-based)
        _values 'image-based action' \
          'create' 'wait-for' && ret=0
        ;;
      (coreos)
        _values 'coreos action' 'print-stream-json' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
