#compdef aragorn
# Documentation: https://www.trna.se/options.txt
# ARAGORN - detect tRNA, mtRNA and tmRNA genes in nucleotide sequences

local ret=1

_arguments -s -S \
  '-m[search for tmRNA genes]' \
  '-t[search for tRNA genes]' \
  '-mt[search for Metazoan mitochondrial tRNA genes]' \
  '-mtmam[search for Mammalian mitochondrial tRNA genes]' \
  '-mtx[as -mt but low scoring tRNA genes not reported]' \
  '-mtd[report overlapping metazoan mito tRNA on opposite strands]' \
  '-gcstd[use standard genetic code]' \
  '-gcmet[use composite Metazoan mitochondrial genetic code]' \
  '-gcvert[use Vertebrate mitochondrial genetic code]' \
  '-gcinvert[use Invertebrate mitochondrial genetic code]' \
  '-gcyeast[use Yeast mitochondrial genetic code]' \
  '-gcprot[use Mold/Protozoan/Coelenterate mito genetic code]' \
  '-gcciliate[use Ciliate genetic code]' \
  '-gcflatworm[use Echinoderm/Flatworm mito genetic code]' \
  '-gceuplot[use Euplotid genetic code]' \
  '-gcbact[use Bacterial/Plant chloroplast genetic code]' \
  '-c[assume circular topology (wraps around ends)]' \
  '-l[assume linear topology (no wrap)]' \
  '-d[search both strands of each sequence]' \
  '-s[do not search complementary strand]' \
  '-sc[do not search sense strand]' \
  '-i[search for tRNA genes with introns]' \
  '-io[allow intron-containing genes to overlap shorter genes]' \
  '-if[fix intron between positions 37-38 on C-loop]' \
  '-ir[report genes meeting minimum intron length]' \
  '-tv[do not search for mito TV replacement loop genes]' \
  '-c7[search for tRNA genes with 7 base C-loops only]' \
  '-ss[use stricter canonical spacer requirements]' \
  '-j[display 4-base sequence on 3 prime end of astem]' \
  '-jr[allow divergence from NCCA in 3 prime acceptor]' \
  '-jr4[allow NCCA divergence and display 4 bases]' \
  '-e[print score for each reported gene]' \
  '-ps[lower scoring thresholds to 95% of default]' \
  '-rp[flag possible pseudogenes]' \
  '-seq[print primary sequence]' \
  '-br[show secondary structure using round brackets]' \
  '-svg[generate SVG image file for secondary structure]' \
  '-fasta[print primary sequence in fasta format]' \
  '-fo[print primary sequence in fasta format only]' \
  '-fon[as -fo with sequence and gene numbering]' \
  '-fos[as -fo with no spaces in header]' \
  '-fons[as -fo with numbering and no spaces]' \
  '-a[print tRNA domain for tmRNA genes]' \
  '-a7[restrict tRNA astem length to maximum 7 bases]' \
  '-aa[display mismatch message if iso-acceptor differs]' \
  '-v[verbose output to stderr during search]' \
  '-q[omit configuration line from output]' \
  '-rn[repeat sequence name before summary info]' \
  '-w[print output in batch mode]' \
  '-wa[batch mode with iso-acceptor notation]' \
  '-o+[print output to specified file]:file:_files' \
  '*:nucleotide file:_files' && ret=0

return ret
