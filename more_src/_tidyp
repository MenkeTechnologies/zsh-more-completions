#compdef tidyp

_arguments \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)'{-v,-version}'[show version]' \
  '-indent[indent element content]' \
  '-wrap[wrap text at column]:column number' \
  '-upper[force tags to upper case]' \
  '-clean[replace FONT/NOBR/CENTER with CSS]' \
  '-bare[strip out smart quotes and dashes]' \
  '-gdoc[produce clean version of Google Docs HTML]' \
  '-numeric[output numeric rather than named entities]' \
  '-errors[show only errors and warnings]' \
  '-quiet[suppress nonessential output]' \
  '-omit[omit optional start and end tags]' \
  '-xml[input is well formed XML]' \
  '-asxml[convert HTML to XHTML]' \
  '-asxhtml[convert HTML to XHTML]' \
  '-access[do accessibility checks]:level:(0 1 2 3)' \
  '-raw[output values above 127 without conversion]' \
  '-ascii[use US-ASCII for output]' \
  '-latin0[use ISO-8859-15 for output]' \
  '-latin1[use ISO-8859-1 for output]' \
  '-utf8[use UTF-8 for both input and output]' \
  '-utf16le[use UTF-16LE for both input and output]' \
  '-utf16be[use UTF-16BE for both input and output]' \
  '-utf16[use UTF-16 for both input and output]' \
  '-mac[use MacRoman for input]' \
  '-win1252[use Windows-1252 for input]' \
  '-config[set configuration options from file]:file:_files' \
  '-f[write errors to file]:file:_files' \
  '-output[write output to file]:file:_files' \
  '-modify[modify original input files]' \
  '*:input file:_files -g "*.{html,htm,xhtml,xml}"'
