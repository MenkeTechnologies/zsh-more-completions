#compdef tidyp
# Documentation: https://github.com/petdance/tidyp/blob/master/src/tidyp.c
# Reference accessed: 2026-05-21
# Verified: upstream tidyp.c usage strings at the URL above.

_arguments \
  '(- *)'{-h,-help,-\?}'[show help]' \
  '(- *)'{-v,-version}'[show version]' \
  '-indent[indent element content]' \
  '-i[indent element content]' \
  '-wrap[wrap text at column]:column:' \
  '-w[wrap text at column]:column:' \
  '-upper[force tags to upper case]' \
  '-u[force tags to upper case]' \
  '-clean[replace FONT/NOBR/CENTER with CSS]' \
  '-c[replace FONT/NOBR/CENTER with CSS]' \
  '-bare[strip out smart quotes and em dashes]' \
  '-b[strip out smart quotes and em dashes]' \
  '-numeric[output numeric rather than named entities]' \
  '-n[output numeric rather than named entities]' \
  '-errors[show only errors and warnings]' \
  '-e[show only errors and warnings]' \
  '-quiet[suppress nonessential output]' \
  '-q[suppress nonessential output]' \
  '-omit[omit optional end tags]' \
  '-xml[treat input as well-formed XML]' \
  '-asxml[convert HTML to XHTML]' \
  '-asxhtml[convert HTML to XHTML]' \
  '-ashtml[force XHTML to well-formed HTML]' \
  '-access[do accessibility checks]:level:(0 1 2 3)' \
  '-raw[output values above 127 without conversion]' \
  '-ascii[use US-ASCII for output]' \
  '-latin0[use ISO-8859-15 for output]' \
  '-latin1[use ISO-8859-1 for output]' \
  '-iso2022[use ISO-2022 encoding]' \
  '-utf8[use UTF-8 for both input and output]' \
  '-utf16le[use UTF-16LE for both input and output]' \
  '-utf16be[use UTF-16BE for both input and output]' \
  '-utf16[use UTF-16 for both input and output]' \
  '-mac[use MacRoman for input]' \
  '-win1252[use Windows-1252 for input]' \
  '-ibm858[use IBM-858 (CP850+Euro) for input]' \
  '-big5[use Big5 for input]' \
  '-shiftjis[use Shift_JIS for input]' \
  '-language[two-letter language code]:lang:' \
  '-config[set configuration options from file]:file:_files' \
  '-f[write errors to file]:file:_files' \
  '-file[write errors to file]:file:_files' \
  '-output[write output to file]:file:_files' \
  '-o[write output to file]:file:_files' \
  '-modify[modify original input files]' \
  '-m[modify original input files]' \
  '-xml-help[display help in XML format]' \
  '-help-config[list all configuration options]' \
  '-xml-config[list configuration options in XML format]' \
  '-show-config[display current configuration settings]' \
  '*:input file:_files -g "*.{html,htm,xhtml,xml}"'
