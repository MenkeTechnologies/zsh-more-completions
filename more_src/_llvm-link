#compdef llvm-link
# _llvm-link — LLVM bitcode linker (LLVM project, C++); merge LLVM bitcode files into one module
# upstream: https://github.com/llvm/llvm-project

_llvm-link() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-f[force overwrite]' \
        '-o+[output file]:file:_files' \
        '-S[output LLVM IR]' \
        '-v[verbose]' \
        '--internalize[internalize linked symbols]' \
        '--disable-debug-info-type-map[disable debug info type map]' \
        '--disable-lazy-loading[disable lazy loading]' \
        '--ignore-non-bitcode[ignore non-bitcode files]' \
        '--ignore-empty[ignore empty modules]' \
        '--only-needed[only needed symbols]' \
        '--summary-index=+[summary index file]:file:_files' \
        '--export-list=+[export list file]:file:_files' \
        '--import=+[import names]:str:' \
        '--override=+[override modules]:str:' \
        '-override=+[override modules]:str:' \
        '--print-cyclic-import[print cyclic import]' \
        '*:file:_files -g "*.(bc|ll)"'
}

_llvm-link "$@"
