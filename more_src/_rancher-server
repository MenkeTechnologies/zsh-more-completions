#compdef rancher-server
# Documentation: https://man.archlinux.org/search?q=rancher-server
# Reference accessed: 2026-05-16

# Rancher server: Rancher Kubernetes management platform
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--http-listen-port=[HTTP listen port]:port:' \
  '--https-listen-port=[HTTPS listen port]:port:' \
  '--add-local=[add local cluster]:val:(true false auto)' \
  '--debug[debug logging]' \
  '--trace[trace logging]' \
  '--no-cacerts[do not generate CA certs]' \
  '--k8s-mode=[k8s mode]:mode:(auto external embedded)' \
  '--audit-log-path=[audit log path]:file:_files' \
  '--audit-log-maxage=[audit log max age]:days:' \
  '--audit-log-maxbackup=[audit log max backups]:n:' \
  '--audit-log-maxsize=[audit log max size MB]:mb:' \
  '--audit-level=[audit level]:level:(0 1 2 3)' \
  '--features=[feature flags]:flags:' \
  '*::rancher-server args:_files' && ret=0
return ret
