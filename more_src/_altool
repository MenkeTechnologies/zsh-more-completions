#compdef altool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--validate-app[validate the application archive]' \
  '--upload-app[upload application to App Store Connect]' \
  '--upload-package[upload an unsigned IPA package]' \
  '--notarize-app[submit the app for notarization]' \
  '--notarization-info[get notarization status (deprecated)]:request UUID:' \
  '--notarization-history[show notarization history (deprecated)]' \
  '--list-apps[list applications you can upload]' \
  '--list-providers[list providers (teams) for your account]' \
  '--list-builds[list builds for an app]' \
  '--store-password-in-keychain-item=[store password as keychain item]:label:' \
  '-f+[file to upload or validate]:file:_files -g "*.(ipa|pkg|zip)"' \
  '--file=[file to upload or validate]:file:_files -g "*.(ipa|pkg|zip)"' \
  {-t+,--type=}'[application platform]:platform:(ios osx tvos appletvos)' \
  {-u+,--username=}'[Apple ID username]:user:_email_addresses' \
  {-p+,--password=}'[Apple ID password (use @keychain:label or @env:NAME)]:password:' \
  '--apiKey=[App Store Connect API Key ID]:key id:' \
  '--apiIssuer=[App Store Connect Issuer ID]:issuer id:' \
  '--asc-provider=[short provider/team name]:provider:' \
  '--team-id=[team ID]:team id:' \
  '--bundle-id=[app bundle ID]:bundle id:' \
  '--bundle-version=[app bundle version]:version:' \
  '--bundle-short-version-string=[CFBundleShortVersionString]:version:' \
  '--asc-public-id=[App Store Connect public ID]:id:' \
  '--app-apple-id=[App Apple ID]:id:' \
  {-v,--verbose}'[verbose output]' \
  '--output-format=[output format]:format:(xml normal)' \
  '--primary-bundle-id=[bundle ID for notarization]:bundle id:' \
  '--asc-provider=[provider name]:provider:' \
  '--itc_provider=[iTunes Connect provider]:provider:' && ret=0

return ret
