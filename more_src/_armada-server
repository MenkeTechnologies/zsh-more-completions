#compdef armada-server
# _armada-server — Armada batch workload submission API server (gRPC + REST gateway) for multi-cluster Kubernetes job scheduling
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/server/main.go on tip; runtime config is YAML-driven (./config/server/config.yaml + --config overrides) with viper ARMADA_* env binding.

_armada-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[YAML config file (repeat or comma-separate for multiple)]:file:_files'
}

_armada-server "$@"
