#compdef checkov
# Documentation: https://man.archlinux.org/search?q=checkov
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --directory)*'{-d+,--directory=}'[directory]:dir:_files -/' \
  '(-f --file)*'{-f+,--file=}'[file]:file:_files' \
  '(--workdir)--workdir=[work dir]:dir:_files -/' \
  '(--external-checks-dir)*--external-checks-dir=[ext checks dir]:dir:_files -/' \
  '(--external-checks-git)*--external-checks-git=[ext checks git]:url:' \
  '(-l --list)'{-l,--list}'[list checks]' \
  '(-o --output)*'{-o+,--output=}'[output format]:f:(cli github_failed_only csv cyclonedx cyclonedx_json json junitxml sarif spdx gitlab_sast)' \
  '(--output-file-path)--output-file-path=[output dir]:dir:_files -/' \
  '(--output-bc-ids)--output-bc-ids[output BC IDs]' \
  '(--include-all-checkov-policies)--include-all-checkov-policies[all policies]' \
  '(--quiet)--quiet[quiet]' \
  '(--compact)--compact[compact output]' \
  '(--framework)*--framework=[frameworks csv]:list:(ansible argo_workflows arm azure_pipelines bitbucket_pipelines bicep cdk circleci_pipelines cloudformation dockerfile github_actions github_configuration gitlab_ci gitlab_configuration helm json yaml kubernetes kustomize openapi sast sast_python sast_java sast_javascript sast_typescript secrets serverless terraform terraform_json terraform_plan all)' \
  '(--skip-framework)*--skip-framework=[skip frameworks csv]:list:' \
  '(--skip-check)*--skip-check=[skip checks csv]:list:' \
  '(-c --check)*'{-c+,--check=}'[checks csv]:list:' \
  '(--secrets-history)--secrets-history[scan git history]' \
  '(--no-guide)--no-guide[no guide URLs]' \
  '(--soft-fail)--soft-fail[soft fail]' \
  '(--soft-fail-on)*--soft-fail-on=[soft fail on csv]:list:' \
  '(--hard-fail-on)*--hard-fail-on=[hard fail on csv]:list:' \
  '(--evaluate-variables)--evaluate-variables=[eval variables]:b:(True False)' \
  '(--repo-id)--repo-id=[repo id]:id:' \
  '(--branch)--branch=[branch]:b:' \
  '(--bc-api-key)--bc-api-key=[BC API key]:k:' \
  '(--prisma-api-url)--prisma-api-url=[Prisma API URL]:url:' \
  '(--policy-metadata-filter)--policy-metadata-filter=[metadata filter]:s:' \
  '(--policy-metadata-filter-exception)--policy-metadata-filter-exception=[exception filter]:s:' \
  '(--ca-certificate)--ca-certificate=[CA cert]:file:_files' \
  '(--no-cert-verify)--no-cert-verify[skip cert verify]' \
  '(--config-file)--config-file=[config file]:file:_files' \
  '(--create-config)--create-config=[create config]:file:_files' \
  '(--show-config)--show-config[show config]' \
  '(--baseline)--baseline=[baseline file]:file:_files' \
  '(--create-baseline)--create-baseline[create baseline]' \
  '(--summary-position)--summary-position=[summary position]:p:(top bottom)' \
  '(--max-violations-per-file)--max-violations-per-file=[max violations]:n:' \
  '(--mask)*--mask=[mask values]:s:' \
  '(--block-list-secret-scan)*--block-list-secret-scan=[block list]:s:' \
  '(--debug)--debug[debug]' \
  '(--no-fail-on-crash)--no-fail-on-crash[no fail on crash]' \
  '(--repo-root-for-plan-enrichment)*--repo-root-for-plan-enrichment=[repo root]:dir:_files -/' \
  '(--enable-secret-scan-all-files)--enable-secret-scan-all-files[secret scan all]' \
  '(--download-external-modules)--download-external-modules=[download ext modules]:b:(True False)' \
  '(--var-file)*--var-file=[var file]:file:_files' \
  '*: :_files' && ret=0

return ret
