#compdef nix-prefetch-git

# Zsh completion for nix-prefetch-git (prefetch git repos for Nix)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--url[repository URL]:URL' \
  '--rev[git revision to fetch]:revision' \
  '--hash[expected hash of the output]:hash' \
  '--branch-name[branch to fetch]:branch' \
  '--builder[use a builder to check the hash]' \
  '--no-deepClone[do not deep clone]' \
  '--deepClone[deep clone (fetch all branches and tags)]' \
  '--leave-dotGit[keep the .git directory]' \
  '--fetch-submodules[fetch git submodules]' \
  '--no-fetch-submodules[do not fetch git submodules]' \
  '--sparse-checkout[paths to check out sparsely]:paths' \
  '--quiet[suppress output]' \
  '--help[show help]' \
  '1:repository URL' \
  '2:revision' && ret=0

return ret
