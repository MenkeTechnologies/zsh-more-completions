autoload -U is-at-least

_pomodoro() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_pomodoro_commands" \
"*::: :->pomodoro" \
&& ret=0
    case $state in
    (pomodoro)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pomodoro-command-$line[1]:"
        case $line[1] in
            (create)
_arguments "${_arguments_options[@]}" \
'-w+[]: : ' \
'-b+[]: : ' \
'(-w -b)-d[]' \
'(-w -b)--default[]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(queue)
_arguments "${_arguments_options[@]}" \
'-w+[]: : ' \
'-b+[]: : ' \
'(-w -b)-d[]' \
'(-w -b)--default[]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" \
'(-a --all)-i+[The ID of notification to delete]: : ' \
'(-a --all)--id=[The ID of notification to delete]: : ' \
'-a[The flag to delete all notifications]' \
'--all[The flag to delete all notifications]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" \
'-p[show work time completion percentage]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(history)
_arguments "${_arguments_options[@]}" \
'-c[The flag to delete all notifications from history]' \
'--clear[The flag to delete all notifications from history]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(test)
_arguments "${_arguments_options[@]}" \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(exit)
_arguments "${_arguments_options[@]}" \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
":: :_pomodoro__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pomodoro-help-command-$line[1]:"
        case $line[1] in
            (create)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(queue)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(history)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(test)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(exit)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_pomodoro_commands] )) ||
_pomodoro_commands() {
    local commands; commands=(
'create:create the notification' \
'queue:create the notification' \
'delete:delete a notification' \
'list:list notifications' \
'history:show archived notifications' \
'test:test notification' \
'clear:clear terminal' \
'exit:exit pomodoro app' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'pomodoro commands' commands "$@"
}
