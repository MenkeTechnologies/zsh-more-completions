#compdef imodjoin
# Documentation: https://bio3d.colorado.edu/imod/doc/man/imodjoin.html
# Combine two or more IMOD models into one

local ret=1

_arguments -s \
  '-o[may be entered before each input model.]' \
  '-r[This option can be used to replace the listed objects in the]:value' \
  '-c[Change colors of the objects being added to the first...]' \
  '-d[Models are from different volumes rather than from the same...]' \
  '-i[With this option, the header information in the given image...]:file:_files' \
  '-s[Do not adjust for scale (pixel spacing) differences between...]' \
  '-f[Retain (or restore) the original Y-Z flipped state of each]' \
  '-n[Do not transform models at all. This option will prevent...]' \
  '*:file:_files' && ret=0

return ret
