#compdef gmx-bundle
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-bundle.html
# gmx bundle: analyze bundles of axes, e.g. helices

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[structure+mass(db) file]:file:_files' \
  '-n[index file]:file:_files' \
  '-ol[xvgr/xmgr file for axis length]:file:_files' \
  '-od[xvgr/xmgr file for distance]:file:_files' \
  '-oz[xvgr/xmgr file for z-shift]:file:_files' \
  '-ot[xvgr/xmgr file for total tilt]:file:_files' \
  '-otr[xvgr/xmgr file for radial tilt]:file:_files' \
  '-otl[xvgr/xmgr file for lateral tilt]:file:_files' \
  '-ok[xvgr/xmgr file for total kinks]:file:_files' \
  '-okr[xvgr/xmgr file for radial kinks]:file:_files' \
  '-okl[xvgr/xmgr file for lateral kinks]:file:_files' \
  '-oa[PDB file for axis coordinates]:file:_files' \
  '-b[start time for trajectory reading]:time:' \
  '-e[end time for trajectory reading]:time:' \
  '-dt[frame sampling interval]:time:' \
  '-tu[unit for time values]:unit:(fs ps ns us ms s)' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-na[number of axes to analyze]:int:' \
  '-z[use z-axis as reference instead of average axis]' && ret=0

return ret
