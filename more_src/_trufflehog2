#compdef trufflehog2
# _trufflehog2 — Truffle Security trufflehog2 CLI command-line frontend wrapping the TruffleHog open-source tool that finds and verifies credentials secrets keys in code in git history Docker images S3 buckets Postman GitHub GitLab Bitbucket Confluence Jira Slack Notion AWS Azure GCP Travis Circle CI Heroku Mailgun Twilio Vault Stripe Sentry Twitter API keys verifying with the corresponding service that the key actually works only-verified continuously continuous-integration filesystem (Truffle Security team Dylan Ayrey, Go); cobra
# upstream: https://trufflesecurity.com/trufflehog

_trufflehog2() {
    local -a sub=(
        'git:scan a git repo'
        'github:scan GitHub'
        'gitlab:scan GitLab'
        'bitbucket:scan Bitbucket'
        'azure-repos:scan Azure Repos'
        'gerrit:scan Gerrit'
        'circleci:scan CircleCI'
        'travisci:scan TravisCI'
        'jenkins:scan Jenkins'
        'docker:scan Docker images'
        'filesystem:scan filesystem'
        'fs:scan filesystem'
        's3:scan S3 buckets'
        'gcs:scan GCS'
        'syslog:scan syslog'
        'stdin:scan stdin'
        'postman:scan Postman'
        'jira:scan Jira'
        'confluence:scan Confluence'
        'sharepoint:scan SharePoint'
        'slack:scan Slack'
        'slack-realtime:scan Slack realtime'
        'huggingface:scan HuggingFace'
        'elasticsearch:scan Elasticsearch'
        'completion:generate shell completion'
        'analyze:analyze tokens'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--trace[trace]' \
        '--profile[profile]' \
        '--no-color[no color]' \
        '--no-update[no update check]' \
        '--no-banner[no banner]' \
        '--json[JSON output]' \
        '--github-actions[GitHub Actions output]' \
        '--concurrency=+[N]:n:' \
        '--only-verified[only verified secrets]' \
        '--allow-verification-overlap[allow verification overlap]' \
        '--results=+[r]:r:(verified unknown unverified filtered_unverified)' \
        '--filter-unverified[filter unverified]' \
        '--filter-entropy=+[N]:str:' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '--print-avg-detector-time[print avg detector time]' \
        '--print-detector-times[print detector times]' \
        '--no-verification[no verification]' \
        '--exclude-detectors=+[list]:str:' \
        '--include-detectors=+[list]:str:' \
        '--include-paths=+[file]:file:_files' \
        '--exclude-paths=+[file]:file:_files' \
        '--archive-max-size=+[bytes]:str:' \
        '--archive-max-depth=+[N]:n:' \
        '--archive-timeout=+[d]:str:' \
        '--archive-disable[no archive scan]' \
        '--fail[fail on found]' \
        '--ignore-secrets-store[ignore secrets store]' \
        '--detector-timeout=+[d]:str:' \
        '--custom-verifiers=+[file]:file:_files' \
        '--no-fail-on-verification-errors[no fail on verify err]' \
        '--force-skip-archives[force skip archives]' \
        '--force-skip-binaries[force skip binaries]' \
        '--user-agent=+[ua]:str:' \
        '--log-file=+[file]:file:_files' \
        '--compare-detection-strategies[compare detection]' \
        '--max-file-depth=+[N]:n:' \
        '--max-job-size=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'trufflehog subcommand' sub ;;
        args)
            case $words[1] in
                git) _arguments '*:repo:' ;;
                github|gitlab|bitbucket) _arguments '*:url:' ;;
                docker) _arguments '*:image:' ;;
                filesystem|fs) _arguments '*:path:_files -/' ;;
                s3) _arguments '*:bucket:' ;;
            esac
            ;;
    esac
}

_trufflehog2 "$@"
