#compdef connectomestats
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/connectomestats.html
# Source: MRtrix3/mrtrix3 cmd/connectomestats.cpp — connectome group statistics (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-threshold+[t-statistic threshold]:n:_default' \
    '-notest[do not run statistical test]' \
    '-nshuffles+[number of permutations]:n:_default' \
    '-permutations+[permutations file]:file:_files' \
    '-tfce_dh+[TFCE step size]:n:_default' \
    '-tfce_e+[TFCE extent power]:n:_default' \
    '-tfce_h+[TFCE height power]:n:_default' \
    '1:input (file listing connectomes):_files -g "*.txt"' \
    '2:algorithm:(nbs nbse cfe)' \
    '3:design (matrix):_files -g "*.txt"' \
    '4:contrast (matrix):_files -g "*.txt"' \
    '5:output prefix:_default' \
    && ret=0

return ret
