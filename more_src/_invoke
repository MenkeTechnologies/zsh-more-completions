#compdef invoke inv
# _invoke — Invoke Python task execution tool (pyinvoke/invoke)
# upstream: https://github.com/pyinvoke/invoke

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-l --list)'{-l,--list}'[list available tasks]' \
  '(-c --collection)'{-c,--collection}'=[task collection module]:module:' \
  '(-r --search-root)'{-r,--search-root}'=[root directory to search for tasks]:dir:_files -/' \
  '(-f --config)'{-f,--config}'=[config file]:file:_files' \
  '--no-dedupe[do not deduplicate tasks]' \
  '--prompt-for-sudo-password[prompt for sudo password]' \
  '(-e --echo)'{-e,--echo}'[echo commands before running]' \
  '(-w --warn-only)'{-w,--warn-only}'[warn on failure instead of stopping]' \
  '--hide=[hide output]:stream:(out err both)' \
  '--pty[use pseudo-terminal]' \
  '--dry[dry run mode]' \
  '--write-pyc[write .pyc files]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '--complete[print completion candidates]' \
  '*:task:_invoke_tasks'

_invoke_tasks() {
    local -a tasks
    tasks=(${(f)"$(invoke --list --list-format=plain 2>/dev/null | awk '{print $1}')"})
    if (( ${#tasks} )); then
        _describe -t tasks 'invoke task' tasks
    else
        _message 'task name'
    fi
}
