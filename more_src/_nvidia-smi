#compdef nvidia-smi

# Zsh completion for nvidia-smi (NVIDIA System Management Interface)

_nvidia-smi() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-L[list all available NVIDIA devices]' \
    '-q[display GPU or unit info]' \
    '--query[display GPU or unit info]' \
    '-i+[target a specific GPU]:GPU index or UUID:' \
    '--id=[target a specific GPU]:GPU index or UUID:' \
    '-f+[redirect query output to a file]:output file:_files' \
    '--filename=[redirect query output to a file]:output file:_files' \
    '-x[produce XML output]' \
    '--xml-format[produce XML output]' \
    '-d+[display only selected information]:info type:(MEMORY UTILIZATION ECC TEMPERATURE POWER CLOCK COMPUTE PIDS PERFORMANCE SUPPORTED_CLOCKS PAGE_RETIREMENT ACCOUNTING ENCODER_STATS)' \
    '--display=[display only selected information]:info type:(MEMORY UTILIZATION ECC TEMPERATURE POWER CLOCK COMPUTE PIDS PERFORMANCE SUPPORTED_CLOCKS PAGE_RETIREMENT ACCOUNTING ENCODER_STATS)' \
    '-l+[continuously report query data at specified interval]:interval (seconds):' \
    '--loop=[continuously report query data at specified interval]:interval (seconds):' \
    '-lms=[continuously report at specified interval in ms]:interval (ms):' \
    '--loop-ms=[continuously report at specified interval in ms]:interval (ms):' \
    '--query-gpu=[query specific GPU attributes]:attributes:' \
    '--query-compute-apps=[query compute apps attributes]:attributes:' \
    '--query-accounted-apps=[query accounted apps attributes]:attributes:' \
    '--query-retired-pages=[query retired pages attributes]:attributes:' \
    '--query-remapped-rows=[query remapped rows attributes]:attributes:' \
    '--format=[format for query output]:format:(csv noheader nounits)' \
    '-pm+[set persistence mode]:mode:(0 1)' \
    '--persistence-mode=[set persistence mode]:mode:(0 1)' \
    '-e+[toggle ECC support]:mode:(0 1)' \
    '--ecc-config=[toggle ECC support]:mode:(0 1)' \
    '-p+[reset ECC error counts]:type:(0 1)' \
    '--reset-ecc-errors=[reset ECC error counts]:type:(0 1)' \
    '-c+[set compute mode]:mode:(0 1 2 3)' \
    '--compute-mode=[set compute mode]:mode:(0 1 2 3)' \
    '--gom=[set GPU operation mode]:mode:(0 1 2)' \
    '-r[trigger reset of the GPU]' \
    '--gpu-reset[trigger reset of the GPU]' \
    '-ac+[set application clocks]:clocks (mem,graphics):' \
    '--applications-clocks=[set application clocks]:clocks (mem,graphics):' \
    '-rac[reset application clocks to default]' \
    '--reset-applications-clocks[reset application clocks to default]' \
    '-acp+[toggle application clock permission]:mode:(0 1)' \
    '--applications-clocks-permission=[toggle application clock permission]:mode:(0 1)' \
    '-pl+[set power management limit]:power limit (watts):' \
    '--power-limit=[set power management limit]:power limit (watts):' \
    '-am+[toggle accounting mode]:mode:(0 1)' \
    '--accounting-mode=[toggle accounting mode]:mode:(0 1)' \
    '-caa[clear all accounting pids]' \
    '--clear-accounted-apps[clear all accounting pids]' \
    '--auto-boost-default=[set auto boost default]:mode:(0 1)' \
    '--auto-boost-permission=[set auto boost permission]:mode:(0 1)' \
    '-mig+[toggle MIG mode]:mode:(0 1)' \
    '--multi-instance-gpu=[toggle MIG mode]:mode:(0 1)' \
    '-gtt+[set GPU target temperature]:temperature (C):' \
    '--gpu-target-temperature=[set GPU target temperature]:temperature (C):' \
    '--lock-gpu-clocks=[lock GPU clocks to range]:min,max:' \
    '--reset-gpu-clocks[reset GPU clocks]' \
    '--lock-memory-clocks=[lock memory clocks to range]:min,max:' \
    '--reset-memory-clocks[reset memory clocks]' \
    '-dtd[display device topology diagram]' \
    '-t[display device topology]' \
    '--debug=[set debug file]:debug file:_files' \
    '-h[display help message]' \
    '--help[display help message]' \
    && ret=0

  return ret
}

_nvidia-smi "$@"
