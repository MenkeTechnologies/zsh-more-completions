#compdef kmscon

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--debug[enable debug logging]' \
  '--silent[suppress all logging]' \
  '--configdir[path to configuration directory]:directory:_files -/' \
  '--vt[VT to use]:vt number:' \
  '--switchvt[automatically switch to new VT]' \
  '--seats[seats to run on]:seats:' \
  '--listen[listen on additional sockets]' \
  '--xkb-model[XKB keyboard model]:model:' \
  '--xkb-layout[XKB keyboard layout]:layout:' \
  '--xkb-variant[XKB keyboard variant]:variant:' \
  '--xkb-options[XKB keyboard options]:options:' \
  '--xkb-keymap[path to XKB keymap file]:keymap:_files' \
  '--xkb-repeat-delay[key repeat delay in ms]:delay:' \
  '--xkb-repeat-rate[key repeat rate in ms]:rate:' \
  '--font-name[font name to use]:font name:' \
  '--font-size[font size in points]:size:' \
  '--font-dpi[DPI for font rendering]:dpi:' \
  '--palette[color palette to use]:palette:(default solarized solarized-black solarized-white)' \
  '--sb-size[scrollback buffer size in lines]:lines:' \
  '--login[login program to execute]:program:_command_names' \
  '--term[TERM environment variable value]:term type:'
