#compdef typtea
# Documentation: https://github.com/ashish0kumar/typtea
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# typtea: minimal terminal typing tester (Go cobra CLI)

local curcontext="$curcontext" state line ret=1
local -a _typtea_cmds

_typtea_cmds=(
  'start:initiate a typing test'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'typtea command' _typtea_cmds && ret=0 ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '--duration=[test duration in seconds]:seconds:' \
          '--lang=[language for test words]:language:' \
          '--list-langs[list all available languages]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0 ;;
    esac ;;
esac

return ret
