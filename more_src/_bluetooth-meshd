#compdef bluetooth-meshd
# Documentation: https://github.com/bluez/bluez/blob/master/mesh/main.c
# Source: BlueZ — Bluetooth Mesh daemon (provisioner / node implementing the Mesh Profile spec).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--io=[I/O implementation]:io:(auto generic ell-hci)' \
    '--storage=[mesh node configuration directory]:dir:_directories' \
    '--config=[daemon configuration directory]:dir:_directories' \
    '--nodetach[run in foreground]' \
    '--debug[enable debug output]' \
    '--dbus-debug[enable D-Bus debugging]' \
    '(- *)--help[show help]' \
    && ret=0

return ret
