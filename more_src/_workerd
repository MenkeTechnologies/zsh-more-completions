#compdef workerd
# Documentation: https://github.com/cloudflare/workerd/blob/main/src/workerd/server/workerd.c%2B%2B
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# workerd: Cloudflare Workers runtime.
# Subcommands and flags verified against workerd.c++ argument parsing.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--verbose[enable verbose logging]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'serve:run the server'
      'compile:create a self-contained binary'
      'test:run unit tests'
      'pyodide-lock:output Pyodide package lock file'
    )
    _describe -t commands 'workerd commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      serve)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--verbose[enable verbose logging]' \
          '(-I --import-path)'{-I+,--import-path=}'[add directory to import search paths]:dir:_files -/' \
          '(-b --binary)'{-b,--binary}'[treat config as encoded binary Cap'\''n Proto message]' \
          '(-s --socket-addr)'{-s+,--socket-addr=}'[override socket binding address (name=addr)]:override:' \
          '(-S --socket-fd)'{-S+,--socket-fd=}'[override socket with file descriptor (name=fd)]:override:' \
          '(-d --directory-path)'{-d+,--directory-path=}'[override directory path (name=path)]:override:' \
          '(-e --external-addr)'{-e+,--external-addr=}'[override external service address (name=addr)]:override:' \
          '(-w --watch)'{-w,--watch}'[watch config files and reload on changes]' \
          '(-i --inspector-addr)'{-i+,--inspector-addr=}'[enable inspector protocol]:addr:' \
          '--control-fd=[file descriptor for control channel]:fd:' \
          '--debug-port=[listen for debug RPC connections]:addr:' \
          '*:config file:_files -g "*.capnp"' && ret=0
        ;;
      compile)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--verbose[enable verbose logging]' \
          '--config-only[output only encoded config without executable wrapper]' \
          '(-I --import-path)'{-I+,--import-path=}'[add directory to import search paths]:dir:_files -/' \
          '(-b --binary)'{-b,--binary}'[treat config as encoded binary Cap'\''n Proto message]' \
          '*:config file:_files -g "*.capnp"' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--verbose[enable verbose logging]' \
          '--no-verbose[disable INFO-level logging]' \
          '--predictable[deterministic test mode]' \
          '--gc-stress[force V8 GC at continuation points]' \
          '--all-autogates[enable all autogate features]' \
          '--compat-date=[override compatibility date]:date:' \
          '(-I --import-path)'{-I+,--import-path=}'[add directory to import search paths]:dir:_files -/' \
          '(-b --binary)'{-b,--binary}'[treat config as encoded binary Cap'\''n Proto message]' \
          '*:filter pattern:' && ret=0
        ;;
      pyodide-lock)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
