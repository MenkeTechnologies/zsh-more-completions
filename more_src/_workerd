#compdef workerd

# Zsh completion for workerd - Cloudflare Workers runtime

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--verbose[enable verbose logging]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'serve:Run the server'
      'compile:Compile a worker bundle'
      'test:Run tests'
    )
    _describe -t commands 'workerd commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      serve)
        _arguments -s -S \
          '--help[show help]' \
          '--verbose[enable verbose logging]' \
          '(-c --config)'{-c,--config}'[path to config file]:file:_files' \
          '(-w --watch)'{-w,--watch}'[watch for config changes and reload]' \
          '--inspector-addr=[inspector address]:address:' \
          '--control-fd=[file descriptor for control channel]:fd:' \
          '--directory-override=[override a directory binding]:name\:path:' \
          '--socket-addr=[override socket address]:name\:address:' \
          '--external-addr=[override external address]:name\:address:' \
          '--binary=[override module with binary]:path:_files' && ret=0
        ;;
      compile)
        _arguments -s -S \
          '--help[show help]' \
          '--verbose[enable verbose logging]' \
          '(-c --config)'{-c,--config}'[path to config file]:file:_files' && ret=0
        ;;
      test)
        _arguments -s -S \
          '--help[show help]' \
          '--verbose[enable verbose logging]' \
          '(-c --config)'{-c,--config}'[path to config file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
