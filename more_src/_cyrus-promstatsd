#compdef cyrus-promstatsd
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/promstatsd.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org promstatsd(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-promstatsd: aggregate Cyrus stats for Prometheus scraping
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-D[run external debugger (debug_command in imapd.conf)]' \
  '-1[update reports once and exit]' \
  '-c[clean up stats directory and exit]' \
  '-d[debug mode (do not background)]' \
  '-f[update frequency seconds]:seconds:' \
  '*-v[increase verbosity (repeatable)]' && ret=0
return ret
