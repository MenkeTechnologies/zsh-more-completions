#compdef pm2-dev
# _pm2-dev — PM2 watch + auto-restart development helper (Unitech/pm2)
# upstream: https://github.com/Unitech/pm2
# Flags from lib/binaries/DevCLI.js (commander).

_pm2-dev() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--raw[raw log output]' \
        '--timestamp[print timestamps]' \
        '--node-args=[extra node args]:args:' \
        '--ignore=[files to ignore while watching (comma)]:list:' \
        '--post-exec=[command to run after change]:cmd:' \
        '--silent-exec[do not output post-exec result]' \
        '--test-mode[debug mode for test suite]' \
        '--interpreter=[interpreter (bash, python, ...)]:interp:_command_names -e' \
        '--env=[select env_NAME variables]:name:' \
        '--auto-exit[exit if all apps stopped or 0 launched]' \
        '*:app.js or ecosystem.json:_files'
}

_pm2-dev "$@"
