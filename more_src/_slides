#compdef slides
# Documentation: https://man.archlinux.org/search?q=slides
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  '--theme[set theme]:theme:(dark light)' \
  '1:slides file:_files -g "*.md"' \
  && ret=0

return ret
