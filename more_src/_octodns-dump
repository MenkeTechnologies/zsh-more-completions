#compdef octodns-dump
# Documentation: https://github.com/octodns/octodns

_arguments -s -S \
  '(- *)--help[show help]' \
  '--config-file=[path to configuration file]:config:_files -g "*.y(a|)ml"' \
  '--output-dir=[directory to write zone files]:dir:_files -/' \
  '--output-provider=[provider class for output format]:provider:' \
  '--lenient[allow non-fatal validation errors]' \
  '--split[split records into individual files]' \
  '--source=[specific source to dump from]:source:' \
  '*:zone:' \
  && return 0
