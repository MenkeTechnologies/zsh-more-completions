#compdef cadvisor

# Zsh completion for cadvisor - container resource usage analyzer

_arguments -s -S \
  '--port[HTTP port to listen on]:port:' \
  '--listen_ip[IP address to listen on]:ip:' \
  '--max_procs[max number of CPUs to use]:cpus:' \
  '--http_auth_file[HTTP basic auth file]:file:_files' \
  '--http_auth_realm[HTTP basic auth realm]:realm:' \
  '--http_digest_file[HTTP digest auth file]:file:_files' \
  '--http_digest_realm[HTTP digest auth realm]:realm:' \
  '--docker_env_metadata_whitelist[docker env vars to add as metadata]:vars:' \
  '--docker_only[only report docker containers]' \
  '--raw_cgroup_prefix_whitelist[cgroup path prefix whitelist]:prefixes:' \
  '--disable_metrics[comma-separated list of metrics to disable]:metrics:' \
  '--enable_metrics[comma-separated list of metrics to enable]:metrics:' \
  '--store_container_labels[store container labels as metadata]' \
  '--whitelisted_container_labels[whitelisted container labels]:labels:' \
  '--event_storage_age_limit[max age for events]:age:' \
  '--event_storage_event_limit[max number of events to store]:limit:' \
  '--storage_driver[storage driver to use]:driver:' \
  '--storage_driver_user[storage driver database username]:user:' \
  '--storage_driver_password[storage driver database password]:password:' \
  '--storage_driver_host[storage driver database host]:host:' \
  '--storage_driver_db[storage driver database name]:db:' \
  '--storage_driver_table[storage driver table name]:table:' \
  '--storage_driver_secure[use secure connection for storage driver]' \
  '--storage_driver_buffer_duration[writes buffer duration]:duration:' \
  '--housekeeping_interval[interval between container housekeepings]:interval:' \
  '--global_housekeeping_interval[interval between global housekeepings]:interval:' \
  '--allow_dynamic_housekeeping[allow dynamic housekeeping]' \
  '--containerd[containerd endpoint]:endpoint:' \
  '--docker[docker endpoint]:endpoint:' \
  '--docker_tls[use TLS to connect to docker]' \
  '--docker_tls_cert[path to TLS certificate]:file:_files' \
  '--docker_tls_key[path to TLS key]:file:_files' \
  '--docker_tls_ca[path to TLS CA certificate]:file:_files' \
  '--log_cadvisor_usage[log cAdvisor resource usage]' \
  '--machine_id_file[comma-separated list of files to check for machine ID]:files:_files' \
  '--boot_id_file[comma-separated list of files to check for boot ID]:files:_files' \
  '--application_metrics_count_limit[max number of application metrics]:limit:' \
  '(-v --verbosity)'{-v,--verbosity}'[log level verbosity]:level:(0 1 2 3 4)' \
  '--alsologtostderr[log to stderr as well]' \
  '--stderrthreshold[logs at or above this threshold go to stderr]:threshold:' \
  '--log_dir[log directory]:dir:_files -/' \
  '--log_backtrace_at[when logging hits file:N, emit a stack trace]:file_line:' \
  '--vmodule[per-module verbosity]:pattern:' \
  '(- *)--version[show version]'
