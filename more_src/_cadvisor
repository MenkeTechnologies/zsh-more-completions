#compdef cadvisor
# Documentation: https://github.com/google/cadvisor/blob/master/docs/runtime_options.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for cAdvisor (container resource usage / Prometheus exporter).

_arguments -s -S \
  '--store_container_labels[convert container labels to Prometheus labels]' \
  '--whitelisted_container_labels=[comma-separated container labels to convert]:labels:' \
  '--env_metadata_whitelist=[comma-separated env var keys to collect]:vars:' \
  '--docker_only[do not report raw cgroup metrics except root]' \
  '--raw_cgroup_prefix_whitelist=[cgroup path prefixes to collect]:prefixes:' \
  '--disable_root_cgroup_stats[disable collecting root cgroup stats]' \
  '--container_hints=[container hints file]:file:_files' \
  '--enable_load_reader[enable cpu load reader]' \
  '--max_procs=[max CPUs to use]:n:' \
  '--log_backtrace_at=[emit stack trace at file:N]:file_line:' \
  '--log_cadvisor_usage[log cAdvisor container usage]' \
  '(- *)--version[print version and exit]' \
  '--profiling[enable web profiling endpoint]' \
  '--log_dir=[directory for log files]:dir:_files -/' \
  '--logtostderr[log to stderr instead of files]' \
  '--alsologtostderr[log to stderr as well as files]' \
  '--stderrthreshold=[threshold for stderr logs]:n:' \
  '--v=[verbosity level for V logs]:n:' \
  '--vmodule=[per-module verbosity]:pattern:' \
  '--docker=[docker endpoint]:endpoint:' \
  '--docker_root=[DEPRECATED docker root]:dir:_files -/' \
  '--docker-tls[use TLS for docker]' \
  '--docker-tls-cert=[docker TLS cert]:file:_files' \
  '--docker-tls-key=[docker TLS key]:file:_files' \
  '--docker-tls-ca=[docker TLS CA]:file:_files' \
  '--podman=[podman endpoint]:endpoint:' \
  '--allow_dynamic_housekeeping[allow dynamic housekeeping interval]' \
  '--global_housekeeping_interval=[interval between global housekeepings]:duration:' \
  '--housekeeping_interval=[interval between container housekeepings]:duration:' \
  '--max_housekeeping_interval=[max housekeeping interval]:duration:' \
  '--http_auth_file=[HTTP basic auth file]:file:_files' \
  '--http_auth_realm=[HTTP basic auth realm]:realm:' \
  '--http_digest_file=[HTTP digest auth file]:file:_files' \
  '--http_digest_realm=[HTTP digest auth realm]:realm:' \
  '--listen_ip=[bind IP]:ip:' \
  '--port=[HTTP port]:port:' \
  '--url_base_prefix=[path prefix for all resource URLs]:prefix:' \
  '--storage_duration=[in-memory storage duration]:duration:' \
  '--boot_id_file=[comma-separated boot-id files]:files:_files' \
  '--machine_id_file=[comma-separated machine-id files]:files:_files' \
  '--update_machine_info_interval=[interval between machine info updates]:duration:' \
  '--application_metrics_count_limit=[max application metrics to store]:n:' \
  '--collector_cert=[collector certificate]:file:_files' \
  '--collector_key=[collector certificate key]:file:_files' \
  '--disable_metrics=[comma-separated metrics to disable]:metrics:' \
  '--enable_metrics=[comma-separated metrics to enable]:metrics:' \
  '--prometheus_endpoint=[Prometheus metrics endpoint]:path:' \
  '--storage_driver=[storage driver]:driver:(bigquery elasticsearch influxdb kafka redis statsd stdout)' \
  '--storage_driver_buffer_duration=[storage driver write buffer]:duration:' \
  '--storage_driver_db=[storage driver database name]:db:' \
  '--storage_driver_host=[storage driver host:port]:host:' \
  '--storage_driver_password=[storage driver password]:password:' \
  '--storage_driver_secure[use secure storage driver connection]' \
  '--storage_driver_table=[storage driver table name]:table:' \
  '--storage_driver_user=[storage driver username]:user:' \
  '--perf_events_config=[perf events JSON config]:file:_files' \
  '--resctrl_interval=[resctrl mon groups update interval]:duration:'
