#compdef litmusctl
# Documentation: https://man.archlinux.org/search?q=litmusctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'config:manage ChaosCenter accounts'
  'connect:connect to chaos infrastructure'
  'disconnect:disconnect chaos infrastructure'
  'create:create resources'
  'delete:delete resources'
  'get:retrieve resources'
  'list:list resources'
  'describe:describe resources'
  'save:save chaos experiment'
  'run:run chaos experiment'
  'update:update resources'
  'version:print version'
  'completion:generate shell completion'
)

_arguments -C \
  '--cacert=[CA certificate]:file:_files' \
  '--config=[config file]:file:_files' \
  '--skipSSL[skip SSL verification]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'litmusctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (config)
        _values 'config action' 'set-account' 'view' 'get-accounts' 'use-account' && ret=0
        ;;
      (connect|disconnect)
        _values 'target' 'chaos-infra' && ret=0
        ;;
      (create)
        _values 'create target' 'chaos-experiment' 'project' 'chaos-environment' && ret=0
        ;;
      (delete)
        _values 'delete target' 'chaos-experiment' 'chaos-environment' && ret=0
        ;;
      (get)
        _values 'get target' 'projects' 'chaos-infra' 'chaos-experiment' 'chaos-experiment-runs' 'chaos-environment' && ret=0
        ;;
      (list)
        _values 'list target' 'chaos-environments' && ret=0
        ;;
      (describe|save|run)
        _values 'target' 'chaos-experiment' && ret=0
        ;;
      (update)
        _values 'update target' 'password' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
