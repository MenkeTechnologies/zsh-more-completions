#compdef ftmgtime
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftmgtime.html
# Merge multiple GTI FITS files using AND (intersection) or OR (union)

local ret=1

_arguments -s -S \
  'ingtis=[input GTI FITS files, @list allowed]:ingtis:_files' \
  'outgti=[output merged GTI FITS file]:outgti:_files' \
  'merge=[merge operation]:merge:(AND OR)' \
  'instarts=[start-time column names in inputs]:instarts:' \
  'instops=[stop-time column names in inputs]:instops:' \
  'outstart=[output start-time column name]:outstart:' \
  'outstop=[output stop-time column name]:outstop:' \
  'mjdref=[reference time for output GTI]:mjdref:' \
  'indates=[reference-date keywords]:indates:' \
  'intimes=[legacy parameter, ignored]:intimes:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
