#compdef gdallocationinfo
# Documentation: https://gdal.org/programs/gdallocationinfo.html
# Reference accessed: 2026-05-16
# Verified: upstream GDAL docs for gdallocationinfo.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# gdallocationinfo: print pixel values at a given location
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--help-general[show general help]' \
  '-xml[output as XML]' \
  '(-valonly)-lifonly[print only location info]' \
  '(-lifonly)-valonly[print only pixel values]' \
  '*-b[band number]:band:' \
  '-r[resampling method]:method:(nearest bilinear cubic cubicspline)' \
  '-overview[overview level]:level:' \
  '-l_srs[input coordinate SRS]:srs:' \
  '-geoloc[use geolocation arrays]' \
  '-wgs84[input coords are WGS84]' \
  '*-oo[open option NAME=VALUE]:option:' \
  '-ignore_extra_input[ignore extra input args]' \
  '-E[echo input coordinates]' \
  '-field_sep[output field separator]:sep:' \
  '*:raster:_files' && ret=0
return ret
