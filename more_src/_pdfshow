#compdef pdfshow
# Documentation: https://man.archlinux.org/search?q=pdfshow
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --count)'{-c,--count}'+[number of pages]:n:' \
  '(-f --first)'{-f,--first}'+[first page]:n:' \
  '(-r --rect)'{-r,--rect}'+[rectangle x,y,w,h]:rect:' \
  '*:pdf file:_files -g "*.pdf"' && ret=0

return ret
