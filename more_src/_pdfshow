#compdef pdfshow
# Documentation: https://www.unix.com/man_page/debian/1/pdfshow/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --count)'{-c,--count}'+[number of pages]:n:' \
  '(-f --first)'{-f,--first}'+[first page]:n:' \
  '(-r --rect)'{-r,--rect}'+[rectangle x,y,w,h]:rect:' \
  '*:pdf file:_files -g "*.pdf"' && ret=0

return ret
