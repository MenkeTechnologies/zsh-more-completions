#compdef simpleterminal

# Zsh completion for st - simple terminal from suckless

_arguments -s -S \
  '-a[disable alternate screens in terminal]' \
  '-c+[set window class]:class:' \
  '-f+[set font]:font:' \
  '-g+[specify window geometry]:geometry:' \
  '-i[fix location to specified -g]' \
  '-n+[set window instance name]:name:' \
  '-o+[write I/O to file (use - for stdout)]:file:_files' \
  '-T+[set window title]:title:' \
  '-t+[same as -T]:title:' \
  '-l+[use a tty line]:line:' \
  '-w+[embed st within the window id]:windowid:' \
  '-v[print version information and exit]' \
  '-e[execute command (rest of command line)]:*:command:_command_names -e'
