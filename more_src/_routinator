#compdef routinator

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'vrps:produce list of VRPs'
  'validate:validate prefix/ASN'
  'server:run as RPKI-to-Router server'
  'update:update local repository'
  'dump:dump validation output'
  'archive-stats:show archive stats'
  'man:show manual'
)

_arguments -C \
  '(-c --config)'{-c,--config}'=[config file]:file:_files -g "*.conf"' \
  '(-r --repository-dir)'{-r,--repository-dir}'=[repository dir]:dir:_files -/' \
  '*--tal=[TAL file]:file:_files' \
  '--extra-tals-dir=[extra TALs dir]:dir:_files -/' \
  '--no-rir-tals[do not use bundled RIR TALs]' \
  '(-x --exceptions)'{-x,--exceptions}'=[SLURM file]:file:_files' \
  '--strict[strict validation]' \
  '--stale=[stale handling]:mode:(reject warn accept)' \
  '--allow-dubious-hosts[allow dubious hosts]' \
  '--rsync-command=[rsync command]:cmd:' \
  '--rsync-timeout=[rsync timeout]:s:' \
  '--disable-rsync[disable rsync]' \
  '--disable-rrdp[disable RRDP]' \
  '--rrdp-fallback=[fallback policy]:mode:(never new stale)' \
  '--rrdp-fallback-time=[fallback time]:s:' \
  '--rrdp-max-delta-count=[max delta count]:n:' \
  '--rrdp-max-delta-list-len=[max delta list length]:n:' \
  '--rrdp-timeout=[RRDP timeout]:s:' \
  '--rrdp-read-timeout=[RRDP read timeout]:s:' \
  '--rrdp-connect-timeout=[RRDP connect timeout]:s:' \
  '--rrdp-tcp-keepalive=[RRDP TCP keepalive]:s:' \
  '--rrdp-local-addr=[local addr]:addr:' \
  '--rrdp-root-cert=[root cert]:file:_files' \
  '--rrdp-proxy=[proxy URL]:url:' \
  '--max-object-size=[max object size]:bytes:' \
  '--max-ca-depth=[max CA depth]:n:' \
  '--enable-bgpsec[enable BGPsec]' \
  '--enable-aspa[enable ASPA]' \
  '--dirty[do not clean cache]' \
  '--validation-threads=[validation threads]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--syslog[log to syslog]' \
  '--syslog-facility=[syslog facility]:facility:(daemon user local0 local1 local2 local3 local4 local5 local6 local7)' \
  '--logfile=[log file]:file:_files' \
  '--log-repository-issues[log repository issues]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'routinator subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (vrps)
        _arguments \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-f --format)'{-f,--format}'=[format]:fmt:(csv csvcompat csvext json jsonext slurm slurm2 openbgpd bird1 bird2 rpsl summary none)' \
          '(-n --noupdate)'{-n,--noupdate}'[do not update]' \
          '(-u --update-after)'{-u,--update-after}'[update after output]' \
          '--complete[require complete validation]' \
          '*'{-a,--select-asn}'=[select ASN]:asn:' \
          '*'{-p,--select-prefix}'=[select prefix]:prefix:' \
          '(-m --more-specifics)'{-m,--more-specifics}'[include more-specifics]' \
          '--no-route-origins[no route origins]' \
          '--no-router-keys[no router keys]' \
          '--no-aspas[no ASPAs]' && ret=0
        ;;
      (validate)
        _arguments \
          '(-a --asn)'{-a,--asn}'=[ASN]:asn:' \
          '(-p --prefix)'{-p,--prefix}'=[prefix]:prefix:' \
          '(-i --input)'{-i,--input}'=[input file]:file:_files' \
          '(-j --json)'{-j,--json}'[JSON output]' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-n --noupdate)'{-n,--noupdate}'[do not update]' \
          '--complete[require complete validation]' && ret=0
        ;;
      (server)
        _arguments \
          '(-d --detach)'{-d,--detach}'[detach (daemonize)]' \
          '*--rtr=[RTR listen addr]:addr:' \
          '*--rtr-tls=[RTR TLS listen addr]:addr:' \
          '*--http=[HTTP listen addr]:addr:' \
          '*--http-tls=[HTTPS listen addr]:addr:' \
          '--listen-systemd[listen on systemd socket]' \
          '--rtr-tcp-keepalive=[RTR keepalive]:s:' \
          '--rtr-client-metrics[per-client metrics]' \
          '--rtr-tls-key=[RTR TLS key]:file:_files' \
          '--rtr-tls-cert=[RTR TLS cert]:file:_files' \
          '--http-tls-key=[HTTP TLS key]:file:_files' \
          '--http-tls-cert=[HTTP TLS cert]:file:_files' \
          '--refresh=[refresh interval]:s:' \
          '--min-refresh=[min refresh]:s:' \
          '--retry=[retry interval]:s:' \
          '--expire=[expire interval]:s:' \
          '--history=[history size]:n:' \
          '--pid-file=[pid file]:file:_files' \
          '--working-dir=[working dir]:dir:_files -/' \
          '--chroot=[chroot dir]:dir:_files -/' \
          '--user=[user]:user:_users' \
          '--group=[group]:group:_groups' && ret=0
        ;;
      (update)
        _arguments '--complete[require complete validation]' && ret=0
        ;;
      (dump|man)
        _arguments '(-o --output)'{-o,--output}'=[output file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
