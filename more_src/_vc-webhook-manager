#compdef vc-webhook-manager volcano-admission
# _vc-webhook-manager — Volcano admission webhook manager (volcano-sh/volcano)
# upstream: https://github.com/volcano-sh/volcano
# Flags from cmd/webhook-manager/app/options/options.go on tip.

_vc-webhook-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--master=[apiserver URL override]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--ca-cert-file=[CA cert file for HTTPS]:file:_files' \
        '--tls-cert-file=[TLS server cert]:file:_files' \
        '--tls-private-key-file=[TLS server key]:file:_files' \
        '--listen-address=[admission server bind address]:host\:port:' \
        '--port=[admission server port]:port:' \
        '--kube-api-qps=[Kubernetes API QPS]:f:' \
        '--kube-api-burst=[Kubernetes API burst]:n:' \
        '--webhook-namespace=[admission webhook namespace]:ns:' \
        '--webhook-service-name=[admission webhook Service name]:name:' \
        '--webhook-url=[admission webhook URL]:url:_urls' \
        '--enabled-admission=[comma-sep enabled admission paths]:list:' \
        '*--scheduler-name=[handled scheduler names]:name:' \
        '--admission-conf=[admission configmap path]:file:_files' \
        '--enable-healthz=[enable health check]:bool:(true false)' \
        '--healthz-address=[health-check bind host\:port]:host\:port:' \
        '--graceful-shutdown-time=[graceful shutdown wait]:dur:' \
        '--enable-queue-allocated-pods-check=[reject queue deletion with allocated pods]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_vc-webhook-manager "$@"
