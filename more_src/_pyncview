#compdef pyncview
# Documentation: https://github.com/BoldingBruggeman/pyncview
# pyncview - cross-platform NetCDF viewer written in Python

local ret=1

_arguments -s \
  '(-v --version)'{-v,--version}'[display the program version number and exit]' \
  '--nc[select which NetCDF module implementation to use]:module' \
  '(-p --profile)'{-p,--profile}'[activate profiling, writing results to the given path]:path:_files' \
  '(-d --debug)'{-d,--debug}'[send exceptions to stderr instead of the error dialog]' \
  '*:file:_files -g "*.(nc|cdf)"' && ret=0

return ret
