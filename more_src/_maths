#compdef maths
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss112.html
# KAPPA: evaluate a mathematical expression involving NDFs

local ret=1

_arguments -s \
  'EXP=[Fortran-77 expression to evaluate per pixel]:expression' \
  'LIKE=[template NDF for bounds and data type]:NDF:_files' \
  'LBOUND=[lower bounds for output NDF]:lbound' \
  'UBOUND=[upper bounds for output NDF]:ubound' \
  'OUT=[output NDF]:NDF:_files' \
  'QUICK=[variance calculation method]:quick:(TRUE FALSE)' \
  'VARIANCE=[calculate output variance]:variance:(TRUE FALSE)' \
  'TITLE=[title for the output NDF]:title' \
  'TYPE=[output data type]:type:(_DOUBLE _REAL)' \
  'UNITS=[propagate UNITS component]:units:(TRUE FALSE)' \
  '*:NDF:_files' && ret=0

return ret
