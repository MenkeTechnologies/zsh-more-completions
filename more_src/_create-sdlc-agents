local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--platform=[target AI platform]:platform:(all claude copilot antigravity)' \
  '--type=[project type]:type:(fullstack backend-api frontend-spa mobile-app cli-library batch-job data-pipeline custom)' \
