#compdef vcluster

local curcontext="$curcontext" state line ret=1

_vcluster_commands() {
  local -a commands=(
    'connect:connect to a virtual cluster'
    'create:create a virtual cluster'
    'delete:delete a virtual cluster'
    'disconnect:disconnect from a virtual cluster'
    'list:list virtual clusters'
    'pause:pause a virtual cluster'
    'resume:resume a virtual cluster'
    'completion:generate shell completions'
    'upgrade:upgrade the vcluster CLI'
    'version:print the version'
    'telemetry:manage telemetry settings'
    'platform:manage the vCluster platform'
  )
  _describe -t commands 'vcluster command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--context=[kube context to use]:context' \
  '--debug[enable debug logging]' \
  '--log-output=[log output format]:format:(plain json)' \
  '(-n --namespace)'{-n,--namespace}'=[Kubernetes namespace]:namespace' \
  '(-s --silent)'{-s,--silent}'[suppress output]' \
  '1: :_vcluster_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      create)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--chart-name=[Helm chart name]:name' \
          '--chart-repo=[Helm chart repo]:url' \
          '--chart-version=[Helm chart version]:version' \
          '--connect[connect to vcluster after creation]' \
          '--distro=[Kubernetes distro]:distro:(k8s k3s k0s eks)' \
          '(-f --extra-values)'{-f,--extra-values}'=[path to extra values file]:file:_files' \
          '--expose[create a load balancer for the vcluster]' \
          '--kubernetes-version=[Kubernetes version]:version' \
          '--set=[set Helm values]:values' \
          '--update-current[update current kubeconfig context]' \
          '1:vcluster name'
        ;;
      delete)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--delete-namespace[delete the namespace]' \
          '--keep-pvc[keep persistent volume claims]' \
          '1:vcluster name'
        ;;
      connect)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--kube-config=[path to write kubeconfig]:file:_files' \
          '--local-port=[local port for port forwarding]:port' \
          '--pod=[pod name to connect to]:pod' \
          '--server=[server address]:address' \
          '--service-account=[service account to use]:account' \
          '--update-current[update current kubeconfig context]' \
          '1:vcluster name'
        ;;
    esac
    ;;
esac

return ret
