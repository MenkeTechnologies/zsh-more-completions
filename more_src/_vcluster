#compdef vcluster
# Documentation: https://www.vcluster.com/docs/vcluster/cli/vcluster_create
# Reference accessed: 2026-05-21
# Verified: upstream loft-sh vcluster CLI docs.

local curcontext="$curcontext" state line ret=1

_vcluster_commands() {
  local -a commands=(
    'connect:connect to a virtual cluster'
    'create:create a virtual cluster'
    'delete:delete a virtual cluster'
    'disconnect:disconnect from a virtual cluster'
    'list:list virtual clusters'
    'pause:pause a virtual cluster'
    'resume:resume a virtual cluster'
    'completion:generate shell completions'
    'upgrade:upgrade the vcluster CLI'
    'version:print the version'
    'telemetry:manage telemetry settings'
    'platform:manage the vCluster platform'
  )
  _describe -t commands 'vcluster command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :_vcluster_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      create)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--add[add to platform]' \
          '--cluster=[target cluster]:cluster' \
          '--connect[connect after creation]' \
          '--driver=[driver]:driver' \
          '--upgrade[upgrade if exists]' \
          '--use[use after creation]' \
          '--chart-name=[Helm chart name]:name' \
          '--chart-repo=[Helm chart repo]:url' \
          '--chart-version=[Helm chart version]:version' \
          '--set=[set Helm values]:values' \
          '--values=[values file]:file:_files' \
          '--create-namespace[create namespace]' \
          '--expose[create a load balancer]' \
          '--kube-config-context-name=[kubeconfig context name]:name' \
          '--print[print manifests instead of applying]' \
          '--annotations=[annotations]:annotations' \
          '--description=[description]:description' \
          '--display-name=[display name]:name' \
          '--labels=[labels]:labels' \
          '--link=[link]:link' \
          '--parameters=[parameters file]:file:_files' \
          '--params=[parameters]:params' \
          '--project=[project]:project' \
          '--recreate[recreate]' \
          '--set-parameters=[set parameters]:params' \
          '--set-params=[set params]:params' \
          '--skip-wait[skip waiting]' \
          '--team=[team]:team' \
          '--template=[template]:template' \
          '--template-version=[template version]:version' \
          '--user=[user]:user' \
          '--background-proxy[background proxy]' \
          '--background-proxy-image=[background proxy image]:image' \
          '--restore=[restore from]:source' \
          '1:vcluster name'
        ;;
      delete|connect|disconnect|pause|resume)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '1:vcluster name'
        ;;
    esac
    ;;
esac

return ret
