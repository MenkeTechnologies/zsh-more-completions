#compdef pmgstatistic pmg-statistic
# _pmg-statistic — Proxmox Server Solutions pmgstatistic Proxmox Mail Gateway statistics database generator (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pmg-api.git

_pmg-statistic() {
    local -a sub=(
        'commit:commit pending statistics'
        'reset:reset statistics database'
        'process:reprocess statistics'
        'rebuild:rebuild statistics db'
        'cleanup:clean statistics'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pmg-statistic subcommand' sub ;;
        args)
            case $words[1] in
                cleanup) _arguments \
                    '--keep-days=+[N]:n:' \
                    '--all-vacate[remove all data]' ;;
                process) _arguments \
                    '--starttime=+[start time]:str:' \
                    '--endtime=+[end time]:str:' ;;
            esac
            ;;
    esac
}

_pmg-statistic "$@"
