#compdef waybackpack
# Documentation: https://github.com/jsvine/waybackpack
# download the entire Wayback Machine archive for a given URL

local ret=1

_arguments -s -S \
  '(-d --dir)'{-d,--dir}'[directory to save the files]:dir:_files -/' \
  '--list[only print the list of snapshots, do not download]' \
  '--raw[fetch file in its original state, without Wayback processing]' \
  '--root[root URL for snapshotted resources]:root' \
  '--from-date[earliest snapshot to download (timestamp)]:from date' \
  '--to-date[latest snapshot to download (timestamp)]:to date' \
  '--user-agent[custom User-Agent header]:user agent' \
  '--follow-redirects[follow HTTP redirects]' \
  '--uniques-only[download only the first version of duplicate files]' \
  '--collapse[archive.org collapse parameter]:collapse' \
  '--ignore-errors[do not crash on non-HTTP errors]' \
  '--max-retries[retry attempts for 4XX/5XX status codes]:retries' \
  '--no-clobber[skip re-downloading existing files]' \
  '--quiet[suppress progress logging]' \
  '--progress[display progress bar (requires tqdm)]' \
  '--delay[sleep seconds between fetches]:delay' \
  '--delay-retry[sleep seconds between retry attempts]:delay' \
  '--version[show version and exit]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:url' && ret=0

return ret
