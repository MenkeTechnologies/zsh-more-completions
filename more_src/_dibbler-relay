#compdef dibbler-relay
# Documentation: https://man.archlinux.org/search?q=dibbler-relay
# Reference accessed: 2026-05-16

# dibbler-relay: Dibbler DHCPv6 relay
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '1:action:(run start stop status install uninstall help)' && ret=0
return ret
