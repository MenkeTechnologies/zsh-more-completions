#compdef carve
# _carve — Michiel Borkent carve unused-var remover for Clojure CLI alias (borkdude team, Clojure); custom argparse
# upstream: https://github.com/borkdude/carve

_carve() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--paths=+[paths edn vec]:str:' \
        '--ignore-paths=+[ignore paths edn vec]:str:' \
        '--report=+[report mode]:r:(progress raw text)' \
        '--out-dir=+[out dir]:dir:_files -/' \
        '--dry-run[dry run]' \
        '--interactive[interactive]' \
        '--silent[silent]' \
        '--api-namespaces=+[api ns edn set]:str:' \
        '--clj-kondo-config=+[clj-kondo config edn]:str:' \
        '--config=+[carve config edn]:str:' \
        '--aggressive[aggressive removal]' \
        '*:args:'
}

_carve "$@"
