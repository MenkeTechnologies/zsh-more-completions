#compdef slackcat
# Documentation: https://man.archlinux.org/search?q=slackcat
# Reference accessed: 2026-05-16

# Zsh completion for slackcat

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-c --channel)'{-c,--channel}'[channel]' \
  '(-t --team)'{-t,--team}'[team]' \
  '(-n --username)'{-n,--username}'[username]' \
  '(-i --icon)'{-i,--icon}'[emoji icon]' \
  '--file[path]:file:_files' && ret=0

return ret
