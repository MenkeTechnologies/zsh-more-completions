#compdef tidb-operator
# _tidb-operator — PingCAP TiDB Operator controller manager (v2)
# upstream: https://github.com/pingcap/tidb-operator
# Flags from cmd/tidb-operator/main.go on tip.

_tidb-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--backup-manager-image=[backup-manager image reference]:image:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--max-concurrent-reconciles=[max concurrent reconciles per controller]:n:' \
        '--watch-delay-duration=[delay before processing watched events]:dur:' \
        '--default-prestop-checker-image=[default prestop checker image]:image:' \
        '--default-resource-syncer-image=[default resource syncer image]:image:' \
        '--allow-empty-old-version=[allow upgrade from empty old version]:bool:(true false)' \
        '--skip-crds-management=[skip checking + applying CRDs]:bool:(true false)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_tidb-operator "$@"
