#compdef sculpin
# Documentation: https://sculpin.io/getstarted/
# Sculpin PHP static site generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--watch[monitor files and regenerate on change]' \
  '--server[launch a local PHP web server]' \
  '--port=[server port]:port:' \
  '--env=[environment mode]:env:(dev prod)' \
  '--url=[base url]:url:' \
  '--quiet[suppress output]' \
  '--verbose[verbose output]' \
  '1:command:(generate serve init install)' \
  '*::arg:_files' && ret=0

return ret
