#compdef gftodvi
# Documentation: gftodvi --help (TeX Live 2026)
# Source: render each character of a GF font as one page of a DVI proof.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-verbose[display progress reports]' \
    '-overflow-label-offset=[override 2.1in offset for overflow labels]:real:' \
    '1:gf font:_files -g "*gf"' \
    && ret=0

return ret
