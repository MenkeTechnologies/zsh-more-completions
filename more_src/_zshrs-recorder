#compdef zshrs-recorder
# Documentation: https://github.com/MenkeTechnologies/zshrs/blob/main/bins/zshrs-recorder.rs
# Reference accessed: 2026-05-21
# Verified: bins/zshrs-recorder.rs argv parser at HEAD on main —
# -f/--file, -o/--output, --shell-id, --quiet, --json, --no-daemon,
# -h/--help, --version. shell_id menu sourced from docs/SHELL_IDS.md.

# zsh completion for zshrs-recorder (the Plugin-Framework-Agnostic
# State-Modification Recorder binary).

local curcontext=$curcontext state line
typeset -A opt_args

# Reserved shell_ids from docs/SHELL_IDS.md — completion menu so users
# don't typo `bsh` instead of `bash` when impersonating.
local -a known_shell_ids
known_shell_ids=(
    zshrs zsh bash dash ksh mksh fish nu elvish pwsh xonsh
    'oil:Oil shell — OSH dialect'
    'ysh:Oil shell — YSH dialect'
    csh tcsh
)

_arguments -S -s : \
    '(- *)'{-h,--help}'[print help and exit]' \
    '(- *)--version[print version and exit]' \
    {-f,--file}'[source PATH instead of ~/.zshrc]:source script:_files -g "*.(zsh|sh|zshrc)"' \
    {-o,--output}'[write captured bundle as JSON to PATH]:output path:_files' \
    '--shell-id[override the bundle shell_id (default zshrs); see docs/SHELL_IDS.md]:shell identifier:(($known_shell_ids))' \
    '--quiet[suppress per-event "Captured KIND ..." stderr firehose]' \
    '--json[emit end-of-run summary as JSON to stdout instead of human text on stderr]' \
    '--no-daemon[skip the end-of-run IPC bundle ship-out (combine with -o to capture without a daemon)]' \
    && return 0
