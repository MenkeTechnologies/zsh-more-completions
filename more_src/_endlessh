#compdef endlessh

# Zsh completion for endlessh (SSH tarpit)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-p+[Port to listen on (default 2222)]:port' \
  '-d+[Message delay in milliseconds (default 10000)]:delay' \
  '-l+[Maximum line length (default 32)]:length' \
  '-m+[Maximum number of clients (default 4096)]:max clients' \
  '-f[Run in foreground (do not daemonize)]' \
  '-v[Print version and exit]' \
  '-4[Bind to IPv4 only]' \
  '-6[Bind to IPv6 only]' \
  '-h[Print help message]' && ret=0

return ret
