#compdef tkn-hub
# _tkn-hub — Tekton Hub CLI (browse/install resources from the Tekton or Artifact Hub catalog)
# upstream: https://github.com/tektoncd/hub
# Subcommands + flags from api/pkg/cli/cmd/root.go on tip (cobra).

_tkn-hub() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--api-server=[Hub API server URL (default: https://api.hub.tekton.dev or https://artifacthub.io)]:url:_urls' \
        '--type=[hub type to pull from]:type:(tekton artifact)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                downgrade:'downgrade an installed resource to an older version'
                get:'get a resource manifest by name, kind and version'
                info:'display info about a resource by its name and kind'
                install:'install a resource by its name, kind and version'
                reinstall:'reinstall a resource by its name and kind'
                search:'search for a resource by name, kind, tags or categories'
                upgrade:'upgrade an installed resource'
                check-upgrade:'check which installed resources have a newer version'
            )
            _describe -t commands 'tkn-hub subcommand' subs
            ;;
    esac
}

_tkn-hub "$@"
