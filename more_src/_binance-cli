#compdef binance-cli binance
# _binance-cli — Binance binance-cli CLI command-line frontend wrapping the Binance global cryptocurrency exchange Spot Margin Futures Options REST WebSocket API managing accounts orders trades market-data klines ticker24hr depth book-tickers wallet deposit withdraw history user-data-stream listen-key-fundingRate funding (Binance team, Go); cobra
# upstream: https://www.binance.com/

_binance-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'order:order operations'
        'trade:trade operations'
        'ticker:ticker operations'
        'depth:order book depth'
        'klines:klines candlesticks'
        'wallet:wallet operations'
        'deposit:deposit operations'
        'withdraw:withdraw operations'
        'transfer:transfer between wallets'
        'futures:futures operations'
        'options:options operations'
        'margin:margin operations'
        'savings:savings products'
        'staking:staking operations'
        'mining:mining operations'
        'sub-account:sub-account management'
        'listen-key:user data stream'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--api-url=+[url]:str:' \
        '--environment=+[e]:e:(spot futures margin options testnet)' \
        '--recv-window=+[ms]:n:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'binance-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list get place cancel cancel-all status)' \
                    '--symbol=+[ticker]:str:' \
                    '--side=+[s]:s:(BUY SELL)' \
                    '--type=+[t]:t:(LIMIT MARKET STOP_LOSS STOP_LOSS_LIMIT TAKE_PROFIT TAKE_PROFIT_LIMIT LIMIT_MAKER)' \
                    '--time-in-force=+[t]:t:(GTC IOC FOK GTX)' \
                    '--quantity=+[N]:str:' \
                    '--price=+[N]:str:' \
                    '--stop-price=+[N]:str:' \
                    '*:order id:' ;;
                account|trade|wallet|deposit|withdraw|transfer|futures|options|margin|savings|staking|mining|sub-account|listen-key) _arguments '1:op:(list get create update delete cancel start stop)' '*:id:' ;;
                ticker|depth|klines) _arguments \
                    '--symbol=+[ticker]:str:' \
                    '--limit=+[N]:n:' \
                    '--interval=+[i]:i:(1m 3m 5m 15m 30m 1h 2h 4h 6h 8h 12h 1d 3d 1w 1M)' ;;
            esac
            ;;
    esac
}

_binance-cli "$@"
