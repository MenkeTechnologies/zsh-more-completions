#compdef crane
# _crane-bin — Google go-containerregistry crane CLI (Google, Go); interact with remote container registries (pull, push, copy, inspect)
# upstream: https://github.com/google/go-containerregistry/tree/main/cmd/crane

_crane-bin() {
    local -a sub=(
        'append:append fs contents to an image'
        'auth:auth helper'
        'blob:retrieve a blob'
        'catalog:list registry repositories'
        'completion:print shell completion'
        'config:get image config'
        'copy:copy an image'
        'cp:alias for copy'
        'delete:delete image/tag'
        'digest:print image digest'
        'export:export image filesystem as tar'
        'flatten:flatten layers'
        'index:manage manifest index'
        'manifest:get image manifest'
        'mutate:modify an image'
        'optimize:reorder image layers for better caching'
        'pull:pull image to tarball'
        'push:push tarball to registry'
        'rebase:rebase image onto a new base'
        'registry:run a local registry'
        'tag:tag an image'
        'validate:validate an image'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--allow-nondistributable-artifacts[allow nondistributable artifacts]' \
        '--insecure[skip TLS verify]' \
        '--platform+[platform]:platform:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'crane subcommand' sub ;;
        args)
            case $words[1] in
                pull|push) _arguments \
                    '--format+[format]:fmt:(tarball legacy oci)' \
                    '--name+[image name]:name:' \
                    '*::ref or tarball:_files' ;;
                copy|cp) _arguments '1:src image:' '2:dest image:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_crane-bin "$@"
