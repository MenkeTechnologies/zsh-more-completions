#compdef ipa-replica-install
# Documentation: https://man.archlinux.org/search?q=ipa-replica-install
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-U --unattended)'{-U,--unattended}'[unattended]' \
  '(-p --password)'{-p,--password}'+[directory manager password]:pw:' \
  '(-P --principal)'{-P,--principal}'+[Kerberos principal]:principal:' \
  '(-w --admin-password)'{-w,--admin-password}'+[admin password]:pw:' \
  '(--mkhomedir)--mkhomedir[create home directories]' \
  '(--no-host-dns)--no-host-dns[do not check DNS]' \
  '(--no-ntp)--no-ntp[do not configure NTP]' \
  '(--no-dns-sshfp)--no-dns-sshfp[do not create SSHFP records]' \
  '(--force-join)--force-join[force join replica]' \
  '(--ip-address)--ip-address=+[IP address]:ip:' \
  '(--domain)--domain=+[domain name]:domain:' \
  '(--realm)--realm=+[Kerberos realm]:realm:' \
  '(--server)--server=+[server to install from]:host:_hosts' \
  '(--setup-ca)--setup-ca[setup CA]' \
  '(--setup-kra)--setup-kra[setup KRA]' \
  '(--setup-dns)--setup-dns[setup DNS]' \
  '(--no-forwarders)--no-forwarders[no DNS forwarders]' \
  '(--forwarder)--forwarder=+[DNS forwarder]:ip:' \
  '(--auto-reverse)--auto-reverse[create reverse zone]' \
  '(--no-reverse)--no-reverse[do not create reverse zone]' \
  '(--ca-cert-file)--ca-cert-file=+[external CA cert]:file:_files' \
  '(--no-pkinit)--no-pkinit[disable pkinit]' \
  '(--no-ui-redirect)--no-ui-redirect[no UI redirect]' \
  '(--no-ssh)--no-ssh[do not configure SSH]' \
  '(--no-sshd)--no-sshd[do not configure SSHD]' \
  '(--ssh-trust-dns)--ssh-trust-dns[trust DNS for SSH]' \
  '*:replica_file:_files -g "*.gpg"' && ret=0

return ret
