#compdef asusctl
# Zsh completion for asusctl - ASUS laptop control (ROG, TUF, etc.)
# https://gitlab.com/asus-linux/asusctl

local -a commands=(
  'led-mode:set keyboard LED mode'
  'led-pow:set keyboard LED power states'
  'profile:set power profile / fan curves'
  'graphics:deprecated, use supergfxctl instead'
  'anime:control AniMe Matrix display'
  'bios:BIOS/UEFI settings'
  '-c:show current settings'
  '-s:show supported features'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[show current settings]' \
  '-s[show supported features]' \
  '1:command:->cmds' \
  '*::args:->args'

case $state in
  cmds)
    _describe -t commands 'asusctl command' commands
    ;;
  args)
    case $words[1] in
      profile)
        _arguments \
          '-l[list available profiles]' \
          '-p[set profile]:profile:(Balanced Performance Quiet)' \
          '-f[fan curve control]'
        ;;
      led-mode)
        _arguments \
          '-l[list available modes]' \
          '-s[set mode]:mode:(Static Breathe Strobe Rainbow Star Rain Highlight Laser Ripple Pulse Comet Flash Multi-Static Multi-Breathe)'
        ;;
      bios)
        _arguments \
          '-p[set POST sound]:state:(on off)' \
          '-o[set panel overdrive]:state:(on off)' \
          '-g[set GPU MUX mode]:mode:(Discrete Optimus)'
        ;;
      anime)
        _arguments \
          '-e[enable AniMe]:state:(on off)' \
          '-b[set brightness]:brightness:' \
          '-l[list built-in animations]' \
          '-s[set built-in animation]:animation:'
        ;;
    esac
    ;;
esac
