#compdef sfgaussmooth
# Documentation: https://ahay.org/RSF/sfgaussmooth.html
# Madagascar: recursive Gaussian smoothing on the fast axis

local ret=1

_arguments -s \
  'der=[compute derivative (y/n)]:bool:(y n)' \
  'rect=[smoothing radius]:float:' \
  'repeat=[repeat filtering several times]:int:' \
  '*:rsf file:_files' && ret=0

return ret
