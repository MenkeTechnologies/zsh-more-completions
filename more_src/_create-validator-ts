#compdef create-validator-ts
# Documentation: https://github.com/azu/create-validator-ts
# Reference accessed: 2026-05-24
# Verified: npm view create-validator-ts bin; GitHub README and module/cli.js at the URL above.

# Zsh completion for create-validator-ts - JSON Schema validator generator from TypeScript

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--watch[start watch mode]' \
  '--cache[cache the generated validator]' \
  '--check[start test mode]' \
  '--cwd=[current working directory]:directory:_directories' \
  '--tsconfigFilePath=[path to tsconfig.json]:file:_files' \
  '--generatorScript=[custom validator code generator script]:file:_files' \
  '--verbose[show progressing logs]' \
  '--sortProps[enable sortProps for ts-json-schema-generator]' \
  '--no-sortProps[disable sortProps]' \
  '--strictTuples[enable strictTuples]' \
  '--no-strictTuples[disable strictTuples]' \
  '--encodeRefs[enable encodeRefs]' \
  '--no-encodeRefs[disable encodeRefs]' \
  '--skipTypeCheck[enable skipTypeCheck]' \
  '--no-skipTypeCheck[disable skipTypeCheck]' \
  '--additionalProperties[enable additionalProperties]' \
  '--no-additionalProperties[disable additionalProperties]' \
  '*:file or glob:_files' && ret=0

return ret
