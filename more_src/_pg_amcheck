#compdef pg_amcheck
# Documentation: https://www.postgresql.org/docs/current/app-pgamcheck.html
# Source: postgres/postgres src/bin/pg_amcheck/pg_amcheck.c — check PostgreSQL B-tree and heap relations (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-\?,--help}'[show help]' \
    {-h+,--host=}'[server host or socket dir]:host:_hosts' \
    {-p+,--port=}'[server port]:port:_default' \
    {-U+,--username=}'[connect as user]:user:_users' \
    {-w,--no-password}'[never prompt for password]' \
    {-W,--password}'[force password prompt]' \
    '--maintenance-db=-[alternate maintenance db]:db:_default' \
    {-a,--all}'[check all databases]' \
    '*'{-d+,--database=}'[check named database]:db:_default' \
    '*'{-D+,--exclude-database=}'[exclude named database]:db:_default' \
    {-e,--echo}'[show commands sent to server]' \
    '*'{-i+,--index=}'[check named index]:index:_default' \
    '*'{-I+,--exclude-index=}'[exclude named index]:index:_default' \
    {-j+,--jobs=}'[parallel jobs]:n:_default' \
    {-P,--progress}'[show progress]' \
    '*'{-r+,--relation=}'[check named relation]:rel:_default' \
    '*'{-R+,--exclude-relation=}'[exclude named relation]:rel:_default' \
    '*'{-s+,--schema=}'[check named schema]:schema:_default' \
    '*'{-S+,--exclude-schema=}'[exclude named schema]:schema:_default' \
    '*'{-t+,--table=}'[check named table]:tbl:_default' \
    '*'{-T+,--exclude-table=}'[exclude named table]:tbl:_default' \
    {-v,--verbose}'[verbose output]' \
    '--no-dependent-indexes[do not check dependent indexes]' \
    '--no-dependent-toast[do not check TOAST tables]' \
    '--exclude-toast-pointers[skip TOAST pointer checks]' \
    '--on-error-stop[stop on first verification error]' \
    '--skip=-[skip categories]:category:(all-frozen all-visible)' \
    '--startblock=-[start block]:n:_default' \
    '--endblock=-[end block]:n:_default' \
    '--rootdescend[check root-to-leaf]' \
    '--no-strict-names[ignore missing relations]' \
    '--checkunique[check uniqueness of index entries]' \
    && ret=0

return ret
