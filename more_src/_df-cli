#compdef df-cli
# _df-cli — GNU coreutils df file system disk space usage CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_df-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[include pseudo, dummy, duplicate fs]' \
        '--all[include pseudo, dummy, duplicate fs]' \
        '-B+[scale block size]:str:' \
        '--block-size=+[scale block size]:str:' \
        '--direct[show stats for file]' \
        '-h[print human readable]' \
        '--human-readable[print human readable]' \
        '-H[print human readable (1000)]' \
        '--si[print human readable (1000)]' \
        '-i[list inode info]' \
        '--inodes[list inode info]' \
        '-k[block size 1024]' \
        '-l[only local file systems]' \
        '--local[only local file systems]' \
        '--no-sync[do not sync before stats]' \
        '--output=+[fields]:str:' \
        '-P[POSIX output]' \
        '--portability[POSIX output]' \
        '--sync[sync before stats]' \
        '--total[grand total line]' \
        '-t+[type]:str:' \
        '--type=+[type]:str:' \
        '-T[print fs type]' \
        '--print-type[print fs type]' \
        '-x+[exclude type]:str:' \
        '--exclude-type=+[exclude type]:str:' \
        '*:files:_files'
}

_df-cli "$@"
