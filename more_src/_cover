#compdef cover
# Documentation: man cover(1)
# Source: pjcj/Devel--Cover bin/cover (master) — generate Devel::Cover code coverage reports (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*--add_uncoverable_point=[add uncoverable point]:spec:_default' \
    '*--annotation=[annotation class]:class:_default' \
    '(--clean_uncoverable_points --noclean_uncoverable_points)--clean_uncoverable_points[clean uncoverable points]' \
    '*--coverage=[coverage criteria]:criteria:(statement branch condition subroutine pod time all default)' \
    '(--delete --nodelete)--delete[delete coverage database]' \
    '*--delete_uncoverable_point=[delete uncoverable point]:spec:_default' \
    '(--dump_db --nodump_db)--dump_db[dump coverage database]' \
    '(--gcov --nogcov)--gcov[run gcov on XS code]' \
    '(--gcov_chdir --nogcov_chdir)--gcov_chdir[chdir before gcov]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '*--ignore=[ignore file pattern]:pattern:_default' \
    '(--ignore_covered_err --noignore_covered_err)--ignore_covered_err[ignore covered errors]' \
    '*--ignore_re=[ignore regex]:regex:_default' \
    '(-i --info)'{-i,--info}'[show info]' \
    '(-j --jobs)'{-j+,--jobs=}'[parallel jobs]:N:_default' \
    '(--launch --nolaunch)--launch[launch report in browser]' \
    '--make=[make command]:cmd:_command_names -e' \
    '--outputdir=[output directory]:dir:_files -/' \
    '--prefer_lib[prefer lib over blib]' \
    '(--relative_only --norelative_only)--relative_only[only show relative paths]' \
    '*--report=[report format]:format:(html html_basic compilation text json codecov sonarqube)' \
    '--report_c0=[c0 threshold]:N:_default' \
    '--report_c1=[c1 threshold]:N:_default' \
    '--report_c2=[c2 threshold]:N:_default' \
    '*--select=[select file pattern]:pattern:_default' \
    '*--select_dir=[select directory]:dir:_files -/' \
    '*--select_re=[select regex]:regex:_default' \
    '(--silent --nosilent)--silent[suppress output]' \
    '(--summary --nosummary)--summary[show summary (default)]' \
    '(--test --notest)--test[run tests]' \
    '*--uncoverable_file=[file with uncoverable points]:file:_files' \
    '(-v --version)'{-v,--version}'[show version]' \
    '--write=[coverage database directory]:dir:_files -/' \
    '*:coverage database:_files' \
    && ret=0

return ret
