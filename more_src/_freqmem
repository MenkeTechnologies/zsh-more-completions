#compdef freqmem
# Documentation: https://gaussian.com/freqmem/
# Estimate memory needed for an analytic Gaussian frequency calculation

local ret=1

_arguments -s -S \
  '-m[memory to allocate (must precede other arguments)]:amount' \
  '1:natoms (number of atoms)' \
  '2:nbasis (number of basis functions)' \
  '3:r or u (RHF closed shell / UHF open shell):(r u)' \
  '4:function (highest angular momentum, e.g. p d f spdf)' && ret=0

return ret
