#compdef berglas
# _berglas — Seth Vargo GoogleCloudPlatform berglas KMS-backed secrets manager (gcp team, Go); cobra
# upstream: https://github.com/GoogleCloudPlatform/berglas

_berglas() {
    local -a sub=(
        'access:access a secret'
        'bootstrap:bootstrap a project'
        'create:create a secret'
        'delete:delete a secret'
        'edit:edit a secret'
        'exec:exec a command with secrets'
        'grant:grant access to a secret'
        'list:list secrets'
        'read:read a secret'
        'replace:replace a secret value'
        'resolve:resolve a reference'
        'revoke:revoke access to a secret'
        'update:update a secret'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--logtostderr[log to stderr]' \
        '-v+[verbosity]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'berglas subcommand' sub ;;
        args)
            case $words[1] in
                bootstrap) _arguments \
                    '--project=+[gcp project]:str:' \
                    '--bucket=+[bucket name]:str:' \
                    '--bucket-location=+[location]:str:' \
                    '--kms-location=+[kms location]:str:' \
                    '--kms-keyring=+[kms keyring]:str:' \
                    '--kms-key=+[kms key]:str:' ;;
                create|update|replace) _arguments \
                    '--key=+[kms key]:str:' \
                    '-k+[kms key]:str:' \
                    '*:bucket/secret:' ;;
                access|read|delete|edit|grant|revoke|resolve) _arguments \
                    '*:bucket/secret:' ;;
                exec) _arguments \
                    '--local[use local file]' \
                    '*:command:_command_names' ;;
                list) _arguments \
                    '*:bucket:' ;;
            esac
            ;;
    esac
}

_berglas "$@"
