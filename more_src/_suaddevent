#compdef suaddevent
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/synthetics_waveforms_testpatterns/suaddevent.c
# Add a linear or hyperbolic moveout event to seismic data

local ret=1

_arguments -s -S \
  'type=[=lmo for linear event; otherwise hyperbolic (nmo)]:type:(nmo lmo)' \
  't0=[zero-offset intercept time in seconds]:t0' \
  'vel=[moveout velocity in m/s]:vel' \
  'amp=[amplitude]:amp' \
  'dt=[sample interval; required if 0 in headers (seconds)]:dt' \
  '*:file:_files' && ret=0

return ret
