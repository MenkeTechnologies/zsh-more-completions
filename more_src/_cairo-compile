#compdef cairo-compile

# Zsh completion for cairo-compile (starkware-libs/cairo, clap 4).
# Command line from crates/bin/cairo-compile/src/main.rs on the main branch.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --single-file)'{-s,--single-file}'[path is a single file, not a project directory]' \
  '(-r --replace-ids)'{-r,--replace-ids}'[human-readable Sierra IDs instead of numeric ones]' \
  '(-i --inlining-strategy)'{-i+,--inlining-strategy=}'[inlining behavior]:strategy:(default avoid)' \
  '1:Cairo project or file:_files' \
  '2::Sierra output file (default stdout):_files' && ret=0

return ret
