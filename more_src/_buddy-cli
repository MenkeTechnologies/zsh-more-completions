#compdef buddy-cli
# _buddy-cli — Buddy.works CI/CD platform CLI alias (buddy team, Go); cobra
# upstream: https://buddy.works/api

_buddy-cli() {
    local -a sub=(
        'login:save token'
        'logout:clear token'
        'whoami:show current user'
        'workspaces:list:list workspaces'
        'workspaces:get:get workspace'
        'projects:list:list projects'
        'projects:create:create project'
        'projects:get:get project'
        'projects:delete:delete project'
        'projects:archive:archive project'
        'pipelines:list:list pipelines'
        'pipelines:create:create pipeline'
        'pipelines:get:get pipeline'
        'pipelines:update:update pipeline'
        'pipelines:delete:delete pipeline'
        'pipelines:run:run pipeline'
        'pipelines:retry:retry pipeline'
        'pipelines:stop:stop pipeline'
        'pipelines:export:export pipeline YAML'
        'pipelines:import:import pipeline YAML'
        'actions:list:list actions'
        'actions:create:create action'
        'actions:get:get action'
        'actions:update:update action'
        'actions:delete:delete action'
        'executions:list:list executions'
        'executions:get:get execution'
        'executions:logs:show execution logs'
        'members:list:list members'
        'members:invite:invite member'
        'members:remove:remove member'
        'permissions:list:list permissions'
        'webhooks:list:list webhooks'
        'webhooks:create:create webhook'
        'webhooks:delete:delete webhook'
        'sshkeys:list:list ssh keys'
        'sshkeys:add:add ssh key'
        'sshkeys:delete:delete ssh key'
        'variables:list:list variables'
        'variables:create:create variable'
        'variables:update:update variable'
        'variables:delete:delete variable'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--token=+[api token]:str:' \
        '--workspace=+[workspace]:str:' \
        '--project=+[project]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'buddy subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish)' ;;
                pipelines:run) _arguments \
                    '1:pipeline id:' \
                    '--ref=+[branch/tag/sha]:str:' \
                    '--comment=+[comment]:str:' \
                    '--variable=+[key=value]:str:' ;;
            esac
            ;;
    esac
}

_buddy-cli "$@"
