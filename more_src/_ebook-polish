#compdef ebook-polish
# Documentation: https://man.archlinux.org/search?q=ebook-polish
# Reference accessed: 2026-05-16

_arguments -s \
  '(-H --add-soft-hyphens)'{-H,--add-soft-hyphens}'[add soft hyphens]' \
  '(-i --compress-images)'{-i,--compress-images}'[compress images]' \
  '(-c --cover)'{-c,--cover}'=[cover image]:file:_files' \
  '(-e --embed-fonts)'{-e,--embed-fonts}'[embed fonts]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-j --jacket)'{-j,--jacket}'[insert jacket]' \
  '(-o --opf)'{-o,--opf}'=[OPF file]:file:_files' \
  '--remove-jacket[remove jacket]' \
  '--remove-soft-hyphens[remove soft hyphens]' \
  '(-u --remove-unused-css)'{-u,--remove-unused-css}'[strip unused CSS]' \
  '(-p --smarten-punctuation)'{-p,--smarten-punctuation}'[smarten punctuation]' \
  '(-f --subset-fonts)'{-f,--subset-fonts}'[subset fonts]' \
  '(-U --upgrade-book)'{-U,--upgrade-book}'[upgrade book]' \
  '--verbose[verbose]' \
  '--version[show version]' \
  '*:ebook:_files'
