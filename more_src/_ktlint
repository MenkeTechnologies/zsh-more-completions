#compdef ktlint

# Zsh completion for ktlint - Kotlin linter and formatter

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-v --version)'{-v,--version}'[show ktlint version]'
  '(-F --format)'{-F,--format}'[fix deviations where possible]'
  '(-a --android)'{-a,--android}'[turn on Android Kotlin Style Guide compatibility]'
  '--code-style[code style]:style:(ktlint_official intellij_idea android_studio)'
  '--color[colorize output]'
  '--color-name[name of color to use]:color:'
  '(-l --log-level)'{-l,--log-level}'[set logging level]:level:(trace debug info warn error none)'
  '--disabled_rules[disabled rules]:rules:'
  '--editorconfig[path to editorconfig]:file:_files -g ".editorconfig"'
  '--experimental[enable experimental rules]'
  '(-y --force-color)'{-y,--force-color}'[force colored output]'
  '--limit[maximum number of errors to show]:n:'
  '--relative[report file paths as relative]'
  '--reporter[report style]:reporter:(plain json sarif html checkstyle baseline)'
  '--ruleset[custom ruleset jar]:file:_files -g "*.jar"'
  '--stdin[read file from stdin]'
  '(-b --baseline)'{-b,--baseline}'[baseline file]:file:_files'
  '--verbose[show rule for each violation]'
  '--patterns-from-stdin[read include patterns from stdin]'
  '--log-type[log type]:type:(human machine)'
  '*:kotlin file:_files -g "*.(kt|kts)"'
)

_arguments -s $arguments
