#compdef concordium-client
# Documentation: https://github.com/Concordium/concordium-client
# concordium-client - Concordium blockchain command-line client

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'transaction:send transactions and query their status'
  'account:inspect and modify accounts on chain'
  'module:deploy and inspect smart contract modules'
  'contract:initialize, interact with, and inspect contract instances'
  'config:inspect and change local configuration'
  'consensus:inspect chain health (branching and finalization)'
  'block:inspect individual blocks'
  'baker:manage your baker'
  'identity:view information about identity providers'
  'raw:commands corresponding directly to the node API'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--grpc-ip=[node gRPC host address]:ip:' \
  '--grpc-port=[node gRPC port]:port:' \
  '--grpc-target=[gRPC target/authority override]:target:' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'concordium-client command' sub && ret=0 ;;
  args)
    case $words[1] in
      account) _arguments '1:account cmd:(show list create update transfer encrypt decrypt-shield)' && ret=0 ;;
      contract) _arguments '1:contract cmd:(show list init update invoke)' && ret=0 ;;
      module) _arguments '1:module cmd:(deploy list show name remove inspect)' && ret=0 ;;
      transaction) _arguments '1:transaction cmd:(submit status deploy-credential)' && ret=0 ;;
    esac
    ;;
esac

return ret
