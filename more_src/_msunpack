# STUB: no canonical CLI named msunpack found in primary sources; closest tool
# is munpack (mpack package, MIME unpacker). Flags below mirror munpack(1).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-f[force overwriting of existing files]' \
  '-q[quiet mode]' \
  '-t[write text MIME parts as files]' \
  '-C+[change directory before processing]:directory:_directories' \
  '*:file:_files' && ret=0

return ret
