#compdef cabal-cache
# _cabal-cache — sync ~/.cabal/store to/from remote archive (haskell-works/cabal-cache)
# upstream: https://github.com/haskell-works/cabal-cache
# Subcommands from app/App/Commands.hs (optparse-applicative).

_cabal-cache() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'plan:print install plan and exit'
                'sync-from-archive:download package store from archive'
                'sync-to-archive:upload package store to archive'
                'version:print version'
                'debug:debug helpers'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_cabal-cache "$@"
