#compdef admesh
# admesh — process and repair STL (stereolithography) files for 3D printing

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '--x-rotate=[rotate about x axis]:angle (degrees):' \
  '--y-rotate=[rotate about y axis]:angle (degrees):' \
  '--z-rotate=[rotate about z axis]:angle (degrees):' \
  '--xy-mirror[mirror about xy plane]' \
  '--yz-mirror[mirror about yz plane]' \
  '--xz-mirror[mirror about xz plane]' \
  '--scale=[scale by factor]:scale factor:' \
  '--scale-xyz=[scale x y z independently]:x,y,z:' \
  '--translate=[translate]:x,y,z:' \
  '--merge=[merge with another STL file]:STL file:_files -g "*.stl"' \
  '--exact[only check exact matching of edges]' \
  '--nearby[find and connect nearby facets]' \
  '--tolerance=[set tolerance for nearby check]:tolerance:' \
  '--iterations=[number of iterations for nearby check]:count:' \
  '--increment=[increment for nearby check]:increment:' \
  '--remove-unconnected[remove facets that have 0 neighbors]' \
  '--fill-holes[add facets to fill holes]' \
  '--normal-directions[fix direction of normals]' \
  '--normal-values[fix normal values]' \
  '--reverse-all[reverse the directions of all facets and normals]' \
  '-a[write output as ASCII STL]:output file:_files -g "*.stl"' \
  '-b[write output as binary STL]:output file:_files -g "*.stl"' \
  '--write-ascii=[write output as ASCII STL]:output file:_files -g "*.stl"' \
  '--write-binary-stl=[write output as binary STL]:output file:_files -g "*.stl"' \
  '--write-off=[write output as OFF format]:output file:_files -g "*.off"' \
  '--write-dxf=[write output as DXF format]:output file:_files -g "*.dxf"' \
  '--write-vrml=[write output as VRML format]:output file:_files -g "*.wrl"' \
  '*:STL file:_files -g "*.stl"'
