#compdef netClass
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: add classification info to a net

local ret=1

_arguments -s -S \
  '-tNewR=[dir of chrN.out.spec files for lineage-specific repeats in target]:dir:_files -/' \
  '-qNewR=[dir of chrN.out.spec files for query]:dir:_files -/' \
  '-noAr[skip ancient repeats lookup]' \
  '-qRepeats=[query repeats table name (replaces default rmsk)]:table' \
  '-tRepeats=[target repeats table name]:table' \
  '-liftQ=[lift query coordinates to chrom-level using this file]:file:_files -g "*.lft"' \
  '-liftT=[lift target coordinates to chrom-level using this file]:file:_files -g "*.lft"' \
  '-qSizes=[query chromosome sizes file instead of database]:file:_files' \
  '1:input net:_files -g "*.net"' \
  '2:target db:' \
  '3:query db:' \
  '4:output net:_files -g "*.net"' && ret=0

return ret
