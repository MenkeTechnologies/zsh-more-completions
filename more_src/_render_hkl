#compdef render_hkl
# Documentation: https://www.desy.de/~twhite/crystfel/manual-render_hkl.html
# Render a slice of reciprocal space as a PDF plot (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-d --down)'{-d+,--down=}'[indices for downward direction]:h,k,l:' \
  '(-r --right)'{-r+,--right=}'[indices for right direction]:h,k,l:' \
  '--zone=[Laue zone number]:z:' \
  '(-o --output)'{-o+,--output=}'[write PDF output to file]:file:_files' \
  '(-p --pdb)'{-p+,--pdb=}'[unit cell file]:file:_files' \
  '--boost=[squash colour scale by factor]:n:' \
  '(-y --symmetry)'{-y+,--symmetry=}'[symmetry of reflection list]:pointgroup:' \
  '(-c --colscale)'{-c+,--colscale=}'[colour scale]:scale:(mono invmono colour)' \
  '(-w --weighting)'{-w+,--weighting=}'[weight for lattice points]:weight:(I sqrtI count rawcts)' \
  '--scale-top=[force colour scale top value]:n:' \
  '--colour-key[write colour scale to key.pdf]' \
  '*--res-ring=[draw resolution ring in Angstroms]:res:' \
  '--highres=[render spots up to resolution]:res:' \
  '--no-axes[do not draw reciprocal space axes]' \
  '*:reflection list:_files' && ret=0

return ret
