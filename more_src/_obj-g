#compdef obj-g
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=obj-g&sektion=1
# BRL-CAD Wavefront OBJ to geometry database converter

local ret=1

_arguments -s \
  '-c[continue on nmg-bomb (fallback to native-bot)]' \
  '-d[output debug information to stderr]' \
  '-f[fuse vertices within distance tolerance]' \
  '-g[face grouping method]:method:(g o m t n)' \
  '-H[plate thickness in mm for open surfaces]:thickness' \
  '-i[ignore obj normals in native-bot mode]' \
  '-m[conversion mode]:mode:(b n v)' \
  '-o[open bot type]:type:(s p n)' \
  '-p[plot open edges to .plot3 file]' \
  '-r[bot orientation]:orientation:(1 2 3)' \
  '-t[distance tolerance (mm) for vertex equivalence]:tolerance' \
  '-u[units of input obj (m cm mm ft in or factor)]:units' \
  '*-v[verbose output (repeatable)]' \
  '-x[raytracer debug flag bits]:flags' \
  '-X[NMG debug flag bits]:flags' \
  '1:input.obj:_files' \
  '2:output:_files -g "*.g"' && ret=0

return ret
