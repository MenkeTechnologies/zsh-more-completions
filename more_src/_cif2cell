#compdef cif2cell
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/cif2cell.1.html
# cif2cell - generate electronic-structure input geometries from CIF files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-f --file)'{-f,--file=}'[input CIF file]:cif:_files -g "*.cif"' \
  '(-p --program)'{-p,--program=}'[target electronic-structure program]:program:(abinit ase atat castep cp2k cpmd crystal09 elk emto exciting fhi-aims fleur lammps mopac pwscf quantum-espresso rspt siesta sprkkr vasp xyz cif spacegroup)' \
  '(-o --outputfile)'{-o,--outputfile=}'[output file name]:file:_files' \
  '(-b --block)'{-b,--block=}'[CIF data block to use]:block:' \
  '(-a --append)'{-a,--append}'[append to output file]' \
  '--no-reduce[do not reduce to the primitive cell]' \
  '--force[force generation even on errors]' \
  '--force-alloy[force alloy treatment]' \
  '--vca[use virtual crystal approximation]' \
  '--cartesian[output in cartesian coordinates]' \
  '--coordinate-tolerance=[tolerance for equal coordinates]:tol:' \
  '--k-resolution=[k-point grid resolution]:res:' \
  '--transform-cell=[transformation matrix for the cell]:matrix:' \
  '--supercell=[create a supercell]:dims:' \
  '--supercell-vacuum=[add vacuum to supercell]:vac:' \
  '--supercell-sort=[sort atoms in supercell]:key:' \
  '--print-digits=[number of digits to print]:n:' \
  '--print-cartesian[print cartesian coordinates]' \
  '--print-symmetry-operations[print symmetry operations]' \
  '--print-charge-state[print charge/oxidation states]' \
  '--export-cif-labels[export original CIF atom labels]' \
  '*:cif:_files -g "*.cif"' && ret=0

return ret
