#compdef cypress

# Zsh completion for Cypress testing framework

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'open:Open Cypress in interactive mode'
      'run:Run Cypress tests'
      'install:Install Cypress binary'
      'verify:Verify Cypress is installed correctly'
      'cache:Manage the Cypress binary cache'
      'info:Print system and Cypress information'
      'version:Print Cypress version'
    )
    _describe -t commands 'cypress command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      open)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--browser=[browser to use]:browser' \
          '--component[open component testing]' \
          '--config=[set configuration values]:config' \
          '--config-file=[config file to use]:config file:_files' \
          '--e2e[open end-to-end testing]' \
          '--env=[set environment variables]:env vars' \
          '--global[open in global mode]' \
          '--port=[override default port]:port' \
          '--project=[path to project]:project path:_directories' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--browser=[browser to use]:browser' \
          '--ci-build-id=[unique build ID for CI]:build id' \
          '--component[run component tests]' \
          '--config=[set configuration values]:config' \
          '--config-file=[config file to use]:config file:_files' \
          '--e2e[run end-to-end tests]' \
          '--env=[set environment variables]:env vars' \
          '--group=[group tests under a label]:group name' \
          '--headed[run browser headed]' \
          '--headless[run browser headlessly]' \
          '--key=[Cypress Dashboard record key]:key' \
          '--no-exit[keep runner open after tests complete]' \
          '--parallel[run tests in parallel across machines]' \
          '--port=[override default port]:port' \
          '--project=[path to project]:project path:_directories' \
          '--quiet[suppress all output except test results]' \
          '--record[record test results to Dashboard]' \
          '--reporter=[mocha reporter to use]:reporter' \
          '--reporter-options=[reporter options]:options' \
          '--spec=[spec files to run]:spec:_files' \
          '--tag=[identify a run with tags]:tags' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--force[force reinstall]' && ret=0
        ;;
      verify)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      cache)
        if (( CURRENT == 2 )); then
          local -a cache_cmds=(
            'list:List cached Cypress versions'
            'clear:Clear the Cypress cache'
            'path:Print the Cypress cache path'
          )
          _describe -t commands 'cache command' cache_cmds && ret=0
        fi
        ;;
      info)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
