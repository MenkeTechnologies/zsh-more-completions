#compdef run_pypeit
# Documentation: https://pypeit.readthedocs.io/en/release/running.html
# PypeIt core end-to-end data reduction executable

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '(-r --redux_path)'{-r,--redux_path}'[path to reduction directory]:dir:_files -/' \
  '(-m --do_not_reuse_calibs)'{-m,--do_not_reuse_calibs}'[do not load previously generated calibrations]' \
  '(-s --show)'{-s,--show}'[show reduction steps via plots and ginga]' \
  '(-o --overwrite)'{-o,--overwrite}'[overwrite any existing files/directories]' \
  '(-c --calib_only)'{-c,--calib_only}'[only run on calibrations]' \
  '*:pypeit file:_files -g "*.pypeit"' && ret=0

return ret
