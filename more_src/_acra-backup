#compdef acra-backup
# _acra-backup — Acra keystore backup/restore utility (cossacklabs/acra) [deprecated; use acra-keys]
# upstream: https://github.com/cossacklabs/acra
# Flags from cmd/acra-backup/acra-backup.go (flag).

_acra-backup() {
    _arguments \
        '(- *)-h[show help]' \
        '-logging_format=[log format]:fmt:(plaintext json CEF)' \
        '-keys_private_dir=[folder with private keys]:dir:_files -/' \
        '-keys_public_dir=[folder with public keys]:dir:_files -/' \
        '-action=[backup action]:action:(export import)' \
        '-file=[file to import from / export to]:file:_files'
}

_acra-backup "$@"
