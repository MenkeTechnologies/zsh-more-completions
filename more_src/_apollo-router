#compdef apollo-router
# _apollo-router — Apollo GraphOS Router GraphQL federation router CLI alias (Apollo GraphQL, Rust); clap-rs
# upstream: https://github.com/apollographql/router

_apollo-router() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[router config file]:file:_files -g "router.yaml *.yaml *.yml"' \
        '-c+[router config file]:file:_files -g "router.yaml *.yaml *.yml"' \
        '--supergraph=+[supergraph schema]:file:_files -g "*.graphql *.graphqls"' \
        '-s+[supergraph schema]:file:_files -g "*.graphql *.graphqls"' \
        '--log=+[log level]:level:(off error warn info debug trace)' \
        '--log-format=+[log format]:fmt:(pretty json json-pretty stderr)' \
        '--listen=+[listen address]:str:' \
        '--graph-ref=+[graphos graph ref]:str:' \
        '--anonymous-telemetry-disabled[disable anonymous telemetry]' \
        '--dev[run with development settings]' \
        '--apollo-key=+[apollo key]:str:' \
        '--apollo-graph-ref=+[apollo graph ref]:str:' \
        '--apollo-router-secret-source=+[secret source]:s:(env file)' \
        '--launch-id=+[launch id]:str:' \
        '--hot-reload[hot reload]' \
        '--no-hot-reload[no hot reload]' \
        '--schema=+[schema file]:file:_files' \
        '--license=+[license file]:file:_files' \
        '--apollo-uplink-endpoints=+[uplink endpoints]:list:_urls' \
        '--apollo-uplink-poll-interval=+[uplink poll interval]:dur:' \
        '--apollo-uplink-timeout=+[uplink timeout]:dur:' \
        '--apollo-persisted-queries-manifest=+[persisted queries manifest]:file:_files' \
        '*:arg:'
}

_apollo-router "$@"
