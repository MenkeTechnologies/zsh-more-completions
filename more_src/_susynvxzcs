#compdef susynvxzcs
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/synthetics_waveforms_testpatterns/susynvxzcs.c
# Synthetic seismograms of common shot in V(X,Z) media via Kirchhoff modeling

local ret=1

_arguments -s -S \
  'nx=[number of x samples (2nd dimension) in velocity]:nx' \
  'nz=[number of z samples (1st dimension) in velocity]:nz' \
  'nt=[number of time samples]:nt' \
  'dt=[time sampling interval (sec)]:dt' \
  'ft=[first time (sec)]:ft' \
  'fpeak=[peak frequency of symmetric Ricker wavelet (Hz)]:fpeak' \
  'nxg=[number of receivers of input traces]:nxg' \
  'dxg=[receiver sampling interval (m)]:dxg' \
  'fxg=[first receiver (m)]:fxg' \
  'nxd=[skipped number of receivers]:nxd' \
  'nxs=[number of offsets]:nxs' \
  'dxs=[shot sampling interval (m)]:dxs' \
  'fxs=[first shot (m)]:fxs' \
  'dx=[x sampling interval (m)]:dx' \
  'fx=[first x sample (m)]:fx' \
  'dz=[z sampling interval (m)]:dz' \
  'nxb=[band width centered at midpoint]:nxb' \
  'nxc=[horizontal range in which velocity is changed]:nxc' \
  'nzc=[vertical range in which velocity is changed]:nzc' \
  'pert=[=1 calculate time correction from v_p]:pert:(0 1)' \
  'vpfile=[file containing slowness perturbation array]:vpfile:_files' \
  'ref=[reflector(s): amplitude:x1,z1;x2,z2;...]:ref' \
  'smooth=[=1 for smooth (piecewise cubic spline) reflectors]:smooth:(0 1)' \
  'ls=[=1 for line source; =0 for point source]:ls:(0 1)' \
  'tmin=[minimum time of interest (sec)]:tmin' \
  'ndpfz=[number of diffractors per Fresnel zone]:ndpfz' \
  'cable=[=1 roll receiver spread with shot; =0 static spread]:cable:(0 1)' \
  'verbose=[=1 to print some useful information]:verbose:(0 1)' \
  '*:vfile:_files' && ret=0

return ret
