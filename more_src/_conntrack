#compdef conntrack
# Documentation: https://manpages.debian.org/conntrack.8
# Source: netfilter/conntrack-tools — Linux kernel connection-tracking table CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-L,--dump}'[list connection tracking or expectation table]' \
    '(- *)'{-G,--get}'[search and show a matching entry]' \
    '(- *)'{-D,--delete}'[delete an entry from the given table]' \
    '(- *)'{-I,--create}'[create a new entry (fails if it exists)]' \
    '(- *)'{-A,--add}'[add a new entry to the given table]' \
    '(- *)'{-U,--update}'[update an entry]' \
    '(- *)'{-E,--event}'[display a real-time event log]' \
    '(- *)'{-F,--flush}'[flush the whole given table]' \
    '(- *)'{-C,--count}'[show the table counter]' \
    '(- *)'{-S,--stats}'[show in-kernel conntrack statistics]' \
    '(- *)'{-R,--load-file}'[load entries from a file]:file:_files' \
    '(-z --zero)'{-z,--zero}'[atomically zero counters after reading]' \
    '(-o --output)'{-o+,--output=}'[output format]:fmt:(xml extended timestamp id ktimestamp labels userspace)' \
    '(-e --event-mask)'{-e+,--event-mask=}'[bitmask of events to generate (NEW UPDATES DESTROY ALL)]:mask:' \
    '(-b --buffer-size)'{-b+,--buffer-size=}'[Netlink socket buffer size in bytes]:bytes:' \
    '(-s --src --orig-src)'{-s+,--src=,--orig-src=}'[source address in original direction]:src:' \
    '(-d --dst --orig-dst)'{-d+,--dst=,--orig-dst=}'[destination address in original direction]:dst:' \
    '(-r --reply-src)'{-r+,--reply-src=}'[source address in reply direction]:src:' \
    '(-q --reply-dst)'{-q+,--reply-dst=}'[destination address in reply direction]:dst:' \
    '(-p --proto)'{-p+,--proto=}'[layer-4 protocol]:proto:(tcp udp sctp dccp gre icmp icmpv6 udplite)' \
    '(-f --family)'{-f+,--family=}'[layer-3 protocol]:family:(ipv4 ipv6)' \
    '(-t --timeout)'{-t+,--timeout=}'[entry timeout]:seconds:' \
    '(-m --mark)'{-m+,--mark=}'[conntrack mark (value or value/mask)]:mark:' \
    '(-l --label)'{-l+,--label=}'[conntrack label]:label:' \
    '--label-add=[add label to selected conntracks]:label:' \
    '--label-del=[delete label from selected conntracks]:label:' \
    '(-c --secmark)'{-c+,--secmark=}'[conntrack SELinux security mark]:secmark:' \
    '(-u --status)'{-u+,--status=}'[conntrack status]:status:(ASSURED SEEN_REPLY UNSET FIXED_TIMEOUT EXPECTED)' \
    '(-n --src-nat)'{-n+,--src-nat=}'[filter source NAT connections]:ip:' \
    '(-g --dst-nat)'{-g+,--dst-nat=}'[filter destination NAT connections]:ip:' \
    '(-j --any-nat)'{-j+,--any-nat=}'[filter any NAT connections]:ip:' \
    '(-w --zone)'{-w+,--zone=}'[filter by conntrack zone]:zone:' \
    '--orig-zone=[filter by zone in original direction]:zone:' \
    '--reply-zone=[filter by zone in reply direction]:zone:' \
    '--tuple-src=[tuple source address of an expectation]:src:' \
    '--tuple-dst=[tuple destination address of an expectation]:dst:' \
    '--mask-src=[source address mask]:mask:' \
    '--mask-dst=[destination address mask]:mask:' \
    '--sport=[source port (original direction)]:port:' \
    '--orig-port-src=[source port (original direction, alias)]:port:' \
    '--dport=[destination port (original direction)]:port:' \
    '--orig-port-dst=[destination port (original direction, alias)]:port:' \
    '--reply-port-src=[source port (reply direction)]:port:' \
    '--reply-port-dst=[destination port (reply direction)]:port:' \
    '--state=[TCP/SCTP/DCCP state]:state:' \
    '--icmp-type=[ICMP type]:type:' \
    '--icmp-code=[ICMP code]:code:' \
    '--icmp-id=[ICMP id]:id:' \
    '--srckey=[source key (original direction)]:key:' \
    '--orig-key-src=[source key (original direction, alias)]:key:' \
    '--dstkey=[destination key (original direction)]:key:' \
    '--orig-key-dst=[destination key (original direction, alias)]:key:' \
    '--reply-key-src=[source key (reply direction)]:key:' \
    '--reply-key-dst=[destination key (reply direction)]:key:' \
    '--orig-vtag=[verification tag (32-bit) in original direction]:tag:' \
    '--reply-vtag=[verification tag (32-bit) in reply direction]:tag:' \
    '--role=[role tracked by original tuple]:role:' \
    && ret=0

return ret
