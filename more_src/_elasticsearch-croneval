#compdef elasticsearch-croneval
# Documentation: https://www.elastic.co/guide/en/elasticsearch/reference/current/elasticsearch-croneval.html
# Validate and evaluate a cron expression, showing its next scheduled times

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[return all of the command parameters]' \
  '(-c --count)'{-c,--count}'=[number of future times this expression will be triggered]:count:' \
  '(-d --detail)'{-d,--detail}'[show detail for invalid cron expression]' \
  '(-s --silent -v --verbose)'{-s,--silent}'[show minimal output]' \
  '(-s --silent -v --verbose)'{-v,--verbose}'[show verbose output]' \
  '*:cron expression:' && ret=0

return ret
