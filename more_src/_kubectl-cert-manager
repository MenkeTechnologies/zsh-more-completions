#compdef kubectl-cert-manager
# kubectl-cert-manager (krew plugin): manage cert-manager resources
# https://github.com/cert-manager/cmctl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'approve:approve a CertificateRequest'
      'check:check cert-manager components'
      'convert:convert cert-manager config files'
      'create:create cert-manager resources'
      'deny:deny a CertificateRequest'
      'inspect:inspect cert-manager resources'
      'renew:renew certificates'
      'status:get the status of cert-manager'
      'upgrade:upgrade cert-manager'
      'version:print version'
    )
    _describe -t commands 'cert-manager command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
      '(-A --all-namespaces)'{-A,--all-namespaces}'[query all namespaces]' \
      '--context=[kubernetes context]:context' \
      '--kubeconfig=[path to kubeconfig]:file:_files' \
      '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml)' \
      '*:args' && ret=0
    ;;
esac

return ret
