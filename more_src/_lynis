#compdef lynis
# _lynis — Linux/macOS security auditing tool (CISOfy/lynis)
# upstream: https://github.com/CISOfy/lynis
# Flags from include/parameters (case).

_lynis() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--auditor=[name of the auditor performing the scan]:name:' \
        '--bindirs=[colon-separated list of additional bin dirs]:dirs:' \
        '--cron-job[run as cron job (less output)]' \
        '--debug[debug output]' \
        '--developer[developer mode]' \
        '--devops[devops mode]' \
        '--forensics[forensics mode]' \
        '--logfile=[output log file]:file:_files' \
        '--no-colors[no colored output]' \
        '--no-log[disable log file]' \
        '--no-plugins[skip plugins]' \
        '--pen-test[enable pen-test mode]' \
        '--profile=[profile file to use]:file:_files' \
        '--plugindir=[plugin directory]:dir:_files -/' \
        '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
        '(-Q --quick)'{-Q,--quick}'[quick mode]' \
        '--report-file=[report file path]:file:_files' \
        '--reverse-colors[invert color scheme for light backgrounds]' \
        '--rootdir=[root directory]:dir:_files -/' \
        '--tests=[comma-separated test ids to run]:list:' \
        '--tests-from-category=[run tests from category]:category:' \
        '--tests-from-group=[run tests from group]:group:' \
        '--upload[upload data to central server]' \
        '--usecwd[use current working directory for includes]' \
        '--verbose[verbose output]' \
        '--view-manpage[show man page]' \
        '--wait[wait for keypress between sections]' \
        '--warnings-only[show warnings only]' \
        '--slow-warning[warn about slow performance]' \
        '--tests-category[show test categories]' \
        '(-c --check-all)'{-c,--check-all}'[check all]' \
        '--check-update[check for updates]' \
        '--dump-options[dump options used]' \
        '--license-key=[license key for Lynis Enterprise]:key:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                audit:'audit a target'
                show:'show information'
                update:'update Lynis'
                configure:'configure Lynis'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                audit)
                    _arguments \
                        '1:target:(system dockerfile)' \
                        '*:file or option:_files' ;;
                show)
                    _arguments '1:topic:(commands details environment groups help language license man options plugins profiles release report settings tests version)' ;;
                update)
                    _arguments '1:action:(info release check)' ;;
            esac
            ;;
    esac
}

_lynis "$@"
