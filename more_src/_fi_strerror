#compdef fi_strerror
# Documentation: https://man.archlinux.org/search?q=fi_strerror
# Reference accessed: 2026-05-16

# fi_strerror: print libfabric error code string
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:error code:' && ret=0
return ret
