#compdef orchestrate
# Documentation: https://github.com/IBM/ibm-watsonx-orchestrate
# Reference accessed: 2026-05-23
# Verified: orchestrate --help (IBM watsonx Orchestrate ADK Typer CLI).

# Zsh completion for orchestrate - IBM watsonx Orchestrate agent development CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show ADK and Developer Edition version]' \
  '--debug[enable debug mode]' \
  '--install-completion[install shell completion]' \
  '--show-completion[show shell completion script]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'orchestrate command' \
      'env[manage active Orchestrate environment]' \
      'agents[manage agents in active env]' \
      'tools[manage tools in active env]' \
      'toolkits[manage toolkits in active env]' \
      'knowledge-bases[manage knowledge bases]' \
      'connections[manage connections]' \
      'voice-configs[configure voice providers]' \
      'server[local Developer Edition server]' \
      'chat[launch chat UI and CLI]' \
      'models[list available LLMs]' \
      'channels[configure agent channels]' \
      'phone[manage phone configurations]' \
      'evaluations[evaluate agent performance]' \
      'settings[configure active env settings]' \
      'partners[partner agent artifact packaging]' \
      'observability[search and export trace data]' && ret=0
    ;;
esac

return ret
