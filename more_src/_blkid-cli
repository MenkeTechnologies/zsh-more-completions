#compdef blkid-cli
# _blkid-cli — util-linux blkid block device info CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_blkid-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[cache file]:file:_files' \
        '--cache-file=+[cache file]:file:_files' \
        '-d[do not encode utf8]' \
        '--no-encoding[do not encode utf8]' \
        '-g[garbage collect cache]' \
        '--garbage-collect[garbage collect cache]' \
        '-i[show I/O limits]' \
        '--info[show I/O limits]' \
        '-k[list known fs]' \
        '--list-filesystems[list known fs]' \
        '-l[lookup only]' \
        '--lookup[lookup only]' \
        '-L+[label]:str:' \
        '--label=+[label]:str:' \
        '-n+[fstype filter]:str:' \
        '--match-types=+[fstype filter]:str:' \
        '-D[no part info]' \
        '--no-part-details[no part info]' \
        '-o+[output format]:f:(value device export full)' \
        '--output=+[output format]:f:(value device export full)' \
        '-O+[offset]:n:' \
        '--offset=+[offset]:n:' \
        '-p[probe (no cache)]' \
        '--probe[probe (no cache)]' \
        '-S+[size limit]:n:' \
        '--size=+[size limit]:n:' \
        '-s+[tag types]:str:' \
        '--match-tag=+[tag types]:str:' \
        '-t+[type[=value]]:str:' \
        '--match-token=+[type[=value]]:str:' \
        '-U+[uuid]:str:' \
        '--uuid=+[uuid]:str:' \
        '-u+[usages]:u:(filesystem raid crypto other)' \
        '--usages=+[usages]:u:(filesystem raid crypto other)' \
        '*:devices:_files -g "/dev/{sd,hd,nvme,mapper,loop}*"'
}

_blkid-cli "$@"
