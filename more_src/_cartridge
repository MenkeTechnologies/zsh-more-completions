#compdef cartridge
# Documentation: https://man.archlinux.org/search?q=cartridge
# Reference accessed: 2026-05-16

# tarantool/cartridge-cli (go); Homebrew: Formula/c/cartridge-cli.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'cartridge command' compadd -- create build pack start stop status gen admin
  ;;
rest)
  case $line[1] in
    create)
      _arguments -s '--name=[project name]:name:' '*::path:_files -/' && ret=0
      ;;
    gen)
      _arguments '2: :((completion))' '3: :((bash zsh))' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
