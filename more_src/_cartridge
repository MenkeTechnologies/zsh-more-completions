#compdef cartridge
# Documentation: https://github.com/tarantool/cartridge-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above. Archived; deprecated in favor of the `tt` CLI.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'cartridge command' compadd -- \
    create build pack start stop status enter connect log clean repair \
    replicasets failover admin gen
  ;;
rest)
  case $line[1] in
    create)
      _arguments -s '--name=[project name]:name:' '*::path:_files -/' && ret=0
      ;;
    pack)
      _arguments \
        '1:format:(tgz rpm deb docker)' \
        '--name=[application name]:name:' \
        '--version=[application version]:version:' \
        '*: :_files' && ret=0
      ;;
    gen)
      _arguments '2: :((completion))' '3: :((bash zsh fish))' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
