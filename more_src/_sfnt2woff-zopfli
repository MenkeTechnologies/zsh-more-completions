#compdef sfnt2woff-zopfli woff2sfnt-zopfli
# Documentation: https://man.archlinux.org/search?q=sfnt2woff-zopfli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '-v+[font version (maj.min)]:version:' \
  '-m+[include metadata from XML]:file:_files -g "*.xml"' \
  '-n+[zopfli iterations]:n:' \
  '-p+[include private data block]:file:_files' \
  '*:font_file:_files -g "*.{ttf,otf,woff,sfnt}"' && ret=0

return ret
