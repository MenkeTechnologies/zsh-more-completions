#compdef 7za 7zr
# Documentation: 7za usage (p7zip 17.05)
# Source: 7-Zip standalone CLI (a/b/d/e/h/i/l/rn/t/u/x verbs).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'a:add files to archive'
    'b:benchmark'
    'd:delete files from archive'
    'e:extract (without directory names)'
    'h:hash files'
    'i:show information about supported formats'
    'l:list contents of archive'
    'rn:rename files in archive'
    't:test integrity'
    'u:update files to archive'
    'x:eXtract with full paths'
)

_arguments -C -s \
    '-ao+[overwrite mode]:mode:(a s t u)' \
    '-an[disable archive-name field]' \
    '-bb+[output log level]:level:(0 1 2 3)' \
    '-bd[disable progress indicator]' \
    '-bt[show execution time]' \
    '-m+[compression method (e.g. mt8, x9)]:params:' \
    '-o+[output directory]:dir:_files -/' \
    '-p+[password]:password:' \
    '-r[recurse subdirectories]' \
    '-r-[do not recurse]' \
    '-sa+[archive-name mode]:mode:(a e s)' \
    '-scc+[console charset]:charset:(UTF-8 WIN DOS)' \
    '-scs+[list-file charset]:charset:(UTF-8 UTF-16LE UTF-16BE WIN DOS)' \
    '-scrc+[hash function]:hash:(CRC32 CRC64 SHA1 SHA256)' \
    '-sdel[delete files after compression]' \
    '-seml[send archive by email]' \
    '-sfx-[create SFX archive]::name:_files' \
    '-si-[read data from stdin]::name:' \
    '-slp[Large Pages mode]' \
    '-slt[technical info for l (List)]' \
    '-snh[store hard links as links]' \
    '-snl[store symbolic links as links]' \
    '-sni[store NT security information]' \
    '-so[write data to stdout]' \
    '-spd[disable wildcard matching]' \
    '-spe[eliminate duplication of root]' \
    '-spf[use full paths]' \
    '-ssc-[case-sensitive mode off]' \
    '-stl[set Latest archive timestamp]' \
    '-stm+[stream mode for solid archives]:mask:' \
    '-stx+[exclude archive type]:type:' \
    '-t+[archive type]:type:(7z xz split zip gzip bzip2 tar wim iso udf ar arj cab chm cpio deb dmg elf fat flv hfs lzh lzma lzma86 macho mbr mslz mub nsis ntfs ppmd qcow rar rpm squashfs swf swfc te uefif vdi vhd vmdk wim xar xpe z)' \
    '-u+[update options]:options:' \
    '-v+[create volume archive (size)]:size:' \
    '-w+[work directory]:dir:_files -/' \
    '-x+[exclude filenames pattern]:pattern:' \
    '-y[assume Yes on all queries]' \
    '1:command:->verbs' \
    '2:archive:_files -g "*.(7z|zip|tar|gz|bz2|xz|rar|cab|lzh|wim|iso|ar|arj|cpio|deb|dmg|elf|fat|hfs|lzma|nsis|ntfs|rpm|squashfs|udf|vdi|vhd|vmdk|wim|xar|z)"' \
    '*:files:_files' \
    && ret=0

case $state in
    verbs) _describe -t verbs command verbs && ret=0 ;;
esac

return ret
