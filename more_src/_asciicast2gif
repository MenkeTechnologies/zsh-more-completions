#compdef asciicast2gif
# Documentation: https://github.com/asciinema/asciicast2gif
# asciicast2gif - generate GIF animations from asciicasts

local ret=1

_arguments -s \
  '-t[color theme]:theme:(asciinema tango solarized-dark solarized-light monokai)' \
  '-s[animation speed]:speed' \
  '-S[image scale / pixel density]:scale' \
  '-w[clip terminal to specified number of columns]:cols' \
  '-h[clip terminal to specified number of rows]:rows' \
  '1:input asciicast (path or url):_files' \
  '2:output gif path:_files' && ret=0

return ret
