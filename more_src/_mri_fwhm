#compdef mri_fwhm
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_fwhm
# FreeSurfer estimate and apply smoothness (FWHM) of volume/surface data

local ret=1

_arguments -s -S \
  '--i[input data]:inputvol:_files' \
  '--o[save input after smoothing]:outputvol:_files' \
  '--smooth-only[smooth and save without FWHM analysis]' \
  '--save-detended[save after smoothing, masking, detrending]' \
  '--save-unmasked[save smoothed/detrended without masking]' \
  '--mask[binary mask]:maskvol:_files' \
  '--mask-thresh[threshold mask (default 0.5)]:absthresh:' \
  '--auto-mask[compute mask from fraction of global mean]:rthresh:' \
  '--nerode[erode mask n times before fwhm]:n:' \
  '--mask-inv[invert mask]' \
  '--out-mask[save final mask]:outmask:_files' \
  '--ar1[save spatial AR1 volume]:ar1path:_files' \
  '--X[matlab4 detrending matrix]:x.mat:_files' \
  '--detrend[polynomial detrending (default 0)]:order:' \
  '--sqr[compute square of input before smoothing]' \
  '--fwhm[smooth BY fwhm mm before estimating]:fwhm:' \
  '--gstd[same as --fwhm but as stddev]:gstd:' \
  '--to-fwhm[smooth TO tofwhm mm]:tofwhm:' \
  '--to-fwhm-tol[smooth to fwhm +/- tol (default .5mm)]:tolerance:' \
  '--to-fwhm-nmax[max iterations (default 20)]:nitersmax:' \
  '--to-fwhm-file[save to-fwhm params in file]:file:_files' \
  '--sum[summary/log]:sumfile:_files' \
  '--dat[only the final fwhm estimate]:datfile:_files' \
  '--synth[synthesize input with white gaussian noise]' \
  '--synth-frames[number of frames (default 10)]:nframes:' \
  '--nframesmin[require at least this many frames]:n:' \
  '--ispm[input is spm-analyze]' \
  '--in_nspmzeropad[zero-padding for spm-analyze]:nz:' \
  '--debug[turn on debugging]' \
  '--checkopts[check options and exit]' \
  '--help[print help]' \
  '--version[print version]' && ret=0

return ret
