#compdef gxtuner gxtuner-jack
# _gxtuner — Hermann Meyer Guitarix gxtuner JACK chromatic instrument tuner displaying pitch in Hz and cents deviation with strobe-style indicator (guitarix team, C++/GTK); GOption
# upstream: https://github.com/brummer10/gxtuner

_gxtuner() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--help-all[show all help]' \
        '--help-gtk[GTK help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-J+[jack client name]:str:' \
        '--jack-name=+[jack client name]:str:' \
        '-i+[jack input port]:str:' \
        '--jack-input=+[jack input port]:str:' \
        '-o+[jack output port]:str:' \
        '--jack-output=+[jack output port]:str:' \
        '-S+[jack server name]:str:' \
        '--jack-server=+[jack server name]:str:' \
        '-A+[scale]:s:(chromatic standard equal temperament just-intonation pythagorean mean-tone werckmeister kirnberger)' \
        '-r+[reference Hz]:f:' \
        '--reference=+[reference Hz]:f:' \
        '-t+[tuning]:t:(standard drop-D drop-C drop-B open-D open-G open-A open-C celtic-DADGAD)' \
        '--tuning=+[tuning]:t:(standard drop-D drop-C drop-B open-D open-G open-A open-C celtic-DADGAD)' \
        '-c+[mode]:m:(needle digital strobe analog)' \
        '--mode=+[mode]:m:(needle digital strobe analog)' \
        '--low-frequency=+[Hz]:f:' \
        '--high-frequency=+[Hz]:f:' \
        '--no-fullscreen[no fullscreen]' \
        '--fullscreen[fullscreen]'
}

_gxtuner "$@"
