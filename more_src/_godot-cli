#compdef godot godot4
# Documentation: https://man.archlinux.org/search?q=godot
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help,-?}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(--verbose --verbose)*--verbose[verbose]' \
  '(-v)*-v[verbose]' \
  '--quiet[quiet]' \
  '--no-header[no header]' \
  '--editor[start editor]' \
  '-e[start editor]' \
  '--project-manager[start project manager]' \
  '-p[project manager]' \
  '--debug-server=[debug server URL]:url:' \
  '--quit[quit after first iteration]' \
  '--quit-after=[quit after N iterations]:n:' \
  '--language=[language]:l:' \
  '--path=[project path]:dir:_files -/' \
  '--upwards[search upwards for project]' \
  '--main-pack=[main pack]:file:_files -g "*.pck"' \
  '--render-thread=[render thread]:m:(unsafe safe separate)' \
  '--remote-fs=[remote fs URL]:url:' \
  '--remote-fs-password=[remote fs password]:p:' \
  '--audio-driver=[audio driver]:d:' \
  '--display-driver=[display driver]:d:' \
  '--rendering-method=[rendering method]:m:(forward_plus mobile gl_compatibility)' \
  '--rendering-driver=[rendering driver]:d:(vulkan opengl3 d3d12 metal)' \
  '--gpu-index=[GPU index]:n:' \
  '--text-driver=[text driver]:d:' \
  '--tablet-driver=[tablet driver]:d:' \
  '--single-window[single window mode]' \
  '--screen=[screen index]:n:' \
  '--fullscreen[fullscreen]' \
  '-f[fullscreen]' \
  '--maximized[maximized]' \
  '-m[maximized]' \
  '--windowed[windowed]' \
  '-w[windowed]' \
  '--always-on-top[always on top]' \
  '-t[always on top]' \
  '--resolution=[width x height]:res:' \
  '--position=[xxy]:pos:' \
  '--headless[headless mode]' \
  '--script=[run script]:file:_files -g "*.gd"' \
  '-s+[run script]:file:_files -g "*.gd"' \
  '--check-only[only check syntax]' \
  '--export-release=[release export preset]:preset:' \
  '--export-debug=[debug export preset]:preset:' \
  '--export-pack=[pack export preset]:preset:' \
  '--convert-3to4[convert Godot 3 to 4]' \
  '--validate-conversion-3to4[validate conv]' \
  '--doctool=[doctool path]:dir:_files -/' \
  '--gdscript-docs=[gdscript docs path]:dir:_files -/' \
  '--no-docbase[no doc base]' \
  '--build-solutions[build C# solutions]' \
  '--dump-extension-api[dump extension API]' \
  '--validate-extension-api=[validate extension API]:file:_files' \
  '--benchmark[benchmark]' \
  '--benchmark-file=[benchmark file]:file:_files' \
  '--gpu-profile[GPU profile]' \
  '--gpu-validation[GPU validation]' \
  '--gpu-abort[GPU abort]' \
  '--write-movie=[output movie]:file:_files -g "*.avi *.png"' \
  '--audio-output-latency=[latency ms]:ms:' \
  '--server-name=[server name]:n:' \
  '--debug[debug mode]' \
  '-d[debug]' \
  '--breakpoints=[breakpoints csv]:list:' \
  '--profiling[profiling]' \
  '--gpu-profile[GPU profile]' \
  '--remote-debug=[remote debug URL]:url:' \
  '--frame-delay=[delay ms]:ms:' \
  '--time-scale=[time scale]:n:' \
  '--disable-render-loop[no render loop]' \
  '--disable-crash-handler[no crash handler]' \
  '--fixed-fps=[fixed fps]:n:' \
  '--print-fps[print fps]' \
  '*: :_files' && ret=0

return ret
