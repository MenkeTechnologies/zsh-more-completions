#compdef wormhole

# Zsh completion for magic-wormhole (secure file transfer)

_wormhole_send() {
  _arguments -s -S \
    '--code[use a pre-generated code]:code:' \
    '--text[send a text message]:text message:' \
    '--hide-progress[suppress progress bar]' \
    '--relay-url[override relay URL]:URL:_urls' \
    '--transit-helper[override transit helper URL]:URL:_urls' \
    '--code-length[set number of code words]:length:' \
    '--verify[display verification string]' \
    '*:file or directory:_files'
}

_wormhole_receive() {
  _arguments -s -S \
    '--code[provide the wormhole code]:code:' \
    {-o,--output-file}'[output file path]:file:_files' \
    '--accept-file[accept file transfer without prompting]' \
    '--hide-progress[suppress progress bar]' \
    '--relay-url[override relay URL]:URL:_urls' \
    '--transit-helper[override transit helper URL]:URL:_urls' \
    '1:wormhole code:'
}

_wormhole() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help message]' \
    '(- *)--version[show version]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case $state in
    cmds)
      local -a commands
      commands=(
        'send:send a file, directory, or text'
        'receive:receive a file, directory, or text'
      )
      _describe -t commands 'wormhole command' commands
      ;;
    args)
      case $line[1] in
        send) _wormhole_send ;;
        receive) _wormhole_receive ;;
      esac
      ;;
  esac
}

_wormhole "$@"
