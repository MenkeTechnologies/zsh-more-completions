#compdef wormhole
# Documentation: https://magic-wormhole.readthedocs.io/en/latest/welcome.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# wormhole: magic-wormhole — get things from one computer to another safely.

_wormhole_send() {
  _arguments -s -S \
    '--code=[use a pre-generated code]:code:' \
    '--code-length=[number of code words]:length:' \
    '--text=[send a text message]:text:' \
    '--verify[display verification string]' \
    '--hide-progress[suppress progress bar]' \
    '--relay-url=[override relay URL]:URL:_urls' \
    '--transit-helper=[override transit helper URL]:URL:_urls' \
    '*:file or directory:_files'
}

_wormhole_receive() {
  _arguments -s -S \
    '--code-length=[number of code words]:length:' \
    {-o+,--output-file=}'[output file path]:file:_files' \
    '--accept-file[accept file transfer without prompting]' \
    '--verify[display verification string]' \
    '--relay-url=[override relay URL]:URL:_urls' \
    '--transit-helper=[override transit helper URL]:URL:_urls' \
    '1:wormhole code:'
}

_wormhole() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help message]' \
    '(- *)--version[show version]' \
    '--appid=[application identifier]:appid:' \
    '--relay-url=[default relay URL]:URL:_urls' \
    '--transit-helper=[default transit relay URL]:URL:_urls' \
    '--tor[enable Tor]' \
    '--launch-tor[launch a Tor process]' \
    '--tor-control-port=[Tor control port]:port:' \
    '--tor-socks-port=[Tor SOCKS port]:port:' \
    '--dump-timing=[write timing JSON to file]:file:_files' \
    '1:command:->cmds' \
    '*::arg:->args'

  case $state in
    cmds)
      local -a commands
      commands=(
        'send:send a file, directory, or text'
        'receive:receive a file, directory, or text'
        'ssh:send/receive SSH public keys'
      )
      _describe -t commands 'wormhole command' commands
      ;;
    args)
      case $line[1] in
        send) _wormhole_send ;;
        receive) _wormhole_receive ;;
      esac
      ;;
  esac
}

_wormhole "$@"
