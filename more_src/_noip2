#compdef noip2
# Documentation: https://man.archlinux.org/search?q=noip2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-C[configure]' \
  '-c+[config file]:file:_files' \
  '-d[debug mode]' \
  '-F[force update]' \
  '-i+[interface]:iface:_net_interfaces' \
  '-I+[poll interval seconds]:sec:' \
  '-K+[FQDN to update]:fqdn:' \
  '-M[multiple updates]' \
  '-S[status info]' \
  '-U+[username]:user:' \
  '-P+[password]:pw:' \
  '-Y[show usernames in status]' \
  '-Z[suppress version banner]' && ret=0

return ret
