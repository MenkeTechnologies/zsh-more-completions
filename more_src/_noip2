#compdef noip2
# Documentation: https://man.cx/noip2
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Per man.cx noip2(8): -C creates config, -c uses alternate config file,
# -F forces NAT off, -Y selects all hosts/groups, -L selects specific
# hosts/groups, -U sets update interval (minutes), -u username,
# -p password, -x executable, -i supplied IP, -I supplied interface,
# -d increases debug verbosity, -D toggles debug for PID, -S shows
# config, -M permits multiple instances, -K terminate instance by PID,
# -z activates shm dump, -h displays usage. Prior file had several
# flags miscoded (-K, -i, -I, -U, -P).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-C[create configuration data file]' \
  '-c+[use alternate config file]:file:_files' \
  '-F[force NAT off]' \
  '-Y[select all hosts/groups]' \
  '-L[select specific hosts/groups]' \
  '-U+[set update interval in minutes]:minutes:' \
  '-u+[username]:user:' \
  '-p+[password]:password:' \
  '-x+[executable]:command:_command_names' \
  '-i+[use supplied IP address]:ip:' \
  '-I+[use supplied interface]:iface:_net_interfaces' \
  '-d[increase debug verbosity]' \
  '-D+[toggle debug flag for PID]:pid:_pids' \
  '-S[show configuration data]' \
  '-M[permit multiple instances]' \
  '-K+[terminate instance by PID]:pid:_pids' \
  '-z[activate shm dump code]' && ret=0

return ret
