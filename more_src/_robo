#compdef robo
# Documentation: https://github.com/consolidation/Robo
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (Application.php + Runner.php).

# Zsh completion for robo - PHP task runner (Symfony Console based)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--ansi[force ANSI output]' \
  '--no-ansi[disable ANSI output]' \
  '(-n --no-interaction)'{-n,--no-interaction}'[do not ask interactive questions]' \
  '(-f --load-from)'{-f,--load-from}'[load RoboFile from path]:path:_files' \
  '--simulate[run in simulated mode]' \
  '--progress-delay[seconds before showing progress bar]:secs:' \
  '(-D --define)*'{-D,--define}'[define configuration value]:key=value:' \
  '1:task:->tasks' \
  '*::arg:->args' && ret=0

case $state in
  (tasks)
    local -a tasks
    if [[ -f RoboFile.php ]]; then
      tasks=(${(f)"$(grep -oP '(?<=function )\w+' RoboFile.php 2>/dev/null)"})
      _describe -t tasks 'task' tasks && ret=0
    fi
    ;;
esac

return ret
