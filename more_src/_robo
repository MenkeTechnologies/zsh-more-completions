#compdef robo

# Zsh completion for robo - PHP task runner

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--ansi[force ANSI output]' \
  '--no-ansi[disable ANSI output]' \
  '-n[do not ask interactive questions]' \
  '-f[robo file to use]:file:_files' \
  '--load-from[directory to search for RoboFile]:dir:_directories' \
  '--simulate[run in simulated mode]' \
  '1:task:->tasks' \
  '*::arg:->args' && ret=0

case $state in
  (tasks)
    local -a tasks
    if [[ -f RoboFile.php ]]; then
      tasks=(${(f)"$(grep -oP '(?<=function )\w+' RoboFile.php 2>/dev/null)"})
      _describe -t tasks 'task' tasks && ret=0
    fi
    ;;
esac

return ret
