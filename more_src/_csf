#compdef csf
# Documentation: https://man.archlinux.org/search?q=csf
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-e --enable)'{-e,--enable}'[enable csf and lfd]' \
  '(-x --disable)'{-x,--disable}'[disable csf and lfd]' \
  '(-s --start)'{-s,--start}'[start firewall rules]' \
  '(-f --stop)'{-f,--stop}'[stop firewall rules]' \
  '(-r --restart)'{-r,--restart}'[restart firewall rules]' \
  '(-q --startq)'{-q,--startq}'[quick restart via lfd]' \
  '(-sf --startf)'{-sf,--startf}'[force restart]' \
  '(-ra --restartall)'{-ra,--restartall}'[restart csf and lfd]' \
  '(-crs --crestart)'{-crs,--crestart}'[cluster restart]' \
  '--lfd[control lfd daemon]:action:(stop start restart status)' \
  '(-c --check)'{-c,--check}'[check for updates]' \
  '(-u --update)'{-u,--update}'[install updates]' \
  '-uf[force update]' \
  '(-in --insiders)'{-in,--insiders}'[show release channel]' \
  '(-a --add)'{-a+,--add=}'[allow IP with optional comment]:ip:' \
  '(-ar --addrm)'{-ar+,--addrm=}'[remove from allow list]:ip:' \
  '(-d --deny)'{-d+,--deny=}'[deny IP with optional comment]:ip:' \
  '(-dr --denyrm)'{-dr+,--denyrm=}'[remove from deny list]:ip:' \
  '(-df --denyf)'{-df,--denyf}'[clear all deny entries]' \
  '(-g --grep)'{-g+,--grep=}'[search iptables for IP]:ip:' \
  '(-i --iplookup)'{-i+,--iplookup=}'[lookup IP geolocation]:ip:' \
  '(-t --temp)'{-t,--temp}'[show temporary entries]' \
  '(-tr --temprm)'{-tr+,--temprm=}'[remove temp entry]:ip:' \
  '(-trd --temprmd)'{-trd+,--temprmd=}'[remove temp ban only]:ip:' \
  '(-tra --temprma)'{-tra+,--temprma=}'[remove temp allow only]:ip:' \
  '(-td --tempdeny)'{-td+,--tempdeny=}'[add temporary deny]:ip:' \
  '(-ta --tempallow)'{-ta+,--tempallow=}'[add temporary allow]:ip:' \
  '(-tf --tempf)'{-tf,--tempf}'[clear all temp entries]' \
  '(-ap --addport)'{-ap+,--addport=}'[open port proto:port]:portspec:' \
  '(-rp --removeport)'{-rp+,--removeport=}'[close port proto:port]:portspec:' \
  '(-lp --listports)'{-lp,--listports}'[list configured ports]' \
  '(-p --ports)'{-p,--ports}'[show listening ports]' \
  '(-l --status)'{-l,--status}'[list IPv4 iptables rules]' \
  '(-l6 --status6)'{-l6,--status6}'[list IPv6 ip6tables rules]' \
  '(-lr --logrun)'{-lr,--logrun}'[run log scanner report]' \
  '--graphs[generate stats graphs]:type:' && ret=0

return ret
