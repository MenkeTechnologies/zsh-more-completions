#compdef create-backend-buddy
# Documentation: https://www.npmjs.com/package/create-backend-buddy
# Reference accessed: 2026-05-23
# Verified: npm view create-backend-buddy bin; npm readme CLI Arguments section.

# Zsh completion for create-backend-buddy - Express API scaffolder with ORM and Docker

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--name=[API project name]:name:' \
  '--lang=[project language]:lang:(typescript javascript)' \
  '--orm=[ORM/ODM choice]:orm:(prisma sequelize mongoose)' \
  '--db=[database engine]:database:(postgres mysql sqlite mongodb)' \
  '--swagger[include Swagger/OpenAPI setup]' \
  '--docker[include Docker and docker-compose files]' \
  '--git[initialize git repository]' && ret=0

return ret
