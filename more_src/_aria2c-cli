#compdef aria2c-cli aria2-cli
# _aria2c-cli — Tatsuhiro Tsujikawa aria2 multi-protocol multi-source download utility CLI alias (aria2 team, C++); custom argparse
# upstream: https://github.com/aria2/aria2

_aria2c-cli() {
    _arguments \
        '--help[show help]' \
        '-h+[help category]:c:(help http ftp metalink bittorrent rpc all)' \
        '--version[show version]' \
        '-v[show version]' \
        '--conf-path=+[config file]:file:_files' \
        '--no-conf[no conf]' \
        '-d+[dir]:dir:_files -/' \
        '--dir=+[dir]:dir:_files -/' \
        '-o+[output file]:file:_files' \
        '--out=+[output file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '--log-level=+[level]:l:(debug info notice warn error)' \
        '-j+[max concurrent downloads]:n:' \
        '--max-concurrent-downloads=+[max concurrent downloads]:n:' \
        '-V[check integrity]' \
        '--check-integrity[check integrity]' \
        '-c[continue download]' \
        '--continue[continue download]' \
        '-U+[user-agent]:str:' \
        '--user-agent=+[user-agent]:str:' \
        '--http-user=+[user]:_users' \
        '--http-passwd=+[password]:str:' \
        '--http-auth-challenge[http auth challenge]' \
        '--header=+[header]:str:' \
        '--check-certificate=+[bool]:b:(true false)' \
        '--ca-certificate=+[file]:file:_files' \
        '--certificate=+[file]:file:_files' \
        '--private-key=+[file]:file:_files' \
        '--all-proxy=+[proxy]:str:' \
        '--http-proxy=+[proxy]:str:' \
        '--https-proxy=+[proxy]:str:' \
        '--ftp-proxy=+[proxy]:str:' \
        '--no-proxy=+[hosts]:str:' \
        '--proxy-method=+[method]:m:(get tunnel)' \
        '-T+[torrent file]:file:_files -g "*.torrent"' \
        '--torrent-file=+[torrent file]:file:_files -g "*.torrent"' \
        '-S[show torrent info]' \
        '--show-files[show torrent info]' \
        '--bt-tracker=+[trackers csv]:str:' \
        '--bt-stop-timeout=+[seconds]:n:' \
        '--seed-time=+[minutes]:n:' \
        '--seed-ratio=+[ratio]:str:' \
        '--enable-dht[enable DHT]' \
        '--enable-dht6[enable DHT v6]' \
        '--bt-enable-lpd[enable BT LPD]' \
        '--listen-port=+[ports]:str:' \
        '--max-overall-download-limit=+[rate]:str:' \
        '--max-download-limit=+[rate]:str:' \
        '--max-overall-upload-limit=+[rate]:str:' \
        '--max-upload-limit=+[rate]:str:' \
        '-x+[connections per server]:n:' \
        '--max-connection-per-server=+[connections per server]:n:' \
        '-s+[split count]:n:' \
        '--split=+[split count]:n:' \
        '-k+[min split size]:str:' \
        '--min-split-size=+[min split size]:str:' \
        '-i+[input file]:file:_files' \
        '--input-file=+[input file]:file:_files' \
        '--save-session=+[file]:file:_files' \
        '--save-session-interval=+[seconds]:n:' \
        '--summary-interval=+[seconds]:n:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--console-log-level=+[level]:l:(debug info notice warn error)' \
        '--show-console-readout=+[bool]:b:(true false)' \
        '--enable-rpc[enable RPC]' \
        '--rpc-listen-all[rpc listen all]' \
        '--rpc-listen-port=+[port]:port:' \
        '--rpc-user=+[user]:_users' \
        '--rpc-passwd=+[password]:str:' \
        '--rpc-secret=+[secret]:str:' \
        '--rpc-allow-origin-all[allow all origins]' \
        '-D[daemon]' \
        '--daemon[daemon]' \
        '--metalink-file=+[file]:file:_files' \
        '--follow-metalink=+[bool]:b:(true false mem)' \
        '--no-netrc[no netrc]' \
        '-n[no netrc]' \
        '--netrc-path=+[file]:file:_files' \
        '*:url:_urls'
}

_aria2c-cli "$@"
