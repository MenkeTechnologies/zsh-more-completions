#compdef blcal
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/blcal.html
# MIRIAD blcal - baseline-based calibration

local ret=1

_arguments -s -S \
  'vis=[reference and source visibility datasets]:vis:_files' \
  'select=[uv selection applied to both datasets]:select' \
  'line=[uv line type specification]:line' \
  'stokes=[polarization/Stokes processing]:stokes' \
  'interval=[solution time interval in minutes]:interval' \
  'out=[output uv dataset name]:out:_files' \
  'options=[nopassol,nopolsol,replace]:options' \
  '*:visibility data:_files' && ret=0

return ret
