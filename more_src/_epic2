#compdef epic2
# Documentation: https://github.com/biocore-ntnu/epic2
# epic2: ultraperformant reimplementation of the SICER ChIP-seq broad peak caller

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*'{-t+,--treatment=}'[treatment (pull-down) file(s)]:file:_files' \
  '*'{-c+,--control=}'[control (input) file(s)]:file:_files' \
  '(-gn --genome)'{-gn+,--genome=}'[genome to analyze]:genome:' \
  '(-kd --keep-duplicates)'{-kd,--keep-duplicates}'[keep reads at identical positions on same strand]' \
  '(-oa --original-algorithm)'{-oa,--original-algorithm}'[use original SICER algorithm]' \
  '(-bin --bin-size)'{-bin+,--bin-size=}'[window size for genome scanning]:bp:' \
  '(-g --gaps-allowed)'{-g+,--gaps-allowed=}'[multiplier for max gaps between eligible windows]:n:' \
  '(-fs --fragment-size)'{-fs+,--fragment-size=}'[size of the sequenced fragment]:bp:' \
  '(-fdr --false-discovery-rate-cutoff)'{-fdr+,--false-discovery-rate-cutoff=}'[remove islands with FDR above cutoff]:fdr:' \
  '(-egf --effective-genome-fraction)'{-egf+,--effective-genome-fraction=}'[custom effective genome fraction]:fraction:' \
  '(-cs --chromsizes)'{-cs+,--chromsizes=}'[file with chromosome names and sizes]:file:_files' \
  '(-e --e-value)'{-e+,--e-value=}'[genome-wide error rate of identified islands]:n:' \
  '(-f --required-flag)'{-f+,--required-flag=}'[BAM flag bits to keep]:n:' \
  '(-F --filter-flag)'{-F+,--filter-flag=}'[BAM flag bits to discard]:n:' \
  '(-m --mapq)'{-m+,--mapq=}'[minimum mapping quality]:n:' \
  '(-a --autodetect-chroms)'{-a,--autodetect-chroms}'[auto-detect chromosomes from BAM files]' \
  '(-d --discard-chromosomes-pattern)'{-d+,--discard-chromosomes-pattern=}'[pattern for filtering chromosomes]:pattern:' \
  '(-o --output)'{-o+,--output=}'[file to write results to]:file:_files' \
  '--original-statistics[use original SICER statistics computation method]' \
  '--guess-bampe[auto-detect paired-end BAM format from first 100 reads]' \
  '(-q --quiet)'{-q,--quiet}'[suppress stderr output]' \
  '(-ex --example)'{-ex,--example}'[show example data paths and command]' && ret=0

return ret
