#compdef pkaction
# _pkaction — polkit pkaction (list registered polkit action ids and their default authorization rules; -a/--action-id filter to one action, -v/--verbose include description and message, --version, --help; positional argument is an optional action id pattern)
# upstream: https://github.com/polkit-org/polkit
# Flags from polkit-org/polkit src/programs/pkaction.c on tip.

_pkaction() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-a+[action id]:action:' \
        '--action-id+[action id]:action:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '*:action id pattern:'
}

_pkaction "$@"
