#compdef bigPslToPsl
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# convert bigPsl file to psl

local ret=1

_arguments -s -S \
  '-chrom=[restrict to this chromosome]:chrom:' \
  '-start=[restrict to start coordinate]:n:' \
  '-end=[restrict to end coordinate]:n:' \
  '-bed=[restrict to ranges in BED file]:bed:_files' \
  '-positions=[restrict to positions in file]:positions:_files' \
  '-collapseStrand[collapse strand to single character]' \
  '-udcDir=[local cache dir for remote bigPsl files]:dir:_files -/' \
  '-skipChromCheck[do not check chrom names against bigPsl]' \
  '*:bigPsl.bb output.psl:_files' && ret=0

return ret
