#compdef 3dWilcoxon
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dWilcoxon.html
# AFNI: nonparametric Wilcoxon signed-rank test for paired comparisons

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-dset[dataset number and filename]:num filename:_files' \
  '-workmem[megabytes of RAM to use]:mega:' \
  '-voxel[print results for given voxel]:num:' \
  '-out[output prefix name]:prefix:_files' \
  '*:dataset:_files' && ret=0

return ret
