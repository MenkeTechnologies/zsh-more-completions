#compdef aardvark-dns
# Documentation: https://github.com/containers/aardvark-dns/blob/main/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run the DNS server'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config directory]:dir:_files -/' \
  '(-p --port)'{-p+,--port=}'[host port]:port:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'aardvark-dns command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config dir]:dir:_files -/' \
          '(-p --port)'{-p+,--port=}'[host port]:port:' && ret=0 ;;
    esac ;;
esac

return ret
