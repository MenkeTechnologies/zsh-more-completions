#compdef gearmand
# Documentation: https://gearman.org/gearmand/gearmand/
# gearmand - Gearman job server daemon

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --daemon)'{-d,--daemon}'[detach and run in the background]' \
  '(-L --listen)'{-L,--listen}'+[address the server should listen on]:address:' \
  '(-p --port)'{-p,--port}'+[port the server should listen on]:port:' \
  '(-q --queue-type)'{-q,--queue-type}'+[enable a persistent queue module]:type:' \
  '-t+[number of I/O threads]:threads:' \
  '*:arg:' && ret=0

return ret
