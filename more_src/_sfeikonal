#compdef sfeikonal
# Documentation: https://github.com/ahay/src/blob/master/user/fomels/Meikonal.c
# Madagascar: fast marching eikonal solver for 3-D traveltime computation

local ret=1

_arguments -s -S \
  'vel=[if y, input is velocity; n, slowness squared]:vel:(y n)' \
  'order=[accuracy order (1 or 2)]:order:(1 2)' \
  'sweep=[if y, use fast sweeping instead of fast marching]:sweep:(y n)' \
  'br1=[constant-velocity box around source (dimension 1)]:br1' \
  'br2=[constant-velocity box around source (dimension 2)]:br2' \
  'br3=[constant-velocity box around source (dimension 3)]:br3' \
  'plane1=[plane-wave source on axis 1]:plane1:(y n)' \
  'plane2=[plane-wave source on axis 2]:plane2:(y n)' \
  'plane3=[plane-wave source on axis 3]:plane3:(y n)' \
  'b1=[constant-velocity box (samples, axis 1)]:b1' \
  'b2=[constant-velocity box (samples, axis 2)]:b2' \
  'b3=[constant-velocity box (samples, axis 3)]:b3' \
  'shotfile=[file with shot locations]:shotfile:_files' \
  'zshot=[shot z location]:zshot' \
  'yshot=[shot y location]:yshot' \
  'xshot=[shot x location]:xshot' \
  '*:RSF file:_files' && ret=0

return ret
