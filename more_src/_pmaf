#compdef pmaf
# _pmaf — Performance Co-Pilot pmaf (Performance Metrics Application Framework runtime: discovers locally installed PCP applications under /etc/pcp/apps and runs them by stem name; -h host, -V verbose, --list shows applications, --config picks alt config; positional argument is the application name then per-app args)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmaf/pmaf on tip.

_pmaf() {
    _arguments \
        '-h+[host]:host:_hosts' \
        '-V[verbose]' \
        '--list[list applications]' \
        '--config+[config file]:file:_files' \
        '1:application:' \
        '*::app args:'
}

_pmaf "$@"
