#compdef wac
# Documentation: https://github.com/bytecodealliance/wac
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. Subcommands plug, compose,
# parse, resolve, targets all confirmed in the README.
# Note: this completion targets bytecodealliance/wac (Rust component
# composition CLI), not kanaka/wac (C-language WebAssembly interpreter).
# Removed from prior file: bogus man.archlinux.org URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'plug:connect plug components to a socket component'
  'compose:encode a composed component from WAC source'
  'parse:parse WAC source to JSON AST'
  'resolve:resolve dependencies to a DOT graph'
  'targets:verify a component targets a WIT world'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'wac command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (plug)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-t --wat)'{-t,--wat}'[emit WAT instead of raw wasm]' \
          '(-o --output)'{-o,--output=}'[write output to path]:file:_files' \
          '--registry=[Warg registry URL]:url:' \
          '*--plug=[plug component path or registry package]:path:_files' \
          '1:socket path or registry package:_files' && ret=0 ;;
      (compose)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*-d+[dependency PKG=PATH map]:dependency mapping:' \
          '*--dep=[dependency PKG=PATH map]:dependency mapping:' \
          '--deps-dir=[dependency search directory]:directory:_files -/' \
          '--no-validate[skip wasm validation]' \
          '(-t --wat)'{-t,--wat}'[emit WAT instead of raw wasm]' \
          '(-i --import-dependencies)'{-i,--import-dependencies}'[composed component imports its dependencies]' \
          '(-o --output)'{-o,--output=}'[write output to path]:file:_files' \
          '--registry=[Warg registry URL]:url:' \
          '1:WAC source file:_files' && ret=0 ;;
      (parse)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:WAC source file:_files' && ret=0 ;;
      (resolve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*-d+[dependency PKG=PATH map]:dependency mapping:' \
          '*--dep=[dependency PKG=PATH map]:dependency mapping:' \
          '--deps-dir=[dependency search directory]:directory:_files -/' \
          '--registry=[Warg registry URL]:url:' \
          '1:WAC source file:_files' && ret=0 ;;
      (targets)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--wit=[WIT package path]:WIT file or directory:_files' \
          '--world=[world name in WIT package]:world name:' \
          '1:component wasm path:_files' && ret=0 ;;
    esac ;;
esac

return ret
