#compdef chromedriver
# Documentation: chromium chromedriver source chrome/test/chromedriver/server/chromedriver_server.cc
# Source: ChromeDriver — WebDriver implementation for Google Chrome.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--port=[port to listen on]:port:_ports' \
    '--adb-port=[Android Debug Bridge port]:port:_ports' \
    '--log-path=[write log to FILE instead of stderr]:file:_files' \
    '--log-level=[log level]:level:(ALL DEBUG INFO WARNING SEVERE OFF)' \
    '--verbose[verbose logging]' \
    '--silent[silence logging]' \
    '--append-log[append to log instead of truncating]' \
    '--replayable[output reproducible log format]' \
    '(- *)--version[show version and exit]' \
    '--url-base=[URL base path served from /]:path:' \
    '--readable-timestamp[human-readable timestamps in log]' \
    '--enable-chrome-logs[capture logs from Chrome itself]' \
    '--bidi-mapper-path=[WebDriver BiDi mapper JS path]:file:_files -g "*.js"' \
    '--disable-dev-shm-usage[disable /dev/shm usage]' \
    '--ignore-explicit-port[ignore --port and pick automatically]' \
    '--allowed-ips=[comma-separated IPs allowed to connect]:ips:' \
    '--whitelisted-ips=[deprecated alias for --allowed-ips]:ips:' \
    '--allowed-origins=[comma-separated origins allowed by CORS]:origins:' \
    '(- *)--help[show help and exit]' \
    && ret=0

return ret
