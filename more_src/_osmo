#compdef osmo
# Documentation: https://manpages.debian.org/bookworm/osmo/osmo.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm osmo(1) manpage OPTIONS section.

# Osmo: personal organizer (calendar/tasks/contacts/notes)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-? --help)'{-?,--help}'[show help]' \
  '(-c --calendar)'{-c,--calendar}'[show small calendar window]' \
  '(-e --check)'{-e,--check}'[check for events since last run]' \
  '(-d --days)'{-d,--days=}'[days forward to check for events]:n:' \
  '(-q --mutt-query)'{-q,--mutt-query=}'[match contacts with given string]:string:' \
  '--html-stylesheet=[CSS stylesheet for HTML renderer]:file:_files -g "*.css"' \
  '--display=[X display]:display:' && ret=0
return ret
