#compdef bneptest
# Documentation: https://github.com/bluez/bluez/blob/master/tools/bneptest.c
# Source: BlueZ tools/bneptest.c — BNEP (Bluetooth Network Encapsulation Protocol) PAN test harness.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i[HCI device number (default 0)]:hciN:' \
    '(-s -c)-s[start server listening mode]' \
    '(-s -c)-c[connect mode with destination address]:bdaddr:' \
    '-t[control message type to send]:type:' \
    '-w[BNEP generic frame type to send]:type:' \
    '-k[source MAC address]:src mac:' \
    '-f[destination MAC address]:dst mac:' \
    '-T[seconds before disconnect after setup]:seconds:' \
    '-d[network protocol type range start]:start:' \
    '-e[network protocol type range end]:end:' \
    '-g[multicast address range start]:start:' \
    '-j[multicast address range end]:end:' \
    '-l[local role (16-bit service value)]:role:' \
    '-r[remote role (16-bit service value)]:role:' \
    '-b[bridge name]:bridge:' \
    '-n[interface name]:iface:' \
    '-N[do not close after disconnect]' \
    '-y[control frame retransmission count]:n:' \
    '-u[BNEP frame retransmission count]:n:' \
    '(- *)-h[show help]' \
    && ret=0

return ret
