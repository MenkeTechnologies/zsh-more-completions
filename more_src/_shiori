#compdef shiori

local curcontext="$curcontext" state line ret=1

_shiori_commands() {
  local -a commands=(
    'add:Add a bookmark'
    'print:Print saved bookmarks'
    'delete:Delete saved bookmarks'
    'update:Update saved bookmarks'
    'open:Open bookmarks in browser'
    'pocket:Import bookmarks from Pocket'
    'import:Import bookmarks from HTML file'
    'export:Export bookmarks to HTML file'
    'serve:Start the web server'
    'check:Check and fix bookmarks'
    'version:Show version'
  )
  _describe -t commands 'shiori command' commands
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '--portable[Use portable mode]' \
  '--storage-directory[Directory for storing data]:directory:_files -/' \
  '1:command:_shiori_commands' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$words[1]" in
      add)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          {-t,--title}'[Custom title]:title' \
          {-e,--excerpt}'[Custom excerpt]:excerpt' \
          '--tags[Comma-separated tags]:tags' \
          '--no-archival[Do not archive the page]' \
          '--log-archival[Log archival process]' \
          '*:url' \
          && ret=0
        ;;
      print)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          {-i,--index}'[Only print bookmarks with specific index]:index' \
          {-t,--tags}'[Filter by tags]:tags' \
          {-s,--search}'[Search bookmarks]:query' \
          '--newest[Sort by newest first]' \
          '--oldest[Sort by oldest first]' \
          && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '*:bookmark-id' \
          && ret=0
        ;;
      update)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          {-i,--index}'[Bookmark index to update]:index' \
          '--url[New URL]:url' \
          {-t,--title}'[New title]:title' \
          {-e,--excerpt}'[New excerpt]:excerpt' \
          '--tags[New tags]:tags' \
          '--no-archival[Do not re-archive]' \
          '--log-archival[Log archival process]' \
          && ret=0
        ;;
      open)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--archive[Open the archived version]' \
          '--text-cache[Open the text cache]' \
          '*:bookmark-id' \
          && ret=0
        ;;
      pocket)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '*:pocket-file:_files' \
          && ret=0
        ;;
      import)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '*:file:_files' \
          && ret=0
        ;;
      export)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '*:file:_files' \
          && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          {-p,--port}'[Port to listen on]:port' \
          {-a,--address}'[Address to listen on]:address' \
          && ret=0
        ;;
      check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          && ret=0
        ;;
      version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
