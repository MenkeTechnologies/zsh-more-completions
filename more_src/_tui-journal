#compdef tui-journal
# Documentation: https://github.com/AmmarAbouZor/tui-journal
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-j --json-file-path)'{-j,--json-file-path}'=[JSON file path]:file:_files' \
  '(-s --sqlite-file-path)'{-s,--sqlite-file-path}'=[SQLite file path]:file:_files' \
  '(-b --backend-type)'{-b,--backend-type}'=[backend type]:backend:(json sqlite)' \
  '(-c --config)'{-c,--config}'=[configuration directory path]:dir:_directories' \
  '*'{-v,--verbose}'[increase logging verbosity (stackable up to 3)]' \
  '(-l --log)'{-l,--log}'=[log output file]:file:_files' && ret=0

return ret
