#compdef AdGuardHome adguardhome

# Zsh completion for AdGuardHome (network-wide ad and tracker blocking DNS server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'=[Path to configuration file]:config file:_files -g "*.{yaml,yml}"' \
  '(-w --work-dir)'{-w,--work-dir}'=[Path to the working directory]:directory:_files -/' \
  '(-h --host)'{-h,--host}'=[Host address to bind HTTP server on]:host' \
  '(-p --port)'{-p,--port}'=[Port to serve HTTP pages on]:port' \
  '-s+[Service command]:command:(install uninstall start stop restart status reload)' \
  '--service=[Service command]:command:(install uninstall start stop restart status reload)' \
  '--web-addr=[Address and port to serve the web UI on]:addr\:port' \
  '--update[Check for updates]' \
  '--no-check-update[Do not check for updates]' \
  '--pidfile=[Path to the PID file]:file:_files' \
  '-v[Enable verbose logging]' \
  '--verbose[Enable verbose logging]' \
  '--version[Print version]' \
  '--help[Print help]' \
  '--no-etc-hosts[Do not use /etc/hosts]' \
  '--local-frontend[Use a local directory for frontend assets]' && ret=0

return ret
