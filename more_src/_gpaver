#compdef gpaver
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/gpaver.html
# MIRIAD gpaver - average gain solutions over time

local ret=1

_arguments -s -S \
  'vis=[input visibility file with gain file]:vis:_files' \
  'interval=[time averaging interval in minutes]:interval' \
  'options=[vector,scalar]:options' \
  '*:dataset:_files' && ret=0

return ret
