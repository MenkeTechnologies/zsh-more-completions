#compdef venus
# _venus — IPFS Force Community venus alternative Filecoin implementation in Go featuring modular architecture remote actor execution and cluster mining (filecoin-project team, Go); urfave/cli
# upstream: https://github.com/filecoin-project/venus

_venus() {
    local -a sub=(
        'daemon:start daemon'
        'wallet:wallet operations'
        'send:send FIL'
        'chain:chain operations'
        'state:state operations'
        'sync:sync operations'
        'net:network operations'
        'mpool:mpool operations'
        'msig:multisig operations'
        'paych:payment channel operations'
        'client:storage client operations'
        'log:logging operations'
        'auth:auth operations'
        'info:show node info'
        'version:show version'
        'config:show config'
        'fetch:fetch parameters'
        'inspect:inspect data'
        'storer:storer operations'
        'pprof:profiling'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--repo-dir=+[dir]:dir:_files -/' \
        '--api-address=+[addr]:str:' \
        '--auth-token=+[token]:str:' \
        '--block-time=+[d]:str:' \
        '--no-config[no config]' \
        '--debug[debug logging]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'venus subcommand' sub ;;
        args)
            case $words[1] in
                daemon) _arguments \
                    '--bootstrap-peers=+[csv]:str:' \
                    '--cli-api-port=+[port]:n:' \
                    '--network=+[net]:n:(mainnet calibrationnet butterfly interopnet 2k force)' \
                    '--import-snapshot=+[file]:file:_files -g "*.car"' \
                    '--genesisfile=+[file]:file:_files -g "*.car"' \
                    '--init[init repo]' \
                    '--password=+[password]:str:' ;;
                wallet) _arguments \
                    '1:wallet action:(new ls balance default set-default delete export import verify sign)' \
                    '*:key:' ;;
            esac
            ;;
    esac
}

_venus "$@"
