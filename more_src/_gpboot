#compdef gpboot
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/gpboot.html
# Correct the gains table of a visibility dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'cal=[cal keyword]:cal:' \
  'select=[select keyword]:select:' \
  '*:visibility dataset:_files' && ret=0

return ret
