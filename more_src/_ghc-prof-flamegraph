#compdef ghc-prof-flamegraph
# Documentation: https://github.com/fpco/ghc-prof-flamegraph
# Generate a flame graph from a GHC .prof time/allocation profile

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--alloc[use the allocation measurements instead of time measurements]' \
  '--entry[use the entries measurements instead of time measurements]' \
  '--bytes[memory measurements in bytes (+RTS -P -RTS)]' \
  '--ticks[time measurements in ticks (+RTS -P -RTS)]' \
  '--time[use time measurements]' \
  '(-o --output)'{-o,--output}'=[optional output SVG file]:file:_files' \
  '*--flamegraph-option=[option to pass to flamegraph.pl]:option' \
  '*:prof file:_files -g "*.prof"' && ret=0

return ret
