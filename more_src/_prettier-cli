#compdef prettier-cli
# _prettier-cli — Prettier opinionated code formatter CLI alias (Prettier team / James Long, JavaScript); commander
# upstream: https://github.com/prettier/prettier

_prettier-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--check[check formatting]' \
        '-c[check formatting]' \
        '--list-different[list different files]' \
        '-l[list different files]' \
        '--write[edit files in place]' \
        '-w[edit files in place]' \
        '--config=+[config file]:file:_files -g ".prettierrc *.json *.yml *.js"' \
        '--no-config[no config]' \
        '--config-precedence=+[config precedence]:p:(cli-override file-override prefer-file)' \
        '--no-editorconfig[no editorconfig]' \
        '--ignore-path=+[ignore path]:list:_files -g ".prettierignore *.gitignore"' \
        '--with-node-modules[with node_modules]' \
        '--debug-check[debug check]' \
        '--debug-print-doc[debug print doc]' \
        '--debug-print-ast[debug print AST]' \
        '--debug-print-comments[debug print comments]' \
        '--loglevel=+[log level]:level:(silent error warn log debug)' \
        '--no-color[no color]' \
        '--cursor-offset=+[cursor offset]:n:' \
        '--range-start=+[range start]:n:' \
        '--range-end=+[range end]:n:' \
        '--parser=+[parser]:p:(babel babel-flow babel-ts flow typescript css scss less postcss json json5 json-stringify graphql markdown mdx vue yaml glimmer html lwc angular meriyah espree acorn)' \
        '--filepath=+[file path]:file:_files' \
        '--stdin-filepath=+[stdin filepath]:file:_files' \
        '--arrow-parens=+[arrow parens]:p:(always avoid)' \
        '--bracket-same-line[bracket same line]' \
        '--no-bracket-same-line[no bracket same line]' \
        '--bracket-spacing[bracket spacing]' \
        '--no-bracket-spacing[no bracket spacing]' \
        '--embedded-language-formatting=+[embedded language formatting]:m:(auto off)' \
        '--end-of-line=+[end of line]:e:(lf crlf cr auto)' \
        '--html-whitespace-sensitivity=+[html whitespace sensitivity]:s:(css strict ignore)' \
        '--insert-pragma[insert pragma]' \
        '--no-insert-pragma[no insert pragma]' \
        '--jsx-single-quote[jsx single quote]' \
        '--no-jsx-single-quote[no jsx single quote]' \
        '--print-width=+[print width]:n:' \
        '--prose-wrap=+[prose wrap]:p:(always never preserve)' \
        '--quote-props=+[quote props]:q:(as-needed consistent preserve)' \
        '--require-pragma[require pragma]' \
        '--no-require-pragma[no require pragma]' \
        '--semi[semicolons]' \
        '--no-semi[no semicolons]' \
        '--single-attribute-per-line[single attribute per line]' \
        '--single-quote[single quote]' \
        '--no-single-quote[no single quote]' \
        '--tab-width=+[tab width]:n:' \
        '--trailing-comma=+[trailing comma]:c:(all es5 none)' \
        '--use-tabs[use tabs]' \
        '--no-use-tabs[no use tabs]' \
        '--vue-indent-script-and-style[vue indent script and style]' \
        '--plugin=+[plugin]:list:' \
        '--cache[use cache]' \
        '--cache-location=+[cache location]:file:_files' \
        '--cache-strategy=+[cache strategy]:s:(metadata content)' \
        '--ignore-unknown[ignore unknown]' \
        '-u[ignore unknown]' \
        '--find-config-path=+[find config path]:dir:_files -/' \
        '--file-info=+[file info]:file:_files' \
        '--support-info[show support info]' \
        '*:file:_files'
}

_prettier-cli "$@"
