#compdef dnsscope
# Documentation: https://doc.powerdns.com/authoritative/manpages/dnsscope.1.html
# Analyze PCAP files of DNS traffic and produce statistics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '--rd[only process packets with RD flag set]' \
  '--ipv4=[enable/disable IPv4 packet processing]:state:(0 1)' \
  '--ipv6=[enable/disable IPv6 packet processing]:state:(0 1)' \
  '(-f --filter-name)'{-f,--filter-name=}'[restrict to packets within a domain]:domain:' \
  '--full-histogram[generate histogram with given bin-size]:msec:' \
  '--log-histogram[create log-histogram of response times]' \
  '--no-servfail-stats[exclude servfail from latency stats]' \
  '--port[source/destination port(s)]:port:_ports' \
  '--servfail-tree[identify subtrees generating servfail]' \
  '--stats-dir[output statistics files to directory]:dir:_files -/' \
  '(-l --load-stats)'{-l,--load-stats}'[output per-second load metrics]' \
  '(-w --write-failures)'{-w,--write-failures}'[write anomalous packets to PCAP]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '1:infile:_files' && ret=0

return ret
