#compdef usort
# Documentation: https://raw.githubusercontent.com/facebook/usort/main/usort/cli.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-V,--version}'[show version]' \
  '--debug[enable debug output]' \
  '--benchmark[output benchmark timing]' \
  '--native[enable native parser]' \
  '--no-native[disable native parser]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'format:format imports in files'
      'diff:show diff of import changes'
      'check:check if imports are sorted'
      'list-imports:show import blocks for troubleshooting'
    )
    _describe -t commands 'usort command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (list-imports)
        _arguments -s -S \
          '--multiples[only display files with multiple blocks]' \
          '--debug[show internal information]' \
          '*:file:_files -g "*.py"' && ret=0
        ;;
      (format|diff|check)
        _arguments -s -S \
          '*:file:_files -g "*.py"' && ret=0
        ;;
    esac
    ;;
esac

return ret
