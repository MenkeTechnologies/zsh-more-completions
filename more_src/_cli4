#compdef cli4

# Zsh completion for cli4 (cloudflare-cli4 — Cloudflare API v4)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-e --email)'{-e,--email}'[account email]:email' \
  '(-k --key)'{-k,--key}'[global API key]' \
  '(-t --token)'{-t,--token}'[API token]' \
  '(-u --url)'{-u,--url}'[API base URL]:url' \
  '*:method+args:' && ret=0

return ret
