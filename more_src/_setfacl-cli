#compdef setfacl-cli
# _setfacl-cli — Andreas Grünbacher acl setfacl set file access control lists CLI alias (acl team, C); custom argparse
# upstream: https://savannah.nongnu.org/projects/acl

_setfacl-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--access[apply to access ACL]' \
        '-a[apply to access ACL]' \
        '-b[remove all ACL entries]' \
        '--remove-all[remove all ACL entries]' \
        '-d[default ACL]' \
        '--default[default ACL]' \
        '--mask[recalculate mask]' \
        '-n[no recalculate mask]' \
        '--no-mask[no recalculate mask]' \
        '-m+[modify ACL]:str:' \
        '--modify=+[modify ACL]:str:' \
        '-M+[modify from file]:file:_files' \
        '--modify-file=+[modify from file]:file:_files' \
        '-P[no follow symlinks]' \
        '--physical[no follow symlinks]' \
        '-L[follow symlinks]' \
        '--logical[follow symlinks]' \
        '-R[recursive]' \
        '--recursive[recursive]' \
        '--restore=+[file]:file:_files' \
        '-r[recursive]' \
        '-x+[remove acl entries]:str:' \
        '--remove=+[remove acl entries]:str:' \
        '-X+[remove from file]:file:_files' \
        '--remove-file=+[remove from file]:file:_files' \
        '--set=+[set acl]:str:' \
        '--set-file=+[set acl from file]:file:_files' \
        '--test[test mode]' \
        '-k[remove default acl]' \
        '--remove-default[remove default acl]' \
        '*:files:_files'
}

_setfacl-cli "$@"
