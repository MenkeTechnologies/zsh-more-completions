#compdef licensed
# Documentation: https://github.com/licensee/licensed/tree/main/docs/commands
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'cache:cache dependency metadata'
      'env:print licensed environment'
      'list:list licenses for dependencies'
      'migrate:migrate configuration to current version'
      'notices:generate NOTICES file'
      'status:check license compliance'
      'version:show licensed version'
      'help:show help for a command'
    )
    _describe -t commands 'licensed command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-c --config)'{-c+,--config=}'[licensed config file or directory]:path:_files' \
      '--sources=[comma-separated source enabler list]:sources:' \
      '--format=[output format]:format:(yaml json)' \
      '*:path:_files' \
      && ret=0
    ;;
esac

return ret
