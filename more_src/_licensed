#compdef licensed

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'cache:cache dependency metadata'
      'list:list licenses for dependencies'
      'notice:generate NOTICES file'
      'status:check license compliance'
    )
    _describe -t commands 'licensed command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-c --config)'{-c,--config}'=[licensed config path]:file:_files' \
      '--format=[output format]:format:(json csv text markdown)' \
      '*:path:_directories' \
      && ret=0
    ;;
esac

return ret
