#compdef bashate
# _bashate — bash style linter (openstack/bashate)
# upstream: https://github.com/openstack/bashate
# Flags from bashate/bashate.py (argparse).

_bashate() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-i --ignore)'{-i+,--ignore=}'[rules to ignore (E001,E002)]:rules:' \
        '(-w --warn)'{-w+,--warn=}'[rules to treat as warnings]:rules:' \
        '(-e --error)'{-e+,--error=}'[rules to treat as errors]:rules:' \
        '--max-line-length=[max line length (default 79)]:n:' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-s --show)'{-s,--show}'[show rule descriptions]' \
        '*:file:_files'
}

_bashate "$@"
