# massmine CLI surface (decoded from `opts` list
# at massmine.scm:119-160):
#   -h / --help [TOPIC]    Help (also: -help, --h, with TOPIC: task, examples, etc.)
#   -v / --version         Version information
#   -p / --project NAME    Create project directory
#   -a / --auth FILE       Credentials file path
#   -o / --output FILE     Write data to file
#   -i / --input FILE      Load input file
#   -t / --task NAME       Task name (twitter-stream, twitter-search, twitter-trends,
#                          reddit, wikipedia, tumblr, web, youtube, etc.)
#   -q / --query STRING    Query string for searches
#   -c / --count N         Number of records to retrieve
#   -d / --dur SECONDS     Max runtime in seconds
#   -g / --geo LOCATION    Location (geo-id, country, etc.)
#   -l / --lang CODE       Language code (en, fr, es, etc.)
#   -u / --user NAME       Screen name
#   --date DATE            Date or date range (YYYY-MM-DD)
#   --config FILE          Config file
#   --no-splash            Inhibit splash screen
#   --server PORT          Start in server mode on PORT
#   --test                 Run development tests
#
# Each two-symbol option (h help)/(v version)/etc.
# automatically accepts FOUR variants: -h, -help,
# --h, --help (Chicken `args` egg quirk).
