local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# Task values from the include/import statements +
# example block (twitter-stream, twitter-search,
# twitter-trends, twitter-trends-nohash, reddit,
# wikipedia, tumblr, web, youtube)
local -a massmine_tasks=(
  'twitter-stream:realtime Twitter streaming API'
  'twitter-search:search past Twitter messages'
  'twitter-trends:current top trends'
  'twitter-trends-nohash:current top trends excluding hashtags'
  'twitter-locations:Twitter location IDs'
  'reddit:Reddit subreddit / post data'
  'wikipedia:Wikipedia page / revision data'
  'tumblr:Tumblr post data'
  'web:generic web HTTP data'
  'youtube:YouTube video / channel data'
)
# 17 named options (chicken args egg auto-expands
# each (short long) into 4 variants -h/-help/--h/
# --help; we expose the standard -h/--help pair).
_arguments -s -S \
  '(- *)'{-h,--help}'[help information (optionally with TOPIC)]:topic:(task examples task-options)' \
  '(- *)'{-v,--version}'[version information]' \
  '(-p --project)'{-p+,--project=}'[create project directory]:project name:' \
  '(-a --auth)'{-a+,--auth=}'[credentials file path]:auth file:_files' \
  '(-o --output)'{-o+,--output=}'[write data to file]:output file:_files' \
  '(-i --input)'{-i+,--input=}'[load input file]:input file:_files' \
  '(-t --task)'{-t+,--task=}'[task name]:task:->tasks' \
  '(-q --query)'{-q+,--query=}'[query string]:query:' \
  '(-c --count)'{-c+,--count=}'[number of records]:count:' \
  '(-d --dur)'{-d+,--dur=}'[max runtime in seconds]:seconds:' \
  '(-g --geo)'{-g+,--geo=}'[location (geo-id, country, etc.)]:location:' \
  '(-l --lang)'{-l+,--lang=}'[language code (en, fr, es, etc.)]:lang:' \
  '(-u --user)'{-u+,--user=}'[screen name]:user name:' \
  '--date=[date or date range (YYYY-MM-DD)]:date:' \
  '--config=[config file]:config file:_files' \
  '--no-splash[inhibit splash screen]' \
  '--server=[start in server mode on PORT]:port:' \
  '--test=[run development tests]:test:' && ret=0

case $state in
  tasks)
    _describe -t massmine_tasks 'massmine task' massmine_tasks && ret=0
    ;;
esac

return ret
