#compdef rdisc6
# Documentation: https://man.archlinux.org/man/rdisc6.8.en
# Reference accessed: 2026-05-30
# rdisc6 — ICMPv6 Router Discovery: send Router Solicitation + print Router Advertisements.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version and license]' \
  '(-1 --single -m --multiple)'{-1,--single}'[exit on first advertisement]' \
  '(-1 --single -m --multiple)'{-m,--multiple}'[wait for multiple advertisements and print all (default)]' \
  '(-n --numeric)'{-n,--numeric}'[do not DNS-resolve IPv6 addresses]' \
  '(-q --quiet -v --verbose)'{-q,--quiet}'[only display advertised IPv6 prefixes (silent on failure)]' \
  '(-q --quiet -v --verbose)'{-v,--verbose}'[show detailed information (default)]' \
  '(-r --retry)'{-r,--retry=}'[Router Discovery attempts before abort (default 3)]:N:' \
  '(-s --source)'{-s,--source=}'[IPv6 source address for solicitation packets]:ip6:' \
  '(-w --wait)'{-w,--wait=}'[wait N ms for a response before retrying (default 4000)]:ms:' \
  '1:network interface:_net_interfaces' \
  && ret=0

return ret
