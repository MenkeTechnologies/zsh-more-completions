#compdef kubetui
# Documentation: https://man.archlinux.org/search?q=kubetui
# Reference accessed: 2026-05-16

# sarub0b0/kubetui — Kubernetes TUI (`src/cmd/command.rs` + `subcommand.rs`)

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '(-s)'{-s+,--split-direction=}'[pane split]:dir:(v h)' \
  '(-n)'{-n+,--namespaces=}'[comma namespaces]:namespaces:' \
  '--context=[kube context]:context:' \
  '-A=[all namespaces true|false]:bool:(true false)' \
  '--all-namespaces=-[all namespaces true|false]:bool:(true false)' \
  '(-C)'{-C+,--kubeconfig=}'[kubeconfig path]:kubeconfig:_files' \
  '(-l)'{-l,--logging}'[enable logging]' \
  '--config-file=[config YAML]:file:_files' \
  '--pod-columns=[pod table columns comma or full]:cols:' \
  '--pod-columns-preset=[preset name]:preset:' \
  '--clipboard=[copy mode]:mode:(auto system osc52)' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'kubetui command' compadd -- completion
  ;;
rest)
  case $line[1] in
    completion)
      _arguments '2:shell:(zsh bash)' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
