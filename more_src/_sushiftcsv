#compdef sushiftcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/statics/sushiftcsv.c
# SUSHIFTCSV - apply static shifts from nearest Q-file records

local ret=1

_arguments -s -S \
  'sin=[input source Q-file]:f:_files' \
  'rin=[input receiver Q-file]:f:_files' \
  'cin=[input cdp Q-file]:f:_files' \
  'skeyloc=[source location key name]:k:' \
  'rkeyloc=[receiver location key name]:k:' \
  'ckeyloc=[cdp location key name]:k:' \
  'sstat=[source static value name]:s:' \
  'rstat=[receiver static value name]:r:' \
  'cstat=[cdp static value name]:c:' \
  'smult=[source multiplier]:s:' \
  'rmult=[receiver multiplier]:r:' \
  'cmult=[cdp multiplier]:c:' \
  'slimit=[source shift limit]:s:' \
  'rlimit=[receiver shift limit]:r:' \
  'climit=[cdp shift limit]:c:' \
  'kdist=[distance key]:k:' \
  'kmult=[distance key multiplier]:k:' \
  '*:SU file:_files' && ret=0

return ret
