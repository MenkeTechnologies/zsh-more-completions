#compdef iosnoop-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/iosnoop.8
# trace block device I/O (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-d+[device string, e.g. 202,1]:device' \
  '-i+[match type, e.g. *R* for all reads]:iotype' \
  '-n+[process name to match on I/O issue]:name' \
  '-p+[PID to match on I/O issue]:pid:_pids' \
  '-Q[use queue insert as start time]' \
  '-s[include start time of I/O in seconds]' \
  '-t[include completion time of I/O in seconds]' \
  '*:duration seconds:' && ret=0

return ret
