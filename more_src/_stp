#compdef stp
# Documentation: https://man.archlinux.org/search?q=stp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-a)-a[do not enable optimisations]' \
  '(-b)-b[print STP input back]' \
  '(-c)-c[enable check counter-example]' \
  '(-d)-d[print counter-example as bvconst]' \
  '(-e)-e[expand finite-for]' \
  '(-f)-f[flatten array reads]' \
  '(-g)-g[turn off off-line cnf gen]' \
  '-i+[input format]:fmt:(smtlib smtlib2 cvc)' \
  '-l+[time limit s]:s:' \
  '-m[use SMT-LIB1 format]' \
  '--SMTLIB1[SMT-LIB1]' \
  '--SMTLIB2[SMT-LIB2]' \
  '-n[do not return ce]' \
  '(-o)-o[output AIG]' \
  '(-p)-p[print counter-example]' \
  '(-q)-q[quick statistics]' \
  '(-r)-r[switch refinement]' \
  '(-s)-s[print statistics]' \
  '(-t)-t[print time used]' \
  '(-v)-v[verbose]' \
  '(-w)-w[witness only]' \
  '(-x)-x[hex print]' \
  '(-y)-y[print binary]' \
  '--cryptominisat[use cryptominisat]' \
  '--minisat[use minisat]' \
  '--simplifying-minisat[simplifying minisat]' \
  '--output-CNF[output cnf]' \
  '--output-bench[output bench]' \
  '--disable-cbitp[disable CBitP]' \
  '--disable-equality[disable equality]' \
  '--disable-simplifications[disable simplification]' \
  '--print-back-CVC[print back CVC]' \
  '--print-back-SMTLIB1[print back SMTLIB1]' \
  '--print-back-SMTLIB2[print back SMTLIB2]' \
  '--print-back-GDL[print back GDL]' \
  '--print-back-dot[print back dot]' \
  '*: :_files -g "*.smt *.smt2 *.cvc *.stp"' && ret=0

return ret
