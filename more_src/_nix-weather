# Reference accessed: 2026-05-16
# Source: nixpkgs (https://github.com/NixOS/nixpkgs)
# Package: nix-weather
# Type: maintainer-shipped (nixpkgs)
# Harvested: 2026-05-15

autoload -U is-at-least

_nix-weather() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--cache=[Check a specific cache]:CACHE: ' \
'-n+[Hostname of machine.]:HOST: ' \
'--name=[Hostname of machine.]:HOST: ' \
'-c+[Path to NixOS config.]:FILE: ' \
'--config=[Path to NixOS config.]:FILE: ' \
'--timestamp[Add timestamp to log output.]' \
'*-v[Verbosity level.]' \
'*--verbose[Verbosity level.]' \
'(-v --verbose)-L[Verbosity level.]' \
'(-v --verbose)--print-build-logs[Verbosity level.]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::installable -- A nix installable:' \
&& ret=0
}

(( $+functions[_nix-weather_commands] )) ||
_nix-weather_commands() {
    local commands; commands=()
    _describe -t commands 'nix-weather commands' commands "$@"
}

if [ "$funcstack[1]" = "_nix-weather" ]; then
    _nix-weather "$@"
else
    compdef _nix-weather nix-weather
fi
