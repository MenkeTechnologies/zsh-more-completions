#compdef perc
# Documentation: https://man.archlinux.org/search?q=perc
# Reference accessed: 2026-05-16

# Zsh completion for perc (crabby-utils/perc). Subcommands match clap::Subcommand.

local -a cmds
cmds=(
  'new:create a new perc project'
  'status:show project status'
  'config:manage operator credentials'
  'env:manage perc.toml environment variables'
  'deploy:deploy to configured targets'
  'dev:local docker dev environment'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--target=[deploy target]:target:' \
  '--json[machine-readable JSON output]' \
  '*'{-v,--verbose}'[increase log verbosity]' \
  '1: :{_describe '\''command'\'' cmds}' \
  '*::arguments:_default'
