#compdef cargo-release

# Zsh completion for cargo-release (Rust release workflow tool)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'release:Release a package (default)'
      'changes:Print commits since last tag'
      'version:Bump crate version'
      'hook:Run release hooks'
      'owner:Verify crate ownership'
      'config:Dump resolved config for a crate'
      'replace:Search and replace version strings'
    )
    _describe -t commands 'cargo-release command' commands && ret=0
    ;;
  args)
    local -a common_flags=(
      '-h[Print help]'
      '--help[Print help]'
      '-q[Do not print cargo log messages]'
      '--quiet[Do not print cargo log messages]'
      '-v[Use verbose output]'
      '--verbose[Use verbose output]'
      '--color=[Coloring]:when:(auto always never)'
      '--manifest-path=[Path to Cargo.toml]:file:_files'
      '-p+[Package to release]:package'
      '--package=[Package to release]:package'
      '--exclude=[Packages to exclude]:package'
      '--workspace[Release all packages in the workspace]'
      '--config=[Custom config file path]:file:_files'
      '--isolated[Do not push, publish, or tag]'
    )

    case ${words[1]} in
      release)
        _arguments -s -S \
          $common_flags \
          '--dry-run[Do not actually perform the release]' \
          '--no-confirm[Skip confirmation prompt]' \
          '--no-verify[Do not verify the contents of the package]' \
          '--no-push[Do not push to remote]' \
          '--no-tag[Do not create git tag]' \
          '--no-publish[Do not publish to crates.io]' \
          '--allow-branch=[Branches allowed for release]:branch' \
          '--sign[Sign git tag]' \
          '--sign-commit[Sign git commit]' \
          '--dependent-version=[How to handle dependent version bumps]:strategy:(upgrade fix error warn ignore)' \
          '--features=[Space-separated list of features to activate]:features' \
          '--all-features[Activate all features]' \
          '--token=[crates.io API token]:token' \
          '--registry=[Registry to publish to]:registry' \
          '--target=[Target triple for verification]:target' \
          '--execute[Actually perform the release (not dry-run)]' \
          '--prev-tag-name=[Customize how the previous tag is detected]:pattern' \
          '--tag-prefix=[Prefix for the git tag]:prefix' \
          '--tag-name=[Format string for tag name]:format' \
          '1:level:(major minor patch release rc beta alpha)' && ret=0
        ;;
      changes)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      version)
        _arguments -s -S \
          $common_flags \
          '--dry-run[Do not actually perform the version bump]' \
          '--execute[Actually perform the version bump]' \
          '1:level:(major minor patch release rc beta alpha)' && ret=0
        ;;
      hook)
        _arguments -s -S \
          $common_flags \
          '--dry-run[Do not actually run hooks]' \
          '--execute[Actually run hooks]' && ret=0
        ;;
      owner)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      config)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      replace)
        _arguments -s -S \
          $common_flags \
          '--dry-run[Do not actually perform replacements]' \
          '--execute[Actually perform replacements]' && ret=0
        ;;
    esac
    ;;
esac

return ret
