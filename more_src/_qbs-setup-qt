#compdef qbs-setup-qt
# _qbs-setup-qt — Qt Project qbs-setup-qt CLI tool detecting installed Qt5 Qt6 installations qmake paths through directory tree walking and registering them as named qbs profiles for the qbs build system so .qbs scripts can reference Qt by profile name (Qt Project team, C++); custom argparse
# upstream: https://doc.qt.io/qbs/qbs-setup-qt.html

_qbs-setup-qt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--detect[auto-detect Qt installations]' \
        '--name=+[profile name]:str:' \
        '--system-scope[system scope]' \
        '--user-scope[user scope]' \
        '--settings-dir=+[dir]:dir:_files -/' \
        '*:qmake path:_files'
}

_qbs-setup-qt "$@"
