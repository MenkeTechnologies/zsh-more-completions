#compdef impacket-dpapidump
# Documentation: https://github.com/fortra/impacket/blob/master/examples/dpapidump.py
# Remote extraction of SYSTEM DPAPI credentials and SCCM client secrets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-creds[extract SYSTEM user DPAPI credentials (default all)]' \
  '-sccm[extract SCCM client credentials (default all)]' \
  '-userkey=[dpapi_userkey for SYSTEM]:key' \
  '-ts[adds timestamp to every logging output]' \
  '-debug[turn DEBUG output ON]' \
  '-com-version=[DCOM version, format MAJOR_VERSION:MINOR_VERSION e.g. 5.7]:version' \
  '-bootkey=[bootkey for SYSTEM hive]:bootkey' \
  '-throttle=[throttle in seconds between operations]:seconds' \
  '-hashes=[NTLM hashes, format is LMHASH:NTHASH]:hashes' \
  '-no-pass[don'\''t ask for password (useful for -k)]' \
  '-k[use Kerberos authentication from ccache file]' \
  '-aesKey=[AES key to use for Kerberos authentication (128 or 256 bits)]:hexkey' \
  '-keytab=[read keys for SPN from keytab file]:file:_files' \
  '-rpc-auth-level=[level for RPC authentication]:level:(default integrity privacy)' \
  '-dc-ip=[IP address of the domain controller]:ip' \
  '-target-ip=[IP address of the target machine]:ip' \
  '1:target (\[\[domain/\]username\[:password\]@\]<host>):' && ret=0

return ret
