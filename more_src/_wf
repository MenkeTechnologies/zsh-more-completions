#compdef wf
# _wf — Tanzu Operations Wavefront wf shorthand CLI for sending direct ingestion metrics dashboards alerts events sources to a Wavefront proxy or direct-ingest endpoint with API token auth (vmwareSpectrum team, Python); argparse
# upstream: https://github.com/wavefrontHQ/python-client

_wf() {
    local -a sub=(
        'proxy:proxy operations'
        'config:config operations'
        'metric:metric operations'
        'event:event operations'
        'alert:alert operations'
        'dashboard:dashboard operations'
        'send:send metric to wavefront'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--profile=+[name]:str:' \
        '--api-url=+[url]:str:' \
        '--api-token=+[token]:str:' \
        '--proxy=+[host:port]:str:' \
        '--no-tls-verify[no TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wf subcommand' sub ;;
        args)
            case $words[1] in
                send) _arguments \
                    '--name=+[metric name]:str:' \
                    '--value=+[F]:f:' \
                    '--ts=+[unix ts]:n:' \
                    '--source=+[host]:h:_hosts' \
                    '--tags=+[csv]:str:' ;;
                metric|event|alert|dashboard) _arguments \
                    '1:action:(list show query get set delete)' \
                    '*:id:' ;;
            esac
            ;;
    esac
}

_wf "$@"
