#compdef litecoind litecoin-qt litecoin-node
# Documentation: https://github.com/litecoin-project/litecoin (src/init.cpp SetupServerArgs + configure.ac BITCOIN_DAEMON_NAME=litecoind)
# Reference accessed: 2026-05-29
# Litecoin Core daemon (Bitcoin Core fork). litecoind=monolithic, litecoin-node=multiprocess, litecoin-qt=GUI.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-version[print version and exit]' \
  '-help[print help and exit]' \
  '-?[print help and exit]' \
  '-h[print help and exit]' \
  '(-testnet -signet -regtest)-testnet[use Litecoin testnet (chain=test)]' \
  '(-testnet -signet -regtest)-signet[use Litecoin signet (chain=signet)]' \
  '(-testnet -signet -regtest)-regtest[use Litecoin regression test mode]' \
  '-chain=[chain to use]:chain:(main test signet regtest)' \
  '-datadir=[data directory]:dir:_directories' \
  '-conf=[read-only configuration file (relative to datadir)]:file:_files -g "*.conf"' \
  '-blocksdir=[directory to hold blocks subdirectory]:dir:_directories' \
  '-settings=[dynamic settings data file]:file:_files -g "*.json"' \
  '-pid=[pid file]:file:_files' \
  '-daemon[run in background as a daemon]' \
  '-daemonwait[wait for daemon initialization to finish before returning]' \
  '-debug=[output debugging information (category, or 0=none, 1=all)]:category:(net tor mempool http bench zmq walletdb rpc estimatefee addrman selectcoins reindex cmpctblock rand prune proxy mempoolrej libevent coindb qt leveldb validation i2p ipc lock util blockstorage mempool)' \
  '-debuglogfile=[debug log file]:file:_files -g "*.log"' \
  '-printtoconsole[send trace/debug info to console]' \
  '-shrinkdebugfile[shrink debug.log file on startup]' \
  '-logtimestamps[prepend debug output with timestamp]' \
  '-loglevel=[global log severity]:level:(trace debug info warning error)' \
  '-logips[include IP addresses in debug output]' \
  '-listen[accept connections from outside]' \
  '-discover[discover own IP addresses]' \
  '-port=[listen for connections on this port]:port:' \
  '-bind=[bind to given address and always listen on it]:addr:' \
  '-whitebind=[bind with permissions]:perms@addr:' \
  '-proxy=[connect through SOCKS5 proxy]:ip\:port:' \
  '-onion=[hidden Tor onion proxy (default proxy)]:ip\:port:' \
  '-i2psam=[I2P SAM proxy]:addr\:port:' \
  '-addnode=[add a node to connect to and attempt to keep the connection open]:addr:' \
  '-connect=[connect only to specified nodes (disables auto)]:addr:' \
  '-maxconnections=[maintain at most N connections]:N:' \
  '-onlynet=[only connect to nodes in network]:net:(ipv4 ipv6 onion i2p cjdns)' \
  '-dns[allow DNS lookups for -addnode/-seednode/-connect]' \
  '-dnsseed[query DNS for peers]' \
  '-server[accept command line and JSON-RPC commands]' \
  '-rest[accept public REST requests]' \
  '-rpcbind=[bind to given address to listen for JSON-RPC connections]:addr:' \
  '-rpcallowip=[allow JSON-RPC connections from specified source]:source:' \
  '-rpcauth=[username and hashed password for JSON-RPC]:auth:' \
  '-rpccookiefile=[location of the auth cookie]:file:_files' \
  '-rpcuser=[username for JSON-RPC connections]:user:' \
  '-rpcpassword=[password for JSON-RPC connections]:pw:' \
  '-rpcport=[listen for JSON-RPC on this port]:port:' \
  '-rpcworkqueue=[set the depth of the work queue]:N:' \
  '-rpcthreads=[set the number of threads to service RPC]:N:' \
  '-rpcservertimeout=[timeout during HTTP requests]:sec:' \
  '-disablewallet[do not load the wallet and disable RPC calls]' \
  '-wallet=[specify wallet path to load at startup]:name:' \
  '-walletdir=[specify directory to hold wallets]:dir:_directories' \
  '-zmqpubhashblock=[publish hash block in zmq]:addr:' \
  '-zmqpubhashtx=[publish hash tx in zmq]:addr:' \
  '-zmqpubrawblock=[publish raw block in zmq]:addr:' \
  '-zmqpubrawtx=[publish raw tx in zmq]:addr:' \
  '-prune=[reduce storage by pruning]:MiB or 1=manual:' \
  '-txindex[maintain a full transaction index]' \
  '-reindex[rebuild chain state and block index from blk files]' \
  '-reindex-chainstate[rebuild chain state only from currently indexed blocks]' \
  '-assumevalid=[skip script verification up to this block hash]:hash:' \
  '-dbcache=[set database cache size in MiB]:MiB:' \
  '-par=[set script verification threads]:N:' \
  '-maxmempool=[keep transaction memory pool below N MB]:MB:' \
  '-mempoolexpiry=[do not keep transactions in mempool longer than hrs]:hours:' \
  '-checkmempool=[run mempool consistency checks every N transactions]:N:' \
  && ret=0

return ret
