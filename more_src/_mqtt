#compdef mqtt
# Documentation: https://man.archlinux.org/search?q=mqtt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'pub:publish a message'
  'publish:publish a message'
  'sub:subscribe to topics'
  'subscribe:subscribe to topics'
  'sh:interactive shell mode'
  'shell:interactive shell mode'
  'test:test broker features'
  'hivemq:HiveMQ-specific operations'
  'swarm:HiveMQ Swarm operations'
  'version:show version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mqtt subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (pub|publish)
        _arguments \
          '(-h --host)'{-h,--host=}'[broker host]:host:_hosts' \
          '(-p --port)'{-p,--port=}'[broker port]:port:' \
          '(-V --mqttVersion)'{-V,--mqttVersion=}'[MQTT version]:ver:(3 5)' \
          '(-i --identifier)'{-i,--identifier=}'[client id]:id:' \
          '(-u --user)'{-u,--user=}'[username]:user:' \
          '(-pw --password)'{-pw,--password=}'[password]:pw:' \
          '(-s --secure)'{-s,--secure}'[use TLS]' \
          '(-t --topic)'{-t,--topic=}'[topic]:topic:' \
          '(-m --message)'{-m,--message=}'[message]:msg:' \
          '-m:file=[message file]:file:_files' \
          '-m:empty[empty message]' \
          '(-r --retain)'{-r,--retain}'[retain message]' \
          '(-q --qos)'{-q,--qos=}'[QoS level]:qos:(0 1 2)' \
          '(-e --messageExpiryInterval)'{-e,--messageExpiryInterval=}'[expiry secs]:secs:' \
          '*-d[debug]' \
          '*-v[verbose]' && ret=0
        ;;
      (sub|subscribe)
        _arguments \
          '(-h --host)'{-h,--host=}'[broker host]:host:_hosts' \
          '(-p --port)'{-p,--port=}'[broker port]:port:' \
          '(-V --mqttVersion)'{-V,--mqttVersion=}'[MQTT version]:ver:(3 5)' \
          '(-i --identifier)'{-i,--identifier=}'[client id]:id:' \
          '(-u --user)'{-u,--user=}'[username]:user:' \
          '(-pw --password)'{-pw,--password=}'[password]:pw:' \
          '(-s --secure)'{-s,--secure}'[use TLS]' \
          '*'{-t,--topic=}'[topic]:topic:' \
          '*'{-q,--qos=}'[QoS level]:qos:(0 1 2)' \
          '--output-to-file=[output file]:file:_files' \
          '--base64[base64 output]' \
          '(-J --json-output)'{-J,--json-output}'[JSON output]' \
          '(-T --show-topics)'{-T,--show-topics}'[show topics]' && ret=0
        ;;
      (test)
        _arguments \
          '(-h --host)'{-h,--host=}'[broker host]:host:_hosts' \
          '(-p --port)'{-p,--port=}'[broker port]:port:' \
          '(-V --mqttVersion)'{-V,--mqttVersion=}'[MQTT version]:ver:(3 5)' \
          '(-a --all)'{-a,--all}'[run all tests]' \
          '(-t --timeOut)'{-t,--timeOut=}'[timeout]:secs:' \
          '(-q --qosTries)'{-q,--qosTries=}'[QoS tries]:n:' && ret=0
        ;;
      (sh|shell)
        _arguments \
          '-l[log session]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-V --version)'{-V,--version}'[show version]' && ret=0
        ;;
    esac
    ;;
esac

return ret
