#compdef flux-pgrep
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-pgrep.html
# search Flux jobs by expression

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a[include jobs in all states]' \
  '-A[include jobs for all users]' \
  '(-u --user)'{-u,--user=}'[retrieve jobs for specified user]:user' \
  '(-f --filter)'{-f,--filter=}'[include jobs with specific states or results]:filter' \
  '(-q --queue)'{-q,--queue=}'[restrict results to named queue(s)]:queue' \
  '(-c --count)'{-c,--count=}'[limit output to first N matches]:n' \
  '--max-entries=[limit number of jobs to consider]:n' \
  '(-o --format)'{-o,--format=}'[specify output format]:format' \
  '(-n --no-header)'{-n,--no-header}'[suppress header line]' \
  '*:expression:_default' && ret=0

return ret
