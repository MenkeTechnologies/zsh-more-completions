#compdef custodian

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)--version[Show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcmds
    subcmds=(
      'run:Execute a policy'
      'report:Generate a report for a policy'
      'schema:Browse the resource schema'
      'validate:Validate a policy config'
      'logs:Access policy logs'
      'version:Show version'
    )
    _describe -t commands 'custodian subcommand' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[Policy config file]:config:_files' \
          '(-s --output-dir)'{-s,--output-dir}'[Output directory]:directory:_directories' \
          '(-p --policy-filter)'{-p,--policy-filter}'[Filter policies by name]:filter:' \
          '--dryrun[Dry run mode]' \
          '(-r --region)'{-r,--region}'[AWS region]:region:' \
          '--profile[AWS profile]:profile:' \
          '--assume[Role to assume]:role arn:' \
          '--log-group[CloudWatch log group]:log group:' \
          '(-m --metrics)'{-m,--metrics}'[Enable metrics]:metrics backend:' \
          '--cache[Cache directory]:cache dir:_directories' \
          '--cache-period[Cache period in seconds]:seconds:' \
          '--skip-validation[Skip policy validation]' \
          '(-v --verbose)'{-v,--verbose}'[Verbose output]' \
          '--debug[Debug output]' \
          '--help[Show help]' && ret=0
        ;;
      report)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[Policy config file]:config:_files' \
          '(-s --output-dir)'{-s,--output-dir}'[Output directory]:directory:_directories' \
          '--days[Number of days to report]:days:' \
          '--no-default-fields[Exclude default fields]' \
          '--format[Output format]:format:(csv json grid)' \
          '--field[Extra fields to include]:field:' \
          '(-r --region)'{-r,--region}'[AWS region]:region:' \
          '--help[Show help]' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '--help[Show help]' \
          '*:config files:_files' && ret=0
        ;;
      schema)
        _arguments -s -S \
          '--help[Show help]' \
          '1::resource type:' && ret=0
        ;;
      logs)
        _arguments -s -S \
          '--help[Show help]' && ret=0
        ;;
      version)
        _arguments -s -S \
          '--help[Show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
