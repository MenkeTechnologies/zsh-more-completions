#compdef ExtractSequences
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#ExtractSequences
# Picard: extract a set of intervals from a reference sequence into a FASTA

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  '--INTERVAL_LIST=[intervals to extract from the reference]:interval_list:_files -g "*.interval_list"' \
  {-R=,--REFERENCE_SEQUENCE=}'[reference sequence FASTA file]:fasta:_files -g "*.(fa|fasta)"' \
  {-O=,--OUTPUT=}'[output FASTA file]:fasta:_files -g "*.(fa|fasta)"' \
  '--LINE_LENGTH=[maximum line length for sequence data]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:interval list:_files -g "*.interval_list"' && ret=0

return ret
