#compdef argocd
# _argocd-cli — Argo CD GitOps CD platform CLI (Argo Project, Go); manage Argo CD apps + clusters + accounts
# upstream: https://github.com/argoproj/argo-cd

_argocd-cli() {
    local -a sub=(
        'account:manage local users'
        'admin:admin tasks (offline)'
        'app:manage applications'
        'appset:manage applicationsets'
        'cert:manage TLS certs'
        'cluster:manage cluster credentials'
        'completion:print shell completion'
        'context:manage contexts'
        'gpg:manage GPG keys'
        'login:login to a server'
        'logout:logout'
        'proj:manage projects'
        'relogin:re-login'
        'repo:manage repos'
        'repocreds:manage repo credential templates'
        'version:show client + server version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--auth-token+[auth token]:str:' \
        '--config+[config file]:file:_files' \
        '--core[use Core mode]' \
        '--grpc-web[use gRPC-Web]' \
        '--grpc-web-root-path+[gRPC-Web root path]:path:' \
        '-H+[server addr]:host:_hosts' \
        '--server+[server addr]:host:_hosts' \
        '--insecure[skip TLS verify]' \
        '--logformat+[log format]:fmt:(text json)' \
        '--loglevel+[log level]:level:(debug info warn error)' \
        '--plaintext[use plaintext]' \
        '--port-forward[port forward to argocd server]' \
        '--port-forward-namespace+[port-forward namespace]:ns:' \
        '--prompts-enabled[enable interactive prompts]' \
        '--redis-haproxy-name+[redis haproxy name]:str:' \
        '--redis-name+[redis name]:str:' \
        '--repo-server-name+[repo-server name]:str:' \
        '--server-name+[server name]:str:' \
        '--server-crt+[server cert]:file:_files' \
        '--client-crt+[client cert]:file:_files' \
        '--client-crt-key+[client cert key]:file:_files' \
        '--http1.1[force HTTP/1.1]' \
        '--kube-context+[kube context]:context:' \
        '--controller-name+[controller name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'argocd subcommand' sub ;;
        args)
            case $words[1] in
                app) _arguments '1:app cmd:(actions create delete delete-resource diff edit get history list logs manifests patch patch-resource resources rollback set sync sync-status terminate-op unset wait)' '*:app name:' ;;
                cluster) _arguments '1:cluster cmd:(add get list rm rotate-auth)' '*:cluster:' ;;
                repo) _arguments '1:repo cmd:(add get list rm)' '*:repo:' ;;
                proj) _arguments '1:proj cmd:(add-destination add-source allow-cluster-resource allow-namespace-resource create delete deny-cluster-resource deny-namespace-resource get list remove-destination remove-source role set windows)' '*:proj name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_argocd-cli "$@"
