#compdef detect-secrets

_detect_secrets_scan() {
  _arguments \
    '--list-all-plugins[list all available plugins]' \
    '--all-files[scan all files]' \
    '--baseline[specify baseline file]:file:_files' \
    '--force-use-all-plugins[use all plugins]' \
    '--only-allowlisted[only report allowlisted secrets]' \
    '--word-list[specify word list file]:file:_files' \
    '--custom-plugins[specify custom plugins directory]:dir:_directories' \
    '--exclude-files[exclude files matching pattern]:pattern:' \
    '--exclude-lines[exclude lines matching pattern]:pattern:' \
    '--exclude-secrets[exclude secrets matching pattern]:pattern:' \
    '--no-verify[disable verification]' \
    '--slim[produce slim baseline]' \
    '--no-keyword-scan[disable keyword scanning]' \
    '*:file:_files'
}

_detect_secrets_audit() {
  _arguments \
    '--diff[compare two baselines]' \
    '--stats[show statistics]' \
    '--report[show report]' \
    '--json[output as JSON]' \
    '--only-real[only show real secrets]' \
    '--only-false[only show false positives]' \
    '--display-results[display results]' \
    ':baseline file:_files'
}

_detect_secrets_update() {
  _arguments \
    '--no-verify[disable verification]' \
    ':baseline file:_files'
}

_detect-secrets() {
  local -a commands
  commands=(
    'scan:scan for secrets'
    'audit:audit a baseline'
    'update:update an existing baseline'
  )

  _arguments \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--verbose[enable verbose output]' \
    '1:command:->command' \
    '*::arguments:->arguments'

  case "$state" in
    command)
      _describe -t commands 'detect-secrets command' commands
      ;;
    arguments)
      case "$words[1]" in
        scan) _detect_secrets_scan ;;
        audit) _detect_secrets_audit ;;
        update) _detect_secrets_update ;;
      esac
      ;;
  esac
}

_detect-secrets "$@"
