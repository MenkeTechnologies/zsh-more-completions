#compdef chainSplit
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# split chains up by target or query sequence

local ret=1

_arguments -s -S \
  '-q[split on query (default is on target)]' \
  '-lump=[lump together so have only N split files]:n' \
  '1:out dir:_files -/' \
  '*:in chain:_files -g "*.chain"' && ret=0

return ret
