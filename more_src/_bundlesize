#compdef bundlesize bundlesize-init bundlesize-pipe
# ============================================================================
# bundlesize - Bundle size budgeting + CI budgeting (Node, MIT)
#
# Author : Siddharth Kshetrapal (siddharthkp)
# Upstream: https://github.com/siddharthkp/bundlesize
# npm    : bundlesize
#
# bundlesize is a CI-friendly bundle-size budget enforcer for
# JavaScript / TypeScript projects. Operator declares per-file
# size budgets in `package.json` (`bundlesize: [{path, maxSize,
# compression}]`); the `bundlesize` CLI globs over the matched
# files, measures their on-the-wire size after the configured
# compression (gzip / brotli / none), and fails the CI run if any
# file exceeds its budget. Integrates with GitHub status checks
# via a backend OAuth flow (`bundlesize-init` registers the
# repo), and supports stdin streaming via `bundlesize-pipe`.
#
# Three binaries shipped:
#   bundlesize       - the main budget-check CLI
#   bundlesize-init  - register a repo with the GitHub-app backend
#   bundlesize-pipe  - read stdin instead of from disk
#
# The Brotli compression lane is built on `brotli-size 0.1.0`
# (declared verbatim at upstream package.json HEAD), a thin
# wrapper over the Node stdlib `zlib.brotliCompress` API that
# returns just the compressed byte length (no allocation of the
# full compressed buffer for sizes-only use). This makes
# bundlesize one of the canonical Node consumers of the stdlib
# Brotli API - on Node 12+ the Brotli encoder/decoder is built
# into `zlib`, so no native binding or external compression lib
# is needed.
#
# ----------------------------------------------------------------------------
# AXIS 214 :: BROTLI COMPRESSION (RFC 7932)  [CLOSES]
# Round 1342 :: TS-Node slot 3 of 4 :: CLOSES Axis 214 (207th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : dropbox/rust-brotli           [R1340 _javy]
#   Go      : andybalholm/brotli            [R1341 _broccoli]
#   TS/Node : Node stdlib zlib brotli APIs  [R1342 THIS FILE]
#
# Node's brotli implementation is unique across the three lanes
# for being in the standard library (since v12, 2019). The
# Rust + Go lanes both maintain community-managed pure-language
# ports of Google's reference C brotli. The Node `zlib.brotli*`
# APIs are thin bindings to the same `google/brotli` C library
# bundled with the Node binary - which means Node's brotli is
# binary-compatible with the C reference on all three EC levels
# and the LGW (Large Window) extension.
#
# bundlesize is the canonical Node downstream consumer pattern
# for Brotli: "measure the on-the-wire size of static assets at
# CI time to enforce a budget." The same workflow runs against
# every major JS framework's CI pipeline (Next.js, Remix, Astro,
# SvelteKit, Vite) using either bundlesize directly or one of
# its downstream forks (`size-limit`, `relative-ci`, etc.).
# ============================================================================

_bundlesize() {
    case "$service" in
        bundlesize)       _bundlesize_main_args ;;
        bundlesize-init)  _bundlesize_init_args ;;
        bundlesize-pipe)  _bundlesize_pipe_args ;;
    esac
}

_bundlesize_main_args() {
    _arguments -s -S \
        '--files[file paths to check (overrides package.json)]:files:_files' \
        '--max-size[max size budget (e.g., "10 kB", "100 KB")]:size:' \
        '--compression[compression algorithm]:compression:(gzip brotli none)' \
        '--debug[print debug information]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_bundlesize_init_args() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[print help]'
}

_bundlesize_pipe_args() {
    _arguments -s -S \
        '--max-size[max size budget]:size:' \
        '--compression[compression algorithm]:compression:(gzip brotli none)' \
        '(- *)'{-h,--help}'[print help]'
}

_bundlesize "$@"
