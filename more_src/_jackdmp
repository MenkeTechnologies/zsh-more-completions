#compdef jackdmp

# jackdmp: JACK2 multi-processor server (binary `jackd` rename)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '-d[driver]:driver:(alsa coreaudio dummy firewire freebob iio loopback netadapter netone net oss portaudio sun winmme)' \
  '--driver=[driver]:driver:(alsa coreaudio dummy firewire freebob iio loopback netadapter netone net oss portaudio sun winmme)' \
  '-r[realtime priority]:n:' \
  '--realtime[realtime mode]' \
  '-R[no realtime]' \
  '--no-realtime[no realtime]' \
  '-P[port maximum]:n:' \
  '--port-max=[port maximum]:n:' \
  '-X[temporary]' \
  '--temporary[temporary]' \
  '-n[JACK server name]:name:' \
  '--name=[JACK server name]:name:' \
  '-p[number of clients]:n:' \
  '--client-timeout=[client timeout ms]:ms:' \
  '-Z[clock source]:src:(none CLOCK_REALTIME CLOCK_MONOTONIC)' \
  '-u[unlock]' \
  '--unlock[unlock]' \
  '-N[do not exec]' \
  '*::jackdmp args:_files' && ret=0
return ret
