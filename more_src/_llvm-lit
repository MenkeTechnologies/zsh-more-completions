#compdef llvm-lit lit
# Documentation: https://llvm.org/docs/CommandGuide/lit.html
# Source: llvm/llvm-project llvm/utils/lit/lit/cl_arguments.py — LLVM Integrated Tester (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    {-v,--verbose}'[show test output]' \
    {-q,--quiet}'[suppress test output, only show passes]' \
    {-s,--succinct}'[succinct output mode]' \
    '-a[show all output (alias of --show-all)]' \
    '--show-all[show all test output]' \
    '--show-suites[show all test suites]' \
    '--show-tests[show all tests]' \
    '--show-used-features[show features used by tests]' \
    '--no-progress-bar[disable progress bar]' \
    '--progress-bar[show progress bar (default)]' \
    '--no-terse-summary[no terse summary]' \
    '--terse-summary[terse summary]' \
    '--print-result-after=-[print result after Nth test]:n:_default' \
    '--relative-paths[use relative test paths]' \
    '--diagnostic-level=-[diagnostic level]:level:(warning all)' \
    '*-D+[set parameter NAME=VAL]:param:_default' \
    '--param=-[set parameter NAME=VAL]:param:_default' \
    {-o+,--output=}'[output JSON file]:file:_files' \
    '--resultdb-output=-[ResultDB JSON file]:file:_files' \
    '--time-trace-output=-[time-trace output]:file:_files' \
    '--report-failures-only[report only failed tests]' \
    '--echo-all-commands[echo all shell commands]' \
    '--allow-empty-runs[allow runs without tests]' \
    '--ignore-fail[exit 0 even on failure]' \
    '--config-prefix=-[config file prefix (default lit)]:prefix:_default' \
    {-j+,--threads=}'[run N tests in parallel]:n:_default' \
    '--workers=-[alias for --threads]:n:_default' \
    '*--path=-[add to PATH]:path:_files -/' \
    '--no-execute[do not execute tests; show only]' \
    '--timeout=-[per-test timeout (seconds)]:seconds:_default' \
    '--max-time=-[max wall time (seconds)]:seconds:_default' \
    '--max-failures=-[stop after N failures]:n:_default' \
    '--max-retries-per-test=-[retry failed test N times]:n:_default' \
    '--max-tests=-[max tests to run]:n:_default' \
    '--shuffle[shuffle test order]' \
    '--order=-[test order]:order:(lexical default random failing-first random shuffled smart)' \
    '*--filter=-[run only matching tests]:regex:_default' \
    '*--filter-out=-[skip tests matching regex]:regex:_default' \
    '*--xfail=-[mark tests as XFAIL]:tests:_default' \
    '*--xfail-not=-[mark tests as not XFAIL]:tests:_default' \
    '--exclude-xfail[exclude XFAIL tests]' \
    '*--unsupported=-[mark tests UNSUPPORTED]:tests:_default' \
    '*--unsupported-not=-[mark tests not UNSUPPORTED]:tests:_default' \
    '--time-tests[time each test]' \
    '--debug[enable lit debug output]' \
    '--per-test-coverage[record per-test coverage]' \
    '--skip-test-time-recording[skip recording test times]' \
    '--update-tests[update test files in place]' \
    '--filter-failed[only re-run previously failed tests]' \
    {-i,--incremental}'[run failed tests first]' \
    {-r+,--num-shards=}'[number of shards]:n:_default' \
    '--run-shard=-[run shard k of N]:k:_default' \
    '--no-gtest-sharding[disable GTest sharding]' \
    '--gtest-sharding[enable GTest sharding]' \
    '--min-output-interval=-[min seconds between output]:seconds:_default' \
    '--test-output=-[per-test stdout/stderr file]:file:_files' \
    '*:test path:_files' \
    && ret=0

return ret
