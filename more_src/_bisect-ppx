#compdef bisect-ppx bisect-ppx-report
# _bisect-ppx — OCaml bisect_ppx code coverage CLI alias (aantron team, OCaml); cmdliner
# upstream: https://github.com/aantron/bisect_ppx

_bisect-ppx() {
    local -a sub=(
        'summary:print summary'
        'html:generate HTML report'
        'cobertura:generate cobertura xml'
        'coveralls:generate coveralls json'
        'codecov:generate codecov json'
        'send-to:upload report'
        'merge:merge several .coverage files'
        'dump:dump coverage file'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bisect-ppx-report subcommand' sub ;;
        args)
            case $words[1] in
                html) _arguments \
                    '--coverage-path=+[coverage path]:dir:_files -/' \
                    '--source-path=+[source path]:dir:_files -/' \
                    '--output-directory=+[output dir]:dir:_files -/' \
                    '--theme=+[theme]:t:(light dark auto)' \
                    '--title=+[title]:str:' \
                    '--tab-size=+[tab size]:n:' \
                    '--expect=+[expect coverage pct]:n:' \
                    '--do-not-expect=+[do not expect pct]:n:' \
                    '--per-file[per-file]' \
                    '--verbose[verbose]' \
                    '*:coverage file:_files -g "*.coverage"' ;;
                cobertura|coveralls|codecov) _arguments \
                    '1:output file:_files' \
                    '--coverage-path=+[coverage path]:dir:_files -/' \
                    '--source-path=+[source path]:dir:_files -/' \
                    '--service-name=+[service name]:str:' \
                    '--service-job-id=+[service job id]:str:' \
                    '--service-pull-request=+[pr id]:str:' \
                    '--repo-token=+[repo token]:str:' \
                    '--git-info[include git info]' \
                    '--verbose[verbose]' ;;
                send-to) _arguments \
                    '1:target:(coveralls codecov)' \
                    '--coverage-path=+[coverage path]:dir:_files -/' \
                    '--source-path=+[source path]:dir:_files -/' \
                    '--service-name=+[service name]:str:' \
                    '--repo-token=+[repo token]:str:' \
                    '--dry-run[dry run]' ;;
                summary) _arguments \
                    '--coverage-path=+[coverage path]:dir:_files -/' \
                    '--per-file[per file]' \
                    '--verbose[verbose]' \
                    '--expect=+[expect pct]:n:' \
                    '*:coverage file:_files -g "*.coverage"' ;;
                merge) _arguments \
                    '1:output file:_files' \
                    '*:coverage files:_files -g "*.coverage"' ;;
                dump) _arguments '1:coverage file:_files -g "*.coverage"' ;;
            esac
            ;;
    esac
}

_bisect-ppx "$@"
