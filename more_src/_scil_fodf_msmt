#compdef scil_fodf_msmt
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_fodf_msmt.html
# Scilpy: compute multi-shell multi-tissue fODF via CSD

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--sh_order=[SH order for CSD]:order' \
  '--mask=[binary mask]:mask:_files' \
  '--tolerance=[tolerated gap between b-values]:tol' \
  '--skip_b0_check[skip b0 existence validation]' \
  '--sh_basis=[SH basis]:basis:(descoteaux07 tournier07 descoteaux07_legacy tournier07_legacy)' \
  '--processes=[number of sub-processes]:nbr' \
  '--not_all[only saved outputs are computed]' \
  '--wm_out_fODF=[WM fODF output]:file:_files' \
  '--gm_out_fODF=[GM fODF output]:file:_files' \
  '--csf_out_fODF=[CSF fODF output]:file:_files' \
  '--vf=[volume fraction output]:file:_files' \
  '--vf_rgb=[volume fraction RGB output]:file:_files' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_dwi:_files' \
  '2:in_bval:_files' \
  '3:in_bvec:_files' \
  '4:in_wm_frf:_files' \
  '5:in_gm_frf:_files' \
  '6:in_csf_frf:_files' && ret=0

return ret
