#compdef prettyplot

# EMBOSS prettyplot: render multiple aligned sequences with coloured columns
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequences=[aligned sequence(s)]:alignment USA:_files' \
  '-matrixfile=[scoring matrix file]:matrix:_files' \
  '-residuesperline=[residues per output line]:n:' \
  '-resbreak=[residues between split blocks]:n:' \
  '-ccolours[colour consensus characters]' \
  '-cidentity=[colour for identical residues]:colour:' \
  '-csimilarity=[colour for similar residues]:colour:' \
  '-cother=[colour for non-similar residues]:colour:' \
  '-docolour[colour by amino-acid property]' \
  '-shade=[shading scheme letters (BLPW)]:scheme:' \
  '-pair=[pair-similarity threshold values]:values:' \
  '-identity=[minimum identity %]:pct:' \
  '-box[draw boxes around blocks]' \
  '-boxcol[colour boxes]' \
  '-boxuse=[colour for box drawing]:colour:' \
  '-name[show sequence names]' \
  '-maxnamelen=[max sequence name length]:n:' \
  '-number[number residues]' \
  '-listoptions[list option settings]' \
  '-plurality=[plurality score for consensus]:n:' \
  '-consensus[show consensus row]' \
  '-collision[mark consensus collisions]' \
  '-alternative=[alternative scoring style]:style:(0 1 2 3)' \
  '-showscore=[show scores every N positions]:n:' \
  '-portrait[portrait orientation]' \
  '-graph=[graph output format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '*:alignment USA:_files' && ret=0
return ret
