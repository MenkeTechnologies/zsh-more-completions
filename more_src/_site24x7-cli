#compdef site24x7-cli site24x7
# _site24x7-cli — ManageEngine Zoho Site24x7 site24x7-cli CLI command-line frontend wrapping the Site24x7 all-in-one performance monitoring website server cloud network application observability platform REST API providing monitor monitor-group threshold action user-group on-call schedule report dashboard tag location-profile notification-profile data-collection-profile credential incident-page (Zoho ManageEngine Site24x7 team, Go); cobra
# upstream: https://www.site24x7.com/

_site24x7-cli() {
    local -a sub=(
        'login:authenticate'
        'whoami:show identity'
        'monitor:monitor operations'
        'monitor-group:monitor group operations'
        'threshold-profile:threshold profile operations'
        'notification-profile:notification profile operations'
        'user-alert-group:user alert group operations'
        'action:action operations'
        'tag:tag operations'
        'location-profile:location profile operations'
        'schedule-maintenance:scheduled maintenance ops'
        'web-page-speed:webpage speed operations'
        'aws-account:AWS account operations'
        'azure-account:Azure account operations'
        'gcp-account:GCP account operations'
        'kubernetes-account:Kubernetes account ops'
        'dashboard:dashboard operations'
        'incident:incident operations'
        'msp:MSP operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--refresh-token=+[token]:str:' \
        '--access-token=+[token]:str:' \
        '--zaaid=+[id]:str:' \
        '--data-center=+[r]:r:(US EU IN AU CN JP CA)' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '--display-name=+[name]:str:' \
        '--check-frequency=+[sec]:n:' \
        '--type=+[t]:t:(URL HTTPS HOMEPAGE FTP SMTP IMAP POP DNS PING WEBSOCKET REST-API SOAP PING-AROUND-WORLD WEB-TRANSACTION)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'site24x7 subcommand' sub ;;
        args)
            case $words[1] in
                monitor|monitor-group|threshold-profile|notification-profile|user-alert-group|action|tag|location-profile|schedule-maintenance|web-page-speed|aws-account|azure-account|gcp-account|kubernetes-account|dashboard|incident|msp) _arguments '1:op:(list get create update delete poll suspend resume)' '*:id:' ;;
            esac
            ;;
    esac
}

_site24x7-cli "$@"
