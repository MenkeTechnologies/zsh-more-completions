#compdef llamafile-server
# _llamafile-server — Mozilla Justine Tunney llamafile-server self-contained LLM server in a single file with cosmocc cross-OS binary supporting OpenAI-compatible chat completion API (Mozilla-Ocho team, C++); getopt-ish
# upstream: https://github.com/Mozilla-Ocho/llamafile

_llamafile-server() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-m+[model file]:file:_files -g "*.gguf *.bin *.llamafile"' \
        '--model=+[model file]:file:_files -g "*.gguf *.bin *.llamafile"' \
        '--mmproj=+[mmproj file]:file:_files -g "*.gguf *.bin"' \
        '--host=+[host]:str:' \
        '--port=+[port]:n:' \
        '--path=+[path]:str:' \
        '--api-key=+[key]:str:' \
        '--api-key-file=+[file]:file:_files' \
        '-c+[ctx size]:n:' \
        '--ctx-size=+[ctx size]:n:' \
        '-n+[n predict]:n:' \
        '--n-predict=+[n predict]:n:' \
        '-b+[batch size]:n:' \
        '--batch-size=+[batch size]:n:' \
        '--threads=+[N]:n:' \
        '-t+[N]:n:' \
        '--threads-batch=+[N]:n:' \
        '-tb+[N]:n:' \
        '--threads-http=+[N]:n:' \
        '--n-gpu-layers=+[N]:n:' \
        '-ngl+[N]:n:' \
        '--split-mode=+[m]:m:(layer row none)' \
        '-sm+[m]:m:(layer row none)' \
        '--main-gpu=+[N]:n:' \
        '-mg+[N]:n:' \
        '--tensor-split=+[csv]:str:' \
        '-ts+[csv]:str:' \
        '--rope-scaling=+[s]:s:(none linear yarn)' \
        '--rope-freq-base=+[F]:f:' \
        '--rope-freq-scale=+[F]:f:' \
        '--yarn-ext-factor=+[F]:f:' \
        '--yarn-attn-factor=+[F]:f:' \
        '--yarn-beta-slow=+[F]:f:' \
        '--yarn-beta-fast=+[F]:f:' \
        '--no-mmap[no mmap]' \
        '--mlock[mlock]' \
        '--no-warmup[no warmup]' \
        '--cont-batching[continuous batching]' \
        '-cb[continuous batching]' \
        '--embedding[embedding]' \
        '--metrics[expose Prometheus metrics]' \
        '--slots-endpoint-disable[disable slots endpoint]' \
        '--chat-template=+[t]:t:(chatml llama2 llama3 mistral mixtral phi3 gemma command-r openchat vicuna zephyr deepseek)' \
        '--system-prompt=+[prompt]:str:' \
        '--log-file=+[file]:file:_files' \
        '--no-display-prompt[no display prompt]' \
        '--server[server mode]' \
        '--nobrowser[no browser]'
}

_llamafile-server "$@"
