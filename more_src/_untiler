#compdef untiler
# Documentation: https://github.com/mapbox/untiler
# Mosaic web map tiles into composite TIFs at lower zoom levels

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(- *)--help[show help and exit]' \
  '1:command:((
    streamdir\:"mosaic tiles from a directory into composite TIFs"
    streammbtiles\:"convert an mbtiles file into composite zoom extent TIFs"
    inspectdir\:"stream tile coordinates from a directory"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      streamdir)
        _arguments -s -S \
          '(-c --compositezoom)'{-c,--compositezoom}'+[tile size to mosaic into]:zoom' \
          '(-z --maxzoom)'{-z,--maxzoom}'+[force a maximum zoom]:zoom' \
          '(-l --logdir)'{-l,--logdir}'+[location for log files]:dir:_directories' \
          '(-t --readtemplate)'{-t,--readtemplate}'+[input file path template]:template' \
          '(-s --scenetemplate)'{-s,--scenetemplate}'+[output scenetif filename template]:template' \
          '(-w --workers)'{-w,--workers}'+[number of workers in processing pool]:workers' \
          '(-x --no-fill)'{-x,--no-fill}'[do not fill in with lower zooms]' \
          '(-r --tile-resolution)'{-r,--tile-resolution}'+[size of input tiles]:resolution' \
          '--help[show help]' \
          '*:directory:_directories' && ret=0
        ;;
      streammbtiles)
        _arguments -s -S \
          '--co=[driver-specific creation options]:NAME=VALUE' \
          '(-c --compositezoom)'{-c,--compositezoom}'+[tile size to mosaic into]:zoom' \
          '(-z --maxzoom)'{-z,--maxzoom}'+[force a maximum zoom]:zoom' \
          '(-s --scenetemplate)'{-s,--scenetemplate}'+[output filename template]:template' \
          '(-w --workers)'{-w,--workers}'+[number of workers]:workers' \
          '(-x --no-fill)'{-x,--no-fill}'[do not fill in with lower zooms]' \
          '--help[show help]' \
          '*:mbtiles file:_files -g "*.mbtiles"' && ret=0
        ;;
      inspectdir)
        _arguments -s -S \
          '(-z --zoom)'{-z,--zoom}'+[zoom level to inspect]:zoom' \
          '--help[show help]' \
          '*:directory:_directories' && ret=0
        ;;
      *)
        _arguments '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
