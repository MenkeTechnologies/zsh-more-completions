#compdef tv tidy-viewer

# Zsh completion for tidy-viewer (tv - CSV viewer)

_arguments -s -S \
  '(-c --color)'{-c,--color}'[color level]:level:(0 1 2)' \
  '(-d --delimiter)'{-d,--delimiter}'[field delimiter]:delimiter:' \
  '(-e --extend-width-and-length)'{-e,--extend-width-and-length}'[extend display width and length]' \
  '(-f --footer)'{-f,--footer}'[show footer]' \
  '(-g --sigfig)'{-g,--sigfig}'[significant figures]:digits:' \
  '(-l --lower-column-width)'{-l,--lower-column-width}'[minimum column width]:width:' \
  '(-n --number)'{-n,--number}'[max number of rows]:rows:' \
  '(-u --upper-column-width)'{-u,--upper-column-width}'[maximum column width]:width:' \
  '(-a --color-column)'{-a,--color-column}'[column to use for color gradient]:column:' \
  '(-s --na-string)'{-s,--na-string}'[string to display for NA]:string:' \
  '(-D --debug-mode)'{-D,--debug-mode}'[enable debug mode]' \
  '(-R --no-row-numbering)'{-R,--no-row-numbering}'[disable row numbering]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:csv file:_files -g "*.csv *.tsv"' && return 0
