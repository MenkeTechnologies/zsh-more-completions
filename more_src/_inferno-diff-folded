#compdef inferno-diff-folded
# Documentation: https://man.archlinux.org/search?q=inferno-diff-folded
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--normalize[normalize sample counts]' \
  '--strip-hex[strip hex addresses from function names]' \
  '1:before folded stacks:_files' \
  '2:after folded stacks:_files' && ret=0

return ret
