#compdef inferno-diff-folded
# Documentation: https://github.com/jonhoo/inferno
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--normalize[normalize sample counts]' \
  '--strip-hex[strip hex addresses from function names]' \
  '1:before folded stacks:_files' \
  '2:after folded stacks:_files' && ret=0

return ret
