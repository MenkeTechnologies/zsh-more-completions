_mm0-rs() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _mm_cmds=(
                'compile:compile MM1/MM0 source to verification format'
                'join:join modular .mm0 files into standalone proof artifact'
                'doc:generate HTML documentation pages'
                'server:start LSP language server (feature server)'
            )
            _describe -t commands 'mm0-rs command' _mm_cmds && ret=0
            ;;
        args)
            case $words[1] in
                compile)
                    _arguments \
                        '(-n --no-proofs)'{-n,--no-proofs}'[skip proof checking]' \
                        '--warn-unnecessary-parens[warn on redundant parens]' \
                        '(-q --quiet)'{-q,--quiet}'[suppress info logs]' \
                        '(-s --strip)'{-s,--strip}'[strip debug info from output]' \
                        '(-W --warn-as-error)'{-W,--warn-as-error}'[treat warnings as errors]' \
                        '(-o --output)'{-o,--output}'=[output file path]:file:_files -g "*.(mmb|mm0)"' \
                        '1:input:_files -g "*.(mm0|mm1)"' \
                        '2:output:_files -g "*.(mmb|mm0)"' && ret=0
                    ;;
                join)
                    _arguments \
                        '(-H --no-header)'{-H,--no-header}'[omit output header block]' \
                        '(-b --bare)'{-b,--bare}'[bare-mode output (no decorations)]' \
                        '1:input:_files -g "*.mm0"' \
                        '2:output:_files -g "*.mm0"' && ret=0
                    ;;
                doc)
                    _arguments \
                        '*--only=[render only listed theorems (comma separated)]:thms:' \
                        '--open[open generated docs in browser]' \
                        '--open-to=[open specific theorem]:thm:' \
                        '--order=[proof tree ordering]:order:(pre post both)' \
                        '--src=[source-link URL prefix]:url:' \
                        '1:input:_files -g "*.(mm0|mm1)"' \
                        '2:output:_files -/' && ret=0
                    ;;
                server)
                    _arguments \
                        '(-n --no-proofs)'{-n,--no-proofs}'[skip proof checking]' \
                        '--warn-unnecessary-parens[warn on redundant parens]' \
                        '(-q --quiet)'{-q,--quiet}'[suppress info logs]' \
                        '(-s --strip)'{-s,--strip}'[strip debug info]' \
                        '(-W --warn-as-error)'{-W,--warn-as-error}'[treat warnings as errors]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_mm0-rs "$@"
