#compdef ipmosflm
# Documentation: https://www.mrc-lmb.cam.ac.uk/mosflm/mosflm/mosflm_user_guide.html
# ipMOSFLM: process diffraction images; logical-file keywords on command line

local ret=1

_arguments -s -S \
  '*:keyword or file:->kw' && ret=0

if [[ $state == kw ]]; then
  _alternative \
    'keywords:logical file:(IMAGE HKLOUT NEWMAT MATRIX SUMMARY SPOTOD COORDS GENFILE DIRECTORY TEMPLATE)' \
    'files:file:_files' && ret=0
fi

return ret
