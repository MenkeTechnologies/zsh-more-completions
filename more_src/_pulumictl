#compdef pulumictl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'completion:generate shell completion'
  'convert-version:convert versions'
  'copyright:check copyright notices'
  'cover:manipulate coverage profiles'
  'create:create commands'
  'dispatch:send GitHub repository_dispatch event'
  'download-binary:download a binary version'
  'generate:run code generator over schema'
  'get:get commands'
  'version:print version'
  'winget-deploy:create WinGet deployment'
  'help:show help'
)

_arguments -C \
  '(-D --debug)'{-D,--debug}'[debug output]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-t --token)'{-t,--token=}'[GitHub token]:token:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pulumictl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
