#compdef vivaldi vivaldi-stable vivaldi-snapshot

# Zsh completion for Vivaldi browser

_arguments -s -S \
  '--app=[run as app]:url:' \
  '--disable-extensions[disable extensions]' \
  '--disable-gpu[disable GPU hardware acceleration]' \
  '--disable-plugins[disable plugins]' \
  '--disable-sync[disable sync]' \
  '--disk-cache-dir=[disk cache directory]:directory:_files -/' \
  '--disk-cache-size=[disk cache size in bytes]:bytes:' \
  '--enable-features=[enable features]:features:' \
  '--disable-features=[disable features]:features:' \
  '--force-dark-mode[force dark mode]' \
  '--headless[run in headless mode]' \
  '--incognito[start in incognito mode]' \
  '--new-window[open a new window]' \
  '--no-default-browser-check[skip default browser check]' \
  '--no-first-run[skip first run wizards]' \
  '--no-proxy-server[disable proxy]' \
  '--password-store=[set password store backend]:backend:(basic gnome-libsecret kwallet kwallet5)' \
  '--process-per-site[use one process per site]' \
  '--profile-directory=[profile directory name]:directory:' \
  '--proxy-auto-detect[auto-detect proxy settings]' \
  '--proxy-server=[proxy server]:proxy:' \
  '--remote-debugging-port=[remote debugging port]:port:' \
  '--restore-last-session[restore last session]' \
  '--start-maximized[start maximized]' \
  '--start-fullscreen[start in fullscreen]' \
  '--user-data-dir=[user data directory]:directory:_files -/' \
  '--window-position=[set window position]:x,y:' \
  '--window-size=[set window size]:width,height:' \
  '--version[show version]' \
  '--help[show help]' \
  '*:URL:'
