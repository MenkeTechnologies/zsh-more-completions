#compdef cargo-auditable
# Documentation: https://man.archlinux.org/search?q=cargo-auditable
# Reference accessed: 2026-05-16

# https://github.com/rust-secure-code/cargo-auditable — forwards argv after `auditable` to Cargo

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::arguments to cargo:_default' && ret=0

return ret
