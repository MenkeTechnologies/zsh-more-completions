#compdef ctfphaseflip
# Documentation: https://bio3d.colorado.edu/imod/doc/man/ctfphaseflip.html
# ctfphaseflip - correct tilt series for microscope CTF by phase flipping

local ret=1

_arguments -s -S \
  '(-inp --input)'{-inp,-input}'[input stack that will be corrected]:file:_files' \
  '(-o --output)'{-o,-output}'[name of output file for the corrected views]:file:_files' \
  '(-an --angleFn)'{-an,-angleFn}'[file containing tilt angles for the input stack]:file:_files' \
  '(-inv --invert)'{-inv,-invert}'[invert the sign of the tilt angles]' \
  '(-ax --axis)'{-ax,-axis}'[angle the tilt axis is rotated from vertical]:angle' \
  '(-xt --xtilt)'{-xt,-xtilt}'[angle the specimen plane is tilted about the X axis]:angle' \
  '(-defF --defFn)'{-defF,-defFn}'[file with tilt angle ranges and defocus values]:file:_files' \
  '(-zo --zoff)'{-zo,-zoff}'[adjust defocus for the given displacement in Z]:offset' \
  '(-xf --xform)'{-xf,-xform}'[file with the linear transformations]:file:_files' \
  '(-defT --defTol)'{-defT,-defTol}'[defocus tolerance in nanometers]:tolerance' \
  '(-m --maxWidth)'{-m,-maxWidth}'[maximum width of strips in pixels]:width' \
  '(-iW --iWidth)'{-iW,-iWidth}'[distance in pixels between strip centers]:width' \
  '(-ze --zero)'{-ze,-zero}'[minimum spacing between successive zeros]:spacing' \
  '(-pi --pixelSize)'{-pi,-pixelSize}'[image pixel size of the input file in nanometers]:size' \
  '(-un --unbinned)'{-un,-unbinned}'[pixel size in nanometers of the original images]:size' \
  '(-e --expanded)'{-e,-expanded}'[value of ExpandByFactor used in Newstack]:factor' \
  '(-vo --volt)'{-vo,-volt}'[microscope voltage in kV]:voltage' \
  '-cs[microscope spherical aberration in millimeters]:value' \
  '(-am --ampContrast)'{-am,-ampContrast}'[fraction of amplitude contrast]:fraction' \
  '(-deg --degPhase)'{-deg,-degPhase}'[fixed value for the phase shift in degrees]:degrees' \
  '(-ph --phase)'{-ph,-phase}'[fixed value for the phase plate shift]:value' \
  '(-cu --cuton)'{-cu,-cuton}'[fixed value for cut-on frequency]:frequency' \
  '(-sc --scale)'{-sc,-scale}'[scale frequency components by CTF power]:value' \
  '(-g --gpu)'{-g,-gpu}'[use the GPU for computations]:value' \
  '(-ac --action)'{-ac,-action}'[action to take when the GPU cannot be used]:two ints' \
  '(-vi --views)'{-vi,-views}'[starting and ending views to correct]:start,end' \
  '(-t --totalViews)'{-t,-totalViews}'[starting and ending views needing correction]:start,end' \
  '(-b --boundary)'{-b,-boundary}'[file with information about boundaries]:file:_files' \
  '(-sk --skipFlag)'{-sk,-skipFlag}'[control setting the CTF-corrected flag]:value' \
  '(-deb --debug)'{-deb,-debug}'[value to control debug output]:value' \
  '(-pa --param)'{-pa,-param}'[read parameter entries from this file]:file:_files' \
  '(-h --help)'{-h,-help}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
