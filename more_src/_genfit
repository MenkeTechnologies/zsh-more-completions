#compdef genfit genfit2 genfit-cli
# _genfit — GenFit collaboration generic track-fitting framework for high-energy physics Belle II PANDA neutrino experiments (genfit team, C++); custom argparse
# upstream: https://github.com/GenFit/GenFit

_genfit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i+[input root file]:file:_files -g "*.root"' \
        '--input=+[input root file]:file:_files -g "*.root"' \
        '-o+[output root file]:file:_files -g "*.root"' \
        '--output=+[output root file]:file:_files -g "*.root"' \
        '-n+[number of events]:n:' \
        '--num-events=+[number of events]:n:' \
        '-t+[tree name]:str:' \
        '--tree=+[tree name]:str:' \
        '-c+[config file]:file:_files -g "*.json *.cfg *.ini"' \
        '--config=+[config file]:file:_files -g "*.json *.cfg *.ini"' \
        '-d[debug level]' \
        '--debug-level=+[level]:n:' \
        '-f+[fitter]:f:(KalmanFitter KalmanFitterRefTrack DAF GBL)' \
        '--fitter=+[fitter]:f:(KalmanFitter KalmanFitterRefTrack DAF GBL)' \
        '--detector=+[detector]:d:(silicon TPC drift muon pixel mixed)' \
        '--material-effects=+[bool]:b:(true false)' \
        '--energy-loss=+[bool]:b:(true false)' \
        '--multiple-scattering=+[bool]:b:(true false)' \
        '--magnetic-field=+[field]:str:' \
        '--max-iterations=+[N]:n:' \
        '--rel-chi2-change=+[F]:f:' \
        '--rep=+[track rep]:r:(rkrep helixrep)' \
        '*:input root file:_files -g "*.root *.dat *.txt"'
}

_genfit "$@"
