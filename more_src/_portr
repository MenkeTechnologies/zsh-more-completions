#compdef portr
# Documentation: https://portr.dev/docs/client/installation/
# portr - expose local servers to the internet (self-hostable tunnel)

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(http tcp auth logs)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      http)
        _arguments -s \
          '--subdomain=[pin the tunnel to a subdomain]:subdomain:' \
          '*:port:' && ret=0
        ;;
      tcp)
        _arguments -s '*:port:' && ret=0
        ;;
      auth)
        _arguments -s \
          '1:subcommand:(set)' \
          '--token=[authentication token]:token:' \
          '--remote=[server address]:remote:' && ret=0
        ;;
      logs)
        _arguments -s \
          '--json[emit stored records as JSON]' \
          '*:subdomain:' && ret=0
        ;;
    esac
    ;;
esac

return ret
