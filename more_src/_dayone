#compdef dayone
# Documentation: https://dayoneapp.com/guides/tips-and-tutorials/command-line-interface-cli/
# dayone - Day One journal command line interface (formerly dayone2)

local ret=1
local line

_arguments -s -C \
  '(-h --help)'{-h,--help}'[display help documentation]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '--verbose[enable verbose logging to stderr]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'dayone command' '(new:create a new journal entry)' && ret=0
    ;;
  args)
    case $line[1] in
      new)
        _arguments -s \
          '(-j --journal)'{-j,--journal}'=[target journal by name]:journal:' \
          '(-d --date)'{-d,--date}'=[entry date/time yyyy-mm-dd]:date:' \
          '(-z --time-zone)'{-z,--time-zone}'=[timezone IANA name or GMT offset]:tz:' \
          '(-s --starred)'{-s,--starred}'[star the entry]' \
          '(-t --tags)'{-t,--tags}'=[assign one or more tags]:tags:' \
          '--all-day[mark entry as all-day event]' \
          '(-p --photos)'{-p,--photos}'=[deprecated, use attachments]:photos:_files' \
          '(-a --attachments)'{-a,--attachments}'=[add up to 10 attachment files]:files:_files' \
          '--coordinate=[set location via latitude and longitude]:coordinate:' \
          '--isoDate=[date in ISO 8601 format]:isodate:' \
          '--no-stdin[ignore standard input]' \
          '*:text:' && ret=0
        ;;
    esac
    ;;
esac

return ret
