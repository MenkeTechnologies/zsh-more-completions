#compdef growy
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Grow a spectrum into the columns of an image

local ret=1

_arguments -s -S \
  'SPECTRUM=[spectrum to be grown into image]:spectrum:_files' \
  'IMAGE=[image to grow spectrum into]:image:_files' \
  'XSTART=[first cross-section to copy spectrum into]:xstart:' \
  'XEND=[last cross-section to copy spectrum into]:xend:' \
  'NEW=[force creation of a new image]:new:(TRUE FALSE)' \
  'XSIZE=[X dimension of new image]:xsize:' \
  '*:NDF data file:_files' && ret=0

return ret
