#compdef scdl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'me:download authenticated user content'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-l[track/playlist/user URL]:url:' \
  '-s[search query]:query:' \
  '-a[all user tracks (incl reposts)]' \
  '-t[only user uploads]' \
  '-f[user favorites/likes]' \
  '-C[tracks user commented on]' \
  '-p[all user playlists]' \
  '-r[all user reposts]' \
  '-c[continue if files exist]' \
  '--force-metadata[re-apply metadata]' \
  '-o[start playlist at track N]:offset:' \
  '--addtimestamp[prefix timestamp]' \
  '--addtofile[add artist to filename]' \
  '--debug[debug log level]' \
  '--error[error log level]' \
  '--download-archive=[track downloaded IDs]:file:_files' \
  '--extract-artist[extract artist from title]' \
  '--hide-progress[hide progress bar]' \
  '--hidewarnings[suppress warnings]' \
  '--max-size=[skip files above]:size:' \
  '--min-size=[skip files below]:size:' \
  '--no-playlist-folder[flatten playlists]' \
  '--onlymp3[MP3 only]' \
  '--path=[download directory]:dir:_files -/' \
  '--remove[delete files not in session]' \
  '--sync=[sync archive file]:file:_files' \
  '--flac[convert lossless to FLAC]' \
  '--no-album-tag[no shared album cover]' \
  '--original-art[full-res cover art]' \
  '--original-name[keep original filenames]' \
  '--original-metadata[keep original metadata]' \
  '--no-original[skip originals]' \
  '--only-original[only tracks with originals]' \
  '--name-format=[filename format]:fmt:' \
  '--playlist-name-format=[playlist filename format]:fmt:' \
  '--client-id=[client ID]:id:' \
  '--auth-token=[auth token]:token:' \
  '--overwrite[replace existing]' \
  '--strict-playlist[abort playlist on failure]' \
  '--add-description[save descriptions]' \
  '--no-playlist[skip playlists]' \
  '--opus[prefer Opus]' \
  '--yt-dlp-args=[pass-through to yt-dlp]:args:' \
  '1: :->subcommand' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'scdl subcommand' subcommands && ret=0
    ;;
esac

return ret
