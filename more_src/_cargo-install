#compdef cargo-install
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-install.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for cargo install

_arguments -s -S \
  '1:crate name:' \
  '--version=[specify version to install]:version:' \
  '--git=[git URL to install from]:url:' \
  '--branch=[branch to use when installing from git]:branch:' \
  '--tag=[tag to use when installing from git]:tag:' \
  '--rev=[specific commit to use when installing from git]:rev:' \
  '--path=[local filesystem path to install from]:path:_files -/' \
  '--list[list all installed packages]' \
  '--root=[directory to install packages into]:directory:_files -/' \
  '(-f --force)'{-f,--force}'[force overwriting existing crates]' \
  '(-n --dry-run)'{-n,--dry-run}'[perform checks without installing (unstable)]' \
  '--no-track[do not save tracking information]' \
  '*--bin=[install only specified binary]:binary:' \
  '--bins[install all binaries]' \
  '*--example=[install only specified example]:example:' \
  '--examples[install all examples]' \
  '(-F --features)'{-F+,--features=}'[space or comma separated list of features]:features:' \
  '--all-features[activate all available features]' \
  '--no-default-features[do not activate default feature]' \
  '--target=[build for target triple]:target triple:' \
  '--target-dir=[directory for generated artifacts]:dir:_files -/' \
  '--profile=[install with specified profile]:profile:(dev release test bench)' \
  '--debug[build with dev profile instead of release]' \
  '--timings[output compilation timing information]' \
  '--keep-going[build as many crates as possible, do not abort on first failure]' \
  '--ignore-rust-version[ignore rust-version specification]' \
  '(-j --jobs)'{-j+,--jobs=}'[number of parallel jobs]:jobs:' \
  '--index=[registry index to install from]:index url:' \
  '--registry=[registry to install from]:registry:' \
  '(-v --verbose)*'{-v,--verbose}'[use verbose output (specify twice for very verbose)]' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '--color=[coloring]:when:(auto always never)' \
  '--message-format=[output format]:format:(human short json json-diagnostic-short json-diagnostic-rendered-ansi json-render-diagnostics)' \
  '--frozen[require Cargo.lock and cache are up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without accessing the network]' \
  '--config=[override configuration value]:KEY=VALUE:' \
  '-C[change working directory before execution]:dir:_files -/' \
  '*-Z[unstable (nightly-only) flag]:flag:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::args:_default'
