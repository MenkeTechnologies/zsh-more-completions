#compdef GetSampleName
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/GetSampleName.java
# GATK4: emit the sample name from a BAM/CRAM read group

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-I --input)'{-I,--input}'[input BAM/CRAM file]:file:_files -g "*.(bam|cram|sam)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-O --output)'{-O,--output}'[output file with only the sample name in it]:file:_files' \
  '(--encode --use-url-encoding)'{--encode,--use-url-encoding}'[URL-encode spaces and special characters in sample name]' \
  '*:options:_files' && ret=0

return ret
