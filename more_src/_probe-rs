#compdef probe-rs
# Documentation: https://github.com/probe-rs/probe-rs/blob/master/probe-rs-tools/src/bin/probe-rs/main.rs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for probe-rs - embedded debugging and flashing CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list all connected debug probes'
  'info:gets info about the selected debug probe and connected target'
  'gdb:run a GDB server'
  'dap-server:Debug Adapter Protocol (DAP) server'
  'debug:basic command line debugger'
  'download:download memory to attached target'
  'erase:erase all nonvolatile memory of attached target'
  'verify:compare memory to attached target'
  'run:flash and run an ELF program'
  'attach:attach to rtt logging'
  'reset:reset the target attached to the selected debug probe'
  'read:read from target memory'
  'write:write to target memory'
  'chip:inspect internal registry of supported chips'
  'trace:trace a memory location on the target'
  'itm:configure and monitor ITM trace packets'
  'benchmark:measure throughput of the selected debug probe'
  'profile:profile on-target runtime performance'
  'serve:start a server that accepts remote connections'
  'mi:machine interface'
  'complete:generate shell completions'
)

local -a common_flags=(
  '--chip[target chip name]:chip:'
  '--chip-description-path[YAML chip description file]:file:_files -g "*.(yaml|yml)"'
  '--probe[probe selector (VID:PID[:SERIAL])]:selector:'
  '--speed[protocol speed in kHz]:speed:'
  '--connect-under-reset[connect to chip with reset asserted]'
  '--allow-erase-all[allow erasing the entire chip]'
  '--protocol[wire protocol]:protocol:(swd jtag)'
  '--log[log level filter]:filter:(off error warn info debug trace)'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-V --version)'{-V,--version}'[show probe-rs version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'probe-rs command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (list)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (info)
        _arguments $common_flags && ret=0
        ;;
      (download|run|verify)
        _arguments $common_flags \
          '--format[binary format]:format:(elf hex bin idf uf2)' \
          '--base-address[base address for bin files]:address:' \
          '--skip[skip bytes from start of file]:bytes:' \
          '--disable-progressbars[disable progress bars]' \
          '--disable-double-buffering[disable flash double-buffering]' \
          '--restore-unwritten[restore flash bytes that would be overwritten]' \
          '--preverify[check if data is already present before writing]' \
          '--no-verify[skip verification after flashing]' \
          '--catch-hardfault[break on hardfault]' \
          '--catch-reset[break on reset]' \
          '--rtt-scan-memory[scan memory for RTT control block]' \
          '*:file:_files' && ret=0
        ;;
      (erase)
        _arguments $common_flags && ret=0
        ;;
      (reset)
        _arguments $common_flags \
          '--assert-under-reset[keep reset asserted]' && ret=0
        ;;
      (gdb)
        _arguments $common_flags \
          '--gdb-connection-string[GDB listen address]:addr:' \
          '*:file:_files' && ret=0
        ;;
      (dap-server)
        _arguments \
          '--port[port to listen on]:port:' \
          '--vscode[report errors to VSCode]' && ret=0
        ;;
      (read)
        _arguments $common_flags \
          '1:width:(b h w)' \
          '2:address:' \
          '3:words:' && ret=0
        ;;
      (write)
        _arguments $common_flags \
          '1:width:(b h w)' \
          '2:address:' \
          '*:value:' && ret=0
        ;;
      (chip)
        _arguments \
          '1:subcommand:(list info)' \
          '2:chip name:' && ret=0
        ;;
      (complete)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
