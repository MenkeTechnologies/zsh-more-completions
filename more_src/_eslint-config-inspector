#compdef eslint-config-inspector
# Documentation: https://www.npmjs.com/package/@eslint/config-inspector
# Reference accessed: 2026-05-23
# Verified: npx @eslint/config-inspector --help (eslint-config-inspector bin alias).

# Zsh completion for eslint-config-inspector - alias bin for @eslint/config-inspector

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build inspector for static hosting'
  'mcp:start MCP server exposing the inspector'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[ESLint config file path]:file:_files' \
  '--files[include matched file paths in payload]' \
  '--no-files[omit matched file paths from payload]' \
  '--basePath=[base directory for globs]:dir:_directories' \
  '--host=[host to bind]:host:' \
  '--port=[port to bind]:port:' \
  '--open[open browser]' \
  '--no-open[do not open browser]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'eslint-config-inspector command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
