#compdef dstack

# Zsh completion for dstack
# Upstream: ML workflow orchestration system designed for reproducibility and collaboration
# Conservative fallback — run `dstack --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
