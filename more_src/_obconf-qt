#compdef obconf-qt

# obconf-qt: Qt configuration tool for the Openbox window manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--config-file=[config file]:file:_files' \
  '--theme=[start on theme tab]:theme:' \
  '*::obconf-qt args:_files' && ret=0
return ret
