#compdef pixi
# Documentation: https://man.archlinux.org/search?q=pixi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add a dependency to manifest'
  'auth:authenticate against channels'
  'build:build conda packages'
  'clean:clean cache or environments'
  'completion:generate shell completion'
  'config:configuration management'
  'exec:run command in temporary env'
  'global:manage global env packages'
  'help:show help'
  'info:show info about project'
  'init:initialize a new project'
  'install:install dependencies'
  'list:list installed packages'
  'lock:update lockfile'
  'project:project management'
  'remove:remove a dependency'
  'run:run a task'
  'search:search packages'
  'self-update:update pixi'
  'shell:start a shell in env'
  'shell-hook:print shell hook'
  'task:manage project tasks'
  'tree:display dependency tree'
  'update:update dependencies'
  'upload:upload packages'
  'workspace:workspace management'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--quiet[quiet]' \
  '*-q[quiet]' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '*--color=[color mode]:m:(always never auto)' \
  '*--no-progress[disable progress bars]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pixi command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '(--manifest-path)--manifest-path=[manifest path]:file:_files -g "pixi.toml *.toml"' \
          '(--host)*--host[host dependency]' \
          '(--build)*--build[build dependency]' \
          '(--pypi)--pypi[pypi dependency]' \
          '(-p --platform)*'{-p+,--platform=}'[platform]:p:(linux-64 linux-aarch64 linux-ppc64le osx-64 osx-arm64 win-64)' \
          '(-f --feature)'{-f+,--feature=}'[feature]:feat:' \
          '(--no-install)--no-install[skip install]' \
          '(--no-lockfile-update)--no-lockfile-update[skip lockfile update]' \
          '(--editable)--editable[editable install]' \
          '(--git)*--git=[git URL]:url:' \
          '(--branch)--branch=[branch]:b:' \
          '(--tag)--tag=[tag]:t:' \
          '(--rev)--rev=[revision]:r:' \
          '(--path)*--path=[local path]:dir:_files -/' \
          '*:package:' && ret=0 ;;
      (run)
        _arguments \
          '(--manifest-path)--manifest-path=[manifest]:file:_files' \
          '(-e --environment)'{-e+,--environment=}'[environment]:env:' \
          '(--clean-env)--clean-env[clean env vars]' \
          '(--no-install)--no-install[no install]' \
          '*:task:' && ret=0 ;;
      (install)
        _arguments \
          '(--manifest-path)--manifest-path=[manifest]:file:_files' \
          '(--frozen)--frozen[frozen]' \
          '(--locked)--locked[locked]' \
          '(--no-install)--no-install[no install]' \
          '(-e --environment)*'{-e+,--environment=}'[environment]:env:' \
          '(-a --all)'{-a,--all}'[all environments]' \
          '*: :' && ret=0 ;;
      (init)
        _arguments \
          '(--channel -c)*'{-c+,--channel=}'[conda channel]:channel:' \
          '(--platform -p)*'{-p+,--platform=}'[platform]:p:' \
          '(--import)--import=[env yaml]:file:_files' \
          '(--format)--format=[format]:f:(pixi pyproject)' \
          '(--scm)--scm=[scm]:s:(git github gitlab none)' \
          '*: :_files -/' && ret=0 ;;
      (remove)
        _arguments \
          '(--manifest-path)--manifest-path=[manifest]:file:_files' \
          '(--host)*--host[host]' \
          '(--build)*--build[build]' \
          '(--pypi)--pypi[pypi]' \
          '(-p --platform)*'{-p+,--platform=}'[platform]:p:' \
          '(-f --feature)'{-f+,--feature=}'[feature]:feat:' \
          '*:package:' && ret=0 ;;
      (search)
        _arguments \
          '(-c --channel)*'{-c+,--channel=}'[channel]:c:' \
          '(-p --platform)'{-p+,--platform=}'[platform]:p:' \
          '(-l --limit)'{-l+,--limit=}'[limit]:n:' \
          '*:query:' && ret=0 ;;
      (global)
        _arguments \
          '1:subcommand:(install list remove update upgrade upgrade-all expose sync edit shortcut)' \
          '*: :' && ret=0 ;;
      (project|workspace)
        _arguments \
          '1:subcommand:(channel description environment export name platform system-requirements version)' \
          '*: :' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(append edit list prepend set unset)' \
          '*: :' && ret=0 ;;
      (auth)
        _arguments \
          '1:subcommand:(login logout)' \
          '*: :' && ret=0 ;;
      (task)
        _arguments \
          '1:subcommand:(add alias list remove)' \
          '*: :' && ret=0 ;;
      (exec)
        _arguments \
          '(-s --spec)*'{-s+,--spec=}'[package spec]:s:' \
          '(-c --channel)*'{-c+,--channel=}'[channel]:c:' \
          '(--force-reinstall)--force-reinstall[force reinstall]' \
          '*: :_command_names -e' && ret=0 ;;
      (clean)
        _arguments \
          '1:subcommand:(cache)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '(-s --shell)'{-s+,--shell=}'[shell]:shell:(bash zsh fish powershell elvish nushell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
