#compdef sfunif2
# Documentation: http://www.ahay.org/RSF/sfunif2.html
# Madagascar: generate a 2-D layered velocity model from interfaces

local ret=1

_arguments -s \
  'n1=[number of depth samples]:n1' \
  'd1=[depth axis sampling]:d1' \
  'o1=[depth origin]:o1' \
  'label1=[depth axis label]:label1' \
  'unit1=[depth axis unit]:unit1' \
  'x0=[interface x-coordinates]:x0' \
  'z0=[interface z-coordinates]:z0' \
  'v00=[velocity values per layer]:v00' \
  'dvdx=[velocity gradient in x per layer]:dvdx' \
  'dvdz=[velocity gradient in z per layer]:dvdz' \
  '*:rsf file:_files' && ret=0

return ret
