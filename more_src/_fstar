#compdef fstar fstar.exe

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--admit_smt_queries[admit all SMT queries]' \
  '--cache_checked_modules[cache checked modules]' \
  '--cache_dir=[cache directory]:dir:_files -/' \
  '--codegen=[code generation target]:target:(OCaml FSharp Kremlin Plugin)' \
  '--codegen-lib=[code generation library]:lib:' \
  '--debug=[debug module]:module:' \
  '--detail_errors[detailed error messages]' \
  '--detail_hint_replay[detailed hint replay]' \
  '--dump_module=[dump module]:module:' \
  '--eager_subtyping[enable eager subtyping]' \
  '--ext=[extension]:extension:' \
  '--extract_all[extract all modules]' \
  '--extract_module=[extract module]:module:' \
  '--extract_namespace=[extract namespace]:namespace:' \
  '--fuel=[fuel for unfolding]:fuel:' \
  '--ifuel=[fuel for inverting]:fuel:' \
  '--include=[include path]:path:_files -/' \
  '--lax[lax type-checking]' \
  '--load=[load module]:module:' \
  '--log_types[log type constraints]' \
  '--log_queries[log SMT queries]' \
  '--MLish[MLish mode]' \
  '--no_default_includes[do not include default paths]' \
  '--no_extract=[do not extract module]:module:' \
  '--no_location_info[disable location info]' \
  '--no_smt[disable SMT]' \
  '--odir=[output directory]:dir:_files -/' \
  '--print_bound_var_types[print bound variable types]' \
  '--print_effect_args[print effect arguments]' \
  '--print_full_names[print fully qualified names]' \
  '--print_implicits[print implicit arguments]' \
  '--print_universes[print universe levels]' \
  '--prn[print return types]' \
  '--query_stats[print query statistics]' \
  '--quake=[quake mode]:repetitions:' \
  '--record_hints[record verification hints]' \
  '--retry=[retry failed queries]:count:' \
  '--silent[silent mode]' \
  '--smt=[SMT solver]:solver:_files' \
  '--smtencoding.elim_box=[box elimination]:bool:(true false)' \
  '--smtencoding.l_arith_repr=[arithmetic representation]:repr:(native boxwrap)' \
  '--smtencoding.nl_arith_repr=[nonlinear arithmetic]:repr:(native wrapped boxwrap)' \
  '--tactic_trace[trace tactics]' \
  '--timing[show timing information]' \
  '--trace_error[trace error messages]' \
  '--ugly[ugly printing]' \
  '--unsafe_tactic_exec[allow unsafe tactic execution]' \
  '--use_hints[use verification hints]' \
  '--use_hint_hashes[use hint hashes]' \
  '--using_facts_from=[use facts from modules]:modules:' \
  '--vcgen.optimize_bind_as_seq[optimize binds]' \
  '--verify_all[verify all modules]' \
  '--verify_module=[verify specific module]:module:' \
  '--warn_error=[warning/error configuration]:config:' \
  '--z3cliopt=[Z3 CLI option]:option:' \
  '--z3refresh[refresh Z3 process between queries]' \
  '--z3rlimit=[Z3 resource limit]:limit:' \
  '--z3rlimit_factor=[Z3 resource limit factor]:factor:' \
  '--z3seed=[Z3 random seed]:seed:' \
  '*:F* source file:_files -g "*.fst(|i)"' && ret=0

return ret
