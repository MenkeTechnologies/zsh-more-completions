#compdef mshowfat
# Documentation: https://man.archlinux.org/search?q=mshowfat
# Reference accessed: 2026-05-16

# mshowfat: show FAT entries (mtools utility)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-i[image file]:file:_files' \
  '-V[show version]' \
  '*:MS-DOS path:_files' && ret=0
return ret
