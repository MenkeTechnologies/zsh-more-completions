#compdef rqlite rqlited

local curcontext="$curcontext" state line ret=1

case $service in
  (rqlite)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '-H+[host]:host:_hosts' \
      '-p+[port]:port:' \
      '-P+[protocol]:p:(http https)' \
      '--scheme+[scheme]:s:(http https)' \
      '-u+[user:pass]:auth:' \
      '--user+[user]:user:_users' \
      '--password+[password]:pass:' \
      '-i+[input file]:file:_files -g "*.sql"' \
      '-q+[query string]:q:' \
      '-n+[connect timeout s]:s:' \
      '-t+[client cert]:file:_files' \
      '-k+[client key]:file:_files' \
      '--ca-cert+[CA cert]:file:_files' \
      '--no-verify[skip TLS verify]' \
      '--token+[bearer token]:t:' \
      '*: :' && ret=0 ;;
  (rqlited)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '-node-id+[node id]:id:' \
      '-http-addr+[HTTP listen addr]:addr:' \
      '-http-adv-addr+[HTTP advertise addr]:addr:' \
      '-http-allow-origin+[CORS origin]:origin:' \
      '-http-ca-cert+[HTTP CA cert]:file:_files' \
      '-http-cert+[HTTP cert]:file:_files' \
      '-http-key+[HTTP key]:file:_files' \
      '-http-verify-client[verify client]' \
      '-auth+[auth file]:file:_files -g "*.json"' \
      '-bootstrap-expect+[bootstrap expected nodes]:n:' \
      '-bootstrap-expect-timeout+[bootstrap timeout]:t:' \
      '-disco-mode+[discovery mode]:m:(consul etcd dns dns-srv)' \
      '-disco-config+[discovery config]:cfg:' \
      '-disco-key+[discovery key]:key:' \
      '-fk[foreign keys constraint]' \
      '-join+[join address]:addr:' \
      '-join-attempts+[join attempts]:n:' \
      '-join-interval+[join interval]:t:' \
      '-node-cert+[node TLS cert]:file:_files' \
      '-node-key+[node TLS key]:file:_files' \
      '-node-ca-cert+[node CA cert]:file:_files' \
      '-node-verify-client[node verify client]' \
      '-on-disk[use on-disk SQLite]' \
      '-on-disk-path+[on-disk SQLite path]:file:_files' \
      '-on-disk-startup[on-disk startup]' \
      '-raft-addr+[raft listen addr]:addr:' \
      '-raft-adv-addr+[raft advertise]:addr:' \
      '-raft-apply-timeout+[raft apply timeout]:t:' \
      '-raft-heartbeat-timeout+[raft heartbeat timeout]:t:' \
      '-raft-election-timeout+[raft election timeout]:t:' \
      '-raft-leader-lease-timeout+[raft leader lease]:t:' \
      '-raft-shutdown-stepdown[shutdown stepdown]' \
      '-raft-snap+[raft snapshot threshold]:n:' \
      '-raft-snap-int+[raft snap interval]:t:' \
      '-raft-log-level+[raft log level]:l:(DEBUG INFO WARN ERROR)' \
      '-raft-no-freelist-sync[no freelist sync]' \
      '-raft-non-voter[run as non-voter]' \
      '*: :_files -/' && ret=0 ;;
esac

return ret
