#compdef wcalc
# Documentation: https://manpages.debian.org/testing/wcalc/wcalc.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-H,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d -dec --decimal)'{-d,-dec,--decimal}'[base 10 output (default)]' \
  '(-h -hex --hexadecimal)'{-h,-hex,--hexadecimal}'[base 16 output with 0x prefix]' \
  '(-o -oct --octal)'{-o,-oct,--octal}'[base 8 output with 0 prefix]' \
  '(-b -bin --binary)'{-b,-bin,--binary}'[base 2 output with 0b prefix]' \
  '(-p --prefixes)'{-p,--prefixes}'[toggle base prefixes]' \
  '-E[scientific notation output]' \
  '-EE[disable scientific notation]' \
  '-P-[decimal places to display (-1 for auto)]:digits:' \
  '(-q --quiet)'{-q,--quiet}'[toggle equals sign before results]' \
  '(-C --color)'{-C,--color}'[toggle colored output]' \
  '(-l --lenient)'{-l,--lenient}'[assume undefined vars equal zero]' \
  '(-r --radians)'{-r,--radians}'[toggle radians mode]' \
  '(-c --conservative)'{-c,--conservative}'[toggle FP accuracy guards]' \
  '--remember[toggle error expression history]' \
  '--dsep=[decimal separator character]:char:' \
  '--tsep=[thousands separator character]:char:' \
  '--idsep=[input-only decimal separator]:char:' \
  '--itsep=[input-only thousands separator]:char:' \
  '--bits=[internal precision bits (default 1024)]:n:' \
  '--ints[toggle long integer abbreviation]' \
  '--round=[rounding indication]:method:(none simple sig_fig)' \
  '--verbose[display expressions before calculating]' \
  '--defaults[skip reading .wcalcrc]' \
  '(-u --units)'{-u,--units}'[list available units]:type:' \
  '*:expression:' && ret=0

return ret
