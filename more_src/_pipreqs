#compdef pipreqs

# Zsh completion for pipreqs - generate requirements.txt from imports

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--use-local[use local package info instead of querying PyPI]' \
  '--pypi-server[use custom PyPI server]:URL:' \
  '--proxy[use proxy]:URL:' \
  '--debug[print debug information]' \
  '--print[print requirements to stdout instead of saving to file]' \
  '--savepath[save the list of requirements to given file]:file:_files' \
  '--force[overwrite existing requirements.txt]' \
  '--diff[compare modules in requirements.txt to project imports]:requirements file:_files' \
  '--clean[clean unneeded packages from requirements.txt]:requirements file:_files' \
  '--mode[create requirements using specified operator mode]:mode:(compat gt no-pin)' \
  '--encoding[use encoding parameter for file open function]:encoding:' \
  '--no-follow-links[do not follow symbolic links in the project]' \
  '--ignore[ignore extra directories (comma-separated)]:directories:' \
  '--no-pin[omit version of output packages]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '--version[show version and exit]' \
  '1::project path:_files -/' && ret=0

return ret
