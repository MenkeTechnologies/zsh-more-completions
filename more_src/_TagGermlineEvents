#compdef TagGermlineEvents
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/utils/TagGermlineEvents.java
# GATK4: tag tumor copy-ratio segments that are possible germline events

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-SF --segment-file)'{-SF,--segment-file}'=[input tumor called segment file]:file:_files' \
  '--called-matched-normal-seg-file=[matched normal called segment file]:file:_files' \
  '(-O --output)'{-O,--output}'=[output TSV with added POSSIBLE_GERMLINE tag column]:file:_files' \
  '--endpoint-padding=[padding in bases to allow a breakpoint match]:bases:' \
  '--input-call-header=[column header used for the call value]:header:' \
  '--reciprocal-threshold=[reciprocal threshold to match a segment]:val:' \
  '*:options:_files' && ret=0

return ret
