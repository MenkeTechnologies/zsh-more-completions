#compdef chainlit

# Chainlit CLI completion

_chainlit_subcommands() {
  local -a subcmds=(
    'run:Run a Chainlit app'
    'hello:Run the hello demo'
    'init:Initialize a new Chainlit project'
    'create-secret:Create a secret for authentication'
    'lint-translations:Lint translation files'
  )
  _describe -t commands 'chainlit subcommand' subcmds
}

_chainlit() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_chainlit_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        run)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            {-w,--watch}'[watch for file changes and reload]' \
            '--host=[host to bind to]:host' \
            '--port=[port to listen on]:port' \
            '--headless[run without opening browser]' \
            {-d,--debug}'[enable debug mode]' \
            {-c,--ci}'[run in CI mode]' \
            '--no-cache[disable cache]' \
            '--root-path=[root path for the application]:path' \
            '1:target file:_files -g "*.py"'
          ;;
        hello)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        init)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        create-secret)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        lint-translations)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_chainlit "$@"
