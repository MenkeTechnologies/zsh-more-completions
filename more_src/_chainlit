#compdef chainlit
# Documentation: https://github.com/Chainlit/chainlit/blob/main/backend/chainlit/cli/__init__.py
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_chainlit_subcommands() {
  local -a subcmds=(
    'run:Run a Chainlit app'
    'hello:Run the hello demo'
    'init:Initialize a new Chainlit project'
    'create-secret:Create a secret for authentication'
    'lint-translations:Lint translation files'
  )
  _describe -t commands 'chainlit subcommand' subcmds
}

_chainlit() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_chainlit_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        run)
          _arguments \
            '--help[show help]' \
            {-w,--watch}'[reload the app when the module changes]' \
            {-h,--headless}'[do not auto-open the app in the browser]' \
            {-d,--debug}'[set log level to debug]' \
            {-c,--ci}'[run in CI mode]' \
            '--no-cache[disable third-party caches (e.g. LangChain)]' \
            '--host=[host to bind to]:host:' \
            '--port=[port to listen on]:port:' \
            '--root-path=[root path for the application]:path:' \
            '--ssl-cert=[SSL certificate file]:cert:_files' \
            '--ssl-key=[SSL key file]:key:_files' \
            '1:target file:_files -g "*.py"'
          ;;
        hello)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        init)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        create-secret)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        lint-translations)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_chainlit "$@"
