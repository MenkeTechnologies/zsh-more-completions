#compdef suicepstrum
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/suicepstrum.c
# fft of complex log frequency traces to real time traces

local ret=1

_arguments -s -S \
  'sign2=[sign2]:sign2:' \
  'sign1=[sign1]:sign1:' \
  'sym=[sym]:sym:' \
  'dt=[dt]:dt:' \
  '*:file:_files' && ret=0

return ret
