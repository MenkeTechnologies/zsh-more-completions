# Package: desk-exec
# Type: maintainer-shipped (nixpkgs)
# Harvested: 2026-05-15

autoload -U is-at-least

_desk-exec() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-c+[Path to a configuration file]:CONFIG_FILE:_files' \
'--config-file=[Path to a configuration file]:CONFIG_FILE:_files' \
'-d[Run the program in the background, detaching it from the terminal]' \
'--detach[Run the program in the background, detaching it from the terminal]' \
'-f[Run the first matching entry without prompting]' \
'--first-only[Run the first matching entry without prompting]' \
'-g[Generate a default configuration file]' \
'--generate-config[Generate a default configuration file]' \
'--list-dirs[Display all directories searched for desktop entries, in order of priority]' \
'--list-entries[Display all available desktop entries]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::program -- The name of or path to the desktop entry:' \
&& ret=0
}

(( $+functions[_desk-exec_commands] )) ||
_desk-exec_commands() {
    local commands; commands=()
    _describe -t commands 'desk-exec commands' commands "$@"
}

if [ "$funcstack[1]" = "_desk-exec" ]; then
    _desk-exec "$@"
else
    compdef _desk-exec desk-exec
fi
