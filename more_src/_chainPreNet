#compdef chainPreNet
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# remove chains that do not have a chance of being netted

local ret=1

_arguments -s -S \
  '-dots=[output a dot periodically during processing]:n' \
  '-pad=[extra padding around blocks (default 1)]:n' \
  '-inclHap[include query sequences matching _hap or _alt]' \
  '1:in chain:_files -g "*.chain"' \
  '2:target sizes:_files' \
  '3:query sizes:_files' \
  '4:out chain:_files' && ret=0

return ret
