#compdef git-when-merged
# Documentation: https://github.com/mhagger/git-when-merged
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --pattern)'{-p+,--pattern=}'[match references using regexp]:pattern:' \
  '(-n --name)'{-n+,--name=}'[use configured pattern with given name]:name:' \
  '(-s --default)'{-s,--default}'[shorthand for --name=default]' \
  '(-r --recursive)'{-r,--recursive}'[follow merges back recursively]' \
  '(-c --show-commit)'{-c,--show-commit}'[display only the SHA-1 of the merge commit]' \
  '(-b --show-branch)'{-b,--show-branch}'[display range of commits merged together]' \
  '--abbrev=[abbreviate commit SHAs to N characters]:n:' \
  '--no-abbrev[do not abbreviate commit SHAs]' \
  '--describe[use git-describe for merge commit description]' \
  '--describe-contains[describe using nearby containing tag]' \
  '(-l --log)'{-l,--log}'[show merge commit log]' \
  '(-d --diff)'{-d,--diff}'[show merge commit diff]' \
  '(-v --visualize)'{-v,--visualize}'[visualize merge in gitk]' \
  '*::args:_default' && return 0
