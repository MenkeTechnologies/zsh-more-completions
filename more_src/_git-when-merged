#compdef git-when-merged
# Documentation: https://man.archlinux.org/search?q=git-when-merged
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/git-when-merged — identify merge commits for a commit

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
