#compdef code-server
# Documentation: https://github.com/coder/code-server/blob/main/src/node/cli.ts
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--auth=[authentication type]:type:(password none)' \
  '--password=[set password for authentication]:password' \
  '--hashed-password=[set hashed password]:hashed password' \
  '--cert=[path to TLS certificate]:cert file:_files' \
  '--cert-host=[hostname for self-signed certificate]:hostname' \
  '--cert-key=[path to TLS certificate key]:key file:_files' \
  '--bind-addr=[address to bind to (host:port)]:address' \
  '--host=[host for bind-addr]:host' \
  '--port=[port for bind-addr]:port' \
  '--socket=[path to socket]:socket path:_files' \
  '--socket-mode=[socket file mode]:mode' \
  '--session-socket=[path to session socket]:path:_files' \
  '--cookie-suffix=[cookie suffix]:suffix' \
  '--trusted-origins=[comma-separated trusted origins]:origins' \
  '--user-data-dir=[path to user data directory]:directory:_directories' \
  '--extensions-dir=[path to extensions directory]:directory:_directories' \
  '--builtin-extensions-dir=[path to builtin extensions]:directory:_directories' \
  '--config=[path to config file]:config file:_files' \
  '--json[output JSON]' \
  '--disable-telemetry[disable telemetry]' \
  '--disable-update-check[disable update check]' \
  '--disable-file-downloads[disable file downloads from the server]' \
  '--disable-file-uploads[disable file uploads]' \
  '--disable-workspace-trust[disable workspace trust]' \
  '--disable-getting-started-override[disable getting started override]' \
  '--disable-proxy[disable port proxy]' \
  '--proxy-domain=[domain for proxying ports]:domain' \
  '--abs-proxy-base-path=[absolute proxy base path]:path' \
  '--skip-auth-preflight[skip preflight auth check]' \
  '--ignore-last-opened[do not open the last opened directory]' \
  '--link-protection-trusted-domains=[trusted domains for link protection]:domains' \
  '--locale=[set display language]:locale' \
  '--i18n=[i18n locale]:locale' \
  '--log=[set log level]:level:(trace debug info warn error)' \
  '--force[avoid prompts when installing extensions]' \
  '--verbose[enable verbose logging]' \
  '--open[open in browser on startup]' \
  '--new-window[open in a new window]' \
  '--reuse-window[reuse existing window]' \
  '--app-name=[custom app name]:name' \
  '--welcome-text=[custom welcome text]:text' \
  '--idle-timeout-seconds=[idle timeout in seconds]:seconds' \
  '--reconnection-grace-time=[reconnection grace time in seconds]:seconds' \
  '--list-extensions[list installed extensions]' \
  '--locate-extension=[print extension path]:extension' \
  '--category=[filter extensions by category]:category' \
  '--install-extension=[install extension]:extension' \
  '--enable-proposed-api=[enable proposed API]:extension' \
  '--uninstall-extension=[uninstall extension]:extension' \
  '--show-versions[show extension versions]' \
  '--enable=[enable a feature]:feature' \
  '--github-auth=[GitHub auth token]:token' \
  '*:file or directory:_files' && ret=0

return ret
