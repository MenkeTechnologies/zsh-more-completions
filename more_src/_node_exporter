#compdef node_exporter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--web.max-requests=[max parallel scrape requests]:count:' \
  '--web.disable-exporter-metrics[exclude default metrics]' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '--collector.disable-defaults[disable all default collectors]' \
  '--collector.cpu[enable CPU collector]' \
  '--no-collector.cpu[disable CPU collector]' \
  '--collector.diskstats[enable diskstats collector]' \
  '--no-collector.diskstats[disable diskstats collector]' \
  '--collector.filesystem[enable filesystem collector]' \
  '--no-collector.filesystem[disable filesystem collector]' \
  '--collector.loadavg[enable loadavg collector]' \
  '--no-collector.loadavg[disable loadavg collector]' \
  '--collector.meminfo[enable meminfo collector]' \
  '--no-collector.meminfo[disable meminfo collector]' \
  '--collector.netdev[enable netdev collector]' \
  '--no-collector.netdev[disable netdev collector]' \
  '--collector.netstat[enable netstat collector]' \
  '--no-collector.netstat[disable netstat collector]' \
  '--collector.stat[enable stat collector]' \
  '--no-collector.stat[disable stat collector]' \
  '--collector.textfile[enable textfile collector]' \
  '--no-collector.textfile[disable textfile collector]' \
  '--collector.time[enable time collector]' \
  '--no-collector.time[disable time collector]' \
  '--collector.uname[enable uname collector]' \
  '--no-collector.uname[disable uname collector]' \
  '--collector.vmstat[enable vmstat collector]' \
  '--no-collector.vmstat[disable vmstat collector]' \
  '--collector.thermal_zone[enable thermal_zone collector]' \
  '--no-collector.thermal_zone[disable thermal_zone collector]' \
  '--collector.processes[enable processes collector]' \
  '--no-collector.processes[disable processes collector]' \
  '--collector.systemd[enable systemd collector]' \
  '--no-collector.systemd[disable systemd collector]' \
  '--collector.textfile.directory=[textfile directory]:directory:_directories' \
  '--collector.filesystem.mount-points-exclude=[mount points to exclude]:regexp:' \
  '--collector.filesystem.fs-types-exclude=[filesystem types to exclude]:regexp:' \
  '--collector.netdev.device-include=[include devices]:regexp:' \
  '--collector.netdev.device-exclude=[exclude devices]:regexp:' \
  '--collector.diskstats.device-include=[include devices]:regexp:' \
  '--collector.diskstats.device-exclude=[exclude devices]:regexp:' \
  '--path.procfs=[procfs mountpoint]:path:_directories' \
  '--path.sysfs=[sysfs mountpoint]:path:_directories' \
  '--path.rootfs=[rootfs mountpoint]:path:_directories' && ret=0

return ret
