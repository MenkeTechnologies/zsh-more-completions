#compdef pkgsite
# _pkgsite — generate/serve Go documentation (golang.org/x/pkgsite)
# upstream: https://github.com/golang/pkgsite
# Flags from cmd/pkgsite/main.go.

_pkgsite() {
    _arguments \
        '(- *)-h[show help]' \
        '-http=[HTTP service address]:addr:' \
        '-gorepo=[path to local Go repo]:dir:_files -/' \
        '-proxy[fetch from GOPROXY if not found locally]' \
        '-open[open browser window to server address]' \
        '-cache[fetch from module cache]' \
        '-cachedir=[module cache directory]:dir:_files -/' \
        '-list=[serve all modules in build list]:bool:(true false)' \
        '-dev[enable developer mode]' \
        '-static=[path to static files folder]:dir:_files -/' \
        '-gopath_mode[assume local modules relative to GOPATH/src]' \
        '*:path:_files -/'
}

_pkgsite "$@"
