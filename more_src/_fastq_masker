#compdef fastq_masker
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastq_masker.1.en.html
# FASTX-Toolkit: mask low-quality nucleotides in a FASTQ file

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-q+[quality threshold; lower-quality bases are masked (default 10)]:quality' \
  '-r+[replace low-quality nucleotides with character C (default N)]:char' \
  '-Q+[FASTQ ASCII offset (default 33)]:offset' \
  '-v[verbose: report number of sequences]' \
  '-z[compress output with GZIP]' \
  '-i+[FASTQ input file (default STDIN)]:input file:_files' \
  '-o+[FASTQ output file (default STDOUT)]:output file:_files' && ret=0

return ret
