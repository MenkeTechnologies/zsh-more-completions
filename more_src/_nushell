#compdef nu nushell
# Documentation: https://www.nushell.sh/book/
# Reference accessed: 2026-05-19
# Verified: nu --help output (homebrew installed binary).

# Zsh completion for nushell (nu)

_arguments -s -S \
  '(-c --commands)'{-c,--commands}'[run the given commands and exit]:commands:' \
  '(-e --execute)'{-e,--execute}'[run the given commands and then enter interactive shell]:commands:' \
  '(-I --include-path)'{-I,--include-path}'[set NU_LIB_DIRS]:path:_files -/' \
  '(-l --login)'{-l,--login}'[start as a login shell]' \
  '(-i --interactive)'{-i,--interactive}'[start as an interactive shell]' \
  '--lsp[start the language server]' \
  '--stdin[redirect standard input]' \
  '(-n --no-config-file)'{-n,--no-config-file}'[do not load config files]' \
  '--no-history[disable reading and writing to command history]' \
  '--no-std-lib[do not load the standard library]' \
  '--config=[alternate config file]:file:_files' \
  '--env-config=[environment config file]:file:_files' \
  '--plugin-config=[plugin config file]:file:_files' \
  '*--plugins=[plugin executable files to load]:file:_files' \
  '--log-level=[log level]:level:(error warn info debug trace)' \
  '--log-target=[log target]:target:(stdout stderr mixed file)' \
  '--log-file=[custom log file path]:file:_files' \
  '*--log-include=[Rust module prefixes to include in log]:prefix:' \
  '*--log-exclude=[Rust module prefixes to exclude from log]:prefix:' \
  '--testbin=[run internal test binary]:name:' \
  '--threads=[number of threads]:threads:' \
  '(-m --table-mode)'{-m,--table-mode}'[table display mode]:mode:(rounded basic compact compact_double light thin with_love reinforced heavy none)' \
  '--error-style=[error style]:style:(fancy plain)' \
  '--no-newline[do not append newline to pipeline output]' \
  '--mcp[start MCP server]' \
  '--mcp-transport=[MCP server transport]:transport:(stdio http)' \
  '--mcp-port=[MCP HTTP transport port]:port:' \
  '*--experimental-options=[enable/disable experimental options]:opt:' \
  '--ide-goto-def=[go to definition at cursor position]:position:' \
  '--ide-hover=[show info at cursor position]:position:' \
  '--ide-complete=[list completions at cursor position]:position:' \
  '--ide-check=[run diagnostic check]:max-errors:' \
  '--ide-ast[generate AST]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:script file:_files -g "*.nu"' && return 0
