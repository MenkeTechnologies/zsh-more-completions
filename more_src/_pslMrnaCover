# UCSC kent: make histogram of coverage percentage of mRNA in psl

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-minSize=[minimum size of mRNA considered]:n:' \
  '-listZero=[list accessions that don'\''t align]:file:_files' \
  ':mrna psl:_files' \
  ':mrna fa:_files' && ret=0

return ret
