#compdef rtl_433
# Documentation: https://github.com/merbanan/rtl_433/blob/master/src/rtl_433.c
# Reference accessed: 2026-05-27
# Verified: upstream usage() function and OPTSTRING in src/rtl_433.c

# Zsh completion for rtl_433 (Generic RF data receiver and decoder for ISM band devices)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[output usage help and exit]' \
  '-V[output the version string and exit]' \
  '*-v[increase verbosity (repeat for more)]' \
  '-c+[read config options from a file]:file:_files' \
  '-d+[input device selection (RTL-SDR index, :serial, SoapySDR query, rtl_tcp, help)]:device:' \
  '-g+[gain setting (default: auto)]:gain:' \
  '-t+[apply keyword=value settings to the SDR device]:settings:' \
  '*-f+[receive frequency(s) in Hz]:frequency:' \
  '-H+[hop interval for polling of multiple frequencies in seconds]:seconds:' \
  '-p+[correct rtl-sdr tuner frequency offset error in ppm]:ppm_error:' \
  '-s+[set sample rate in Hz]:rate:' \
  '-D+[input device run mode]:mode:(quit restart pause manual)' \
  '*-R+[enable only the specified device decoding protocol (negative number disables)]:protocol:' \
  '*-X+[add a general purpose decoder spec (use help for syntax)]:spec:' \
  '*-Y+[FSK pulse detector mode or tuning]:mode:(auto classic minmax autolevel squelch ampest magest)' \
  '-A[pulse analyzer; enable pulse analysis and decode attempt]' \
  '-y+[verify decoding of demodulated test data with enabled devices]:code:' \
  '-S+[signal auto save; creates one file per signal]:mode:(none all unknown known)' \
  '-r+[read data from input file instead of a receiver]:file:_files' \
  '-w+[save data stream to output file (- for stdout)]:file:_files' \
  '-W+[save data stream to output file, overwrite existing file]:file:_files' \
  '*-F+[produce decoded output in given format]:format:(log kv json csv mqtt influx syslog trigger rtl_tcp http null help)' \
  '*-M+[add various meta data to each output]:meta:(time protocol level noise stats bits help)' \
  '*-K+[add an expanded token or fixed tag to every output line]:tag:' \
  '-C+[convert units in decoded output]:units:(native si customary)' \
  '-n+[specify number of samples to take (each sample is an I/Q pair)]:samples:' \
  '-T+[specify number of seconds to run (also 12:34 or 1h23m45s)]:duration:' \
  '-E+[hop or quit after outputting successful event(s)]:action:(hop quit)' \
  '-G[deprecated: register all protocols]' \
  '-q[deprecated: quiet is default]' \
  '-U[deprecated: UTC mode; use -M utc]' \
  '-I+[deprecated: include_only; use -S]:mode:' \
  '-m+[deprecated: legacy demod mode]:mode:' \
  '-b+[deprecated: bytes-per-block]:bytes:' \
  '-l+[deprecated: level limit; use -Y level=]:level:' \
  '-a[deprecated: analyze AM signal]' \
  '-x+[deprecated: override long pulse]:value:' \
  '-z+[deprecated: override short pulse]:value:' && ret=0

return ret
