#compdef mlc_llm
# Documentation: https://llm.mlc.ai/docs/deploy/cli.html
# MLC-LLM universal LLM deployment engine

local ret=1
local -a state line
local curcontext="$curcontext"

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'chat:run a compiled LLM interactively'
      'serve:deploy a compiled LLM as a REST API server'
      'compile:compile a model to a model library'
      'convert_weight:convert and quantize model weights'
      'gen_config:generate mlc-chat-config.json and tokenizer files'
      'package:package model libraries and weights for app deployment'
      'calibrate:calibrate quantized model parameters'
      'router:launch a request router for disaggregated serving'
    )
    _describe -t commands 'mlc_llm command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      chat)
        _arguments -s -S \
          '--model-lib=[path to model library file]:path:_files' \
          '--device=[device name and id]:device:(cuda metal vulkan rocm opencl auto)' \
          '--overrides=[config field overrides]:overrides:' \
          '1:model:' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '--model-lib=[path to model library file]:path:_files' \
          '--device=[device name and id]:device:(cuda metal vulkan rocm opencl auto)' \
          '--mode=[engine mode]:mode:(local interactive server)' \
          '--additional-models=[paths for additional models]:models:' \
          '--speculative-mode=[speculative decoding type]:mode:(disable small_draft eagle medusa)' \
          '--overrides=[config field overrides]:overrides:' \
          '--enable-tracing[enable per-request event logging]' \
          '--host=[server host address]:host:' \
          '--port=[server port]:port:' \
          '--allow-credentials[enable CORS credentials]' \
          '--allowed-origins=[JSON list of allowed origins]:origins:' \
          '--allowed-methods=[JSON list of allowed methods]:methods:' \
          '--allowed-headers=[JSON list of allowed headers]:headers:' \
          '1:model:' && ret=0
        ;;
      compile)
        _arguments -s -S \
          '--quantization=[quantization mode]:quant:' \
          '--model-type=[model architecture type]:type:' \
          '--device=[target device]:device:(cuda metal vulkan rocm opencl auto)' \
          '--host=[host LLVM triple]:triple:' \
          '--opt=[optimization flags]:opt:' \
          '--system-lib-prefix=[system library prefix]:prefix:' \
          '(-o --output)'{-o,--output}'=[output model library path]:path:_files' \
          '--overrides=[config field overrides]:overrides:' \
          '1:config:_files' && ret=0
        ;;
      convert_weight)
        _arguments -s -S \
          '--quantization=[quantization mode]:quant:' \
          '--model-type=[model architecture type]:type:' \
          '--device=[device for conversion]:device:(cuda metal vulkan rocm opencl auto)' \
          '--source=[source weight path]:path:_files' \
          '--source-format=[source weight format]:format:(auto huggingface-torch huggingface-safetensor awq)' \
          '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
          '1:config:_files' && ret=0
        ;;
      gen_config)
        _arguments -s -S \
          '--quantization=[quantization mode]:quant:' \
          '--model-type=[model architecture type]:type:' \
          '--conv-template=[conversation template name]:template:' \
          '--context-window-size=[context window size]:size:' \
          '--sliding-window-size=[sliding window size]:size:' \
          '--prefill-chunk-size=[prefill chunk size]:size:' \
          '--tensor-parallel-shards=[number of tensor parallel shards]:num:' \
          '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
          '1:config:_files' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
