#compdef mcom
# Documentation: https://man.archlinux.org/search?q=mcom
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-to[set To header]:address:' \
  '-cc[set Cc header]:address:' \
  '-bcc[set Bcc header]:address:' \
  '-subject[set Subject header]:subject:' \
  '-from[set From header]:address:' \
  '-attach[attach a file]:file:_files' \
  '-no-strstrp[do not strstrp original body]' \
  '*:address or file:_files' && ret=0

return ret
