#compdef rocm rocm-utils amd-rocm
# _amd-rocm — Advanced Micro Devices ROCm Open Compute platform meta CLI wrapper for ROCm device discovery and version info (ROCm team, Bash); custom argparse
# upstream: https://github.com/ROCm/ROCm

_amd-rocm() {
    local -a sub=(
        'info:show ROCm installation info'
        'list-devices:list ROCm-capable GPUs'
        'version:show ROCm version'
        'env:show ROCm environment vars'
        'install:install ROCm components'
        'uninstall:uninstall ROCm components'
        'update:update ROCm'
        'reset:reset device'
        'enable:enable a component'
        'disable:disable a component'
        'driver-version:show driver version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--rocm-path=+[ROCm install path]:dir:_files -/' \
        '--rocr-visible-devices=+[device id csv]:str:' \
        '--hip-visible-devices=+[device id csv]:str:' \
        '--gpu=+[gpu id]:n:' \
        '--all-gpus[apply to all]' \
        '--json[json output]' \
        '--csv[csv output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amd-rocm subcommand' sub ;;
    esac
}

_amd-rocm "$@"
