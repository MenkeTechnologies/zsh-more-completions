#compdef remarshal

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-i --input)'{-i,--input}'[input file]:file:_files' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '--if[input format]:format:(cbor json msgpack toml yaml)' \
  '--of[output format]:format:(cbor json msgpack toml yaml)' \
  '--indent-json[indent JSON output]' \
  '--json-indent[JSON indent size]:size' \
  '--yaml-style[YAML style]:style:(block flow)' \
  '--yaml-width[max YAML line width]:width' \
  '--stringify[output scalar values as strings]' \
  '--unwrap[unwrap top-level key]:key' \
  '--wrap[wrap in top-level key]:key' \
  '--preserve-key-order[preserve key order]' \
  '*:input file:_files'
