#compdef rpmlint
# Documentation: https://github.com/rpm-software-management/rpmlint/blob/main/rpmlint/cli.py
# Reference accessed: 2026-05-21
# Verified: upstream argparse definitions in rpmlint/cli.py.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-V,--version}'[show package version and exit]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[load additional configuration from path]:file or dir:_files' \
  '(-e --explain)'{-e+,--explain=}'[provide detailed explanation for one message id]:*:msgid:' \
  '*'{-r+,--rpmlintrc=,--file=}'[load rpmlintrc file (repeatable)]:file:_files' \
  '(-v --verbose --info)'{-v,--verbose,--info}'[detailed explanations where available]' \
  '(-p --print-config)'{-p,--print-config}'[print settings in effect]' \
  '(-i --installed)'{-i+,--installed=}'[installed packages to validate]:*:pkg:' \
  '(-t --time-report)'{-t,--time-report}'[print time report for checks]' \
  '(-T --profile)'{-T,--profile}'[print cProfile report]' \
  '--ignore-unused-rpmlintrc[do not report unused-rpmlintrc-filter errors]' \
  '--checks=[debugging: only run selected checks (comma separated)]:checks:' \
  '(-s --strict -P --permissive)'{-s,--strict}'[treat all messages as errors]' \
  '(-s --strict -P --permissive)'{-P,--permissive}'[treat individual errors as non-fatal]' \
  '*:rpm or spec:_files -g "*.(rpm|spec)"' && ret=0
return ret
