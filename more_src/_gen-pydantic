#compdef gen-pydantic
# _gen-pydantic — generate Pydantic models from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/pydanticgen/pydanticgen.py (click).

_gen-pydantic() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files'
        '(-f --format)'{-f+,--format=}'[output format]:format:(python)'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '--useuris[use URI references for terms]'
        '--metauris[use meta URI references]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into generated output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '--template-dir=[Jinja2 template directory]:dir:_files -/'
        '*--array-representations=[array representation]:repr:(list np-array pandas-array xarray-array hdf5 zarr)'
        '--extra-fields=[handling of extra fields in BaseModel]:mode:(allow ignore forbid)'
        '--black[format generated models with black]'
        '--meta=[how to include LinkML schema metadata]:mode:(auto full none)'
        '--emptylist-for-multivalued-slots[default optional multivalued fields to [] instead of None]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-pydantic "$@"
