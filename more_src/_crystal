#compdef crystal

# Zsh completion for Crystal programming language

_crystal() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:generate a new Crystal project'
    'build:build an executable'
    'docs:generate documentation'
    'env:print Crystal environment information'
    'eval:eval code from args or standard input'
    'play:starts Crystal playground server'
    'run:build and run program'
    'spec:build and run specs'
    'tool:run a tool'
    'clear_cache:clear the compiler cache'
    'version:show version'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'crystal command' commands && ret=0
      ;;
    (args)
      local -a common_build_opts=(
        '-d[compile in debug mode]'
        '--debug[compile in debug mode]'
        '--no-debug[skip debug info]'
        '-D+[define a compile-time flag]:flag:'
        '--define=[define a compile-time flag]:flag:'
        '--emit=[emit intermediate code]:type:(asm llvm-bc llvm-ir obj)'
        '--error-trace[show full error trace]'
        '--no-color[disable colored output]'
        '--prelude=[use given file as prelude]:file:_files -g "*.cr"'
        '--release[compile in release mode]'
        '-s[compile statically]'
        '--static[compile statically]'
        '-t+[use given LLVM target triple]:triple:'
        '--target=[use given LLVM target triple]:triple:'
        '--threads=[max number of threads]:threads:'
        '--mcpu=[target CPU]:cpu:'
        '--mattr=[target CPU features]:features:'
        '--mcmodel=[code model]:model:(default small medium large)'
        '--cross-compile[cross-compile]'
        '--single-module[generate a single LLVM module]'
        '--warnings=[warnings mode]:mode:(all none)'
        '--error-on-warnings[treat warnings as errors]'
        '--exclude-warnings=[exclude warnings from these paths]:path:_files -/'
        '-l+[link with library]:library:'
        '--link-flags=[additional linker flags]:flags:'
        '--no-codegen[skip code generation]'
        '--progress[show compilation progress]'
        '--verbose[verbose output]'
        '-o+[output filename]:output file:_files'
        '--output=[output filename]:output file:_files'
      )
      case ${words[1]} in
        init)
          _arguments -s -S \
            '1:type:(lib app)' \
            '2:name:' \
            '-d+[set description]:description:' \
            '--dir=[set directory]:directory:_files -/' \
            '--skip-existing[skip existing files]' \
            '--force[force overwrite]' \
            && ret=0
          ;;
        build)
          _arguments -s -S $common_build_opts \
            '*:source files:_files -g "*.cr"' \
            && ret=0
          ;;
        run)
          _arguments -s -S $common_build_opts \
            '*:source files:_files -g "*.cr"' \
            && ret=0
          ;;
        eval)
          _arguments -s -S $common_build_opts \
            '*:code:' \
            && ret=0
          ;;
        spec)
          _arguments -s -S $common_build_opts \
            '--junit_output=[JUnit XML output file]:file:_files' \
            '--fail-fast[stop on first failure]' \
            '--order=[run order]:order:(default random)' \
            '--tag=[run specs matching tag]:tag:' \
            '*:spec files:_files -g "*.cr"' \
            && ret=0
          ;;
        docs)
          _arguments -s -S \
            '-o+[output directory]:directory:_files -/' \
            '--output=[output directory]:directory:_files -/' \
            '--canonical-base-url=[base URL]:URL:' \
            '-b+[base URL]:URL:' \
            '--project-name=[project name]:name:' \
            '--project-version=[project version]:version:' \
            '--json-config-url=[JSON config URL]:URL:' \
            '--source-refname=[git ref name]:ref:' \
            '--source-url-pattern=[source URL pattern]:pattern:' \
            '--sitemap-base-url=[sitemap base URL]:URL:' \
            '--sitemap-priority=[sitemap priority]:priority:' \
            '--sitemap-changefreq=[sitemap change frequency]:frequency:' \
            '*:source files:_files -g "*.cr"' \
            && ret=0
          ;;
        tool)
          _arguments -s -S \
            '1:tool:(context dependencies expand flags format hierarchy implementations types unreachable)' \
            '*:files:_files -g "*.cr"' \
            && ret=0
          ;;
        play)
          _arguments -s -S \
            '-p+[port]:port:' \
            '--port=[port]:port:' \
            '-b+[host]:host:_hosts' \
            '--binding=[host]:host:_hosts' \
            '-v[verbose]' \
            '--verbose[verbose]' \
            && ret=0
          ;;
        env)
          _arguments -s -S \
            '1:variable:(CRYSTAL_CACHE_DIR CRYSTAL_LIBRARY_PATH CRYSTAL_PATH CRYSTAL_VERSION CRYSTAL_OPTS)' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[print version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_crystal "$@"
