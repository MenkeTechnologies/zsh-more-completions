#compdef vcfstats
# Documentation: https://github.com/pwwang/vcfstats/blob/master/vcfstats/args.toml
# Reference accessed: 2026-05-27
# Verified: upstream args.toml argument definitions (pwwang/vcfstats)

# vcfstats: Powerful variant statistics and plotting from VCF files

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --vcf)'{-v+,--vcf=}'[input VCF file]:file:_files -g "*.(vcf|vcf.gz|bcf)"' \
  '--loglevel=[logging level]:level:(debug info warning error critical)' \
  '(-o --outdir)'{-o+,--outdir=}'[output directory]:dir:_files -/' \
  '*--figtype=[plot type per formula]:type:(boxplot density pie histogram scatter bar violin freqpoly)' \
  '*--figfmt=[figure format per formula]:fmt:(png pdf svg jpg jpeg tiff)' \
  '*'{-r+,--region=}'[region CHR or CHR:START-END]:region:' \
  '*--Region=[regions BED file]:file:_files -g "*.bed"' \
  '(-p --passed)'{-p,--passed}'[only analyze variants that pass all filters]' \
  '(-l --list)'{-l,--list}'[list all available macros]' \
  '(-s --save)'{-s,--save}'[save plotting data for further exploration]' \
  '*'{-f+,--formula=}'[plotting formula in form Y ~ X]:formula:' \
  '--macro=[user-defined macro file]:file:_files -g "*.py"' \
  '*'{-t+,--title=}'[title of each figure (also used to name output files)]:title:' \
  '*'{-g+,--ggs=}'[extra ggplot2 expressions for each plot]:expr:' \
  '*--devpars.width=[plot width]:px:' \
  '*--devpars.height=[plot height]:px:' \
  '*--devpars.res=[plot resolution]:dpi:' \
  '--config=[TOML configuration file (overrides CLI args)]:file:_files -g "*.toml"' && ret=0

return ret
