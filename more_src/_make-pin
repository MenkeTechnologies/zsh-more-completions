#compdef make-pin
# Documentation: https://crux.ms/commands/make-pin.html
# Crux make-pin: produce a Percolator input (PIN) file from PSMs.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--max-charge-feature=[maximum charge state feature (0=observed max)]:n' \
  '--unique-scannr=[make each PSM ScanNr unique]:bool:(T F)' \
  '--decoy-prefix=[prefix indicating a decoy protein]:prefix' \
  '--top-match=[matches to report per spectrum]:n' \
  '--output-file=[path where the pin file is written]:file:_files' \
  '--fileroot=[prefix for output filenames]:prefix' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--overwrite=[replace existing files]:bool:(T F)' \
  '--parameter-file=[configuration file]:file:_files' \
  '--verbosity=[verbosity level 0-60]:level' \
  '*:psm input:_files' && ret=0

return ret
