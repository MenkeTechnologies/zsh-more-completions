#compdef netToBed
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert target coverage of a net to a bed file

local ret=1

_arguments -s -S \
  '-maxGap=[break up at gaps of given size or more]:n' \
  '-minFill=[only include fill of given size or above]:n' \
  '1:input net:_files -g "*.net"' \
  '2:output bed:_files -g "*.bed"' && ret=0

return ret
