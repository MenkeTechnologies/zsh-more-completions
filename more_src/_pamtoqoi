#compdef pamtoqoi
# Documentation: https://man.archlinux.org/search?q=pamtoqoi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--quiet[suppress informational messages]' \
  '*:pnm file:_files -g "*.(pnm|pam|ppm|pgm|pbm)"' && ret=0

return ret
