#compdef complgen
# Documentation: https://github.com/adaszko/complgen
# complgen: compile grammar files into shell completion scripts

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(--bash --fish --zsh --pwsh)--bash[generate a bash completion script]' \
  '(--bash --fish --zsh --pwsh)--fish[generate a fish completion script]' \
  '(--bash --fish --zsh --pwsh)--zsh[generate a zsh completion script]' \
  '(--bash --fish --zsh --pwsh)--pwsh[generate a PowerShell completion script]' \
  '1:output file:_files' \
  '2:grammar file:_files' && ret=0

return ret
