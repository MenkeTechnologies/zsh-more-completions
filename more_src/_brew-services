#compdef brew-services
# _brew-services — Homebrew services launchd/systemd wrapper subcommand alias (Homebrew team, Ruby); custom argparse
# upstream: https://github.com/Homebrew/homebrew-services

_brew-services() {
    local -a sub=(
        'cleanup:remove unused services'
        'info:show info about services'
        'kill:stop running services without unloading'
        'list:list services'
        'restart:stop then start a service'
        'run:run a service (no boot persistence)'
        'start:start a service'
        'stop:stop a service'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--all[all services]' \
        '-a[all services]' \
        '--file=+[plist override file]:file:_files' \
        '-f+[plist override file]:file:_files' \
        '--json[json output]' \
        '--keep-alive[keep alive]' \
        '--max-wait=+[max wait sec]:n:' \
        '--no-wait[no wait]' \
        '--quiet[quiet]' \
        '--sudo-service-user=+[sudo service user]:str:_users' \
        '--debug[debug]' \
        '-d[debug]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'brew services subcommand' sub ;;
        args)
            case $words[1] in
                start|stop|restart|info|kill|run|cleanup) _arguments '*:service:' ;;
            esac
            ;;
    esac
}

_brew-services "$@"
