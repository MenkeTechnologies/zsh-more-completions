#compdef jabba

# Zsh completion for jabba - Java version manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:download and install JDK'
  'uninstall:uninstall JDK'
  'use:modify PATH & JAVA_HOME to use specific JDK'
  'current:display currently ''use''d version'
  'ls:list installed versions'
  'ls-remote:list remote versions available for install'
  'link:resolve or update a link'
  'unlink:delete a link'
  'deactivate:undo effects of ''use'' in the current shell'
  'alias:resolve or update an alias'
  'unalias:delete an alias'
  'which:display path to the given version of the JDK'
  'help:show help'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'jabba command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (use|uninstall|which)
        local -a versions
        versions=("${(@f)$(jabba ls 2>/dev/null)}")
        _describe -t versions 'installed versions' versions && ret=0
        ;;
      (alias|unalias)
        local -a aliases
        aliases=("${(@f)$(jabba alias 2>/dev/null | awk -F= '{print $1}')}")
        _describe -t aliases 'alias' aliases && ret=0
        ;;
    esac
    ;;
esac

return ret
