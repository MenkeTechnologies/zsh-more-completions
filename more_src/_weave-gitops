#compdef gitops

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create Weave GitOps resources'
  'get:get Weave GitOps resources'
  'delete:delete Weave GitOps resources'
  'beta:beta features'
  'check:pre-flight checks'
  'version:show version'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--namespace[namespace]:namespace:' \
  '-e[endpoint]:endpoint:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'gitops command' commands && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments -s -S \
          '1:resource:(dashboard helmrelease)' \
          '--export[export as YAML]' \
          '--help[show help]' && ret=0
        ;;
      get)
        _arguments -s -S \
          '1:resource:(bcrypt helmrelease kustomization)' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
