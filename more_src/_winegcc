#compdef winegcc wineg++
# Wine GCC wrapper compiler

local ret=1

_arguments -s -S \
  '-b[specify target]:target:' \
  '-B[specify binary path]:path:_files -/' \
  '-c[compile only]' \
  '-D[define preprocessor symbol]:symbol:' \
  '-E[preprocess only]' \
  '-g[include debug info]' \
  '-I[specify include path]:directory:_files -/' \
  '-L[specify library path]:directory:_files -/' \
  '-l[link library]:library:' \
  '-m[specify architecture]:arch:(32 64)' \
  '-mno-cygwin[disable Cygwin]' \
  '-mconsole[build console application]' \
  '-mwindows[build Windows GUI application]' \
  '-municode[build Unicode application]' \
  '-nodefaultlibs[do not use default libraries]' \
  '-nostartfiles[do not use standard start files]' \
  '-nostdlib[do not use standard system library]' \
  '-o[specify output file]:file:_files' \
  '-O[optimization level]:level:(0 1 2 3 s)' \
  '-shared[create shared library]' \
  '-static[create static executable]' \
  '-v[verbose mode]' \
  '-W[warning option]:warning:' \
  '--help[show help]' \
  '--version[show version]' \
  '--wine-objdir=[specify Wine object directory]:directory:_files -/' \
  '--winebuild=[specify winebuild]:winebuild:_files' \
  '*:source files:_files -g "*.(c|cpp|o|a|def|spec|rc|res)"' && ret=0

return ret
