#compdef k9s
# _k9s-cli — k9s k8s cluster TUI (Fernand Galiana, Go); terminal UI for managing k8s clusters
# upstream: https://github.com/derailed/k9s

_k9s-cli() {
    local -a sub=(
        'completion:print shell completion'
        'info:print K9s info'
        'help:show help'
        'version:show version'
        'data:K9s data commands'
        'config:K9s config commands'
        'plugin:list installed K9s plugins'
        'view:open K9s with view'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-A[all namespaces]' \
        '--all-namespaces[all namespaces]' \
        '--cluster+[k8s cluster]:cluster:' \
        '--command+[start command]:cmd:' \
        '-c+[start command]:cmd:' \
        '--context+[kube context]:context:' \
        '--crumbsless[hide crumbs]' \
        '--headless[hide header]' \
        '--insecure-skip-tls-verify[skip TLS verify]' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '--logFile+[log file]:file:_files' \
        '-l+[log level]:level:(debug info warn error fatal panic trace disable)' \
        '--logLevel+[log level]:level:' \
        '--logoless[hide logo]' \
        '-n+[namespace]:namespace:' \
        '--namespace+[namespace]:namespace:' \
        '--readonly[read only mode]' \
        '--refresh+[refresh rate sec]:n:' \
        '-r+[refresh rate]:n:' \
        '--request-timeout+[request timeout]:duration:' \
        '--screen-dump-dir+[screen dump dir]:dir:_files -/' \
        '--splashless[hide splash]' \
        '--token+[bearer token]:str:' \
        '--user+[kubeconfig user]:user:' \
        '--write[write mode]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'k9s subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_k9s-cli "$@"
