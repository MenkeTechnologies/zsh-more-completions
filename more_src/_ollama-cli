#compdef ollama-cli
# Documentation: https://www.npmjs.com/package/ollama-cli
# Reference accessed: 2026-05-23
# Verified: npx ollama-cli --help.

# Zsh completion for ollama-cli - generate text from local Ollama models

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --model)'{-m+,--model=}'[model to use]:model:' \
  '-j[output as JSON]' \
  '--json[output as JSON]' \
  '-c[extract code from markdown output]' \
  '--code[extract code from markdown output]' \
  ':prompt:' && ret=0

return ret
