#compdef pplacer
# pplacer: phylogenetic placement of query sequences on a reference tree

local ret=1

_arguments -s -S \
  '(-help --help)'{-help,--help}'[show help]' \
  '--version[write version number and exit]' \
  '-c[reference package path]:dir:_files -/' \
  '-t[reference tree filename]:file:_files' \
  '-r[reference alignment filename]:file:_files' \
  '-s[PhyML stats.txt or RAxML info file]:file:_files' \
  '-d[directory containing reference information]:dir:_files -/' \
  '-o[output file name]:file:_files' \
  '--out-dir[directory for place file output]:dir:_files -/' \
  '-m[substitution model]:model:(LG WAG JTT GTR)' \
  '--model-freqs[use model frequencies instead of alignment frequencies]' \
  '--gamma-cats[discrete gamma model category count]:n:' \
  '--gamma-alpha[gamma model shape parameter]:alpha:' \
  '--always-refine[force model refinement before placement]' \
  '-p[calculate posterior probabilities]' \
  '--ml-tolerance[branch length optimization tolerance]:tol:' \
  '--pp-rel-err[posterior probability relative error]:err:' \
  '--unif-prior[use uniform prior instead of exponential]' \
  '--inform-prior[use informative exponential prior]' \
  '--prior-lower[informative prior mean lower bound]:bound:' \
  '--start-pend[starting pendant branch length]:len:' \
  '--max-pend[maximum ML pendant branch length]:len:' \
  '--max-strikes[maximum strikes for baseball (0 disables)]:n:' \
  '--strike-box[strike box size in log likelihood units]:n:' \
  '--max-pitches[maximum pitches for baseball]:n:' \
  '--fantasy[likelihood cutoff for fantasy baseball mode]:cutoff:' \
  '--fantasy-frac[fragment fraction for fantasy baseball]:frac:' \
  '--fig-cutoff[cutoff for fig determination]:cutoff:' \
  '--fig-eval-all[evaluate all likelihoods to verify best location]' \
  '--fig-eval-discrepancy-tree[write tree showing placement discrepancies]' \
  '--fig-tree[write tree showing figs]' \
  '--no-pre-mask[disable pre-masking sequences]' \
  '--write-pre-masked[write pre-masked sequences to file]:file:_files' \
  '--write-masked[write alignment masked per query sequence]:file:_files' \
  '--discard-nonoverlapped[discard non-overlapping sequences during pre-masking]' \
  '--map-mrca[write MAP sequences for MRCAs with placements]:file:_files' \
  '--map-mrca-min[MAP sequence inclusion cutoff]:cutoff:' \
  '--map-identity[add percent identity to nearest MAP sequence]' \
  '--mrca-class[classify with MRCAs instead of painted tree]' \
  '--keep-at-most[maximum placements retained]:n:' \
  '--keep-factor[ML ratio threshold multiplier]:factor:' \
  '--groups[split alignment into specified number of groups]:n:' \
  '-j[number of child processes]:n:' \
  '--mmap-file[mmap file instead of large memory allocations]:file:_files' \
  '--check-like[write reference tree likelihood]' \
  '--pretend[check files and report without running analysis]' \
  '--timing[display timing information after run]' \
  '--verbosity[verbosity level (0-2)]:level:(0 1 2)' \
  '*:query alignment:_files' && ret=0

return ret
