#compdef wfmash
# Documentation: https://github.com/waveygang/wfmash
# wfmash: base-accurate DNA sequence alignment using minmers and WFA

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-k --kmer-size)'{-k+,--kmer-size=}'[k-mer size]:int:' \
  '(-s --sketch-size)'{-s+,--sketch-size=}'[number of minmers per window]:int:' \
  '(-w --window-size)'{-w+,--window-size=}'[window size for minmer selection]:int:' \
  '(-m --approx-mapping)'{-m,--approx-mapping}'[output mappings only, no alignment]' \
  '(-p --map-pct-id)'{-p+,--map-pct-id=}'[minimum identity percentage or ANI preset]:id:' \
  '(-n --mappings)'{-n+,--mappings=}'[number of mappings per segment]:int:' \
  '(-l --block-length)'{-l+,--block-length=}'[minimum mapping block length]:int:' \
  '(-c --chain-jump)'{-c+,--chain-jump=}'[maximum gap to chain mappings]:int:' \
  '(-P --max-length)'{-P+,--max-length=}'[maximum mapping length for alignment]:int:' \
  '(-N --no-split)'{-N,--no-split}'[map each sequence as a single block]' \
  '(-f --no-filter)'{-f,--no-filter}'[disable all filtering]' \
  '(-M --no-merge)'{-M,--no-merge}'[keep fragment mappings separate]' \
  '(-o --one-to-one)'{-o,--one-to-one}'[report only best mapping per query/target pair]' \
  '(-H --l1-hits)'{-H+,--l1-hits=}'[minimum sketch hits for L1 filter]:int:' \
  '(-F --filter-freq)'{-F+,--filter-freq=}'[filter high-frequency minimizers]:float:' \
  '--hg-filter=[hypergeometric filter parameters]:params:' \
  '(-S --scaffold-mass)'{-S+,--scaffold-mass=}'[minimum scaffold length]:int:' \
  '(-D --scaffold-dist)'{-D+,--scaffold-dist=}'[maximum distance from scaffold anchors]:int:' \
  '(-j --scaffold-jump)'{-j+,--scaffold-jump=}'[maximum gap for scaffold chaining]:int:' \
  '--scaffold-out=[output scaffold chains to FILE]:file:_files' \
  '(-X --self-maps)'{-X,--self-maps}'[include self-mappings]' \
  '(-Y --group-prefix)'{-Y+,--group-prefix=}'[exclude mappings within groups by prefix delimiter]:char:' \
  '(-L --lower-triangular)'{-L,--lower-triangular}'[only map seq_i to seq_j if i>j]' \
  '(-T --target-prefix)'{-T+,--target-prefix=}'[only map to targets with prefix]:prefix:' \
  '(-Q --query-prefix)'{-Q+,--query-prefix=}'[only map queries with prefix(es)]:prefixes:' \
  '(-g --wfa-params)'{-g+,--wfa-params=}'[WFA gap costs]:costs:' \
  '(-E --target-padding)'{-E+,--target-padding=}'[bases to extend target region]:int:' \
  '(-U --query-padding)'{-U+,--query-padding=}'[bases to extend query region]:int:' \
  '(-a --sam)'{-a,--sam}'[output in SAM format (default PAF)]' \
  '(-d --md-tag)'{-d,--md-tag}'[include MD tag in output]' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:int:' \
  '(-I --read-index)'{-I+,--read-index=}'[load pre-built index from FILE]:file:_files' \
  '(-W --write-index)'{-W+,--write-index=}'[save index to FILE]:file:_files' \
  '(-b --batch)'{-b+,--batch=}'[target index batch size]:size:' \
  '*:target and query fasta:_files' && ret=0

return ret
