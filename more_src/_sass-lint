#compdef sass-lint
# Documentation: https://github.com/sasstools/sass-lint
# node-sass focused linter for Sass/SCSS

local ret=1

_arguments -s -S \
  '(-c --config)'{-c+,--config=}'[custom configuration file path]:config:_files' \
  '(-f --format)'{-f+,--format=}'[output format for warnings/errors]:format' \
  '(-o --output)'{-o+,--output=}'[write linter output to a file]:file:_files' \
  '(-i --ignore)'{-i+,--ignore=}'[files/patterns to exclude]:pattern' \
  '(-s --syntax)'{-s+,--syntax=}'[specify syntax]:syntax:(sass scss)' \
  '(-v --verbose)'{-v,--verbose}'[display both warnings and errors]' \
  '(-q --no-exit)'{-q,--no-exit}'[show all issues without halting on first error]' \
  '--max-warnings=[warning count threshold before failure]:count' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:Sass/SCSS file:_files' && ret=0

return ret
