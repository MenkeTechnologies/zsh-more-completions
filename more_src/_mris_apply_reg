#compdef mris_apply_reg
# Documentation: https://github.com/freesurfer/freesurfer/blob/dev/mris_apply_reg/mris_apply_reg.help.xml
# Resample surface overlay data through spherical registration

local ret=1

_arguments -s -S \
  '--src[source value file]:file:_files' \
  '--i[source value file]:file:_files' \
  '--trg[target value file]:file:_files' \
  '--o[target value file]:file:_files' \
  '*--streg[source/target registration pair]:srcreg:_files:trgreg:_files' \
  '--lta[apply LTA: source-surf ltafile outputsurf]:srcsurf:_files:lta:_files:out:_files' \
  '--lta-rot[apply LTA rotation only]:srcsurf:_files:lta:_files:out:_files' \
  '--center[center the surface]' \
  '--curv[source is a curv-format file]' \
  '--map-vertex[map a single vertex]:vertexno:srcsurf:_files:trgsurf:_files:outfile:_files' \
  '--warp[apply gcam warp: source-surf gcamfile outputsurf]:srcsurf:_files:gcam:_files:out:_files' \
  '--vg-thresh[volume geometry threshold]:thresh:' \
  '--bci[input srcreg trgreg output]:input:_files:srcreg:_files:trgreg:_files:output:_files' \
  '--bci-xyz[inputsurf srcreg trgreg output]:inputsurf:_files:srcreg:_files:trgreg:_files:output:_files' \
  '--reg-scanner-ras[registration in scanner RAS]' \
  '--xzy-scanner-ras[xyz in scanner RAS]' && ret=0

return ret
