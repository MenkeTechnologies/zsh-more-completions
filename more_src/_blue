#compdef blue
# Documentation: https://github.com/grantjenks/blue
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-c --code)'{-c,--code}'=[format code string]:code:' \
  '(-l --line-length)'{-l,--line-length}'=[line length]:n:' \
  '*'{-t,--target-version}'=[target Python]:ver:(py33 py34 py35 py36 py37 py38 py39 py310 py311 py312)' \
  '--pyi[stub file]' \
  '--ipynb[Jupyter notebook]' \
  '(-S --skip-string-normalization)'{-S,--skip-string-normalization}'[skip string norm]' \
  '(-C --skip-magic-trailing-comma)'{-C,--skip-magic-trailing-comma}'[skip trailing comma]' \
  '--experimental-string-processing[experimental]' \
  '--check[check only]' \
  '--diff[show diff]' \
  '--color[color diff]' \
  '--no-color[no color]' \
  '--fast[skip AST check]' \
  '--safe[run AST check]' \
  '--required-version=[required version]:ver:' \
  '--include=[include regex]:regex:' \
  '--exclude=[exclude regex]:regex:' \
  '--extend-exclude=[extra excludes]:regex:' \
  '--force-exclude=[force exclude]:regex:' \
  '--stdin-filename=[stdin name]:name:' \
  '(-W --workers)'{-W,--workers}'=[workers]:n:' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '--version[show version]' \
  '--config=[config file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '*:src:_files'
