#compdef edquota
# Documentation: man edquota(8) (BSD)
# Source: BSD edquota — edit user / group disk quotas.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-u -g)-u[edit user quotas (default)]' \
    '(-u -g)-g[edit group quotas]' \
    '-p+[prototype user/group to duplicate]:proto:_users' \
    '-t[edit grace period (with -u or -g)]' \
    '*:user or group name:_users' \
    && ret=0

return ret
