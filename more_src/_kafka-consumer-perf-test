#compdef kafka-consumer-perf-test

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--topic[Topic to consume from]:topic:'
    '--group[Consumer group ID]:group:'
    '--messages[Number of messages to consume]:count:'
    '--threads[Number of consumer threads]:count:'
    '--num-fetch-threads[Number of fetcher threads]:count:'
    '--reporting-interval[Interval in ms at which to print progress]:ms:'
    '--show-detailed-stats[Print out metrics per partition]'
    '--from-latest[Start consuming from latest offset]'
    '--consumer.config[Consumer config properties file]:file:_files'
    '--print-metrics[Print out the metrics at the end]'
    '--timeout[Exit if no messages received in this time]:ms:'
    '--fetch-size[Fetch size per request]:bytes:'
    '--socket-buffer-size[TCP receive buffer size]:bytes:'
    '--date-format[Date format for reporting]:format:'
    '--hide-header[Do not print the header]'
)

_arguments -s -S $arguments
