#compdef tuc

# Zsh completion for tuc - cut text with delimiters

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --delimiter)'{-d,--delimiter}'[delimiter character]:delimiter:' \
  '(-f --fields)'{-f,--fields}'[field ranges to select]:ranges:' \
  '(-e --regex)'{-e,--regex}'[use delimiter as a regex]' \
  '(-p --replace-delimiter)'{-p,--replace-delimiter}'[replace delimiter in output]:string:' \
  '(-c --characters)'{-c,--characters}'[character ranges to select]:ranges:' \
  '--complement[select complement of fields]' \
  '--json[output as JSON]' \
  '(-s --only-delimited)'{-s,--only-delimited}'[only print lines containing delimiter]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:file:_files' && ret=0

return ret
