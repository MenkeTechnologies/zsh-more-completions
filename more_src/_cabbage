#compdef cabbage Cabbage
# Documentation: https://github.com/rorywalsh/cabbage
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-sandbox[disable Chromium sandbox]' \
  '--disable-gpu[disable GPU acceleration]' \
  '*:csd_file:_files -g "*.{csd,csound,cabbage}"' && ret=0

return ret
