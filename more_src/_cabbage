#compdef cabbage Cabbage
# Documentation: https://man.archlinux.org/search?q=cabbage
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-sandbox[disable Chromium sandbox]' \
  '--disable-gpu[disable GPU acceleration]' \
  '*:csd_file:_files -g "*.{csd,csound,cabbage}"' && ret=0

return ret
