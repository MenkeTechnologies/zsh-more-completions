#compdef duca

# https://github.com/thomaspmurphy/duca

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a _duca_cmds
    _duca_cmds=(
      search:'search verses'
      canto:'show canto'
      tui:'interactive reader'
    )
    _describe -t commands 'duca command' _duca_cmds && ret=0
    ;;
  (args)
    case $line[1] in
      (search)
        _arguments '::pattern:' '--cantica=[limit cantica]:cantica:(inferno purgatorio paradiso)' && ret=0 ;;
      (canto)
        _arguments ':cantica:(inferno purgatorio paradiso)' ':canto number:' && ret=0 ;;
    esac ;;
esac

return ret
