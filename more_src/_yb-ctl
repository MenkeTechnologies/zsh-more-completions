#compdef yb-ctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create:create a local cluster'
  'start:start the cluster'
  'stop:stop the cluster'
  'destroy:destroy the cluster'
  'status:cluster status'
  'restart:restart the cluster'
  'wipe_restart:wipe and restart'
  'add_node:add a tserver node'
  'remove_node:remove a node'
  'start_node:start a stopped node'
  'stop_node:stop a node'
  'restart_node:restart a node'
)

_arguments -C \
  '--binary_dir=[YB binary dir]:dir:_files -/' \
  '--data_dir=[data dir]:dir:_files -/' \
  '--master_flags=[master gflags]:gflags:' \
  '--tserver_flags=[tserver gflags]:gflags:' \
  '--placement_info=[placement info]:info:' \
  '(-rf --replication_factor)'{-rf,--replication_factor}'=[replication factor]:n:' \
  '--require_clock_sync=[require clock sync]:bool:(true false)' \
  '--listen_ip=[listen IP]:ip:' \
  '--num_shards_per_tserver=[shards per tserver]:n:' \
  '--timeout-yb-admin-sec=[yb-admin timeout]:s:' \
  '--timeout-processes-running-sec=[processes timeout]:s:' \
  '--verbose[verbose]' \
  '--ysql_enable_auth[enable YSQL auth]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'yb-ctl subcommand' subcommands && ret=0
    ;;
esac

return ret
