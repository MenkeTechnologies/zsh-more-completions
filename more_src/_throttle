#compdef throttle

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-v[verbose]' \
  '-w+[block writes when buffer exceeds bytes]:bytes:' \
  '-s+[buffer block size]:bytes:' \
  '-b+[total buffer size]:bytes:' \
  '-t+[bytes per second]:bps:' \
  '-k+[kilobytes per second]:kbps:' \
  '-m+[megabytes per second]:mbps:' \
  '-K+[KiB per second]:kib:' \
  '-M+[MiB per second]:mib:' \
  '-T+[seconds per period]:sec:' \
  '-B+[bytes per period]:bytes:' && ret=0

return ret
