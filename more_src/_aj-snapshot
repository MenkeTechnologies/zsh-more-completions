#compdef aj-snapshot
# Documentation: https://github.com/jackaudio/jack-example-tools
# store and restore ALSA and JACK connections to/from a file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --alsa)'{-a,--alsa}'[only store or restore ALSA midi connections]' \
  '(-j --jack)'{-j,--jack}'[only store or restore JACK audio and midi connections]' \
  '(-d --daemon)'{-d,--daemon}'[run in daemon mode]' \
  '(-r --restore)'{-r,--restore}'[restore connections from FILE]' \
  '(-x --remove)'{-x,--remove}'[remove all existing connections before restoring]' \
  '(-f --force)'{-f,--force}'[overwrite existing file without asking]' \
  '(-q --quiet)'{-q,--quiet}'[do not print connection information]' \
  '(-p --poll)'{-p,--poll}'+[polling interval in milliseconds]:interval' \
  '*'{-i,--ignore}'+[ignore a specific client by name]:client name' \
  '*:file:_files' && ret=0

return ret
