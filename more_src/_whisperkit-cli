#compdef whisperkit-cli
# Documentation: https://github.com/argmaxinc/WhisperKit
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for whisperkit-cli - Apple Silicon native Whisper speech recognition

local curcontext="$curcontext" state line ret=1

local -a _wk_cmds
_wk_cmds=(
  'transcribe:transcribe an audio file or microphone stream'
  'diarize:perform speaker diarization on an audio file'
  'serve:start a local API server'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'whisperkit-cli command' _wk_cmds && ret=0
    ;;
  args)
    case $words[1] in
      transcribe)
        _arguments \
          '--model-path=[path to the CoreML model directory]:dir:_directories' \
          '--audio-path=[path to audio file]:file:_files -g "*.(wav|mp3|m4a|flac)"' \
          '--stream[stream audio directly from microphone]' \
          '--language=[source language code]:code' \
          '--prompt=[text to guide transcription style]:text' \
          '--temperature=[sampling temperature]:temperature' \
          '--verbose[enable detailed logging output]' && ret=0
        ;;
      diarize)
        _arguments \
          '--audio-path=[path to audio file]:file:_files -g "*.(wav|mp3|m4a|flac)"' \
          '--rttm-path=[output RTTM file]:file:_files' && ret=0
        ;;
      serve)
        _arguments \
          '--host=[host to listen on]:host' \
          '--port=[port to listen on]:port' && ret=0
        ;;
    esac
    ;;
esac

return ret
