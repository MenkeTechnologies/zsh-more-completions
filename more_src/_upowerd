#compdef upowerd

# upowerd: D-Bus daemon for monitoring power/battery devices
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[show extra debug information]' \
  '(-t --timed-exit)'{-t,--timed-exit}'[exit after a short delay]' \
  '(-r --replace)'{-r,--replace}'[replace running upowerd]' \
  '*::upowerd args:_files' && ret=0
return ret
