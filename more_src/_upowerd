#compdef upowerd
# Documentation: https://man.archlinux.org/search?q=upowerd
# Reference accessed: 2026-05-16

# upowerd: UPower D-Bus service for battery/power
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-r[replace existing instance]' \
  '--replace[replace existing instance]' \
  '-i[immediate exit]' \
  '--immediate-exit[immediate exit]' \
  '-t[shutdown timeout in seconds]:seconds:' \
  '--timed-exit=[shutdown timeout in seconds]:seconds:' \
  '*::upowerd args:_files' && ret=0
return ret
