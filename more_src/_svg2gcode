#compdef svg2gcode
# Documentation: https://github.com/sameer/svg2gcode
# svg2gcode - convert vector graphics to g-code for plotters/laser/CNC

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--tolerance=[curve interpolation tolerance (mm)]:tolerance' \
  '--feedrate=[machine feed rate (mm/min)]:feedrate' \
  '--dpi=[dots per inch for scaling visual units]:dpi' \
  '--on=[g-code for turning on the tool]:gcode' \
  '--off=[g-code for turning off the tool]:gcode' \
  '--begin=[g-code for initializing the machine]:gcode' \
  '--end=[g-code for stopping/idling the machine]:gcode' \
  '(-o --out)'{-o,--out}'=[output file path]:file:_files' \
  '--settings=[provide settings from a JSON file]:file:_files' \
  '--export=[export current settings to a JSON file]:file:_files' \
  '--origin=[coordinates for the bottom left corner of the machine]:origin' \
  '--dimensions=[override the width and height of the SVG]:dimensions' \
  '--circular_interpolation=[use circular arcs when generating g-code]:bool:(true false)' \
  '--line_numbers=[include line numbers at start of each line]:bool:(true false)' \
  '--checksums=[include checksums at end of each line]:bool:(true false)' \
  '--newline_before_comment=[add a newline before each comment]:bool:(true false)' \
  '--extra_attribute_name=[print an extra attribute with each node name]:name' \
  '--optimize_path_order=[reorder paths to minimize travel time]:bool:(true false)' \
  '--selector_filter=[CSS selector to filter which SVG elements convert]:selector' \
  '--starting_point=[starting point used when optimizing path]:point' \
  '*:svg file:_files -g "*.svg"' && ret=0

return ret
