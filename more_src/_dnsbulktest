#compdef dnsbulktest
# Documentation: https://doc.powerdns.com/authoritative/manpages/dnsbulktest.1.html
# Send bulk DNS queries to a nameserver and generate response statistics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show summary of options]' \
  '(-q --quiet)'{-q,--quiet}'[suppress per-query result detail]' \
  '(-t --type)'{-t,--type}'[DNS record type to query]:type:(A AAAA MX NS TXT SOA CNAME SRV PTR)' \
  '(-e --envoutput)'{-e,--envoutput}'[format results as shell environment variables]' \
  '--version[show version]' \
  '1:ipaddress:_hosts' \
  '2:port:_ports' \
  '3:limit:' && ret=0

return ret
