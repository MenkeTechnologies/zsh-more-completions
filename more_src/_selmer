#compdef selmer
# _selmer — Yogthos Selmer Django-inspired Clojure template engine CLI alias (yogthos team, Clojure); tools.deps function CLI
# upstream: https://github.com/yogthos/Selmer

_selmer() {
    local -a sub=(
        'render:render a template file with context'
        'compile:precompile templates'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--cache[enable cache]' \
        '--no-cache[disable cache]' \
        '--resource-path=+[resource path]:dir:_files -/' \
        '-r+[resource path]:dir:_files -/' \
        '--escape-variables[escape variables]' \
        '--no-escape-variables[disable escape]' \
        '--template-dir=+[template dir]:dir:_files -/' \
        '-d+[template dir]:dir:_files -/' \
        '--context=+[context edn or json]:str:' \
        '-c+[context edn or json]:str:' \
        '--context-file=+[context file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'selmer subcommand' sub ;;
        args)
            case $words[1] in
                render) _arguments \
                    '1:template file:_files -g "*.{html,txt,selmer}"' \
                    '--context=+[context]:str:' \
                    '--context-file=+[context file]:file:_files' \
                    '--output=+[output file]:file:_files' ;;
                compile) _arguments \
                    '1:template dir:_files -/' \
                    '--output-dir=+[output dir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_selmer "$@"
