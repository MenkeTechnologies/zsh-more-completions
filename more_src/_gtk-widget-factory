#compdef gtk-widget-factory gtk4-widget-factory
# _gtk-widget-factory — GTK demo gtk-widget-factory (GTK developer demo that exercises every stock widget on multiple pages; --version prints, --display picks an X display, --dark forces dark theme, gtk debug flags work via GTK_DEBUG env var)
# upstream: https://gitlab.gnome.org/GNOME/gtk (demos/widget-factory)
# Flags from gtk demos/widget-factory/widget-factory.c on tip.

_gtk-widget-factory() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--display+[X display]:display:' \
        '--dark[force dark theme]'
}

_gtk-widget-factory "$@"
