#compdef pyrasite-memviewer
# _pyrasite-memviewer — urwid-based memory viewer for pyrasite (lmacken/pyrasite)
# upstream: https://github.com/lmacken/pyrasite
# Usage from pyrasite/tools/memory_viewer.py.

_pyrasite-memviewer() {
    _arguments \
        '1:PID:_pids' \
        '2:objects JSON file:_files -g "*.json"'
}

_pyrasite-memviewer "$@"
