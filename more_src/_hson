#compdef hson
# Documentation: https://man.archlinux.org/search?q=hson
# Reference accessed: 2026-05-16

# Zsh completion for hson JSON ↔︎ Headson encoding

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-d[decode Headson to JSON]' \
  '-e[encode JSON to Headson]' \
  '-p[include path column in tables]' \
  '-s[field separator for composites]:separator' \
  '*::files:_files' && ret=0

return ret
