#compdef distrobox-create
# Documentation: https://github.com/89luca89/distrobox/blob/main/docs/usage/distrobox-create.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for distrobox-create. Flags taken verbatim from
# docs/usage/distrobox-create.md (short/long pairs preserved).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --name)'{-n,--name}'[container name]:name' \
  '(-i --image)'{-i,--image}'[container image]:image' \
  '--hostname[container hostname]:hostname' \
  '(-c --clone)'{-c,--clone}'[clone an existing container]:container' \
  '(-H --home)'{-H,--home}'[custom home directory]:directory:_directories' \
  '--volume[additional volumes]:volume:_directories' \
  '(-a --additional-flags)'{-a,--additional-flags}'[extra container manager flags]:flags' \
  '(-ap --additional-packages)'{-ap,--additional-packages}'[additional packages to install]:packages' \
  '--init-hooks=[hooks to run during init]:hooks' \
  '--pre-init-hooks=[hooks before init]:hooks' \
  '(-I --init)'{-I,--init}'[use init system inside container]' \
  '--nvidia[integrate NVIDIA drivers]' \
  '--platform[platform architecture]:platform' \
  '(-r --root)'{-r,--root}'[create as root container]' \
  '(-p --pull)'{-p,--pull}'[pull image even if local]' \
  '(-Y --yes)'{-Y,--yes}'[non-interactive mode]' \
  '--unshare-all[unshare all namespaces]' \
  '--unshare-devsys[unshare /dev and /sys]' \
  '--unshare-groups[unshare user groups]' \
  '--unshare-ipc[unshare IPC namespace]' \
  '--unshare-netns[unshare network namespace]' \
  '--unshare-process[unshare PID namespace]' \
  '(-C --compatibility)'{-C,--compatibility}'[list compatible images]' \
  '--no-entry[skip menu entry generation]' \
  '(-d --dry-run)'{-d,--dry-run}'[dry run]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--absolutely-disable-root-password-i-am-really-positively-sure[disable root password]' && ret=0

return ret
