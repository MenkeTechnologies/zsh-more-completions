#compdef distrobox-create

# Zsh completion for distrobox-create

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-n+[container name]:name' \
  '--name=[container name]:name' \
  '-i+[container image]:image' \
  '--image=[container image]:image' \
  '-I[use init system inside container]' \
  '--init[use init system inside container]' \
  '--nvidia[integrate NVIDIA drivers]' \
  '--unshare-devsys[unshare /dev]' \
  '--unshare-ipc[unshare IPC namespace]' \
  '--unshare-netns[unshare network namespace]' \
  '--unshare-process[unshare PID namespace]' \
  '--unshare-all[unshare all namespaces]' \
  '-H+[home directory]:directory:_directories' \
  '--home=[home directory]:directory:_directories' \
  '--volume=[additional volumes]:volume:_directories' \
  '--additional-flags=[additional podman/docker flags]:flags' \
  '--additional-packages=[additional packages to install]:packages' \
  '--init-hooks=[hooks to run during init]:hooks' \
  '--pre-init-hooks=[hooks before init]:hooks' \
  '-C[clone an existing container]' \
  '--clone=[clone an existing container]:container' \
  '-r[create as root container]' \
  '--root[create as root container]' \
  '-a[create in absolutely ephemeral mode]' \
  '--absolutely-disable-root-password-i-am-really-positively-sure[disable root password]' \
  '-d[dry run]' \
  '--dry-run[dry run]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-Y[non-interactive mode]' \
  '--yes[non-interactive mode]' && ret=0

return ret
