#compdef dcrd
# _dcrd — Decred Project dcrd daemon CLI for the hybrid PoW PoS governance privacy-focused Blake-256 fork of Bitcoin running a full node maintaining the blockchain validating transactions stake voting Politeia governance ticket purchases RPC API (decred team, Go); flag
# upstream: https://github.com/decred/dcrd

_dcrd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-C+[config file]:file:_files -g "*.conf dcrd.conf"' \
        '--configfile=+[config file]:file:_files -g "*.conf dcrd.conf"' \
        '-d+[data dir]:dir:_files -/' \
        '--datadir=+[data dir]:dir:_files -/' \
        '--logdir=+[log dir]:dir:_files -/' \
        '--testnet[use testnet]' \
        '--simnet[use simnet]' \
        '--regnet[use regnet]' \
        '--addrindex[address index]' \
        '--txindex[transaction index]' \
        '--cpuprofile=+[file]:file:_files' \
        '--memprofile=+[file]:file:_files' \
        '--debuglevel=+[level]:l:(error warn info debug trace)' \
        '--listen=+[host:port]:str:' \
        '--externalip=+[ip]:str:' \
        '--addpeer=+[host:port]:str:' \
        '--connect=+[host:port]:str:' \
        '--nodnsseed[no DNS seed]' \
        '--maxpeers=+[N]:n:' \
        '--banduration=+[d]:str:' \
        '--banthreshold=+[N]:n:' \
        '--whitelist=+[csv]:str:' \
        '--rpcuser=+[user]:str:' \
        '--rpcpass=+[password]:str:' \
        '--rpclimituser=+[user]:str:' \
        '--rpclimitpass=+[password]:str:' \
        '--rpccert=+[file]:file:_files -g "*.cert *.pem"' \
        '--rpckey=+[file]:file:_files -g "*.key *.pem"' \
        '--rpclisten=+[host:port]:str:' \
        '--norpc[disable RPC server]' \
        '--norest[disable REST]' \
        '--maxorphantx=+[N]:n:' \
        '--blockmaxsize=+[bytes]:n:' \
        '--blockmaxweight=+[bytes]:n:' \
        '--blockminsize=+[bytes]:n:' \
        '--blockprioritysize=+[bytes]:n:' \
        '--miningaddr=+[addr]:str:' \
        '--blocknotify=+[command]:str:' \
        '--generate[enable CPU mining]' \
        '--proxy=+[host:port]:str:' \
        '--proxyuser=+[user]:str:' \
        '--proxypass=+[password]:str:' \
        '--onion=+[host:port]:str:' \
        '--onionuser=+[user]:str:' \
        '--onionpass=+[password]:str:' \
        '--tor[use Tor]' \
        '--noonion[no onion]' \
        '--upnp[use UPnP]' \
        '--natpmp[use NAT-PMP]' \
        '--minrelaytxfee=+[DCR/kB]:f:' \
        '--limitfreerelay=+[KB/min]:n:' \
        '--norelaypriority[no relay priority]' \
        '--allowoldforks[allow old forks]'
}

_dcrd "$@"
