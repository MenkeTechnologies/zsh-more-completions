#compdef rnix-fmt
# Documentation: https://man.archlinux.org/search?q=rnix-fmt
# Reference accessed: 2026-05-16

# nix-community/rnix-fmt — Nix formatter CLI (`rnix-fmt`/`cargo run` entry uses Clap): input files default to stdin.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--check[exit non-zero if changes needed]' \
  '*:nix file:_files' && ret=0

return ret
