#compdef rnix-fmt
# Documentation: https://github.com/nix-community/rnix-parser
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. STUB: rnix-fmt is not a
# separately published binary; rnix-parser only ships parsing examples.
# Closest formatter is nixpkgs-fmt under a different binary name.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:nix file:_files -g "*.nix"' && ret=0

return ret
