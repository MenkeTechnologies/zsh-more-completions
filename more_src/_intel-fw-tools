#compdef intel-fw-tools

# intel-fw-tools umbrella: Intel firmware tools (csbt, mei, vsccommn)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'mei-mkconf:create MEI configuration'
  'mei-stat:show ME engine status'
  'csbt-update:flash CSE/CSME firmware'
  'fpt:Flash Programming Tool (FPT)'
  'meinfo:show ME info'
  'meflash:flash ME image'
  'igsc:Intel Graphics System Controller update'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'intel-fw-tools command' commands && ret=0 ;;
esac
return ret
