#compdef pvlook
# Documentation: https://csound.com/docs/manual/
# Csound utility to print a formatted text view of a pvanal analysis file

local ret=1

_arguments -s -S \
  '-bb+[begin at analysis bin number n]:bin' \
  '-eb+[end at analysis bin number n]:bin' \
  '-bf+[begin at analysis frame number n]:frame' \
  '-ef+[end at analysis frame number n]:frame' \
  '-i[print values as integers]' \
  '*:pvanal file:_files' && ret=0

return ret
