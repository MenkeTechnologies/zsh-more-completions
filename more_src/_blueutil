#compdef blueutil

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '(-p --power)'{-p,--power}'[Get or set Bluetooth power]:state:(0 1)' \
  '(-d --discoverable)'{-d,--discoverable}'[Get or set discoverable state]:state:(0 1)' \
  '--favourites[List favourite devices]' \
  '--inquiry=[Inquiry for devices with timeout]:seconds:' \
  '--paired[List paired devices]' \
  '--recent=[List recent devices with limit]:count:' \
  '--connected[List connected devices]' \
  '--info=[Show device info]:address:' \
  '--is-connected=[Check if device is connected]:address:' \
  '--connect=[Connect to device]:address:' \
  '--disconnect=[Disconnect from device]:address:' \
  '--pair=[Pair with device]:address:' \
  '--unpair=[Unpair device]:address:' \
  '--add-favourite=[Add device to favourites]:address:' \
  '--remove-favourite=[Remove device from favourites]:address:' \
  '--format=[Output format]:format:(default new-default json json-pretty)' \
  '--wait-connect=[Wait for connection with timeout]:address,timeout:' \
  '--wait-disconnect=[Wait for disconnection with timeout]:address,timeout:' \
  '--wait-rssi=[Wait for RSSI with timeout]:address,timeout:' && return 0
