#compdef tck2connectome
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tck2connectome.html
# generate a connectome matrix from a streamlines file and a node parcellation image

local ret=1

_arguments -s -S \
  '-assignment_end_voxels[use voxel lookup at each streamline endpoint]' \
  '-assignment_radial_search=[radial search from each endpoint (mm)]:radius' \
  '-assignment_reverse_search=[traverse inwards in search of last node (mm)]:max_dist' \
  '-assignment_forward_search=[project streamline forwards from endpoint (mm)]:max_dist' \
  '-assignment_all_voxels[assign streamline to all nodes it intersects]' \
  '-scale_length[scale each contribution by streamline length]' \
  '-scale_invlength[scale each contribution by inverse streamline length]' \
  '-scale_invnodevol[scale each contribution by inverse node volumes]' \
  '-scale_file=[scale each contribution per a vector file]:file:_files' \
  '-symmetric[make matrices symmetric on output]' \
  '-zero_diagonal[set matrix diagonal to zero on output]' \
  '-stat_edge=[statistic for combining edge values]:statistic:(sum mean min max)' \
  '-tck_weights_in=[text scalar file of streamline weights]:file:_files' \
  '-keep_unassigned[keep streamlines not assigned to a node pair]' \
  '-out_assignments=[output node assignments of each streamline]:file:_files' \
  '-vector[output a vector rather than a matrix]' \
  '-info[display information messages]' \
  '-quiet[suppress information and progress messages]' \
  '-debug[display debugging messages]' \
  '-force[force overwrite of output files]' \
  '-nthreads=[number of threads]:number' \
  '-config=[temporarily set a config entry]:key:_default:value' \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[display version information]' \
  '1:tracks_in:_files' \
  '2:nodes_in:_files' \
  '3:connectome_out:_files' && ret=0

return ret
