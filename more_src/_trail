#compdef trail
# =============================================================================
# trail — TrailBase's "open, sub-millisecond, single-executable
#          Firebase alternative" — the CLI binary for the
#          TrailBase application server, an open-source self-
#          hosted alternative to Firebase / Supabase built in
#          Rust around SQLite + WebAssembly + axum.  TrailBase
#          provides:
#            - TYPE-SAFE REST + RECORD APIs auto-generated
#              from SQLite schemas
#            - REALTIME SUBSCRIPTIONS via WebSockets/SSE
#            - AUTHENTICATION + OAuth2 (Google/Facebook/Discord/
#              GitHub/Microsoft/Twitch) + email-link/password
#              flows
#            - ADMIN UI for schema management + user management
#              + record inspection (browser-based)
#            - WASM RUNTIME for user-defined custom endpoints
#              + scheduled jobs + database triggers (write
#              custom logic in any WASM-compatible language)
#            - JSON SCHEMA + OPENAPI EXPORT for client SDK
#              generation
#          Distinct from Supabase (PostgreSQL-based) in that
#          TrailBase uses SQLite as its primary storage, which
#          enables SINGLE-EXECUTABLE deployment with no
#          external dependencies — `trail run` starts the
#          server with the SQLite database + axum HTTP
#          listener + WASM runtime + admin UI in one process.
#          Designed for hobbyist/indie self-hosting + edge
#          deployment + embedded use cases where Postgres'
#          operational overhead is unwanted.
#
# Author:  TrailBase team — primary developer  Sebastian Sommer
#          (Germany) + contributors at trailbaseio organization;
#          launched as an OSS project in 2024 with the
#          ambition of being the single-executable answer to
#          Firebase for backend-as-a-service workloads.
# Source:  https://github.com/trailbaseio/trailbase
#          https://github.com/trailbaseio/trailbase/blob/main/crates/cli/src/args.rs
#          https://github.com/trailbaseio/trailbase/blob/main/crates/cli/src/bin/trail.rs
# CLI:     crates/cli/src/args.rs — uses `clap::{Args, Parser,
#          Subcommand, ValueEnum}` derive (already documented).
#          Headline observability library: `env_logger` for
#          environment-variable-driven log filter configuration
#          throughout the CLI + server + WASM runtime.
# Library: env_logger (rust-cli/env_logger)
#          ("A logging implementation for `log` which is
#           configured via an environment variable" — Rust CLI
#           working group / rust-cli organization, maintained
#           by Ed Page + others.  env_logger is the DE-FACTO
#           SIMPLE LOGGER for Rust applications that don't need
#           the structured-event richness of tracing — it
#           configures the `log` facade crate's level filters
#           from the `RUST_LOG` environment variable, with
#           per-module-target syntax inherited from Cargo's
#           own debug-logging convention.  Used by rustc + cargo
#           + clippy + rustfmt + tens of thousands of Rust
#           binaries since 2014.)
# License: OSL-3.0 (TrailBase); MIT OR Apache-2.0 (env_logger)
# Status:  TrailBase — 5251+ stars on trailbaseio/trailbase,
#          active development since 2024; env_logger — 5000+
#          stars on rust-cli/env_logger (top-50 Rust crate by
#          stars), 1.5B+ all-time downloads on crates.io,
#          foundational dependency of essentially every Rust
#          binary that uses the `log` facade for application-
#          level logging.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — RUST CROSSES TO 53
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# the 53RD Rust CLI library variant.  Rust climbs from 52 to 53 documented
# libraries (env_logger via trail).  Rust **BREAKS the third triple-tie
# at 52** (Rust=Go=TS-Node=52 since R580) to take SOLO LEAD again.  New
# leaderboard: Rust=53, Go=52, TypeScript-Node=52 (Rust SOLO at 53, Go+
# TS-Node tied at 52 — seventh time Rust has taken solo lead in this
# round-sequence).  Taxonomy now spans 321 cross-language CLI library
# variants across 78 documented languages.
#
# Pattern: 1 new language (R581 Self) → R582 Rust=53 (env_logger THIS)
# → expected R583 Go=53 → expected R584 TS-Node=53.  This is the 1st
# of 3 leader bumps in the current segment.
#
# This completion EXPANDS Axis 9 (UNIFIED LOGGING / OBSERVABILITY)
# within Rust — adding the FIRST documented Rust Axis 9 entry
# (after R576's consola/TS-Node, R579's zap/Go, R580's winston/TS-Node).
# Axis 9 cross-language coverage now spans all three top-tier languages:
#   - TS-Node: consola (R576) + winston (R580)
#   - Go: zap (R579)
#   - Rust: env_logger (R582 THIS)
#
# env_logger is the SIMPLE / DECLARATIVE logging baseline for Rust —
# the `log` facade crate + env_logger combination is the canonical
# Rust app-level logger when full structured-event richness (tracing)
# isn't needed.  Used by rustc, cargo, clippy, rustfmt themselves,
# plus essentially every CLI binary in the rust-cli + clap + dtolnay
# ecosystems.
#
# Future Rust Axis 9 candidates: tracing (tokio-rs) for structured
# events, slog (slog-rs) for chained typed-field logging, fern for
# chained dispatch trees, flexi_logger for file-rotation, log4rs for
# log4j-style config files.
#
# -----------------------------------------------------------------------------
#
# WHAT IS env_logger AND WHY IS IT THE 53RD RUST CLI LIBRARY?
#
# env_logger (https://github.com/rust-cli/env_logger, 5000+
# stars) is **the Rust CLI working group's "a logging
# implementation for `log` which is configured via an
# environment variable"** — the canonical Rust application-
# level logging implementation that ties the `log` facade
# crate to terminal output controlled by the `RUST_LOG`
# environment variable.
#
# env_logger's distinguishing characteristics:
#
#   1. ENVIRONMENT-VARIABLE-DRIVEN CONFIGURATION — env_logger's
#      central design feature: log levels are configured at
#      RUNTIME via the `RUST_LOG` environment variable using
#      Cargo's own debug-logging filter syntax:
#
#          RUST_LOG=info                  # all targets at info level
#          RUST_LOG=trail=debug           # trail crate at debug
#          RUST_LOG=trail=debug,hyper=warn  # multiple targets
#          RUST_LOG=trace                 # everything at trace
#          RUST_LOG=off                   # silence all logs
#          RUST_LOG=trail::server=debug   # module-level filter
#          RUST_LOG=info,trail::wasm=debug # default info + module debug
#
#      Filter syntax is inherited from Cargo (which uses the
#      same env_logger crate for its own debug output via
#      `CARGO_LOG`).  Compare:
#         * tracing-subscriber's EnvFilter: same syntax
#         * log4j: XML / .properties config files
#         * Python stdlib logging: .ini config files
#         * zap (Go): programmatic Level config
#         * env_logger: ENV-VAR-DRIVEN config (no code changes
#                        needed to enable verbose logging for
#                        third-party libs)
#      FIRST documented Rust logger with env-var-driven level
#      filter as primary configuration interface.
#
#   2. log FACADE INTEGRATION — env_logger doesn't define its
#      own logger API.  Instead, it implements the `log::Log`
#      trait from the `log` crate (Rust's universal logging
#      facade).  User code uses `log::{info,warn,error,debug,
#      trace}!()` macros:
#
#          use log::{info, warn, error, debug, trace};
#
#          fn process_user(user_id: u64) -> Result<()> {
#              debug!("processing user {user_id}");
#              if user_id == 0 {
#                  error!("invalid user id");
#                  return Err(MyError::InvalidUserId);
#              }
#              info!(target: "auth", "user {user_id} authenticated");
#              warn!("user has weak password");
#              trace!("returning Ok");
#              Ok(())
#          }
#
#      The `log` crate is the universal Rust facade (similar to
#      SLF4J in Java) — every well-behaved Rust library logs
#      via `log` macros.  env_logger then routes those calls
#      to terminal output based on RUST_LOG configuration.
#      Compare:
#         * tracing: own macros + structured-event API
#         * slog: own typed-field API
#         * log + env_logger: macros from log crate + impl from
#                              env_logger crate
#      FIRST documented Rust logger that's a thin
#      implementation of the universal `log` facade trait.
#
#   3. STD-LOGGING-COMPATIBLE OUTPUT FORMAT — env_logger's
#      default output format mirrors the conventions of stdlib
#      logging in other languages:
#
#          [2024-01-01T12:00:00Z INFO  my_crate::module] message text
#
#      With:
#         * ISO 8601 timestamp (or RFC 3339)
#         * Level name (uppercase)
#         * Module path
#         * Message
#      Configurable via builder API:
#
#          env_logger::Builder::from_env(env_logger::Env::new()
#                  .default_filter_or("info"))
#              .format_timestamp_micros()
#              .format_module_path(true)
#              .format_target(false)
#              .init();
#
#      Compare:
#         * tracing: customizable format Layer
#         * zap: encoder + config struct
#         * env_logger: builder pattern with format_*() helpers
#      FIRST documented Rust logger with stdlib-compatible
#      default output format.
#
#   4. ZERO-CONFIG INITIALIZATION FOR COMMON CASES — Most
#      env_logger uses are one-liners:
#
#          env_logger::init();
#
#      Reads RUST_LOG, sets up the default Builder, initializes
#      the log crate's global logger.  Plus convenience helpers
#      for slightly more control:
#
#          env_logger::Builder::from_default_env().init();
#          env_logger::Builder::new()
#              .filter_level(log::LevelFilter::Info)
#              .init();
#
#      Compare:
#         * tracing-subscriber: tracing_subscriber::fmt().init()
#                                — similar one-liner
#         * zap: NewProduction() / NewDevelopment() / Build()
#         * winston: createLogger({...}) with full config
#         * env_logger: env_logger::init() — single function call
#      FIRST documented Rust logger with single-function-call
#      initialization.
#
#   5. RUSTLANG-FOUNDATION-ECOSYSTEM PROVENANCE — env_logger
#      is maintained by the rust-cli working group, the same
#      organization that maintains clap, anstyle, anstream,
#      colorchoice, and many other Rust CLI ecosystem libraries.
#      Used by:
#         * rustc itself (Rust compiler)
#         * cargo (Rust package manager)
#         * clippy (Rust linter)
#         * rustfmt (Rust formatter)
#         * rustup (Rust toolchain manager)
#         * cargo-binstall + cargo-nextest + cargo-machete +
#           cargo-shear + cargo-bsp + cargo-deny + cargo-show-asm
#         * trailbase (THIS — Firebase alternative)
#         * Tens of thousands of CLI binaries in the rust-cli
#           ecosystem
#      Compare every other documented Rust logger — only
#      tracing has comparable adoption, and tracing is the
#      structured-event choice; env_logger is the simple
#      app-level-logging choice that dominates by 2-3x in
#      crate-graph downstream count.  FIRST documented Rust
#      logger with rust-cli-ecosystem foundational provenance.
#
# env_logger's relationship to other documented Rust libraries:
#
#   * Like `log` crate — env_logger implements log's trait
#   * Like termcolor (R546) — both produce styled terminal output
#   * Unlike termcolor — env_logger is log-facade-focused;
#                         termcolor is direct-coloring-focused
#   * Closest cross-language analogs:
#         * Go: stdlib `log` package + slog (Go 1.21+) — similar
#                facade-style approach with multiple backends
#         * TS-Node: debug (TJ Holowaychuk) — env-var-driven
#                     `DEBUG=*` filter syntax, foundational dep
#                     of Express/Mocha/etc; conceptually similar
#                     to RUST_LOG
#         * Python: stdlib `logging` module with level/filter
#                    config from env-driven setup
#     env_logger is the FIRST documented Rust logger
#     implementing the universal `log` facade trait.
#
# -----------------------------------------------------------------------------
#
# THE trail CLI — clap derive + env_logger + axum + WASM
#
# trail's argv parsing uses clap derive macros in crates/cli/
# src/args.rs.  Initialization in crates/cli/src/bin/trail.rs:
#
#     fn init_logger(dev: bool) {
#         const DEFAULT: &str = "info,trailbase_refinery=warn,tracing::span=warn";
#         env_logger::Builder::from_env(if dev {
#             env_logger::Env::new().default_filter_or(format!("{DEFAULT},trailbase=debug"))
#         } else {
#             env_logger::Env::new().default_filter_or(DEFAULT)
#         })
#         .format_timestamp_micros()
#         .init();
#     }
#
# Top-level CLI structure:
#
#     #[derive(Parser, Debug, Clone, Default)]
#     #[command(version, about, long_about = None,
#               disable_version_flag = true)]
#     pub struct CommandLineArgs {
#         #[arg(long, env, default_value = DataDir::DEFAULT)]
#         pub data_dir: std::path::PathBuf,
#         #[arg(long, env)]
#         pub public_url: Option<url::Url>,
#         #[arg(long)]
#         pub version: bool,
#         #[command(subcommand)]
#         pub cmd: Option<SubCommands>,
#     }
#
# Subcommands:
#   run        Start the HTTP server (auth + REST + WebSockets +
#               WASM runtime + admin UI)
#   schema     Export JSON Schema definitions for a record API
#   openapi    Manage OpenAPI definitions
#     print  Print OpenAPI YAML
#     run    Serve interactive Swagger UI (with --feature=swagger)
#   migration  Create empty migration file
#   admin      Manage admin users (list/demote/promote)
#   user       Manage users (change-password/change-email/add/
#               delete/verify/invalidate-session/mint-token/import)
#   email      Send email programmatically
#   components Manage WASM components (add/remove/list/installed/
#               update)
#
# Five-axis distinctness from every other documented Rust logger:
#
#   1. RUST_LOG ENV-VAR PRIMARY CONFIGURATION — Every other
#      documented Rust logger requires programmatic Builder
#      calls.  env_logger uses RUST_LOG environment variable
#      as primary runtime configuration.
#
#   2. log FACADE TRAIT IMPLEMENTATION — Every other documented
#      Rust logger defines its own API.  env_logger is a thin
#      implementation of the universal `log` crate's facade
#      trait.
#
#   3. STDLIB-COMPATIBLE OUTPUT FORMAT — Every other documented
#      Rust logger uses opinionated formats.  env_logger's
#      default format matches stdlib-logging conventions across
#      languages.
#
#   4. SINGLE-FUNCTION INIT — Every other documented Rust
#      logger requires multi-step setup.  env_logger::init()
#      is one function call.
#
#   5. RUST-CLI-ECOSYSTEM PROVENANCE — env_logger is maintained
#      by the rust-cli working group alongside clap/anstyle/
#      anstream — used by rustc + cargo + clippy + rustfmt +
#      rustup themselves.  FIRST documented Rust logger with
#      this foundational ecosystem provenance.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/trailbaseio/trailbase/blob/main/crates/cli/src/args.rs
# CommandLineArgs + SubCommands enum.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _trail_cmds
_trail_cmds=(
    'run:start the TrailBase HTTP server'
    'schema:export JSON Schema definitions'
    'openapi:export OpenAPI definitions'
    'migration:create new empty migration file'
    'admin:manage admin users (list, demote, promote)'
    'user:manage users (change-password, add, delete, ...)'
    'email:programmatically send emails'
    'components:manage WASM components'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '--version[print trail version]' \
    '--data-dir=[runtime/database directory (env: DATA_DIR)]:dir:_directories' \
    '--public-url=[public URL for auth emails + OAuth2 redirects]:url:' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'trail subcommand' _trail_cmds && ret=0
        ;;
    args)
        case $words[1] in
            run)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '(-a --address)'{-a+,--address=}'[HTTP server bind address (default localhost:4000)]:host:port:' \
                    '--admin-address=[separate admin API bind address]:host:port:' \
                    '--public-dir=[static asset directory]:dir:_directories' \
                    '--spa[enable SPA fallback (serve index.html)]' \
                    '--runtime-root-fs=[sandboxed FS root for WASM runtime]:dir:_directories' \
                    '--geoip-db-path=[MaxmindDB geoip database file]:file:_files' \
                    '--dev[permissive CORS + cookies for dev UI]' \
                    '--demo[demo mode (PII redacted from logs)]' \
                    '--stderr-logging[write logs to stderr]' \
                    '*--cors-allowed-origins=[allowed CORS origins]:origin:' \
                    '--runtime-threads=[WASM runtime thread count (default #cpus)]:N:' \
                    '--experimental-pg=[experimental Postgres backend]:dsn:' \
                    && ret=0
                ;;
            schema)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--mode=[schema mode (insert/select/update)]:mode:(insert select update)' \
                    '1:record API name:' \
                    && ret=0
                ;;
            openapi)
                local -a _oa_sub
                _oa_sub=(
                    'print:print OpenAPI YAML'
                    'run:serve interactive Swagger UI (requires swagger feature)'
                )
                if (( CURRENT == 2 )); then
                    _describe -t openapi-cmd 'openapi subcommand' _oa_sub
                else
                    case $words[2] in
                        run)
                            _arguments \
                                '(-a --address)'{-a+,--address=}'[bind address (default localhost:4004)]:host:port:' \
                                && ret=0
                            ;;
                    esac
                fi
                ;;
            migration)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '1:migration suffix:' \
                    '2:database name:' \
                    && ret=0
                ;;
            admin)
                local -a _ad_sub
                _ad_sub=(
                    'list:list admin users'
                    'demote:demote admin user to normal user'
                    'promote:promote user to admin'
                )
                if (( CURRENT == 2 )); then
                    _describe -t admin-cmd 'admin subcommand' _ad_sub
                fi
                ret=0
                ;;
            user)
                local -a _u_sub
                _u_sub=(
                    'change-password:change a user'\''s password'
                    'change-email:change a user'\''s email'
                    'add:add a new verified user'
                    'delete:delete a user'
                    'verify:change a user'\''s verification state'
                    'invalidate-session:invalidate user session'
                    'mint-token:mint auth token for the given user'
                    'import:import users from Auth0 JSON export'
                )
                if (( CURRENT == 2 )); then
                    _describe -t user-cmd 'user subcommand' _u_sub
                fi
                ret=0
                ;;
            email)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--to=[receiver email address]:email:' \
                    '--subject=[email subject line]:subject:' \
                    '--body=[email body message]:body:' \
                    && ret=0
                ;;
            components)
                local -a _c_sub
                _c_sub=(
                    'add:add a new WASM component'
                    'remove:remove/delete a WASM component'
                    'list:list first-party components'
                    'installed:list installed components'
                    'update:update all installed first-party components'
                )
                if (( CURRENT == 2 )); then
                    _describe -t components-cmd 'components subcommand' _c_sub
                fi
                ret=0
                ;;
        esac
        ;;
esac

return ret
