#compdef loki loki-canary promtail loki-mixtool
# Documentation: https://github.com/kyle-rader/loki-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (loki)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-version[show version]' \
      '-config.file+[config file]:file:_files -g "*.yml *.yaml"' \
      '-config.expand-env+[expand env vars]:b:(true false)' \
      '-target+[run mode]:t:(all read write distributor ingester querier query-frontend table-manager ruler index-gateway compactor pattern-ingester bloom-compactor bloom-gateway)' \
      '-modules[list modules]' \
      '-print-config-stderr[print config to stderr]' \
      '-log-config-reverse-order[log config reverse]' \
      '-log.level+[log level]:l:(debug info warn error)' \
      '-log.format+[log format]:f:(logfmt json)' \
      '-server.http-listen-port+[HTTP port]:port:' \
      '-server.grpc-listen-port+[gRPC port]:port:' \
      '-tracing.enabled+[tracing enabled]:b:(true false)' \
      '-list-targets[list run modes]' \
      '*: :' && ret=0 ;;
  (promtail)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-version[show version]' \
      '-config.file+[config file]:file:_files -g "*.yml *.yaml"' \
      '-config.expand-env+[expand env]:b:(true false)' \
      '-print-config-stderr[print config]' \
      '-server.http-listen-port+[HTTP port]:port:' \
      '-server.grpc-listen-port+[gRPC port]:port:' \
      '-server.disable[disable HTTP server]' \
      '-client.url+[client URL]:url:_urls' \
      '-client.batch-size-bytes+[batch size]:n:' \
      '-client.batch-wait+[batch wait]:t:' \
      '-client.external-labels+[labels]:s:' \
      '-client.tenant-id+[tenant id]:id:' \
      '-positions.file+[positions file]:file:_files' \
      '-positions.sync-period+[sync period]:t:' \
      '-target.config+[target config]:file:_files' \
      '-dry-run[dry run]' \
      '-inspect[inspect]' \
      '-list-targets[list targets]' \
      '*: :' && ret=0 ;;
  (loki-canary)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-version[show version]' \
      '-addr+[loki address]:addr:' \
      '-tls[use TLS]' \
      '-cert-file+[cert file]:file:_files' \
      '-key-file+[key file]:file:_files' \
      '-ca-file+[CA file]:file:_files' \
      '-user+[user]:user:_users' \
      '-pass+[password]:pass:' \
      '-pprof-port+[pprof port]:port:' \
      '-port+[metrics port]:port:' \
      '-labelname+[label name]:name:' \
      '-labelvalue+[label value]:value:' \
      '-interval+[push interval]:t:' \
      '-size+[entry size]:n:' \
      '-wait+[query timeout]:t:' \
      '-query-timeout+[query timeout]:t:' \
      '-spot-check-interval+[spot check interval]:t:' \
      '-spot-check-max+[spot check max]:t:' \
      '-spot-check-query-rate+[spot check rate]:t:' \
      '-out-of-order-percentage+[out of order pct]:n:' \
      '-out-of-order-min+[oo min]:t:' \
      '-out-of-order-max+[oo max]:t:' \
      '-stream-name+[stream name]:n:' \
      '-stream-value+[stream value]:v:' \
      '*: :' && ret=0 ;;
  (loki-mixtool)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*: :_files' && ret=0 ;;
esac

return ret
