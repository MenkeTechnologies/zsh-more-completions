#compdef usbrip

# Zsh completion for usbrip - USB event forensics tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'banner:print banner'
  'events:work with USB event history'
  'storage:work with USB event storage'
  'ids:work with USB device IDs'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      events)
        local -a events_cmds=(
          'history:show USB event history'
          'open:open dump file'
          'genauth:generate authorized device list'
          'violations:show unauthorized USB events'
        )
        _arguments \
          ':action:->events_action' \
          '*:: :->events_args' && ret=0
        case $state in
          events_action)
            _describe -t commands 'action' events_cmds && ret=0
            ;;
          events_args)
            _arguments \
              '(-q --quiet)'{-q,--quiet}'[quiet output]' \
              '(-l --list)'{-l,--list}'[output as list]' \
              '(-e --external)'{-e,--external}'[show external devices only]' \
              '(-n --number)'{-n,--number}'[number of events]:count:' \
              '(-d --date)'{-d,--date}'[filter by date range]:dates:' \
              '(-c --column)'{-c,--column}'[columns to show]:columns:' \
              '(-f --file)'{-f,--file}'[log file]:file:_files' \
              '--vid=[filter by vendor ID]:vid:' \
              '--pid=[filter by product ID]:pid:' \
              '--manufact=[filter by manufacturer]:manufacturer:' \
              '--serial=[filter by serial number]:serial:' \
              '--port=[filter by port]:port:' \
              '-o[output file]:file:_files' && ret=0
            ;;
        esac
        ;;
      storage)
        local -a storage_cmds=(
          'list:list storage entries'
          'open:open storage file'
          'update:update storage'
          'create:create storage'
          'passwd:change password'
        )
        _arguments ':action:_describe -t commands action storage_cmds' && ret=0
        ;;
      ids)
        local -a ids_cmds=(
          'search:search USB IDs'
          'download:download USB ID database'
        )
        _arguments ':action:_describe -t commands action ids_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
