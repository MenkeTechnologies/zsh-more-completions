#compdef snapper-gui
# _snapper-gui — Snapper btrfs/Snapper GTK frontend CLI alias (Snapper team, Python); argparse
# upstream: https://github.com/openSUSE/snapper

_snapper-gui() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config name]:str:' \
        '-c+[config name]:str:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '*:arg:'
}

_snapper-gui "$@"
