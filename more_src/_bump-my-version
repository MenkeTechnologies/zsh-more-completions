#compdef bump-my-version
# Documentation: https://callowayproject.github.io/bump-my-version/reference/cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# callowayproject/bump-my-version — modern successor to bump2version.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'bump:bump a version part'
  'show:show parsed version info'
  'show-bump:show what would be bumped'
  'replace:replace strings in configured files'
  'sample-config:emit a sample config'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'bump-my-version subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (bump)
        _arguments \
          '--config-file=[config file]:file:_files' \
          '*-v[verbose (repeatable)]' \
          '*--verbose[verbose (repeatable)]' \
          '--allow-dirty[allow uncommitted changes]' \
          '--no-allow-dirty[disallow uncommitted changes]' \
          '--current-version=[current version]:version:' \
          '--new-version=[new version]:version:' \
          '--parse=[parse regex]:regex:' \
          '--serialize=[serialization format]:format:' \
          '--search=[search pattern]:pattern:' \
          '--replace=[replacement]:replace:' \
          '--regex[treat search/replace as regex]' \
          '--no-regex[do not treat as regex]' \
          '--no-configured-files[skip configured files]' \
          '--ignore-missing-files[ignore missing files]' \
          '--no-ignore-missing-files[do not ignore missing files]' \
          '--ignore-missing-version[ignore missing version]' \
          '--no-ignore-missing-version[do not ignore missing version]' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '--commit[commit changes]' \
          '--no-commit[do not commit]' \
          '--tag[tag commit]' \
          '--no-tag[do not tag]' \
          '--sign-tags[sign tags]' \
          '--no-sign-tags[do not sign tags]' \
          '--tag-name=[tag name template]:template:' \
          '--tag-message=[tag message template]:template:' \
          '(-m --message)'{-m,--message=}'[commit message template]:template:' \
          '--commit-args=[extra git commit args]:args:' \
          ':part:(major minor patch)' \
          '*:file:_files' && ret=0
        ;;
      (show)
        _arguments \
          '--config-file=[config file]:file:_files' \
          '(-f --format)'{-f,--format=}'[output format]:format:(default yaml json)' \
          '(-i --increment)'{-i,--increment=}'[increment version part]:part:' \
          '--current-version=[current version]:version:' \
          '*:key:' && ret=0
        ;;
      (show-bump)
        _arguments \
          '--config-file=[config file]:file:_files' \
          '--ascii[ASCII-only output]' \
          '*-v[verbose]' \
          ':version:' && ret=0
        ;;
      (replace)
        _arguments \
          '--config-file=[config file]:file:_files' \
          '*-v[verbose]' \
          '--allow-dirty[allow dirty working dir]' \
          '--no-allow-dirty[disallow dirty working dir]' \
          '--current-version=[current version]:version:' \
          '--new-version=[new version]:version:' \
          '--parse=[parse regex]:regex:' \
          '--serialize=[serialization format]:format:' \
          '--search=[search pattern]:pattern:' \
          '--replace=[replacement]:replace:' \
          '--regex[treat as regex]' \
          '--no-regex[do not treat as regex]' \
          '--no-configured-files[skip configured files]' \
          '--ignore-missing-files[ignore missing files]' \
          '--ignore-missing-version[ignore missing version]' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '*:file:_files' && ret=0
        ;;
      (sample-config)
        _arguments \
          '--prompt[interactive config]' \
          '--no-prompt[non-interactive]' \
          '--destination=[output location]:dest:(stdout .bumpversion.toml pyproject.toml)' && ret=0
        ;;
    esac
    ;;
esac

return ret
