#compdef usdedit
# Documentation: https://openusd.org/release/toolset.html
# Converts USD files to text format for editing, then converts back

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --noeffect)'{-n,--noeffect}'[do not edit the file]' \
  '(-f --forcewrite)'{-f,--forcewrite}'[override file permissions for writing]' \
  '(-p --prefix)'{-p,--prefix}'[provide prefix for temporary file name]:prefix:' \
  '*:USD file:_files' && ret=0

return ret
