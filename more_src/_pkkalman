#compdef pkkalman
# Documentation: https://pktools.nongnu.org/html/pkkalman.html
# spatio-temporal Kalman filter data assimilation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-dir --direction)'{-dir,--direction}'[direction to run model (forward|backward|smooth)]:value:' \
  '(-mod --model)'{-mod,--model}'[coarse spatial resolution input datasets(s) used as model. Use either]:file:_files' \
  '(-modmask --modmask)'{-modmask,--modmask}'[model mask datasets(s). Must have same dimension as model input. Use e]:file:_files' \
  '(-obs --observation)'{-obs,--observation}'[fine spatial resolution input dataset(s) used as observation. Use eith]:file:_files' \
  '(-obsmask --obsmask)'{-obsmask,--obsmask}'[observation mask dataset(s). Must have same dimension as observation i]:file:_files' \
  '(-tmod --tmodel)'{-tmod,--tmodel}'[time sequence of model input. Sequence must have exact same length as]:value:' \
  '(-tobs --tobservation)'{-tobs,--tobservation}'[time sequence of observation input. Sequence must have exact same leng]:value:' \
  '(-a_srs --a_srs)'{-a_srs,--a_srs}'[Override the projection for the output file (leave blank to copy from]:value:' \
  '(-ofw --outputfw)'{-ofw,--outputfw}'[Output raster dataset for forward model]:value:' \
  '(-u_ofw --u_outputfw)'{-u_ofw,--u_outputfw}'[Uncertainty output raster dataset for forward model]:value:' \
  '(-obw --outputbw)'{-obw,--outputbw}'[Output raster dataset for backward model]:value:' \
  '(-u_obw --u_outputbw)'{-u_obw,--u_outputbw}'[Uncertainty output raster dataset for backward model]:value:' \
  '(-ofb --outputfb)'{-ofb,--outputfb}'[Output raster dataset for smooth model]:value:' \
  '(-u_ofb --u_outputfb)'{-u_ofb,--u_outputfb}'[Uncertainty output raster dataset for smooth model]:value:' \
  '(-modnodata --modnodata)'{-modnodata,--modnodata}'[invalid value for model input]:value:' \
  '(-obsnodata --obsnodata)'{-obsnodata,--obsnodata}'[invalid value for observation input]:value:' \
  '(-msknodata --msknodata)'{-msknodata,--msknodata}'[Mask value not to consider]:value:' \
  '(-mskband --mskband)'{-mskband,--mskband}'[Mask band to read (0 indexed)]:value:' \
  '(-obsmin --obsmin)'{-obsmin,--obsmin}'[Minimum value for observation data]:value:' \
  '(-obsmax --obsmax)'{-obsmax,--obsmax}'[Maximum value for observation data]:value:' \
  '(-eps --eps)'{-eps,--eps}'[epsilon for non zero division]:value:' \
  '(-um --uncertmodel)'{-um,--uncertmodel}'[Uncertainty of the model]:value:' \
  '(-uo --uncertobs)'{-uo,--uncertobs}'[Uncertainty of valid observations]:value:' \
  '(-unodata --uncertnodata)'{-unodata,--uncertnodata}'[Uncertainty in case of no-data values in observation]:value:' \
  '(-q --q)'{-q,--q}'[Process noise\: expresses instability (variance) of proportions of fine]:value:' \
  '(-down --down)'{-down,--down}'[Downsampling factor for reading model data to calculate regression (de]:value:' \
  '(-ot --otype)'{-ot,--otype}'[Data type for output image ({Byte/Int16/UInt16/UInt32/Int32/Float32/Fl]:value:' \
  '(-of --oformat)'{-of,--oformat}'[Output image format (see also gdal_translate).]:value:' \
  '(-co --co)'{-co,--co}'[Creation option for output file. Multiple options can be specified.]:value:' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode when positive]' \
  '*:file:_files' && ret=0

return ret
