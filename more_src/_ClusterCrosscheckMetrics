#compdef ClusterCrosscheckMetrics
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/fingerprint/ClusterCrosscheckMetrics.java
# Picard: clusters the results of a CrosscheckFingerprints run by LOD score

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[cross-check metrics file to be clustered]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output metrics file]:file:_files' \
  '(-LOD --LOD_THRESHOLD)'{-LOD,--LOD_THRESHOLD}'=[LOD score threshold for clustering]:n:' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
