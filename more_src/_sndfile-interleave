#compdef sndfile-interleave
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/sndfile-interleave.1.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu jammy sndfile-interleave(1) manpage and upstream
# libsndfile/programs/sndfile-interleave.c. Usage:
# `sndfile-interleave input1 input2 ... -o output`. Output format
# inferred from extension.

local -a arguments

arguments=(
    '-o[output file]:file:_files'
    '*:input mono sound file:_files -g "*.{wav,flac,ogg,aiff,aif,au,snd,w64,caf,rf64}"'
)

_arguments -s -S $arguments
