#compdef arelo
# Documentation: https://github.com/makiuchi-d/arelo
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for arelo
# Upstream: Simple auto reload (live reload) utility
# Conservative fallback — run `arelo --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
