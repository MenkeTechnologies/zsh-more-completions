#compdef 3dClusterize
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dClusterize.html
# AFNI: find clusters of contiguous voxels and report them

local ret=1

_arguments -s -S \
  '-inset[input dataset to threshold and cluster]:dataset:_files' \
  '-mask[mask dataset defining cluster search region]:mask:_files' \
  '-mask_from_hdr[use internal mask from dataset header]' \
  '-out_mask[output the used mask as a volume]:prefix:' \
  '-ithr[sub-brick index for threshold source]:index:' \
  '-idat[sub-brick index for data source]:index:' \
  '-1sided[one-sided test: tail and threshold]:tail:' \
  '-2sided[two-sided test: left and right bounds]:left:' \
  '-bisided[two-sided, clusters cannot mix tails]:left:' \
  '-within_range[cluster values within a range]:lower:' \
  '-NN[voxel connectivity 1/2/3]:nn:(1 2 3)' \
  '-clust_nvox[minimum cluster size in voxels]:n:' \
  '-clust_vol[minimum cluster size in microliters]:vol:' \
  '-pref_map[output filename for cluster ROI map]:prefix:' \
  '-pref_dat[output filename for cluster-masked data]:prefix:' \
  '-1Dformat[write output in 1D format (default)]' \
  '-no_1Dformat[disable 1D format output]' \
  '-summarize[output only total voxel count and volume]' \
  '-nosum[suppress totals printout]' \
  '-quiet[suppress non-essential output]' \
  '-outvol_if_no_clust[output empty volume if no clusters]' \
  '-orient[coordinate orientation in report table]:orient:' \
  '-abs_table_data[use absolute values for mean and SEM]' \
  '-noabs[deprecated; no longer needed]' \
  '-binary[convert cluster map to binary mask]' \
  '*:dataset:_files' && ret=0

return ret
