#compdef ip-tunnel
# Documentation: https://man.archlinux.org/man/ip-tunnel.8.en
# ip tunnel - tunnel configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip tunnel command' \
      'add[create new tunnel]' 'change[modify existing tunnel]' \
      'del[destroy tunnel]' 'show[list tunnels]' \
      'prl[potential router list]' '6rd[6rd configuration]' \
      'mode[tunnel encapsulation type]' 'remote[endpoint address]' \
      'local[fixed local address]' 'dev[bind to physical device]' \
      'ttl[fixed TTL]' 'hoplimit[fixed hoplimit]' 'tos[type of service]' \
      'dsfield[type of service]' 'tclass[traffic class]' \
      'flowlabel[IPv6 flowlabel]' 'encaplimit[IPv6 encapsulation limit]' \
      'key[keyed GRE identifier]' 'ikey[input key]' 'okey[output key]' \
      'csum[checksums]' 'icsum[require input checksums]' \
      'ocsum[generate output checksums]' 'seq[packet serialization]' \
      'iseq[input sequencing]' 'oseq[output sequencing]' \
      'pmtudisc[Path MTU Discovery]' 'nopmtudisc[disable Path MTU Discovery]' \
      'ignore-df[suppress IPv4 DF flag]' 'allow-localremote[permit local remote]' && ret=0
    ;;
esac

return ret
