#compdef apt-fast

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-y --yes --assume-yes)'{-y,--yes,--assume-yes}'[assume yes to prompts]' \
  '(-d --download-only)'{-d,--download-only}'[download only]' \
  '(-s --simulate --dry-run)'{-s,--simulate,--dry-run}'[simulate actions]' \
  '--no-install-recommends[do not install recommended packages]' \
  '--install-suggests[install suggested packages]' \
  '--fix-broken[fix broken packages]' \
  '--purge[use purge instead of remove]' \
  '-q[quiet output]' \
  '1:command:(install remove purge update upgrade full-upgrade dist-upgrade autoremove clean autoclean source build-dep download changelog show search list edit-sources)' \
  '*:package:_deb_packages avail' && ret=0

return ret
