#compdef gfxrecon-replay
# Documentation: https://vulkan.lunarg.com/doc/view/latest/linux/capture_tools.html
# gfxrecon-replay - replay GFXReconstruct capture files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '--version[print version information]' \
  '--log-level=[specify minimum log severity]:level:(debug info warning error fatal)' \
  '--log-file=[write log messages to a file]:file:_files' \
  '--paused[pause replay before the first frame]' \
  '--pause-frame=[pause after replaying the given frame]:frame' \
  '--screenshot-all[generate a screenshot for every frame]' \
  '--screenshots=[generate screenshots for the specified frame ranges]:frames' \
  '--screenshot-format=[image file format for screenshots]:format:(bmp png)' \
  '--screenshot-dir=[directory to write screenshots]:dir:_files -/' \
  '--screenshot-prefix=[prefix for screenshot file names]:prefix' \
  '--screenshot-scale=[scale screenshot dimensions]:scale' \
  '--screenshot-size=[set screenshot dimensions]:size' \
  '--screenshot-interval=[take a screenshot every Nth frame in a range]:n' \
  '--sync[synchronize after each queue submission]' \
  '--validate[enable the Vulkan validation layer]' \
  '--sfa[skip allocations that fail on replay]' \
  '--skip-failed-allocations[skip allocations that fail on replay]' \
  '--opcd[omit pipeline cache data]' \
  '--omit-pipeline-cache-data[omit pipeline cache data]' \
  '--replace-shaders=[replace shaders from the given directory]:dir:_files -/' \
  '--wsi=[force a specific windowing system integration]:wsi' \
  '--surface-index=[restrict rendering to a single surface]:index' \
  '--remove-unsupported[remove unsupported extensions and features]' \
  '(-m --memory-translation)'{-m,--memory-translation}'=[enable memory translation mode]:mode:(none remap realign rebind)' \
  '--fwo[force a windowed origin at the given coordinates]:origin' \
  '--force-windowed-origin=[force a windowed origin at the given coordinates]:origin' \
  '--dump-resources=[dump graphics resources for the given submit/command]:spec' \
  '--dump-resources-dir=[directory to write dumped resources]:dir:_files -/' \
  '*:capture file:_files' && ret=0

return ret
