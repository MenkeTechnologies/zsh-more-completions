#compdef varnishhist

# Zsh completion for varnishhist - varnish request histogram

_arguments -s -S \
  '-h[show help]' \
  '-V[show version]' \
  '-B+[bucket magnitude]:bucket magnitude:' \
  '-d[process only log records already in the buffer, then exit]' \
  '-g+[the grouping of log records]:grouping:(session request vxid raw)' \
  '-k+[exit after processing N log records]:n:' \
  '-n+[specify the name of the varnishd instance to get logs of]:name:' \
  '-N+[specify a stale VSM file]:file:_files' \
  '-p+[refresh interval (seconds)]:seconds:' \
  '-P+[profile definition]:profile:' \
  '-q+[VSL query]:query:' \
  '-r+[read from file instead of a running varnishd instance]:file:_files' \
  '-R+[maximum log records to process per second]:n:' \
  '-t+[specify the varnishd status response timeout]:seconds:' \
  '-w+[number of buckets in width]:n:'
