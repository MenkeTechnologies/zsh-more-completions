#compdef gwf
# Documentation: https://gwf.app/
# Flexible, pragmatic workflow tool for building and running pipelines

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '--version[show version]' \
  '(-f --file)'{-f,--file}'=[workflow file/object to load]:file:_files -g "*.py"' \
  '(-b --backend)'{-b,--backend}'=[backend used to run the workflow]:backend' \
  '(-v --verbose)'{-v,--verbose}'=[set the verbosity level]:level:(warning debug info error)' \
  '(--no-color --use-color)--no-color[disable colored output]' \
  '(--no-color --use-color)--use-color[enable colored output]' \
  '1:command:((
    init\:"initialize a new gwf workflow"
    run\:"run the targets of a workflow"
    status\:"show the status of workflow targets"
    logs\:"show the logs of a target"
    cancel\:"cancel running or submitted targets"
    clean\:"clean output files of targets"
    info\:"show detailed information about targets"
    config\:"get and set configuration options"
    touch\:"touch output files to mark targets as up to date"
    workers\:"start local workers for the local backend"
  ))' \
  '*::arg:_default' && ret=0

return ret
