#compdef appinspector devskim oss-defog oss-detect-backdoor oss-detect-cryptography oss-diff oss-download oss-find-source oss-find-squats oss-health oss-metadata oss-risk-calculator
# Documentation: upstream READMEs + wiki at github.com/microsoft/{ApplicationInspector,DevSkim,OSSGadget}
# Reference accessed: 2026-05-30
# Microsoft security/analysis CLI suite harvest. 12 stems via single
# multi-stem file dispatched on $service.
# Hunt-defer log this round:
#   oss-characteristic — wiki page exists but enumerates no flags;
#     defer per the gh-grep precedent.
#   oss-find-domain-squats — wiki page not enumerated; defer.
#   oss-reproducible — wiki page not enumerated; defer.

local curcontext="$curcontext" state line ret=1

case $service in

  appinspector)
    # microsoft/ApplicationInspector — static analysis CLI (.NET Global Tool).
    # Binary: appinspector. 7 subcommands.
    local -a _subcmds
    _subcmds=(
      'analyze:inspect source for defined characteristics'
      'tagdiff:compare unique tag values between two sources'
      'exporttags:export the list of tags associated with rules'
      'verifyrules:verify custom rules syntax'
      'packrules:combine multiple rule files into one'
      'help:show help for a command'
      'version:show version'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'appinspector subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          analyze)
            _arguments \
              '-s+[source path (required)]:path:_files' \
              '-f+[output format]:format:(html json sarif markdown)' \
              '-o+[output file path]:file:_files' \
              '-g+[glob patterns for excluding files]:globs:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  devskim)
    # microsoft/DevSkim — security analysis CLI (.NET Global Tool).
    # Binary: devskim. Primary subcommand `analyze` with ~30 flags.
    local -a _subcmds
    _subcmds=(
      'analyze:scan files/directory for security issues'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'devskim subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          analyze)
            _arguments \
              '(-I --source-code)-I+[source path (required)]:path:_files' \
              '(-I --source-code)--source-code=[source path (required)]:path:_files' \
              '(-O --output-file)-O+[output file]:file:_files' \
              '(-O --output-file)--output-file=[output file]:file:_files' \
              '--options-json=[JSON file with serialized analyze options]:file:_files -g "*.json"' \
              '-r+[comma-separated custom rule files/dirs]:rules:' \
              '--rule-ids=[comma-separated rule IDs to include]:ids:' \
              '--ignore-rule-ids=[comma-separated rule IDs to exclude]:ids:' \
              '--languages=[custom JSON language definitions]:file:_files -g "*.json"' \
              '--comments=[custom JSON comments file]:file:_files -g "*.json"' \
              '(-o --output-format)-o+[custom text output format template]:template:' \
              '(-o --output-format)--output-format=[custom text output format template]:template:' \
              '(-f --file-format)-f+[output format]:format:(text sarif)' \
              '(-f --file-format)--file-format=[output format]:format:(text sarif)' \
              '(-s --severity)-s+[severity levels (comma-separated)]:severities:' \
              '(-s --severity)--severity=[severity levels (comma-separated)]:severities:' \
              '--confidence=[confidence levels (comma-separated)]:levels:' \
              '(-g --ignore-globs)-g+[glob patterns to skip]:globs:' \
              '(-g --ignore-globs)--ignore-globs=[glob patterns to skip]:globs:' \
              '(-d --disable-supression)-d[disable comment-based suppressions]' \
              '(-d --disable-supression)--disable-supression[disable comment-based suppressions]' \
              '--disable-parallel[disable parallel processing]' \
              '(-i --ignore-default-rules)-i[use only custom rules]' \
              '(-i --ignore-default-rules)--ignore-default-rules[use only custom rules]' \
              '(-c --crawl-archives)-c[analyze files inside archives]' \
              '(-c --crawl-archives)--crawl-archives[analyze files inside archives]' \
              '--skip-git-ignored-files[skip files ignored by .gitignore]' \
              '--base-path=[root path for SARIF result URIs]:path:_directories' \
              '--absolute-path[output absolute file paths]' \
              '--skip-excerpts[omit excerpts from reports]' \
              '(-x --console-verbosity)-x+[console output verbosity]:level:' \
              '(-x --console-verbosity)--console-verbosity=[console output verbosity]:level:' \
              '--disable-console[suppress console logging]' \
              '(-v --log-file-level)-v+[log file verbosity]:level:' \
              '(-v --log-file-level)--log-file-level=[log file verbosity]:level:' \
              '(-l --log-file-path)-l+[log file path]:file:_files' \
              '(-l --log-file-path)--log-file-path=[log file path]:file:_files' \
              '-E[use exit code to represent issue count]' \
              '--help[show help]' \
              '--version[show version]' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  oss-defog)
    # microsoft/OSSGadget oss-defog — find obfuscated text (hex/base64).
    _arguments -s -S \
      '--download-directory=[directory to download package to]:directory:_directories' \
      '--report-blobs[report unidentified data blobs (verbose)]' \
      '--minimum-hex-length=[minimum hex string length (default 8)]:N:' \
      '--minimum-base64-length=[minimum base64 length (default 1)]:N:' \
      '--save-found-binaries-to=[save discovered encoded binaries to dir]:directory:_directories' \
      '--save-archives-to=[save encoded compressed files to dir]:directory:_directories' \
      '--save-blobs-to=[save unknown encoded blobs to dir]:directory:_directories' \
      '--use-cache[skip downloading if package already exists]' \
      '--help[show help]' \
      '--version[show version]' \
      '*:Package URL (purl) or directory:' \
      && ret=0
    ;;

  oss-detect-backdoor)
    # microsoft/OSSGadget oss-detect-backdoor — flag potential malicious code.
    _arguments -s -S \
      '(-d --download-directory)-d+[download directory (default .)]:directory:_directories' \
      '(-d --download-directory)--download-directory=[download directory (default .)]:directory:_directories' \
      '(-f --format)-f+[output format]:format:(text sarifv1 sarifv2)' \
      '(-f --format)--format=[output format]:format:(text sarifv1 sarifv2)' \
      '(-o --output-file)-o+[output file]:file:_files' \
      '(-o --output-file)--output-file=[output file]:file:_files' \
      '(-c --use-cache)-c[skip downloading if package already exists]' \
      '(-c --use-cache)--use-cache[skip downloading if package already exists]' \
      '--help[show help]' \
      '--version[show version]' \
      '*:Package URL (purl):' \
      && ret=0
    ;;

  oss-detect-cryptography)
    # microsoft/OSSGadget oss-detect-cryptography — find crypto implementations.
    _arguments -s -S \
      '--verbose[increase output verbosity]' \
      '--custom-rule-directory=[custom rules directory]:directory:_directories' \
      '--disable-default-rules[do not load default rules]' \
      '--download-directory=[download directory]:directory:_directories' \
      '--use-cache[skip downloading if package already exists]' \
      '--format=[output format]:format:(text sarifv1 sarifv2)' \
      '--output-file=[output file]:file:_files' \
      '--help[show help]' \
      '--version[show version]' \
      '*:Package URL (purl) or directory:' \
      && ret=0
    ;;

  oss-diff)
    # microsoft/OSSGadget oss-diff — compare two package versions.
    _arguments -s -S \
      '(-d --download-directory)-d+[download directory]:directory:_directories' \
      '(-d --download-directory)--download-directory=[download directory]:directory:_directories' \
      '(-c --use-cache)-c[skip re-downloading + retain files]' \
      '(-c --use-cache)--use-cache[skip re-downloading + retain files]' \
      '(-w --crawl-archives)-w[explore archives within packages (default true)]' \
      '(-w --crawl-archives)--crawl-archives[explore archives within packages (default true)]' \
      '(-B --context-before)-B+[lines of preceding context (default 0)]:N:' \
      '(-B --context-before)--context-before=[lines of preceding context (default 0)]:N:' \
      '(-A --context-after)-A+[lines of following context (default 0)]:N:' \
      '(-A --context-after)--context-after=[lines of following context (default 0)]:N:' \
      '(-C --context)-C+[lines of context (-1 = all; overrides -B/-A)]:N:' \
      '(-C --context)--context=[lines of context (-1 = all; overrides -B/-A)]:N:' \
      '(-a --added-only)-a[show only newly added lines + context]' \
      '(-a --added-only)--added-only[show only newly added lines + context]' \
      '(-r --removed-only)-r[show only deleted lines + context]' \
      '(-r --removed-only)--removed-only[show only deleted lines + context]' \
      '(-f --format)-f+[output format]:format:(text sarifv1 sarifv2)' \
      '(-f --format)--format=[output format]:format:(text sarifv1 sarifv2)' \
      '(-o --output-location)-o+[output file]:file:_files' \
      '(-o --output-location)--output-location=[output file]:file:_files' \
      '--help[show help]' \
      '--version[show version]' \
      '*:Package URL (purl):' \
      && ret=0
    ;;

  oss-download)
    # microsoft/OSSGadget oss-download — download a package locally.
    _arguments -s -S \
      '(-x --download-directory)-x+[save directory (default cwd)]:directory:_directories' \
      '(-x --download-directory)--download-directory=[save directory (default cwd)]:directory:_directories' \
      '(-m --download-metadata-only)-m[retrieve metadata only, no download]' \
      '(-m --download-metadata-only)--download-metadata-only[retrieve metadata only, no download]' \
      '(-e --extract)-e[unpack downloaded package contents]' \
      '(-e --extract)--extract[unpack downloaded package contents]' \
      '(-c --use-cache)-c[skip re-download if package already exists]' \
      '(-c --use-cache)--use-cache[skip re-download if package already exists]' \
      '--help[show help]' \
      '--version[show version]' \
      '*:Package URL (purl):' \
      && ret=0
    ;;

  oss-find-source)
    # microsoft/OSSGadget oss-find-source — locate source repository for a package.
    _arguments -s -S \
      '(-f --format)-f+[output format]:format:(text sarifv1 sarifv2)' \
      '(-f --format)--format=[output format]:format:(text sarifv1 sarifv2)' \
      '(-o --output-file)-o+[output file]:file:_files' \
      '(-o --output-file)--output-file=[output file]:file:_files' \
      '(-S --single)-S[show only top possibility]' \
      '(-S --single)--single[show only top possibility]' \
      '--help[show help]' \
      '--version[show version]' \
      '*:Package URL (purl):' \
      && ret=0
    ;;

  oss-find-squats)
    # microsoft/OSSGadget oss-find-squats — detect typo-squatting candidates.
    _arguments -s -S \
      '(-o --output-file)-o+[output file]:file:_files' \
      '(-o --output-file)--output-file=[output file]:file:_files' \
      '(-f --format)-f+[output format]:format:(text sarifv1 sarifv2)' \
      '(-f --format)--format=[output format]:format:(text sarifv1 sarifv2)' \
      '(-q --quiet)-q[suppress console output]' \
      '(-q --quiet)--quiet[suppress console output]' \
      '(-s --sleep-delay)-s+[ms sleep between checks]:N:' \
      '(-s --sleep-delay)--sleep-delay=[ms sleep between checks]:N:' \
      '--help[show help]' \
      '--version[show version]' \
      '*:Package URL (purl):' \
      && ret=0
    ;;

  oss-health)
    # microsoft/OSSGadget oss-health — collect project health metrics.
    _arguments -s -S \
      '(-f --format)-f+[output format]:format:(text sarifv1 sarifv2)' \
      '(-f --format)--format=[output format]:format:(text sarifv1 sarifv2)' \
      '(-o --output-file)-o+[output file]:file:_files' \
      '(-o --output-file)--output-file=[output file]:file:_files' \
      '--help[show help]' \
      '--version[show version]' \
      '*:Package URL (purl):' \
      && ret=0
    ;;

  oss-metadata)
    # microsoft/OSSGadget oss-metadata — fetch package metadata.
    _arguments -s -S \
      '(-o --output-file)-o+[output file]:file:_files' \
      '(-o --output-file)--output-file=[output file]:file:_files' \
      '--help[show help]' \
      '--version[show version]' \
      '*:Package URL (purl):' \
      && ret=0
    ;;

  oss-risk-calculator)
    # microsoft/OSSGadget oss-risk-calculator — generate risk assessment.
    _arguments -s -S \
      '(-d --download-directory)-d+[download directory (required)]:directory:_directories' \
      '(-d --download-directory)--download-directory=[download directory (required)]:directory:_directories' \
      '(-r --external-risk)-r+[external risk to include (default 0)]:N:' \
      '(-r --external-risk)--external-risk=[external risk to include (default 0)]:N:' \
      '(-f --format)-f+[output format]:format:(text sarifv1 sarifv2)' \
      '(-f --format)--format=[output format]:format:(text sarifv1 sarifv2)' \
      '(-o --output-file)-o+[output file]:file:_files' \
      '(-o --output-file)--output-file=[output file]:file:_files' \
      '(-n --no-health)-n[skip project health check]' \
      '(-n --no-health)--no-health[skip project health check]' \
      '--verbose[enable verbose output]' \
      '(-c --use-cache)-c[skip re-download if package already exists]' \
      '(-c --use-cache)--use-cache[skip re-download if package already exists]' \
      '--help[show help]' \
      '--version[show version]' \
      '*:Package URL (purl):' \
      && ret=0
    ;;

esac

return ret
