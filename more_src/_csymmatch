#compdef csymmatch
# Documentation: https://www.ccp4.ac.uk/html/csymmatch.html
# CCP4 csymmatch: match symmetry-related copies of a PDB model to a reference

local ret=1

_arguments -s -S \
  '-pdbin-ref[reference PDB file]:file:_files' \
  '-pdbin[input PDB file to be shifted]:file:_files' \
  '-pdbout[output PDB file]:file:_files' \
  '-connectivity-radius[radius (A) for contiguous fragments]:radius:' \
  '-origin-hand[try all origin shifts and changes of hand]' \
  '-stdin[read keywords from standard input]' \
  '*:file:_files' && ret=0

return ret
