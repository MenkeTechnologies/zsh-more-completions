#compdef cvs-debuild
# Documentation: https://manpages.debian.org/cvs-debuild
# Source: debian/devscripts scripts/cvs-debuild.pl — wrapper around cvs-buildpackage using debuild (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '--lintian-opts[end of debuild opts; rest are lintian opts]' \
    '*::debuild / cvs-buildpackage / lintian opts:_default' \
    && ret=0

return ret
