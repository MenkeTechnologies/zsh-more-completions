#compdef virt-v2v
# _virt-v2v — virt-v2v (convert a foreign-hypervisor VM (VMware, Hyper-V, Xen, raw OVA) into a libvirt/KVM domain; -i input mode (libvirt|disk|libvirtxml|ova|vmx), -ic input URI, -ip password file, -o output mode (libvirt|local|qemu|null|kubevirt|json), -oc output URI, -on output name, -os storage pool, -of format, -oa allocation, --bridge map host bridge, --network override; positional argument is source guest name)
# upstream: https://github.com/libguestfs/virt-v2v
# Flags from virt-v2v v2v/v2v.ml on tip.

_virt-v2v() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-x[trace libguestfs calls]' \
        '-q[quiet]' \
        '-i+[input mode]:mode:(libvirt libvirtxml disk vmx ova kubevirt vddk)' \
        '-ic+[input URI]:uri:' \
        '-ip+[input password file]:file:_files' \
        '-it+[input transport]:transport:(ssh vddk)' \
        '-io+[input option]:opt:' \
        '-o+[output mode]:mode:(libvirt local qemu null kubevirt openstack rhv-upload glance disk json)' \
        '-oc+[output URI]:uri:' \
        '-on+[output name]:name:' \
        '-os+[storage pool]:pool:' \
        '-of+[output format]:fmt:(raw qcow2 vmdk)' \
        '-oa+[allocation]:alloc:(sparse preallocated)' \
        '-op+[output password]:file:_files' \
        '-oo+[output option]:opt:' \
        '*--bridge+[srcbridge=dstbridge]:bridge:' \
        '*--network+[srcnet=dstnet]:network:' \
        '*--mac+[mac=type:name]:mac:' \
        '--root+[root drive]:drive:' \
        '--machine-readable[machine readable output]' \
        '*:guest:'
}

_virt-v2v "$@"
