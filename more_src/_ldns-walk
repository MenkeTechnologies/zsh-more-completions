#compdef ldns-walk
# _ldns-walk — NLnet Labs ldns-walk (DNSSEC NSEC-chain walker; enumerates owner names + record types in a signed zone by following NSEC records)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-walk.c usage on tip.

_ldns-walk() {
    _arguments \
        '(-4 -6)-4[force IPv4]' \
        '(-4 -6)-6[force IPv6]' \
        '-f[full mode: fetch all RRsets, not just name+types]' \
        '-s+[start from this name]:name:' \
        '-v+[verbosity level]:level:(1 2 3 4 5)' \
        '-version[show version and exit]' \
        '*:domain-or-@nameserver:'
}

_ldns-walk "$@"
