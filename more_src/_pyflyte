#compdef pyflyte pyflyte-fast-execute pyflyte-map-execute pyflyte-execute
# Documentation: https://github.com/flyteorg/flytekit
# Reference accessed: 2026-05-23
# Verified: pyflyte --help (Flytekit Python CLI).

# Zsh completion for pyflyte - Flytekit Python workflow CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '(-v --verbose)'{-v+,--verbose=}'[verbose messages and traces]:level:' \
  '(-k --pkgs)'{-k+,--pkgs=}'[python packages to operate on]:packages:' \
  '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'pyflyte command' \
      'backfill[generate and register backfill workflow]' \
      'build[build image for workflow or task]' \
      'execution[interact with Flyte executions]' \
      'fetch[retrieve execution inputs and outputs]' \
      'get[get remote objects]' \
      'info[print Flyte Python CLI environment info]' \
      'init[create flyte-ready projects]' \
      'launchplan[activate or deactivate launch plan]' \
      'local-cache[interact with local cache]' \
      'metrics[metrics commands]' \
      'package[produce registrable Flyte package]' \
      'register[compile and register entities to backend]' \
      'run[run workflow or task from command line]' \
      'serialize[produce task and workflow protobufs]' \
      'serve[start a Flyte service]' && ret=0
    ;;
esac

return ret
