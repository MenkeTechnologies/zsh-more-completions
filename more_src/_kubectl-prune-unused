#compdef kubectl-prune-unused
# kubectl-prune-unused (krew plugin): prune unused Kubernetes resources
# https://github.com/micnncim/kubectl-prune

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[scan all namespaces]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--dry-run[show what would be deleted]' \
  '--force[skip confirmation prompt]' \
  '*:resource type:(configmap secret serviceaccount pvc role rolebinding)'
