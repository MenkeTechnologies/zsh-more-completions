#compdef ocamlfind
# _ocamlfind-bin — OCamlFind library manager (Gerd Stolpmann, OCaml); package resolver for OCaml libs
# upstream: https://github.com/ocaml/ocamlfind

_ocamlfind-bin() {
    local -a sub=(
        'browser:browse package'
        'install:install package'
        'list:list installed packages'
        'lint:lint META file'
        'ocamlc:wrap ocamlc'
        'ocamldep:wrap ocamldep'
        'ocamldoc:wrap ocamldoc'
        'ocamlmklib:wrap ocamlmklib'
        'ocamlmktop:wrap ocamlmktop'
        'ocamlopt:wrap ocamlopt'
        'printconf:print configuration'
        'printppx:print ppx info'
        'query:query package info'
        'remove:remove package'
        'reset:reset to factory defaults'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ocamlfind subcommand' sub ;;
        args)
            case $words[1] in
                list) _arguments '-describe[describe each]' ;;
                query) _arguments \
                    '-recursive[recursive]' \
                    '-r[recursive]' \
                    '-format+[format string]:str:' \
                    '-predicates+[predicates]:str:' \
                    '-prefix+[prefix]:str:' \
                    '-suffix+[suffix]:str:' \
                    '-separator+[separator]:str:' \
                    '-pp[print pp]' \
                    '-ppopt[print ppopt]' \
                    '-l[print directory]' \
                    '-d[show description]' \
                    '-a-format[print archive format]' \
                    '*:package:' ;;
                install) _arguments \
                    '-destdir+[destdir]:dir:_files -/' \
                    '-metadir+[meta dir]:dir:_files -/' \
                    '-ldconf+[ld.conf]:file:_files' \
                    '-don'\''t-add-directory-directive[no directory directive]' \
                    '-add-toolchain+[toolchain]:tc:' \
                    '-optional[optional]' \
                    '-patch-version+[version]:ver:' \
                    '-patch-archives+[archives]:str:' \
                    '*:meta:_files' ;;
                remove) _arguments '-destdir+[destdir]:dir:_files -/' '-metadir+[meta dir]:dir:_files -/' '*:package:' ;;
                printconf) _arguments '1:section:(conf path destdir metadir metapath stdlib ldconf)' ;;
            esac
            ;;
    esac
}

_ocamlfind-bin "$@"
