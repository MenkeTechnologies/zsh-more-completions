#compdef conflux conflux-rust
# _conflux-rust — Conflux Foundation conflux-rust full-node implementation for the Conflux Tree-Graph DAG-based public PoS/PoW hybrid Layer-1 blockchain (Conflux-Chain team, Rust); clap
# upstream: https://github.com/Conflux-Chain/conflux-rust

_conflux-rust() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.toml"' \
        '--config=+[config file]:file:_files -g "*.toml"' \
        '--full-config-deserialize[full config deserialize]' \
        '--mode=+[mode]:m:(full archive light dev)' \
        '--network-id=+[id]:n:' \
        '--port=+[port]:n:' \
        '--udp-port=+[port]:n:' \
        '--jsonrpc-tcp-port=+[port]:n:' \
        '--jsonrpc-http-port=+[port]:n:' \
        '--jsonrpc-ws-port=+[port]:n:' \
        '--public-address=+[addr]:str:' \
        '--bootnodes=+[csv]:str:' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--db-dir=+[dir]:dir:_files -/' \
        '--netconf-dir=+[dir]:dir:_files -/' \
        '--log-conf=+[file]:file:_files' \
        '--log-file=+[file]:file:_files' \
        '--mining-author=+[addr]:str:' \
        '--mining-type=+[type]:t:(cpu stratum disable)' \
        '--mining-power-fraction=+[F]:f:' \
        '--stratum-listen-address=+[addr]:str:' \
        '--stratum-port=+[port]:n:' \
        '--stratum-secret=+[secret]:str:' \
        '--start-mining[start mining]' \
        '--pos-config=+[file]:file:_files' \
        '--pos-private-key=+[file]:file:_files' \
        '--persist-block-number-index[persist block number index]' \
        '--persist-tx-index[persist tx index]' \
        '--get-logs-filter-max-block-number-range=+[N]:n:' \
        '--get-logs-filter-max-limit=+[N]:n:' \
        '--node-table-promote-timeout=+[N]:n:' \
        '--node-table-demote-timeout=+[N]:n:' \
        '--metrics-output-file=+[file]:file:_files' \
        '--metrics-influxdb-host=+[host]:h:_hosts'
}

_conflux-rust "$@"
