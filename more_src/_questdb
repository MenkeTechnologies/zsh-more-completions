#compdef questdb

# Zsh completion for questdb - QuestDB time-series database

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start QuestDB'
  'stop:stop QuestDB'
  'status:show QuestDB status'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'questdb command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (start)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --root-directory)'{-d,--root-directory}'[root directory]:directory:_files -/' \
          '(-f --force)'{-f,--force}'[force start]' \
          '(-n --node)'{-n,--node}'[node id]:id' \
          '(-t --tag)'{-t,--tag}'[service tag]:tag' \
          '--http-port=[HTTP port]:port' \
          '--pg-port=[PostgreSQL wire protocol port]:port' \
          '--ilp-port=[InfluxDB line protocol port]:port' \
          '--min-port=[minimum IPC port]:port' \
          '--max-port=[maximum IPC port]:port' \
          '--log-file=[log file path]:file:_files' \
          '--config=[server configuration file]:file:_files' && ret=0
        ;;
      (stop)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --root-directory)'{-d,--root-directory}'[root directory]:directory:_files -/' \
          '(-t --tag)'{-t,--tag}'[service tag]:tag' && ret=0
        ;;
      (status)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --root-directory)'{-d,--root-directory}'[root directory]:directory:_files -/' \
          '(-t --tag)'{-t,--tag}'[service tag]:tag' && ret=0
        ;;
    esac
    ;;
esac

return ret
