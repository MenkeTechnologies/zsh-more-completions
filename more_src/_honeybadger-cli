#compdef honeybadger-cli honeybadger
# _honeybadger-cli — Honeybadger honeybadger-cli CLI command-line frontend wrapping the Honeybadger error monitoring application performance monitoring uptime monitoring cron monitoring exception tracking platform CLI providing login deploy install test heartbeat notify source-map upload-source-map sourcemap-upload project user team revision context environment-name (Honeybadger team, Ruby); thor
# upstream: https://www.honeybadger.io/

_honeybadger-cli() {
    local -a sub=(
        'login:authenticate'
        'whoami:show identity'
        'install:install client'
        'test:send test notice'
        'deploy:report a deployment'
        'notify:notify an event'
        'heartbeat:send heartbeat'
        'source-map:source map operations'
        'upload-source-map:upload source map'
        'project:project operations'
        'user:user operations'
        'team:team operations'
        'check:check operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--personal-auth-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '-e+[environment]:str:' \
        '--environment=+[env]:str:' \
        '--revision=+[sha]:str:' \
        '--repository=+[url]:str:' \
        '--user=+[name]:_users' \
        '--message=+[text]:str:' \
        '--token=+[token]:str:' \
        '--app-name=+[name]:str:' \
        '--js-url=+[url]:str:' \
        '--map-url=+[url]:str:' \
        '--map-file=+[file]:file:_files -g "*.map"' \
        '--no-config[no config]' \
        '-c+[config file]:file:_files -g "honeybadger.yml *.yml"' \
        '--config=+[file]:file:_files -g "honeybadger.yml *.yml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'honeybadger subcommand' sub ;;
        args)
            case $words[1] in
                deploy|notify|heartbeat) _arguments '*:arg:' ;;
                source-map|upload-source-map) _arguments '*:file:_files -g "*.map *.js"' ;;
                project|user|team|check) _arguments '1:op:(list get create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_honeybadger-cli "$@"
