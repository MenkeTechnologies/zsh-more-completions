#compdef grrshell
# Documentation: https://github.com/google/grrshell
# GRRShell - interactive CLI for GRR remote clients

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--grr-server=[GRR HTTP endpoint address]:url' \
  '--username=[GRR username]:user' \
  '--password=[GRR password]:password' \
  '--client=[target client FQDN or ID]:client' \
  '--max-file-size=[max file size for collections]:bytes' \
  '--remote-path=[ClientFileFinder expression]:expression' \
  '--local-path=[local directory for files]:directory:_directories' \
  '--artefact=[artifact name to collect]:artifact' \
  '--initial-timeline=[existing timeline flow ID]:id' \
  '--no-initial-timeline[start without collecting timeline]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'grrshell command' \
      'shell[interactive remote filesystem shell]' \
      'collect[collect files from client]' \
      'artefact[collect artifacts from client]' \
      'artifact[collect artifacts from client]' && ret=0
    ;;
esac

return ret
