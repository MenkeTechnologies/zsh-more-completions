#compdef ovs-pki
# Documentation: https://man.archlinux.org/search?q=ovs-pki
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize new PKI'
  'req:generate private key and CSR'
  'sign:sign cert request'
  'req+sign:combined req and sign'
  'verify:verify certificate'
  'fingerprint:print cert fingerprint'
  'self-sign:sign cert with own private key'
)

_arguments -C \
  '(-k --key)'{-k,--key=}'[key type]:type:(rsa dsa)' \
  '(-B --bits)'{-B,--bits=}'[key bits]:n:' \
  '(-D --dsaparam)'{-D,--dsaparam=}'[dsaparam file]:file:_files' \
  '(-b --batch)'{-b,--batch}'[batch mode]' \
  '(-f --force)'{-f,--force}'[force overwrite]' \
  '(-d --dir)'{-d,--dir=}'[PKI directory]:dir:_files -/' \
  '(-l --log)'{-l,--log=}'[log file]:file:_files' \
  '(-u --unique)'{-u,--unique}'[unique CN]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ovs-pki subcommand' subcommands && ret=0
    ;;
esac

return ret
