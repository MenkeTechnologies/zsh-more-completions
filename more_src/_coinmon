#compdef coinmon
# Documentation: https://github.com/bichenkk/coinmon
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '(-c --convert)'{-c,--convert}'=[convert to currency]:currency:(USD EUR GBP JPY AUD CAD CHF CNY BTC ETH)'
  '(-f --find)'{-f,--find}'=[find specific coin]:coin name:'
  '(-t --top)'{-t,--top}'=[show top N coins]:number:'
  '(-H --humanize)'{-H,--humanize}'[humanize large numbers]'
  '(-h --help)'{-h,--help}'[show help message]'
  '(-V --version)'{-V,--version}'[show version]'
)

_arguments -s -S $arguments
