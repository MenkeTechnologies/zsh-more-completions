#compdef carla-database
# Documentation: https://github.com/falkTX/Carla
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (see data/carla-database launcher and source/frontend/carla_database.py).

# Carla plugin database browser/editor. Launcher script wraps the Python frontend.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--gdb[run inside gdb]' \
  '--with-libprefix=[library prefix path]:path:_directories' \
  '*::args:_files' && ret=0
return ret
