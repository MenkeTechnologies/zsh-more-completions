#compdef carla-database
# Documentation: https://man.archlinux.org/search?q=carla-database
# Reference accessed: 2026-05-16

# Carla plugin database browser/editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '*::carla-database args:_files' && ret=0
return ret
