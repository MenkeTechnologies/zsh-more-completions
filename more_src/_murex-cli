#compdef murex-cli murex2
# _murex-cli — Lawrence Murex murex-cli CLI command-line frontend wrapping the Murex modern POSIX-like shell with full structured data type support inspired by zsh fish PowerShell and so forth open-source written in Go originally Lawrence now Murex team Murex is a shell like Bash but designed for a modern workload and exists as a hobbyist project structured-data-types pipelines-bytes pipelines-JSON pipelines-CSV pipelines-YAML pipelines-arrays pipelines-tables type-safe-pipelines event-driven-shell file-system-events network-events daemon-restart-events autocompletion BetterStandardErrors aliases automation runtime test unit-tests integration-tests interactive REPL script murex sandbox subshell rm -c --command --file --interactive --quiet --no-rc --no-history --no-color --no-bg --debug (Lawrence Murex team, Go); custom argparse
# upstream: https://murex.rocks/

_murex-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[command]:str:' \
        '--command=+[command]:str:' \
        '*-c+[command]:str:' \
        '--file=+[file]:file:_files -g "*.mx *.murex"' \
        '-f+[file]:file:_files -g "*.mx *.murex"' \
        '--source=+[code]:str:' \
        '*--source=+[code]:str:' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-rc[no rc]' \
        '--no-history[no history]' \
        '--no-color[no color]' \
        '--no-bg[no background]' \
        '--no-banner[no banner]' \
        '--debug[debug]' \
        '--profile=+[file]:file:_files -g "*.mx"' \
        '--rcfile=+[file]:file:_files -g "*.mx"' \
        '--cd=+[dir]:dir:_files -/' \
        '*:murex file:_files -g "*.mx *.murex"'
}

_murex-cli "$@"
