#compdef runai
# Documentation: https://run-ai-docs.nvidia.com/saas/reference/cli/runai
# Run:ai command-line interface for submitting and managing GPU workloads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config-file=[config file name (RUNAI_CLI_CONFIG_FILE)]:file:_files' \
  '--config-path=[config path (RUNAI_CLI_CONFIG_PATH)]:dir:_files -/' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all output except errors]' \
  '--verbose[enable verbose mode]' \
  '1:command:(auth cluster config compute datasource department diagnostics environment inference jax kubeconfig login logout mpi my-credential node nodepool project pvc pytorch report template tensorflow training upgrade version whoami workload workload-type workspace xgboost)' \
  '*::arg:->args' && ret=0

return ret
