#compdef nf-core

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'pipelines:pipeline commands (create/list/download/lint/sync/launch/etc.)'
  'modules:module commands (install/remove/create/lint/etc.)'
  'subworkflows:subworkflow commands'
  'configs:configs commands'
  'tui:open the textual TUI'
  'lint:legacy lint shortcut for pipelines lint'
  'list:legacy list shortcut'
  'create:legacy create shortcut'
  'download:legacy download shortcut'
  'launch:legacy launch shortcut'
  'sync:legacy sync shortcut'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-l --log-file)'{-l+,--log-file=}'[log to file]:file:_files' \
  '--hide-progress[hide progress bar]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nf-core command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (pipelines)
        local -a pipe_subs=(
          'list:list nf-core pipelines'
          'create:scaffold a new pipeline'
          'create-logo:generate a logo for a pipeline'
          'create-params-file:create a params file from schema'
          'download:download a pipeline for offline use'
          'launch:launch a pipeline interactively'
          'lint:lint a pipeline against nf-core specifications'
          'sync:sync a pipeline with the latest template'
          'bump-version:bump the version of a pipeline'
          'schema:schema commands (build/lint/docs/validate)'
          'rocrate:create RO-Crate metadata'
        )
        _describe -t pcmds 'pipelines subcommand' pipe_subs && ret=0
        _arguments \
          '--fix[apply automatic fixes]' \
          '--release[treat as release-time]' \
          '--no-update[skip checking for updates]' && ret=0 ;;
      (modules)
        local -a mod_subs=(
          'list:list available modules (remote/local)'
          'install:install a DSL2 module into a pipeline'
          'update:update a module'
          'remove:remove a module from a pipeline'
          'create:create a new module from template'
          'create-test-yml:create a test yaml file'
          'lint:lint module(s)'
          'info:show module info'
          'patch:apply patches to local modules'
          'bump-versions:bump module versions'
        )
        _describe -t mcmds 'modules subcommand' mod_subs && ret=0
        _arguments \
          '(-g --git-remote)'{-g+,--git-remote=}'[git remote of modules repo]:url:' \
          '(-b --branch)'{-b+,--branch=}'[branch of modules repo]:branch:' \
          '(-d --dir)'{-d+,--dir=}'[pipeline directory]:dir:_files -/' \
          '*::tool:' && ret=0 ;;
      (subworkflows)
        _arguments '*::sub:(list install update remove create lint info)' && ret=0 ;;
      (configs)
        _arguments '*::sub:(list)' && ret=0 ;;
    esac ;;
esac

return ret
