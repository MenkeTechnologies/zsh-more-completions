#compdef cutseq
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/cutseq.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# EMBOSS cutseq: cut a region from a sequence (delete a sub-region)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence]:sequence USA:_files' \
  '-from=[first base to remove]:n:' \
  '-to=[last base to remove]:n:' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output format]:format:(fasta embl genbank swiss gcg pir raw msf text)' \
  '*:sequence USA:_files' && ret=0
return ret
