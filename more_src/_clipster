#compdef clipster
# _clipster — clipster clipboard manager (Markus Demarmels et al, Python); GTK clipboard manager with dmenu/rofi integration
# upstream: https://github.com/mrichar1/clipster

_clipster() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-c+[config file]:file:_files' \
        '-d[debug]' \
        '-l[run as daemon]' \
        '-p+[paste from history]:str:' \
        '-s+[selection]:sel:(PRIMARY CLIPBOARD)' \
        '-n+[history length]:n:' \
        '-N+[primary length]:n:' \
        '-o+[output]:stream:' \
        '-w+[wait timeout]:sec:' \
        '-r[restore last clipboard]' \
        '--rofi[use rofi to select]' \
        '--dmenu[use dmenu to select]' \
        '--select[select from history]' \
        '--list[list history]' \
        '--erase[clear history]'
}

_clipster "$@"
