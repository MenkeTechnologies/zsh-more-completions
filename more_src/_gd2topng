#compdef gd2topng
# Documentation: https://man.archlinux.org/search?q=gd2topng
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input GD2:_files -g "*.gd2"' \
  '2:output PNG:_files -g "*.png"' \
  '3::source x:' \
  '4::source y:' \
  '5::width:' \
  '6::height:' && ret=0

return ret
