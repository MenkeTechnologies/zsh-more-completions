#compdef vcfglbound
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfglbound.md
# vcflib: normalize and bound genotype likelihoods in a VCF

local ret=1

_arguments -s -S \
  '(-b --bound)'{-b,--bound}'[bound GLs to this limit]:N' \
  '(-x --exclude-broken)'{-x,--exclude-broken}'[if GLs are > 0, remove site]' \
  '*:vcf file:_files' && ret=0

return ret
