#compdef lxqt-session
# Documentation: https://github.com/lxqt/lxqt-session/blob/master/lxqt-session/src/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c,--config}'+[configuration file path]:file:_files' \
  '(-w --window-manager)'{-w,--window-manager}'+[window manager to use]:wm:_command_names' && ret=0

return ret
