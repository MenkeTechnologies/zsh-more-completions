#compdef lxqt-session

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config-file)'{-c,--config-file}'+[config file]:file:_files' \
  '(-w --window-manager)'{-w,--window-manager}'+[window manager]:wm:_command_names' && ret=0

return ret
