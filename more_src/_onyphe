#compdef onyphe

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-k,--apikey}'=[API key]:api key' \
  {-p,--page}'=[page number]:page' \
  {-o,--output}'=[output file]:output file:_files' \
  {-f,--format}'=[output format]:format:(json csv tsv)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'search:search Onyphe data'
      'summary:get summary for a query'
      'simple:simple API lookup'
      'export:export search results'
      'alert:manage alerts'
      'bulk:bulk query API'
    )
    _describe -t commands 'onyphe command' commands && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-k,--apikey}'=[API key]:api key' \
          {-p,--page}'=[page number]:page' \
          {-o,--output}'=[output file]:output file:_files' \
          {-f,--format}'=[output format]:format:(json csv tsv)' \
          '1:category:(datascan synscan inetnum threatlist pastries resolver sniffer onionscan ctl vulnscan datashot topsite whois)' \
          '2:query' && ret=0
        ;;
      summary)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-k,--apikey}'=[API key]:api key' \
          {-o,--output}'=[output file]:output file:_files' \
          {-f,--format}'=[output format]:format:(json csv tsv)' \
          '1:category' \
          '2:query' && ret=0
        ;;
      simple)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-k,--apikey}'=[API key]:api key' \
          {-o,--output}'=[output file]:output file:_files' \
          {-f,--format}'=[output format]:format:(json csv tsv)' \
          '1:category:(geoloc inetnum pastries resolver sniffer synscan threatlist datascan onionscan ctl vulnscan datashot whois)' \
          '2:query' && ret=0
        ;;
      export)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-k,--apikey}'=[API key]:api key' \
          {-o,--output}'=[output file]:output file:_files' \
          {-f,--format}'=[output format]:format:(json csv tsv)' \
          '1:category' \
          '2:query' && ret=0
        ;;
      alert)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-k,--apikey}'=[API key]:api key' \
          '1:action:(list add del)' && ret=0
        ;;
      bulk)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-k,--apikey}'=[API key]:api key' \
          {-o,--output}'=[output file]:output file:_files' \
          {-f,--format}'=[output format]:format:(json csv tsv)' \
          '1:category' \
          '2:input file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
