#compdef ncplayer
# Documentation: https://www.mankier.com/1/ncplayer
# ncplayer - render images and video to the terminal with Notcurses

local ret=1

_arguments -s -S \
  '-h[print help and exit]' \
  '-V[print version and exit]' \
  '-q[suppress frame/timing information and exit summary]' \
  '-d[apply a non-negative rational multiplier to the delayscale]:delaymult' \
  '-l[log between everything (7) and nothing (0) to stderr]:loglevel:(0 1 2 3 4 5 6 7)' \
  '-b[blitter to use]:blitter:(ascii half quad sex oct braille pixel)' \
  '-s[scaling mode]:scalemode:(none hires scale scalehi stretch)' \
  '-k[use direct mode, leaving output onscreen after exit]' \
  '-L[loop frames until a key is pressed]' \
  '-t[delay seconds after each file]:seconds' \
  '-n[use non-interpolative scaling]' \
  '-a[treat color as if it were transparent]:color' \
  '-m[define rendering margins]:margins' \
  '*:file:_files' && ret=0

return ret
