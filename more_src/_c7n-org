#compdef c7n-org

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:execute policies across accounts'
  'run-script:run a script across accounts'
  'report:generate cross-account report'
  'accounts:list configured accounts'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'c7n-org command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s -S \
          '-c[accounts config file]:file:_files' \
          '-s[output directory]:directory:_directories' \
          '-u[policy file or directory]:path:_files' \
          '--dryrun[simulate execution]' \
          '-r[region]:region:' \
          '--region[region]:region:' \
          '--debug[enable debug logging]' \
          '-v[verbose output]' \
          '--cache-period[cache period in seconds]:seconds:' \
          '-a[run against specific accounts]:accounts:' \
          '-t[filter by account tags]:tags:' \
          '--metrics[enable metrics]:metrics:(aws)' \
          '-l[log group for output]:log-group:' \
          '-p[policy name filter]:policy:' \
          '--help[show help]' && ret=0
        ;;
      run-script)
        _arguments -s -S \
          '-c[accounts config file]:file:_files' \
          '-s[script to run]:script:_files' \
          '-r[region]:region:' \
          '-a[specific accounts]:accounts:' \
          '-t[filter by tags]:tags:' \
          '--help[show help]' && ret=0
        ;;
      report)
        _arguments -s -S \
          '-c[accounts config file]:file:_files' \
          '-s[output directory]:directory:_directories' \
          '-u[policy file or directory]:path:_files' \
          '-r[region]:region:' \
          '--field[report fields]:fields:' \
          '--no-default-fields[skip default fields]' \
          '--format[output format]:format:(csv json grid)' \
          '--help[show help]' && ret=0
        ;;
      accounts)
        _arguments -s -S \
          '-c[accounts config file]:file:_files' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
