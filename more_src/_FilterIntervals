#compdef FilterIntervals
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/FilterIntervals.java
# Filters intervals based on annotations and/or count statistics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--annotated-intervals=[Input file containing annotations for genomic intervals (output of AnnotateIntervals).]:value:_files' \
  '(--input -I)'{--input,-I}'[Input TSV or HDF5 files containing integer read counts in genomic intervals (output of...]:value:_files' \
  '(--output -O)'{--output,-O}'[Output Picard interval-list file containing the filtered intervals.]:value:_files' \
  '--minimum-gc-content=[Minimum allowed value for GC-content annotation (inclusive).]:value:' \
  '--maximum-gc-content=[Maximum allowed value for GC-content annotation (inclusive).]:value:' \
  '--minimum-mappability=[Minimum allowed value for mappability annotation (inclusive).]:value:' \
  '--maximum-mappability=[Maximum allowed value for mappability annotation (inclusive).]:value:' \
  '--minimum-segmental-duplication-content=[Minimum allowed value for segmental-duplication-content annotation (inclusive).]:value:' \
  '--maximum-segmental-duplication-content=[Maximum allowed value for segmental-duplication-content annotation (inclusive).]:value:' \
  '--low-count-filter-count-threshold=[Count-threshold parameter for the low-count filter. Intervals with a count]:value:' \
  '--low-count-filter-percentage-of-samples=[Percentage-of-samples parameter for the low-count filter. Intervals with a count]:value:' \
  '--extreme-count-filter-minimum-percentile=[Minimum-percentile parameter for the extreme-count filter. Intervals with a count]:value:' \
  '--extreme-count-filter-maximum-percentile=[Maximum-percentile parameter for the extreme-count filter. Intervals with a count]:value:' \
  '--extreme-count-filter-percentage-of-samples=[Percentage-of-samples parameter for the extreme-count filter. Intervals with a count]:value:' \
  '*:argument:_files' && ret=0

return ret
