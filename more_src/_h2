#compdef h2
# Documentation: https://h2database.com/javadoc/org/h2/tools/Server.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s \
  '-web[start web server]' \
  '-webPort=[web port]:port:' \
  '-webSSL[web server SSL]' \
  '-webAllowOthers[allow remote web]' \
  '-webExternalNames=[external names]:names:' \
  '-webDaemon[web as daemon]' \
  '-webVirtualThreads[web use virtual threads]' \
  '-webAdminPassword=[web admin password]:password:' \
  '-tcp[start TCP server]' \
  '-tcpPort=[TCP port]:port:' \
  '-tcpSSL[TCP SSL]' \
  '-tcpAllowOthers[allow remote TCP]' \
  '-tcpDaemon[TCP as daemon]' \
  '-tcpVirtualThreads[TCP use virtual threads]' \
  '-tcpPassword=[TCP password]:password:' \
  '-tcpShutdown=[TCP shutdown URL]:url:' \
  '-tcpShutdownForce[force TCP shutdown]' \
  '-pg[start PostgreSQL server]' \
  '-pgPort=[PG port]:port:' \
  '-pgAllowOthers[allow remote PG]' \
  '-pgDaemon[PG as daemon]' \
  '-pgVirtualThreads[PG use virtual threads]' \
  '-browser[start browser]' \
  '-properties=[server.properties dir]:dir:_files -/' \
  '-baseDir=[base dir]:dir:_files -/' \
  '-ifExists[only if DB exists]' \
  '-ifNotExists[create if not exists]' \
  '-key=[server key]:key:' \
  '-trace[enable trace]' \
  '(- *)-help[show help]' \
  '(- *)-?[show help]'
