#compdef llvm-windres
# _llvm-windres — LLVM Windows resource compiler (LLVM project, C++); compile .rc to .res or .o (windres-compatible)
# upstream: https://github.com/llvm/llvm-project

_llvm-windres() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-i+[input file]:file:_files -g "*.rc"' \
        '--input=+[input file]:file:_files -g "*.rc"' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-J+[input format]:fmt:(rc res coff)' \
        '--input-format=+[input format]:fmt:(rc res coff)' \
        '-O+[output format]:fmt:(rc res coff)' \
        '--output-format=+[output format]:fmt:(rc res coff)' \
        '-F+[target]:target:' \
        '--target=+[target]:target:' \
        '--preprocessor=+[preprocessor]:cmd:' \
        '--preprocessor-arg=+[preprocessor arg]:arg:' \
        '--no-preprocess[no preprocess]' \
        '-D+[define]:def:' \
        '--define=+[define]:def:' \
        '-U+[undefine]:def:' \
        '--undefine=+[undefine]:def:' \
        '-I+[include path]:dir:_files -/' \
        '--include-dir=+[include path]:dir:_files -/' \
        '-c+[codepage]:cp:' \
        '--codepage=+[codepage]:cp:' \
        '-l+[langid]:id:' \
        '--language=+[langid]:id:' \
        '-r[ignored]' \
        '*:file:_files'
}

_llvm-windres "$@"
