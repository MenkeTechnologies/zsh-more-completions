#compdef pspy
# Unprivileged Linux process snooping tool

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --ppid)'{-p,--ppid}'[enable parent PID logging]' \
  '(-f --fsevents)'{-f,--fsevents}'[enable filesystem event logging]' \
  '(-r --recursive)'{-r,--recursive}'[watch directories recursively]' \
  '(-d --dirs)'{-d,--dirs}'[directories to watch]:dirs:_files -/' \
  '(-t --truncate)'{-t,--truncate}'[truncate long command lines]' \
  '(-c --color)'{-c,--color}'[enable colored output]' \
  '(-i --interval)'{-i,--interval}'[scan interval in milliseconds]:ms:' \
  && return 0
