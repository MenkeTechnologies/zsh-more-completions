#compdef mu
# Documentation: https://www.mankier.com/1/mu
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mu: maildir-utils. Index, search, and view email stored in Maildirs.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--muhome+[specify mu home directory]:directory:_files -/' \
  '-d+[debug level]:level:' \
  '--quiet[be quiet]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'add:add specific messages to the database'
      'cfind:find contacts'
      'extract:extract attachments and other MIME parts'
      'find:find messages in the database'
      'help:get help on a command'
      'index:(re)index messages in a Maildir'
      'info:show mu database info'
      'init:initialize the mu database'
      'mkdir:create a new Maildir'
      'remove:remove specific messages from the database'
      'server:start mu server (for mu4e)'
      'view:view a specific message'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (init)
        _arguments \
          '--maildir+[specify Maildir root]:directory:_files -/' \
          '--my-address+[personal email addresses]:addresses:' \
          '--reinit[reinitialize database]' && ret=0
        ;;
      (index)
        _arguments \
          '--maildir+[specify Maildir root]:directory:_files -/' \
          '--lazy-check[only check new/changed messages]' \
          '--nocleanup[do not remove stale messages]' \
          '--reindex[perform complete reindexing]' && ret=0
        ;;
      (find)
        _arguments \
          '--fields+[output fields]:fields:' \
          '--sortfield+[sort field]:field:(date from to subject size msgid prio flag)' \
          '--reverse[reverse sort order]' \
          '--maxnum+[max number of results]:number:' \
          '--threads[show threads]' \
          '--format+[output format]:format:(plain links sexp xml json)' \
          '--summary-len+[summary length]:length:' \
          '--bookmark+[use named bookmark]:bookmark:' \
          '--include-related[include related messages]' \
          '--skip-dups[skip duplicate messages]' \
          '*:search query:' && ret=0
        ;;
      (view)
        _arguments \
          '--format+[output format]:format:(plain sexp)' \
          '--summary-len+[summary length]:length:' \
          '--terminate[terminate output with null]' \
          '*:message file:_files' && ret=0
        ;;
      (mkdir)
        _arguments '*:directory:_files -/' && ret=0
        ;;
      (extract)
        _arguments \
          '--parts+[MIME parts to extract]:parts:' \
          '--target-dir+[target directory]:directory:_files -/' \
          '--overwrite[overwrite existing files]' \
          '--save-attachments[save all attachments]' \
          '--save-all[save all MIME parts]' \
          '*:message file:_files' && ret=0
        ;;
      (cfind)
        _arguments \
          '--format+[output format]:format:(plain mutt-alias mutt-ab org-contact bbdb csv)' \
          '--personal[only personal contacts]' \
          '--after+[contacts after date]:date:' \
          '*:pattern:' && ret=0
        ;;
      (server)
        _arguments && ret=0
        ;;
      (add|remove)
        _arguments '*:message file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
