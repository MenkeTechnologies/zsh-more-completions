#compdef kramdown-rfc kramdown-rfc2629
# Documentation: https://man.archlinux.org/search?q=kramdown-rfc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:markdown:_files -g "*.{md,mkd,markdown}"' && ret=0

return ret
