#compdef kramdown-rfc kramdown-rfc2629
# Documentation: https://github.com/cabo/kramdown-rfc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (lib/kramdown-rfc/
# command.rb OptionParser). Added real -V/-H/-v/-3/-2 flags.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-H,--help}'[show option summary and exit]' \
  '(- *)'{-V,--version}'[display version information and terminate]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--no-verbose[disable verbose output]' \
  '(-3 --v3)'{-3,--v3}'[apply RFCXML v3 processing rules]' \
  '--no-v3[disable RFCXML v3 processing]' \
  '(-2 --v2)'{-2,--v2}'[apply RFCXML v2 processing rules]' \
  '--no-v2[disable RFCXML v2 processing]' \
  '*:markdown:_files -g "*.{md,mkd,markdown}"' && ret=0

return ret
