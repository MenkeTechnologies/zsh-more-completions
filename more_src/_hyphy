#compdef hyphy hyphympi HYPHYMPI
# HyPhy: hypothesis testing using phylogenies (selection analysis)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-c[calculator mode; drop into expression evaluation]' \
  '-d[debug mode; enter expression evaluation on script error]' \
  '-i[interactive mode; always prompt for analysis options]' \
  '-p[postprocessor mode; interactive post-processing script]' \
  '-m[write diagnostic messages to messages.log]' \
  '*:analysis or argument:->methods' && ret=0

if [[ $state == methods ]]; then
  _values 'analysis method or keyword argument' \
    'BASEPATH=[base directory for path operations]' \
    'CPU=[number of threads]' \
    'LIBPATH=[HyPhy library files directory]' \
    'USEPATH=[working and relative path directory]' \
    'ENV=[set HBL environment variables]' \
    'MEME[mixed effects model of evolution]' \
    'FEL[fixed effects likelihood]' \
    'FUBAR[fast unconstrained Bayesian approximation]' \
    'SLAC[single likelihood ancestor counting]' \
    'BUSTED[branch-site unrestricted statistical test for episodic diversification]' \
    'aBSREL[adaptive branch-site random effects likelihood]' \
    'RELAX[test for selection intensity relaxation]' \
    'GARD[genetic algorithm for recombination detection]' \
    'FADE[FUBAR approach to directional evolution]' \
    'BGM[Bayesian graphical model]' \
    'PRIME[property informed models of evolution]' \
    'Contrast-FEL[test for differential selection between branch sets]' && ret=0
fi

return ret
