#compdef nostcat
# ============================================================================
# _nostcat — zsh completion for Blake Jakopovic's nostcat, a WebSocket
#             client for nostr relay scripting (tungstenite-backed)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/blakejakopovic/nostcat
#   Author     : Blake Jakopovic
#   License    : MIT
#   Language   : Rust
#   Crate      : nostcat
#   Binary     : nostcat  (Cargo.toml [package] name = "nostcat",
#                           built from src/main.rs)
#   Last push  : 2023-11-24
#
# WHAT IT IS
#   nostcat is "a WebSocket client for nostr relay scripting" —
#   Blake Jakopovic's `cat`-style WebSocket tool aimed at scripting
#   the nostr decentralized social protocol.  Given one or more
#   `wss://relay.example.com` URLs as trailing arguments, nostcat
#   reads JSON nostr requests (REQ / EVENT / CLOSE / AUTH) from
#   stdin, multiplexes them to every supplied relay in parallel
#   via `tokio` + `tungstenite`, and streams every server response
#   to stdout — optionally deduplicating responses (`--unique`),
#   keeping the connection open for live subscription mode
#   (`--stream`), or running once-and-exit (default).  The result
#   is pipeable into `jq` for ad-hoc nostr queries, broadcast
#   tests, and relay-comparison scripts.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/lib.rs `pub fn cli()`
#                       clap Command builder)
#   nostcat [OPTIONS] <SERVERS>...
#
#   Options:
#     -u, --unique              Sort and unique returned events
#                               (deduplicate the response stream)
#     -s, --stream              Stream the WebSocket connection
#                               (keep open for live subscription
#                                events instead of exiting after
#                                the first EOSE)
#         --connect-timeout <MS>
#                               WebSocket connection timeout in
#                               milliseconds (non-streaming mode)
#                               [default: 10000]
#
#   Standard clap auto-flags:
#     -h, --help                Show help
#     -V, --version             Show version
#
#   Positional:
#     <SERVERS>...              One or more `wss://` (or `ws://`)
#                               WebSocket relay URLs;  trailing
#                               variable-argument list, at least
#                               one required.  Each request from
#                               stdin is sent to every supplied
#                               server in parallel.
#
#   Stdin:
#     Each line of stdin is treated as a JSON message to send.
#     For nostr usage these are typically REQ subscription filters,
#     EVENT publishes, CLOSE notifications, or AUTH responses.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `tungstenite = "0.18.0"` (with the
#   `native-tls` feature) declared in Cargo.toml — the canonical
#   Rust WebSocket implementation maintained by Vlad Vorobjov +
#   the snapview / tokio-tungstenite team (snapview/tungstenite-rs).
#   tungstenite is the underlying synchronous WebSocket protocol
#   library that powers `tokio-tungstenite` for async use;  it
#   handles RFC 6455 framing, control-frame ping/pong, close
#   handshakes, fragmentation, and TLS via either `native-tls` or
#   `rustls`.  nostcat's `src/lib.rs` constructs a per-server
#   `tungstenite::Client` (via the `connect` helper), writes each
#   stdin line as a `Message::Text`, and reads back `Message::Text`
#   frames into the mpsc channel that feeds stdout.  Verified via:
#     gh api repos/blakejakopovic/nostcat/contents/Cargo.toml
#       → tungstenite = {version = "0.18.0", features = ["native-tls"]}
#       → clap = "4.0.26"
#     gh api repos/blakejakopovic/nostcat/contents/src/lib.rs
#       → pub fn cli() -> Command {Command::new("nostcat") ...}
#         arg "servers" trailing_var_arg(true) required(true)
#   This entry is the Rust=133 leader bump that OPENS Axis 78
#   (WebSocket Protocol Library), pairing with future Go=
#   gorilla/websocket and TS-Node=websockets/ws poles to close
#   the axis at 1/1/1.
#
#   No completion for `nostcat` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_nostcat() {
    _arguments -s \
        '(-u --unique)'{-u,--unique}'[sort and unique returned events]' \
        '(-s --stream)'{-s,--stream}'[stream the WebSocket connection]' \
        '--connect-timeout=[WebSocket connection timeout in ms (default 10000)]:ms:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '*:WebSocket relay URL:'
}

_nostcat "$@"
