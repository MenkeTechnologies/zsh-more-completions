#compdef sips
# Documentation: https://www.unix.com/man-page/osx/1/sips/
# Source: Apple macOS — Scriptable Image Processing System (raster + ColorSync image CLI).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*'{-g,--getProperty=}'[output property value for key]:key:(format formatOptions space samplesPerPixel bitsPerSample dpiHeight dpiWidth typeIdentifier pixelHeight pixelWidth profile description make model creation modification copyright author softwareUsed)' \
    '*'{-s,--setProperty=}'[set property value]:key value:' \
    '*'{-d,--deleteProperty=}'[remove property value for key]:key:' \
    '(-v --verify)'{-v,--verify}'[verify profile problems and log to stdout]' \
    '(-r --rotate)'{-r+,--rotate=}'[rotate image clockwise]:degrees:' \
    '(-f --flip)'{-f+,--flip=}'[flip image]:axis:(horizontal vertical)' \
    '(-c --cropToHeightWidth)'{-c+,--cropToHeightWidth=}'[crop to height width]:H W:' \
    '(-z --resampleHeightWidth)'{-z+,--resampleHeightWidth=}'[resample to height width]:H W:' \
    '--resampleWidth=[resample to width]:width:' \
    '--resampleHeight=[resample to height]:height:' \
    '(-Z --resampleHeightWidthMax)'{-Z+,--resampleHeightWidthMax=}'[resample with max dimension]:max:' \
    '(-i --addIcon)'{-i,--addIcon}'[add Finder icon to file]' \
    '(-x --extractProfile)'{-x+,--extractProfile=}'[extract embedded color profile]:profile-file:_files' \
    '(-X --extractTag)'{-X+,--extractTag=}'[extract profile tag to file]:tag-file:_files' \
    '-o[output file]:file:_files' \
    '--out=[output file or directory]:path:_files' \
    '*:image file:_files' \
    && ret=0

return ret
