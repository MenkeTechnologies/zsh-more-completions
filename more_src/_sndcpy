#compdef sndcpy
# Documentation: https://man.archlinux.org/search?q=sndcpy
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-s+[device serial]:serial:' \
  '*:: :' && ret=0

return ret
