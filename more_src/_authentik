#compdef ak

_ak_subcommands() {
  local -a subcmds=(
    'create_admin_group:Create an admin group'
    'dump_config:Dump current configuration'
    'export_blueprint:Export configuration as blueprint'
    'healthcheck:Run healthcheck'
    'import_blueprint:Import a blueprint'
    'migrate:Run database migrations'
    'repair:Repair the installation'
    'test_all:Run all tests'
    'worker:Start the worker'
    'server:Start the server'
  )
  _describe -t commands 'ak subcommand' subcmds
}

_ak() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '--version[Show version]' \
    '1:subcommand:_ak_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        server)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--bind[Address to bind to]:address:' \
            '--port[Port to listen on]:port:'
          ;;
        worker)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--concurrency[Worker concurrency]:count:' \
            '-B[Enable beat scheduler]'
          ;;
        import_blueprint)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '1:blueprint:_files -g "*.yaml"'
          ;;
        export_blueprint)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '1:output:_files'
          ;;
        migrate)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--fake[Mark migrations as run without running them]' \
            '--run-syncdb[Run synchronous DB operations]'
          ;;
      esac
      ;;
  esac
}

_ak "$@"
