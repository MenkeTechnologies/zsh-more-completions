#compdef timescaledb-tune

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--quiet[suppress interactive prompts]' \
  '--yes[accept all recommendations]' \
  '--no-color[disable colored output]' \
  '--memory=[memory base e.g. 4GB]:size:' \
  '--cpus=[CPU cores base]:n:' \
  '--max-conns=[max connections]:n:' \
  '--max-bg-workers=[max background workers]:n:' \
  '--wal-disk-size=[WAL disk size]:size:' \
  '--statistics-target=[default_statistics_target]:n:' \
  '--conf-path=[postgresql.conf path]:file:_files' \
  '--pg-config=[pg_config path]:file:_files' \
  '--restore[restore from backup]' \
  '--dry-run[print suggestions without writing]' \
  '--include-space=[include space-related parameters]:flag:(true false)' \
  '--quiet-mode[quiet mode]' \
  '--debug[debug output]' \
  '--version[show version]' \
  '--profile-type=[profile type]:type:(default oltp web mixed dw timeseries)' \
  '--pg-version=[PostgreSQL version]:version:' && ret=0

return ret
