#compdef timescaledb-tune
# Documentation: https://github.com/timescale/timescaledb-tune/blob/master/cmd/timescaledb-tune/main.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-memory=[memory to base recommendations on e.g. 4GB]:size:' \
  '-cpus=[number of CPU cores]:n:' \
  '-pg-version=[PostgreSQL major version]:version:(11 12 13 14 15 16 17)' \
  '-wal-disk-size=[WAL disk size e.g. 4GB]:size:' \
  '-max-conns=[max database connections]:n:' \
  '-max-bg-workers=[max background workers]:n:' \
  '-conf-path=[path to postgresql.conf]:file:_files' \
  '-out-path=[output config path]:file:_files' \
  '-pg-config=[path to pg_config binary]:file:_files' \
  '-yes[answer yes to every prompt]' \
  '-quiet[only show total recommendations]' \
  '-color[use color output]' \
  '-dry-run[show changes without writing]' \
  '-restore[restore previous backup]' \
  '-profile=[workload profile]:profile:(promscale)' \
  '-version[show version]' \
  && ret=0

return ret
