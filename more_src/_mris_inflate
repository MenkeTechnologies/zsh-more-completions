#compdef mris_inflate
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_inflate
# FreeSurfer inflate a cortical surface

local ret=1

_arguments -s -S \
  '-n[maximum # of iterations (default 55)]:iterations:' \
  '-w[write a snapshot every nth time step]:n:' \
  '-dist[metric distortion/smoothness tradeoff (default 0.1)]:distcoeff:' \
  '1:input surface file:_files' \
  '2:output surface file:_files' && ret=0

return ret
