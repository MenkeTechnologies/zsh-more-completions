#compdef imspec
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imspec.html
# MIRIAD: plot spectra from image data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image dataset]:in:_files' \
  'region=[region of interest]:region:' \
  'axes=[averaging axes]:axes:' \
  'plot=[output type]:plot:(mean sum flux pbcflux)' \
  'cutoff=[exclusion threshold]:cutoff:' \
  'device=[PGPLOT device]:device:' \
  'options=[plot characteristics]:options:' \
  'beam=[beam parameters]:beam:' \
  'log=[output log file]:log:_files' \
  '*:image:_files' && ret=0

return ret
