#compdef ipfs-cluster-follow

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'info:show peer info'
  'init:initialize follower'
  'run:run follower'
  'list:list pinset items'
)

_arguments -C \
  '(-c --config)'{-c,--config=}'[config & data folder]:dir:_files -/' \
  '(- *)'{-h,--help}'[show help]' \
  '1:cluster name:' \
  '2: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'follow subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[2] in
      (init)
        _arguments '--gateway=[IPFS gateway URL]:url:' && ret=0
        ;;
      (run)
        _arguments \
          '--init=[init from URL]:url:' \
          '--gateway=[IPFS gateway URL]:url:' && ret=0
        ;;
    esac
    ;;
esac

return ret
