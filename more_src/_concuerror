#compdef concuerror
# Documentation: https://concuerror.hexdocs.pm/concuerror_options.html
# Stateless model checking tool for concurrent Erlang programs

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help documentation]' \
  '--version[show version information]' \
  '(-m --module)'{-m,--module}'+[module containing the test function]:module' \
  '(-t --test)'{-t,--test}'+[name of the test function]:function' \
  '*'{-f,--file}'+[load specified .beam or .erl files]:file:_files' \
  '*--pa+[prepend directory to code path]:dir:_files -/' \
  '*--pz+[append directory to code path]:dir:_files -/' \
  '(-o --output)'{-o,--output}'+[analysis report filename]:file:_files' \
  '--no_output[disable report generation]' \
  '(-g --graph)'{-g,--graph}'+[produce DOT graph output]:file:_files' \
  '--print_depth=[max depth for printed terms]:n' \
  '--symbolic_names[replace PIDs with symbolic names in output]' \
  '(-v --verbosity)'{-v,--verbosity}'+[verbosity level 0-7]:level' \
  '(-q --quiet)'{-q,--quiet}'[suppress standard error output]' \
  '(-d --depth_bound)'{-d,--depth_bound}'+[maximum events per interleaving]:n' \
  '(-i --interleaving_bound)'{-i,--interleaving_bound}'+[maximum interleavings to explore]:n' \
  '(-b --scheduling_bound)'{-b,--scheduling_bound}'+[maximum scheduling rule violations]:n' \
  '(-c --scheduling_bound_type)'{-c,--scheduling_bound_type}'+[bounding technique]:type:(bpor delay ubpor none)' \
  '*--ignore_error=[error categories to ignore]:category' \
  '*--treat_as_normal=[exit reasons not reported as errors]:reason' \
  '--assertions_only[report only assertion-related abnormal exits]' \
  '(-k --keep_going)'{-k,--keep_going}'[continue exploration after finding errors]' \
  '--first_process_errors_only[report only parent process errors]' \
  '(-a --after_timeout)'{-a,--after_timeout}'+[timeout threshold for after clauses]:ms' \
  '--instant_delivery=[messages arrive instantly]:bool:(true false)' \
  '--timeout=[wait time before assuming process stuck]:ms' \
  '--use_receive_patterns=[races only with matching patterns]:bool:(true false)' \
  '--non_racing_system=[assume messages to system processes do not race]:name' \
  '--dpor=[DPOR technique]:technique:(optimal source persistent none)' \
  '--optimal[shorthand for dpor optimal]' \
  '--disable_sleep_sets[disable sleep set optimization]' \
  '--assume_racing=[assume unknown operations may race]:bool:(true false)' \
  '--scheduling=[process scheduling order]:order:(oldest newest round_robin)' \
  '--strict_scheduling=[enforce scheduling strictly]:bool:(true false)' \
  '--log_all[show all interleavings, not just errors]' \
  '--show_races[include racing event pairs in output]' \
  '*'{-x,--exclude_module}'+[exclude modules from instrumentation]:module' && ret=0

return ret
