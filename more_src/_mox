#compdef mox
# Documentation: https://www.xmox.nl/commands/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'serve:run the mail server'
  'quickstart:bootstrap initial config'
  'stop:stop running mox'
  'localserve:run a local development server'
  'help:show help'
  'setaccountpassword:set password for account'
  'setadminpassword:set admin password'
  'loglevels:show or change log levels'
  'queue:manage queue'
  'import:import maildir or mbox'
  'export:export maildir or mbox'
  'backup:back up data dir'
  'verifydata:verify backed up data'
  'licenses:show third-party licenses'
  'config:configuration commands'
  'admin:admin commands'
  'checkupdate:check for newer mox version'
  'cid:show command for cid'
  'clientconfig:show client config for domain'
  'dane:DANE commands'
  'dns:DNS lookup helpers'
  'dkim:DKIM commands'
  'dmarc:DMARC commands'
  'dnsbl:DNSBL commands'
  'mtasts:MTA-STS lookup'
  'rdap:RDAP commands'
  'tlsrpt:TLSRPT commands'
  'spf:SPF commands'
  'retrain:retrain bayesian filter'
  'sendmail:sendmail compatible interface'
  'version:print version'
  'webapi:invoke webapi method'
  'example:print example config'
  'message:message helpers'
  'bumpuidvalidity:bump UIDVALIDITY'
  'reassignuids:reassign UIDs'
  'fixuidmeta:fix UID metadata'
  'fixmsgsize:fix message sizes'
  'reparse:reparse messages'
  'ensureparsed:ensure messages parsed'
  'recalculatemailboxcounts:recalculate mailbox counts'
  'reassignthreads:reassign threads'
)

local -a queue_subs config_subs

queue_subs=(
  'list:list queue'
  'hold:hold messages'
  'unhold:unhold messages'
  'fail:fail messages'
  'drop:drop messages'
  'schedule:schedule next attempt'
  'transport:set transport'
  'requiretls:set require-TLS'
  'dump:dump message'
  'holdrules:manage hold rules'
  'retired:retired messages'
  'suppress:suppression list'
  'webhook:webhook commands'
)

config_subs=(
  'test:test config'
  'dnscheck:DNS check for domain'
  'dnsrecords:DNS records for domain'
  'describe-domains:describe domains'
  'describe-static:describe static config'
  'describe-sendmail:describe sendmail config'
  'account:account management'
  'address:address management'
  'domain:domain management'
  'tlspubkey:TLS public key management'
  'alias:alias management'
  'printservice:print service unit'
  'ensureacmehostprivatekeys:ensure ACME host keys'
  'example:print example'
)

_arguments -C \
  '-config=[config file]:file:_files -g "*.conf"' \
  '-pedantic[strict checks]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mox subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (queue)
        _describe -t queue_subs 'queue subcommand' queue_subs && ret=0
        ;;
      (config)
        _describe -t config_subs 'config subcommand' config_subs && ret=0
        ;;
      (import)
        _values 'import format' maildir mbox && ret=0
        ;;
      (export)
        _values 'export format' maildir mbox && ret=0
        ;;
      (dane)
        _values 'dane action' dial dialmx makerecord && ret=0
        ;;
      (dkim)
        _values 'dkim action' gened25519 genrsa lookup txt verify sign && ret=0
        ;;
      (dmarc)
        _values 'dmarc action' lookup parsereportmsg verify checkreportaddrs && ret=0
        ;;
      (dnsbl)
        _values 'dnsbl action' check checkhealth && ret=0
        ;;
      (tlsrpt)
        _values 'tlsrpt action' lookup parsereportmsg && ret=0
        ;;
      (spf)
        _values 'spf action' check lookup parse && ret=0
        ;;
      (mtasts)
        _values 'mtasts action' lookup && ret=0
        ;;
    esac
    ;;
esac

return ret
