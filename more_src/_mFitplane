#compdef mFitplane
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mFitplane.html
# Fit a plane to an overlap difference image

local ret=1

_arguments -s -S \
  '-b+[border pixels to ignore at image edges]:border' \
  '-d+[debugging level (1-3)]:level' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '1:input difference FITS:_files -g "*.fits"' && ret=0

return ret
