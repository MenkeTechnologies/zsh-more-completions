#compdef skaffold
# _skaffold-bin — Skaffold k8s dev/build/deploy CLI (Google, Go); continuous build + deploy for k8s applications
# upstream: https://github.com/GoogleContainerTools/skaffold

_skaffold-bin() {
    local -a sub=(
        'apply:apply manifests'
        'build:build images'
        'completion:print shell completion'
        'config:k=v config'
        'credits:credits'
        'debug:run in debug mode'
        'delete:delete app'
        'deploy:deploy manifests'
        'dev:auto-build+deploy on change'
        'diagnose:print effective skaffold config'
        'exec:execute a custom action'
        'fix:upgrade skaffold yaml schema'
        'help:show help'
        'init:write initial skaffold yaml'
        'inspect:inspect skaffold config'
        'lint:lint skaffold yaml'
        'options:print global flags'
        'render:render manifests'
        'run:run a single dev loop'
        'schema:list config schemas'
        'survey:open Skaffold survey'
        'test:run tests'
        'verify:verify run'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbosity)'{-v,--verbosity}'+[verbosity]:level:(panic fatal error warning info debug trace)' \
        '-f+[skaffold filename]:file:_files' \
        '--filename+[skaffold filename]:file:_files' \
        '-d+[default repo]:repo:' \
        '--default-repo+[default repo]:repo:' \
        '--cache-artifacts+[cache artifacts]:bool:(true false)' \
        '--remote-cache-dir+[remote cache dir]:str:' \
        '-p+[skaffold profile]:profile:' \
        '--profile+[skaffold profile]:profile:' \
        '--module+[skaffold module]:module:' \
        '-n+[namespace]:namespace:' \
        '--namespace+[namespace]:namespace:' \
        '--kube-context+[kube context]:context:' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '--enable-rpc+[enable rpc server]:bool:(true false)' \
        '--rpc-http-port+[rpc http port]:port:' \
        '--rpc-port+[rpc port]:port:' \
        '--detect-minikube[detect minikube]' \
        '--no-color[no color]' \
        '--update-check+[update check]:bool:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'skaffold subcommand' sub ;;
        args)
            case $words[1] in
                dev|run|build|deploy|render|test|delete) _arguments '*:args:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_skaffold-bin "$@"
