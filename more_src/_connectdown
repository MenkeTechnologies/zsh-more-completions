#compdef connectdown ConnectDown
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/ConnectDown.html
# TauDEM: connect watershed outlets downstream

local ret=1

_arguments -s -S \
  '-p[input D8 flow directions grid]:pfile:_files' \
  '-ad8[input D8 contributing area grid]:ad8file:_files' \
  '-w[input watershed grid]:wfile:_files' \
  '-o[output outlets file (OGR writeable dataset)]:outletfile:_files' \
  '-od[output moved-outlets file (OGR writeable dataset)]:moved outletfile:_files' \
  '-olyr[OGR layer name in the outlets file]:outlet layer name:' \
  '-odlyr[OGR layer name in the moved-outlets file]:moved outlet layer name:' \
  '-d[number of grid cells to move downstream (default 1)]:cells:' \
  '*:file:_files' && ret=0

return ret
