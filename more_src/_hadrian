#compdef hadrian
# Documentation: https://gitlab.haskell.org/ghc/ghc/-/tree/master/hadrian
# Shake-based build system for the Glasgow Haskell Compiler

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--flavour=[choose a build flavour]:flavour:(default quick quickest perf prof devel1 devel2)' \
  '(-o --build-root)'{-o,--build-root=}'[directory for storing build products]:dir:_files -/' \
  '--freeze1[do not rebuild Stage1 GHC even if sources change]' \
  '--freeze2[freeze both Stage1 and Stage2 GHC from rebuilding]' \
  '--skip-depends[skip rebuilding Haskell module dependency files]' \
  '--bignum=[select bignum backend (deprecated)]:backend:(native gmp)' \
  '--color[enable colored progress output]' \
  '--no-color[disable colored progress output]' \
  '--progress-info=[set progress display style]:style:(none brief normal unicorn)' \
  '(-V --verbose)'{-V,--verbose}'[run in verbose mode with detailed command output]' \
  '-VV[diagnostics mode with Shake oracle messages and full commands]' \
  '--lint[run Shake Lint checks during the build]' \
  '--docs=[selectively disable documentation targets]:setting:(none no-haddocks no-sphinx)' \
  '--haddock-for-hackage[generate Hackage-appropriate documentation URLs]' \
  '-j+[number of parallel jobs]:jobs:' \
  '*:target:_files' && ret=0

return ret
