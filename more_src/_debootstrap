#compdef debootstrap

# Zsh completion for debootstrap - Debian bootstrapper

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--arch=[target architecture]:architecture:(amd64 i386 arm64 armhf armel mips64el ppc64el s390x riscv64)' \
  '--include=[comma-separated list of packages to include]:packages' \
  '--exclude=[comma-separated list of packages to exclude]:packages' \
  '--components=[comma-separated list of components]:components:(main contrib non-free non-free-firmware)' \
  '--variant=[bootstrap variant]:variant:(minbase buildd fakechroot scratchbox)' \
  '--keyring=[keyring file]:keyring file:_files' \
  '--no-check-gpg[do not check GPG signatures]' \
  '--force-check-gpg[force GPG signature checking]' \
  '--merged-usr[use merged /usr layout]' \
  '--no-merged-usr[do not use merged /usr layout]' \
  '--foreign[do not run second stage (for cross-arch)]' \
  '--second-stage[run second stage of bootstrap]' \
  '--keep-debootstrap-dir[keep debootstrap directory after install]' \
  '--verbose[be more verbose]' \
  '--print-debs[print packages to be installed and exit]' \
  '--download-only[download packages only, do not install]' \
  '--resolve-deps[resolve dependencies]' \
  '--make-tarball=[create a tarball instead of installing]:tarball:_files -g "*.tar(|.gz|.xz)"' \
  '--unpack-tarball=[unpack tarball instead of downloading]:tarball:_files -g "*.tar(|.gz|.xz)"' \
  '--cache-dir=[package cache directory]:directory:_directories' \
  '--boot-floppies[used for boot-floppies build]' \
  '--debian-installer[used for debian-installer build]' \
  '--extractor=[package extractor]:extractor:(dpkg-deb ar)' \
  '1:suite:(bookworm bullseye trixie sid jammy noble focal)' \
  '2:target directory:_directories' \
  '3:mirror URL:_urls'
