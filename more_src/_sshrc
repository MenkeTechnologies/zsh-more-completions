#compdef sshrc
# Documentation: https://github.com/Russell91/sshrc
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
#
# sshrc is a wrapper around ssh that ships ~/.sshrc and ~/.sshrc.d to the
# remote host. It accepts the same options as ssh and passes them through.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-l[login name]:username:_users' \
  '-p[port]:port:' \
  '-i[identity file]:key file:_files' \
  '-o[SSH option]:option:' \
  '-F[config file]:config file:_files' \
  '-J[jump host]:jump:_hosts' \
  '-L[local port forwarding]:bind:' \
  '-R[remote port forwarding]:bind:' \
  '-W[forward stdio to host:port]:host\:port:' \
  '-b[bind address]:bind addr:' \
  '-c[cipher specification]:cipher:' \
  '-D[dynamic port forwarding]:port:' \
  '-E[log file]:file:_files' \
  '-e[escape char]:char:' \
  '-m[MAC specification]:mac:' \
  '-O[control command]:ctl:(check forward exit stop cancel)' \
  '-Q[query supported algorithms]:query:' \
  '-S[control socket]:socket:_files' \
  '1:host:_hosts' \
  '*:command:' && ret=0

return ret
