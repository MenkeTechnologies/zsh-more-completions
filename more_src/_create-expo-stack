#compdef create-expo-stack
# Documentation: https://www.npmjs.com/package/create-expo-stack
# Reference accessed: 2026-05-24
# Verified: npx create-expo-stack --help.

# Zsh completion for create-expo-stack - configurable Expo project scaffolder

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new Expo project'
  'publish:publish current project to GitHub'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --default)'{-d,--default}'[use default configuration]' \
  '--nonInteractive[skip interactive CLI]' \
  '--overwrite[overwrite existing directory]' \
  '--noInstall[skip installing dependencies]' \
  '--noGit[skip git initialization]' \
  '--publish[create GitHub repo and push code]' \
  '--blank[use blank TypeScript template]' \
  '--npm[use npm as package manager]' \
  '--yarn[use yarn as package manager]' \
  '--pnpm[use pnpm as package manager]' \
  '--bun[use bun as package manager]' \
  '--importAlias[enable TS path aliases]' \
  '--exporouter[use Expo Router for navigation]' \
  '--reactnavigation[use React Navigation]' \
  '--tabs[use tabs for navigation]' \
  '--drawer+tabs[use drawer and tabs navigation]' \
  '--firebase[use Firebase authentication]' \
  '--supabase[use Supabase authentication]' \
  '--vexo-analytics[use Vexo Analytics]' \
  '--nativewind[use NativeWind styling]' \
  '--unistyles[use Unistyles styling]' \
  '--stylesheet[use StyleSheet styling]' \
  '--i18next[use i18next internationalization]' \
  '(-i --ignite)'{-i,--ignite}'[use Ignite opinionated stack]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'create-expo-stack command' commands && ret=0
    ;;
  (args)
    _arguments '*::args:' && ret=0
    ;;
esac

return ret
