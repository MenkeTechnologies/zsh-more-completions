#compdef yosys-config
# Documentation: https://github.com/YosysHQ/yosys/blob/main/misc/yosys-config.in
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)-h[show help]' \
  '(- *)-\?[show help]' \
  '--cxx[print C++ compiler]' \
  '--cxxflags[print C++ compile flags]' \
  '--linkflags[print linker flags]' \
  '--ldflags[print linker flags (alias)]' \
  '--libs[print libraries to link]' \
  '--ldlibs[print libraries to link (alias)]' \
  '--bindir[print bin directory]' \
  '--datdir[print data directory]' \
  '--exec[execute a command instead of generating output]' \
  '--build[build a Yosys plugin: modname.so cppsources]' \
  '--prefix[change replacement prefix]:prefix:' \
  '*::yosys-config args:_files' && ret=0
return ret
