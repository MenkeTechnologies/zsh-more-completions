#compdef yosys-config
# Documentation: https://man.archlinux.org/search?q=yosys-config
# Reference accessed: 2026-05-16

# Yosys yosys-config: query Yosys installation paths and flags
local curcontext="$curcontext" ret=1
_arguments -C \
  '--cxx[print C++ compiler]' \
  '--cxxflags[print C++ compile flags]' \
  '--linkflags[print linker flags]' \
  '--ldflags[print linker flags]' \
  '--libs[print libraries to link]' \
  '--ldlibs[print libraries to link]' \
  '--bindir[print bin directory]' \
  '--datdir[print data directory]' \
  '--exec[run helper executable]:tool:' \
  '--build[build a Yosys plugin]:file:_files' \
  '*::yosys-config args:_files' && ret=0
return ret
