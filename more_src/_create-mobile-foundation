#compdef create-mobile-foundation
# Documentation: https://www.npmjs.com/package/create-mobile-foundation
# Reference accessed: 2026-05-24
# Verified: npm view create-mobile-foundation bin; npm readme Options section.

# Zsh completion for create-mobile-foundation - React Native Expo modules scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--js[generate JavaScript project]' \
  '--ts[keep TypeScript project]' \
  '--firebase[include Firebase packages and native setup]' \
  '--no-firebase[skip Firebase setup]' \
  '--analytics[include Analytics packages and native setup]' \
  '--no-analytics[skip Analytics setup]' \
  '--crashlytics[include Crashlytics packages and native setup]' \
  '--no-crashlytics[skip Crashlytics setup]' \
  '--calendar[include Expo Calendar and iOS usage descriptions]' \
  '--no-calendar[skip Expo Calendar setup]' \
  '--expo-updates[include expo-updates and update prompt UI]' \
  '--no-expo-updates[skip expo-updates setup]' \
  '--netinfo[include offline detector with connectivity monitoring]' \
  '--no-netinfo[skip offline detector]' \
  '--drawer[include @react-navigation/drawer]' \
  '--no-drawer[skip drawer navigation package]' \
  '--material-top-tabs[include material top tabs navigation]' \
  '--no-material-top-tabs[skip material top tabs navigation]' \
  '--expo-version=[Expo SDK version to target]:version:' \
  '--design-width=[design width for responsive utilities]:width:' \
  '--design-height=[design height for responsive utilities]:height:' \
  '--google-font-family=[Google font family to download]:font:' \
  '--italic-fonts[include italic font variants]' \
  '--no-italic-fonts[skip italic font variants]' \
  '--dark-mode[include distinct dark mode palettes]' \
  '--no-dark-mode[keep light and dark palettes identical]' \
  '--dry-run[print commands without running them]' \
  '--help[show help]' \
  ':project name:' && ret=0

return ret
