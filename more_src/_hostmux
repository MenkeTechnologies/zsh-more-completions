#compdef hostmux
# Documentation: https://man.archlinux.org/search?q=hostmux
# Reference accessed: 2026-05-16
# Source: https://github.com/hukl/hostmux/blob/e3f1358db5bb2bbe09a27e7bbe71163ef2f471be/zsh-completion/_hostmux
# Repository: hukl/hostmux (zsh-completion/_hostmux)

typeset -A opt_args

_arguments -C \
  '*-l[Layout]:layouts:->layouts' \
  '*-s[Session Name]' \
  '*-x[Auto close pane]' \
  '*-p[Set pane title to ssh hostname]' \
  '*-P[Set remote prompt to ssh hostname]' \
  '*-a[Sync panes]' \
  '*-f[Use hostnames from file]:host file:_files'\
  '*:destinations:->destinations' \
&& ret=0


case "$state" in
  (destinations)
     local destinations; destinations=(
        $hosts
     )

      _describe -t destinations 'destinations' destinations && ret=0
  ;;
  (layouts)
    local layouts; layouts=(
      'even-vertical'
      'even-horizontal'
      'tiled'
      'main-vertical'
      'main-horizontal'
    )
    _describe -t layouts 'layouts' layouts && ret=0
  ;;
esac;

return 1;
