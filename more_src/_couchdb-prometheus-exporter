#compdef couchdb-prometheus-exporter
# Documentation: https://github.com/gesellix/couchdb-prometheus-exporter
# Prometheus exporter for CouchDB metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[path to config ini file that configures the CouchDB connection]:file:_files' \
  '--web.config=[path to config yaml file that can enable TLS or authentication]:file:_files' \
  '--filtered.scraping.enabled[enable filtered scraping with collect[] parameter support]' \
  '--telemetry.address=[address on which to expose metrics]:address' \
  '--telemetry.endpoint=[path under which to expose metrics]:path' \
  '--couchdb.uri=[URI to the CouchDB instance]:uri' \
  '--couchdb.username=[basic auth username for the CouchDB instance]:username' \
  '--couchdb.password=[basic auth password for the CouchDB instance]:password' \
  '--couchdb.insecure[ignore server certificate if using https]' \
  '--scrape.interval=[duration between metrics collection from the CouchDB cluster]:duration' \
  '--scrape.localonly[collect metrics from local instance instead of whole cluster]' \
  '--databases=[comma separated list of database names, or _all_dbs]:databases' \
  '--databases.views[collect view details of every observed database]' \
  '--database.concurrent.requests=[maximum concurrent calls to CouchDB, or 0 for unlimited]:count' \
  '--scheduler.jobs[collect active replication jobs (CouchDB 2.x+ only)]' \
  '*:arg:_default' && ret=0

return ret
