#compdef appium-cli
# _appium-cli — Appium cross-platform mobile UI automation server CLI alias (Appium project, Node.js); commander/argparse
# upstream: https://github.com/appium/appium

_appium-cli() {
    local -a sub=(
        'server:start the appium server (default)'
        'driver:manage drivers'
        'plugin:manage plugins'
        'setup:perform interactive setup'
        'extension:manage drivers + plugins'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "*.(yml|yaml|json)"' \
        '--show-config[show resolved config]' \
        '--show-build-info[show build info]' \
        '--shell[launch repl]' \
        '--log-level=+[log level]:level:(error warn info debug verbose silly)' \
        '--log=+[log file]:file:_files' \
        '--log-timestamp[log timestamps]' \
        '--local-timezone[local timezone]' \
        '--log-no-colors[no log colors]' \
        '--debug-log-spacing[debug log spacing]' \
        '--keep-alive-timeout=+[keep alive timeout sec]:n:' \
        '--callback-address=+[callback address]:host:_hosts' \
        '--callback-port=+[callback port]:port:' \
        '--port=+[bind port]:port:' \
        '-p+[bind port]:port:' \
        '--address=+[bind address]:host:_hosts' \
        '-a+[bind address]:host:_hosts' \
        '--base-path=+[base path]:str:' \
        '--use-drivers=+[use drivers]:list:' \
        '--use-plugins=+[use plugins]:list:' \
        '--driver=+[driver json]:str:' \
        '--plugin=+[plugin json]:str:' \
        '--no-perms-check[no permissions check]' \
        '--strict-caps[strict caps]' \
        '--tmp=+[tmp dir]:dir:_files -/' \
        '--trace-dir=+[trace dir]:dir:_files -/' \
        '--webhook=+[webhook url]:url:_urls' \
        '--allow-cors[allow CORS]' \
        '--allow-insecure=+[allow insecure features]:list:' \
        '--deny-insecure=+[deny insecure features]:list:' \
        '--relaxed-security[relaxed security]' \
        '--ssl-cert-path=+[ssl cert]:file:_files' \
        '--ssl-key-path=+[ssl key]:file:_files' \
        '--log-filters=+[log filters]:file:_files' \
        '--log-format=+[log format]:fmt:(text json pretty)' \
        '--nodeconfig=+[node config json]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'appium subcommand' sub ;;
        args)
            case $words[1] in
                driver|plugin|extension) _arguments \
                    '1:cmd:(install uninstall update list run doctor)' \
                    '--source=+[source]:s:(npm git github local file)' \
                    '--package=+[package]:str:' \
                    '--json[json output]' \
                    '*:name:' ;;
                setup) _arguments \
                    '1:preset:(mobile browser desktop)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_appium-cli "$@"
