_isogit() {
    local context state state_descr line ret=1
    typeset -A opt_args

    # Every isomorphic-git API method exported by src/api/*.js becomes an
    # isogit subcommand verbatim via `git[command](opts)`.
    local -a cmds
    cmds=(
        # Working-directory operations
        'add:add files to the index'
        'remove:remove files from the index'
        'status:get the status of a file'
        'statusMatrix:efficient bulk status comparison'
        'listFiles:list working-tree files'
        'walk:walk multiple trees in parallel'
        'updateIndex:apply a single index update'
        'resetIndex:reset index entries to HEAD'
        'isIgnored:test against .gitignore rules'
        'stash:stash and pop changes'
        # Commit / log
        'commit:create a new commit'
        'log:read commit history'
        'readCommit:read a commit by oid'
        'writeCommit:write a commit to objects'
        'findMergeBase:find common ancestor between commits'
        'isDescendent:test if commit is descendant of another'
        # Branches / refs
        'branch:create a branch'
        'deleteBranch:delete a branch'
        'renameBranch:rename a branch'
        'listBranches:list local or remote branches'
        'currentBranch:get the current branch name'
        'checkout:checkout a branch or paths'
        'writeRef:write a Git ref'
        'deleteRef:delete a Git ref'
        'resolveRef:resolve a ref to its OID'
        'expandRef:expand a ref shorthand'
        'expandOid:expand a short OID to the full OID'
        'listRefs:list refs matching a prefix'
        # Tags
        'tag:create a lightweight tag'
        'annotatedTag:create an annotated tag'
        'deleteTag:delete a tag'
        'listTags:list tags'
        'readTag:read a tag object'
        'writeTag:write a tag object'
        # Notes
        'addNote:add a note to an object'
        'removeNote:remove a note from an object'
        'readNote:read a note for an object'
        'listNotes:list notes'
        # Network — push/pull/fetch/clone
        'clone:clone a repository (works in browsers via CORS proxy)'
        'init:initialize a new Git repository'
        'fetch:fetch from a remote'
        'pull:pull from a remote'
        'push:push to a remote'
        'fastForward:fast-forward the current branch'
        'merge:merge two branches'
        'cherryPick:cherry-pick a commit'
        'abortMerge:abort an in-progress merge'
        'getRemoteInfo:get remote repository info (refs/HEAD/capabilities)'
        'getRemoteInfo2:get remote info (v2 protocol)'
        'listServerRefs:list refs on a remote server'
        'addRemote:add a remote'
        'deleteRemote:delete a remote'
        'listRemotes:list remotes'
        # Low-level / plumbing
        'hashBlob:compute the OID of a blob without writing'
        'indexPack:index a packfile'
        'packObjects:pack objects into a packfile'
        'readBlob:read a blob by OID'
        'writeBlob:write a blob to objects'
        'readObject:read any object by OID'
        'writeObject:write any object to objects'
        'readTree:read a tree by OID'
        'writeTree:write a tree to objects'
        # Config
        'getConfig:read a config value'
        'getConfigAll:read all values for a config key'
        'setConfig:write a config value'
        'findRoot:find the .git directory from a path'
        # Meta
        'version:print isomorphic-git version'
    )

    _arguments -C \
        '--dir=[working tree directory (default ".")]:dir:_files -/' \
        '--gitdir=[git directory (default <dir>/.git)]:gitdir:_files -/' \
        '--username=[HTTP basic auth username]:user:' \
        '--password=[HTTP basic auth password]:password:' \
        '--ref=[git ref (branch / tag / OID)]:ref:' \
        '--oid=[object id]:oid:' \
        '--filepath=[path within the repository]:path:_files' \
        '--remote=[remote name]:remote:(origin)' \
        '--depth=[shallow clone/fetch depth]:n:' \
        '--singleBranch[only fetch the named branch]' \
        '--noTags[do not fetch tags]' \
        '--force[force the operation]' \
        '--url=[remote URL]:url:' \
        '--corsProxy=[CORS proxy URL (for browser usage)]:url:' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'isogit command (isomorphic-git API method)' cmds && ret=0
            ;;
        args)
            # Free-form positional args / additional --key value pairs
            # (minimisted parses them into the opts object for git[command])
            _files && ret=0
            ;;
    esac

    return ret
}

_isogit "$@"
