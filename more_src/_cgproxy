#compdef cgproxy

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start service'
  'stop:stop service'
  'reload:reload config'
  'status:show status'
  'enable:enable cgroup attach'
  'disable:disable cgroup attach'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=+[config file]:file:_files' \
  '--daemon[run as daemon]' \
  '--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cgproxy command' commands && ret=0 ;;
esac

return ret
