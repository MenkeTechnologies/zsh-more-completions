#compdef cgproxy
# Documentation: https://github.com/springzfx/cgproxy
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cgproxy is a wrapper: `cgproxy [--debug] <cmd>`. Daemon lifecycle is
# managed via systemd, not via cgproxy subcommands.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[verbose debug output]' \
  '*::command: _command_names -e'
