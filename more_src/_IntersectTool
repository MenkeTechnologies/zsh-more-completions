#compdef IntersectTool
# Documentation: https://geographiclib.sourceforge.io/C++/doc/IntersectTool.1.html
# GeographicLib: find intersections between geodesics

local ret=1

_arguments -s -S \
  '-c[find the closest intersection]' \
  '-n[find intersection closest to a given intersection]' \
  '-i[find intersection of two geodesic segments]' \
  '-o[find the closest intersection with an offset]' \
  '-R[return all intersections within L1 distance maxdist]:maxdist:' \
  '-C[check the intersections and print verification to stderr]' \
  '-e[specify ellipsoid via equatorial radius and flattening]:a:' \
  '-E[use exact algorithms based on elliptic integrals]' \
  '-w[longitude precedes latitude on input]' \
  '-p[set output precision]:prec:' \
  '--comment-delimiter[set comment delimiter]:delim:' \
  '--version[print version and exit]' \
  '(-h --help)-h[print usage and exit]' \
  '(-h --help)--help[print full documentation and exit]' \
  '--input-file[read input from file]:infile:_files' \
  '--input-string[read input from string]:string:' \
  '--line-separator[set line separator character]:linesep:' \
  '--output-file[write output to file]:outfile:_files' && ret=0

return ret
