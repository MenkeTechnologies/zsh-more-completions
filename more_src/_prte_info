#compdef prte_info

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*--param=[show MCA parameters]:framework:' \
  '--all[show all available info]' \
  '--internal[show internal MCA params]' \
  '--config[show build configuration]' \
  '--hostname[show hostname]' && ret=0

return ret
