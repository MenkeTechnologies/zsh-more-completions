#compdef hipcub-test hipcub-benchmark
# _hipcub — AMD ROCm hipCUB marshalling layer wrapping rocPRIM or CUB CUDA collective primitives test and benchmark runners (ROCm team, C++); custom argparse
# upstream: https://github.com/ROCm/hipCUB

_hipcub() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--gtest_filter=+[pattern]:str:' \
        '--gtest_list_tests[list tests]' \
        '--gtest_repeat=+[N]:n:' \
        '--gtest_random_seed=+[N]:n:' \
        '--gtest_color=+[mode]:m:(yes no auto)' \
        '--algorithm=+[algorithm]:a:(reduce scan sort merge radix_sort merge_sort histogram device_select device_unique device_partition device_run_length_encode block_reduce block_scan warp_reduce warp_scan)' \
        '--input-type=+[type]:t:(int uint int64 uint64 float double half int8 uint8 short ushort)' \
        '--output-type=+[type]:t:(int uint int64 uint64 float double half int8 uint8 short ushort)' \
        '--size=+[N]:n:' \
        '--trials=+[N]:n:' \
        '--bench=+[bench name]:str:' \
        '--seed=+[seed]:n:' \
        '--device=+[id]:n:' \
        '--threads=+[N]:n:' \
        '--blocks=+[N]:n:' \
        '--items-per-thread=+[N]:n:' \
        '--scan-mode=+[mode]:m:(inclusive exclusive)' \
        '--sort-mode=+[mode]:m:(ascending descending)' \
        '--radix=+[bits]:n:' \
        '--api=+[api]:a:(device block warp)'
}

_hipcub "$@"
