#compdef k3s
# _k3s-cli — Rancher k3s lightweight k8s distro (Rancher/SUSE, Go); single-binary CNCF-conformant k8s
# upstream: https://github.com/k3s-io/k3s

_k3s-cli() {
    local -a sub=(
        'server:run k3s server'
        'agent:run k3s agent'
        'kubectl:run kubectl'
        'crictl:run crictl'
        'ctr:run containerd ctr'
        'check-config:verify host config'
        'token:manage cluster tokens'
        'etcd-snapshot:manage etcd snapshots'
        'secrets-encrypt:secrets encryption'
        'certificate:cert mgmt'
        'completion:print shell completion'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--debug[debug log]' \
        '-d[debug log]' \
        '--data-dir+[data dir]:dir:_files -/' \
        '--config+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'k3s subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments \
                    '--bind-address+[bind address]:host:_hosts' \
                    '--listen-port+[listen port]:port:' \
                    '--cluster-init[initialize HA cluster]' \
                    '--server+[server URL]:url:_urls' \
                    '--token+[shared token]:str:' \
                    '--token-file+[token file]:file:_files' \
                    '--write-kubeconfig+[kubeconfig output]:file:_files' \
                    '--write-kubeconfig-mode+[kubeconfig mode]:mode:' \
                    '--disable+[disable component]:component:(traefik servicelb local-storage metrics-server coredns)' \
                    '--cluster-cidr+[cluster CIDR]:cidr:' \
                    '--service-cidr+[service CIDR]:cidr:' \
                    '--cluster-dns+[cluster DNS]:dns:' \
                    '--node-ip+[node IP]:ip:' \
                    '--node-external-ip+[external IP]:ip:' \
                    '--node-name+[node name]:name:' \
                    '--no-deploy+[no deploy]:component:' \
                    '--flannel-backend+[flannel backend]:backend:(vxlan host-gw wireguard ipsec none)' ;;
                agent) _arguments \
                    '--server+[server URL]:url:_urls' \
                    '--token+[shared token]:str:' \
                    '--token-file+[token file]:file:_files' \
                    '--node-ip+[node IP]:ip:' \
                    '--node-name+[node name]:name:' \
                    '--node-external-ip+[external IP]:ip:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_k3s-cli "$@"
