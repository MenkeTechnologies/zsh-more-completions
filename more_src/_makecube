#compdef makecube
# Documentation: https://github.com/dftbplus/dftbplus/blob/main/tools/dptools/src/dptools/scripts/makecube.py
# DFTB+ dptools: build a Gaussian cube or VTK file from grid data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--xvec=[file containing X vector coordinates]:file:_files' \
  '--yvec=[file containing Y vector coordinates]:file:_files' \
  '--zvec=[file containing Z vector coordinates]:file:_files' \
  '--reference=[reference file for difference output]:file:_files' \
  '--format=[output format]:format:(cube vtk)' \
  '1:grid data source:_files' \
  '2:output cube/vtk file:_files' && ret=0

return ret
