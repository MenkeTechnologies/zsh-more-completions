#compdef sioyek

local -a arguments

arguments=(
  '--new-window[open a new window]'
  '--reuse-instance[reuse an existing sioyek instance]'
  '--nofullscreen[do not start in fullscreen mode]'
  '--page=[open at specified page number]:page number:'
  '--inverse-search=[set inverse search command]:command:'
  '--forward-search-file=[set forward search file]:file:_files'
  '--forward-search-line=[set forward search line]:line number:'
  '--execute-command=[execute a sioyek command]:command:'
  '--execute-command-at=[execute command at coordinates]:coordinates:'
  '--shared-database-path=[path to shared database]:path:_files -/'
  '--version[show version information]'
  '(-h --help)'{-h,--help}'[show help message]'
  '*:PDF file:_files -g "*.pdf"'
)

_arguments -s -S $arguments
