#compdef podofobox
# set the media, crop, bleed, trim, and art box on pages of a PDF file

local ret=1

_arguments -s -S \
  '1:input PDF:_files -g "*.pdf"' \
  '2:output PDF:_files -g "*.pdf"' \
  '3:box:(media crop bleed trim art)' \
  '4:left' \
  '5:bottom' \
  '6:width' \
  '7:height' && ret=0

return ret
