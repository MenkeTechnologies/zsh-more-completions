#compdef axiom

# Zsh completion for Axiom CLI
# https://github.com/axiomhq/axiom-cli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'ingest:Ingest data into a dataset'
  'query:Execute an APL query'
  'stream:Stream data from a dataset'
  'auth:Manage authentication'
  'config:Manage CLI configuration'
  'dataset:Manage datasets'
  'annotation:Manage annotations'
)

_arguments -s -S \
  '(-O --auth-org-id)'{-O,--auth-org-id}'[Organization ID to use]:org_id:' \
  '(-T --auth-token)'{-T,--auth-token}'[API token to use]:token:' \
  '(-C --config)'{-C,--config}'[path to config file]:file:_files' \
  '(-D --deployment)'{-D,--deployment}'[deployment to use]:deployment:' \
  '--no-spinner[disable activity indicator]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'axiom command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (ingest)
        _arguments -s -S '1:dataset:' '*:file:_files' && ret=0
        ;;
      (query)
        _arguments -s -S '1:APL query:' && ret=0
        ;;
      (stream)
        _arguments -s -S '1:dataset:' && ret=0
        ;;
      (auth)
        _arguments -s -S '1:subcommand:(login logout status switch)' && ret=0
        ;;
      (dataset)
        _arguments -s -S '1:subcommand:(create list update delete stats)' && ret=0
        ;;
    esac
    ;;
esac

return ret
