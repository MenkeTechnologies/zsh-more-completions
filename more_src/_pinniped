#compdef pinniped
# Documentation: https://pinniped.dev/docs/reference/cli/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      'login:authenticate with an identity provider'
      'get:retrieve cluster configuration'
      'whoami:print current user identity'
      'completion:generate shell completion script'
      'version:print version'
      'help:show help for any command'
    )
    _describe -t commands 'pinniped command' cmds && ret=0
    ;;
  (rest)
    case ${words[1]} in
      (login)
        _arguments \
          '1:subcommand:(oidc static)' \
          '*::arg:_files' && ret=0
        ;;
      (get)
        _arguments \
          '1:subcommand:(kubeconfig)' \
          '*::arg:_files' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
