#compdef pinniped

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      login:'OIDC login flow'
      whoami:'print current identity'
      get-kubeconfig:'merge cluster identity into kubeconfig'
      version:'print version'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
