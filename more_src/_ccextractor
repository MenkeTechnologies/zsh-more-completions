#compdef ccextractor
# Zsh completion for CCExtractor (closed caption extraction)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-in=[input file format]:format:(ts ps es mkv mp4 wtv)' \
  '-out=[output file format]:format:(srt sami txt ttxt smptett dvdraw null)' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(--input)--input[input file]:file:_files' \
  '-codec=[select codec]:codec:(dvbsub teletext)' \
  '-srt[generate SRT output]' \
  '-sami[generate SAMI output]' \
  '-txt[generate plain text output]' \
  '-ttxt[generate timed text output]' \
  '-smptett[generate SMPTE-TT output]' \
  '-dvdraw[generate raw DVD output]' \
  '-delay=[add delay to subtitles in milliseconds]:milliseconds:' \
  '-trim[trim whitespace from lines]' \
  '--no_rollup[do not produce roll-up captions]' \
  '--startcreditstext=[text for start credits]:text:' \
  '--endcreditstext=[text for end credits]:text:' \
  '-datapid=[PID for data track]:pid:' \
  '-fixpadding[fix padding on DVDs]' \
  '-gui_mode_reports[report progress in GUI-friendly format]' \
  '-utf8[encode output in UTF-8]' \
  '-latin1[encode output in Latin-1]' \
  '-unicode[encode output in Unicode]' \
  '-nofc[do not add font color info]' \
  '-noru[do not repeat lines in roll-up mode]' \
  '*:input file:_files' && ret=0

return ret
