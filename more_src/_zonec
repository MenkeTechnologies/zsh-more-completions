#compdef zonec
# _zonec — NLnet Labs NSD zonec (zone-file compiler that converts BIND-format master zone files into NSD's binary nsd.db database; -c config file, -d directory override, -f db file, -p print stats, -R reload, -L log file, -v verbose, -z process one zone only; usually invoked from nsdc(8) but exposed standalone for advanced operators)
# upstream: https://github.com/NLnetLabs/nsd
# Flags from NLnetLabs/nsd zonec.c on tip.

_zonec() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '-d+[directory]:dir:_files -/' \
        '-f+[database file]:file:_files' \
        '-p[print stats]' \
        '-R[reload nsd after compile]' \
        '-L+[log file]:file:_files' \
        '-z+[single zone name]:zone:'
}

_zonec "$@"
