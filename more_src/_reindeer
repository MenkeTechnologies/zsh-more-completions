#compdef reindeer
# Documentation: https://github.com/facebookincubator/reindeer/blob/main/docs/MANUAL.md
# transform Rust Cargo dependencies into generated Buck build rules

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--third-party-dir=[directory where output will be written]:dir:_files -/' \
  '(-c --config)'{-c,--config=}'[path to the reindeer.toml configuration file]:file:_files' \
  '1:command:((
    vendor\:"download crate sources into the repository"
    buckify\:"generate or regenerate the BUCK file from Cargo dependencies"
    update\:"update Rust dependencies"
    import\:"import dependencies into the build system"
  ))' \
  '*::arg:->args' && ret=0

return ret
