#compdef khal

# completions for khal calendar CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)--version[show version and exit]' \
  {-c+,--config=}'[configuration file]:file:_files' \
  {-v,--verbose}'[verbose output]' \
  '--color=[enable or disable color]:color:(auto always never)' \
  '*::args:->subcmds' && ret=0

case $state in
  subcmds)
    local -a commands
    commands=(
      'at:show events at a specific time'
      'calendar:show calendar'
      'configure:create initial configuration'
      'edit:interactively edit an event'
      'export:export events as iCal'
      'import:import events from iCal file'
      'interactive:start interactive mode'
      'list:list events for a date range'
      'new:create a new event'
      'printcalendars:list configured calendars'
      'printformats:print available format strings'
      'search:search for events'
    )
    _describe -t commands 'khal command' commands && ret=0
    ;;
esac

return ret
