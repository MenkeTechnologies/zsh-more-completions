#compdef attsys
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/attsys.html
# Do various operations with Tsys values

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'out=[out keyword]:out:' \
  'tsysif=[tsysif keyword]:tsysif:' \
  'factor=[factor keyword]:factor:' \
  'options=[options keyword]:options:' \
  '*:visibility dataset:_files' && ret=0

return ret
