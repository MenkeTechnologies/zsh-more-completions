#compdef poetry-plugin-export
# _poetry-plugin-export — poetry export plugin flags (python-poetry/poetry-plugin-export)
# upstream: https://github.com/python-poetry/poetry-plugin-export
# Flags from src/poetry_plugin_export/command.py (cleo options).

_poetry-plugin-export() {
    _arguments \
        '(-f --format)'{-f+,--format=}'[export format]:fmt:(constraints.txt requirements.txt pylock.toml)' \
        '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
        '--without-hashes[exclude package hashes]' \
        '--without-urls[exclude source repository URLs]' \
        '--dev[include dev dependencies (deprecated)]' \
        '--all-groups[include all dependency groups]' \
        '*--with=[dependency groups to include]:group:' \
        '*--only=[only these dependency groups]:group:' \
        '*--without=[dependency groups to exclude]:group:' \
        '*'{-E+,--extras=}'[extra dependency sets to include]:extra:' \
        '--all-extras[include all extras]' \
        '--with-credentials[include credentials for extra indices]'
}

_poetry-plugin-export "$@"
