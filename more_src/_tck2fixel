#compdef tck2fixel
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tck2fixel.html
# compute a fixel TDI map from a tractogram

local ret=1

_arguments -s -S \
  '-angle=[max angle for assigning streamline tangents to fixels (deg)]:value' \
  '-info[display information messages]' \
  '-quiet[suppress information and progress messages]' \
  '-debug[display debugging messages]' \
  '-force[force overwrite of output files]' \
  '-nthreads=[number of threads]:number' \
  '-config=[temporarily set a config entry]:key:_default:value' \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[display version information]' \
  '1:tracks:_files' \
  '2:fixel_folder_in:_files -/' \
  '3:fixel_folder_out:_files -/' \
  '4:fixel_data_out:_files' && ret=0

return ret
