#compdef mihari
# Documentation: https://github.com/ninoseki/mihari/tree/master/lib/mihari/cli
# Reference accessed: 2026-05-27
# Verified: upstream lib/mihari/cli/application.rb and lib/mihari/commands/*.rb on master.

local curcontext="$curcontext" state line ret=1

local -a _mihari_subcommands _mihari_db_subcommands _mihari_rule_subcommands
local -a _mihari_alert_subcommands _mihari_artifact_subcommands
local -a _mihari_tag_subcommands _mihari_config_subcommands

_mihari_subcommands=(
  'search:search by a rule'
  'rule:rule subcommands (init/validate/format/list/get/delete/list-transform)'
  'alert:alert subcommands (create/list/get/delete/list-transform)'
  'artifact:artifact subcommands (list/get/delete/enrich/list-transform)'
  'tag:tag subcommands (list/delete/list-transform)'
  'db:database subcommands (migrate)'
  'config:config subcommands (list)'
  'sidekiq:start Sidekiq'
  'web:start the web app'
  'help:show usage'
)

_mihari_db_subcommands=(
  'migrate:migrate DB schemas (up or down)'
)

_mihari_rule_subcommands=(
  'init:initialize a new rule file'
  'validate:validate rule(s)'
  'format:format a rule file'
  'list:list/search rules'
  'list-transform:list/search rules with Jbuilder transformation'
  'get:get a rule by ID'
  'delete:delete a rule by ID'
  'search:search by a rule'
)

_mihari_alert_subcommands=(
  'create:create an alert from a YAML file'
  'list:list/search alerts'
  'list-transform:list/search alerts with Jbuilder transformation'
  'get:get an alert by ID'
  'delete:delete an alert by ID'
)

_mihari_artifact_subcommands=(
  'list:list/search artifacts'
  'list-transform:list/search artifacts with Jbuilder transformation'
  'get:get an artifact by ID'
  'enrich:enrich an artifact by ID'
  'delete:delete an artifact by ID'
)

_mihari_tag_subcommands=(
  'list:list/search tags'
  'list-transform:list/search tags with Jbuilder transformation'
  'delete:delete a tag by ID'
)

_mihari_config_subcommands=(
  'list:list configs'
)

_arguments -C \
  '(-d --debug)'{-d,--debug}'[set up debug mode]' \
  '(-v --version)'{-v,--version}'[print the version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

_mihari_paging_args() {
  _arguments \
    '--page=[page number]:n:' \
    '--limit=[results per page]:n:'
}

case $state in
  cmd)
    _describe -t commands 'mihari subcommand' _mihari_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _arguments \
          '(-f --force_overwrite)'{-f,--force_overwrite}'[force overwriting an existing rule]' \
          '1:rule path or rule id:_files' && ret=0
        ;;
      sidekiq)
        _arguments \
          '--env=[environment]:env:' \
          '(-c --concurrency)'{-c,--concurrency}'=[sidekiq concurrency]:n:' && ret=0
        ;;
      web)
        _arguments \
          '--port=[port to listen on]:port:' \
          '--host=[hostname to listen on]:host:' \
          '--threads=[min:max threads]:threads:' \
          '--verbose[do not report each request]' \
          '--worker_timeout=[worker timeout in seconds]:seconds:' \
          '--open[open the app in browser]' \
          '--no-open[do not open the app in browser]' \
          '--env=[environment]:env:' && ret=0
        ;;
      db)
        _arguments -C '1: :->dbcmd' '*:: :->dbargs' && ret=0
        case $state in
          dbcmd) _describe -t commands 'mihari db subcommand' _mihari_db_subcommands && ret=0 ;;
          dbargs)
            case $line[1] in
              migrate)
                _arguments \
                  '--verbose[verbose migration output]' \
                  '--no-verbose[non-verbose migration output]' \
                  '1:direction:(up down)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      rule)
        _arguments -C '1: :->rcmd' '*:: :->rargs' && ret=0
        case $state in
          rcmd) _describe -t commands 'mihari rule subcommand' _mihari_rule_subcommands && ret=0 ;;
          rargs)
            case $line[1] in
              init|format|validate)
                _arguments '*:path:_files' && ret=0
                ;;
              list|list-transform)
                _mihari_paging_args
                [[ $line[1] == list-transform ]] && _arguments '(-t --template)'{-t+,--template=}'[Jbuilder template]:tpl:'
                _arguments '1:query:' && ret=0
                ;;
              get|delete)
                _arguments '1:id:' && ret=0
                ;;
              search)
                _arguments \
                  '(-f --force_overwrite)'{-f,--force_overwrite}'[force overwriting an existing rule]' \
                  '1:rule path or rule id:_files' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      alert)
        _arguments -C '1: :->acmd' '*:: :->aargs' && ret=0
        case $state in
          acmd) _describe -t commands 'mihari alert subcommand' _mihari_alert_subcommands && ret=0 ;;
          aargs)
            case $line[1] in
              create) _arguments '1:alert YAML path:_files' && ret=0 ;;
              list|list-transform)
                _mihari_paging_args
                [[ $line[1] == list-transform ]] && _arguments '(-t --template)'{-t+,--template=}'[Jbuilder template]:tpl:'
                _arguments '1:query:' && ret=0
                ;;
              get|delete)
                _arguments '1:id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      artifact)
        _arguments -C '1: :->arcmd' '*:: :->arargs' && ret=0
        case $state in
          arcmd) _describe -t commands 'mihari artifact subcommand' _mihari_artifact_subcommands && ret=0 ;;
          arargs)
            case $line[1] in
              list|list-transform)
                _mihari_paging_args
                [[ $line[1] == list-transform ]] && _arguments '(-t --template)'{-t+,--template=}'[Jbuilder template]:tpl:'
                _arguments '1:query:' && ret=0
                ;;
              get|delete|enrich)
                _arguments '1:id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      tag)
        _arguments -C '1: :->tcmd' '*:: :->targs' && ret=0
        case $state in
          tcmd) _describe -t commands 'mihari tag subcommand' _mihari_tag_subcommands && ret=0 ;;
          targs)
            case $line[1] in
              list|list-transform)
                _mihari_paging_args
                [[ $line[1] == list-transform ]] && _arguments '(-t --template)'{-t+,--template=}'[Jbuilder template]:tpl:'
                _arguments '1:query:' && ret=0
                ;;
              delete) _arguments '1:id:' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      config)
        _arguments -C '1: :->ccmd' && ret=0
        case $state in
          ccmd) _describe -t commands 'mihari config subcommand' _mihari_config_subcommands && ret=0 ;;
        esac
        ;;
      help)
        _arguments '*:subcommand:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
