#compdef trufont
# _trufont — Adrien Tétar TruFont cross-platform Python/Qt UFO3 font-editing CLI launching a GUI editor with FontTools-based pen abstraction kerning groups composites layers OpenType feature editor (trufont team, Python/Qt); Qt argparse
# upstream: https://github.com/trufont/trufont

_trufont() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--style=+[Qt style]:s:(fusion windows windowsvista gtk2 macintosh)' \
        '--platform=+[platform]:p:(xcb wayland cocoa windows direct2d minimal)' \
        '--quiet[quiet]' \
        '-c+[python config]:file:_files -g "*.py"' \
        '--config=+[python config]:file:_files -g "*.py"' \
        '--extension-dir=+[dir]:dir:_files -/' \
        '--user-data-dir=+[dir]:dir:_files -/' \
        '--user-config-dir=+[dir]:dir:_files -/' \
        '--reset-prefs[reset preferences]' \
        '--no-tools[no tools]' \
        '*:UFO files:_files -g "*.ufo *.ufoz *.otf *.ttf"'
}

_trufont "$@"
