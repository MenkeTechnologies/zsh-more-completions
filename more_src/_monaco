#compdef monaco
# Documentation: https://docs.dynatrace.com/docs/manage/configuration-as-code/monaco/reference/commands
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'deploy:deploy configurations to a Dynatrace environment'
  'download:download configurations from a Dynatrace environment'
  'delete:remove configurations from a Dynatrace environment'
  'purge:remove all configurations from a Dynatrace environment'
  'generate:generate auxiliary files from configuration'
  'account:manage account-management resources'
  'convert:convert v1 manifest to v2'
  'help:show help'
  'version:show version'
  'completion:generate shell completion'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--verbose[verbose output]' \
  '--log-format=[log output format]:format:(plain json)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'monaco command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy)
        _arguments \
          '(-e --environment)*'{-e+,--environment=}'[target environment(s)]:env:' \
          '(-p --project)*'{-p+,--project=}'[project to deploy]:project:' \
          '(-g --group)*'{-g+,--group=}'[environment group]:group:' \
          '--continue-on-error[continue on individual errors]' \
          '(-d --dry-run)'{-d,--dry-run}'[validate only]' \
          '*::manifest:_files -g "manifest.{yaml,yml}"' && ret=0 ;;
      (download)
        _arguments \
          '(-u --url)'{-u+,--url=}'[Dynatrace environment URL]:url:' \
          '--manifest=[manifest file]:file:_files' \
          '(-e --environment)'{-e+,--environment=}'[manifest env name]:env:' \
          '(-o --output-folder)'{-o+,--output-folder=}'[output folder]:dir:_files -/' \
          '(-p --project)'{-p+,--project=}'[output project name]:project:' \
          '*--only-api=[only download an API type]:api:' \
          '*--only-settings=[only download a settings schema]:schema:' \
          '*--specific-api=[download specific API type]:api:' \
          '*--specific-environment=[download specific env]:env:' \
          '--force[overwrite existing files]' \
          '--include-deprecated[include deprecated APIs]' \
          '--token=[API token env var]:env:' \
          '--oauth-client-id=[OAuth client id env var]:env:' \
          '--oauth-client-secret=[OAuth client secret env var]:env:' && ret=0 ;;
      (delete)
        _arguments \
          '--manifest=[manifest file]:file:_files' \
          '*--environment=[target env]:env:' \
          '*--file=[delete file]:file:_files' \
          '--continue-on-error[continue on errors]' && ret=0 ;;
      (purge)
        _arguments \
          '--manifest=[manifest file]:file:_files' \
          '*--environment=[target env]:env:' \
          '--continue-on-error[continue on errors]' && ret=0 ;;
      (account)
        _arguments '*::sub:(download deploy delete)' && ret=0 ;;
      (generate)
        _arguments '*::sub:(deletefile schema)' && ret=0 ;;
      (convert)
        _arguments \
          '(-o --output-folder)'{-o+,--output-folder=}'[output folder]:dir:_files -/' \
          '*::file:_files' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
