#compdef clj-new
# _clj-new — Sean Corfield clj-new project generator CLI alias (seancorfield team, Clojure); tools.deps function CLI
# upstream: https://github.com/seancorfield/clj-new

_clj-new() {
    local -a sub=(
        'app:scaffold app project'
        'lib:scaffold library project'
        'template:create new template'
        'create:create from custom template'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'clj-new subcommand' sub ;;
        args)
            case $words[1] in
                app|lib|template|create) _arguments \
                    '1:project name:' \
                    ':name=+[name]:str:' \
                    ':template=+[template]:str:' \
                    ':args=+[args edn]:str:' \
                    ':to-dir=+[output dir]:dir:_files -/' \
                    ':target-dir=+[target dir]:dir:_files -/' \
                    ':force=+[force]:b:(true false)' \
                    ':overwrite=+[overwrite]:b:(true false)' \
                    ':verbose=+[verbose]:b:(true false)' \
                    ':env=+[env edn]:str:' ;;
            esac
            ;;
    esac
}

_clj-new "$@"
