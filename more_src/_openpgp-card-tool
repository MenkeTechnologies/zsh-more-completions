#compdef openpgp-card-tool

# openpgp-card-tool: GnuPG-style ops on an OpenPGP smartcard via PCSC
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'status:show card status / PINs'
  'list:list inserted cards'
  'pin:change/verify PIN/admin PIN'
  'reset:factory-reset the card'
  'public-key:export public key'
  'fingerprint:show key fingerprints'
  'generate:generate keys on-card'
  'import:import existing keys'
  'sign:sign a message'
  'decrypt:decrypt a message'
  'attestation:export attestation certs (Yubikey)'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--card=[card serial]:serial:' \
  '--pin=[pin]:pin:' \
  '--admin-pin=[admin pin]:pin:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'openpgp-card-tool command' commands && ret=0 ;;
esac
return ret
