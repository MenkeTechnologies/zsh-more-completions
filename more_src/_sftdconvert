#compdef sftdconvert
# Documentation: https://github.com/ahay/src/blob/master/user/llisiw/Mtdconvert.c
# Madagascar: iterative time-to-depth velocity conversion

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'velocity=[y, input is velocity / n, slowness-squared]:flag:(y n)' \
  'dix=[Dix velocity input]:file:_files' \
  'order=[fastmarch accuracy order]:order' \
  'thres=[thresholding for caustics]:value' \
  'niter=[number of nonlinear updates]:count' \
  'cgiter=[number of CG iterations]:count' \
  'shape=[regularization, default Tikhonov]:flag:(y n)' \
  'eps=[regularization parameter]:value' \
  'nline=[maximum number of line search]:count' \
  'verb=[verbosity flag]:flag:(y n)' \
  'tol=[tolerance for shaping regularization]:value' \
  '*rect=[smoothing radius on the n-th axis]:radius' \
  't0=[output transformation matrix (time)]:file:_files' \
  'x0=[output transformation matrix (space)]:file:_files' \
  'f0=[output auxiliary label]:file:_files' \
  'grad=[output gradient]:file:_files' \
  'cost=[output cost]:file:_files' \
  'mask=[input mask, desired minimum]:file:_files' \
  'mval=[input cost, desired minimum]:file:_files' \
  'prec=[input preconditioner]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
