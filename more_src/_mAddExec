#compdef mAddExec
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mAddExec.html
# Coadd reprojected images into a set of output tiles

local ret=1

_arguments -s -S \
  '-p+[directory containing reprojected images]:imgdir:_files -/' \
  '-n[ignore pixel-area weighting; no area output]' \
  '-a+[averaging method]:type:(mean median)' \
  '-e[exact size mode: match template exactly]' \
  '-d+[debugging level (1-3)]:level' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '-x+[tile size along axis 0 (pixels)]:TileSizeAxis0' \
  '-y+[tile size along axis 1 (pixels)]:TileSizeAxis1' \
  '-o+[overlap along axis 0 (pixels)]:OverlapAxis0' \
  '-q+[overlap along axis 1 (pixels)]:OverlapAxis1' \
  '1:images table:_files -g "*.tbl"' \
  '2:header template:_files' \
  '3:tile directory:_files -/' \
  '4:output FITS:_files -g "*.fits"' && ret=0

return ret
