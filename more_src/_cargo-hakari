#compdef cargo-hakari

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'generate:generate or update the workspace-hack package'
      'manage-deps:manage workspace-hack dependency declarations'
      'init:initialize workspace-hack support in a workspace'
      'disable:disable workspace-hack'
      'remove-deps:remove workspace-hack from dependency declarations'
      'publish:prepare workspace-hack for publishing'
      'verify:verify that the workspace-hack is up-to-date'
    )
    _describe -t commands 'cargo hakari command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (generate)
        _arguments -s -S \
          '--diff[show diff instead of writing]' \
          '--quiet[suppress output]' \
          '--workspace-root=[workspace root]:dir:_directories' && ret=0
        ;;
      (manage-deps)
        _arguments -s -S \
          '--add[add workspace-hack to all crates]' \
          '--remove[remove workspace-hack from all crates]' \
          '--yes[skip confirmation]' \
          '--workspace-root=[workspace root]:dir:_directories' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '--yes[skip confirmation]' \
          '--workspace-root=[workspace root]:dir:_directories' \
          '1:hack package name' && ret=0
        ;;
      (verify)
        _arguments -s -S \
          '--quiet[suppress output]' \
          '--workspace-root=[workspace root]:dir:_directories' && ret=0
        ;;
      (disable|remove-deps|publish)
        _arguments -s -S \
          '--yes[skip confirmation]' \
          '--workspace-root=[workspace root]:dir:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
