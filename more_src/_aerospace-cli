#compdef aerospace-cli
# _aerospace-cli — AeroSpace i3-like tiling WM for macOS CLI alias (Anton Khvorov / nikitabobko, Swift); custom argparse
# upstream: https://github.com/nikitabobko/AeroSpace

_aerospace-cli() {
    local -a sub=(
        'balance-sizes:balance container sizes'
        'close-all-windows-but-current:close all windows but current'
        'close:close window'
        'config:show config'
        'debug-windows:debug windows'
        'enable:enable/disable AeroSpace'
        'exec-and-forget:exec command and forget'
        'flatten-workspace-tree:flatten workspace tree'
        'focus:focus direction'
        'focus-back-and-forth:focus back and forth'
        'focus-monitor:focus monitor'
        'fullscreen:toggle fullscreen'
        'join-with:join with sibling'
        'layout:change layout'
        'list-apps:list apps'
        'list-exec-env-vars:list exec env vars'
        'list-modes:list modes'
        'list-monitors:list monitors'
        'list-windows:list windows'
        'list-workspaces:list workspaces'
        'macos-native-fullscreen:toggle macOS native fullscreen'
        'macos-native-minimize:macOS native minimize'
        'mode:change mode'
        'move:move window'
        'move-mouse:move mouse'
        'move-node-to-monitor:move node to monitor'
        'move-node-to-workspace:move node to workspace'
        'move-workspace-to-monitor:move workspace to monitor'
        'reload-config:reload config'
        'resize:resize window'
        'split:split window direction'
        'summon-workspace:summon workspace'
        'trigger-binding:trigger binding'
        'volume:control volume'
        'workspace:switch workspace'
        'workspace-back-and-forth:workspace back and forth'
        'enable-toggle:toggle AeroSpace on/off'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aerospace subcommand' sub ;;
        args)
            case $words[1] in
                focus) _arguments \
                    '1:direction:(left right up down)' \
                    '--boundaries=+[boundaries]:b:(workspace all-monitors-outer-frame)' \
                    '--boundaries-action=+[boundaries action]:a:(stop wrap-around-the-workspace wrap-around-all-monitors)' \
                    '--ignore-floating[ignore floating]' ;;
                move) _arguments \
                    '1:direction:(left right up down)' \
                    '--boundaries=+[boundaries]:b:(workspace all-monitors-outer-frame)' \
                    '--boundaries-action=+[boundaries action]:a:(stop wrap-around-the-workspace wrap-around-all-monitors)' ;;
                resize) _arguments \
                    '1:dim:(width height smart smart-opposite)' \
                    '2:value:' ;;
                layout) _arguments '*:layout:(h_tiles v_tiles h_accordion v_accordion tiles accordion horizontal vertical tiling floating)' ;;
                split) _arguments '1:direction:(horizontal vertical opposite)' ;;
                workspace) _arguments \
                    '1:workspace:' \
                    '--auto-back-and-forth[auto back and forth]' ;;
                summon-workspace) _arguments \
                    '1:workspace:' ;;
                move-node-to-workspace) _arguments \
                    '1:workspace:' \
                    '--focus-follows-window[focus follows]' \
                    '--wrap-around[wrap around]' ;;
                move-node-to-monitor) _arguments \
                    '1:monitor:(left right up down next prev)' \
                    '--focus-follows-window[focus follows]' \
                    '--wrap-around[wrap around]' ;;
                mode) _arguments \
                    '1:mode-name:' ;;
                exec-and-forget) _arguments \
                    '*:cmd:_command_names -e' ;;
                trigger-binding) _arguments \
                    '1:binding:' ;;
                join-with) _arguments \
                    '1:direction:(left right up down)' ;;
                volume) _arguments \
                    '1:cmd:(up down mute set show)' \
                    '2:value:' ;;
                list-windows) _arguments \
                    '--all[all]' \
                    '--focused[focused]' \
                    '--monitor=+[monitor]:list:' \
                    '--workspace=+[workspace]:list:' \
                    '--pid=+[pid]:pid:_pids' \
                    '--app-bundle-id=+[app bundle id]:str:' \
                    '--format=+[format]:str:' \
                    '--json[json output]' \
                    '--count[count only]' ;;
                list-workspaces) _arguments \
                    '--all[all]' \
                    '--focused[focused]' \
                    '--visible[visible]' \
                    '--monitor=+[monitor]:list:' \
                    '--empty[empty workspaces]' \
                    '--format=+[format]:str:' \
                    '--json[json output]' \
                    '--count[count only]' ;;
                list-monitors) _arguments \
                    '--focused[focused]' \
                    '--mouse[mouse monitor]' \
                    '--format=+[format]:str:' \
                    '--json[json output]' \
                    '--count[count only]' ;;
            esac
            ;;
    esac
}

_aerospace-cli "$@"
