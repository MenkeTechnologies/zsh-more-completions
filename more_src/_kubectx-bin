#compdef kubectx
# _kubectx-bin — kubectx fast k8s context switcher (Ahmet Alp Balkan, Go); switch between kube-contexts with completion
# upstream: https://github.com/ahmetb/kubectx

_kubectx-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-c[print current context]' \
        '--current[print current context]' \
        '-d[delete contexts]' \
        '-u[unset current context]' \
        '--unset[unset current context]' \
        '*:context:'
}

_kubectx-bin "$@"
