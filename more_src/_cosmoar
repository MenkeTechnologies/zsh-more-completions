#compdef cosmoar
# Documentation: https://github.com/jart/cosmopolitan/blob/master/tool/cosmocc/bin/cosmoar
# Reference accessed: 2026-05-27
# Verified: upstream tool/cosmocc/bin/cosmoar shell script

# Zsh completion for cosmoar.
# Dual-architecture wrapper that splits input objects into x86_64 and
# aarch64 sets (the aarch64 objects live in mirrored .aarch64/ paths) and
# invokes x86_64-linux-cosmo-ar plus aarch64-linux-cosmo-ar in parallel.
# Accepts the standard GNU binutils ar argv. @file response files and
# paths containing spaces are explicitly rejected.

local arguments

arguments=(
  '--help[display help and exit]'
  '--version[print version information]'
  '--plugin=[load the named plugin]:plugin:_files'
  '--target=[specify object file target]:bfdname:'
  '--output=[specify output directory for extracted members]:directory:_files -/'
  '--record-libdeps=[set library dependency entry to write]:libdeps:'
  '--thin[create a thin archive (D modifier)]'
  '*:archive or object:_files -g "*.(a|o)(-.)"'
)

_arguments -s $arguments
