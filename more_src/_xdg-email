#compdef xdg-email
# _xdg-email — XDG xdg-email (open user's mail client with a pre-filled message; --subject/--body/--cc/--bcc/--utf8 set headers, --attach attaches a file, positional args are mailto: URIs or addresses)
# upstream: https://gitlab.freedesktop.org/xdg/xdg-utils
# Flags from xdg-utils scripts/xdg-email.in on tip.

_xdg-email() {
    _arguments \
        '--help[show help]' \
        '--manual[show full manual]' \
        '--version[show version]' \
        '--utf8[subject/body are UTF-8]' \
        '--subject+[subject]:subject:' \
        '--body+[body]:body:' \
        '--cc+[CC address]:address:' \
        '--bcc+[BCC address]:address:' \
        '*--attach+[file to attach]:file:_files' \
        '*:mailto/address:'
}

_xdg-email "$@"
