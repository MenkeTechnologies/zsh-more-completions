#compdef lazarus lazarus-ide
# Documentation: https://man.archlinux.org/search?q=lazarus
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug-log=+[debug log]:file:_files' \
  '--debug-enable=+[debug groups]:groups:' \
  '--language=+[language]:lang:' \
  '--gtk-debug=+[gtk debug]:flag:' \
  '--lazarusdir=+[lazarus dir]:dir:_files -/' \
  '--primary-config-path=+[config path]:path:_files -/' \
  '--secondary-config-path=+[secondary path]:path:_files -/' \
  '--no-splash-screen[no splash screen]' \
  '--ignore-binaries[ignore binaries]' \
  '--skip-last-project[skip last project]' \
  '*:project:_files -g "*.lpi"' && ret=0

return ret
