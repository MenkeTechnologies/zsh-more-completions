#compdef broadside
# _broadside — Armada load-test orchestrator (drives a real cluster + Postgres / Pulsar dependencies through synthetic submission scenarios + collects latency metrics)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/broadside/main.go on tip; deeper config in the YAML file (cmd/broadside/configs or --config).

_broadside() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[application configuration file (repeatable; comma-separated paths also accepted)]:file:_files -g "*.yaml"' \
        '--results-dir=[directory to write result files to]:dir:_files -/' \
        '--teardown-only[connect to the configured database, tear it down, then exit]' \
        '(-y --yes)'{-y,--yes}'[skip the data-generation confirmation prompt]'
}

_broadside "$@"
