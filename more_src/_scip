#compdef scip
# Documentation: https://www.scipopt.org/doc/html/SHELL.php
# SCIP mixed-integer programming and constraint solver

local ret=1

_arguments -s \
  '(-v --version)'{-v,--version}'[print version and build options]' \
  '-l[copy output into log file]:logfile:_files' \
  '-q[suppress screen messages]' \
  '-s[load parameter settings (.set) file]:settings:_files' \
  '-f[load and solve problem file]:problem:_files' \
  '-b[load and execute dialog command batch file]:batchfile:_files' \
  '-c[execute single line of dialog commands]:command' \
  '-r[nonnegative integer to be used as random seed]:randseed' \
  '-t[number of threads (triggers concurrent solving)]:threads' \
  '-o[pass primal and dual objective reference values]:primref' \
  '*:file:_files' && ret=0

return ret
