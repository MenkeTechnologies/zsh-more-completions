#compdef digikam-cli

# digiKam CLI: KDE photo manager CLI front-end
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--database-type=[database backend]:type:(QSQLITE QMYSQL)' \
  '--database-directory=[SQLite database directory]:dir:_files -/' \
  '--config=[load alternate config]:file:_files' \
  '--detect-camera[detect attached camera]' \
  '--download-from=[download photos from camera path]:path:_files -/' \
  '--download-from-udi=[download photos from camera UDI]:udi:' \
  '--detect-rawfiles[detect raw files in dir]:dir:_files -/' \
  '*:album dir:_files -/' && ret=0
return ret
