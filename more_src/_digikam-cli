#compdef digikam-cli

# digikam-cli: digiKam batch helper (digiKam photo management)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--help-all[show all help (Qt/KDE included)]' \
  '--version[show version]' \
  '--database-directory=[database directory]:dir:_files -/' \
  '--config=[config file]:file:_files' \
  '*:image file or folder:_files' && ret=0
return ret
