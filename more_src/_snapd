#compdef snapd
# Documentation: https://man.archlinux.org/search?q=snapd
# Reference accessed: 2026-05-16

# Zsh completion for snapd (snap daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--version[Print version]' \
  '--no-sprout[Do not launch the snapd snap seed]' && ret=0

return ret
