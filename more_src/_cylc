#compdef cylc
# Documentation: https://cylc.github.io/cylc-doc/stable/html/reference/command-line-interface.html
# Cylc workflow engine and scheduler

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:((
    install\:"install a workflow"
    play\:"start, resume or restart a workflow"
    stop\:"stop a running workflow"
    clean\:"clean a workflow from the run directory"
    reinstall\:"reinstall a workflow"
    validate\:"validate a workflow configuration"
    vip\:"validate, install and play a workflow"
    vr\:"validate and reinstall a workflow"
    scan\:"scan for running workflows"
    cat-log\:"print, tail or list workflow and job logs"
    trigger\:"force tasks to run"
    hold\:"hold tasks in a workflow"
    release\:"release held tasks in a workflow"
    pause\:"pause a workflow"
    broadcast\:"override workflow configuration at runtime"
    set\:"set task prerequisites and outputs"
    message\:"record task job messages"
    kill\:"kill running or submitted task jobs"
    poll\:"poll task jobs"
    remove\:"remove tasks from a workflow"
    show\:"show workflow and task information"
    list\:"list tasks and families"
    config\:"print the cylc configuration"
    graph\:"render a workflow graph"
    ping\:"check that a workflow is running"
    diff\:"compare two workflow configurations"
    gui\:"start the cylc web GUI"
    tui\:"start the cylc terminal UI"
    ext-trigger\:"report an external trigger event"
    workflow-state\:"check or poll a workflow database"
    verbosity\:"change a running workflow log level"
    report-timings\:"generate task timing reports"
    completion-server\:"server for shell tab completion"
  ))' \
  '*::arg:_files' && ret=0

return ret
