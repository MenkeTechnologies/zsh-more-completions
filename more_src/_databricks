#compdef databricks

# Zsh completion for databricks - Databricks CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authentication utilities'
  'bundle:Databricks Asset Bundles'
  'clusters:manage Databricks clusters'
  'cluster-policies:manage cluster policies'
  'current-user:get information about current user'
  'dashboards:manage SQL dashboards'
  'experiments:manage MLflow experiments'
  'fs:filesystem utilities'
  'git-credentials:manage git credentials'
  'groups:manage groups'
  'instance-pools:manage instance pools'
  'ip-access-lists:manage IP access lists'
  'jobs:manage Databricks jobs'
  'libraries:manage cluster libraries'
  'metastores:manage Unity Catalog metastores'
  'model-registry:manage model registry'
  'permissions:manage permissions'
  'pipelines:manage Delta Live Tables pipelines'
  'repos:manage Databricks Repos'
  'schemas:manage Unity Catalog schemas'
  'secrets:manage Databricks secrets'
  'service-principals:manage service principals'
  'serving-endpoints:manage model serving endpoints'
  'sql:manage Databricks SQL'
  'storage-credentials:manage storage credentials'
  'tokens:manage personal access tokens'
  'unity-catalog:manage Unity Catalog'
  'users:manage users'
  'volumes:manage Unity Catalog volumes'
  'warehouses:manage SQL warehouses'
  'workspace:manage workspace objects'
  'account:manage Databricks account'
  'configure:configure Databricks CLI'
  'help:help about any command'
  'version:show version'
)

_arguments -s -S \
  '1:command:->command' \
  '--debug[enable debug logging]' \
  '(-o --output)'{-o,--output}'[output format]:format:(json text)' \
  '(-p --profile)'{-p,--profile}'[connection profile]:profile' \
  '(-t --target)'{-t,--target}'[bundle target]:target' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'databricks command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (clusters)
        local -a cluster_commands=(
          'create:create a cluster'
          'delete:permanently delete a cluster'
          'edit:edit a cluster'
          'events:list cluster events'
          'get:get a cluster'
          'list:list clusters'
          'list-node-types:list node types'
          'list-zones:list availability zones'
          'permanent-delete:permanently delete a cluster'
          'pin:pin a cluster'
          'resize:resize a cluster'
          'restart:restart a cluster'
          'spark-versions:list Spark versions'
          'start:start a terminated cluster'
          'unpin:unpin a cluster'
        )
        _arguments '1:cluster command:->cluster_cmd' && ret=0
        if [[ $state == cluster_cmd ]]; then
          _describe -t commands 'cluster command' cluster_commands && ret=0
        fi
        ;;
      (jobs)
        local -a jobs_commands=(
          'create:create a job'
          'delete:delete a job'
          'get:get a job'
          'get-run:get a job run'
          'list:list jobs'
          'list-runs:list job runs'
          'cancel-run:cancel a job run'
          'repair-run:repair a job run'
          'reset:reset a job'
          'run-now:trigger a new run'
          'submit:submit a one-time run'
          'update:update a job'
          'delete-run:delete a job run'
          'export-run:export a job run'
        )
        _arguments '1:jobs command:->jobs_cmd' && ret=0
        if [[ $state == jobs_cmd ]]; then
          _describe -t commands 'jobs command' jobs_commands && ret=0
        fi
        ;;
      (fs)
        local -a fs_commands=(
          'cat:show file contents'
          'cp:copy files'
          'ls:list files'
          'mkdir:create a directory'
          'rm:remove files'
        )
        _arguments '1:fs command:->fs_cmd' && ret=0
        if [[ $state == fs_cmd ]]; then
          _describe -t commands 'fs command' fs_commands && ret=0
        fi
        ;;
      (workspace)
        local -a ws_commands=(
          'delete:delete an object'
          'export:export a notebook'
          'get-status:get object status'
          'import:import a notebook'
          'list:list objects'
          'mkdirs:make directories'
        )
        _arguments '1:workspace command:->ws_cmd' && ret=0
        if [[ $state == ws_cmd ]]; then
          _describe -t commands 'workspace command' ws_commands && ret=0
        fi
        ;;
      (secrets)
        local -a secrets_commands=(
          'create-scope:create a secret scope'
          'delete:delete a secret'
          'delete-acl:delete a secret ACL'
          'delete-scope:delete a secret scope'
          'get-acl:get a secret ACL'
          'get-secret:get a secret'
          'list:list secrets'
          'list-acls:list secret ACLs'
          'list-scopes:list secret scopes'
          'put:write a secret'
          'put-acl:write a secret ACL'
        )
        _arguments '1:secrets command:->secrets_cmd' && ret=0
        if [[ $state == secrets_cmd ]]; then
          _describe -t commands 'secrets command' secrets_commands && ret=0
        fi
        ;;
      (auth)
        local -a auth_commands=(
          'describe:describe auth configuration'
          'env:get auth environment variables'
          'login:login to Databricks'
          'profiles:list configured profiles'
          'token:get a token'
        )
        _arguments '1:auth command:->auth_cmd' && ret=0
        if [[ $state == auth_cmd ]]; then
          _describe -t commands 'auth command' auth_commands && ret=0
        fi
        ;;
      (bundle)
        local -a bundle_commands=(
          'deploy:deploy bundle resources'
          'destroy:destroy bundle resources'
          'generate:generate bundle configuration'
          'init:initialize a new bundle'
          'run:run a resource'
          'schema:show bundle JSON schema'
          'summary:show bundle summary'
          'sync:synchronize bundle tree'
          'validate:validate bundle configuration'
        )
        _arguments '1:bundle command:->bundle_cmd' && ret=0
        if [[ $state == bundle_cmd ]]; then
          _describe -t commands 'bundle command' bundle_commands && ret=0
        fi
        ;;
      (configure)
        _arguments -s -S \
          '--host=[Databricks host]:host' \
          '--token=[personal access token]:token' \
          '--profile=[profile name]:profile' && ret=0
        ;;
    esac
    ;;
esac

return ret
