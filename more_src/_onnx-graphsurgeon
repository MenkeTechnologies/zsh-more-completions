#compdef onnx-graphsurgeon

# onnx-graphsurgeon: NVIDIA tool to surgery an ONNX graph
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'cleanup:clean up the graph'
  'sanitize:sanitize the graph'
  'extract:extract subgraph'
  'fold-constants:fold constants'
  'inspect:inspect graph'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'onnx-graphsurgeon command' commands && ret=0 ;;
esac
return ret
