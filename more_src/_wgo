#compdef wgo
# Documentation: https://github.com/bokwoon95/wgo
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for wgo - live reload for Go

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '*-file=[include files matching regex]:pattern' \
  '*-xfile=[exclude files matching regex]:pattern' \
  '*-dir=[include directories matching regex]:dir:_directories' \
  '*-xdir=[exclude directories matching regex]:dir:_directories' \
  '-cd=[change to a different directory to run the commands]:dir:_directories' \
  '*-root=[additional root directories to watch]:dir:_directories' \
  '-exit[exit when the last command exits]' \
  '-stdin[enable stdin for the last command]' \
  '-verbose[log file events]' \
  '-debounce=[how quickly to react to file events]:duration' \
  '-postpone[postpone first execution until a file is modified]' \
  '-poll=[how often to poll for file changes]:duration' \
  '*:command and arguments' && ret=0

return ret
