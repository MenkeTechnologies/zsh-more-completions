#compdef wgo
# Documentation: https://man.archlinux.org/search?q=wgo
# Reference accessed: 2026-05-16

# Zsh completion for wgo - live reload for Go

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-file=[file patterns to watch]:pattern' \
  '-xfile=[file patterns to exclude]:pattern' \
  '-dir=[directories to watch]:directory:_directories' \
  '-xdir=[directories to exclude]:directory:_directories' \
  '-verbose[verbose output]' \
  '*:command and arguments' && ret=0

return ret
