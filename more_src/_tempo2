#compdef tempo2
# Documentation: https://github.com/mattpitkin/tempo2/blob/master/documentation/1_USER_GUIDE.md
# TEMPO2: high-precision pulsar timing package.

local ret=1

_arguments -s -S \
  '-h[show help and list of installed plugins]' \
  '*-f+[parameter (.par) and timing (.tim) files]:file:_files' \
  '-newpar[write updated parameters to new.par]' \
  '-gr+[run a graphical plugin]:plugin:' \
  '-output+[run an output-type plugin]:plugin:' \
  '-fitfunc+[alternative fit routine]:func:' \
  '-select+[run a ToA filtering plugin]:plugin:' \
  '*:file:_files' && ret=0

return ret
