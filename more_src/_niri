#compdef niri

# Zsh completion for niri (scrollable-tiling Wayland compositor)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'[path to config file]:config:_files' \
  '--validate[validate config and exit]' \
  '(-s --session)'{-s,--session}'[start as a session]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'msg:send a message to the running compositor'
      'validate:validate config file'
    )
    _describe -t commands 'niri command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (msg)
        local -a actions=(
          'action:perform an action'
          'output:manage outputs'
          'workspaces:list workspaces'
          'focused-window:get focused window info'
          'version:show version'
          'event-stream:subscribe to events'
          'request-error:show request error'
        )
        _arguments '1:action:->action' '*:: :->actionargs' && ret=0
        case $state in
          (action)
            _describe -t actions 'msg action' actions && ret=0
            ;;
          (actionargs)
            case ${words[1]} in
              (action)
                _arguments '1:action:(quit power-off-monitors power-on-monitors spawn focus-column-left focus-column-right focus-window-down focus-window-up move-column-left move-column-right move-window-down move-window-up focus-workspace-down focus-workspace-up consume-window-into-column expel-window-from-column switch-preset-column-width maximize-column fullscreen-window close-window screenshot screenshot-screen screenshot-window)' && ret=0
                ;;
              (output)
                _arguments '1:action:(list focus)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
