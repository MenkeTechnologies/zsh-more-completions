#compdef niri
# Documentation: https://github.com/niri-wm/niri/blob/main/src/cli.rs
# Reference accessed: 2026-05-19
# Verified: upstream source crates/niri/src/cli.rs at the URL above.

# Zsh completion for niri (scrollable-tiling Wayland compositor).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[path to config file]:config:_files' \
  '--session[import environment to systemd/D-Bus]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'msg:communicate with the running niri instance'
      'validate:validate the config file'
      'panic:cause a panic to check backtraces'
      'completions:generate shell completions'
    )
    _describe -t commands 'niri subcommand' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (msg)
        local -a msg_subs=(
          'outputs:list connected outputs'
          'workspaces:list workspaces'
          'windows:list open windows'
          'layers:list open layer-shell surfaces'
          'keyboard-layouts:get configured keyboard layouts'
          'focused-output:print information about the focused output'
          'focused-window:print information about the focused window'
          'pick-window:pick a window with the mouse'
          'pick-color:pick a color from the screen'
          'action:perform an action'
          'output:change output configuration temporarily'
          'event-stream:start receiving events from the compositor'
          'version:print the version of the running niri instance'
          'request-error:request an error from the running niri instance'
          'overview-state:print the overview state'
          'casts:list screencasts'
        )
        _arguments \
          '(-j --json)'{-j,--json}'[format output as JSON]' \
          '1:msg subcommand:->msgcmd' \
          '*:: :->msgargs' && ret=0
        case $state in
          (msgcmd)
            _describe -t msgcommands 'msg subcommand' msg_subs && ret=0
            ;;
        esac
        ;;
      (validate)
        _arguments \
          '(-c --config)'{-c,--config}'+[path to config file]:config:_files' && ret=0
        ;;
      (completions)
        _arguments \
          '1:shell:(bash elvish fish powershell zsh nushell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
