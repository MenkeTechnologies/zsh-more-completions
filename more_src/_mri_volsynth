#compdef mri_volsynth
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_volsynth
# Synthesize a volume with various values

local ret=1

_arguments -s -S \
  '--vol[output volume path id and format]:volid:' \
  '--dim[dimensions nc nr ns nf]:nc:' \
  '--temp[volume id for template]:templateid:' \
  '--nframes[override template number of frames]:nframes:' \
  '--res[resolution dc dr ds df]:dc:' \
  '--cdircos[column direction cosines x y z]:x:' \
  '--rdircos[row direction cosines x y z]:x:' \
  '--sdircos[slice direction cosines x y z]:x:' \
  '--c_ras[center RAS c_r c_a c_s]:c_r:' \
  '--seed[random seed]:seed:' \
  '--seedfile[write seed value to file]:fname:_files' \
  '--pdf[probability distribution function]:pdf:(gaussian uniform const delta)' && ret=0

return ret
