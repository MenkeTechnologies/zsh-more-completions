#compdef robyn
# Documentation: https://robyn.tech/documentation/en/api_reference/getting_started
# Robyn - fast async Python web framework with a Rust runtime

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show Robyn version]' \
  '--dev[run in development mode with hot reload]' \
  '--fast[enable fast mode with optimal processes/workers]' \
  '--processes=[number of processes]:processes' \
  '--workers=[number of workers]:workers' \
  '--log-level=[set the log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--port=[port to bind]:port' \
  '--create[create a new project template]' \
  '--docs[open the Robyn documentation]' \
  '--open-browser[open the browser on startup]' \
  '--disable-openapi[disable the OpenAPI documentation]' \
  '--compile-rust-path=[compile Rust files in the given path]:path:_files -/' \
  '--create-rust-file=[create a new Rust file with the given name]:name' \
  '*:app file:_files -g "*.py"' && ret=0

return ret
