#compdef tsoa
# Documentation: https://man.archlinux.org/search?q=tsoa
# Reference accessed: 2026-05-16

# Zsh completion for tsoa CLI
# https://github.com/lukeautry/tsoa

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'spec:Generate OpenAPI specification'
  'routes:Generate framework-specific routes'
  'spec-and-routes:Generate both specification and routes'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tsoa command' commands && ret=0
    ;;
  (args)
    _arguments -s -S \
      '(-c --configuration)'{-c,--configuration}'[path to tsoa.json]:file:_files -g "*.json"' \
      '(-b --basePath)'{-b,--basePath}'[override basePath]:path:' \
      '(-h --host)'{-h,--host}'[override host]:host:' \
      '(-j --json)'{-j,--json}'[force JSON output (for spec)]' \
      '(-y --yaml)'{-y,--yaml}'[force YAML output (for spec)]' && ret=0
    ;;
esac

return ret
