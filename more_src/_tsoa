#compdef tsoa
# Documentation: https://github.com/lukeautry/tsoa/blob/master/packages/cli/src/cli.ts
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Verified against packages/cli/src/cli.ts (yargs definition).
# spec, routes, spec-and-routes commands; options: -c|--configuration,
# --basePath, --host, --json, --yaml (no short aliases for -b/-h/-j/-y).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'spec:Generate OpenAPI spec'
  'routes:Generate routes'
  'spec-and-routes:Generate OpenAPI spec and routes'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tsoa command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      spec|spec-and-routes)
        _arguments -s -S \
          '(-c --configuration)'{-c,--configuration}'[tsoa configuration file]:file:_files' \
          '--basePath[Base API path]:path:' \
          '--host[API host]:host:' \
          '--json[Swagger spec json format]' \
          '--yaml[Swagger spec yaml format]' && ret=0
        ;;
      routes)
        _arguments -s -S \
          '(-c --configuration)'{-c,--configuration}'[tsoa configuration file]:file:_files' \
          '--basePath[Base API path]:path:' && ret=0
        ;;
    esac
    ;;
esac

return ret
