#compdef buzz
# ============================================================================
#  _buzz — buzz: small/lightweight statically-typed scripting language
#
#  Source-direct extraction from
#    https://github.com/buzz-language/buzz/blob/main/src/main.zig
#    https://github.com/Hejsil/zig-clap (the zig-clap library)
#
#  Authored by giann (buzz-language/buzz).  1488 GH stars.  buzz is a
#  small statically-typed scripting language compiler in Zig — fits in
#  the niche between Lua and Crystal, with a JIT, REPL, formatter, and
#  WASM build target.  Sister tools: lua (in corpus), crystal (in
#  corpus), zig (in corpus), gleam (in corpus), v (in corpus).
#
#  CLI library taxonomy update: 2nd Zig CLI library — Hejsil/zig-clap.
#  Zig ecosystem now has 2 documented CLI libraries (R288 + R355
#  zig-clap) joining the multi-library leaders.  zig-clap is Jakub
#  "Hejsil" Konka's CLI parser for Zig — uniquely leverages Zig's
#  `comptime` feature to PARSE THE SPEC AT COMPILE TIME from a
#  MULTI-LINE STRING DSL formatted like a man-page Usage: section.
#
#  zig-clap distinctive features:
#    const params = comptime clap.parseParamsComptime(
#      \\-h, --help             Show help and exit
#      \\-t, --test             Run test blocks in provided script
#      \\-f, --fmt              Reformat script
#      \\--line-width <usize>   Formatter line width
#      \\-c, --check            Check script without running
#      \\-v, --version          Print version
#      \\-L, --library <str>... Add search path (repeatable)
#      \\<str>...               Script to run + args
#      \\
#    );
#    var res = try clap.parse(clap.Help, &params, clap.parsers.default,
#      args, .{ .allocator = ..., .diagnostic = &diag });
#    if (res.args.version == 1) { ... }
#    if (res.args.@"line-width") |w| { ... }   // @"id" for hyphenated
#    for (res.args.library) |path| { ... }     // ... = repeatable slice
#  CLI surface declared in a MULTI-LINE STRING using man-page-like
#  format:
#    - `-x, --long` declares short+long alias
#    - `<TYPE>` is an EXPLICIT TYPE PARAMETER (`<usize>`, `<str>`, etc.)
#      — zig-clap uses Zig's type system at parse time to enforce
#    - `...` after a type means REPEATABLE (similar to docopt)
#    - `<str>...` at the end declares the variadic positional
#    - Description follows the flag declaration on the same line
#  Parsed values are accessed via `res.args.<longname>` — for flag
#  names with HYPHENS (not valid Zig identifiers), use Zig's `@"name"`
#  syntax: `res.args.@"line-width"`.
#  Brings cross-language CLI library taxonomy variant count to 94;
#  Zig ecosystem now has 2 documented CLI libraries.
#
#  Surface (verbatim from src/main.zig `parseParamsComptime` block):
#    -h, --help                  Show help and exit
#    -t, --test                  Run test blocks in script
#    -f, --fmt                   Reformat script to stdout
#    --line-width N              Formatter line width (default 80)
#                                (only valid with -f/--fmt)
#    -c, --check                 Check script for errors (no run)
#    -v, --version               Print version and exit
#    -L, --library PATH          Add search path for external libraries
#                                (repeatable)
#    <script>                    .buzz script to run
#    <args...>                   Args to pass to the script
#
#  Dup-skipped neighbors during hunt (smaller surface or in corpus):
#    - glyph (seatedro/glyph 520 stars ASCII converter — uses zig-clap
#      but simpler 5-flag surface, would be sister demo; HOLD)
#    - ziggybox (Midstall/ziggybox 2 stars Busybox port — too narrow)
#    - wizig (wizig-org/wizig 1 star — too narrow)
#    - jmp (Drust0/jmp — narrow jump tool)
# ============================================================================

_buzz() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '(-t --test)'{-t,--test}'[run test blocks in script]' \
    '(-f --fmt)'{-f,--fmt}'[reformat script to stdout]' \
    '--line-width=[formatter line width (default 80, only with --fmt)]:line width' \
    '(-c --check)'{-c,--check}'[check script for errors without running]' \
    '(-v --version)'{-v,--version}'[print version and exit]' \
    '*'{-L,--library}'=[add search path for external libraries]:library path:_directories' \
    '*:Buzz script + args:_files -g "*.buzz"'
}

_buzz "$@"
