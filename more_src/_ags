#compdef ags
# Documentation: https://man.archlinux.org/search?q=ags
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-c --config)'{-c,--config}'=[Path to config file]:file:_files -g "*.{js,ts,mjs,cjs}(-.)"' \
  '(-b --bus)'{-b,--bus}'=[DBus session address]:address:' \
  '--inspector[Enable GTK inspector]' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '*::arguments: _default'
