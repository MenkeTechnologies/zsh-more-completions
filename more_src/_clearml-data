#compdef clearml-data
# Documentation: https://github.com/clearml/clearml
# Reference accessed: 2026-05-23
# Verified: clearml-data --help dataset management CLI.

# Zsh completion for clearml-data - ClearML dataset versioning CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'clearml-data command' \
      'create[create new dataset]' \
      'add[add files or links to dataset]' \
      'set-description[set dataset description]' \
      'sync[sync local folder with dataset]' \
      'remove[remove files or links from dataset]' \
      'upload[upload local dataset changes]' \
      'close[finalize and close dataset]' \
      'publish[publish dataset task]' \
      'delete[delete dataset]' \
      'rename[rename dataset]' \
      'move[move dataset to another project]' \
      'compare[compare two datasets]' \
      'squash[squash datasets into single version]' \
      'search[search datasets]' \
      'verify[verify dataset]' \
      'list[list datasets]' \
      'get[get dataset details]' && ret=0
    ;;
esac

return ret
