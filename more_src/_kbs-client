#compdef kbs-client
# _kbs-client — Trustee KBS test client (talks to a KBS server: get a resource, request attestation, manage admin config)
# upstream: https://github.com/confidential-containers/trustee
# Subcommands + flags from tools/kbs-client/src/main.rs Cli + Config + ConfigCommands on tip (clap).

_kbs-client() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '--url=[KBS server root URL]:url:_urls' \
        '--cert-file=[KBS HTTPS server custom root certificate (PEM)]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                config:'set/configure admin policy + resources on the KBS'
                get-resource:'fetch a confidential resource from the KBS'
                attest:'run attestation and get an attestation token'
            )
            _describe -t commands 'kbs-client subcommand' subs
            ;;
        args)
            case $line[1] in
                config)
                    _arguments \
                        '--admin-token-file=[admin bearer-token file]:file:_files' \
                        '1: :->cfg'
                    case $state in
                        cfg)
                            local -a cfgsubs=(
                                set-attestation-policy:'set the attestation verification policy'
                                set-resource-policy:'set the resource-release policy'
                                set-resource:'set a confidential resource'
                                'delete-resource':'delete a confidential resource'
                            )
                            _describe -t commands 'kbs-client config subcommand' cfgsubs
                            ;;
                    esac
                    ;;
                get-resource)
                    _arguments \
                        '--path=[KBS resource path (e.g. my_repo/resource_type/123abc)]:path:' \
                        '--tee-key-file=[custom TEE private key (RSA PEM)]:file:_files' \
                        '--attestation-token=[attestation token file]:file:_files' \
                        '1::init-data plaintext:'
                    ;;
                attest)
                    _arguments \
                        '--tee-key-file=[custom TEE private key (RSA PEM)]:file:_files' \
                        '1::init-data plaintext:'
                    ;;
            esac
            ;;
    esac
}

_kbs-client "$@"
