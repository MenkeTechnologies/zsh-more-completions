#compdef hdiff
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hdiff.1.en.html
# Compare two HDF4 files and report the differences

local ret=1

_arguments -s \
  '-V[display version of the HDF4 library and exit]' \
  '-b[verbose mode]' \
  '-g[compare global attributes only]' \
  '-s[compare SD local attributes only]' \
  '-d[compare SD data only]' \
  '-D[compare Vdata data only]' \
  '-S[print statistics]' \
  '-v+[compare SD data on the listed variable(s) only]:variables' \
  '-u+[compare vdata on the listed variable(s) only]:variables' \
  '-e+[print difference up to count for each variable]:count' \
  '-t+[print difference when greater than limit]:limit' \
  '-p+[print difference when greater than a relative limit]:relative' \
  '1:file1:_files -g "*.(hdf|h4)"' \
  '2:file2:_files -g "*.(hdf|h4)"' && ret=0

return ret
