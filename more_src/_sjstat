#compdef sjstat
# Documentation: https://www.mankier.com/1/sjstat
# Reference accessed: 2026-05-21
# Verified: sjstat(1) man page (Slurm contribs).
# Removed from prior file: -l/-c (-c kept, -l is not in upstream),
# -u/-p (not in upstream man page).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[brief help]' \
  '-c[display computing resource information only]' \
  '-r[display only running jobs]' \
  '-v[verbose output]' \
  '-man[show man page]' && ret=0

return ret
