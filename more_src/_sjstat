#compdef sjstat
# Documentation: https://man.archlinux.org/search?q=sjstat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-l[long format]' \
  '-c+[cluster]:cluster:' \
  '-u+[user]:user:_users' \
  '-p+[partition]:partition:' && ret=0

return ret
