#compdef goben
# Documentation: https://github.com/udhos/goben
# goben - TCP/UDP throughput tester written in Go

local ret=1

_arguments -s -S \
  '-hosts[comma-separated target hosts for client mode]:hosts:_hosts' \
  '-listeners[comma-separated listen addresses for server mode]:addrs' \
  '-connections[number of parallel connections to each host]:count' \
  '-defaultPort[default port for hosts without explicit port]:port' \
  '-localAddr[bind specific local address:port]:addr' \
  '-maxSpeed[bandwidth limit in Mbps (0=unlimited)]:mbps' \
  '-reportInterval[periodic throughput report interval]:duration' \
  '-totalDuration[total test duration]:duration' \
  '-tcp[enable TCP transport]' \
  '-udp[use UDP protocol instead of TCP]' \
  '-tls[enable TLS encryption]' \
  '-tlsAuthClient[verify server certificate against CA]' \
  '-tlsAuthServer[verify client certificate against CA]' \
  '-passiveClient[suppress client traffic (receive only)]' \
  '-passiveServer[suppress server traffic (receive only)]' \
  '-ca[TLS CA certificate file (PEM)]:file:_files' \
  '-cert[TLS certificate file (PEM)]:file:_files' \
  '-key[TLS private key file (PEM)]:file:_files' \
  '-tcpReadSize[TCP read buffer size in bytes]:bytes' \
  '-tcpWriteSize[TCP write buffer size in bytes]:bytes' \
  '-udpReadSize[UDP read buffer size in bytes]:bytes' \
  '-udpWriteSize[UDP write buffer size in bytes]:bytes' \
  '-export[export results (ascii,csv,yaml,png or filenames)]:spec' \
  '*::arg:_default' && ret=0

return ret
