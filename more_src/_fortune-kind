#compdef fortune-kind
# Documentation: https://github.com/cafkafk/fortune-kind
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: clap-generated (shipped with the crate)

autoload -U is-at-least

_fortune-kind() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-a+[Shows all fortunes, including unkind.]: : ' \
'--all=[Shows all fortunes, including unkind.]: : ' \
'-u+[Shows only unkind fortunes.]: : ' \
'--unkind=[Shows only unkind fortunes.]: : ' \
'-m+[Finds fortunes matching regex query.]:pattern: ' \
'--find=[Finds fortunes matching regex query.]:pattern: ' \
'-n+[Finds a fortune that is shorter than provided number.]: : ' \
'--length=[Finds a fortune that is shorter than provided number.]: : ' \
'*-s[Shows a short aporism.]' \
'*--short[Shows a short aporism.]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
}

(( $+functions[_fortune-kind_commands] )) ||
_fortune-kind_commands() {
    local commands; commands=()
    _describe -t commands 'fortune-kind commands' commands "$@"
}

if [ "$funcstack[1]" = "_fortune-kind" ]; then
    _fortune-kind "$@"
else
    compdef _fortune-kind fortune-kind
fi
