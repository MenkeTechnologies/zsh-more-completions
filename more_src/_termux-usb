#compdef termux-usb
# Documentation: https://github.com/termux/termux-api-package/blob/master/scripts/termux-usb.in
# Reference accessed: 2026-05-27
# Verified: upstream termux-api-package scripts/termux-usb.in show_usage()/getopts.


# List or access USB devices. Devices cannot be accessed directly,

_arguments \
  '-h[show this help]' \
  '-l[list available devices]' \
  '-r[show permission request dialog if necessary]' \
  '-e+[execute the specified command with a file descriptor referring to the device as an argument (unless -E argument is given)]:command:' \
  '-E[transfer file descriptor as TERMUX_USB_FD env var instead of as command line argument]'
