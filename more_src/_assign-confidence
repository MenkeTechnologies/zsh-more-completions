#compdef assign-confidence
# Documentation: https://crux.ms/commands/assign-confidence.html
# Crux assign-confidence: assign q-values to PSMs.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--estimation-method=[q-value calculation method]:method:(mix-max tdc peptide-level)' \
  '--score=[column/tag holding scores for estimation]:column' \
  '--sidak=[apply Sidak adjustment to p-values]:bool:(T F)' \
  '--top-match-in=[only include matches up to a rank (0=no limit)]:n' \
  '--combine-charge-states=[treat charge states as one peptide]:bool:(T F)' \
  '--combine-modified-peptides=[treat modified peptides as same]:bool:(T F)' \
  '--decoy-prefix=[prefix identifying decoy proteins]:prefix' \
  '--list-of-files=[treat input as file lists]:bool:(T F)' \
  '--fileroot=[prefix for output filenames]:prefix' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--overwrite=[overwrite existing files]:bool:(T F)' \
  '--parameter-file=[parameter configuration file]:file:_files' \
  '--verbosity=[verbosity level 0-60]:level' \
  '*:target input:_files' && ret=0

return ret
