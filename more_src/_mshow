#compdef mshow

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[print specific headers only]:header:' \
  '-A[print all headers]' \
  '-H[print only headers]' \
  '-L[list MIME parts]' \
  '-x[extract MIME parts]:part number:' \
  '-O[extract MIME parts to stdout]' \
  '-B[output raw body]' \
  '-R[render HTML parts as text]' \
  '-N[do not strstrp headers]' \
  '-n[do not decode MIME]' \
  '-r[raw message output]' \
  '-q[print quoted-printable decoded body]' \
  '-t[print text parts only]' \
  '-F[print filename of the message]' \
  '*:message:_files' && ret=0

return ret
