#compdef dino
# _dino — Dino: modern GTK XMPP / Jabber client (dino/dino)
# upstream: https://github.com/dino/dino
# Flags from main/src/ui/application.vala (only --version is exposed beyond the standard GTK / GApplication options).

_dino() {
    local -a args
    args=(
        '--version[show version]'
        '(- *)'{-h,--help}'[show help]'
        '--display=[X display to use]:display:'
    )
    _arguments -s -S $args
}

_dino "$@"
