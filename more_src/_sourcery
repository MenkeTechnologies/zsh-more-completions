#compdef sourcery
# Documentation: https://github.com/krzysztofzablocki/Sourcery
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--sources=[paths to source files or directories]:sources:_files' \
  '--templates=[paths to template files or directories]:templates:_files' \
  '--output=[output path]:output:_files' \
  '--config=[path to configuration file]:config file:_files' \
  '--force-parse=[file extensions to force parsing]:extensions:' \
  '--args=[custom arguments to pass to templates]:arguments:' \
  '--cacheBasePath=[base directory path for caching]:cache directory:_files -/' \
  '--buildPath=[directory for building .swifttemplate files]:build path:_files -/' \
  '--disableCache[disable parsed data caching]' \
  '--prune[remove empty generated files]' \
  '--verbose[enable detailed logging]' \
  '--quiet[suppress all logging except errors]' \
  '--watch[watch source/template folders for automatic regeneration]' \
  '--hideVersionHeader[omit Sourcery version from generated file headers]' \
  '--headerPrefix=[custom prefix for file headers]:prefix:' \
  '--version[display version]' \
  '--help[display help]' && ret=0

return ret
