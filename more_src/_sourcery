#compdef sourcery

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--sources=[paths to source files or directories]:sources:_files' \
  '--templates=[paths to template files or directories]:templates:_files' \
  '--output=[output path]:output:_files' \
  '--config=[path to configuration file]:config file:_files -g "*.yml"' \
  '--force-parse=[file extensions to force parsing]:extensions' \
  '--args=[custom arguments to pass to templates]:arguments' \
  '--cacheBasePath=[path for caching]:cache directory:_files -/' \
  '--disableCache[disable caching]' \
  '--prune[remove empty generated files]' \
  '--verbose[enable verbose logging]' \
  '--quiet[suppress all output]' \
  '--watch[watch for file changes and regenerate]' \
  '--dryrun[perform a dry run without writing output]' \
  '--version[display version]' \
  '--help[display help]' \
  '--buildPath=[path to Xcode build directory]:build path:_files -/' \
  '--xcodeproj=[path to Xcode project]:project:_files -g "*.xcodeproj"' \
  '--xcodebuildArguments=[extra xcodebuild arguments]:arguments' \
  '--headerDoc[generate header doc comment for each type]' \
  '--parseDocumentation[parse documentation comments]' && ret=0

return ret
