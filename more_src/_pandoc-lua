#compdef pandoc-lua
# Documentation: https://github.com/jgm/pandoc/blob/main/doc/pandoc-lua.md
# Run Lua scripts using pandoc's built-in Lua interpreter

local ret=1

_arguments -s -S \
  '*-e[execute statement]:statement:' \
  '*-l[require library mod into a global]:module:' \
  '-v[show version information]' \
  '-i[enter interactive mode after running script]' \
  '-E[ignore environment variables (LUA_INIT)]' \
  '-W[turn warnings on]' \
  '1:lua script:_files -g "*.lua"' \
  '*:argument:' && ret=0

return ret
