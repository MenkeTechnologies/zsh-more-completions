#compdef mdbook-pikchr
# _mdbook-pikchr — render Pikchr diagrams as SVG in mdbook (podsvirov/mdbook-pikchr)
# upstream: https://github.com/podsvirov/mdbook-pikchr
# Subcommands from src/main.rs (clap).

_mdbook-pikchr() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html)' ;;
            esac
            ;;
    esac
}

_mdbook-pikchr "$@"
