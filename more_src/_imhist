#compdef imhist
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imhist.html
# MIRIAD: plot a histogram of image data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image dataset]:in:_files' \
  'region=[region of interest]:region:' \
  'options=[plot appearance options]:options:' \
  'cutoff=[exclude values below threshold]:cutoff:' \
  'xrange=[datavalue range]:xrange:' \
  'device=[PGPLOT output device]:device:' \
  'log=[output log file]:log:_files' \
  '*:image:_files' && ret=0

return ret
