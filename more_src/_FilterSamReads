#compdef FilterSamReads
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/FilterSamReads.java
# Picard: subset a SAM/BAM/CRAM by read list, intervals, tag or JavaScript filter

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM to filter]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output filtered file]:file:_files' \
  '--FILTER=[filter to apply]:f:(includeAligned excludeAligned includeReadList excludeReadList includeJavascript includePairedIntervals includeTagValues excludeTagValues)' \
  '(-RLF --READ_LIST_FILE)'{-RLF,--READ_LIST_FILE}'=[read names to include/exclude]:file:_files' \
  '(-IL --INTERVAL_LIST)'{-IL,--INTERVAL_LIST}'=[intervals to include]:file:_files' \
  '(-T --TAG)'{-T,--TAG}'=[tag to select from input]:tag:' \
  '*'{-TV,--TAG_VALUE}'=[tag value(s) to filter by]:val:' \
  '(-SO --SORT_ORDER)'{-SO,--SORT_ORDER}'=[output sort order]:order:(coordinate queryname unsorted)' \
  '(-JS --JAVASCRIPT_FILE)'{-JS,--JAVASCRIPT_FILE}'=[JavaScript filter script]:file:_files -g "*.js"' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
