#compdef victorialogs victoria-logs vlctl
# _victorialogs — VictoriaMetrics victorialogs CLI launcher for the VictoriaLogs efficient open-source log management database alternative to Elasticsearch Loki ClickHouse providing ingestion via syslog journald JSON Loki-protocol Elasticsearch-protocol bulk-API querying via LogsQL UI on-disk index storage retention compaction (VictoriaMetrics team, Go); pflag
# upstream: https://docs.victoriametrics.com/victorialogs/

_victorialogs() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-httpListenAddr=+[host:port]:str:' \
        '-httpAuth.username=+[user]:str:' \
        '-httpAuth.password=+[password]:str:' \
        '-storageDataPath=+[dir]:dir:_files -/' \
        '-retentionPeriod=+[duration]:str:' \
        '-loggerLevel=+[l]:l:(INFO WARN ERROR FATAL PANIC)' \
        '-loggerFormat=+[f]:f:(default json)' \
        '-loggerOutput=+[o]:o:(stderr stdout)' \
        '-loggerTimezone=+[tz]:str:' \
        '-pushmetrics.url=+[url]:str:' \
        '-pushmetrics.interval=+[duration]:str:' \
        '-search.maxConcurrentRequests=+[N]:n:' \
        '-search.maxQueryDuration=+[duration]:str:' \
        '-search.maxQueryLen=+[N]:n:' \
        '-search.cacheTimestampOffset=+[duration]:str:' \
        '-syslog.listenAddr.tcp=+[host:port]:str:' \
        '-syslog.listenAddr.udp=+[host:port]:str:' \
        '-syslog.tenantID.tcp=+[id]:str:' \
        '-syslog.tenantID.udp=+[id]:str:' \
        '-journald.listenAddr=+[host:port]:str:' \
        '-elasticsearch.version=+[v]:str:' \
        '-logIngestedRows[log ingested rows]' \
        '-internalinsert.disable[disable internal insert]' \
        '-internalselect.disable[disable internal select]' \
        '-promscrape.config=+[file]:file:_files' \
        '-snapshotAuthKey=+[key]:str:' \
        '-snapshotsMaxAge=+[duration]:str:' \
        '-snapshotCreateTimeout=+[duration]:str:' \
        '*::'
}

_victorialogs "$@"
