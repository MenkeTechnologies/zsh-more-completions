#compdef phpbench

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run benchmarks'
  'report:generate report from results'
  'show:show benchmark results'
  'log:manage benchmark logs'
  'archive:archive benchmark results'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[configuration file]:config file:_files -g "*.json"' \
  '--config=[configuration file]:config file:_files -g "*.json"' \
  '-v[verbose output]' \
  '-vv[more verbose]' \
  '-vvv[debug mode]' \
  '--no-ansi[disable ANSI output]' \
  '--ansi[force ANSI output]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'phpbench command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      run)
        _arguments -s -S \
          '--filter=[filter benchmarks]:filter' \
          '--group=[run benchmarks in group]:group' \
          '--subject=[run specific subjects]:subject' \
          '--tag=[tag for this run]:tag' \
          '--ref=[reference tag]:tag' \
          '--store[store results]' \
          '--dump-file=[dump file]:file:_files' \
          '--dump=[dump format]:format:(xml)' \
          '--warmup=[number of warmup revolutions]:count' \
          '--iterations=[number of iterations]:count' \
          '--revs=[number of revolutions per iteration]:count' \
          '--retry-threshold=[retry threshold]:threshold' \
          '--sleep=[sleep between iterations in microseconds]:microseconds' \
          '--output-time-unit=[time unit]:unit:(microseconds milliseconds seconds)' \
          '--output-time-precision=[decimal precision]:precision' \
          '--output-mode=[output mode]:mode:(throughput time)' \
          '--progress=[progress reporter]:reporter:(verbose travis blinken dots none)' \
          '--php-binary=[PHP binary to use]:binary:_files' \
          '--php-config=[PHP config overrides]:config' \
          '--php-wrapper=[PHP wrapper]:wrapper' \
          '--bootstrap=[bootstrap file]:file:_files -g "*.php"' \
          '--path=[path to benchmarks]:path:_files' \
          '--report=[generate report]:report' \
          '--time-unit=[time unit]:unit:(microseconds milliseconds seconds)' \
          '--executor=[executor]:executor:(remote local)' \
          '*:benchmark file:_files -g "*.php"' && ret=0
        ;;
      report)
        _arguments -s -S \
          '--uuid=[run UUID]:uuid' \
          '--file=[results file]:file:_files' \
          '--report=[report name]:report:(default aggregate env)' \
          '--output=[output renderer]:renderer:(console delimited html markdown)' \
          '--time-unit=[time unit]:unit:(microseconds milliseconds seconds)' && ret=0
        ;;
    esac
    ;;
esac

return ret
