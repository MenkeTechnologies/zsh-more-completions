#compdef glif2svg
# Documentation: https://github.com/MFEK/glif2svg
# Convert UFO .glif files to SVG

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '(-B --no-viewbox)'{-B,--no-viewbox}"[don't put viewBox in SVG]" \
  '(-M --no-metrics)'{-M,--no-metrics}"[don't consider glif height/width, use bounds]" \
  '(-o --output)'{-o,--output}'[output file (- for stdout)]:output:_files' \
  '(-F --fontinfo)'{-F,--fontinfo}'[fontinfo.plist file for metrics]:fontinfo:_files' \
  '(-p --precision)'{-p,--precision}'[float precision (default 6)]:precision:' \
  '*:input:_files -g "*.glif"' && ret=0

return ret
