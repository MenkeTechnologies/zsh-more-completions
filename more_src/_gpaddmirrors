#compdef gpaddmirrors
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpaddmirrors.html
# Add mirror segments to a Greenplum Database system

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[display online help]' \
  '--version[display utility version information]' \
  '-a[run in quiet mode, do not prompt for information]' \
  '-b[max segments per host to operate on in parallel (1-128)]:num' \
  '-B[number of hosts to work on in parallel (1-64)]:num' \
  '-d[coordinator data directory]:dir:_files -/' \
  '-i[mirror segment configuration file]:file:_files' \
  '-l[directory for log output]:dir:_files -/' \
  '-m[file listing filesystem locations for mirror directories]:file:_files' \
  '-o[generate sample mirror configuration]:file:_files' \
  '-p[port offset for mirror ports]:offset' \
  '-s[spread mirror segments across available hosts]' \
  '-v[enable verbose logging output]' \
  '--hba-hostnames[use IP (0) or host names (1) in pg_hba.conf]:value:(0 1)' && ret=0

return ret
