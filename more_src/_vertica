#compdef vsql

_vsql() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments \
        '-h[Database server host]:host:_hosts' \
        '-p[Database server port]:port:' \
        '-U[Database user name]:username:' \
        '-w[Password]:password:' \
        '-d[Database name]:dbname:' \
        '-f[Execute commands from file]:file:_files' \
        '-c[Execute a single command string]:command:' \
        '-o[Send query results to file]:file:_files' \
        '-F[Set field separator]:separator:' \
        '-R[Set record separator]:separator:' \
        '-t[Print rows only]' \
        '-T[Set HTML table tag attributes]:attributes:' \
        '-A[Unaligned table output mode]' \
        '-H[HTML table output mode]' \
        '-x[Expanded table output]' \
        '-z[Do not read .vsqlrc]' \
        '-X[Same as -z]' \
        '-q[Quiet mode]' \
        '-e[Echo commands sent to server]' \
        '-E[Display queries generated by internal commands]' \
        '-a[Print all input lines to standard output]' \
        '-l[List available databases]' \
        '-v[Set variable]:var=value:' \
        '-V[Print version]' \
        '-B[Specify TLS mode]:mode:(disable prefer require verify-ca verify-full)' \
        '-C[Specify TLS CA certificate file]:file:_files' \
        '-i[Read input interactively even if not on a terminal]' \
        '-n[Do not read the startup file]' \
        '-1[Execute as a single transaction]' \
        '-s[Single-step mode]' \
        '-S[Single-line mode]' \
        '-P[Set printing option]:option:' \
        '-b[Ring bell on command completion]' \
        '(-? --help)'{'-?',--help}'[Show help]' \
        '*:dbname:'
}

_vsql "$@"
