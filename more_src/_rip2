#compdef rip2
# Documentation: https://github.com/MilesCranmer/rip2
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for rip2 - rm-improved v2 (rm alternative)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-d --decompose)'{-d,--decompose}'[permanently delete the graveyard]' \
  '(-s --seance)'{-s,--seance}'[print files deleted in the current directory]' \
  '(-u --unbury)'{-u,--unbury}'[restore specified files or last file if none specified]' \
  '(-i --inspect)'{-i,--inspect}'[print info about FILES before burying]' \
  '(-f --force)'{-f,--force}'[non-interactive mode]' \
  '--graveyard=[directory where deleted files rest]:dir:_directories' \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '1: :->cmds' \
  '*:file:_files' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'completions:generate shell completions file'
      'graveyard:print the graveyard path'
      'help:print help message or help for subcommands'
    )
    _describe -t commands 'rip2 command' cmds && ret=0
    ;;
esac

return ret
