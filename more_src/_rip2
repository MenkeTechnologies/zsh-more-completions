#compdef rip2

# Zsh completion for rip2 - rm-improved v2 (rm alternative)

_arguments -s -S \
  '(-d --decompose)'{-d,--decompose}'[decompose directory into its contents]' \
  '(-i --inspect)'{-i,--inspect}'[inspect the graveyard]' \
  '(-r --restore)'{-r,--restore}'[restore last deleted item]' \
  '(-s --seance)'{-s,--seance}'[list all deleted items]' \
  '(-u --unbury)'{-u,--unbury}'[restore a specific item]:path:' \
  '--graveyard[set graveyard path]:dir:_directories' \
  '--no-color[disable color output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:file:_files' && return 0
