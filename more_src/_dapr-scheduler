#compdef dapr-scheduler
# _dapr-scheduler — Dapr workflow/jobs scheduler (etcd-backed) (dapr/dapr)
# upstream: https://github.com/dapr/dapr
# Flags from cmd/scheduler/options/options.go on tip.

_dapr-scheduler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--port=[scheduler gRPC bind port]:port:' \
        '--listen-address=[scheduler gRPC bind address]:ip:' \
        '--healthz-port=[healthz bind port]:port:' \
        '--healthz-listen-address=[healthz bind address]:ip:' \
        '--override-broadcast-host-port=[override advertised host\:port]:host\:port:' \
        '--tls-enabled=[enable TLS on scheduler gRPC]:bool:(true false)' \
        '--trust-domain=[control plane trust domain]:domain:' \
        '--trust-anchors-file=[control plane trust anchors file]:file:_files' \
        '--sentry-address=[Dapr Sentry host\:port]:host\:port:' \
        '--mode=[runtime mode]:mode:(kubernetes standalone)' \
        '--id=[scheduler server ID]:id:' \
        '--etcd-embed=[embed etcd in scheduler]:bool:(true false)' \
        '*--etcd-initial-cluster=[initial etcd cluster peers]:list:' \
        '--etcd-data-dir=[etcd data directory]:dir:_files -/' \
        '--etcd-client-port=[etcd client port]:port:' \
        '--etcd-client-listen-address=[etcd client bind address]:ip:' \
        '--etcd-space-quota=[etcd space quota]:size:' \
        '--etcd-compaction-mode=[etcd compaction mode]:mode:(periodic revision)' \
        '--etcd-compaction-retention=[etcd compaction retention]:val:' \
        '--etcd-snapshot-count=[committed-txn count to trigger snapshot]:n:' \
        '--etcd-max-snapshots=[max retained etcd snapshot files (0=unlimited)]:n:' \
        '--etcd-max-wals=[max retained etcd WALs (0=unlimited)]:n:' \
        '--etcd-backend-batch-limit=[max ops before backend txn commit]:n:' \
        '--etcd-backend-batch-interval=[max backend txn batch interval]:dur:' \
        '--etcd-max-txn-ops=[max ops per etcd transaction]:n:' \
        '--log-level=[log level]:level:(debug info warn error fatal panic)' \
        '--log-as-json[log as JSON]' \
        '--enable-metrics[enable Prometheus metrics endpoint]' \
        '--metrics-port=[Prometheus metrics bind port]:port:'
}

_dapr-scheduler "$@"
