#compdef lnk
# Documentation: https://man.archlinux.org/search?q=lnk
# Reference accessed: 2026-05-16

# yarlson/lnk — git-native dotfiles (`lnk --help`)

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'lnk command' compadd -- init add remove sync status
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
