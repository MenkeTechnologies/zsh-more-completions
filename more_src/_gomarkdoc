#compdef gomarkdoc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--output[write output to file instead of stdout]:output file:_files' \
  '--template[override template for rendering]:template file:_files' \
  '--template-file[mapping of template name to file path]:name=path:_files' \
  '--header[header template]:template string:' \
  '--footer[footer template]:template string:' \
  '--format[output format]:format:(github azure plain)' \
  '--repository-url[repository URL for source links]:url:' \
  '--repository-default-branch[default branch for source links]:branch:' \
  '--repository-path[path from repository root]:path:' \
  '--tags[build tags to apply]:tags:' \
  '--check[check whether output matches current content]' \
  '--embed[use go:embed directives for output]' \
  '--verbose[print verbose logging to stderr]' \
  '(- *)--version[print version]' \
  '*:package:_files -/' && ret=0

return ret
