#compdef graph-easy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--as=[output format]:format:(ascii boxart html svg dot gdl graphml txt vcg debug)' \
  '--from=[input format]:format:(txt dot gdl graphml vcg)' \
  '(-i --input)'{-i,--input}'=[input file]:input file:_files' \
  '(-o --output)'{-o,--output}'=[output file]:output file:_files' \
  '--png[output as PNG image]' \
  '--svg[output as SVG image]' \
  '--html[output as HTML]' \
  '--ascii[output as ASCII art]' \
  '--boxart[output as box-drawing art]' \
  '--dot[output as DOT format]' \
  '--gdl[output as GDL format]' \
  '--graphml[output as GraphML format]' \
  '--txt[output as text graph]' \
  '--vcg[output as VCG format]' \
  '--debug=[debug level]:level' \
  '--timeout=[processing timeout in seconds]:seconds' \
  '--stats[show statistics about the graph]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:input file:_files' && ret=0

return ret
