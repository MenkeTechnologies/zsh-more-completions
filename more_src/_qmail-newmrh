#compdef qmail-newmrh
# _qmail-newmrh — qmail's morercpthosts builder (reads control/morercpthosts and atomically writes control/morercpthosts.cdb in cdb format for fast qmail-smtpd(8) lookups)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-newmrh.9 on tip; no flags.

_qmail-newmrh() {
    _arguments '(- *)-h[show help]'
}

_qmail-newmrh "$@"
