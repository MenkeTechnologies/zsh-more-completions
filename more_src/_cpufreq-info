#compdef cpufreq-info

# Zsh completion for cpufreq-info - CPU frequency scaling info

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --cpu)'{-c,--cpu}'[specify CPU number]:cpu number:' \
  '(-e --debug)'{-e,--debug}'[print debug info]' \
  '(-f --freq)'{-f,--freq}'[get current CPU frequency (kernel)]' \
  '(-w --hwfreq)'{-w,--hwfreq}'[get current CPU frequency (hardware)]' \
  '(-l --hwlimits)'{-l,--hwlimits}'[determine CPU frequency hardware limits]' \
  '(-d --driver)'{-d,--driver}'[determine cpufreq kernel driver used]' \
  '(-p --policy)'{-p,--policy}'[determine current cpufreq policy]' \
  '(-g --governors)'{-g,--governors}'[determine available cpufreq governors]' \
  '(-r --related-cpus)'{-r,--related-cpus}'[determine related CPUs]' \
  '(-a --affected-cpus)'{-a,--affected-cpus}'[determine affected CPUs]' \
  '(-s --stats)'{-s,--stats}'[show cpufreq statistics]' \
  '(-y --latency)'{-y,--latency}'[determine CPU frequency transition latency]' \
  '(-b --boost)'{-b,--boost}'[show boost/turbo states]' \
  '(-o --proc)'{-o,--proc}'[print old-style /proc/cpufreq info]' \
  '(-m --human)'{-m,--human}'[human-readable output]' \
  '(-n --no-rounding)'{-n,--no-rounding}'[do not round frequencies]'
