#compdef move
# Documentation: https://github.com/move-language/move/blob/main/language/tools/move-cli/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:compile modules and scripts'
  'coverage:show test coverage'
  'disassemble:disassemble Move bytecode'
  'docgen:generate documentation'
  'errmap:generate error map'
  'info:show package info'
  'new:create a new Move package'
  'prove:run Move prover'
  'sandbox:sandboxed execution commands'
  'test:run Move unit tests'
  'experimental:experimental static analysis tools'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --path)'{-p+,--path=}'[path to Move package]:directory:_directories' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'move command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (new)
        _arguments '1:package name' && ret=0
        ;;
      (sandbox)
        local -a sandbox_cmds=(
          'run:compile and execute scripts'
          'publish:compile and publish modules to storage'
          'view:inspect compiled bytecode or resources'
          'clean:remove storage and build directories'
          'exp-test:run expected-value tests'
          'doctor:validate global storage integrity'
        )
        _describe -t sandbox_cmds 'sandbox subcommand' sandbox_cmds && ret=0
        ;;
      (coverage)
        local -a cov_cmds=(
          'summary:show summary'
          'source:show source coverage'
          'bytecode:show bytecode coverage'
        )
        _describe -t cov_cmds 'coverage subcommand' cov_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
