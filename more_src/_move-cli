#compdef move

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build the package'
  'coverage:show test coverage'
  'disassemble:disassemble Move bytecode'
  'docgen:generate documentation'
  'errmap:generate error map'
  'info:show package info'
  'new:create a new Move package'
  'prove:run Move prover'
  'sandbox:sandboxed execution commands'
  'test:run Move unit tests'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p+[path to Move package]:directory:_directories' \
  '--path=[path to Move package]:directory:_directories' \
  '-d[dev mode (use dev addresses/dependencies)]' \
  '--dev[dev mode]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'move command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (new)
        _arguments '1:package name' && ret=0
        ;;
      (build)
        _arguments \
          '--fetch-deps-only[only fetch dependencies]' \
          '--skip-fetch-latest-git-deps[skip git dependency updates]' && ret=0
        ;;
      (test)
        _arguments \
          '-f+[filter test by name]:filter' \
          '--filter=[filter test by name]:filter' \
          '--list[list available tests]' \
          '-i+[number of iterations]:iterations' \
          '--instructions=[max gas instructions]:instructions' \
          '-s[report test statistics]' \
          '--statistics[report test statistics]' \
          '--threads=[number of threads]:threads' \
          '-g[collect test coverage]' \
          '--gas-limit=[gas limit per test]:limit' && ret=0
        ;;
      (prove)
        _arguments \
          '-f+[filter specs by name]:filter' \
          '--filter=[filter specs by name]:filter' \
          '-t[trace moves during verification]' \
          '--trace[trace moves during verification]' && ret=0
        ;;
      (coverage)
        local -a cov_cmds=('summary:show summary' 'source:show source coverage' 'bytecode:show bytecode coverage')
        _arguments '1:coverage command:_describe -t cov-cmds "coverage command" cov_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
