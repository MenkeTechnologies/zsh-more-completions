#compdef rbcavity
# Documentation: https://rdock.github.io/documentation/html_docs/reference-guide/programs.html
# rbcavity - rDock cavity mapping / docking site generation.

local ret=1

_arguments -s -S \
  '-r+[system definition .prm file]:file:_files' \
  '-ras[load a previously generated docking site (.as) file]' \
  '-was[write the docking site (.as) file to disk]' \
  '-d[dump cavity volumes in InsightII grid format]' \
  '-v[write receptor coordinates in PSF/CRD format]' \
  '-s[write out cavity statistics]' \
  '-l+[list receptor atoms within a given distance]:dist:' \
  '-b+[size of the cavity distance grid]:n:' \
  '*:file:_files' && ret=0

return ret
