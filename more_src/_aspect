#compdef aspect
# _aspect — Aspect Build aspect CLI drop-in for Bazel with developer experience extensions (aspect-build team, Go); cobra
# upstream: https://github.com/aspect-build/aspect-cli

_aspect() {
    local -a sub=(
        'analyze-profile:analyze build profile'
        'aquery:execute action graph query'
        'build:build targets'
        'canonicalize-flags:canonicalize startup options'
        'clean:clean output tree'
        'configure:configure rules from sources'
        'coverage:run tests with coverage'
        'cquery:execute configured graph query'
        'docs:open browser docs'
        'dump:dump bazel internal state'
        'fetch:fetch external repos'
        'help:show help'
        'info:show bazel info'
        'init:scaffold a new workspace'
        'license:show OSS license'
        'lint:run linters'
        'mod:bzlmod query'
        'mobile-install:install mobile app'
        'outputs:fetch outputs'
        'print_action:print action info'
        'query:execute target query'
        'run:run target'
        'shutdown:shutdown bazel server'
        'sync:sync repos'
        'test:run tests'
        'vendor:vendor deps'
        'version:show version'
        'completion:generate completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config name]:str:' \
        '--aspect:config=+[aspect config]:file:_files' \
        '--bazelrc=+[bazelrc file]:file:_files' \
        '--workspace=+[workspace dir]:dir:_files -/' \
        '--output_base=+[output base]:dir:_files -/' \
        '--output_user_root=+[output user root]:dir:_files -/' \
        '--ignore_all_rc_files[ignore rc files]' \
        '--noworkspace_rc[ignore workspace rc]' \
        '--nohome_rc[ignore home rc]' \
        '--nosystem_rc[ignore system rc]' \
        '--interactive=+[interactive]:b:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aspect subcommand' sub ;;
        args)
            case $words[1] in
                build|test|run|coverage|query|cquery|aquery|lint|outputs) _arguments \
                    '*:target:' ;;
                init) _arguments \
                    '--preset=+[preset]:p:(go js python rust)' \
                    '*:dir:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_aspect "$@"
