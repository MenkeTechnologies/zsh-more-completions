            shift 3 2>/dev/null || true
            local covs="$*"
            [ -z "$csv" ] || [ -z "$y" ] || [ -z "$d" ] && { error "Usage: morie causal ate <csv> <outcome> <treatment> [covariates...]"; return 1; }
