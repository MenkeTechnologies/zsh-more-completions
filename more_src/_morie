            [ -z "$file" ] || [ -z "$table" ] && { error "Usage: morie schema validate <csv> <table>"; return 1; }
            cmd_schema compare "$file" "$table"
            ;;
        *)
            error "Unknown: morie schema $subcmd"
            ;;
    esac
