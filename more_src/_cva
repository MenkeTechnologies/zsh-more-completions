#compdef cva
# Documentation: https://www.npmjs.com/package/create-vite
# Reference accessed: 2026-05-23
# Verified: npx create-vite --help (cva bin alias).

# Zsh completion for cva - create a Vite project (create-vite cva bin)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --template)'{-t,--template=}'[template name]:template:(vanilla-ts vanilla vue-ts react-ts react-compiler-ts preact-ts lit-ts svelte-ts solid-ts qwik-ts)' \
  '(-i --immediate)'{-i,--immediate}'[install dependencies and start dev]' \
  '--overwrite[remove existing files in target directory]' \
  '--interactive[force interactive mode]' \
  '--no-interactive[force non-interactive mode]' \
  ':directory:_directories' && ret=0

return ret
