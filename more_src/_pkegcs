#compdef pkegcs
# Documentation: https://pktools.nongnu.org/html/pkegcs.html
# European grid coordinate system conversion

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --image)'{-i,--image}'[input image to analyse]:file:_files' \
  '(-b --band)'{-b,--band}'[Band specific information]:value:' \
  '(-c2b --cell2bb)'{-c2b,--cell2bb}'[convert cell code to geo coordinates of boundingbox (e.g. 32-AB)]:value:' \
  '(-c2m --cell2mid)'{-c2m,--cell2mid}'[convert cell code to centre in geo coordinates (e.g. 32-AB)]:value:' \
  '(-g2c --geo2cell)'{-g2c,--geo2cell}'[get cell code for coordinates in x_opt and y_opt given the resolution]:value:' \
  '(-ref --ref)'{-ref,--ref}'[get reference pixel (lower left corner of centre of gravity pixel)]:value:' \
  '(-m --mask)'{-m,--mask}'[mask value(s) for no data to calculate reference pixel in image]:file:_files' \
  '(-dx --dx)'{-dx,--dx}'[resolution]:value:' \
  '(-x --x)'{-x,--x}'[x coordinate in epsg\:3035]:value:' \
  '(-y --y)'{-y,--y}'[y coordinate in epsg\:3035]:value:' \
  '*:file:_files' && ret=0

return ret
