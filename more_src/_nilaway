#compdef nilaway

_arguments -s \
  '-include-pkgs=[comma-separated package prefixes]:prefixes:' \
  '-json[output JSON]' \
  '-pretty-print[pretty-print JSON]' \
  '-V[print version and exit]' \
  '-flags[print analyzer flags]' \
  '-fix[apply suggested fixes]' \
  '-c=[context lines around diagnostic]:n:' \
  '-cpuprofile=[write CPU profile]:file:_files' \
  '-debug=[debug categories]:cats:' \
  '-memprofile=[write mem profile]:file:_files' \
  '-trace=[write trace]:file:_files' \
  '*:package:'
