#compdef nilaway
# Documentation: https://github.com/uber-go/nilaway
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# uber-go/nilaway: nil-safety static analyzer for Go.
# Built on golang.org/x/tools/go/analysis; ships standard analyzer flags
# plus NilAway-specific ones documented in the project README and
# docs/configurations.md.

_arguments -s \
  '-include-pkgs=[comma-separated package prefixes to analyze]:prefixes:' \
  '-json[output diagnostics as JSON]' \
  '-pretty-print[pretty-print JSON output]' \
  '-V=[print version and exit]:format:(full short)' \
  '-flags[print analyzer flags as JSON]' \
  '-fix[apply suggested fixes]' \
  '-c=[context lines around diagnostic]:n:' \
  '-cpuprofile=[write CPU profile]:file:_files' \
  '-debug=[debug flags]:flags:' \
  '-memprofile=[write memory profile]:file:_files' \
  '-trace=[write execution trace]:file:_files' \
  '*:package:'
