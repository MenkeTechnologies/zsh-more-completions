#compdef radvd-helper
# _radvd-helper — radvd helper script (small wrapper used by NetworkManager/dispatcher.d hooks to start, stop, reload or test the radvd(8) IPv6 router-advertisement daemon when a managed interface comes up/down; subcommands: start, stop, restart, reload, check, status; -c config file, -v verbose, -V version, -h help)
# upstream: https://github.com/reubenhwk/radvd
# Common flag shape from distro radvd helper scripts on tip.

_radvd-helper() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '-v[verbose]' \
        '1::command:(start stop restart reload check status)'
}

_radvd-helper "$@"
