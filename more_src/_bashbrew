#compdef bashbrew
# Documentation: https://github.com/docker-library/bashbrew
# Source: https://github.com/docker-library/bashbrew/blob/main/cmd/bashbrew/main.go
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _bb_cmds
_bb_cmds=(
    'list:list repo:tag combinations for a given repo'
    'ls:alias for list'
    'build:build (and tag) repo:tag combinations for a given repo'
    'tag:tag repo:tag into a namespace'
    'push:push namespace/repo:tag'
    'put-shared:update shared tags in the registry'
    'children:print the repos built FROM a given repo'
    'offspring:alias for children'
    'descendants:alias for children'
    'progeny:alias for children'
    'parents:print the repos this repo is FROM'
    'ancestors:alias for parents'
    'progenitors:alias for parents'
    'cat:print manifest contents for repo or repo:tag'
    'from:print FROM for repo:tag'
    'fetch:ensure Git contents are local'
    'context:Dockerfile-filtered git archive'
    'remote:query registries for bashbrew-related data'
    'help:show help'
)

_arguments -C \
    '--debug[enable more output]' \
    '--no-sort[do not apply any sorting]' \
    '--arch=[current platform architecture]:arch:_default' \
    '--namespace=[repo namespace to act upon]:namespace:_default' \
    '*--constraint=[build constraints]:constraint:_default' \
    '--exclusive-constraints[skip entries without Constraints]' \
    '*--arch-namespace=[arch=namespace mapping]:mapping:_default' \
    '--config=[config dir]:dir:_files -/' \
    '--library=[official-images library dir]:dir:_files -/' \
    '--cache=[cache dir]:dir:_files -/' \
    '(- *)'{-h,--help,-\?}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'bashbrew command' _bb_cmds && ret=0
        ;;
    args)
        case $line[1] in
            list|ls)
                _arguments -s -S \
                    '--all[act upon all repos listed in --library]' \
                    '(--uniq --unique)'{--uniq,--unique}'[only act upon the first tag of each entry]' \
                    '--apply-constraints[apply all Constraints]' \
                    '--arch-filter[apply only Architectures constraint]' \
                    '--build-order[sort by build order (topsort)]' \
                    '--repos[list only repos]' \
                    '*:repo:_default' && ret=0
                ;;
            build)
                _arguments -s -S \
                    '--all[act upon all repos]' \
                    '(--uniq --unique)'{--uniq,--unique}'[only first tag]' \
                    '--pull=[pull FROM before building]:mode:(always missing never)' \
                    '--dry-run[plan only]' \
                    '*:repo:_default' && ret=0
                ;;
            tag)
                _arguments -s -S \
                    '--all[act upon all repos]' \
                    '(--uniq --unique)'{--uniq,--unique}'[only first tag]' \
                    '--dry-run[plan only]' \
                    '--target-namespace=[target namespace]:namespace:_default' \
                    '*:repo:_default' && ret=0
                ;;
            push)
                _arguments -s -S \
                    '--all[act upon all repos]' \
                    '(--uniq --unique)'{--uniq,--unique}'[only first tag]' \
                    '--dry-run[plan only]' \
                    '--force[skip no-op heuristics]' \
                    '--target-namespace=[target namespace]:namespace:_default' \
                    '*:repo:_default' && ret=0
                ;;
            put-shared)
                _arguments -s -S \
                    '--all[act upon all repos]' \
                    '--dry-run[plan only]' \
                    '--force[force push]' \
                    '--target-namespace=[target namespace]:namespace:_default' \
                    '--single-arch[only act on current architecture]' \
                    '*:repo:_default' && ret=0
                ;;
            children|offspring|descendants|progeny|parents|ancestors|progenitors)
                _arguments -s -S \
                    '--apply-constraints[apply all Constraints]' \
                    '--arch-filter[apply only Architectures constraint]' \
                    '--depth=[max traversal levels (0=unlimited)]:n:_default' \
                    '(--uniq --unique)'{--uniq,--unique}'[only first tag]' \
                    '*:repo:_default' && ret=0
                ;;
            cat)
                _arguments -s -S \
                    '--all[act upon all repos]' \
                    '(-f --format)'{-f+,--format=}'[output format (text/template)]:fmt:_default' \
                    '(-F --format-file)'{-F+,--format-file=}'[format from file]:file:_files' \
                    '--build-order[sort by build order]' \
                    '*:repo:_default' && ret=0
                ;;
            from|fetch)
                _arguments -s -S \
                    '--all[act upon all repos]' \
                    '(--uniq --unique)'{--uniq,--unique}'[only first tag]' \
                    '--apply-constraints[apply all Constraints]' \
                    '--arch-filter[apply only Architectures constraint]' \
                    '*:repo:_default' && ret=0
                ;;
            context)
                _arguments -s -S \
                    '--sha256[print sha256 instead of raw tar]' \
                    '*:repo:_default' && ret=0
                ;;
            remote)
                _arguments -s -S \
                    '1:subcommand:(arches)' \
                    '*::arches options:->remote-arches' && ret=0
                case $state in
                    remote-arches)
                        _arguments -s -S \
                            '--json[output JSON]' \
                            '*:image:_default' && ret=0
                        ;;
                esac
                ;;
        esac
        ;;
esac

return ret
