#compdef virt-make-fs
# Documentation: https://libguestfs.org/virt-make-fs.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)--help[show help]' \
  '--blocksize=[sector size]:size:(512 4096)' \
  '--floppy[create virtual floppy]' \
  '(-s --size)'{-s,--size=}'[image size]:size:' \
  '(-F --format)'{-F,--format=}'[output format]:fmt:(raw qcow2 vmdk vdi)' \
  '(-t --type)'{-t,--type=}'[filesystem type]:fs:(ext2 ext3 ext4 xfs btrfs vfat)' \
  '--label=[filesystem label]:label:' \
  '--partition=[partition table type]:type:(mbr gpt)' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(- *)'{-V,--version}'[show version]' \
  '-x[enable libguestfs trace]' \
  ':input:_files' \
  ':output:_files'
