#compdef fastq_quality_filter
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastq_quality_filter.1.en.html
# FASTX-Toolkit: filter FASTQ reads by quality score

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-q+[minimum quality score to keep]:quality' \
  '-p+[minimum percent of bases that must have -q quality]:percent' \
  '-Q+[FASTQ ASCII offset (default 33)]:offset' \
  '-v[verbose: report number of sequences]' \
  '-z[compress output with GZIP]' \
  '-i+[FASTA/Q input file (default STDIN)]:input file:_files' \
  '-o+[FASTA/Q output file (default STDOUT)]:output file:_files' && ret=0

return ret
