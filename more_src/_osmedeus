#compdef osmedeus

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[Show help]' \
  '1:command:->cmds' \
  '*::arg:->args' \
  && ret=0

case $state in
  cmds)
    local -a commands=(
      'scan:Run a scan against target'
      'provider:Cloud provider setup and management'
      'health:Check health of components'
      'utils:Utility functions'
      'server:Run the API server'
      'report:Generate reports'
    )
    _describe -t commands 'osmedeus command' commands && ret=0
    ;;
  args)
    case $line[1] in
      scan)
        _arguments \
          '(-t --target)'{-t,--target}'[Target to scan]:target:' \
          '(-f --flow)'{-f,--flow}'[Flow to run]:flow:' \
          '(-m --module)'{-m,--module}'[Module to run]:module:' \
          '--params[Extra parameters]:params:' \
          '--timeout[Timeout in seconds]:seconds:' \
          '--threads[Number of threads]:number:' \
          '--chunk[Chunk size for targets]:size:' \
          '--debug[Enable debug mode]' \
          '--resume[Resume a previous scan]' \
          '--report[Generate report after scan]' \
          && ret=0
        ;;
      provider)
        _arguments \
          '--debug[Enable debug mode]' \
          && ret=0
        ;;
      health)
        _arguments \
          '--debug[Enable debug mode]' \
          && ret=0
        ;;
      server)
        _arguments \
          '--debug[Enable debug mode]' \
          && ret=0
        ;;
      report)
        _arguments \
          '(-t --target)'{-t,--target}'[Target for report]:target:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
