#compdef scil_tractogram_math
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_tractogram_math.html
# Perform set operations on tractograms

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --precision)'{-p,--precision}'+[precision used to compare streamlines]:decimals' \
  '(-r --robust)'{-r,--robust}'[use version robust to small translation/rotation]' \
  '--bidirectional[allow matching streamlines with flipped orientations]' \
  '(-n --no_metadata)'{-n,--no_metadata}'[strip the streamline metadata from the output]' \
  '--fake_metadata[skip metadata verification, create fake metadata if missing]' \
  '(-s --save_indices)'{-s,--save_indices}'+[save the streamline indices to json file]:file:_files' \
  '--save_empty[save all results, even if tractogram is empty]' \
  '--no_bbox_check[ignore validity of the bounding box during loading/saving]' \
  '--reference=[reference anatomy for tck/vtk/fib/dpy]:nifti:_files -g "*.nii *.nii.gz"' \
  '--indent=[indent for json pretty print]:indent' \
  '--sort_keys[sort keys in output json]' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[force overwriting of the output files]' \
  '1:operation:(difference intersection union concatenate lazy_concatenate)' \
  '*:files:_files' && ret=0

return ret
