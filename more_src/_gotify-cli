#compdef gotify-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[Show help]' \
  '(- *)--version[Show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'push:Push a notification'
      'init:Initialize configuration'
      'config:Show configuration'
      'version:Show version'
      'help:Show help for a command'
    )
    _describe -t commands 'gotify-cli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      push)
        _arguments -s -S \
          '--title[Notification title]:title' \
          '--priority[Notification priority]:priority' \
          '--token[Application token]:token' \
          '--url[Gotify server URL]:url' \
          '--quiet[Do not output anything]' \
          '--help[Show help]' \
          '*:message' && ret=0
        ;;
      init)
        _arguments -s -S \
          '--url[Gotify server URL]:url' \
          '--token[Application token]:token' \
          '--help[Show help]' && ret=0
        ;;
      config)
        _arguments -s -S \
          '--help[Show help]' && ret=0
        ;;
      version)
        _arguments -s -S \
          '--help[Show help]' && ret=0
        ;;
      help)
        local -a commands=(
          'push:Push a notification'
          'init:Initialize configuration'
          'config:Show configuration'
          'version:Show version'
        )
        _describe -t commands 'gotify-cli command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
