#compdef gnubands
# Documentation: https://docs.siesta-project.org/projects/siesta/en/latest/tutorials/basic/analysis-tools/index.html
# SIESTA convert .bands output into Gnuplot format

local ret=1

_arguments -s -S \
  '-h[print help]' \
  '-G[print GNUplot commands for correct labels to stderr]' \
  '-s[only plot selected spin bands [1,nspin]]:spin:' \
  '-F[shift energy to Fermi level]' \
  '-b[first band to write]:band:' \
  '-B[last band to write]:band:' \
  '-e[minimum energy to write]:emin:' \
  '-E[maximum energy to write]:emax:' \
  '-o[output file instead of piping]:file:_files' \
  '*:bands file:_files' && ret=0

return ret
