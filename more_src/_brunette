#compdef brunette
# Opinionated Python code formatter (black fork)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-l --line-length)'{-l,--line-length}'[line length]:length:' \
  '(-t --target-version)'{-t,--target-version}'[target Python version]:version:(py27 py33 py34 py35 py36 py37 py38 py39 py310 py311 py312)' \
  '--check[check if files would be reformatted]' \
  '--diff[show diff of changes]' \
  '--color[show colored diff]' \
  '--no-color[disable colored diff]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '--single-quotes[use single quotes]' \
  '--config[config file]:file:_files' \
  '--include[regex for files to include]:regex:' \
  '--exclude[regex for files to exclude]:regex:' \
  '--force-exclude[regex for files to force exclude]:regex:' \
  '*:file:_files' \
  && return 0
