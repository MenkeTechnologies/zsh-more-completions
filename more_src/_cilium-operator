#compdef cilium-operator
# Documentation: https://man.archlinux.org/search?q=cilium-operator
# Reference accessed: 2026-05-16

# cilium-operator: cluster-wide Cilium operator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--cluster-name=[cluster name]:name:' \
  '--cluster-id=[cluster id]:n:' \
  '--debug[enable debug]' \
  '--enable-metrics[enable metrics]' \
  '--operator-prometheus-serve-addr=[metrics addr]:addr:' \
  '--operator-api-serve-addr=[operator API addr]:addr:' \
  '--leader-election-lease-duration=[leader election lease duration]:duration:' \
  '--leader-election-renew-deadline=[leader election renew deadline]:duration:' \
  '--leader-election-retry-period=[leader election retry period]:duration:' \
  '--enable-leader-election[enable leader election]' \
  '--identity-allocation-mode=[identity allocation mode]:mode:(kvstore crd)' \
  '--identity-gc-interval=[identity GC interval]:duration:' \
  '--identity-heartbeat-timeout=[identity heartbeat timeout]:duration:' \
  '--cnp-status-update-interval=[cnp status update interval]:duration:' \
  '--ces-write-qps-limit=[CES write QPS limit]:n:' \
  '--ces-write-qps-burst=[CES write QPS burst]:n:' \
  '--ces-slice-mode=[CES slice mode]:mode:(cesSliceModeIdentity cesSliceModeFCFS)' \
  '--enable-ipv4=[enable IPv4]:bool:(true false)' \
  '--enable-ipv6=[enable IPv6]:bool:(true false)' \
  '--ipam=[IPAM mode]:mode:(cluster-pool kubernetes azure aws gke crd)' \
  '--cluster-pool-ipv4-cidr=[cluster pool IPv4 CIDR]:cidr:' \
  '--cluster-pool-ipv4-mask-size=[cluster pool IPv4 mask size]:n:' \
  '--cluster-pool-ipv6-cidr=[cluster pool IPv6 CIDR]:cidr:' \
  '--cluster-pool-ipv6-mask-size=[cluster pool IPv6 mask size]:n:' \
  '--cnp-node-status-gc-interval=[cnp node status gc interval]:duration:' \
  '--k8s-namespace=[k8s namespace]:ns:' \
  '--k8s-api-server=[k8s API URL]:url:' \
  '--k8s-kubeconfig-path=[kubeconfig path]:file:_files' \
  '*::cilium-operator args:_files' && ret=0
return ret
