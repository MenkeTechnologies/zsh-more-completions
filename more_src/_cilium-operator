#compdef cilium-operator
# Documentation: https://docs.cilium.io/en/stable/cmdref/cilium-operator/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cilium-operator: cluster-wide Cilium operator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--cluster-name=[cluster name]:name:' \
  '--cluster-id=[cluster id]:n:' \
  '--debug[enable debug]' \
  '--enable-metrics[enable metrics]' \
  '--enable-gops[enable gops debug server]' \
  '--operator-pprof[enable pprof on operator]' \
  '--operator-prometheus-serve-addr=[metrics addr]:addr:' \
  '--operator-api-serve-addr=[operator API addr]:addr:' \
  '--leader-election-lease-duration=[leader election lease duration]:duration:' \
  '--leader-election-renew-deadline=[leader election renew deadline]:duration:' \
  '--leader-election-retry-period=[leader election retry period]:duration:' \
  '--enable-leader-election[enable leader election]' \
  '--identity-allocation-mode=[identity allocation mode]:mode:(kvstore crd)' \
  '--identity-gc-interval=[identity GC interval]:duration:' \
  '--identity-gc-rate-interval=[identity GC rate interval]:duration:' \
  '--identity-heartbeat-timeout=[identity heartbeat timeout]:duration:' \
  '--identity-management-mode=[identity management mode]:mode:' \
  '--cnp-status-update-interval=[cnp status update interval]:duration:' \
  '--cnp-node-status-gc-interval=[cnp node status gc interval]:duration:' \
  '--ces-write-qps-limit=[CES write QPS limit]:n:' \
  '--ces-write-qps-burst=[CES write QPS burst]:n:' \
  '--ces-slice-mode=[CES slice mode]:mode:(cesSliceModeIdentity cesSliceModeFCFS)' \
  '--enable-ipv4=[enable IPv4]:bool:(true false)' \
  '--enable-ipv6=[enable IPv6]:bool:(true false)' \
  '--enable-l7-proxy=[enable L7 proxy]:bool:(true false)' \
  '--enable-policy=[enable policy]:mode:(default always never)' \
  '--enable-ingress-controller=[enable ingress controller]:bool:(true false)' \
  '--enable-gateway-api-alpn=[enable Gateway API ALPN]:bool:(true false)' \
  '--gateway-api-secrets-namespace=[Gateway API secrets namespace]:ns:' \
  '--ingress-secrets-namespace=[Ingress secrets namespace]:ns:' \
  '--mesh-auth-enabled=[mesh auth enabled]:bool:(true false)' \
  '--validate-network-policy=[validate network policy]:bool:(true false)' \
  '--ipam=[IPAM mode]:mode:(cluster-pool kubernetes azure aws gke crd alibaba-cloud)' \
  '--cluster-pool-ipv4-cidr=[cluster pool IPv4 CIDR]:cidr:' \
  '--cluster-pool-ipv4-mask-size=[cluster pool IPv4 mask size]:n:' \
  '--cluster-pool-ipv6-cidr=[cluster pool IPv6 CIDR]:cidr:' \
  '--cluster-pool-ipv6-mask-size=[cluster pool IPv6 mask size]:n:' \
  '--clustermesh-config=[clustermesh config dir]:dir:_files -/' \
  '--clustermesh-enable-endpoint-sync=[enable clustermesh endpoint sync]:bool:(true false)' \
  '--clustermesh-enable-mcs-api=[enable clustermesh MCS API]:bool:(true false)' \
  '--max-connected-clusters=[max connected clusters]:n:' \
  '--alibaba-cloud-vpc-id=[Alibaba Cloud VPC ID]:id:' \
  '--aws-enable-prefix-delegation[enable AWS prefix delegation]' \
  '--aws-max-results-per-call=[AWS max results per call]:n:' \
  '--aws-release-excess-ips[release excess AWS IPs]' \
  '--azure-resource-group=[Azure resource group]:group:' \
  '--azure-subscription-id=[Azure subscription ID]:id:' \
  '--enable-k8s=[enable Kubernetes clientset]:bool:(true false)' \
  '--k8s-namespace=[k8s namespace]:ns:' \
  '--k8s-api-server-urls=[k8s API URLs]:url:' \
  '--k8s-kubeconfig-path=[kubeconfig path]:file:_files' \
  '*::cilium-operator args:_files' && ret=0
return ret
