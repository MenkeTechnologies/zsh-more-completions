#compdef liftctl
# Documentation: https://github.com/liftbridge-io/liftbridge-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# liftctl: command line client for Liftbridge
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create a stream'
  'c:create a stream'
  'subscribe:subscribe to a stream'
  's:subscribe to a stream'
  'subscribe-activity-stream:subscribe to the activity stream'
  'sas:subscribe to the activity stream'
  'publish:publish a message'
  'p:publish a message'
  'set-readonly:mark stream/partitions readonly'
  'r:mark stream/partitions readonly'
  'pause:pause stream partitions'
  'u:pause stream partitions'
  'delete:delete a stream'
  'd:delete a stream'
  'metadata:fetch cluster metadata'
  'm:fetch cluster metadata'
  'partition-metadata:fetch partition metadata'
  't:fetch partition metadata'
  'set-cursor:set a cursor offset'
  'e:set a cursor offset'
  'fetch-cursor:fetch cursor offset'
  'f:fetch cursor offset'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --address)'{-a+,--address=}'[Liftbridge address]:host:_hosts' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'liftctl command' commands && ret=0 ;;
  args)
    _arguments \
      '--stream=[stream name]:stream:' \
      '--subject=[NATS subject]:subject:' \
      '--create-stream[create stream if missing]' \
      '--message=[message payload]:message:' \
      '--ack-policy=[ack policy]:policy:(none leader all)' \
      '--readonly=[readonly true/false]:bool:(true false)' \
      '--partitions=[partition list]:partitions:' \
      '--resume-all[resume all partitions]' \
      '--partition=[partition id]:partition:' \
      '--cursor-id=[cursor id]:id:' \
      '--offset=[cursor offset]:offset:' && ret=0
    ;;
esac
return ret
