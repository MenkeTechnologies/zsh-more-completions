#compdef liftctl

# liftctl: command line client for Liftbridge
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create-stream:create a stream'
  'delete-stream:delete a stream'
  'pause-stream:pause a stream'
  'resume-stream:resume a stream'
  'publish:publish a message'
  'subscribe:subscribe to a stream'
  'fetch-metadata:fetch cluster metadata'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--address=[Liftbridge address]:host:_hosts' \
  '-a[Liftbridge address]:host:_hosts' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'liftctl command' commands && ret=0 ;;
esac
return ret
