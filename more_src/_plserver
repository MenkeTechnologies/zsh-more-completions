#compdef plserver
# Documentation: https://plplot.sourceforge.net/docbook-manual/plplot-html-5.15.0/arguments.html
# plserver - PLplot Tcl/Tk graphics server (standard PLplot arguments)

local ret=1

_arguments -s \
  '-h[print out help message]' \
  '-v[print out the PLplot library version number]' \
  '-verbose[be more verbose than usual]' \
  '-debug[print debugging info (implies -verbose)]' \
  '-dev[output device name]:device' \
  '-o[output filename]:file:_files' \
  '-display[X server to contact]:display' \
  '-px[plots per page in x]:number' \
  '-py[plots per page in y]:number' \
  '-geometry[window size/position (e.g. 400x300-100+200)]:geometry' \
  '-wplt[relative coordinates of window into plot (xl,yl,xr,yr)]:coords' \
  '-mar[margin space in relative coordinates]:margin' \
  '-a[page aspect ratio]:aspect' \
  '-jx[page justification in x]:justx' \
  '-jy[page justification in y]:justy' \
  '-ori[plot orientation (0,1,2,3=landscape,portrait,seascape,upside-down)]:orient' \
  '-freeaspect[allow aspect ratio to adjust to orientation]' \
  '-portrait[sets portrait mode (orientation and aspect ratio)]' \
  '-width[sets pen width (0 <= width)]:width' \
  '-bg[background color (FF0000=opaque red, 0000FF_0.1=blue alpha 0.1)]:color' \
  '-ncol0[number of colors to allocate in cmap 0]:n' \
  '-ncol1[number of colors to allocate in cmap 1]:n' \
  '-fam[create a family of output files]' \
  '-fsiz[output family file size (e.g. 100K)]:size' \
  '-fbeg[first family member number on output]:number' \
  '-finc[increment between family members]:number' \
  '-fflen[minimum field width for number in family name]:length' \
  '-nopixmap[do not use pixmaps in X drivers]' \
  '-db[double buffer X window output]' \
  '-np[no pause between pages]' \
  '-dpi[resolution in dots per inch]:dpi' \
  '-compression[compression level (for supporting devices)]:num' \
  '-cmap0[color map 0 color table file]:file:_files' \
  '-cmap1[color map 1 color table file]:file:_files' \
  '-locale[use LC_NUMERIC locale environment for decimal point]' \
  '-eofill[use even-odd fill rule for self-intersecting boundaries]' \
  '-drvopt[driver-specific options (option[=value][,...])]:option' \
  '-mfo[write plot to this PLplot metafile]:file:_files' \
  '-mfi[read plot from this PLplot metafile]:file:_files' \
  '*:metafile:_files' && ret=0

return ret
