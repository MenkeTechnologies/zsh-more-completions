#compdef bazel-cli2 bazelisk2
# _bazel-cli2 — Google Bazel bazel-cli2 CLI command-line frontend wrapping the Bazel open-source build automation tool from Google originally Blaze internal Google build system written in Java fast scalable multi-language extensible reproducible build and test tool similar to Make Maven Gradle Apache-Ant build query test run analyze-profile aquery canonicalize-flags clean coverage cquery dump fetch help info license mobile-install mod modquery print_action shutdown sync vendor version starlark Skylark BUILD WORKSPACE bzlmod BzlMod Bazelisk MODULE.bazel rules_go rules_python rules_nodejs rules_jvm rules_cc (Google Bazel team Han-Wen Nienhuys, Java/Starlark); custom argparse
# upstream: https://bazel.build/

_bazel-cli2() {
    local -a sub=(
        'analyze-profile:analyze a profile'
        'aquery:execute an action graph query'
        'build:build targets'
        'canonicalize-flags:canonicalize flags'
        'clean:clean output base'
        'coverage:run tests with coverage'
        'cquery:configured query'
        'dump:dump internal state'
        'fetch:fetch external deps'
        'help:show help'
        'info:show runtime info'
        'license:show license'
        'mobile-install:install on device'
        'mod:bzlmod operations'
        'modquery:bzlmod query'
        'print_action:print action'
        'query:execute a query'
        'run:run a target'
        'shutdown:shutdown the server'
        'sync:sync repos'
        'test:run tests'
        'vendor:vendor external deps'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--bazelrc=+[file]:file:_files -g ".bazelrc *.bazelrc"' \
        '*--bazelrc=+[file]:file:_files -g ".bazelrc *.bazelrc"' \
        '--nohome_rc[no home rc]' \
        '--nosystem_rc[no system rc]' \
        '--noworkspace_rc[no workspace rc]' \
        '--output_user_root=+[dir]:dir:_files -/' \
        '--output_base=+[dir]:dir:_files -/' \
        '--server_javabase=+[path]:_files' \
        '--host_jvm_args=+[arg]:str:' \
        '*--host_jvm_args=+[arg]:str:' \
        '--host_jvm_debug[host JVM debug]' \
        '--host_jvm_profile=+[name]:str:' \
        '--max_idle_secs=+[N]:n:' \
        '--shutdown_on_low_sys_mem[shutdown on low mem]' \
        '--batch[batch mode]' \
        '--client_debug[client debug]' \
        '--block_for_lock[block for lock]' \
        '--client_cwd=+[dir]:dir:_files -/' \
        '--keep_state_after_build[keep state]' \
        '--server_jvm_out=+[file]:file:_files' \
        '--watchfs[watch FS]' \
        '--write_command_log[write command log]' \
        '--config=+[name]:str:' \
        '*--config=+[name]:str:' \
        '-c+[compilation mode]:m:(fastbuild opt dbg)' \
        '--compilation_mode=+[m]:m:(fastbuild opt dbg)' \
        '-k[keep going]' \
        '--keep_going[keep going]' \
        '-j+[jobs]:n:' \
        '--jobs=+[N]:n:' \
        '--loading_phase_threads=+[N]:n:' \
        '--logging=+[N]:n:' \
        '--noenable_bzlmod[disable Bzlmod]' \
        '--enable_bzlmod[enable Bzlmod]' \
        '--show_progress[show progress]' \
        '--noprogress[no progress]' \
        '--show_timestamps[show timestamps]' \
        '--curses=+[c]:c:(auto yes no)' \
        '--color=+[c]:c:(auto yes no)' \
        '--terminal_columns=+[N]:n:' \
        '--isatty[isatty]' \
        '--ui_event_filters=+[filters]:str:' \
        '--symlink_prefix=+[prefix]:str:' \
        '--experimental_ui_max_stdouterr_bytes=+[N]:n:' \
        '--build_tests_only[build tests only]' \
        '--cache_test_results=+[v]:v:(yes no auto)' \
        '--test_filter=+[regex]:str:' \
        '--test_output=+[m]:m:(summary errors all streamed)' \
        '--test_arg=+[arg]:str:' \
        '*--test_arg=+[arg]:str:' \
        '--test_env=+[k=v]:str:' \
        '*--test_env=+[k=v]:str:' \
        '--test_timeout=+[sec]:str:' \
        '--test_sharding_strategy=+[s]:s:(explicit disabled forced)' \
        '--test_strategy=+[s]:str:' \
        '--test_tag_filters=+[filter]:str:' \
        '--runs_per_test=+[N]:n:' \
        '--copt=+[opt]:str:' \
        '*--copt=+[opt]:str:' \
        '--cxxopt=+[opt]:str:' \
        '*--cxxopt=+[opt]:str:' \
        '--linkopt=+[opt]:str:' \
        '*--linkopt=+[opt]:str:' \
        '--platforms=+[label]:str:' \
        '--host_platform=+[label]:str:' \
        '--cpu=+[name]:str:' \
        '--remote_cache=+[url]:str:' \
        '--remote_executor=+[url]:str:' \
        '--disk_cache=+[dir]:dir:_files -/' \
        '--repository_cache=+[dir]:dir:_files -/' \
        '--noremote_local_fallback[no remote local fallback]' \
        '--repo_env=+[k=v]:str:' \
        '*--repo_env=+[k=v]:str:' \
        '--action_env=+[k=v]:str:' \
        '*--action_env=+[k=v]:str:' \
        '--define=+[k=v]:str:' \
        '*--define=+[k=v]:str:' \
        '--starlark_cpu_profile=+[file]:file:_files' \
        '--profile=+[file]:file:_files' \
        '--use_singular_pseudo_action_for_test[singular pseudo action]' \
        '--symlink_prefix=+[prefix]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bazel subcommand' sub ;;
        args)
            case $words[1] in
                build|test|run|query|cquery|aquery|coverage|clean|fetch|vendor|sync|info|dump|mobile-install|modquery|mod|print_action) _arguments '*:target:' ;;
            esac
            ;;
    esac
}

_bazel-cli2 "$@"
