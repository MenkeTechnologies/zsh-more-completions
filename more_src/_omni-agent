#compdef omni-agent
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# omni-agent: SideroLabs Omni agent (Talos Kubernetes management)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config-file=[config file]:file:_files' \
  '--account-id=[account id]:id:' \
  '--service-account=[service account file]:file:_files' \
  '--cluster-name=[cluster name]:name:' \
  '--api-endpoint=[API endpoint]:url:' \
  '--insecure-skip-verify[skip TLS verify]' \
  '*::omni-agent args:_files' && ret=0
return ret
