#compdef drupal-console
# _drupal-console — Jesús Manuel Olivas Drupal Console CLI alias (hechoendrupal team, PHP); symfony console
# upstream: https://github.com/hechoendrupal/drupal-console

_drupal-console() {
    local -a sub=(
        'about:show project info'
        'cache:rebuild:rebuild cache'
        'chain:run chain file'
        'check:check requirements'
        'composerize:composerize core'
        'cron:debug:debug cron'
        'cron:execute:execute cron'
        'cron:release:release cron'
        'config:debug:debug config'
        'config:delete:delete config'
        'config:diff:diff config'
        'config:edit:edit config'
        'config:export:export config'
        'config:import:import config'
        'config:override:override config'
        'database:client:open db client'
        'database:connect:connect db'
        'database:drop:drop db'
        'database:dump:dump db'
        'database:log:clear:clear db log'
        'database:log:debug:debug db log'
        'database:query:run query'
        'database:restore:restore db'
        'database:table:debug:debug tables'
        'database:table:drop:drop tables'
        'debug:configuration:debug configuration'
        'debug:container:debug container'
        'debug:dotenv:debug dotenv'
        'debug:event:debug events'
        'debug:plugin:debug plugin'
        'debug:permission:debug permissions'
        'debug:roles:debug roles'
        'debug:router:debug router'
        'debug:settings:debug settings'
        'debug:theme:debug theme'
        'debug:update:debug updates'
        'debug:user:debug users'
        'debug:views:debug views'
        'devel:dumper:set dumper'
        'features:debug:debug features'
        'features:import:import features'
        'image:styles:debug:debug image styles'
        'image:styles:flush:flush image styles'
        'list:list commands'
        'locale:language:add:add language'
        'locale:language:delete:delete language'
        'locale:translation:status:translation status'
        'migrate:debug:debug migrations'
        'migrate:execute:execute migration'
        'migrate:setup:setup migration'
        'module:debug:debug modules'
        'module:download:download module'
        'module:install:install module'
        'module:uninstall:uninstall module'
        'module:update:update module'
        'multisite:new:new multisite'
        'multisite:update:update multisite'
        'queue:debug:debug queue'
        'queue:run:run queue'
        'rest:debug:debug rest'
        'rest:disable:disable rest'
        'rest:enable:enable rest'
        'router:rebuild:rebuild router'
        'shell:open shell'
        'site:install:install site'
        'site:maintenance:set maintenance mode'
        'site:mode:set site mode'
        'site:new:create new site'
        'site:status:show site status'
        'site:statistics:show stats'
        'site:uninstall:uninstall site'
        'state:debug:debug state'
        'state:delete:delete state'
        'state:override:override state'
        'taxonomy:term:delete:delete term'
        'theme:debug:debug theme'
        'theme:download:download theme'
        'theme:install:install theme'
        'theme:path:show theme path'
        'theme:uninstall:uninstall theme'
        'translation:cleanup:cleanup translations'
        'translation:pending:show pending translations'
        'translation:stats:show translation stats'
        'translation:sync:sync translations'
        'update:debug:debug updates'
        'update:execute:execute updates'
        'user:create:create user'
        'user:delete:delete user'
        'user:login:clear-attempts:clear login attempts'
        'user:login:url:get login url'
        'user:password:hash:hash password'
        'user:password:reset:reset password'
        'user:role:add role'
        'user:role:remove role'
        'views:debug:debug views'
        'views:disable:disable view'
        'views:enable:enable view'
        'generate:command:generate command'
        'generate:controller:generate controller'
        'generate:entity:bundle:generate bundle entity'
        'generate:entity:config:generate config entity'
        'generate:entity:content:generate content entity'
        'generate:event:subscriber:generate event subscriber'
        'generate:form:generate form'
        'generate:module:generate module'
        'generate:plugin:block:generate block plugin'
        'generate:plugin:field:formatter:generate field formatter'
        'generate:plugin:field:type:generate field type'
        'generate:plugin:field:widget:generate field widget'
        'generate:service:generate service'
        'generate:theme:generate theme'
        'generate:twig:extension:generate twig extension'
        'init:init drupal console'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--root=+[drupal root]:dir:_files -/' \
        '--uri=+[uri]:url:_urls' \
        '-l+[uri]:url:_urls' \
        '--env=+[env]:str:' \
        '-e+[env]:str:' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'drupal subcommand' sub ;;
        args)
            case $words[1] in
                module:install|module:uninstall) _arguments '*:module:' '--latest[latest]' '--composer[via composer]' ;;
                user:role) _arguments '1:role:' '2:user:' ;;
                site:install) _arguments \
                    '1:profile:(standard minimal demo_umami)' \
                    '--langcode=+[language]:str:' \
                    '--db-type=+[db type]:t:(mysql pgsql sqlite)' \
                    '--db-host=+[db host]:host:_hosts' \
                    '--db-name=+[db name]:str:' \
                    '--db-user=+[db user]:user:_users' \
                    '--db-pass=+[db password]:str:' \
                    '--db-port=+[db port]:port:' \
                    '--site-name=+[site name]:str:' \
                    '--site-mail=+[site mail]:str:' \
                    '--account-name=+[admin name]:user:_users' \
                    '--account-mail=+[admin mail]:str:' \
                    '--account-pass=+[admin password]:str:' ;;
            esac
            ;;
    esac
}

_drupal-console "$@"
