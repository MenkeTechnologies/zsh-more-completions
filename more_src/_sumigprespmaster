#compdef sumigprespmaster
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/PVM/PsPvmMig/iso_sp_pp/sumigprespmaster.c
# master code of 2-D prestack shot-gather 45-90 degree finite-difference migration

local ret=1

_arguments -s -S \
  'nxo=[number of total horizontal output samples]:nxo' \
  'nxshot=[number of shot gathers to be migrated]:nxshot' \
  'nz=[number of depth samples]:nz' \
  'dx=[horizontal sampling interval]:dx' \
  'dz=[depth sampling interval]:dz' \
  'vfile=[velocity profile (binary, vfile[iz][ix])]:file:_files' \
  'cpufile=[file listing computer names for slave tasks]:file:_files' \
  'Ntasks=[number of slaves to start]:Ntasks' \
  'dip=[maximum dip to migrate (45,65,79,80,87,89,90)]:dip:(45 65 79 80 87 89 90)' \
  'Fmax=[peak frequency of Ricker source wavelet]:Fmax' \
  'f1=[low-cut frequency for Hamming window]:f1' \
  'f2=[low-pass frequency for Hamming window]:f2' \
  'f3=[high-pass frequency for Hamming window]:f3' \
  'f4=[high-cut frequency for Hamming window]:f4' \
  'lpad=[zero traces padded on left side of depth section]:lpad' \
  'rpad=[zero traces padded on right side of depth section]:rpad' \
  '*:file:_files' && ret=0

return ret
