_git-rewrite-commits() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--provider=[AI provider]:provider:(openai ollama claude-code)' \
        '(-k --api-key)'{-k,--api-key}'=[OpenAI API key]:key:' \
        '(-m --model)'{-m,--model}'=[AI model name]:model:' \
        '--ollama-url=[Ollama server URL]:url:' \
        '(-b --branch)'{-b,--branch}'=[branch to rewrite]:branch:' \
        '(-d --dry-run)'{-d,--dry-run}'[preview without modifying]' \
        '(-v --verbose)'{-v,--verbose}'[detailed output with diffs]' \
        '--max-commits=[process only the last N commits]:n:' \
        '--skip-backup[skip safety backup branch (not recommended)]' \
        '--no-skip-well-formed[process all commits, even well-formed ones]' \
        '--min-quality-score=[minimum quality score (1-10)]:score:' \
        '(-t --template)'{-t,--template}'=[commit message template]:template:' \
        '(-l --language)'{-l,--language}'=[language for messages (default en)]:lang:(en zh es fr de ja ko ru pt)' \
        '(-p --prompt)'{-p,--prompt}'=[custom prompt]:prompt:' \
        '--staged[generate message for staged changes]' \
        '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
        '--skip-remote-consent[skip consent prompt (CI only)]' \
        '--install-hooks[install pre-commit + prepare-commit-msg hooks]'
}

_git-rewrite-commits "$@"
