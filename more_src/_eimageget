#compdef eimageget
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/eimageget/node10.html
# EPIC vignetting-corrected background-subtracted image production

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--evtfile=[input event list to create images from]:file:_files' \
  '--ootfile=[input out-of-time event list (EPIC-pn)]:file:_files' \
  '--fwcfile=[input filter-wheel-closed event list]:file:_files' \
  '--attfile=[input attitude file]:file:_files' \
  '--gtifile=[input good-time-interval file]:file:_files' \
  '--withemtaglenoise=[identify and remove noisy EPIC-MOS CCDs]:bool:(yes no)' \
  '--withbadpixupdate=[conform bad-pixel extensions across inputs]:bool:(yes no)' \
  '--withfwcimages=[create filter-wheel-closed images]:bool:(yes no)' \
  '--withwindowmode=[include CCD data operated in window mode]:bool:(yes no)' \
  '--pimin=[lower energy boundaries in PI channels]:value' \
  '--pimax=[upper energy boundaries in PI channels]:value' \
  '--patmin=[lower boundaries for PATTERN selection]:value' \
  '--patmax=[upper boundaries for PATTERN selection]:value' \
  '--flag=[flag for final image selection]:flag' \
  '--flagout=[flag for events in shielded detector areas]:flag' \
  '--ximagemin=[lower x coordinate limit]:value' \
  '--ximagemax=[upper x coordinate limit]:value' \
  '--yimagemin=[lower y coordinate limit]:value' \
  '--yimagemax=[upper y coordinate limit]:value' \
  '--imagebinning=[bin size or total image size]:mode:(binSize imageSize)' \
  '--ximagebinsize=[binning factor for x axis]:value' \
  '--yimagebinsize=[binning factor for y axis]:value' \
  '--ximagesize=[image size in pixels along x axis]:value' \
  '--yimagesize=[image size in pixels along y axis]:value' \
  '--withxranges=[use specified x coordinate ranges]:bool:(yes no)' \
  '--withyranges=[use specified y coordinate ranges]:bool:(yes no)' \
  '--squarepixels=[force x and y bin sizes identical]:bool:(yes no)' \
  '--raimagecenter=[Right Ascension for output image center]:ra' \
  '--decimagecenter=[Declination for output image center]:dec' \
  '--withcelestialcenter=[center image on specified sky position]:bool:(yes no)' \
  '--withattcalc=[calculate new image coordinates]:bool:(yes no)' \
  '--nominalra=[celestial RA of central reference point]:ra' \
  '--nominaldec=[celestial Dec of central reference point]:dec' \
  '--imagesize=[half-size of final image in degrees]:degrees' \
  '--withexposure=[create exposure maps]:bool:(yes no)' \
  '--withmask=[create a mask]:bool:(yes no)' \
  '--threshold1=[exposure fraction threshold for mask creation]:value' \
  '--threshold2=[gradient threshold for mask creation]:value' \
  '*:param=value:_default' && ret=0

return ret
