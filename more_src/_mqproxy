#compdef mqproxy
# Documentation: https://rocketmq.apache.org/docs/deploymentOperations/01deploy/
# Apache RocketMQ proxy startup

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-n --namesrvAddr)'{-n,--namesrvAddr}'=[name server address list]:addr' \
  '(-bc --brokerConfigPath)'{-bc,--brokerConfigPath}'=[broker config file path for local mode]:file:_files' \
  '(-pc --proxyConfigPath)'{-pc,--proxyConfigPath}'=[proxy config file path]:file:_files' \
  '(-pm --proxyMode)'{-pm,--proxyMode}'=[proxy run in local or cluster mode]:mode:(local cluster)' && ret=0

return ret
