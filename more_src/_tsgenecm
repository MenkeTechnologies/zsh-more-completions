#compdef tsgenecm
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsgenecm.cpp
# tsgenecm - generate one ECM using a DVB SimulCrypt-compliant ECMG

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--cp-number=[crypto-period number (default 0)]:n:' \
  '(-c --cw-current)'{-c,--cw-current}'=[current control word (hex digits, required)]:hex:' \
  '(-n --cw-next)'{-n,--cw-next}'=[next control word (hex digits, optional)]:hex:' \
  '*:output file:_files' && ret=0

return ret
