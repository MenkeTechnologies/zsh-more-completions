#compdef hive

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-H,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*-e+[query string]:query:' \
  '-f+[SQL file]:file:_files -g "*.(hql|sql|q)"' \
  '*-i+[init SQL file]:file:_files -g "*.(hql|sql|q)"' \
  '-v[verbose]' \
  '-S[silent mode (no info messages)]' \
  '*--database=[database to use]:database:' \
  '*--hiveconf=[set hive configuration variable]:key=value:' \
  '*--hivevar=[set hive variable]:key=value:' \
  '*--define=[alias for --hivevar]:key=value:' \
  '--service=[start a service]:service:(beeline cleardanglingscratchdir cli help hbaseimport hbaseschematool hiveburninclient hiveserver2 hplsql hwi jar lineage llap llapdump llapstatus metastore metatool orcfiledump rcfilecat schemaTool version)' \
  '--auxpath+[auxiliary jar files]:files:' \
  '--config=[Hive config dir]:dir:_files -/' && ret=0

return ret
