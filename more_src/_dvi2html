#compdef dvi2html
# Documentation: https://man.archlinux.org/search?q=dvi2html
# Reference accessed: 2026-05-16

# dvi2html: convert DVI to HTML (basic)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[verbose output]' \
  '*:DVI file:_files -g "*.dvi"' && ret=0
return ret
