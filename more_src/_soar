#compdef soar
# =============================================================================
# soar — pkgforge's "fast, modern package manager for Static
#         Binaries, Portable Formats (AppImage|AppBundle|FlatImage|
#         Runimage) & More."  A Linux package manager that
#         specifically targets STATIC BINARIES and portable-app
#         formats rather than the traditional dynamic-linked
#         Debian/RPM/Pacman approach.  soar's distinguishing
#         design:
#           - Installs ONLY pre-compiled static binaries (no
#             compilation, no source builds, no shared-library
#             dependencies)
#           - Supports portable-app formats: AppImage (Universal
#             Linux App), AppBundle (single-file desktop apps),
#             FlatImage (sandboxed AppImage), Runimage (rootless
#             AppImage variant)
#           - Per-user installation by default (no root needed)
#           - System-wide mode via `--system` (requires root)
#           - Atomic package operations (transactional install/
#             remove)
#           - Multi-repository support (pkgforge org maintains
#             multiple repos: bincache, pkgcache, pkgforge stable)
#           - Public-key-verified package signatures
#           - Declarative `packages.toml` for reproducible
#             package sets (similar to Nix's home-manager but
#             with imperative `soar apply`)
#         Used by Linux power users wanting:
#           - "AppImage everything" workflows
#           - Multiple package versions side-by-side
#           - Zero-dependency-conflict installations
#           - Distro-agnostic package management
#
# Author:  pkgforge / @QaidVoid + contributors at pkgforge org.
#          Created 2024 as a modern alternative to AppImageHub
#          install scripts; gained traction in 2025-2026 as the
#          static-binary package management movement grew.
# Source:  https://github.com/pkgforge/soar
# CLI:     crates/soar-cli/src/cli.rs (uses clap 4 derive Parser +
#                                       zkat/miette for diagnostic
#                                       error reports + indicatif
#                                       for progress display +
#                                       clap_complete for shell
#                                       completion generation)
# Library: zkat/miette
#          ("Fancy diagnostic reporting library and protocol for us
#           mere mortals who aren't compiler hackers" — Kat Marchán's
#           Rust diagnostic library, parallel to zesterer/ariadne
#           R542; THE second documented Rust error-diagnostics
#           library on Axis 6.  Used by Astral tools (uv, ruff,
#           pixi), oxc-project, and now soar.)
# License: MIT
# Status:  Active — 790+ stars on pkgforge/soar (last pushed
#          2026-05-19); miette itself is 2562+ stars on zkat/miette
#          (continuous development since 2021 by Kat Marchán —
#          also author of cacache-rs + many other npm-cli internals
#          when she worked at npm).
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — RUST CROSSES TO 48
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# the 48TH Rust CLI library variant.  Rust climbs from 47 to 48
# documented libraries (zkat/miette via soar).  New leaderboard:
# Rust=48 SOLO LEAD, Go=47, TypeScript-Node=47 (three-way tie at 47
# from R560 broken after R561 Pyret new-language pause).  Taxonomy
# now spans 301 cross-language CLI library variants across 73
# documented languages.
#
# Pattern: 3 leader bumps (R558 clio Rust opening Axis 8 → R559 mpb
# Go → R560 cli-progress TS-Node restoring three-way tie at 47) →
# 1 new lang (R561 Pyret crossing 300 variants) → R562 (THIS) starts
# next leader-bump triple with Rust=48 via miette.  Per established
# pattern, R563 should bring Go to 48 and R564 should bring TS-Node
# to 48.
#
# This completion EXPANDS Axis 6 (ERROR DIAGNOSTICS REPORTING)
# within Rust to TWO documented libraries:
#
#   * R542: zesterer/ariadne (rustc-format-compatible, builder API,
#                                chumsky parser integration, cache-
#                                trait source abstraction)
#   * R562: zkat/miette (THIS, DERIVE-MACRO API, theme system,
#                          thiserror integration, JSON output,
#                          related/help/diagnostic-code chains)
#
# These represent TWO POLAR-DIFFERENT Rust error-diagnostics
# library designs:
#   * ariadne:  BUILDER PATTERN (Report::build().with_label()
#                .finish().eprint()) for runtime error construction;
#                rustc-format-compatible output; chumsky parser
#                integration
#   * miette:   DERIVE-MACRO PATTERN (#[derive(Diagnostic)] on
#                error enum variants) for compile-time error
#                schema; theme system (RGB/256-color/ANSI fallback);
#                thiserror integration; first-class JSON output
#                for IDE/LSP consumers
#
# Rust now has TWO documented error-diagnostics libraries — making
# Rust the FIRST documented language with two diagnostic libraries
# in the taxonomy.  Cross-language error-diagnostics matrix:
#   * Rust:    ariadne R542 (builder) + miette R562 (THIS, derive)
#   * Go:      none documented yet (no clear analog)
#   * TS-Node: none documented yet (no clear analog)
#
# Rust's two-library coverage of Axis 6 mirrors its two-library
# coverage of Axis 4 (terminal coloring: owo-colors R526 + termcolor
# R546) and Axis 7 (low-level terminal: termion R550 + crossterm
# R554).
#
# Crossing 301 variants is also a SUB-MILESTONE — the taxonomy has
# now documented MORE CLI library variants than 4 × 73 languages
# would suggest as a baseline.
#
# -----------------------------------------------------------------------------
#
# WHAT IS miette AND WHY IS IT THE 48TH RUST CLI LIBRARY?
#
# miette (https://github.com/zkat/miette, 2562+ stars) is **Kat
# Marchán (zkat)'s "Fancy diagnostic reporting library and protocol
# for us mere mortals who aren't compiler hackers"** — a Rust
# diagnostic library that takes a different design approach from
# ariadne R542.  zkat (Kat Marchán) is the prolific JavaScript +
# Rust developer who:
#   - Worked at npm Inc as engineering lead for the npm CLI
#     (2014-2020)
#   - Created cacache (content-addressable disk cache; the heart
#     of npm's local cache)
#   - Maintained pacote, libnpmpublish, libnpmaccess, libnpmsearch,
#     and most of the npm-cli supporting libraries
#   - Now works at Anthropic (Claude / Claude Code maintenance)
# miette is zkat's Rust adaptation of the diagnostic-reporting
# best-practices learned from npm's many error-reporting iterations.
#
# miette's distinguishing characteristics:
#
#   1. DERIVE-MACRO PATTERN — miette uses Rust's derive system to
#      attach diagnostic metadata to error enum variants:
#
#          use miette::{Diagnostic, SourceSpan};
#          use thiserror::Error;
#
#          #[derive(Error, Debug, Diagnostic)]
#          #[error("oops!")]
#          #[diagnostic(
#              code(oops::my::bad),
#              url(docsrs),
#              help("try doing it better next time?"),
#          )]
#          struct MyBad {
#              #[source_code]
#              src: String,
#              #[label("This bit here")]
#              bad_bit: SourceSpan,
#          }
#
#      Compare:
#         * ariadne R542: builder pattern at runtime
#                          (Report::build().with_label().finish())
#         * thiserror alone: only error messages, no source-pointer
#         * eyre/anyhow: dynamic error chains, no source-pointers
#         * miette: DERIVE annotates the error type with all
#                    diagnostic metadata (code, url, help, labels,
#                    source-span pointers)
#      FIRST documented Rust diagnostic library with derive-macro
#      error annotation.
#
#   2. THISERROR INTEGRATION — miette's `#[derive(Diagnostic)]` is
#      designed to COMPOSE with `#[derive(Error)]` from `thiserror`
#      (David Tolnay's Rust error library).  A single enum variant
#      gets BOTH derives — `Error` produces the std::error::Error
#      impl + Display impl; `Diagnostic` adds the diagnostic-
#      reporting capabilities on top:
#
#          #[derive(Error, Debug, Diagnostic)]
#          enum MyError {
#              #[error("Parse error at line {line}")]
#              #[diagnostic(code(my::parse::error))]
#              ParseError {
#                  #[source_code] src: String,
#                  #[label("syntax error here")] span: SourceSpan,
#                  line: u32,
#              },
#          }
#
#      Compare ariadne R542 which does NOT integrate with
#      thiserror (you build Reports from scratch).  FIRST
#      documented Rust diagnostic library with first-class
#      thiserror composition.
#
#   3. THEME SYSTEM (TRUE COLOR / 256-COLOR / ANSI FALLBACK) —
#      miette ships with multiple visual themes selectable via
#      `MietteHandlerOpts::theme(theme)`:
#         * `MietteTheme::unicode()` — Unicode + truecolor (default
#                                       for TTY)
#         * `MietteTheme::unicode_nocolor()` — Unicode no color
#         * `MietteTheme::ascii()` — ASCII + ANSI 16-color
#         * `MietteTheme::ascii_nocolor()` — ASCII no color
#         * `MietteTheme::none()` — minimal output
#      Plus custom themes via `MietteTheme::custom(...)`.  Compare
#      ariadne R542 (Unicode + ASCII fallback only, no
#      programmable theming).  FIRST documented Rust diagnostic
#      library with explicit theme-selection system.
#
#   4. JSON-DIAGNOSTIC OUTPUT FOR IDE/LSP — miette supports
#      JSON-format diagnostic output via
#      `MietteHandlerOpts::report_format(ReportFormat::Json)`:
#
#          {
#            "message": "oops!",
#            "code": "oops::my::bad",
#            "severity": "error",
#            "labels": [{
#              "label": "This bit here",
#              "span": { "offset": 5, "length": 3 }
#            }],
#            "help": "try doing it better next time?",
#            "url": "https://docs.rs/...#variant.MyBad"
#          }
#
#      IDEs (rust-analyzer, VS Code, Helix) can consume this JSON
#      directly for inline diagnostic display.  Compare ariadne
#      R542 (no JSON output) and rustc's --error-format=json.
#      FIRST documented Rust diagnostic library with first-class
#      JSON output for IDE/LSP consumption.
#
#   5. RELATED + HELP + DIAGNOSTIC-CODE CHAINS — miette diagnostics
#      can include:
#         * `code(domain::sub::name)` — hierarchical error codes
#                                        like `oops::my::bad`
#         * `url(...)` — link to documentation (auto-generated
#                         docs.rs link if `url(docsrs)`)
#         * `help("...")` — single help message
#         * `#[related]` — vec of related diagnostics
#         * `#[diagnostic_source]` — chain to underlying error
#                                     that ALSO has Diagnostic
#                                     metadata
#      Compare:
#         * ariadne: notes, labels, but no chains
#         * thiserror: source chain via #[source]
#         * miette: rich semantic metadata including related-
#                    diagnostic chains
#      FIRST documented Rust diagnostic library with hierarchical
#      diagnostic codes + url + help + related-chain semantic
#      metadata.
#
# miette's relationship to other documented Rust CLI libraries:
#
#   * Like ariadne R542 — error-diagnostics axis (same axis,
#                          different design philosophy)
#   * Like thiserror (R-undocumented) — composable with thiserror
#                                       for combined Error + Diagnostic
#                                       derives
#   * Like clap-derive — uses Rust derive macros for declarative
#                        configuration
#   * Unlike ariadne R542 — DERIVE-MACRO over BUILDER; theme system;
#                            thiserror integration; JSON output;
#                            related-diagnostic chains
#   * Closest cross-language analogs:
#         * Go:      no clear analog (no documented Go diagnostic
#                     library yet)
#         * TS-Node: no clear analog (TypeScript has its own
#                     compiler diagnostics; no general Node.js
#                     library like miette)
#     miette completes the dual-library coverage of Axis 6
#     within Rust (ariadne + miette), parallel to dual coverage
#     of Axis 4 and Axis 7.
#
# -----------------------------------------------------------------------------
#
# THE soar CLI — clap derive + miette + indicatif Composition
#
# soar's argv parser is clap 4 derive Parser with ~22 subcommands +
# 11 global flags + many sub-flags:
#
#     #[derive(Parser)]
#     pub struct Args {
#         #[arg(short = 'v', long, action = ArgAction::Count,
#                global = true)]
#         pub verbose: u8,
#         #[arg(short, long, global = true)]
#         pub quiet: bool,
#         #[arg(short, long, global = true)]
#         pub json: bool,
#         #[arg(long, global = true)]
#         pub no_color: bool,
#         #[arg(long, global = true)]
#         pub no_progress: bool,
#         #[arg(short, long, global = true)]
#         pub profile: Option<String>,
#         #[arg(short, long, global = true)]
#         pub config: Option<String>,
#         #[arg(long, short = 'P', global = true)]
#         pub proxy: Option<String>,
#         #[arg(long, short = 'H', global = true)]
#         pub header: Option<Vec<String>>,
#         #[arg(long, short = 'A', global = true)]
#         pub user_agent: Option<String>,
#         #[arg(long, short = 'S', global = true)]
#         pub system: bool,
#         #[clap(subcommand)]
#         pub command: Commands,
#     }
#
# When soar fails (network error, signature verification failure,
# missing repository), it uses miette's Diagnostic trait on its
# error types (SoarError + ErrorContext) to produce rich error
# reports with source-pointers + help text + diagnostic codes.
#
# Distinct from every other documented Rust CLI library on FIVE
# specific axes:
#
#   1. DERIVE-MACRO ERROR-DIAGNOSTIC PATTERN — Every other
#      documented Rust diagnostic library (ariadne R542) uses
#      builder pattern at runtime.  miette uses Rust derive macros
#      to annotate error types with diagnostic metadata at
#      compile time.  FIRST documented Rust diagnostic library
#      with derive-macro error annotation.
#
#   2. THISERROR INTEGRATION — Every other documented Rust
#      diagnostic library is standalone.  miette composes with
#      thiserror via dual-derive (#[derive(Error, Diagnostic)]).
#      FIRST documented Rust diagnostic library with first-class
#      thiserror composition.
#
#   3. THEME SYSTEM — Every other documented Rust diagnostic
#      library has fixed visual style (or just Unicode+ASCII).
#      miette has 5 built-in themes (unicode/unicode_nocolor/
#      ascii/ascii_nocolor/none) + custom theme support.  FIRST
#      documented Rust diagnostic library with explicit theme-
#      selection system.
#
#   4. JSON-DIAGNOSTIC OUTPUT — Every other documented Rust
#      diagnostic library is human-text-only.  miette supports
#      JSON output for IDE/LSP consumption via
#      ReportFormat::Json.  FIRST documented Rust diagnostic
#      library with first-class JSON output.
#
#   5. RELATED + HELP + DIAGNOSTIC-CODE CHAINS — Every other
#      documented Rust diagnostic library has flat error reports.
#      miette supports hierarchical diagnostic codes, URL
#      documentation links, help text, and `#[related]` /
#      `#[diagnostic_source]` chains.  FIRST documented Rust
#      diagnostic library with rich semantic metadata + chains.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/pkgforge/soar/blob/main/crates/soar-cli/src/
# cli.rs clap derive Args + Commands definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
    'config:print configuration file to stdout'
    'install:install packages (aliases: i, add)'
    'i:install packages (alias for install)'
    'add:install packages (alias for install)'
    'search:search packages (aliases: s, find)'
    's:search packages (alias for search)'
    'find:search packages (alias for search)'
    'query:query package info (alias: Q)'
    'Q:query package info (alias for query)'
    'remove:remove packages (aliases: r, del)'
    'r:remove packages (alias for remove)'
    'del:remove packages (alias for remove)'
    'sync:sync with remote metadata (aliases: S, fetch)'
    'S:sync with remote metadata (alias for sync)'
    'fetch:sync with remote metadata (alias for sync)'
    'update:update packages (aliases: u, upgrade)'
    'u:update packages (alias for update)'
    'upgrade:update packages (alias for update)'
    'info:show info about installed packages (alias: list-installed)'
    'list:list available packages (alias: ls)'
    'ls:list available packages (alias for list)'
    'log:view package log'
    'inspect:view build script for a package'
    'run:run a package (aliases: exec, execute)'
    'exec:run a package (alias for run)'
    'execute:run a package (alias for run)'
    'use:use alternative package'
    'download:download files (alias: dl)'
    'dl:download files (alias for download)'
    'health:health check'
    'def-config:generate default config'
    'repo:manage repositories'
    'env:show environment info'
    'clean:clean cache'
    'self:self-management commands'
    'apply:apply packages.toml declarative package set'
    'def-packages:show default packages'
    'completions:generate shell completion script'
    'json2db:convert JSON metadata to DB'
)

_arguments -s -C \
    '(-h --help)'{-h,--help}'[print help and exit]' \
    '(-V --version)'{-V,--version}'[print version and exit]' \
    '*'{-v,--verbose}'[increase output verbosity (use -vv for more)]' \
    '(-q --quiet)'{-q,--quiet}'[suppress outputs]' \
    '(-j --json)'{-j,--json}'[output as JSON]' \
    '--no-color[disable colors in output]' \
    '--no-progress[disable progress bar]' \
    '(-p --profile)'{-p+,--profile=}'[set current profile]:profile:' \
    '(-c --config)'{-c+,--config=}'[provide custom config file]:file:_files' \
    '(-P --proxy)'{-P+,--proxy=}'[set proxy URL]:proxy:' \
    '*'{-H+,--header=}'[set request header (repeatable)]:header:' \
    '(-A --user-agent)'{-A+,--user-agent=}'[set user agent string]:user-agent:' \
    '(-S --system)'{-S,--system}'[manage system-wide packages (requires root)]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case "$state" in
    cmd)
        _describe -t commands 'soar subcommand' commands && ret=0
        ;;
    args)
        case "${words[1]}" in
            completions)
                _arguments -s '1:shell:(bash zsh fish powershell elvish nushell)' && ret=0
                ;;
            repo)
                _arguments -s '1:action:(add update remove del list ls)' && ret=0
                ;;
            self)
                _arguments -s '1:action:(update uninstall)' && ret=0
                ;;
        esac
        ;;
esac

return ret
