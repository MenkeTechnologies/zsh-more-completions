#compdef icepack
# Documentation: https://man.archlinux.org/search?q=icepack
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-u[unpack mode (extract bitstream from .asc)]' \
  '-s[generate hex-encoded ascii (deprecated)]' \
  '-b[generate binary]' \
  '-v[verbose]' \
  '-B+[bram type]:type:' \
  '1:input:_files -g "*.{asc,bin}"' \
  '2:output:_files -g "*.{asc,bin}"' && ret=0

return ret
