#compdef gtklock

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemonize)'{-d,--daemonize}'[detach from controlling terminal]' \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  '(-s --style)'{-s,--style}'[specify CSS style file]:CSS file:_files' \
  '(-m --module)'{-m,--module}'[load a module]:module path:_files' \
  '(-b --background)'{-b,--background}'[set background image]:image file:_files' \
  '(-t --time-format)'{-t,--time-format}'[set time format (strftime)]:format string' \
  '(-H --idle-hide)'{-H,--idle-hide}'[hide UI when idle]' \
  '(-i --idle-timeout)'{-i,--idle-timeout}'[set idle timeout in seconds]:seconds' \
  '(-l --start-hidden)'{-l,--start-hidden}'[start with UI hidden]' \
  '(-L --lock-command)'{-L,--lock-command}'[command to run on lock]:command' \
  '(-U --unlock-command)'{-U,--unlock-command}'[command to run on unlock]:command' \
  '(-g --gtk-module)'{-g,--gtk-module}'[load a GTK module]:GTK module'
