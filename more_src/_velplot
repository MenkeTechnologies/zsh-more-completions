#compdef velplot
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/velplot.html
# MIRIAD: interactively plot spectra and slices from images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image]:in:_files' \
  'device=[PGPLOT device]:device:' \
  'region=[region of interest]:region:' \
  'log=[output log file]:log:_files' \
  '*:image:_files' && ret=0

return ret
