#compdef scil_frf_ssst
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_frf_ssst.html
# Scilpy: compute single-shell single-tissue fiber response function (FRF)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--mask=[binary mask]:mask:_files' \
  '--mask_wm=[white matter mask]:mask:_files' \
  '--fa_thresh=[FA threshold for single-fiber voxels]:thresh' \
  '--min_fa_thresh=[minimum FA threshold]:thresh' \
  '--min_nvox=[minimum number of voxels]:nvox' \
  '--roi_radii=[ROI radii]:radii' \
  '--roi_center=[ROI center coordinates]:center' \
  '--b0_threshold=[b0 threshold]:thr' \
  '--skip_b0_check[skip b0 existence validation]' \
  '--precision=[precision of output FRF values]:precision' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_dwi:_files' \
  '2:in_bval:_files' \
  '3:in_bvec:_files' \
  '4:frf_file:_files' && ret=0

return ret
