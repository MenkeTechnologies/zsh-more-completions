#compdef modal
# Documentation: https://modal.com/docs/reference/cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'app:manage deployed and running apps'
      'billing:view workspace billing information'
      'bootstrap:bootstrap a new project'
      'changelog:show the Modal changelog'
      'config:manage configuration'
      'container:manage and connect to running containers'
      'dashboard:open the Modal dashboard'
      'deploy:deploy an app'
      'dict:manage Dict objects'
      'environment:manage environments'
      'launch:launch examples'
      'nfs:manage network file systems'
      'profile:manage profiles'
      'queue:manage Queue objects'
      'run:run a function or local entrypoint'
      'secret:manage secrets'
      'serve:serve an app'
      'setup:set up Modal'
      'shell:run a command or interactive shell inside a Modal container'
      'token:manage tokens'
      'volume:read and edit modal.Volume volumes'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      run)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'[assign a name to this run]:name:' \
          '(-w --write-result)'{-w,--write-result}'[write return value to local path]:path:_files' \
          '(-q --quiet)'{-q,--quiet}'[suppress progress indicators]' \
          '(-d --detach)'{-d,--detach}'[do not stop app if local process dies]' \
          '(-i --interactive)'{-i,--interactive}'[execute in interactive mode]' \
          '(-e --env)'{-e,--env}'[environment]:environment:' \
          '-m[use Python module path instead of file path]' \
          '--timestamps[display timestamps for each log entry]' \
          '(- *)--help[show help]' \
          '1:entrypoint:_files -g "*.py"' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '--name=[deployment name]:name:' \
          '(-e --env)'{-e,--env}'[environment]:environment:' \
          '--stream-logs[activate log streaming]' \
          '--tag=[version tag]:tag:' \
          '-m[use Python module path instead of file path]' \
          '--timestamps[display timestamps]' \
          '--strategy=[deployment strategy]:strategy:(rolling recreate)' \
          '(- *)--help[show help]' \
          '1:entrypoint:_files -g "*.py"' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(-e --env)'{-e,--env}'[environment]:environment:' \
          '-m[use Python module path]' \
          '(- *)--help[show help]' \
          '1:entrypoint:_files -g "*.py"' && ret=0
        ;;
      shell)
        _arguments -s -S \
          '--image=[image tag]:image:' \
          '--gpu=[GPU type]:gpu:(any t4 l4 a10g a100 h100)' \
          '--cpu=[number of CPUs]:cpus:' \
          '--memory=[memory in MiB]:memory:' \
          '(-e --env)'{-e,--env}'[environment]:environment:' \
          '--cmd=[command to run]:command:' \
          '--add-python=[add Python to the image]:version:' \
          '--pty[use PTY]' \
          '--no-pty[do not use PTY]' \
          '(- *)--help[show help]' && ret=0
        ;;
      app)
        _arguments -s -S \
          '1:action:(dashboard history list logs rollback rollover stop)' && ret=0
        ;;
      volume)
        _arguments -s -S \
          '1:action:(cp create dashboard delete get list ls put rename rm)' && ret=0
        ;;
      secret)
        _arguments -s -S \
          '1:action:(create delete list)' && ret=0
        ;;
      environment)
        _arguments -s -S \
          '1:action:(create delete list update)' && ret=0
        ;;
      token)
        _arguments -s -S \
          '1:action:(new set)' && ret=0
        ;;
      config)
        _arguments -s -S \
          '1:action:(set-environment show)' && ret=0
        ;;
    esac
    ;;
esac

return ret
