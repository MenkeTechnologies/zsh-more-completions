#compdef ct

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[Show help]' \
  '1:command:->cmds' \
  '*::arg:->args' \
  && ret=0

case $state in
  cmds)
    local -a commands=(
      'lint:Lint Helm charts'
      'install:Install Helm charts'
      'lint-and-install:Lint and install Helm charts'
    )
    _describe -t commands 'ct command' commands && ret=0
    ;;
  args)
    case $line[1] in
      lint|install|lint-and-install)
        _arguments \
          '--config[Config file path]:file:_files' \
          '*--charts[Specific charts to test]:chart dir:_directories' \
          '*--chart-dirs[Directories containing charts]:dir:_directories' \
          '*--chart-repos[Additional chart repositories]:repos:' \
          '*--excluded-charts[Charts to exclude from testing]:charts:' \
          '--remote[Remote name for git]:remote:' \
          '--target-branch[Target branch for comparison]:branch:' \
          '--since[Only test charts changed since this commit]:commit:' \
          '--debug[Enable debug output]' \
          '--upgrade[Test upgrade from previous chart version]' \
          '--namespace[Kubernetes namespace]:namespace:' \
          '--release-label[Release label for resources]:label:' \
          '--build-id[Build ID for unique resource naming]:id:' \
          '--helm-extra-args[Extra arguments to pass to Helm]:args:' \
          '(- *)--help[Show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
