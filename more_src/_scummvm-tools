#compdef scummvm-tools scummvm-tools-cli
# Documentation: https://github.com/scummvm/scummvm-tools/blob/master/Makefile.common
# Reference accessed: 2026-05-21
# Verified: scummvm-tools-src Makefile.common PROGRAMS list (lines 25-92).
# scummvm-tools and scummvm-tools-cli are the umbrella binaries; the listed
# names are standalone binaries (mostly compress_*/extract_*).
# Removed from prior file: create_lure (no create_lure.cpp anywhere in tree),
# decompile_gui (no such binary - only decompiler/decompiler.cpp exists),
# compress_gob (a subcommand inside -cli, not standalone), compress_scumm_bun
# (subcommand only, not standalone).

# scummvm-tools: SCUMM data extraction/compression tools (umbrella binary)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'compress_agos:compress AGOS speech'
  'compress_kyra:compress Kyra speech'
  'compress_queen:compress Queen speech'
  'compress_saga:compress Saga speech'
  'compress_scumm_san:compress SCUMM .san'
  'compress_scumm_sou:compress SCUMM .sou'
  'compress_sword1:compress Sword1 speech'
  'compress_sword2:compress Sword2 speech'
  'compress_tinsel:compress Tinsel speech'
  'compress_touche:compress Touche speech'
  'compress_tucker:compress Tucker speech'
  'create_sjisfnt:create SJIS font (requires FREETYPE2+ICONV)'
  'dekyra:decompile Kyra resources'
  'decompiler:decompile (requires USE_BOOST)'
  'extract_kyra:extract Kyra resources'
  'extract_loom_tg16:extract Loom (TG16)'
  'extract_mm_apple:extract Maniac Mansion (Apple)'
  'extract_mm_c64:extract Maniac Mansion (C64)'
  'extract_mm_nes:extract Maniac Mansion (NES)'
  'extract_scumm_mac:extract SCUMM macintosh'
  'extract_zak_c64:extract Zak McKracken (C64)'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'scummvm-tools command' commands && ret=0 ;;
esac
return ret
