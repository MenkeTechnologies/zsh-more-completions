#compdef calyptia
# Documentation: https://docs.calyptia.com/
# Calyptia Cloud CLI for managing Fluent Bit core instances and pipelines

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--cloud-url=[Calyptia Cloud URL]:url' \
  '--token=[Calyptia Cloud project token]:token' \
  '*:command:(completion config create delete get help install rollout uninstall update version watch)' && ret=0

return ret
