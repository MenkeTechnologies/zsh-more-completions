#compdef pggb
# Documentation: https://github.com/pangenome/pggb
# pggb: the PanGenome Graph Builder

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-i+[input FASTA file]:file:_files' \
  '-o+[output directory]:dir:_files -/' \
  '-n+[number of haplotypes]:count' \
  '-t+[number of threads]:threads' \
  '-p+[minimum average nucleotide identity for segments]:percent' \
  '-s+[segment length for scaffolding the graph]:length' \
  '-k+[minimum match length threshold]:length' \
  '-V+[variant call parameters]:spec' \
  '(-l --block-length)'{-l+,--block-length=}'[length of collinear chains]:length' \
  '-P+[progressive smoothing parameters]:params' \
  '-G+[graph normalization settings]:params' \
  '-M+[generate MSA in MAF format]:spec' \
  '-x+[mapping sparsification]:value' \
  '(-m --multiqc)'{-m,--multiqc}'[generate MultiQC statistics report]' && ret=0

return ret
