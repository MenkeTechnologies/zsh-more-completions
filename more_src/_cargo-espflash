#compdef cargo-espflash

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'board-info:display information about the connected board'
      'completions:generate shell completions'
      'erase-flash:erase the entire flash'
      'erase-parts:erase specified partitions'
      'erase-region:erase a region of flash'
      'flash:flash an application to a target device'
      'hold-in-reset:hold the target in reset'
      'monitor:open a serial monitor'
      'partition-table:display partition table'
      'read-flash:read flash contents to a file'
      'reset:reset the target device'
      'save-image:save the application image to a file'
      'write-bin:write a binary file to flash'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    local -a common_args=(
      '(-p --port)'{-p,--port}'=[serial port]:port:_files -g "/dev/tty*"'
      '(-b --baud)'{-b,--baud}'=[serial baud rate]:baud:(115200 230400 460800 921600 1500000 2000000)'
      '(-c --chip)'{-c,--chip}'=[target chip]:chip:(esp32 esp32c2 esp32c3 esp32c6 esp32h2 esp32s2 esp32s3 esp8266)'
      '--before=[reset mode before operation]:mode:(default-reset no-reset no-reset-no-sync)'
      '--after=[reset mode after operation]:mode:(hard-reset no-reset no-reset-no-sync)'
      '--connect-attempts=[max connection attempts]:attempts:'
    )
    case ${words[1]} in
      (flash)
        _arguments \
          $common_args \
          '--release[use release profile]' \
          '--example=[build specific example]:example:' \
          '--features=[features to activate]:features:' \
          '--target=[target triple]:target:' \
          '--target-dir=[target directory]:dir:_files -/' \
          '(-T --partition-table)'{-T,--partition-table}'=[partition table file]:file:_files -g "*.csv"' \
          '--bootloader=[bootloader binary]:file:_files -g "*.bin"' \
          '(-M --monitor)'{-M,--monitor}'[open serial monitor after flash]' \
          '--monitor-baud=[monitor baud rate]:baud:' \
          '--erase-parts=[erase partitions before flash]:parts:' \
          '--erase-data-parts=[erase data partitions]:parts:' && ret=0
        ;;
      (monitor)
        _arguments \
          $common_args \
          '(-e --elf)'{-e,--elf}'=[ELF file for address decoding]:file:_files -g "*.elf"' && ret=0
        ;;
      (save-image)
        _arguments \
          $common_args \
          '--release[use release profile]' \
          '--example=[build specific example]:example:' \
          '--features=[features to activate]:features:' \
          '--merge[merge all binaries into single file]' \
          '--skip-padding[skip padding to flash size]' \
          '1:output file:_files -g "*.bin"' && ret=0
        ;;
      (erase-flash|reset|board-info|hold-in-reset)
        _arguments $common_args && ret=0
        ;;
      (read-flash)
        _arguments \
          $common_args \
          '--address=[start address]:address:' \
          '--size=[size to read]:size:' \
          '1:output file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
