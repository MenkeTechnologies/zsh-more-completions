#compdef treefmt
# Documentation: https://github.com/numtide/treefmt
# Reference accessed: 2026-05-21
# Verified: upstream docs (config/config.go SetFlags + cmd/root.go).

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--allow-missing-formatter[do not exit with error if a formatter is missing]' \
  '--ci[run in CI mode (--no-cache, --fail-on-change)]' \
  '(-c --clear-cache)'{-c,--clear-cache}'[reset the evaluation cache]' \
  '--config-file=[path to config file]:file:_files' \
  '--cpu-profile=[write CPU profile to file]:file:_files' \
  '*--excludes=[exclude paths matching globs]:glob' \
  '--fail-on-change[exit with error if any changes were made]' \
  '*'{-f,--formatters}'=[specify formatters to apply]:formatters' \
  '(-i --init)'{-i,--init}'[create a new treefmt.toml]' \
  '--no-cache[ignore the evaluation cache]' \
  '(-u --on-unmatched)'{-u,--on-unmatched}'=[log level for unmatched paths]:level:(debug info warn error fatal)' \
  '(-q --quiet)'{-q,--quiet}'[disable all logs except errors]' \
  '--stdin[format content passed via stdin]' \
  '--tree-root=[root directory]:dir:_directories' \
  '--tree-root-cmd=[command to find tree root]:cmd' \
  '--tree-root-file=[file to search for project root]:file' \
  '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
  '--walk=[walk method]:method:(auto git jujutsu filesystem)' \
  '(-C --working-dir)'{-C,--working-dir}'=[run as if started in path]:dir:_directories' \
  '--completion=[generate shell completion]:shell:(bash zsh fish)' \
  '*:path:_files'
