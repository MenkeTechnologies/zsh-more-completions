#compdef treefmt

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--allow-missing-formatter[do not exit with error if a formatter is missing]' \
  '(-C --working-directory)'{-C,--working-directory}'=[run as if started in path]:dir:_directories' \
  '--ci[fail if any changes were made]' \
  '--clear-cache[reset the evaluation cache]' \
  '--config-file=[path to config file]:file:_files' \
  '--fail-on-change[exit with error if any changes were made]' \
  '--formatters=[specify formatters to run]:formatters' \
  '--init[create a new treefmt.toml config]' \
  '--no-cache[ignore the evaluation cache]' \
  '--on-unmatched=[action for unmatched files]:action:(warn info debug fatal)' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--stdin[format stdin and write to stdout]' \
  '--tree-root=[root directory]:dir:_directories' \
  '--tree-root-file=[file to search for project root]:file' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--walk=[walk method]:method:(auto git filesystem)' \
  '*:path:_files'
