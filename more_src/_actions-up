#compdef actions-up
# Documentation: https://man.archlinux.org/search?q=actions-up
# Reference accessed: 2026-05-16

# actions-up — bumps pinned Actions SHAs; see `actions-up --help`

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--yes[non-interactive]' \
  '*:workflow files:_files' && ret=0

return ret
