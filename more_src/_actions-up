#compdef actions-up
# Documentation: https://github.com/azat-io/actions-up
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# actions-up — bumps pinned Actions SHAs; see `actions-up --help`

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--yes[non-interactive]' \
  '*:workflow files:_files' && ret=0

return ret
