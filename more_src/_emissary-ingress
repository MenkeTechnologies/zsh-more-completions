#compdef emissary-ingress
# Documentation: https://man.archlinux.org/search?q=emissary-ingress
# Reference accessed: 2026-05-16

# emissary-ingress: API gateway / Ingress for Kubernetes (Ambassador)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'ambex:run the ambex sidecar'
  'watt:run the watt configuration watcher'
  'kubestatus:show k8s resource status'
  'entrypoint:run the entrypoint process'
  'snapdump:dump snapshot'
  'snapdiag:compare snapshot diagnostics'
  'envoy:run embedded envoy'
  'agent:run service catalog agent'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config-base-id=[config base id]:id:' \
  '--debug[debug]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'emissary-ingress command' commands && ret=0 ;;
esac
return ret
