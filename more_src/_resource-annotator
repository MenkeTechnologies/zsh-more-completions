#compdef resource-annotator
# _resource-annotator — containers/nri-plugins admission webhook that copies resource-policy hints from pod annotations onto each container
# upstream: https://github.com/containers/nri-plugins
# Flags from cmd/resource-annotator/{main,config}.go on tip; env vars RESOURCE_ANNOTATOR_PORT / _CERT_FILE / _KEY_FILE also bind.

_resource-annotator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--port=[HTTPS port to listen on]:port:' \
        '--cert-file=[TLS certificate file]:file:_files' \
        '--key-file=[TLS certificate key file]:file:_files'
}

_resource-annotator "$@"
