#compdef rargs
# Documentation: https://man.archlinux.org/search?q=rargs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-p --pattern)'{-p,--pattern}'[regex pattern for parsing input]:pattern' \
  '(-d --delimiter)'{-d,--delimiter}'[delimiter for splitting input]:delimiter' \
  '(-w --worker)'{-w,--worker}'[number of workers]:num' \
  '(-e --escape)'{-e,--escape}'[shell escape mode]' \
  '-0[use NUL as input separator]' \
  '--read0[read input delimited by NUL]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:command template' && ret=0
return ret
