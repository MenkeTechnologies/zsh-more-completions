#compdef rargs
# Documentation: https://github.com/lotabout/rargs
# Reference accessed: 2026-05-17
# Verified: lotabout/rargs upstream (xargs + awk with regex).
# Real flag set: -p/--pattern, -d/--delimiter, -s/--separator,
# -w/--worker (alias -j), -0/--read0, -e/--eof, -n/--num-args,
# -I, -h/--help, -V/--version.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -e/--escape (real -e is --eof marker).

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --pattern)'{-p+,--pattern=}'[regex with capture groups]:regex:' \
  '(-d --delimiter)'{-d+,--delimiter=}'[regex delimiter for splitting input]:regex:' \
  '(-s --separator)'{-s+,--separator=}'[separator for ranged fields]:str:' \
  '(-w --worker -j)'{-w+,--worker=,-j+}'[concurrent workers (0=ncpus)]:n:' \
  '(-0 --read0)'{-0,--read0}'[NUL-delimited input]' \
  '(-e --eof)'{-e+,--eof=}'[EOF marker]:str:' \
  '(-n --num-args)'{-n+,--num-args=}'[max args per command]:n:' \
  '-I+[replace string]:repl:' \
  '*:command template:_command_names -e' && ret=0
return ret
