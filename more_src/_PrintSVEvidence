#compdef PrintSVEvidence
# Documentation: https://gatk.broadinstitute.org/hc/en-us/articles/360057440191-PrintSVEvidence-EXPERIMENTAL
# Prints structural variant evidence records, optionally merging and subsetting samples

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-F,--evidence-file}'=[input SV evidence feature file (.sr/.pe/.sd/.baf/.rd .txt or .bci)]:file:_files' \
  '(-O --output)'{-O,--output}'=[output file for features matching the input type]:file:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '*--sample-names=[sample names to extract (.list file or repeated)]:names:' \
  '*'{-L,--intervals}'=[genomic intervals to operate over]:intervals:' \
  '--compression-level=[output compression level (0-9)]:n:' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:file:_files' && ret=0

return ret
