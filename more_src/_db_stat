#compdef db_stat
# Documentation: db_stat usage (Berkeley DB 18.1.40)
# Source: print Berkeley DB environment / database statistics.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-a[show all info]' \
    '-c[show lock-region info]' \
    '-C+[lock-subsystem info flags]:flags:(A c l o p)' \
    '-d+[database file to display]:file:_files' \
    '-E[show env-region info]' \
    '-e[show env mutex info]' \
    '-f[fast statistics]' \
    '-h+[environment home]:dir:_files -/' \
    '-L+[log-region info]:flags:(A)' \
    '-l[show log info]' \
    '-M+[mpool flags Ah]:flags:(A h Ah)' \
    '-m[show mpool info]' \
    '-N[silent: do not acquire DB env lock]' \
    '-P+[password]:password:' \
    '-p+[region directory]:dir:_files -/' \
    '-R+[replication info]:flags:(A)' \
    '-r[show replication info]' \
    '-s+[database to display]:database:' \
    '-S+[verify ov]:flags:(o v ov)' \
    '-t[show txn info]' \
    '-x[show mutex info]' \
    '-X+[extra info flags]:flags:(A)' \
    '-Z[reset statistics after display]' \
    && ret=0

return ret
