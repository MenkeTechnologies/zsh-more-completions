#compdef casaos
# _casaos — CasaOS simple home-cloud OS CLI alias (IceWhaleTech team, Go); cobra
# upstream: https://github.com/IceWhaleTech/CasaOS

_casaos() {
    local -a sub=(
        'start:start casaos'
        'stop:stop casaos'
        'restart:restart casaos'
        'status:show status'
        'install:install service'
        'uninstall:uninstall service'
        'update:update casaos'
        'app:list:list apps'
        'app:install:install app'
        'app:uninstall:uninstall app'
        'app:start:start app'
        'app:stop:stop app'
        'app:restart:restart app'
        'app:logs:show app logs'
        'app:update:update app'
        'app:export:export app data'
        'app:import:import app data'
        'app-store:list:list app stores'
        'app-store:add:add app store'
        'app-store:remove:remove app store'
        'app-store:update:update app store'
        'user:list:list users'
        'user:create:create user'
        'user:delete:delete user'
        'user:passwd:change password'
        'sys:disk:list:list disks'
        'sys:disk:mount:mount disk'
        'sys:disk:umount:unmount disk'
        'sys:disk:format:format disk'
        'sys:share:list:list shares'
        'sys:share:add:add share'
        'sys:share:remove:remove share'
        'service:list:list services'
        'service:logs:show service logs'
        'log:show casaos logs'
        'config:get:get config value'
        'config:set:set config value'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config dir]:dir:_files -/' \
        '--log-level=+[log level]:l:(debug info warn error)' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'casaos subcommand' sub ;;
        args)
            case $words[1] in
                app:install|app:uninstall|app:start|app:stop|app:restart|app:logs|app:update|app:export|app:import) _arguments '1:app id:' ;;
                sys:disk:mount|sys:disk:umount|sys:disk:format) _arguments '1:device:_files -g "/dev/sd*"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_casaos "$@"
