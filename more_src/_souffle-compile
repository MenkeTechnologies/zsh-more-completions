#compdef souffle-compile
# Documentation: https://github.com/souffle-lang/souffle/blob/master/man/souffle-compile.1
# souffle-compile - compile the C++ source generated by souffle into an executable

local ret=1

_arguments -s -S \
  '(-h)-h[show help text]' \
  '(-g)-g[debug build type]' \
  '*-L+[search directory for functors libraries]:directory:_files -/' \
  '*-l+[basename of a functors library to link]:libname' \
  '-s+[generate SWIG interface for language]:language:(java python)' \
  '-o+[output binary file name]:binary:_files' \
  '(-v)-v[verbose output]' \
  '*:source:_files -g "*.cpp"' && ret=0

return ret
