#compdef moon

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new moon workspace'
  'run:run one or more tasks'
  'check:run all build and test tasks for a project'
  'ci:run affected tasks in a CI environment'
  'graph:display a graph in the browser'
  'query:query information about the workspace'
  'project:display information about a project'
  'project-graph:display the project graph'
  'action-graph:display the action graph'
  'sync:sync all projects in the workspace'
  'setup:setup the environment'
  'teardown:teardown the environment'
  'completions:generate shell completions'
  'clean:clean the workspace cache'
  'docker:manage Docker integration'
  'migrate:migrate from other tools'
  'upgrade:upgrade moon to the latest version'
  'ext:execute an extension plugin'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color[force colored output]' \
  '--log=[log level]:level:(off error warn info debug trace)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'moon command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--affected[only run against affected files]' \
          '--dependents[also run tasks for dependents]' \
          '--force[force run and ignore cache]' \
          '--interactive[run in interactive mode]' \
          '--log=[log level]:level:(off error warn info debug trace)' \
          '--profile=[record a CPU profile]:file:_files' \
          '--query=[filter projects using a query]:query' \
          '--status=[filter by task status]:status:(cached failed passed)' \
          '--summary[print a summary after running]' \
          '--update-cache[update the cache with the new output]' \
          '*:target' && ret=0
        ;;
      (check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--affected[only run against affected projects]' \
          '*:project' && ret=0
        ;;
      (ci)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--base=[base branch or commit]:ref' \
          '--head=[head branch or commit]:ref' && ret=0
        ;;
      (graph)
        local -a graph_cmds=(
          'dep:display the dependency graph'
          'project:display the project graph'
          'action:display the action graph'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:graph type:->graph_cmd' && ret=0
        case $state in
          (graph_cmd)
            _describe -t commands 'graph command' graph_cmds && ret=0
            ;;
        esac
        ;;
      (query)
        local -a query_cmds=(
          'projects:query for projects'
          'tasks:query for tasks'
          'touched-files:query for touched files'
          'hash:inspect a content hash'
          'hash-diff:diff two content hashes'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:query type:->query_cmd' && ret=0
        case $state in
          (query_cmd)
            _describe -t commands 'query command' query_cmds && ret=0
            ;;
        esac
        ;;
      (docker)
        local -a docker_cmds=(
          'setup:setup a Docker environment'
          'scaffold:scaffold project sources into Docker'
          'prune:prune unnecessary files for Docker'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:docker command:->docker_cmd' && ret=0
        case $state in
          (docker_cmd)
            _describe -t commands 'docker command' docker_cmds && ret=0
            ;;
        esac
        ;;
      (migrate)
        local -a migrate_cmds=(
          'from-turborepo:migrate from Turborepo'
          'from-package-json:migrate from package.json scripts'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:migrate command:->migrate_cmd' && ret=0
        case $state in
          (migrate_cmd)
            _describe -t commands 'migrate command' migrate_cmds && ret=0
            ;;
        esac
        ;;
      (project)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--json[output as JSON]' \
          '1:project id' && ret=0
        ;;
      (clean)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--lifetime=[clean cache older than lifetime]:lifetime' && ret=0
        ;;
      (completions)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash fish zsh)' && ret=0
        ;;
      (init|sync|setup|teardown|upgrade|project-graph|action-graph|ext)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
