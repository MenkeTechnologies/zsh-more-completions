#compdef linpeas linpeas.sh
# _linpeas — Carlos Polop PEASS-ng linpeas CLI Linux local privilege escalation enumeration shell script scanning misconfigurations SUID GTFO bins capabilities cron services kernel exploits docker container escape passwords for offensive security operations CTF privilege escalation training (Carlos Polop team, shell); getopt
# upstream: https://github.com/peass-ng/PEASS-ng

_linpeas() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a[full scan]' \
        '-s[stealth/superfast mode]' \
        '-S[superfast and superlight]' \
        '-q[quiet]' \
        '-n[do not check network connectivity]' \
        '-N[do not use color]' \
        '-D[debug]' \
        '-P+[password]:str:' \
        '-d+[discover hosts in network]:str:' \
        '-p+[ports to scan]:str:' \
        '-i+[interesting filenames regex]:str:' \
        '-r[regex search mode]' \
        '-e[execute extra tests]' \
        '-t[test connection to outside]' \
        '-w[wait for user input between checks]' \
        '-L+[force linpeas language]:l:(en es fr de zh)' \
        '-o+[output file]:file:_files' \
        '-W[write debug to file]' \
        '-c+[exclude check]:str:' \
        '*::'
}

_linpeas "$@"
