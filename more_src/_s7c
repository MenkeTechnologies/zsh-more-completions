#compdef s7c
# =============================================================================
# s7c — Thomas Mertes' SEED7 COMPILER — the canonical compiler
#        for the Seed7 programming language.  Seed7 is a high-
#        level general-purpose language created and continuously
#        maintained by Thomas Mertes (Vienna, Austria) since
#        1989-1990, with the first public release in 2005.
#        Seed7's defining feature is USER-DEFINABLE SYNTAX: the
#        language's grammar itself is described in Seed7 source
#        files, so user programs can DEFINE NEW STATEMENTS, NEW
#        OPERATORS, AND NEW SYNTAX FORMS that integrate seamlessly
#        into the parser.  This makes Seed7 an EXTENSIBLE
#        LANGUAGE in the strongest sense — every construct in
#        the standard library (loops, conditionals, declarations)
#        is itself defined in Seed7 source, not built into the
#        compiler.
#
#        s7c compiles Seed7 source files (.sd7) to C source,
#        which is then handed off to a C compiler (gcc/clang/
#        msvc/emcc) to produce a native executable.  The Seed7
#        runtime libraries (the .s7i interface files and their
#        compiled C counterparts in `../bin`) provide the
#        standard library — strings, files, networking, GUI,
#        database, regex, big integers, threading, etc — all
#        written in Seed7 itself.
#
# Author:  Thomas Mertes (Vienna, Austria) — solo author since
#          1990; PhD in computer science; designed Seed7 as a
#          research vehicle for EXTENSIBLE LANGUAGES that
#          maintain readability + safety while permitting users
#          to extend the syntax with new constructs.  Has worked
#          on Seed7 continuously for 35+ years.
# Source:  https://github.com/ThomasMertes/seed7
#          https://seed7.sourceforge.net/
# CLI:     prg/s7c.sd7 (the compiler binary source — written
#                       IN SEED7 itself, then bootstrapped via
#                       s7c.c which is a C version generated by
#                       a previous s7c).  The main() procedure
#                       hand-rolls argv processing using stdlib
#                       progs.s7i's `argv(PROGRAM)` function;
#                       each option is matched by string equality
#                       against the argv array.
# Library: Seed7 stdlib progs.s7i + scanstri.s7i
#          (progs.s7i provides `argv(PROGRAM)`, the function that
#           returns the argument array for the current program.
#           scanstri.s7i provides string-scanning primitives used
#           to parse option values like `-On` (optimization level)
#           and `-tx` (trace flags).  There is NO SEPARATE ARGV
#           PARSING LIBRARY — the compiler manually loops through
#           argv with `for index range 1 to length(argv(PROGRAM))`
#           and matches each flag prefix by hand.)
# License: GPL-2.0-or-later (s7c itself); LGPL-2.1-or-later
#          (Seed7 runtime libraries) — dual licensing chosen
#          to allow LGPL-licensed Seed7 programs while keeping
#          the compiler GPL.
# Status:  Active maintenance — Seed7 version 3.5 released 2026,
#          with new revisions every few months for 20+ years.
#          GitHub repo ThomasMertes/seed7 has 443+ stars
#          (modest GitHub presence reflects Seed7's pre-GitHub
#           SourceForge provenance — the SourceForge page has
#           been the primary distribution channel since 2005,
#           with thousands of cumulative downloads).
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 74TH LANGUAGE
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy welcomes
# its 74TH DOCUMENTED LANGUAGE — SEED7 (Thomas Mertes, 1989-present)
# — and its FIRST documented Seed7 CLI mechanism: the stdlib's
# `argv(PROGRAM)` function (defined in progs.s7i) combined with
# hand-rolled option dispatch using scanstri.s7i string-scanning.
# Taxonomy now spans 304 cross-language CLI library variants across
# 74 documented languages.
#
# Pattern: 3 leader bumps (R562 miette Rust → R563 goflags Go →
# R564 nopt TS-Node) followed by 1 NEW LANGUAGE (R565 Seed7 THIS).
# Leaderboard unchanged: Rust=48, Go=48, TypeScript-Node=48
# (three-way tie at 48 since R564 restored TS-Node).
#
# Seed7 is DISTINCT from every other documented language by being
# an EXTENSIBLE LANGUAGE in which the language's own grammar is
# defined IN ITS OWN SOURCE LIBRARY.  The closest comparable
# languages already documented:
#   - Wolfram Language (Mathics3 R549) — has extensible
#       symbolic-rewriting semantics, but the parser is fixed
#   - J (R557) — has dense operator notation but cannot add
#       new statement-level syntax
#   - Pyret (R561) — has user-definable operators but not
#       statement-level grammar extension
#   - Logtalk (R533) — has parametric objects but built atop
#       Prolog's fixed term grammar
# Seed7 allows GRAMMAR EXTENSIONS: a user can write
#
#     const ASSOCIATIVITY: best of := assoc_left;
#     const integer:      prio of := 5;
#     const proc: (in var integer: x) best (in integer: y) is func ...
#
# and immediately use `x best y` as a new infix operator with
# the declared associativity and precedence — the parser
# integrates the new operator into its operator-precedence
# tables at parse time.  This is FIRST documented language in
# the taxonomy with parse-time grammar extension via standard
# language constructs (vs Lisp macros, vs Forth IMMEDIATE words,
# vs Camlp4 preprocessors).
#
# -----------------------------------------------------------------------------
#
# WHAT IS SEED7 AND WHY IS IT THE 74TH LANGUAGE?
#
# Seed7 is a procedural + object-oriented + functional programming
# language whose distinguishing characteristics are:
#
#   1. USER-DEFINABLE STATEMENTS AND OPERATORS — Seed7's syntax
#      is described in Seed7 source files (.s7i in lib/) using
#      `syntax expr:` declarations that bind grammar rules to
#      Seed7 procedures.  Adding a new statement like FOREACH
#      requires no compiler change — the user writes:
#
#          syntax expr: .foreach.(().).in.(().).do.(().).end.foreach
#              is -> 25;
#          const proc: foreach (in var T: item) in (in array T: arr)
#              do (in proc: action) end foreach is func ...
#
#      and `foreach x in arr do ... end foreach` becomes a
#      first-class statement.  Every statement in Seed7's
#      standard library — `for`, `while`, `if`, `repeat`, `case`,
#      etc — is defined this way.  FIRST documented language
#      with user-extensible STATEMENT grammar in the taxonomy.
#
#   2. STATIC TYPING WITH FULL TYPE INFERENCE + GENERIC TYPES —
#      Seed7 is statically typed but rarely requires type
#      annotations on local variables (similar to Hindley-Milner
#      inference).  Generic types (`array T`, `hash [K] V`) are
#      handled by template instantiation at compile time, similar
#      to C++ templates but with cleaner syntax.  Compile-time
#      type checking is enforced rigorously — there is no
#      runtime `Any` type.
#
#   3. BIGINTEGERS BY DEFAULT — Seed7's `bigInteger` type
#      supports arbitrary-precision integers as a first-class
#      built-in (not via a separate library).  Multiplication,
#      division, and exponentiation of bigIntegers are part of
#      the standard library.  Many number-theory programs are
#      one-liners in Seed7.
#
#   4. STRONG SAFETY GUARANTEES — Seed7 enforces:
#         * Index checks on all array/string access (suppress
#           with `-si`)
#         * Range checks on all subtype assignments (`-sr`)
#         * Integer overflow checks on all arithmetic (`-so`)
#         * Division-by-zero checks (`-sd`)
#      These are ON BY DEFAULT.  Disabling them is a per-
#      compile decision via the `-sx` flag.  Compare:
#         * C: no checks
#         * Ada: range checks but no overflow by default
#         * Rust: overflow checks in debug only, off in release
#         * Seed7: all checks ON BY DEFAULT in both debug + release
#      FIRST documented language with all four classes of
#      runtime checks on by default.
#
#   5. COMPILES TO C — s7c emits portable C99 that compiles on
#      Linux/macOS/Windows/BSD via gcc, clang, MSVC, or emscripten
#      (via `-c emcc` for WebAssembly).  The C-backend approach
#      gives Seed7 access to every platform that has a C compiler
#      without needing language-specific code generators.
#
#   6. STDLIB AS LANGUAGE LIBRARY — Seed7's standard library
#      (lib/*.s7i) is enormous — 600+ source files covering
#      strings, files, networking (TCP/UDP/TLS), GUI (Xlib,
#      Win32, Cocoa abstraction in draw.s7i), database (MySQL,
#      PostgreSQL, SQLite, Oracle, DB2, Firebird in `database/`),
#      regex (regexp.s7i), big integers (bigint.s7i), big
#      floats (bigrat.s7i), Unicode (unicode.s7i), HTTP server
#      (http.s7i), 3D graphics (graph.s7i + draw.s7i).  ALL OF
#      THIS IS WRITTEN IN SEED7 ITSELF, calling into C
#      primitives via `external` declarations.
#
#   7. RESERVED WORDS DEFINED IN LIBRARY, NOT IN COMPILER — Even
#      reserved words like `for`, `while`, `if`, `then` are
#      defined in lib/seed7_05.s7i via `syntax expr:` rules.
#      The compiler proper (s7c.sd7 + the C runtime) only knows
#      how to tokenize identifiers, numbers, strings, and a few
#      bracket/punctuation tokens; the GRAMMAR is loaded from
#      seed7_05.s7i at compile time.  This is the deepest
#      sense of "extensible language" — even the core grammar
#      is user-replaceable.
#
# Use cases for Seed7:
#   * Number theory, combinatorics, mathematical programs
#     (bigInteger first-class, safe arithmetic)
#   * Embedded DSLs (extensible grammar lets you define DSL
#     syntax that integrates seamlessly)
#   * Cross-platform GUI applications (draw.s7i abstracts
#     Xlib/Win32/Cocoa)
#   * Database scripting (one connection-string API across
#     6 RDBMS backends)
#   * WebAssembly programs (via `-c emcc`)
#   * Educational use — teaching grammar/parser construction,
#     since every grammar rule is visible in lib/*.s7i
#
# -----------------------------------------------------------------------------
#
# THE s7c CLI — handcoded option dispatch via stdlib argv(PROGRAM)
#
# s7c's argv parsing is in prg/s7c.sd7's `main` procedure,
# which loops through argv using `argv(PROGRAM)` (a Seed7 stdlib
# function from progs.s7i):
#
#     const proc: main is func
#       local
#         var integer: index is 0;
#         var string: currArg is "";
#         var optionHash: compilerOptions is optionHash.value;
#         var string: source is "";
#         var boolean: okay is TRUE;
#       begin
#         if length(argv(PROGRAM)) = 0 then
#           writeln("usage: s7c [options] source");
#         else
#           for index range 1 to length(argv(PROGRAM)) do
#             currArg := argv(PROGRAM)[index];
#             if startsWith(currArg, "-") then
#               if currArg in {"-b", "-c", "-S"} and
#                   index < length(argv(PROGRAM)) then
#                 incr(index);
#                 compilerOptions @:= [currArg] argv(PROGRAM)[index];
#               elsif currArg in {"-l"} and
#                   index < length(argv(PROGRAM)) then
#                 incr(index);
#                 libraryDirs &:= convDosPath(argv(PROGRAM)[index]);
#               else
#                 if currArg not in compilerOptions then
#                   if length(currArg) > 2 then
#                     compilerOptions @:= [currArg[.. 2]] currArg[3 ..];
#                   else
#                     compilerOptions @:= [currArg] "";
#                   end if;
#                 else
#                   if length(currArg) > 2 then
#                     writeln("*** Option " <& currArg[.. 2] <&
#                         " specified twice.");
#                   else
#                     writeln("*** Option " <& currArg <&
#                         " specified twice.");
#                   end if;
#                   okay := FALSE;
#                 end if;
#               end if;
#             else
#               source := currArg;
#             end if;
#           end for;
#           # ... process compilerOptions hash ...
#         end if;
#       end func;
#
# Five-axis distinctness from every other documented CLI parser:
#
#   1. ARGV ACCESS VIA SPECIAL `argv(PROGRAM)` FUNCTION — Seed7
#      exposes argv via the function call `argv(PROGRAM)` where
#      PROGRAM is a special object representing the currently
#      executing program.  This abstraction lets Seed7 programs
#      manipulate ARGV FOR SUB-PROGRAMS (since `argv(some_prog)`
#      can also return another program's argv).  No other
#      documented argv access mechanism abstracts to per-program
#      objects this way.
#
#   2. NO SEPARATE PARSING LIBRARY — Seed7 has no canonical
#      argv parsing library — every Seed7 program rolls its
#      own dispatch.  This is similar to early C (no getopt),
#      but distinct from EVERY other modern language in the
#      taxonomy.
#
#   3. PARSE-TIME GRAMMAR EXTENSION ENABLES DSL-FRIENDLY CLIs —
#      Because Seed7 supports adding new statements at parse
#      time, a user could (in principle) define a `cli option`
#      statement that registers flags declaratively.  In
#      practice no one has built this; the convention is
#      hand-rolled dispatch.
#
#   4. COMPILED-TO-C MEANS ZERO-DEPENDENCY BINARIES — Seed7
#      programs that parse argv produce native binaries with
#      no Seed7 runtime dependency at install time (the runtime
#      libraries are linked into the binary or shipped alongside).
#      Contrast with Python/Ruby/Node argv parsers which require
#      a runtime interpreter at runtime.
#
#   5. STDLIB IS THE LIBRARY — Even Seed7's lowest-level argv
#      access (the `argv` function itself) is declared in
#      lib/progs.s7i — there is no separately versioned
#      "argv library" external to the language.  Argv access
#      is just another stdlib function.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/ThomasMertes/seed7/blob/master/prg/s7c.sd7
# writeHelp procedure circa lines 8932-8975.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[write Seed7 compiler usage]' \
    '-?[write Seed7 compiler usage]' \
    '-O0[no C optimization]' \
    '-O[optimize C output at level 1 (equivalent to -O1)]' \
    '-O1[optimize C output at level 1]' \
    '-O2[optimize C output at level 2]' \
    '-O3[optimize C output at level 3]' \
    '-S+[specify executable stack size in bytes]:size:' \
    '-b+[specify directory of Seed7 runtime libraries]:directory:_directories' \
    '-c+[specify C compiler config (e.g. gcc/clang/emcc)]:compiler:(gcc clang emcc cl msvc tcc cc)' \
    '-e[generate signal-emitting code for uncaught exceptions]' \
    '-flto[enable link-time optimization]' \
    '-g[generate executable with debug information]' \
    '-g-debug_c[generate debug info referring to temporary C program]' \
    '-l+[add directory to include library search path]:directory:_directories' \
    '-oc0[no constant-folding optimization in generated C]' \
    '-oc1[constant-folding with literals (default)]' \
    '-oc2[constant-folding incl. parameter expressions]' \
    '-oc3[constant-folding incl. all constant expressions]' \
    '-p[activate simple function profiling]' \
    '-sd[suppress integer division-by-zero checks]' \
    '-si[suppress index checks (string/array)]' \
    '-so[suppress integer overflow checks]' \
    '-sr[suppress range checks]' \
    '-td[trace dynamic calls]' \
    '-te[trace exceptions and handlers]' \
    '-tf[trace functions]' \
    '-ts[trace signals]' \
    '-w0[omit warnings]' \
    '-w1[write normal warnings (default)]' \
    '-w2[write warnings for raised exceptions]' \
    '*:source file:_files -g "*.sd7"' \
    && ret=0

return ret
