#compdef tmux-xpanes xpanes
# Documentation: https://github.com/greymd/tmux-xpanes
# Reference accessed: 2026-05-21
# Verified: upstream README OPTIONS list.

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[command template for each pane]:command:' \
  '*-B+[begin-command run before main command]:cmd:' \
  '-I+[placeholder string in commands]:placeholder:' \
  '-e[execute arguments as-is]' \
  '-C+[number of columns]:cols:' \
  '--cols=[number of columns]:cols:' \
  '-R+[number of rows]:rows:' \
  '--rows=[number of rows]:rows:' \
  '-l+[layout preset]:layout:(t eh ev mh mv mhm mvm)' \
  '--bulk-cols=[columns for multiple rows]:cols:' \
  '(-d --desync)'{-d,--desync}'[disable synchronized input]' \
  '-s[speedy mode (no interactive shell)]' \
  '-ss[speedy mode with auto pane closure]' \
  '-t[display arguments as pane titles]' \
  '-x[create panes in current window]' \
  '-r[create or reuse panes]' \
  '-n+[max args per pane]:n:' \
  '-S+[tmux socket path]:socket:_files' \
  '--log=[enable logging (optional directory)]::dir:_directories' \
  '--log-format=[log filename format]:format:' \
  '--ssh[SSH shorthand]' \
  '--stay[do not switch to new window]' \
  '--interval=[seconds between pane creation]:seconds:' \
  '--debug[print debug messages]' \
  '*:arguments'
