#compdef dawn
# Documentation: https://www.rubydoc.info/gems/dawnscanner
# dawn static analysis security scanner for ruby web applications

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help]' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '(-G --gem-lock)'{-G,--gem-lock}'[scan only dependencies in Gemfile.lock (deprecated)]' \
  '(-d --dependencies)'{-d,--dependencies}'[scan only dependencies in Gemfile.lock]' \
  '(-a --ascii-tabular-report)'{-a,--ascii-tabular-report}'[format findings using ascii art tables (deprecated)]' \
  '(-j --json)'{-j,--json}'[format findings using json]' \
  '(-K --console)'{-K,--console}'[format findings using plain ascii text]' \
  '(-C --count-only)'{-C,--count-only}'[count vulnerabilities only]' \
  '(-z --exit-on-warn)'{-z,--exit-on-warn}'[return number of found vulnerabilities as exit code]' \
  '(-F --file)'{-F,--file}'[write output to filename]:file:_files' \
  '(-c --config-file)'{-c,--config-file}'[load configuration from filename]:file:_files' \
  '(-D --debug)'{-D,--debug}'[enter dawn debug mode]' \
  '(-V --verbose)'{-V,--verbose}'[more verbose output]' \
  '*:target:_files -/' && ret=0

return ret
