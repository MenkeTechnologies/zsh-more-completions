#compdef craftcms craft
# _craftcms — Pixel & Tonic Craft CMS console CLI bin/craft for managing Craft 3/4/5 CMS installations queues garbage collection cache flushing migration installation plugin and user (craftcms team, PHP); Yii Console
# upstream: https://github.com/craftcms/cms

_craftcms() {
    local -a sub=(
        'cache:cache operations'
        'install:install operations'
        'project-config:project config operations'
        'queue:queue operations'
        'gc:garbage collection'
        'index-assets:index assets'
        'invalidate-tags:invalidate tag dependencies'
        'migrate:migration operations'
        'plugin:plugin operations'
        'restore:restore from backup'
        'serve:built-in PHP server'
        'setup:setup operations'
        'shell:open Tinkerwell shell'
        'tests:run tests'
        'update:update operations'
        'user:user operations'
        'utils:utility operations'
        'mailer:mailer operations'
        'help:show help'
        'list:list commands'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[non-interactive]' \
        '--non-interactive[non-interactive]' \
        '--color=+[mode]:m:(auto on off)' \
        '--interactive=+[b]:b:(0 1)' \
        '--silent-exit-on-exception[silent exit on exception]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'craftcms subcommand' sub ;;
        args)
            case $words[1] in
                cache) _arguments '1:action:(flush flush-all flush-schema index)' ;;
                queue) _arguments '1:action:(info release run listen restart)' ;;
                plugin) _arguments \
                    '1:action:(install uninstall enable disable update)' \
                    '*:plugin handle:' ;;
                user) _arguments \
                    '1:action:(create login impersonate logout-all set-password)' ;;
                migrate) _arguments \
                    '1:action:(up down create fresh history mark redo)' \
                    '--type=+[t]:t:(app plugin content)' \
                    '--plugin=+[handle]:str:' ;;
                project-config) _arguments \
                    '1:action:(apply diff get rebuild remove set touch write)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_craftcms "$@"
