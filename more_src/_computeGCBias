#compdef computeGCBias
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/computeGCBias.html
# deepTools: determine GC bias in sequencing data using Benjamini's method

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bamfile)'{-b,--bamfile}'[BAM file to process]:bam:_files -g "*.bam"' \
  '--effectiveGenomeSize[mappable genome size]:size:' \
  '(-g --genome)'{-g,--genome}'[genome in 2bit format]:file:_files -g "*.2bit"' \
  '(-freq -o --GCbiasFrequenciesFile)'{-freq,-o,--GCbiasFrequenciesFile}'[output frequencies file]:file:_files' \
  '(-l --fragmentLength)'{-l,--fragmentLength}'[fragment length]:length:' \
  '--sampleSize[number of reads to sample]:n:' \
  '--extraSampling[BED file of extra sampling regions]:file:_files' \
  '(-r --region)'{-r,--region}'[genomic region to process]:region:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[BED/GTF file of regions to exclude]:file:_files' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show version]' \
  '--biasPlot[diagnostic bias plot output file]:file:_files' \
  '--plotFileFormat[output file format]:format:(png pdf svg eps plotly)' \
  '--regionSize[region size for plotting]:size:' && ret=0

return ret
