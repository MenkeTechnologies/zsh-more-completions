#compdef partialator
# Documentation: https://www.desy.de/~twhite/crystfel/manual-partialator.html
# Scaling and post-refinement merge of serial crystallography data (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-i --input)'{-i+,--input=}'[input stream file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-y --symmetry)'{-y+,--symmetry=}'[merge according to point group]:pointgroup:' \
  '(-n --iterations)'{-n+,--iterations=}'[cycles of scaling/post-refinement]:n:' \
  '(-m --model)'{-m+,--model=}'[partiality model]:model:(xsphere unity offset ggpm)' \
  '-j+[run n analyses in parallel]:n:' \
  '-w+[apparent symmetry of crystals]:pg:' \
  '--no-scale[disable scaling]' \
  '--no-Bscale[disable Debye-Waller scaling]' \
  '--no-pr[disable post-refinement]' \
  '--no-deltacchalf[disable deltaCChalf rejection]' \
  '--polarisation=[incident radiation polarisation]:type:' \
  '--no-polarisation[synonym for --polarisation=none]' \
  '--max-adu=[include reflections below this peak value]:n:' \
  '--min-res=[merge crystals beyond this resolution]:n:' \
  '--min-measurements=[min times a reflection must appear]:n:' \
  '--push-res=[merge beyond resolution limit, nm^-1]:n:' \
  '--start-after=[ignore first n crystals]:n:' \
  '--stop-after=[stop after n crystals]:n:' \
  '--no-free[disable cross-validation]' \
  '--custom-split=[read filenames, event and dataset IDs]:file:_files' \
  '--max-rel-B=[reject crystals above relative B threshold]:n:' \
  '--output-every-cycle[write lists after every cycle]' \
  '--no-logs[do not write log files]' \
  '--log-folder=[log folder location]:dir:_files -/' \
  '--operator=[indexing ambiguity operator]:op:' \
  '--force-bandwidth=[override X-ray bandwidth]:bw:' \
  '--force-radius=[override initial profile radius]:R:' \
  '--force-lambda=[override wavelength in Angstroms]:l:' \
  '--harvest-file=[write parameters JSON to file]:file:_files' \
  '--unmerged-output=[write unmerged intensities to file]:file:_files' && ret=0

return ret
