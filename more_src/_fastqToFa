#compdef fastqToFa
# convert from fastq to fasta format

local ret=1

_arguments -s -S \
  '-nameVerify=[string that must match within sequence names (multi-line fastq)]:string' \
  '-qual=[output quality scores to specified file]:qual file:_files' \
  '-qualSizes=[write sizes file for quality scores]:sizes file:_files' \
  '-noErrors[warn on problems without exiting]' \
  '-solexa[use Solexa/Illumina quality score algorithm]' \
  '1:in fastq:_files -g "*.(fastq|fq)"' \
  '2:out fa:_files' && ret=0

return ret
