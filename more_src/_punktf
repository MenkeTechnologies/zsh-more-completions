#compdef punktf
# Documentation: https://github.com/Shemnei/punktf
# punktf - a cross-platform multi-target dotfiles manager

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
  '(-q --quite)'{-q,--quite}'[reduce output to errors only]' \
  '--json-output=[write a json report to file]:file:_files' \
  '--yaml-output=[write a yaml report to file]:file:_files' \
  '(-s --source)'{-s,--source}'=[path to the source/dotfiles directory]:dir:_files -/' \
  '1:command:(deploy render verify diff man completions)' \
  '*::arg:->args' && ret=0

return ret
