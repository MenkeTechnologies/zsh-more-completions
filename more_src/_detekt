#compdef detekt detekt-cli

# Zsh completion for detekt - Kotlin static code analyzer

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-v --version)'{-v,--version}'[show detekt version]'
  '(-i --input)'{-i,--input}'[input paths]:path:_files'
  '--includes[include patterns]:pattern:'
  '--excludes[exclude patterns]:pattern:'
  '(-c --config)'{-c,--config}'[path to config file]:file:_files -g "*.(yml|yaml)"'
  '--config-resource[resource name of config]:name:'
  '--create-baseline[create baseline file]'
  '-gs --generate-config[generate a default config file]'
  '(-b --baseline)'{-b,--baseline}'[baseline file]:file:_files -g "*.xml"'
  '(-r --report)'{-r,--report}'[report spec (kind:path)]:report:'
  '-cl[classpath for type resolution]:path:'
  '--classpath[classpath for type resolution]:path:'
  '(-lang --language-version)'{-lang,--language-version}'[Kotlin language version]:version:(1.4 1.5 1.6 1.7 1.8 1.9 2.0 2.1)'
  '(-api --api-version)'{-api,--api-version}'[Kotlin API version]:version:(1.4 1.5 1.6 1.7 1.8 1.9 2.0 2.1)'
  '--jvm-target[JVM target version]:version:(1.6 1.8 9 11 17 21)'
  '--jdk-home[JDK home]:dir:_files -/'
  '--all-rules[activate all available rules]'
  '--build-upon-default-config[inherit from default config]'
  '--disable-default-rulesets[disable default rulesets]'
  '--fail-on-severity[fail on severity]:severity:(never minimum error warning info)'
  '--auto-correct[autocorrect code issues]'
  '--max-issues[maximum tolerated issues]:n:'
  '(-d --debug)'{-d,--debug}'[debug output]'
  '--parallel[enable parallel analysis]'
  '--plugins[plugin jar paths]:paths:'
)

_arguments -s $arguments
