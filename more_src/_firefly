#compdef firefly firefly-iii
# _firefly — James Cole Firefly III free open-source self-hosted personal finance manager artisan CLI (firefly-iii team, PHP/Laravel); symfony console
# upstream: https://github.com/firefly-iii/firefly-iii

_firefly() {
    local -a sub=(
        'list:list commands'
        'help:show help for command'
        'about:show framework info'
        'serve:start dev server'
        'tinker:php shell'
        'cache:clear:clear cache'
        'config:cache:cache config'
        'config:clear:clear config cache'
        'route:list:list routes'
        'view:cache:cache views'
        'view:clear:clear view cache'
        'migrate:run migrations'
        'migrate:fresh:wipe and migrate'
        'migrate:rollback:rollback migrations'
        'migrate:reset:reset migrations'
        'migrate:refresh:refresh database'
        'migrate:install:install migrations table'
        'db:seed:seed database'
        'queue:work:process queued jobs'
        'queue:listen:listen to queue'
        'queue:restart:restart workers'
        'schedule:run:run scheduled tasks'
        'schedule:work:run scheduler loop'
        'firefly-iii:create-export:create export job'
        'firefly-iii:export-data:export user data'
        'firefly-iii:upgrade-database:database upgrade'
        'firefly-iii:correct-database:correct database'
        'firefly-iii:report-empty-objects:report empties'
        'firefly-iii:backup:backup database'
        'firefly-iii:laravel-passport-keys:generate passport keys'
        'firefly-iii:create-user:create a user'
        'firefly-iii:delete-user:delete a user'
        'firefly-iii:scan-attachments:scan attachments'
        'firefly-iii:set-currencies:set currencies'
        'firefly-iii:recurring:run recurring transactions'
        'firefly-iii:rules:run rules'
        'firefly-iii:webhooks:run webhooks'
        'passport:install:install oauth keys'
        'storage:link:link storage'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--env=+[environment]:str:' \
        '--no-interaction[no interactive prompts]' \
        '-n[no interactive prompts]' \
        '--ansi[force ansi]' \
        '--no-ansi[disable ansi]' \
        '--quiet[no output]' \
        '-q[no output]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-vvv[debug verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'firefly subcommand' sub ;;
    esac
}

_firefly "$@"
