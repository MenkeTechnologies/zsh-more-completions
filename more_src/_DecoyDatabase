#compdef DecoyDatabase
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: create a decoy peptide/protein database from a FASTA file

local ret=1

_arguments -s -S \
  '*-in[input FASTA file(s)]:input file:_files' \
  '-out[output FASTA file]:output file:_files' \
  '-decoy_string[string to mark decoys]:string:' \
  '-decoy_string_position[position of decoy marker]:position:(prefix suffix)' \
  '-only_decoy[write only decoy proteins]' \
  '-type[sequence type]:type:(protein RNA)' \
  '-method[decoy generation method]:method:(reverse shuffle)' \
  '-enzyme[enzyme for digestion]:enzyme:' \
  '-shuffle_max_attempts[maximum shuffling attempts]:n:' \
  '-shuffle_sequence_identity_threshold[identity threshold for re-shuffling]:threshold:' \
  '-shuffle_decoy_ratio[target-to-decoy size ratio]:ratio:' \
  '-seed[random seed]:seed:' \
  '-NeighborSearch:in_relevant_proteins[relevant proteins for neighbor search]:file:_files' \
  '-NeighborSearch:out_neighbor[output file for neighbor peptides]:file:_files' \
  '-NeighborSearch:out_relevant[output target+decoy of relevant peptides]:file:_files' \
  '-NeighborSearch:missed_cleavages[missed cleavages]:n:' \
  '-NeighborSearch:mz_bin_size[m/z bin size]:size:' \
  '-NeighborSearch:pc_mass_tolerance[mass tolerance]:tolerance:' \
  '-NeighborSearch:pc_mass_tolerance_unit[tolerance unit]:unit:(Da ppm)' \
  '-NeighborSearch:min_peptide_length[minimum peptide length]:n:' \
  '-NeighborSearch:min_shared_ion_fraction[ion overlap threshold]:fraction:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
