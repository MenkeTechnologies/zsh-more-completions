#compdef fwupd-refresh

# fwupd-refresh: refresh metadata for fwupd (cron helper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-v[verbose output]' \
  '--force[force refresh even if recent]' \
  '*::fwupd-refresh args:_files' && ret=0
return ret
