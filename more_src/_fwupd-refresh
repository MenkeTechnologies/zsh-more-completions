#compdef fwupd-refresh
# Documentation: https://man.archlinux.org/search?q=fwupd-refresh
# Reference accessed: 2026-05-16

# fwupd-refresh: systemd timer helper that runs `fwupdmgr refresh --force`
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--force[refresh even if metadata is current]' \
  '*::fwupd-refresh args:_files' && ret=0
return ret
