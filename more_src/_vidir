#compdef vidir
# _vidir — moreutils vidir (interactively edit a directory listing in $EDITOR: renames, deletes, and reorders are applied based on edits to a "number<TAB>path" table; -v prints applied changes)
# upstream: https://salsa.debian.org/built-using-team/moreutils (joeyh)
# Flags from moreutils vidir.pl on tip.

_vidir() {
    _arguments \
        '-v[verbose - print changes as they happen]' \
        '*:directory:_files -/'
}

_vidir "$@"
