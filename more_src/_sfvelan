#compdef sfvelan
# Documentation: http://www.ahay.org/RSF/sfvelan.html
# Madagascar: velocity analysis

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'cmp=[auxiliary CMP input file]:file:_files' \
  'offset=[auxiliary offset input file]:file:_files' \
  'useoffset=[if irregular offset, pass it]' \
  'half=[half or full offset?]' \
  '*:RSF file:_files' && ret=0

return ret
