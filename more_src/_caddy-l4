#compdef caddy-l4
# Documentation: https://man.archlinux.org/search?q=caddy-l4
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run caddy with layer 4 module'
  'start:start in background'
  'stop:stop running instance'
  'reload:reload config'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'caddy-l4 command' commands && ret=0 ;;
esac

return ret
