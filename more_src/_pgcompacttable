#compdef pgcompacttable

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'+[verbose level]:level:(0 1 2 3 4)' \
  '(--man)--man[show man page]' \
  '(-H --host)'{-H,--host}'+[host]:host:_hosts' \
  '(-P --port)'{-P,--port}'+[port]:port:' \
  '(-U --user)'{-U,--user}'+[user]:user:' \
  '(-W --password)'{-W,--password}'+[password]:pw:' \
  '(-d --dbname)'{-d,--dbname}'+[database name]:db:' \
  '(-a --all)'{-a,--all}'[all databases]' \
  '(-D --excludedb)'{-D,--excludedb}'+[exclude database]:db:' \
  '(-n --schema)'{-n,--schema}'+[schema name]:schema:' \
  '(-N --excludeschema)'{-N,--excludeschema}'+[exclude schema]:schema:' \
  '(-t --table)'{-t,--table}'+[table name]:table:' \
  '(-T --excludetable)'{-T,--excludetable}'+[exclude table]:table:' \
  '(-c --max-pages-per-round)'{-c,--max-pages-per-round}'+[max pages]:n:' \
  '(-r --routine-vacuum)'{-r,--routine-vacuum}'[run routine VACUUM]' \
  '(-s --delay)'{-s,--delay}'+[delay sec]:sec:' \
  '(-o --noanalyze)'{-o,--noanalyze}'[do not analyze]' \
  '(-O --no-pgstattuple)'{-O,--no-pgstattuple}'[do not use pgstattuple]' \
  '(-i --no-initial-vacuum)'{-i,--no-initial-vacuum}'[skip initial vacuum]' \
  '(-l --logger)'{-l,--logger}'+[log file]:file:_files' \
  '(-S --autostatdelay)'{-S,--autostatdelay}'+[auto-stat delay sec]:sec:' && ret=0

return ret
