#compdef afsctool
# Documentation: https://man.archlinux.org/search?q=afsctool
# Reference accessed: 2026-05-16

# Zsh completion for afsctool (HFS+ compression)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-d -c)-v[list compression attributes]' \
  '(-v -c)-d[decompress file in place]' \
  '(-v -d)-c[compress file in place]' \
  '*:path:_files' && ret=0

return ret
