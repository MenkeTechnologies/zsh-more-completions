#compdef cargo-sweep
# Documentation: https://github.com/holmgr/cargo-sweep (src/cli.rs clap)
# Reference accessed: 2026-05-29
# cargo-sweep — clean unused build files in a Cargo target directory. Required criterion group:
# exactly one of --stamp/--file/--all/--time/--installed/--toolchains/--maxsize.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '(-d --dry-run)'{-d,--dry-run}'[dry-run, do not delete any files]' \
  '(-f --file)'{-f,--file=}'[load timestamp file at the given path, clean everything older]:path:_files' \
  '--hidden[also recurse into hidden directories starting with .]' \
  '(-i --installed)'{-i,--installed}'[keep only artifacts made by rustup-installed toolchains]' \
  '(-m --maxsize)'{-m,--maxsize=}'[remove oldest artifacts until target is below MAXSIZE (MB)]:MB:' \
  '(-r --recursive)'{-r,--recursive}'[apply on all projects below the given path]' \
  '(-s --stamp)'{-s,--stamp=}'[store timestamp file at the given path]:path:_files' \
  '(-t --time)'{-t,--time=}'[delete artifacts older than N days]:days:' \
  '(-a --all)'{-a,--all}'[apply on all provided projects (delete entire target dir)]' \
  '--toolchains=[CSV list of rustup toolchains whose artifacts to keep]:toolchains:' \
  '*'{-v,--verbose}'[verbose (stackable: -v debug, -vv trace)]' \
  '*:path:_directories' \
  && ret=0

return ret
