#compdef cargo-sweep

_cargo-sweep() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s -S \
        '--stamp[Stamp the current time for future cleanup]' \
        '--file[Sweep files older than the timestamp in the given file]:file:_files' \
        {-t,--time}'[Number of days to keep build artifacts]:days:' \
        {-i,--installed}'[Remove artifacts from toolchains not currently installed]' \
        '--toolchains[Remove artifacts from specific toolchains]:toolchains:' \
        {-m,--maxsize}'[Maximum size of the target directory in MB]:size:' \
        {-r,--recursive}'[Sweep all projects below the given path]' \
        {-d,--dry-run}'[Dry-run, display what would be deleted]' \
        {-v,--verbose}'[Use verbose output]' \
        '--hidden[Include hidden directories in recursive sweep]' \
        {-h,--help}'[Print help information]' \
        {-V,--version}'[Print version information]' \
        ':path:_directories' && ret=0

    return ret
}

_cargo-sweep "$@"
