#compdef FloatTetwild_bin
# Documentation: https://github.com/wildmeshing/fTetWild
# FloatTetwild_bin - fast tetrahedral meshing in the wild (fTetWild)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[input surface mesh]:file:_files -g "*.{off,obj,stl,ply}"' \
  '(-o --output)'{-o,--output}'[output tetmesh .msh]:file:_files -g "*.msh"' \
  '(-l --lr)'{-l,--lr}'[edge length scaling factor (default 0.05)]:value:' \
  '(-a --la)'{-a,--la}'[absolute edge length value]:value:' \
  '(-e --epsr)'{-e,--epsr}'[envelope size relative to bbox diagonal (default 1e-3)]:value:' \
  '--stop-energy[halt optimization at max energy threshold]:value:' \
  '--skip-simplify[bypass preprocessing]' \
  '--coarsen[reduce output mesh density maximally]' \
  '--smooth-open-boundary[apply Laplacian smoothing to open regions]' \
  '--manifold-surface[enforce manifold output topology]' \
  '--no-binary[export ASCII instead of binary]' \
  '--no-color[exclude color information]' \
  '(-q --is-quiet)'{-q,--is-quiet}'[suppress console output]' \
  '--level[logging verbosity (0 verbose, 6 silent)]:level:' \
  '--log[write logs to file]:file:_files' \
  '--bg-mesh[apply sizing field from background mesh]:file:_files' \
  '--max-threads[parallel processing thread limit]:n:' \
  '*:input surface mesh:_files -g "*.{off,obj,stl,ply}"' && ret=0

return ret
