#compdef slappasswd
# _slappasswd — OpenLDAP slappasswd (generate userPassword hash strings using one of the supported schemes; -h scheme ({SSHA}|{SHA}|{SMD5}|{MD5}|{CRYPT}|{CLEARTEXT}|{ARGON2}), -s plaintext, -T new password file, -c crypt-style salt, -n no newline, -g use generated salt, -v verbose, -V version)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slappasswd)
# Flags from OpenLDAP servers/slapd/slappasswd.c on tip.

_slappasswd() {
    _arguments \
        '-h+[scheme]:scheme:(\{SSHA\} \{SHA\} \{SMD5\} \{MD5\} \{CRYPT\} \{CLEARTEXT\} \{ARGON2\})' \
        '-s+[plaintext password]:password:' \
        '-T+[new password file]:file:_files' \
        '-c+[crypt salt]:salt:' \
        '-n[no newline]' \
        '-g[generate salt]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-o+[option=value]:opt:'
}

_slappasswd "$@"
