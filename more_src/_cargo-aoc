#compdef cargo-aoc
# Documentation: https://github.com/gobanos/cargo-aoc
# Source: gobanos/cargo-aoc cargo-aoc/src/main.rs — cargo helper for Advent of Code.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _aoc_cmds
_aoc_cmds=(
    'bench:run benchmarks for a given day'
    'credentials:set the session cookie'
    'input:download the input for a given day'
)

_arguments -C \
    '(-d --day)'{-d+,--day=}'[specify the day (defaults to last implemented)]:day:_default' \
    '(-p --part)'{-p+,--part=}'[specify the part (defaults to both)]:part:(1 2)' \
    '(-i --input)'{-i+,--input=}'[use an alternate input file]:file:_files' \
    '--profile[add debug info for profiling tools]' \
    '(-g --generate)'{-g,--generate}'[generate boilerplate for the given day]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'cargo-aoc command' _aoc_cmds && ret=0
        ;;
    args)
        case $words[1] in
            bench)
                _arguments \
                    '(-d --day)'{-d+,--day=}'[specify the day]:day:_default' \
                    '(-p --part)'{-p+,--part=}'[specify the part]:part:(1 2)' \
                    '(-i --input)'{-i+,--input=}'[use an alternate input file]:file:_files' \
                    '(-o --open)'{-o,--open}'[open the benchmark report in the browser]' \
                    '(-g --generator)'{-g,--generator}'[also benchmark generator functions]' \
                    '--profile[add debug info for profiling tools]' \
                    && ret=0
                ;;
            input)
                _arguments \
                    '(-d --day)'{-d+,--day=}'[specify the day]:day:_default' \
                    '(-y --year)'{-y+,--year=}'[specify the year]:year:_default' \
                    '(-a --all)'{-a,--all}'[download all possible inputs for a year]' \
                    '(-g --generate)'{-g,--generate}'[generate boilerplate]' \
                    && ret=0
                ;;
            credentials)
                _arguments '1::session-token:_default' && ret=0
                ;;
        esac
        ;;
esac

return ret
