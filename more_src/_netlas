#compdef netlas

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-a[API key]:api key' \
  '--api-key=[API key]:api key' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'search:search for data'
      'count:count results for a query'
      'host:get host information'
      'stat:get statistics for a query'
      'indices:list available indices'
      'download:download search results'
      'profile:get profile information'
    )
    _describe -t commands 'netlas command' commands && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-q,--query}'=[search query]:query' \
          {-d,--datatype}'=[data type]:datatype:(responses dns whois cert)' \
          {-i,--indices}'=[index to search]:index' \
          {-f,--fields}'=[fields to return]:fields' \
          '--no-header[do not print header]' \
          {-c,--count}'=[number of results]:count' \
          {-s,--start}'=[start offset]:offset' \
          {-p,--page}'=[page number]:page' \
          '-j[output as JSON]' && ret=0
        ;;
      count)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-q,--query}'=[search query]:query' \
          {-d,--datatype}'=[data type]:datatype:(responses dns whois cert)' \
          {-i,--indices}'=[index to search]:index' && ret=0
        ;;
      host)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-f,--fields}'=[fields to return]:fields' \
          '1:host or IP' && ret=0
        ;;
      stat)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-q,--query}'=[search query]:query' \
          {-d,--datatype}'=[data type]:datatype:(responses dns whois cert)' \
          {-i,--indices}'=[index to search]:index' \
          '--group-fields=[fields to group by]:fields' && ret=0
        ;;
      indices)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      download)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-q,--query}'=[search query]:query' \
          {-d,--datatype}'=[data type]:datatype:(responses dns whois cert)' \
          {-i,--indices}'=[index to search]:index' \
          {-f,--fields}'=[fields to return]:fields' \
          {-c,--count}'=[number of results]:count' \
          '-j[output as JSON]' && ret=0
        ;;
    esac
    ;;
esac

return ret
