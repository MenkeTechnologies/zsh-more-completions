#compdef vcfgenosummarize
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfgenosummarize.md
# Add summary statistics (RO, QR, AO, QA) from called genotypes to each record

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
