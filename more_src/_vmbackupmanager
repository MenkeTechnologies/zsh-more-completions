#compdef vmbackupmanager
# VictoriaMetrics Enterprise scheduled backup manager

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-backupInterval=[time between backup operations]:duration' \
  '-backupScheduleTimezone=[timezone for daily/weekly/monthly scheduling]:tz' \
  '-disableHourly[disable hourly backups]' \
  '-disableDaily[disable daily backups]' \
  '-disableWeekly[disable weekly backups]' \
  '-disableMonthly[disable monthly backups]' \
  '-disableScheduledBackups[disable all scheduled backups]' \
  '-runOnStart[perform backup immediately on startup]' \
  '-dst=[remote backup destination path]:path' \
  '-storageDataPath=[VictoriaMetrics data directory]:_files -/' \
  '-credsFilePath=[authentication credentials file]:_files' \
  '-customS3Endpoint=[S3-compatible storage endpoint]:url' \
  '-snapshot.createURL=[VictoriaMetrics snapshot creation endpoint]:url' \
  '-snapshot.deleteURL=[snapshot deletion endpoint]:url' \
  '-keepLastHourly=[number of hourly backups to retain]:n' \
  '-keepLastDaily=[number of daily backups to retain]:n' \
  '-keepLastWeekly=[number of weekly backups to retain]:n' \
  '-keepLastMonthly=[number of monthly backups to retain]:n' \
  '-maxBytesPerSecond=[upload speed limit]:bytes' \
  '-concurrency=[number of concurrent workers]:n' \
  '-httpListenAddr=[server listen address]:addr' \
  '-apiURL=[vmbackupmanager API endpoint for CLI commands]:url' \
  '-license=[license key for enterprise functionality]:key' \
  '-licenseFile=[path to license key file]:_files' \
  '*:command:(backup restore)' && ret=0

return ret
