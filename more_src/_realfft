#compdef realfft
# Documentation: https://github.com/scottransom/presto/blob/master/docs/realfft.1
# PRESTO: FFT a PRESTO-format time series (in-core or out-of-core).

local ret=1

_arguments -s -S \
  '-fwd[force a forward FFT (sign=-1)]' \
  '-inv[force an inverse FFT (sign=+1)]' \
  '-del[delete the original file(s) when FFTing]' \
  '-disk[force use of out-of-core memory FFT]' \
  '-mem[force use of in-core memory FFT]' \
  '-tmpdir=[scratch directory for temp files]:dir:_files -/' \
  '-outdir=[directory where result files reside]:dir:_files -/' \
  '*:input data file:_files' && ret=0

return ret
