#compdef oclgrind
# Documentation: https://manpages.debian.org/stretch/oclgrind/oclgrind.1.en.html
# oclgrind - OpenCL device simulator and debugger

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage information]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '(-i --interactive)'{-i,--interactive}'[enable interactive mode]' \
  '(-q --quick)'{-q,--quick}'[only run first and last work-group]' \
  '--build-options=[additional options to pass to the OpenCL compiler]:options' \
  '--check-api[report errors on API calls]' \
  '--data-races[enable data-race detection]' \
  '--disable-pch[do not use precompiled headers]' \
  '--dump-spir[dump SPIR to /tmp/oclgrind_*.{ll,bc}]' \
  '--inst-counts[output histograms of instructions executed]' \
  '--log=[redirect log/error messages to a file]:file:_files' \
  '--max-errors=[limit the number of error/warning messages]:num' \
  '--num-threads=[set the number of worker threads to use]:num' \
  '--pch-dir=[override directory containing precompiled headers]:dir:_files -/' \
  '--plugins=[load colon separated list of plugin libraries]:plugins' \
  '--uniform-writes[do not suppress uniform write-write data-races]' \
  '--uninitialized[report usage of uninitialized values]' \
  '*::command:_normal' && ret=0

return ret
