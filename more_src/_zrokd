#compdef zrokd
# _zrokd — NetFoundry zrokd self-hosted zrok controller daemon CLI for the zrok next-generation sharing platform running OpenZiti-based ingress/proxy administering accounts environments shares and tokens (openziti team, Go); cobra
# upstream: https://github.com/openziti/zrok

_zrokd() {
    local -a sub=(
        'serve:run controller server'
        'bootstrap:bootstrap controller'
        'migrate:run database migration'
        'metrics:report metrics'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.toml"' \
        '-c+[file]:file:_files -g "*.yaml *.yml *.toml"' \
        '--log-format=+[fmt]:f:(text json)' \
        '--log-level=+[level]:l:(panic fatal error warn info debug trace)' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zrokd subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--listen=+[addr]:str:' \
                    '--metrics-listen=+[addr]:str:' \
                    '--limits-listen=+[addr]:str:' ;;
            esac
            ;;
    esac
}

_zrokd "$@"
