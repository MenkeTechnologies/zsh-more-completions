#compdef condor_master
# Documentation: https://htcondor.readthedocs.io/en/latest/admin-manual/installation-startup-shutdown-reconfiguration.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_master: HTCondor master daemon. No dedicated man-page; flags come from the
# DaemonCore set shared by all HTCondor daemons.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-f[run in foreground (no fork)]' \
  '-t[also log to stderr]' \
  '-r[shut down gracefully after N minutes]:minutes:' \
  '-p[port for command socket]:port:' \
  '-l[override LOG directory]:dir:_files -/' \
  '*::condor_master args:_files' && ret=0
return ret
