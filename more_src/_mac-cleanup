#compdef mac-cleanup
# Documentation: https://github.com/mac-cleanup/mac-cleanup-py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mac-cleanup: macOS cleanup utility

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --dry-run)'{-n,--dry-run}'[run without deleting stuff]' \
  '(-u --update)'{-u,--update}'[update Homebrew on cleanup]' \
  '(-c --configure)'{-c,--configure}'[open module configuration screen]' \
  '(-p --custom-path)'{-p,--custom-path}'[specify path for custom modules]' \
  '(-f --force)'{-f,--force}'[accept all warnings]' \
  '(-v --verbose)'{-v,--verbose}'[print folders to be deleted]' \
  '*::args:_default' && return 0
