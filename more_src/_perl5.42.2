#compdef perl5.42.2

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-0+[record separator (octal/hex)]:sep:' \
  '-a[autosplit mode with -n or -p]' \
  '-C+[Unicode features]:flags:' \
  '-c[check syntax only]' \
  '-d[run under debugger]' \
  '-D+[debugging flags]:flags:' \
  '*-e+[one line of program]:command:' \
  '*-E+[program with all features enabled]:command:' \
  '-F+[input field separator regex]:regex:' \
  '-i+[in-place edit]:extension:' \
  '*-I+[include directory]:dir:_files -/' \
  '-l+[output record separator]:octal:' \
  '*-m+[execute use module]:module:' \
  '*-M+[execute use module with options]:module:' \
  '-n[loop over input without printing]' \
  '-p[loop over input with printing]' \
  '-s[switch parsing for arguments]' \
  '-S[search PATH for script]' \
  '-t[taint mode warning]' \
  '-T[taint mode]' \
  '-u[dump core after compiling]' \
  '-U[allow unsafe operations]' \
  '-v[print version]' \
  '-V[print version + config]' \
  '-w[turn warnings on]' \
  '-W[force warnings on]' \
  '-X[force warnings off]' \
  '-x+[ignore until #! perl]:directory:_files -/' \
  '*:program file or args:_files' && ret=0

return ret
