#compdef ceph-bluestore-tool
# Documentation: https://man.archlinux.org/search?q=ceph-bluestore-tool
# Reference accessed: 2026-05-16

# ceph-bluestore-tool: BlueStore admin/repair tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'help:show help'
  'fsck:check bluestore'
  'repair:repair bluestore'
  'quick-fix:quick fix'
  'bluefs-export:export bluefs'
  'bluefs-bdev-new-db:add new db'
  'bluefs-bdev-new-wal:add new wal'
  'bluefs-bdev-migrate:migrate bluefs'
  'show-label:show device label'
  'set-label-key:set label key'
  'rm-label-key:remove label key'
  'free-dump:dump free list'
  'free-score:show free score'
  'reshard:reshard'
  'show-sharding:show sharding'
  'allocmap:export allocator map'
  'restore_cfb:restore consumer free blob list'
  'show-superblock:show superblock'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--path=[OSD path]:dir:_files -/' \
  '--out-dir=[output dir]:dir:_files -/' \
  '--devs-source=[source device path]:dev:' \
  '--dev-target=[target device path]:dev:' \
  '--key=[label key]:k:' \
  '--value=[label value]:v:' \
  '--allocator=[allocator]:alloc:(stupid bitmap avl btree hybrid)' \
  '--log-file=[log file]:file:_files' \
  '--log-level=[log level]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ceph-bluestore-tool command' commands && ret=0 ;;
esac
return ret
