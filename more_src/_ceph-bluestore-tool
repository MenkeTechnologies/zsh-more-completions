#compdef ceph-bluestore-tool
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-bluestore-tool/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ceph-bluestore-tool: BlueStore admin/repair tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'help:show help'
  'fsck:consistency check on BlueStore metadata'
  'repair:repair detectable issues'
  'qfsck:verify metadata by comparing allocator data with ONode state'
  'allocmap:run qfsck-equivalent checks and generate allocation file'
  'restore_cfb:restore RocksDB B Column-Family to prior state'
  'bluefs-export:export BlueFS contents to output directory'
  'bluefs-bdev-sizes:display device capacity information'
  'bluefs-bdev-expand:enable BlueFS to utilize additional block device space'
  'bluefs-bdev-new-db:attach DB storage device'
  'bluefs-bdev-new-wal:attach WAL storage device'
  'bluefs-bdev-migrate:migrate BlueFS data between devices'
  'show-label:display device label contents'
  'show-label-at:display label at particular offset'
  'free-dump:output all unallocated regions'
  'free-score:assess fragmentation quality 0-1'
  'bluefs-stats:present storage usage breakdown'
  'bluefs-files:enumerate all managed files with dimensions'
  'reshard:modify RocksDB column family distribution'
  'show-sharding:present current column family arrangement'
  'trim:execute TRIM/discard operations for SSD optimization'
  'zap-device:clear all device labels'
  'revert-wal-to-plain:convert WAL files to legacy format'
  'create-bdev-labels:write bdev labels to unlabeled devices'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--path=[OSD path]:dir:_files -/' \
  '--dev=[device for operations]:dev:_files' \
  '-i+[OSD identifier]:id:' \
  '--out-dir=[output directory]:dir:_files -/' \
  '--devs-source=[source device(s) for migration]:dev:_files' \
  '--dev-target=[target device for migration]:dev:_files' \
  '--deep[read and validate object data, not just metadata]' \
  '--allocator=[allocator type]:alloc:(stupid bitmap avl btree hybrid)' \
  '--resharding-ctrl=[configure resharding performance parameters]:val:' \
  '-l+[log file]:file:_files' \
  '--log-file=[log file]:file:_files' \
  '--log-level=[log level (default 30)]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ceph-bluestore-tool command' commands && ret=0 ;;
esac
return ret
