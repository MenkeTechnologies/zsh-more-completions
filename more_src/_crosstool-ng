#compdef crosstool-ng ct-ng
# Documentation: https://github.com/crosstool-ng/crosstool-ng/blob/master/ct-ng.in
# Reference accessed: 2026-05-17
# Verified: upstream ct-ng.in + samples/samples.mk define the action list.

# ct-ng is a make(1) driver; the "command" is a make target.
local ret=1

_values -s ' ' 'ct-ng target' \
  menuconfig nconfig oldconfig olddefconfig savedefconfig defconfig \
  upgradeconfig extractconfig check-config \
  show-config show-all 'show-tuple' saveconfig samples \
  list-samples list-samples-short list-steps \
  source build clean distclean version updatetools \
  build-all check-samples update-samples \
  help help-head help-config help-samples help-build \
  help-clean help-distrib help-env help-tail \
  && ret=0

return ret
