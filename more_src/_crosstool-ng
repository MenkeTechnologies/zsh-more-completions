#compdef crosstool-ng ct-ng

# crosstool-ng ct-ng.in + samples/samples.mk — GNU make driver.

local ret=1

_values -s '' 'ct-ng target' \
  menuconfig nconfig oldconfig olddefconfig savedefconfig defconfig upgradeconfig \
  extractconfig 'show-config' saveconfig list-samples list-steps show-tuple \
  source build clean distclean version build-all check-samples update-samples \
  && ret=0

return ret
