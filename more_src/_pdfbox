#compdef pdfbox pdfbox-app

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'debug:open the PDF debugger'
  'decrypt:decrypt a PDF'
  'encrypt:encrypt a PDF'
  'export:images:export images from a PDF'
  'export:xmp:export XMP metadata'
  'export:fdf:export FDF data'
  'export:xfdf:export XFDF data'
  'export:text:extract text'
  'import:fdf:import FDF data'
  'import:xfdf:import XFDF data'
  'overlay:overlay one PDF on another'
  'merge:merge multiple PDFs'
  'split:split a PDF'
  'render:render PDF pages to images'
  'print:print a PDF'
  'fromtext:convert text to PDF'
  'fromimage:convert image to PDF'
  'decode:write decoded PDF stream'
  'version:show version'
  'help:show help'
  'ExtractText:extract text (legacy alias)'
  'ExtractImages:extract images (legacy alias)'
  'PDFMerger:merge PDFs (legacy alias)'
  'PDFToImage:convert PDF to images (legacy alias)'
  'PDFDebugger:open debugger (legacy alias)'
  'PrintPDF:print PDF (legacy alias)'
  'Encrypt:encrypt (legacy alias)'
  'Decrypt:decrypt (legacy alias)'
  'OverlayPDF:overlay PDFs (legacy alias)'
  'WriteDecodedDoc:decode PDF (legacy alias)'
  'ConvertColorspace:convert colorspace (legacy alias)'
  'PDFSplit:split PDF (legacy alias)'
  'FDFMerge:merge FDF (legacy alias)'
  'PDFAConvert:convert to PDF/A (legacy alias)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pdfbox subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (decrypt)
        _arguments \
          '-i=[input PDF]:file:_files -g "*.pdf"' \
          '-password=[password]:password:' \
          '-keyStore=[keystore]:file:_files' \
          '-alias=[alias]:alias:' \
          '-o=[output PDF]:file:_files' && ret=0
        ;;
      (encrypt)
        _arguments \
          '-i=[input PDF]:file:_files -g "*.pdf"' \
          '-O=[owner password]:password:' \
          '-U=[user password]:password:' \
          '-keyLength=[key length]:bits:(40 128 256)' \
          '-canPrint[allow printing]' \
          '-canModify[allow modifications]' && ret=0
        ;;
      (export:images)
        _arguments \
          '-i=[input PDF]:file:_files -g "*.pdf"' \
          '-password=[password]:password:' \
          '-prefix=[output prefix]:prefix:' \
          '-noColorConvert[do not convert colors]' \
          '-useDirectJPEG[extract JPEGs directly]' && ret=0
        ;;
      (export:text)
        _arguments \
          '-i=[input PDF]:file:_files -g "*.pdf"' \
          '-o=[output file]:file:_files' \
          '-encoding=[encoding]:encoding:' \
          '-startPage=[start page]:page:' \
          '-endPage=[end page]:page:' \
          '-html[output HTML]' \
          '-md[output Markdown]' && ret=0
        ;;
      (merge)
        _arguments \
          '*-i=[input PDF]:file:_files -g "*.pdf"' \
          '-o=[output PDF]:file:_files' && ret=0
        ;;
      (split)
        _arguments \
          '-i=[input PDF]:file:_files -g "*.pdf"' \
          '-split=[pages per file]:n:' \
          '-startPage=[start page]:page:' \
          '-endPage=[end page]:page:' \
          '--outputPrefix=[output prefix]:prefix:' && ret=0
        ;;
      (render)
        _arguments \
          '-i=[input PDF]:file:_files -g "*.pdf"' \
          '-format=[image format]:format:(jpg png gif bmp wbmp tiff)' \
          '-dpi=[DPI]:dpi:' \
          '-startPage=[start page]:page:' \
          '-endPage=[end page]:page:' \
          '-color=[color mode]:mode:(rgb gray binary)' && ret=0
        ;;
      (debug)
        _arguments \
          '-password=[password]:password:' \
          '-viewstructure[view structure tree]' \
          ':input:_files -g "*.pdf"' && ret=0
        ;;
    esac
    ;;
esac

return ret
