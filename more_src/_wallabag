#compdef wallabag
# _wallabag — Nicolas Lœuillet wallabag self-hosted read-it-later app symfony console CLI (wallabag team, PHP/Symfony); symfony console
# upstream: https://github.com/wallabag/wallabag

_wallabag() {
    local -a sub=(
        'list:list commands'
        'help:show help for command'
        'about:show framework info'
        'cache:clear:clear cache'
        'cache:pool:clear:clear pool cache'
        'cache:warmup:warm up cache'
        'config:dump-reference:dump config reference'
        'debug:autowiring:debug autowiring'
        'debug:container:debug container'
        'debug:router:debug routes'
        'debug:event-dispatcher:debug events'
        'doctrine:database:create:create database'
        'doctrine:database:drop:drop database'
        'doctrine:schema:create:create schema'
        'doctrine:schema:update:update schema'
        'doctrine:fixtures:load:load fixtures'
        'doctrine:migrations:execute:execute migration'
        'doctrine:migrations:migrate:run migrations'
        'doctrine:migrations:status:show migration status'
        'fos:user:activate:activate user'
        'fos:user:change-password:change user password'
        'fos:user:create:create user'
        'fos:user:demote:demote user'
        'fos:user:promote:promote user'
        'wallabag:install:install wallabag'
        'wallabag:user:create:create wallabag user'
        'wallabag:user:list:list users'
        'wallabag:user:delete:delete user'
        'wallabag:user:info:show user info'
        'wallabag:reload-entries:reload entries'
        'wallabag:export:export entries'
        'wallabag:import:import entries'
        'wallabag:tag:all:tag all entries'
        'wallabag:cleanup-tags:cleanup tags'
        'wallabag:flush-deleted-users:flush deleted users'
        'wallabag:reindex:reindex'
        'wallabag:show-user:show user'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--env=+[environment]:e:(prod dev test)' \
        '-e+[environment]:e:(prod dev test)' \
        '--no-debug[no debug]' \
        '--no-interaction[no interactive prompts]' \
        '-n[no interactive prompts]' \
        '--ansi[force ansi]' \
        '--no-ansi[disable ansi]' \
        '--quiet[no output]' \
        '-q[no output]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-vvv[debug verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wallabag subcommand' sub ;;
    esac
}

_wallabag "$@"
