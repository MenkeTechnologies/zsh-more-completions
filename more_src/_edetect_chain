#compdef edetect_chain
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/edetect_chain/node7.html
# XMM-Newton SAS: run the EPIC source detection chain

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--attitudeset=[name of attitude file]:file:_files' \
  '--eventsets=[names of event list files]:files:_files' \
  '--imagesets=[names of input images]:files:_files' \
  '--pimin=[lower energy boundaries of images (eV)]:ev:' \
  '--pimax=[upper energy boundaries of images (eV)]:ev:' \
  '--likemin=[detection likelihood threshold for emldetect]:like:' \
  '--witheexpmap=[create new exposure maps]:flag:(yes no)' \
  '--ecf=[energy conversion factors]:ecf:' \
  '--eex_attrebin=[positional accuracy of attitude rebinning (arcsec)]:arcsec:' \
  '--emask_threshold1=[fraction of maximum exposure threshold]:thresh:' \
  '--emask_threshold2=[threshold for gradient of exposure]:thresh:' \
  '--eboxl_list=[name of local mode source list]:file:_files' \
  '--eboxm_list=[name of map mode source list]:file:_files' \
  '--eboxl_likemin=[local mode minimum detection likelihood]:like:' \
  '--eboxm_likemin=[map mode minimum detection likelihood]:like:' \
  '--ebox_withdetmask=[detection mask flag for eboxdetect]:flag:(yes no)' \
  '--ebox_withexpimage=[exposure image flag for eboxdetect]:flag:(yes no)' \
  '--ebox_boxsize=[detection box size]:size:(3 5)' \
  '--esp_withcheese=[output cheesed image flag]:flag:(yes no)' \
  '--esp_nsplinenodes=[number of spline nodes]:nodes:' \
  '--esp_nfitrun=[number of iterations]:n:' \
  '--esp_excesssigma=[threshold for excess wrt spline]:sigma:' \
  '--esp_fitmethod=[background fitting method]:method:(spline model)' \
  '--esp_scut=[source cut-out flux level]:flux:' \
  '--eml_list=[name of source list]:file:_files' \
  '--eml_fitextent=[fit source extent]:flag:(yes no)' \
  '--eml_fitnegative=[allow negative fitted count rates]:flag:(yes no)' \
  '--eml_dmlextmin=[extent likelihood threshold]:thresh:' \
  '--eml_ecut=[event cut-out radius]:radius:' \
  '--eml_scut=[source cut-out radius]:radius:' \
  '--eml_determineerrors=[determine statistical errors]:flag:(yes no)' \
  '--eml_nmaxfit=[max simultaneous sources]:n:' \
  '--eml_nmulsou=[max sources per input position]:n:' \
  '--eml_extentmodel=[source extent model]:model:(gaussian beta)' \
  '--eml_threshcolumn=[threshold column]:col:(LIKE RATE SCTS)' \
  '--eml_maxextent=[maximum extent in pixels]:pixels:' \
  '--psfmodel=[PSF model type]:model:(ellbeta medium)' \
  '--esen_mlmin=[upper limit likelihood for esensmap]:like:' \
  '*:file:_files' && ret=0

return ret
