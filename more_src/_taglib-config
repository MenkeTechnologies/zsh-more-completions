#compdef taglib-config
# Documentation: https://github.com/taglib/taglib/blob/master/taglib-config.cmd.cmake
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix[print installation prefix]' \
  '--libs[print linker flags]' \
  '--cflags[print C compiler flags]' \
  '--version[show version]' && ret=0

return ret
