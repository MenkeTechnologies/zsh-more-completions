#compdef warpgate

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:start the Warpgate server'
  'setup:initial setup'
  'unattended-setup:non-interactive setup'
  'check:check configuration'
  'test-target:test connection to a target'
  'client-keys:show client SSH keys'
  'recover-access:create a temporary admin account'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[config file path]:config file:_files -g "*.yaml"' \
  '--config=[config file path]:config file:_files -g "*.yaml"' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'warpgate command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      run)
        _arguments -s -S && ret=0
        ;;
      test-target)
        _arguments -s -S \
          '1:target name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
