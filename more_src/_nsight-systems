#compdef nsight-systems nsys

# Nsight Systems CLI (system-wide profiler)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'profile:profile an application'
  'launch:launch with profiler attached'
  'start:start profiler session'
  'stop:stop profiler session'
  'cancel:cancel a session'
  'shutdown:shutdown a session'
  'sessions:list sessions'
  'export:export to other formats'
  'stats:print stats from report'
  'status:show running status'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'nsight-systems command' commands && ret=0 ;;
esac
return ret
