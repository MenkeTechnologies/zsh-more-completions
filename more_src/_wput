#compdef wput
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/wput.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-nv --less-verbose)'{-nv,--less-verbose}'[less verbose]' \
  '(-a --append-output)'{-a+,--append-output=}'[append output to logfile]:file:_files' \
  '--basename=[set basename path]:path:' \
  '(-i --input-file)'{-i+,--input-file=}'[input file]:file:_files' \
  '(-I --input-pipe)'{-I+,--input-pipe=}'[input from pipe command]:command:' \
  '(-o --output-file)'{-o+,--output-file=}'[output log file]:file:_files' \
  '(-R --remove-source-files)'{-R,--remove-source-files}'[remove source files after upload]' \
  '(-s --sort)'{-s,--sort}'[sort files before upload]' \
  '(-A --ascii)'{-A,--ascii}'[ascii mode]' \
  '(-B --binary)'{-B,--binary}'[binary mode]' \
  '(-b --background)'{-b,--background}'[run in background]' \
  '--bind-address=[bind to address]:addr:' \
  '--force-tls[force TLS]' \
  '(-l --limit-rate)'{-l+,--limit-rate=}'[rate limit]:rate:' \
  '(-m --chmod)'{-m+,--chmod=}'[chmod uploaded files]:mode:' \
  '(-nc --dont-continue)'{-nc,--dont-continue}'[do not continue partial uploads]' \
  '(-N --timestamping)'{-N,--timestamping}'[timestamping]' \
  '(-p --port-mode)'{-p,--port-mode}'[use FTP port mode]' \
  '--proxy=[proxy mode]:mode:' \
  '--proxy-user=[proxy user]:user:' \
  '--proxy-pass=[proxy password]:pw:' \
  '--no-directories[do not create directories]' \
  '(-t --tries)'{-t+,--tries=}'[number of retries]:n:' \
  '(-u --reupload)'{-u,--reupload}'[force reupload]' \
  '--skip-larger[skip files larger than remote]' \
  '--skip-existing[skip existing files]' \
  '*:file:_files' && ret=0

return ret
