#compdef leptosfmt

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--stdin[read from stdin]' \
  '--config-file[path to configuration file]:config file:_files' \
  '--max-width[maximum line width]:width:' \
  '--tab-spaces[number of spaces per tab]:spaces:' \
  '--attr-value-brace-style[brace style for attribute values]:style:(WhenRequired Always AlwaysUnlessLit Preserve)' \
  '--experimental-tailwind[enable experimental Tailwind CSS class sorting]' \
  '--experimental-tailwind-config[path to Tailwind config file]:config file:_files' \
  '*:files:_files' \
  && ret=0

return ret
