#compdef paraFoam

# OpenFOAM paraFoam: launch ParaView with OpenFOAM reader
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-case[case directory]:dir:_files -/' \
  '-region[mesh region]:region:' \
  '-touch[only touch .OpenFOAM file]' \
  '-touchAll[touch .OpenFOAM in all regions]' \
  '-builtin[use ParaView built-in reader]' \
  '-vtk[use VTK output legacy]' \
  '-block[block mesh mode]' \
  '*::paraFoam args:_files' && ret=0
return ret
