#compdef tiltxcorr
# Documentation: https://bio3d.colorado.edu/imod/doc/man/tiltxcorr.html
# tiltxcorr - cross-correlate tilt series images to find alignment or patch tracking

local ret=1

_arguments -s -S \
  '(-input)-input[input file with images to correlate]:file:_files' \
  '(-piece)-piece[piece list file for reordering Z values]:file:_files' \
  '(-reference)-reference[input file with an image to use as a reference]:file:_files' \
  '(-rview)-rview[view number of image to use in reference file]:view' \
  '(-output)-output[output file for transformations or patch tracking]:file:_files' \
  '(-rotation)-rotation[angle of rotation of the tilt axis]:angle' \
  '(-first)-first[tilt angle of first view in degrees]:angle' \
  '(-increment)-increment[increment between tilt angles in degrees]:increment' \
  '(-tiltfile)-tiltfile[file with tilt angles, one per line]:file:_files' \
  '(-angles)-angles[enter tilt angles directly]:angles' \
  '(-offset)-offset[amount to add to all entered tilt angles]:value' \
  '(-reverse)-reverse[reverse order of processing]' \
  '(-prexf)-prexf[file with transformations to pre-align images]:file:_files' \
  '(-imagebinned)-imagebinned[current binning relative to the unbinned images]:binning' \
  '(-pixel)-pixel[pixel size of unbinned images in nanometers]:size' \
  '(-unali)-unali[full size of the unaligned stack]:x,y' \
  '(-binning)-binning[binning to apply to the trimmed images]:binning' \
  '(-antialias)-antialias[type of antialiasing filter for image reduction]:value' \
  '(-radius1)-radius1[low spatial frequencies in the correlation filter]:radius' \
  '(-radius2)-radius2[high spatial frequencies in the correlation filter]:radius' \
  '(-nmrad2)-nmrad2[high-frequency cutoff in reciprocal nanometers]:value' \
  '(-sigma1)-sigma1[sigma to filter low frequencies]:sigma' \
  '(-nmsig1)-nmsig1[low-frequency sigma in reciprocal nanometers]:value' \
  '(-sigma2)-sigma2[sigma for the Gaussian rolloff at high frequencies]:sigma' \
  '(-nmsig2)-nmsig2[high-frequency sigma in reciprocal nanometers]:value' \
  '(-border)-border[pixels to trim off each edge in X and Y]:x,y' \
  '(-ubborder)-ubborder[unbinned pixels to trim off each edge]:x,y' \
  '(-xminmax)-xminmax[starting and ending X of a region to correlate]:start,end' \
  '(-yminmax)-yminmax[starting and ending Y of a region to correlate]:start,end' \
  '(-ubxmm)-ubxmm[unbinned starting and ending X of a region]:start,end' \
  '(-ubymm)-ubymm[unbinned starting and ending Y of a region]:start,end' \
  '(-pad)-pad[pixels to pad images on each side]:x,y' \
  '(-taper)-taper[pixels to taper images in X and Y]:x,y' \
  '(-ccc)-ccc[compute a normalized cross-correlation coefficient]' \
  '(-iterate)-iterate[number of iterations of the correlation]:count' \
  '(-shift)-shift[limits on distance in X and Y to search]:x,y' \
  '(-axial)-axial[limits perpendicular and parallel to tilt axis]:perp,par' \
  '(-rect)-rect[use the older rectangular search behavior]' \
  '(-boundary)-boundary[model file with boundary contours]:file:_files' \
  '(-objbound)-objbound[object number to use from the boundary model]:value' \
  '(-skip)-skip[list of views to skip]:views' \
  '(-break)-break[list of views to break alignment at]:views' \
  '(-views)-views[starting and ending view numbers]:start,end' \
  '(-exclude)-exclude[exclude a central correlation peak]' \
  '(-central)-central[criteria for central peak detection]:three floats' \
  '(-leaveaxis)-leaveaxis[leave the tilt axis in the center of the region]' \
  '(-cumulative)-cumulative[add up previously aligned pictures]' \
  '(-absstretch)-absstretch[stretch each cumulative image by absolute factor]' \
  '(-nostretch)-nostretch[do not do any cosine stretching]' \
  '(-search)-search[search for the magnification factor]' \
  '(-changes)-changes[list of views at which to search for size change]:views' \
  '(-mag)-mag[lower and upper limits for size change]:low,high' \
  '(-scan)-scan[max angle and angular step for searching]:angle,step' \
  '(-second)-second[report on the second peak position]:two ints' \
  '(-size)-size[size in X and Y of patches to track]:x,y' \
  '(-ubsize)-ubsize[unbinned size in X and Y of patches to track]:x,y' \
  '(-varying)-varying[set up patch positions for varying patch size]:x,y' \
  '(-number)-number[number of patches in X and Y to track]:x,y' \
  '(-overlap)-overlap[fractional overlap in X and Y between patches]:x,y' \
  '(-seed)-seed[input model file with center points to track]:file:_files' \
  '(-objseed)-objseed[object number from the seed model]:value' \
  '(-length)-length[length of tracks when tracking patches]:two ints' \
  '(-struct)-struct[eliminate patches with low structure]:value' \
  '(-elim)-elim[max fraction of patches to eliminate]:value' \
  '(-expand)-expand[max linear extents to expand patches by]:x,y' \
  '(-percentile)-percentile[percentile point in distribution of structure]:value' \
  '(-drop)-drop[fraction of structure criterion below percentile]:value' \
  '(-target)-target[min and max pixel sizes in nanometers to reduce to]:min,max' \
  '(-variation)-variation[fraction determining reduction]:value' \
  '(-scurve)-scurve[exponent and half-rise point for a sigmoid curve]:exp,half' \
  '(-box)-box[box size for measuring local SD in reduced images]:size' \
  '(-sdbin)-sdbin[list of reductions at which to compute SD]:list' \
  '(-domains)-domains[number of local patches in X and Y for fitting]:x,y' \
  '(-prob)-prob[probabilities controlling outlier elimination]:two floats' \
  '(-warp)-warp[use patch correlations to save warping transforms]:value' \
  '(-pair)-pair[transforms relating each section to the previous]:two ints' \
  '(-append)-append[append output when doing a raw and aligned pair]' \
  '(-gpu)-gpu[use the GPU for computations]:value' \
  '(-action)-action[action to take when the GPU cannot be used]:two ints' \
  '(-test)-test[filename to save two patch correlations to]:file:_files' \
  '(-single)-single[number of a single patch to process]:value' \
  '(-verbose)-verbose[output diagnostic information at the given level]:level' \
  '(-param)-param[read parameter entries from this file]:file:_files' \
  '(-help -h)'{-help,-h}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
