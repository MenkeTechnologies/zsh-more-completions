#compdef treesize
# Documentation: https://github.com/melak47/treesize-rs
# treesize - list a directory tree sorted by size

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-a[list all files including dotfiles]' \
  '-L[follow symbolic links encountered]' \
  '--one-file-system[stay in the same file system when listing]' \
  '-d[maximal directory depth to recurse, or -1 for infinite]:max-depth:' \
  '-e[maximum number of entries to display per directory, or -1 for infinite]:max-entries:' \
  '-s[size format]:size-format:(human si raw h H r)' \
  '*:directory:_files -/' && ret=0

return ret
