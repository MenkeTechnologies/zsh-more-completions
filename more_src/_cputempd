#compdef cputempd

# cputempd: CPU temperature monitor daemon (Linux thermal zone reader)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-d[run as daemon]' \
  '-f[foreground]' \
  '-i[poll interval seconds]:sec:' \
  '-c[critical temperature threshold (C)]:c:' \
  '-w[warning temperature threshold (C)]:c:' \
  '-l[log file]:file:_files' \
  '*::cputempd args:_files' && ret=0
return ret
