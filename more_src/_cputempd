#compdef cputempd

# cputempd: simple CPU temperature reporter daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-f[run in foreground]' \
  '--foreground[run in foreground]' \
  '-d[debug]' \
  '--debug[debug]' \
  '-i[poll interval (seconds)]:seconds:' \
  '--interval=[poll interval (seconds)]:seconds:' \
  '*::cputempd args:_files' && ret=0
return ret
