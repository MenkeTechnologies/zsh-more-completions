#compdef respgen-extra
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools respgen: generate input files for two-stage resp fitting

local ret=1

_arguments -s -S \
  '-i[input file name (ac)]:file:_files' \
  '-o[output file name]:file:_files' \
  '-l[maximum path length]:length:' \
  '-f[output file format]:format:(resp1 resp2 iresp1 iresp2 resp3 resp4 resp5)' \
  '-e[equalizing atomic charge]:level:(0 1 2)' \
  '-a[additional input data file]:file:_files' \
  '-n[number of conformations]:n:' \
  '-w[weight of charge constraint]:weight:' \
  '*:file:_files' && ret=0

return ret
