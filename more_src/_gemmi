#compdef gemmi
# Documentation: https://gemmi.readthedocs.io/en/latest/program.html
# gemmi - macromolecular crystallography toolkit (CIF/PDB/MTZ/map utilities)

local ret=1
local context state line

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'align:sequence/structure alignment'
      'blobs:find unmodelled blobs in difference map'
      'cif2json:convert CIF to JSON'
      'cif2mtz:convert structure factor CIF to MTZ'
      'cifdiff:compare tags in two CIF files'
      'contact:list contacts'
      'contents:summarize content of a coordinate file'
      'convert:convert between coordinate/CIF formats'
      'crd:create restraint dictionary'
      'drg:produce restraints from monomer'
      'ecalc:calculate normalized structure factors E'
      'fprime:calculate anomalous scattering factors'
      'grep:search for tags in CIF files'
      'h:add or remove hydrogens'
      'json2cif:convert JSON to CIF'
      'map:print info or modify a CCP4 map'
      'map2sf:transform map to structure factors'
      'mask:make a mask from coordinates or map'
      'merge:merge intensities from multi-record reflection file'
      'mondiff:compare two monomer files'
      'mtz:print info about an MTZ file'
      'mtz2cif:convert MTZ to structure factor CIF'
      'reindex:reindex MTZ file'
      'residues:list residues from a coordinate file'
      'rmsz:validate geometry with Z-scores'
      'set:modify coordinate files'
      'sf2map:transform structure factors to map'
      'sfcalc:calculate structure factors from a model'
      'sg:print space group info'
      'ss:determine secondary structure'
      'tags:list tags from CIF files with statistics'
      'validate:validate CIF files'
      'wcn:calculate weighted contact number'
      'xds2mtz:convert XDS_ASCII to MTZ'
    )
    _describe -t commands 'gemmi command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      convert)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-V --version)'{-V,--version}'[show version]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '--from=[input format]:format:(mmcif mmjson pdb chemcomp)' \
          '--to=[output format]:format:(mmcif mmjson pdb)' \
          '--style=[CIF formatting style]:style:' \
          '--all-auth[write _atom_site.auth_atom_id and auth_comp_id]' \
          '(-b --block)'{-b,--block=}'[block name]:name:' \
          '--sort[sort atoms]' \
          '--skip-category=[do not output tags in this category]:cat:' \
          '--minimal[write only the most essential records]' \
          '--shorten[shorten chain names]' \
          '--rename-chain=[rename chain OLD to NEW]:OLD\:NEW:' \
          '--monomer=[rename monomer OLD to NEW]:OLD\:NEW:' \
          '--remove-h[remove hydrogens]' \
          '--remove-waters[remove waters]' \
          '--remove-lig-wat[remove ligands and waters]' \
          '--select=[output only the selection]:sel:' \
          '--remove=[remove the selection]:sel:' \
          '--expand-ncs=[expand strict NCS]:how:(dup num x)' \
          '*:file:_files' && ret=0
        ;;
      sg)
        _arguments -s \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '--asu=[show ASU for given space group]:n:' \
          '*:spacegroup:' && ret=0
        ;;
      contents)
        _arguments -s \
          '-b[show overall B factor]' \
          '--select=[use the given selection]:sel:' \
          '--dihedrals[print dihedral angles]' \
          '-n[examine all models]' \
          '*:file:_files' && ret=0
        ;;
      grep)
        _arguments -s \
          '(-E --extended-regexp)'{-E,--extended-regexp}'[interpret PATTERN as extended regex]' \
          '(-c --count)'{-c,--count}'[print count of matches]' \
          '(-r --recursive)'{-r,--recursive}'[recurse into directories]' \
          '(-n --line-number)'{-n,--line-number}'[print line numbers]' \
          '(-H --with-filename)'{-H,--with-filename}'[print filename]' \
          '(-m --max-count)'{-m,--max-count=}'[stop after NUM matches]:num:' \
          '*:file:_files' && ret=0
        ;;
      *)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
