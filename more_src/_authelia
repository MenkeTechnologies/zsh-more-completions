#compdef authelia

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'access-control:test access control rules'
  'build-info:show build information'
  'config:show effective configuration'
  'crypto:cryptography helpers'
  'debug:debug helpers'
  'storage:storage migrations and tools'
)

_arguments -C \
  '*'{-c,--config}'=[config file]:file:_files -g "*.(yaml|yml)"' \
  '*--config.experimental.filters=[config filter]:filter:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'authelia subcommand' subcommands && ret=0
    ;;
esac

return ret
