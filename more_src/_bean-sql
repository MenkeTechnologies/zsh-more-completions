#compdef bean-sql
# _bean-sql — convert Beancount file into a SQLite database (beancount/beancount)
# upstream: https://github.com/beancount/beancount
# Flags from beancount/scripts/sql.py.

_bean-sql() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '1:Beancount file:_files -g "*.beancount"' \
        '2:database file:_files -g "*.{db,sqlite,sqlite3}"'
}

_bean-sql "$@"
