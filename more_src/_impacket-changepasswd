#compdef impacket-changepasswd
# Documentation: https://github.com/fortra/impacket/blob/master/examples/changepasswd.py
# Change or reset passwords over different protocols

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-ts[adds timestamp to every logging output]' \
  '-debug[turn DEBUG output ON]' \
  '-newpass=[new password]:password' \
  '-newhashes=[new NTLM hashes, format is NTHASH or LMHASH:NTHASH]:hashes' \
  '-hashes=[NTLM hashes, format is NTHASH or LMHASH:NTHASH]:hashes' \
  '-no-pass[don'\''t ask for password (useful for -k)]' \
  '-altuser=[alternative username]:user' \
  '-altpass=[alternative password]:password' \
  '-althash=[alternative NT hash, format is NTHASH or LMHASH:NTHASH]:hash' \
  '-althashes=[alternative NT hash, format is NTHASH or LMHASH:NTHASH]:hash' \
  '(-protocol -p)'{-protocol,-p}'=[protocol to use for password change/reset]:protocol:(smb-samr rpc-samr kpasswd ldap)' \
  '(-reset -admin)'{-reset,-admin}'[try to reset the password with privileges]' \
  '-k[use Kerberos authentication from ccache file]' \
  '-aesKey=[AES key to use for Kerberos authentication (128 or 256 bits)]:hexkey' \
  '-dc-ip=[IP address of the domain controller, for Kerberos]:ip' \
  '1:target (\[\[domain/\]username\[:password\]@\]<host>):' && ret=0

return ret
