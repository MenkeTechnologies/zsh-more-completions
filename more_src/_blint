#compdef blint
# Documentation: https://github.com/owasp-dep-scan/blint
# blint: Binary Linter to check security properties and generate SBOM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --src)'{-i,--src}'[source directories, container images or binary files]:src:_files' \
  '(-o --reports)'{-o,--reports}'[reports output directory]:dir:_files -/' \
  '--no-error[continue on error to prevent build from breaking]' \
  '--no-banner[do not display banner]' \
  '--no-reviews[do not perform method reviews]' \
  '--suggest-fuzzable[suggest functions for fuzzing based on a dictionary]' \
  '--use-blintdb[use blintdb v2 for symbol resolution]' \
  '--disassemble[disassemble functions and store instructions in metadata]' \
  '--export-callgraph-mermaid[export callgraph as Mermaid files]' \
  '--export-callgraph-graphml[export callgraph as GraphML]' \
  '--export-callgraph-gexf[export callgraph as GEXF]' \
  '--callgraph-min-confidence[filter callgraph edges by confidence]:level:(low medium high)' \
  '--custom-rules-dir[path to custom YAML rule files]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[disable logging and progress bars]' \
  '1:command:(sbom db)' \
  '*::arg:_files' && ret=0

return ret
