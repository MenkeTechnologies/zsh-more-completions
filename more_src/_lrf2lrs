#compdef lrf2lrs
# Documentation: https://manual.calibre-ebook.com/generated/en/lrf2lrs.html
# Convert an LRF file into an LRS (XML UTF-8 encoded) file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help message and exit]' \
  '--version[show program version number and exit]' \
  '--verbose[be more verbose]' \
  '--dont-output-resources[do not save embedded image and font files to disk]' \
  '(-o --output)'{-o,--output}'=[output LRS file]:lrs file:_files -g "*.lrs"' \
  '*:lrf file:_files -g "*.lrf"' && ret=0

return ret
