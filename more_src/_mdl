#compdef mdl

# Zsh completion for mdl (Markdown linter)

_arguments -s -S \
  '(-c --config)'{-c,--config}'[configuration file]:file:_files' \
  '(-g --git-recurse)'{-g,--git-recurse}'[recurse into git submodules]' \
  '(-i --ignore-front-matter)'{-i,--ignore-front-matter}'[ignore YAML front matter]' \
  '(-l --list-rules)'{-l,--list-rules}'[list enabled rules]' \
  '(-r --rules)'{-r,--rules}'[rules to enable]:rules:' \
  '(-u --rulesets)'{-u,--rulesets}'[ruleset file]:file:_files' \
  '(-s --style)'{-s,--style}'[style to follow]:style:_files' \
  '(-t --tags)'{-t,--tags}'[rule tags to enable]:tags:' \
  '(-w --warnings)'{-w,--warnings}'[show Kramdown warnings]' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '(-p --skip-default-ruleset)'{-p,--skip-default-ruleset}'[skip default ruleset]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:markdown file:_files -g "*.md *.markdown *.mdown"' && return 0
