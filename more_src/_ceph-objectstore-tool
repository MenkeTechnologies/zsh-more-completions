#compdef ceph-objectstore-tool

# ceph-objectstore-tool: OSD objectstore inspection/repair
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--data-path=[OSD data path]:dir:_files -/' \
  '--journal-path=[journal path]:dir:_files -/' \
  '--type=[objectstore type]:type:(filestore bluestore memstore kstore)' \
  '--pgid=[placement group id]:pgid:' \
  '--op=[operation]:op:(info log remove pg-list pg-info pg-remove pg-export pg-export-removed pg-import dump-export dump-journal dump-super list reset-last-complete fuse trim-pg-log set-osdmap get-osdmap set-inc-osdmap get-inc-osdmap dump-import import update-mon-db)' \
  '--target-data-path=[target data path]:dir:_files -/' \
  '--mon-store-path=[mon store path]:dir:_files -/' \
  '--object-locator=[object locator]:str:' \
  '--namespace=[namespace]:ns:' \
  '--object=[object name]:name:' \
  '--no-overwrite[do not overwrite]' \
  '--force[force]' \
  '--skip-journal-replay[skip journal replay]' \
  '--skip-mount-omap[skip mount omap]' \
  '--head[show only head object]' \
  '--debug[debug logging]' \
  '*::ceph-objectstore-tool args:_files' && ret=0
return ret
