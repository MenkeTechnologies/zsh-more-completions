#compdef ceph-objectstore-tool
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-objectstore-tool/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ceph-objectstore-tool: OSD objectstore inspection/repair
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[produce help message]' \
  '--type=[objectstore type]:type:(bluestore memstore)' \
  '--data-path=[path to object store (mandatory)]:dir:_files -/' \
  '--journal-path=[path to journal]:file:_files' \
  '--pgid=[PG id]:pgid:' \
  '--pool=[pool name]:pool:' \
  '--op=[operation]:op:(info log remove mkfs fsck repair fuse dup export export-remove import list-pgs list list-slow-omap fix-lost list-pgs trim-pg-log statfs reset-last-complete pg-log-inject-dups update-mon-db get-superblock set-superblock get-osdmap set-osdmap get-inc-osdmap set-inc-osdmap dump-export dump-import dump-super)' \
  '--epoch=[epoch for get-osdmap/get-inc-osdmap]:n:' \
  '--file=[file path for export/import]:file:_files' \
  '--mon-store-path=[mon store path for update-mon-db]:dir:_files -/' \
  '--fsid=[fsid for new store with mkfs]:fsid:' \
  '--target-data-path=[target object store (for --op dup)]:dir:_files -/' \
  '--mountpoint=[fuse mountpoint]:dir:_files -/' \
  '--format=[output format]:fmt:(json json-pretty xml xml-pretty plain)' \
  '--debug[enable diagnostic output to stderr]' \
  '--force[ignore some errors and proceed]' \
  '--skip-journal-replay[disable journal replay]' \
  '--skip-mount-omap[disable mounting of omap]' \
  '--head[find head/snapdir when searching by name]' \
  '--dry-run[do not modify the objectstore]' \
  '--namespace=[namespace when searching for objects]:ns:' \
  '--rmtype=[corrupting object removal type]:type:(snapmap nosnapmap)' \
  '*::ceph-objectstore-tool args:_files' && ret=0
return ret
