#compdef boom
# _boom — HTTP load generator
# upstream: https://github.com/rakyll/boom (also known as hey)

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '-n=[number of requests]:requests:' \
    '-c=[number of concurrent workers]:workers:' \
    '-q=[rate limit (queries per second)]:qps:' \
    '-z=[duration of the test]:duration:' \
    '-o=[output type]:type:(csv)' \
    '-m=[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
    '-H=[custom HTTP header]:header:' \
    '-t=[request timeout in seconds]:seconds:' \
    '-A=[HTTP Accept header]:accept:' \
    '-d=[HTTP request body]:body:' \
    '-D=[HTTP request body from file]:file:_files' \
    '-T=[content-type]:content-type:' \
    '-a=[basic authentication (user:password)]:auth:' \
    '-x=[HTTP proxy address]:proxy:_urls' \
    '-disable-compression[disable compression]' \
    '-disable-keepalive[disable HTTP keep-alive]' \
    '-disable-redirects[disable following HTTP redirects]' \
    '-host=[HTTP Host header]:host:' \
    '-cpus=[number of CPUs to use]:cpus:' \
    '1:url:_urls' \
    && return 0
