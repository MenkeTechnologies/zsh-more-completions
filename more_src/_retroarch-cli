#compdef retroarch-cli

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-L --libretro)'{-L+,--libretro=}'[libretro core path]:core:_files -g "*.{so,dll,dylib}"' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.cfg"' \
  '--appendconfig=[append a config file]:file:_files -g "*.cfg"' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '--log-file=[log file]:file:_files' \
  '--menu[start in menu]' \
  '--nodevice=[disable input device]:port:' \
  '--device=[set input device]:port_device:' \
  '--scale=[set windowed scaler]:n:' \
  '--fullscreen[start in fullscreen]' \
  '--record=[record gameplay video]:file:_files' \
  '--recordconfig=[recording config]:file:_files -g "*.cfg"' \
  '--size=[window size WxH]:size:' \
  '--save=[save state path]:file:_files' \
  '--savestate=[save state file]:file:_files' \
  '--bsvplay=[replay BSV file]:file:_files -g "*.bsv"' \
  '--bsvrecord=[record BSV to file]:file:_files' \
  '--sram-mode=[SRAM mode]:mode:(load-only save-only noload-nosave)' \
  '-H+[run as host (netplay)]:port:' \
  '-C+[connect to host (netplay)]:host:' \
  '--nick=[netplay nickname]:nick:' \
  '--max-frames=[exit after N frames]:n:' \
  '*:rom:_files' && ret=0

return ret
