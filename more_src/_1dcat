#compdef 1dcat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dcat.html
# AFNI: catenate AFNI .1D files horizontally

local ret=1

_arguments -s -S \
  '-tsvout[output in TSV format with header line]' \
  '-csvout[output in CSV format with header line]' \
  '-nonconst[exclude columns with constant values]' \
  '-nonfixed[retain only free columns in 3dAllineate headers]' \
  '-form[numeric output format]:form:' \
  '-stack[stack output columns vertically]' \
  '-sel[apply column/row selection to all inputs]:sel:' \
  '-OKempty[exit gracefully on empty files]' \
  '*:1D file:_files' && ret=0

return ret
