#compdef ripper-tags
# Documentation: https://github.com/tmm1/ripper-tags
# Fast, accurate ctags generator for Ruby source using Ripper

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-v --version)'{-v,--version}'[print version information]' \
  '(-f --tag-file)'{-f,--tag-file}'+[file to write tags to (default ./tags)]:file:_files' \
  '(-a --append)-a[append tags to existing file]' \
  '--append=[append tags to existing file]:yesno:(yes no)' \
  '--tag-relative=[make file paths relative to tag file dir]:mode:(yes no always never)' \
  '(-L --input-file)'{-L,--input-file}'+[file listing paths to process (- for stdin)]:file:_files' \
  '(-R --recursive)'{-R,--recursive}'[descend recursively into subdirectories]' \
  '--recurse=[recurse into directories]:yesno:(yes no)' \
  '*--exclude=[exclude a file, directory or pattern]:pattern:' \
  '--excmd=[type of EX command to find tags]:type:(number pattern mixed combined)' \
  '-n[equivalent to --excmd=number]' \
  '--fields=[add extra fields to output]:fields:' \
  '--all-files[parse all files in recursive mode]' \
  '--format=[set output format]:format:(emacs json custom vim)' \
  '(-e --emacs)'{-e,--emacs}'[output Emacs format]' \
  '--extra=[extra flags for the formatter]:flags:' \
  '(-d --debug)'{-d,--debug}'[output parse tree]' \
  '--debug-verbose[output parse tree verbosely]' \
  '(-V --verbose)'{-V,--verbose}'[print additional information on stderr]' \
  '--force[always exit with error code 0]' \
  '--list-kinds=[print tag kinds the parser supports and exit]:lang:' \
  '--options=[read additional options from file]:file:_files' \
  '--ignore-unsupported-options[skip unsupported options instead of failing]' \
  '*:file:_files' && ret=0

return ret
