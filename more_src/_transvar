#compdef transvar
# Documentation: https://transvar.readthedocs.io/en/latest/
# multi-way annotation of genetic variants across reference versions

local ret=1
local -a subcmds

subcmds=(
  'panno:annotate protein-level variants'
  'ganno:annotate genomic-level variants'
  'canno:annotate cDNA-level variants'
  'codonsearch:search alternative codon identifiers'
  'config:configure databases and references'
  'index:index transcript annotation files'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'transvar command' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      config)
        _arguments -s -S \
          '--refversion=[reference genome version]:version:(hg18 hg19 hg38 mm9 mm10)' \
          '--download_anno[download annotation for refversion]' \
          '--download_ref[download reference for refversion]' \
          '-k[config key to set]:key:' \
          '-v[config value to set]:value:' && ret=0
        ;;
      panno|ganno|canno)
        _arguments -s -S \
          '-i[input variant annotation]:variant:' \
          '-l[input list file]:file:_files' \
          '--refversion=[reference genome version]:version:(hg18 hg19 hg38 mm9 mm10)' \
          '--reference=[reference FASTA file]:file:_files' \
          '--ensembl[use Ensembl gene annotation]' \
          '--refseq[use RefSeq gene annotation]' \
          '--ccds[use CCDS gene annotation]' \
          '--gencode[use GENCODE gene annotation]' \
          '--ucsc[use UCSC RefGene annotation]' \
          '--gene=[restrict to gene]:gene:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
