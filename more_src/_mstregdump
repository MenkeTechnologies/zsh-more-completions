#compdef mstregdump
# Documentation: https://man.archlinux.org/search?q=mstregdump
# Reference accessed: 2026-05-16

# mstregdump: register dump tool for Mellanox devices
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '-d[device]:dev:' \
  '--dev=[device]:dev:' \
  '-o[output file]:file:_files' \
  '*::mstregdump args:_files' && ret=0
return ret
