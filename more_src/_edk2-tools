#compdef edk2-tools
# Documentation: https://github.com/tianocore/edk2/tree/master/BaseTools
# Reference accessed: 2026-05-17
# Verified: upstream BaseTools at the URL above (umbrella for GenSec, GenFfs, GenFv, ...)

# edk2-tools: umbrella for EDK2 BaseTools binaries (GenSec, GenFfs, GenFv, GenFds, EfiRom, etc.)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'GenSec:generate a UEFI section'
  'GenFfs:generate a Firmware File System (FFS) file'
  'GenFv:generate Firmware Volume'
  'GenFds:generate full firmware device image'
  'GenFw:generate PE32 image'
  'EfiRom:create UEFI option ROM'
  'BootSectImage:disk boot sector helpers'
  'Brotli:Brotli compression helper'
  'GenBootSector:generate boot sector image'
  'GenCrc32:produce CRC32 for input file'
  'GenPage:generate page tables'
  'GenPatchPcdTable:patch PCD table'
  'GenVtf:generate Volume Top File'
  'LzmaCompress:LZMA compression helper'
  'PatchCheck:check Tianocore patch'
  'Split:split a binary file'
  'TianoCompress:Tiano compression helper'
  'VfrCompile:compile VFR forms'
  'VolInfo:show firmware volume info'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'edk2-tools command' commands && ret=0 ;;
esac
return ret
