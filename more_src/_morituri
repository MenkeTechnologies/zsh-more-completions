#compdef morituri rip

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'cd:CD ripping commands'
  'image:disc-image commands'
  'mblookup:MusicBrainz lookup'
  'offset:detect or set drive offset'
  'drive:list / inspect drives'
  'accurip:AccurateRip helpers'
  'help:show help'
  'debug:debugging utilities'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-R --record)'{-R,--record}'[record session]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'morituri command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (cd)
        _values 'subcmd' rip info verify && ret=0 ;;
      (image)
        _values 'subcmd' encode retag verify && ret=0 ;;
      (drive)
        _values 'subcmd' list analyze && ret=0 ;;
      (offset)
        _values 'subcmd' find && ret=0 ;;
    esac ;;
esac

return ret
