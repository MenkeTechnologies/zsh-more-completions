#compdef morituri rip
# Documentation: https://github.com/thomasvs/morituri/blob/master/morituri/rip/main.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

# Top-level rip subcommands per morituri/rip/main.py subCommandClasses.
commands=(
  'accurip:AccurateRip helpers'
  'cd:CD ripping commands'
  'debug:debugging utilities'
  'drive:drive analysis and listing'
  'image:disc-image commands'
  'offset:detect or set drive offset'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version information]' \
  '(-R --record)'{-R,--record}'[record API requests for playback]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'morituri command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (cd)
        _values 'subcmd' info rip && ret=0 ;;
      (image)
        _values 'subcmd' encode retag verify && ret=0 ;;
      (drive)
        _values 'subcmd' analyze list && ret=0 ;;
      (offset)
        _values 'subcmd' find && ret=0 ;;
      (accurip)
        _values 'subcmd' show && ret=0 ;;
    esac ;;
esac

return ret
