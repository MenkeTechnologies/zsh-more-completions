#compdef mackup

# Zsh completion for mackup - application settings backup

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-f[force, skip confirmation]' \
  '--force[force, skip confirmation]' \
  '-r[root directory]:directory:_directories' \
  '--root=[root directory]:directory:_directories' \
  '-n[dry run, just show what would be done]' \
  '--dry-run[dry run, just show what would be done]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '1:command:->command' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'backup:backup your application settings'
      'restore:restore your application settings'
      'uninstall:revert settings to their original locations'
      'list:display list of supported applications'
      'show:display the current configuration'
    )
    _describe -t commands 'mackup commands' commands && ret=0
    ;;
esac

return ret
