#compdef pfb2pfa
# Documentation: https://man.archlinux.org/man/pfb2pfa.1.en
# pfb2pfa - convert a Type 1 PostScript font in binary (PFB) form into ASCII (PFA)

local ret=1

_arguments -s \
  '-v[print information about what the program is doing]' \
  '1:PFB file:_files -g "*.pfb(-.)"' \
  '2:PFA file:_files -g "*.pfa(-.)"' && ret=0

return ret
