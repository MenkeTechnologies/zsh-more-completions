#compdef iotbx.reflection_file_converter
# Documentation: https://cci.lbl.gov/docs/cctbx/
# iotbx.reflection_file_converter - convert or modify reflection files (cctbx/iotbx)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--weak_symmetry[use weak symmetry from input file]' \
  '--label=[select array by label]:label:' \
  '--non_anomalous[convert to non-anomalous]' \
  '--r_free_label=[label of R-free flags array]:label:' \
  '--r_free_test_flag_value=[value indicating the test set]:val:' \
  '--generate_r_free_flags[generate R-free flags]' \
  '--use_lattice_symmetry_in_r_free_flag_generation[use lattice symmetry generating flags]' \
  '--no_lattice_symmetry_in_r_free_flag_generation[do not use lattice symmetry]' \
  '--r_free_flags_fraction=[fraction of reflections in test set]:frac:' \
  '--r_free_flags_max_free=[maximum number of free reflections]:n:' \
  '--r_free_flags_format=[output format of R-free flags]:format:(cns ccp4 shelx)' \
  '--output_r_free_label=[label for output R-free flags]:label:' \
  '--random_seed=[random seed]:seed:' \
  '--change_of_basis=[apply change-of-basis operator]:op:' \
  '--eliminate_invalid_indices[eliminate invalid Miller indices]' \
  '--expand_to_p1[expand data to spacegroup P1]' \
  '--change_to_space_group=[change to given space group]:sg:' \
  '--write_mtz_amplitudes[write amplitudes to MTZ]' \
  '--write_mtz_intensities[write intensities to MTZ]' \
  '--remove_negatives[remove negative intensities/amplitudes]' \
  '--massage_intensities[massage intensities for refinement]' \
  '--scale_max=[scale data to this maximum]:val:' \
  '--scale_factor=[multiply data by this factor]:val:' \
  '--write_unmerged[write unmerged data]' \
  '--sca=[write Scalepack file]:file:_files' \
  '--mtz=[write MTZ file]:file:_files -g "*.mtz"' \
  '--mtz_root_label=[root label for MTZ columns]:label:' \
  '--cns=[write CNS file]:file:_files' \
  '--shelx=[write SHELX file]:file:_files' \
  '--shelx_std_dynamic_range[use SHELX standard dynamic range]' \
  '*:reflection file:_files' && ret=0

return ret
