#compdef brightnessctl
# Documentation: https://github.com/Hummer12007/brightnessctl
# Reference accessed: 2026-05-17
# Verified: Hummer12007/brightnessctl upstream — subcommands
# (info/i, get/g, max/m, set/s VALUE) and flags (-l/--list,
# -q/--quiet, -p/--pretend, -m/--machine-readable, -s/--save,
# -r/--restore, -d/--device, -c/--class backlight|leds,
# -n/--min-value, -e/--exponent[=K], -P/--percentage, -V/--version,
# -h/--help). Set VALUE forms: N, N%, +N, -N, +N%, -N%.
# Removed from prior file: bogus man.archlinux.org search URL.

# Zsh completion for brightnessctl - backlight brightness control

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'info:get device info'
  'get:get current brightness'
  'max:get maximum brightness value'
  'set:set brightness value'
  'list:list available devices'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '(-l --list)'{-l,--list}'[list devices with available brightness controls]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-p --pretend)'{-p,--pretend}'[do not perform write operations]' \
  '(-r --restore)'{-r,--restore}'[restore previous brightness on start]' \
  '(-s --save)'{-s,--save}'[save state in a temp file]' \
  '(-d --device)'{-d,--device}'[specify device name]:device:->devices' \
  '(-c --class)'{-c,--class}'[specify device class]:class:(backlight leds)' \
  '(-m --machine-readable)'{-m,--machine-readable}'[produce machine-readable output]' \
  '(-n --min-value)'{-n,--min-value}'[set minimum brightness]:value' \
  '(-e --exponent)'{-e,--exponent}'[set exponent for curve]:exponent' \
  '1:command:->command' \
  '*:argument' && ret=0

case $state in
  command)
    _describe -t commands 'brightnessctl command' commands && ret=0
    ;;
  devices)
    local -a devices
    devices=(${(f)"$(brightnessctl --list 2>/dev/null | grep "^Device" | sed "s/Device '\\(.*\\)'.*/\\1/")"})
    _describe -t devices 'device' devices && ret=0
    ;;
esac

return ret
