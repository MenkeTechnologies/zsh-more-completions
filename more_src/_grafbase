#compdef grafbase

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'init:initialize a new project'
      'dev:start the local development server'
      'start:start the Grafbase Gateway'
      'build:build a Grafbase federated graph'
      'create:create a new Grafbase project'
      'deploy:deploy your project'
      'link:link a local project to a Grafbase project'
      'unlink:unlink a local project'
      'branch:manage branches'
      'log:show logs'
      'login:log in to Grafbase'
      'logout:log out'
      'schema:manage schemas'
      'subgraphs:manage subgraphs'
      'trust:manage trusted documents'
      'publish:publish a subgraph'
      'check:check a subgraph schema'
      'introspect:introspect a GraphQL endpoint'
      'completions:generate shell completions'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (init)
        _arguments \
          '(-t --template)'{-t,--template}'=[project template]:template:' \
          '(-g --graph)'{-g,--graph}'=[graph type]:type:(standalone federated)' \
          '1:project name:' && ret=0
        ;;
      (dev)
        _arguments \
          '(-p --port)'{-p,--port}'=[port]:port:' \
          '--search[enable search]' \
          '--log-level=[log level]:level:(error warn info debug trace)' \
          '--disable-watch[disable file watching]' \
          '--listen-address=[listen address]:address:' && ret=0
        ;;
      (start)
        _arguments \
          '--schema=[schema path]:file:_files' \
          '--config=[config file]:file:_files' \
          '(-p --port)'{-p,--port}'=[port]:port:' \
          '--listen-address=[listen address]:address:' \
          '--log-level=[log level]:level:(error warn info debug trace)' && ret=0
        ;;
      (deploy)
        _arguments \
          '--branch=[deploy branch]:branch:' && ret=0
        ;;
      (publish)
        _arguments \
          '--name=[subgraph name]:name:' \
          '--url=[subgraph URL]:url:' \
          '--schema=[schema file]:file:_files -g "*.graphql"' \
          '--dev[publish to dev environment]' && ret=0
        ;;
      (check)
        _arguments \
          '--name=[subgraph name]:name:' \
          '--schema=[schema file]:file:_files -g "*.graphql"' && ret=0
        ;;
      (introspect)
        _arguments \
          '--url=[endpoint URL]:url:' \
          '--header=[HTTP header]:header:' && ret=0
        ;;
    esac
    ;;
esac

return ret
