#compdef analyticsrelationships
# Documentation: https://github.com/Josue87/AnalyticsRelationships
# get related domains/subdomains by Google Analytics IDs

local ret=1

_arguments -s -S \
  '--url[target URL to analyze for Google Analytics IDs]:url' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
