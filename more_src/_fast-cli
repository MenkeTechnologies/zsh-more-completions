#compdef fast fast-cli

# Zsh completion for fast-cli - Netflix speed test CLI

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--json[output results as JSON]' \
  '--single-line[output results on a single line]' \
  '--upload[also measure upload speed]'
