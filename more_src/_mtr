#compdef mtr
# _mtr — Matt Kimball / Travis Cross mtr (My TraceRoute; combined ping + traceroute with continuous per-hop loss/latency stats; curses TUI or report mode)
# upstream: https://github.com/traviscross/mtr
# Flags from ui/mtr.c long_options on tip.

_mtr() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)*'{-v,--version}'[show version and exit (repeat for build info)]' \
        '(-4 --inet -6 --inet6)'{-4,--inet}'[force IPv4]' \
        '(-4 --inet -6 --inet6)'{-6,--inet6}'[force IPv6]' \
        '(-F --filename)'{-F+,--filename=}'[host list from file]:file:_files' \
        '(-r --report -w --report-wide -x --xml -t --curses -g --gtk -l --raw -C --csv -j --json -p --split)'{-r,--report}'[report mode]' \
        '(-r --report -w --report-wide -x --xml -t --curses -g --gtk -l --raw -C --csv -j --json -p --split)'{-w,--report-wide}'[wide report mode]' \
        '--report-on-exit[curses + report-on-exit]' \
        '(-r --report -w --report-wide -x --xml -t --curses -g --gtk -l --raw -C --csv -j --json -p --split)'{-x,--xml}'[XML output]' \
        '(-r --report -w --report-wide -x --xml -t --curses -g --gtk -l --raw -C --csv -j --json -p --split)'{-t,--curses}'[curses TUI mode]' \
        '(-r --report -w --report-wide -x --xml -t --curses -g --gtk -l --raw -C --csv -j --json -p --split)'{-g,--gtk}'[GTK+ GUI mode]' \
        '(-r --report -w --report-wide -x --xml -t --curses -g --gtk -l --raw -C --csv -j --json -p --split)'{-l,--raw}'[raw output]' \
        '(-r --report -w --report-wide -x --xml -t --curses -g --gtk -l --raw -C --csv -j --json -p --split)'{-C,--csv}'[CSV output]' \
        '(-r --report -w --report-wide -x --xml -t --curses -g --gtk -l --raw -C --csv -j --json -p --split)'{-j,--json}'[JSON output]' \
        '(-r --report -w --report-wide -x --xml -t --curses -g --gtk -l --raw -C --csv -j --json -p --split)'{-p,--split}'[split mode (BL)]' \
        '--displaymode=[curses display mode]:mode:(0 1 2)' \
        '--compact[compact curses display]' \
        '--scale=[curses display scale]:n:' \
        '(-n --no-dns)'{-n,--no-dns}'[disable reverse DNS]' \
        '(-b --show-ips)'{-b,--show-ips}'[show both IP and hostname]' \
        '(-o --order)'{-o+,--order=}'[fields to display + order]:fields:' \
        '(-y --ipinfo)'{-y+,--ipinfo=}'[IP info lookup]:n:' \
        '(-z --aslookup)'{-z,--aslookup}'[AS lookup (--ipinfo 0)]' \
        '--ipinfo_provider4=[IPv4 IP-info provider]:provider:' \
        '--ipinfo_provider6=[IPv6 IP-info provider]:provider:' \
        '(-i --interval)'{-i+,--interval=}'[probe interval (sec)]:sec:' \
        '(-c --report-cycles)'{-c+,--report-cycles=}'[probes per host (report mode)]:n:' \
        '(-s --psize)'{-s+,--psize=}'[probe packet size in bytes (-N = rand)]:bytes:' \
        '(-B --bitpattern)'{-B+,--bitpattern=}'[bit pattern (-1=rand, 0-255)]:n:' \
        '(-Q --tos)'{-Q+,--tos=}'[ToS byte (0-255)]:n:' \
        '(-e --mpls)'{-e,--mpls}'[show MPLS info]' \
        '(-I --interface)'{-I+,--interface=}'[outgoing interface]:iface:_net_interfaces' \
        '(-a --address)'{-a+,--address=}'[bind source address]:ip:' \
        '(-f --first-ttl)'{-f+,--first-ttl=}'[start TTL]:n:' \
        '(-m --max-ttl)'{-m+,--max-ttl=}'[max TTL]:n:' \
        '(-D --due-ttl)'{-D+,--due-ttl=}'[due TTL]:n:' \
        '(-U --max-unknown)'{-U+,--max-unknown=}'[max unknown hops]:n:' \
        '(-E --max-display-path)'{-E+,--max-display-path=}'[max displayed hops]:n:' \
        '(-u --udp)'{-u,--udp}'[use UDP probes]' \
        '(-T --tcp)'{-T,--tcp}'[use TCP probes]' \
        '(-S --sctp)'{-S,--sctp}'[use SCTP probes]' \
        '(-P --port)'{-P+,--port=}'[target port (TCP/SCTP/UDP)]:port:' \
        '(-L --localport)'{-L+,--localport=}'[source port (UDP)]:port:' \
        '(-Z --timeout)'{-Z+,--timeout=}'[per-probe timeout (sec)]:sec:' \
        '(-G --gracetime)'{-G+,--gracetime=}'[grace time after last probe (sec)]:sec:' \
        '--cache=[skip probes to recently seen hops (sec)]:sec:' \
        '(-M --mark)'{-M+,--mark=}'[SO_MARK value (Linux)]:mark:' \
        '*:host:_hosts'
}

_mtr "$@"
