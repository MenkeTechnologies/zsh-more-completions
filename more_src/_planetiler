#compdef planetiler
# Documentation: https://github.com/onthegomap/planetiler/blob/main/README.md
# planetiler - build planet-scale vector tilesets from OpenStreetMap data

local ret=1

_arguments -s \
  '--help[show available arguments]' \
  '--area=[download an OSM extract from Geofabrik]:area' \
  '--osm-path=[path to an existing OSM extract on disk]:file:_files' \
  '--download[automatically download input sources]' \
  '--only-download[download sources then exit without generating tiles]' \
  '--output=[output file path and format]:file:_files' \
  '--force[overwrite the output file if it exists]' \
  '--append[append to an existing output archive]' \
  '--tile-format=[output tile format]:format' \
  '--tile-compression=[output tile compression]:compression' \
  '--water-polygons-url=[custom URL for water polygon data]:url' \
  '--natural-earth-url=[custom URL for Natural Earth data]:url' \
  '--pushgateway=[export stats to a Prometheus push gateway]:url' \
  '--building-merge-z13=[merge buildings at zoom level 13]:bool:(true false)' \
  '*::arg:_default' && ret=0

return ret
