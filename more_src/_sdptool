#compdef sdptool
# _sdptool — BlueZ sdptool (Bluetooth Service Discovery Protocol CLI; search records by UUID/name, browse remote SDP records, add a local record from XML, del a record, get/set attributes; -i hciX source device, -l local-only, -t transport (default L2CAP))
# upstream: https://github.com/bluez/bluez (tools/sdptool.c)
# Subcommands from bluez tools/sdptool.c on tip.

_sdptool() {
    _arguments \
        '-h[show help]' \
        '-i+[hciX source]:device:' \
        '-l[local-only operations]' \
        '-t+[transport]:transport:(L2CAP RFCOMM)' \
        '1:command:(search browse records add del get set setattr setseq)' \
        '*::arg:'
}

_sdptool "$@"
