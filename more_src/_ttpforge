# WHAT IS spf13/afero AND WHY IS IT THE 67TH GO CLI LIBRARY?
#
# afero (https://github.com/spf13/afero, 6,658+ stars) is **Steve
# Francia's "Universal Filesystem Abstraction for Go"** — a
# foundational library for Go applications that need to abstract
# filesystem operations behind an interface.  Where camino (R637)
# solves Rust's "paths are OsStr not UTF-8" problem, afero solves
# Go's "I need to mock the filesystem in tests + scope writes to a
# base path + overlay an in-memory layer on a read-only source"
# problem.
#
# afero's distinguishing characteristics:
#
#   1. Fs INTERFACE WITH 7+ BUILT-IN IMPLEMENTATIONS — afero's
#      central feature is the `Fs` interface that any filesystem
#      implementation can satisfy:
#
#          import "github.com/spf13/afero"
#
#          // Production: real OS filesystem
#          var fs afero.Fs = afero.NewOsFs()
#
#          // Test: in-memory filesystem (no disk touch)
#          var testFs afero.Fs = afero.NewMemMapFs()
#
#          // Sandbox: chroot OsFs to /var/lib/myapp
#          var sandboxFs afero.Fs = afero.NewBasePathFs(
#              afero.NewOsFs(), "/var/lib/myapp")
#
#          // Read-only wrapper over any Fs:
#          var roFs afero.Fs = afero.NewReadOnlyFs(fs)
#
#          // Filter files by regex:
#          var filteredFs afero.Fs = afero.NewRegexpFs(fs,
#              regexp.MustCompile(`\.yaml$`))
#
#          // HTTP filesystem (read-only):
#          var httpFs afero.Fs = afero.NewHttpFs(http.Dir("/srv"))
#
#          // Copy-on-write overlay (in-memory writes over OsFs):
#          var cowFs afero.Fs = afero.NewCopyOnWriteFs(
#              afero.NewOsFs(), afero.NewMemMapFs())
#
#          // Cache reads on top of slow Fs (e.g. HTTP):
#          var cachedFs afero.Fs = afero.NewCacheOnReadFs(
#              httpFs, afero.NewMemMapFs(), 0)
#
#      Compare:
#         * Rust camino (R637): UTF-8 path types (different problem)
#         * Go path/filepath stdlib: just string manipulation
#         * Go os package: real filesystem only
#         * Go billy (go-git): similar abstraction for git
#         * afero: 7+ Fs IMPLEMENTATIONS via SINGLE INTERFACE
#      FIRST documented Go Axis 14 library with Fs interface +
#      7+ built-in implementations.
#
#   2. afero.Afero CONVENIENCE WRAPPER — beyond the raw Fs
#      interface, afero provides the Afero struct with
#      higher-level helpers:
#
#          import "github.com/spf13/afero"
#
#          // Wrap an Fs with convenience methods:
#          fs := afero.Afero{Fs: afero.NewOsFs()}
#
#          // Higher-level operations:
#          data, _ := fs.ReadFile("config.yaml")
#          fs.WriteFile("output.txt", []byte("hello"), 0644)
#          entries, _ := fs.ReadDir("/etc")
#          temp, _ := fs.TempDir("", "myapp-")
#          tempfile, _ := fs.TempFile("", "tmp-*.json")
#          matches, _ := fs.Glob("/etc/*.conf")
#          exists, _ := fs.Exists("/etc/passwd")
#          isDir, _ := fs.IsDir("/etc")
#          isEmpty, _ := fs.IsEmpty("/tmp")
#          contains, _ := fs.FileContainsBytes("file", []byte("text"))
#
#      Compare:
#         * Rust camino (R637): no convenience layer
#         * Go path/filepath: no convenience helpers
#         * Go os package: low-level only
#         * afero: HIGH-LEVEL Afero{Fs} struct with 15+ helpers
#      FIRST documented Go Axis 14 library with convenience-
#      wrapper struct adding 15+ high-level helper methods.
#
#   3. TEST-FIRST DESIGN via MemMapFs — afero's MemMapFs (in-
#      memory filesystem) is the DE-FACTO STANDARD for testing
#      Go applications that touch the filesystem.  Tests can
#      set up arbitrary directory structures + run in parallel
#      without disk I/O:
#
#          func TestFileProcessor(t *testing.T) {
#              fs := afero.NewMemMapFs()
#
#              // Set up test fixture in memory:
#              afero.WriteFile(fs, "/test/input.txt",
#                  []byte("hello world"), 0644)
#              afero.WriteFile(fs, "/test/config.yaml",
#                  []byte("key: value"), 0644)
#
#              // Run code under test against the in-memory fs:
#              processor := NewProcessor(fs)
#              result, err := processor.Run("/test/input.txt")
#
#              if err != nil { t.Fatal(err) }
#              // Verify output written to in-memory fs:
#              out, _ := afero.ReadFile(fs, "/test/output.txt")
#              assert.Equal(t, []byte("HELLO WORLD"), out)
#          }
#
#      Compare:
#         * Rust camino (R637): no in-memory filesystem
#         * Go stdlib testing/fstest.MapFS: similar but newer
#                                             (added Go 1.16),
#                                             read-only by default
#         * Node memfs / mock-fs: similar concept in Node
#         * afero MemMapFs: PIONEERING in-memory filesystem for
#                             Go tests (2014+)
#      FIRST documented Go Axis 14 library with read/write
#      in-memory filesystem testing primitive.
#
#   4. CUSTOM Fs IMPLEMENTATIONS via INTERFACE — third-party
#      packages can implement the Fs interface for arbitrary
#      backends without modifying afero itself:
#
#          // Existing third-party afero Fs implementations:
#          // - github.com/spf13/afero/s3      → AWS S3
#          // - github.com/spf13/afero/gcsfs   → Google Cloud Storage
#          // - github.com/spf13/afero/zipfs   → ZIP archives
#          // - github.com/spf13/afero/tarfs   → tar archives
#          // - github.com/spf13/afero/sftpfs  → SFTP
#          // - github.com/airline/afero-azurefs → Azure Blob Storage
#          // - github.com/airline/afero-mssql → MS SQL Server BLOBs
#
#          import "github.com/spf13/afero"
#          import "github.com/spf13/afero/s3"
#
#          fs := s3.NewFs("my-bucket", awsConfig)
#          afero.WriteFile(fs, "path/to/key.json", data, 0644)
#
#      Compare:
#         * Rust camino (R637): single-purpose UTF-8 paths
#         * Go path/filepath: no abstraction
#         * Go billy: limited to git-style backends
#         * afero: PLUGGABLE Fs implementations for cloud + archive
#                   + database backends
#      FIRST documented Go Axis 14 library with pluggable cloud-
#      backend filesystem implementations.
#
#   5. STEVE-FRANCIA / SPF13-ECOSYSTEM PROVENANCE — afero is by
#      Steve Francia (spf13 on GitHub, also author of cobra +
#      pflag + viper + hugo).  With R638, afero becomes the
#      FOURTH spf13 library documented in the taxonomy:
#         * pflag — Axis 1 (POSIX/GNU argument parsing)
#         * cobra — Axis 1 (CLI subcommand framework)
#         * viper — Axis 13 (R630, layered config management)
#         * afero — Axis 14 (R638 THIS — filesystem abstraction)
#         * hugo — built ON TOP of all four, 75k+ stars
#      Steve is the SPF13 TRINITY+1 — his ecosystem powers Hugo
#      (75k) + kubectl + Helm (27k) + Istio + etcd + OpenShift +
#      GitHub CLI + 50,000+ Go applications.
#      Downstream afero users:
#         * Hugo (THE foundational consumer, 75k stars)
#         * kubectl (partial, Kubernetes CLI)
#         * filebrowser (file-sharing UI, 30k stars)
#         * jesseduffield/lazygit (Git TUI, 64k stars)
#         * TykTechnologies/tyk (API gateway, 11k stars)
#         * coder/coder (development environments)
#         * terraform-linters/tflint (Terraform linter, 5k stars)
#         * go-shiori/shiori (bookmark manager, 11k stars)
#         * mgechev/revive (Go linter, 5k stars)
#         * okteto/okteto (Kubernetes dev environments)
#         * kubernetes-sigs/kubebuilder (k8s operator scaffold)
#         * facebookincubator/TTPForge (THIS — 421 stars)
#         * 20,000+ Go applications via cobra/viper transitive
#      FIRST documented Go Axis 14 library with this specific
#      Steve-Francia spf13-trinity-plus-one ecosystem provenance.
#
# afero's relationship to camino (R637) and other Axis 14
# libraries:
#
#   * Unlike camino (R637, Rust) — camino solves UTF-8 path
#                                    encoding; afero solves
#                                    filesystem abstraction
#                                    (different aspects of paths/
#                                    filesystem)
#   * Closest cross-language analogs:
#         * Rust virtual_fs / vfs — similar interface abstraction
#         * Node memfs / mock-fs — in-memory testing
#         * Node fs-extra — convenience wrappers (closer to
#                              afero.Afero helpers)
#         * Python pyfakefs — in-memory fs for tests
#         * Python fsspec — pluggable fs backends
#     afero is the FIRST documented Go Axis 14 library providing
#     Fs interface + 7+ built-in implementations + Afero
