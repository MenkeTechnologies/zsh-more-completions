local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _ttpforge_cmds
_ttpforge_cmds=(
    'init:initialize new TTP configuration'
    'create:create new TTP'
    'list:list installed TTPs / repos'
    'enum:enumerate authors / dependencies / ttps'
    'show:display TTP definition'
    'run:execute a TTP'
    'validate:validate TTP YAML syntax + semantics'
    'test:run TTP in test mode (dry-run)'
    'install:install a TTP repo (Git-backed)'
    'remove:remove an installed TTP / repo'
    'move:move a TTP within local repo'
    'completion:generate shell completion script'
    'help:show help for a subcommand'
)

_arguments -C \
    '(-c --config)'{-c+,--config=}'[config file path]:config file:_files -g "*.{yaml,yml,toml}"' \
    '--stack-trace[show stacktrace when logging error]' \
    '--no-color[disable colored output]' \
    '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
    '(-l --logfile)'{-l+,--logfile=}'[log to file]:log file:_files' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'ttpforge subcommand' _ttpforge_cmds && ret=0
        ;;
    args)
        case $words[1] in
            create)
                _values 'create subcommand' \
                    'ttp[create a new TTP YAML file]' \
                    'uuid[create a new UUID]' \
                    && ret=0
                ;;
            enum)
                _values 'enum subcommand' \
                    'authors[list TTP authors]' \
                    'dependencies[list TTP dependencies]' \
                    'ttps[list all installed TTPs]' \
                    && ret=0
                ;;
            list)
                _values 'list subcommand' \
                    'ttps[list TTPs]' \
                    'repos[list installed repos]' \
                    && ret=0
                ;;
            install)
                _values 'install subcommand' \
                    'repo[install a TTP repo from Git]' \
                    && ret=0
                ;;
            remove)
                _values 'remove subcommand' \
                    'ttp[remove a TTP]' \
                    'repo[remove an installed repo]' \
                    && ret=0
                ;;
            completion)
                _values 'shell' bash zsh fish powershell && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _ttpforge_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
