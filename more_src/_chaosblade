#compdef chaosblade
# Documentation: https://github.com/chaosblade-io/chaosblade
# ChaosBlade chaos engineering experiment toolkit (blade)

local ret=1
local curcontext="$curcontext" state line

_arguments -s -C \
  '(-d --debug)'{-d,--debug}'[set client to DEBUG mode]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'command' \
      'prepare[preparation before the chaos engineering experiment]' \
      'p[preparation before the chaos engineering experiment]' \
      'revoke[undo chaos engineering experiment preparation]' \
      'r[undo chaos engineering experiment preparation]' \
      'create[create a chaos engineering experiment]' \
      'c[create a chaos engineering experiment]' \
      'destroy[destroy a chaos engineering experiment]' \
      'd[destroy a chaos engineering experiment]' \
      'status[query preparation stage or experiment status]' \
      's[query preparation stage or experiment status]' \
      'query[query the parameter values required for chaos experiments]' \
      'server[start the web server and expose the HTTP service]' \
      'version[print version information]' \
      'help[help about any command]' && ret=0
    ;;
  args)
    case $line[1] in
      create|c)
        _arguments -s \
          '--uid=[set Uid for the experiment]:uid' \
          '--timeout=[set experiment timeout in seconds]:seconds' \
          '(-a --async)'{-a,--async}'[whether to create asynchronously]' \
          '(-e --endpoint)'{-e,--endpoint}'=[create result reporting address]:url' \
          '(-n --nohup)'{-n,--nohup}'[used to internal async create]' \
          '(-d --debug)'{-d,--debug}'[set client to DEBUG mode]' \
          '*:target:->targets' && ret=0
        ;;
      destroy|d|revoke|r|status|s)
        _arguments -s \
          '--type=[filter by experiment type create or prepare]:type:(create prepare)' \
          '(-d --debug)'{-d,--debug}'[set client to DEBUG mode]' \
          '*:uid:' && ret=0
        ;;
      server)
        _arguments -s \
          '(-p --port)'{-p,--port}'=[set web server port]:port' \
          '*:action:(start stop)' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
