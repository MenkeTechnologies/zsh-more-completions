#compdef ratproxy

_arguments -s \
  '-w[log file]:file:_files' \
  '-v[trace dir]:dir:_files -/' \
  '-p[listen port]:port:' \
  '*-d[analyze only domain]:domain:' \
  '-P[upstream proxy]:host:port:' \
  '-r[accept remote connections]' \
  '-l[use response length for identity]' \
  '-2[two-page identity check]' \
  '-e[pedantic caching checks]' \
  '-x[log XSS candidates]' \
  '-t[log directory traversal]' \
  '-i[log inline PNG]' \
  '-f[log Flash apps]' \
  '-s[log POST requests]' \
  '-c[log cookie-setting URLs]' \
  '-g[XSRF token checks on GET]' \
  '-j[risky JS constructions]' \
  '-m[log cross-domain active content]' \
  '-X[disruptive XSRF/XSS validation]' \
  '-C[auto-correct after -X]' \
  '-k[flag HTTP requests as bad]' \
  '-a[report all visited URLs]'
