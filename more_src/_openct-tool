#compdef openct-tool

# OpenCT openct-tool: send APDU commands to OpenCT readers
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[debug level]:n:' \
  '-f[config file]:file:_files' \
  '-r[reader number]:n:' \
  '-l[list available readers]' \
  '-h[show help]' \
  '*::openct-tool command:_files' && ret=0
return ret
