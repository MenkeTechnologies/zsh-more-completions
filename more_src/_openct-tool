#compdef openct-tool

# openct-tool: smart card reader/cardstack debug tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'list:list readers'
  'atr:show ATR for reader'
  'mf:show MF for reader'
  'fread:read file'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-d[debug level]:level:' \
  '-r[reader index]:n:' \
  '-s[slot]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'openct-tool command' commands && ret=0 ;;
esac
return ret
