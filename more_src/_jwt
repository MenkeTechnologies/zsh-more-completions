#compdef jwt

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'encode:encode a JWT'
      'decode:decode a JWT'
    )
    _describe -t commands 'jwt command' commands && ret=0
    ;;
  args)
    case $words[1] in
      encode)
        _arguments -s -S \
          {-A,--alg}'=[algorithm]:algorithm:(HS256 HS384 HS512 RS256 RS384 RS512 ES256 ES384 PS256 PS384 PS512 EdDSA)' \
          {-S,--secret}'=[secret key]:secret' \
          {-e,--exp}'=[expiration time]:expiration' \
          {-i,--iss}'=[issuer]:issuer' \
          {-s,--sub}'=[subject]:subject' \
          {-a,--aud}'=[audience]:audience' \
          '--nbf=[not before]:not before' \
          '*'{-P,--payload}'=[payload claim]:claim' \
          '*--header=[header claim]:header' \
          '--no-iat[disable automatic iat claim]' \
          '--secret-b64[decode secret as base64]' \
          && ret=0
        ;;
      decode)
        _arguments -s -S \
          {-S,--secret}'=[secret key]:secret' \
          {-A,--alg}'=[algorithm]:algorithm:(HS256 HS384 HS512 RS256 RS384 RS512 ES256 ES384 PS256 PS384 PS512 EdDSA)' \
          {-j,--json}'[JSON output]' \
          '--iso8601[use ISO 8601 date format]' \
          '--no-verify[skip verification]' \
          '--secret-b64[decode secret as base64]' \
          '1:token' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
