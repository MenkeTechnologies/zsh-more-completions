#compdef cmemit

# Infernal cmemit: emit sequences from a CM (sampling or consensus)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output sequence file]:file:_files' \
  '-N[number of sequences to emit]:n:' \
  '-c[emit consensus sequence]' \
  '-l[emit local alignment-style sequences]' \
  '-u[emit unaligned sequences (default)]' \
  '-a[emit aligned sequences]' \
  '--exp[emit with exponentiated state probabilities]:exp:' \
  '--seed[random seed]:n:' \
  '--rna[emit RNA sequence (default)]' \
  '--dna[emit DNA sequence]' \
  '--idx[number sequences sequentially]' \
  '--devhelp[show developer options]' \
  '--informat[input format]:format:(fasta)' \
  '--outformat[output format]:format:(fasta stockholm pfam a2m afa clustal phylip phylips)' \
  '*:CM file:_files' && ret=0
return ret
