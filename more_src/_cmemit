#compdef cmemit
# Documentation: https://manpages.debian.org/testing/infernal/cmemit.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Infernal cmemit: emit sequences from a CM (sampling or consensus)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output sequence file]:file:_files' \
  '-N[number of sequences to emit]:n:' \
  '-c[emit single majority-rule consensus sequence]' \
  '-l[configure models into local mode]' \
  '-u[output in FASTA format (default)]' \
  '-a[output in aligned Stockholm format]' \
  '-e[embed emitted sequences in larger random sequence]:n:' \
  '--u5p[randomly truncate sequences at 5-prime end]' \
  '--u3p[randomly truncate sequences at 3-prime end]' \
  '--a5p[truncate aligned output at 5-prime match position]:n:' \
  '--a3p[truncate aligned output at 3-prime match position]:n:' \
  '--exp[adjust emission/transition probabilities]:x:' \
  '--seed[random seed]:n:' \
  '--iid[emit 25% iid A/C/G/U sequences]' \
  '--rna[emit RNA (default)]' \
  '--dna[emit DNA]' \
  '--idx[starting sequence index]:n:' \
  '--outformat[alignment output format]:format:(pfam a2m afa clustal phylip phylips)' \
  '--hmmonly[emit from HMM filter instead of CM]' \
  '--nohmmonly[always emit from CM]' \
  '--devhelp[show developer options]' \
  '*:CM file:_files' && ret=0
return ret
