#compdef gmap_build
# Documentation: https://manpages.debian.org/testing/gmap/gmap_build.1.en.html
# Build a GMAP/GSNAP genome database from FASTA files

local ret=1

_arguments -s -S \
  '(-D --genomedir)'{-D,--genomedir=}'[destination directory for installation]:dir:_files -/' \
  '(-d --genomedb)'{-d,--genomedb=}'[genome name (required)]:name:' \
  '(-n --names)'{-n,--names=}'[substitute names for contigs, provided in a file]:file:_files' \
  '(-L --limit-to-names)'{-L,--limit-to-names}'[limit the genome build to lines listed in the --names file]' \
  '(-k --kmer)'{-k,--kmer=}'[k-mer value for genomic index (allowed: 15 or less)]:int:' \
  '-q+[sampling interval for genome (allowed: 1-3)]:int:' \
  '(-s --sort)'{-s,--sort=}'[sort chromosomes using given method]:method:(none alpha numeric-alpha chrom names)' \
  '(-g --gunzip)'{-g,--gunzip}'[files are gzipped, so need to gunzip each file first]' \
  '(-E --fasta-pipe)'{-E,--fasta-pipe=}'[interpret argument as a command, instead of a list of FASTA files]:command:' \
  '(-Q --fastq)'{-Q,--fastq}'[files are in FASTQ format]' \
  '(-R --revcomp)'{-R,--revcomp}'[reverse complement all contigs]' \
  '-w+[wait (sleep) this many seconds after each step]:int:' \
  '(-o --circular)'{-o,--circular=}'[circular chromosomes (a comma-separated list or a filename)]:circular:' \
  '(-2 --altscaffold)'{-2,--altscaffold=}'[file with alt scaffold info]:file:_files' \
  '(-e --nmessages)'{-e,--nmessages=}'[maximum number of messages to report]:int:' \
  '--sarray=[whether to build suffix array: 0=no, 1=yes]:int:' \
  '(-M --mdflag)'{-M,--mdflag=}'[use MD file from NCBI for mapping contigs to chromosomal coordinates]:string:' \
  '(-C --transcriptomedir)'{-C,--transcriptomedir=}'[destination directory for installation]:dir:_files -/' \
  '(-c --transcriptomedb)'{-c,--transcriptomedb=}'[transcriptome name]:name:' \
  '--gtf=[GTF file containing transcripts]:file:_files' \
  '--gff3=[GFF3 file containing transcripts]:file:_files' \
  '(-G --genes)'{-G,--genes=}'[genes file containing transcripts]:file:_files' \
  '(-T --transcripts)'{-T,--transcripts=}'[FASTA file containing transcripts]:file:_files' \
  '(-t --nthreads)'{-t,--nthreads=}'[number of threads for GMAP alignment of transcripts to genome]:int:' \
  '*:fasta file:_files' && ret=0

return ret
