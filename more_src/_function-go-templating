#compdef function-go-templating
# _function-go-templating — Crossplane composition function that renders managed resources from a Go text/template (gRPC server consumed by crossplane)
# upstream: https://github.com/crossplane-contrib/function-go-templating
# Flags from main.go on tip (alecthomas/kong).

_function-go-templating() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[emit debug logs in addition to info logs]' \
        '--network=[network on which to listen for gRPC connections]:net:(tcp unix)' \
        '--address=[address on which to listen for gRPC connections]:addr:' \
        '--tls-server-certs-dir=[directory containing server tls.key + tls.crt + ca.crt]:dir:_files -/' \
        '--insecure[run without mTLS credentials (--tls-server-certs-dir is ignored)]' \
        '--ttl=[function global response TTL]:duration:' \
        '--max-recv-message-size=[max received message size (MB)]:n:' \
        '--default-source=[default template source when input is not provided (FUNCTION_GO_TEMPLATING_DEFAULT_SOURCE)]:src:(Inline FileSystem)' \
        '--default-options=[csv default template options (FUNCTION_GO_TEMPLATING_DEFAULT_OPTIONS)]:csv:'
}

_function-go-templating "$@"
