#compdef coordconv
# CCP4: interconvert various coordinate formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input coordinate file]:coordinates:_files' \
  'XYZOUT[output coordinate file]:output:_files' \
  '*:keyword:(INPUT OUTPUT CELL END)' && ret=0

return ret
