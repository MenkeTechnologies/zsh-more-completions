#compdef sfricker1
# Documentation: https://raw.githubusercontent.com/ahay/src/master/system/seismic/Mricker1.c
# Madagascar: convolve input data with a Ricker wavelet

local ret=1

_arguments -s \
  'frequency=[peak frequency for Ricker wavelet (in Hz)]:frequency' \
  'freq=[peak frequency as fraction of Nyquist]:freq' \
  'deriv=[apply a half-order derivative filter]:deriv:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
