#compdef calligrawords
# Documentation: https://man.archlinux.org/search?q=calligrawords
# Reference accessed: 2026-05-16

# Calligra Words: word processor (Qt/KDE/Calligra suite)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help and exit]' \
  '(- *)--help[show help and exit]' \
  '(- *)--help-all[show all Qt/KF6 help options]' \
  '(- *)--help-kde[show KDE specific options]' \
  '(- *)--help-qt[show Qt specific options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--no-splash[do not show splash screen]' \
  '--template[start from template]:template:_files' \
  '--new[create new document]' \
  '--print[print the document]' \
  '--print-preview[show print preview]' \
  '--export[export to file]:file:_files' \
  '--export-pdf[export to PDF]:file:_files -g "*.pdf"' \
  '--profile[start with a profile]:name:' \
  '*:document:_files -g "*(.odt|.doc|.docx|.rtf|.txt)"' && ret=0
return ret
