#compdef thonny
# Documentation: https://man.archlinux.org/search?q=thonny
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--replayer[run replayer]' \
  '*:file:_files -g "*.py"' && ret=0

return ret
