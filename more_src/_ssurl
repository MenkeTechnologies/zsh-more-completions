#compdef ssurl
# Documentation: https://github.com/shadowsocks/shadowsocks-rust/blob/master/bin/ssurl.rs
# Reference accessed: 2026-05-21
# Verified: upstream Rust source defines encode/decode/qrcode/outline args via clap.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --decode -o --outline)'{-e+,--encode=}'[encode server config (JSON) to ss\:// URL]:file:_files -g "*.json"' \
  '(-e --encode -o --outline)'{-d+,--decode=}'[decode ss\:// URL to JSON config]:file:_files' \
  '(-c --qrcode)'{-c,--qrcode}'[generate QR code with provided configuration]' \
  '(-e --encode -d --decode)'{-o+,--outline=}'[fetch and decode config from ssconf (Outline) URL]:url:' && ret=0

return ret
