#compdef mas-app-store mas-cli2
# _mas-app-store — mas-cli Mac App Store CLI alias (mas-cli team / Andrew Naylor, Swift); ArgumentParser
# upstream: https://github.com/mas-cli/mas

_mas-app-store() {
    local -a sub=(
        'account:show current iTunes/App Store account'
        'home:open home page in browser'
        'info:show app information'
        'install:install app by ID'
        'list:list installed apps'
        'lucky:install first search result'
        'open:open app store page'
        'outdated:list outdated apps'
        'purchase:purchase app (deprecated)'
        'reset:reset cache'
        'search:search apps in App Store'
        'signin:sign in (deprecated)'
        'signout:sign out (deprecated)'
        'uninstall:remove apps'
        'upgrade:upgrade outdated apps'
        'vendor:open vendor page'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mas subcommand' sub ;;
        args)
            case $words[1] in
                install|info|home|open|outdated|reinstall|uninstall|purchase|vendor) _arguments '*:app-id:' ;;
                search|lucky) _arguments \
                    '--price[show price]' \
                    '*:term:' ;;
                list|account|reset|signin|signout|version) _arguments '*:arg:' ;;
                upgrade) _arguments '*:app-id-or-name:' ;;
            esac
            ;;
    esac
}

_mas-app-store "$@"
