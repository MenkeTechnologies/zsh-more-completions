#compdef whaler
# Documentation: https://github.com/P3GLEG/Whaler
# whaler: reverse-engineer Docker images to discover Dockerfile and contents

local ret=1

_arguments -s \
  '-f[file containing images to analyze, one per line]:file:_files' \
  '-filter[filter filenames that create noise (e.g. node_modules)]' \
  '-sV[set Docker client API version (e.g. 1.36)]:version' \
  '-v[print comprehensive details about the image]' \
  '-x[save layers to the current directory]' \
  '*:image:_default' && ret=0

return ret
