#compdef vboxballoonctrl VBoxBalloonCtrl
# Documentation: https://www.virtualbox.org/manual/UserManual.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-b+[balloon increment MB]:mb:' \
  '-d+[balloon decrement MB]:mb:' \
  '-i+[balloon lower limit MB]:mb:' \
  '-l+[balloon safety margin MB]:mb:' \
  '-m+[max balloon size MB]:mb:' \
  '-t+[time delta sec]:sec:' \
  '-r[do not check)\)[do not check VM]' \
  '-P+[pid file]:file:_files' \
  '--logfile=+[log file]:file:_files' \
  '--logrotate=+[log rotation]:n:' \
  '--logsize=+[max log size]:bytes:' \
  '--loginterval=+[log interval]:sec:' \
  '-v[verbose]' \
  '-q[quiet]' \
  '-c[config file]:file:_files' && ret=0

return ret
