#compdef pkmosaic
# Documentation: https://pktools.nongnu.org/html/pkmosaic.html
# mosaic and composite raster images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input image file(s). If input contains multiple images, a multi-band o]:file:_files' \
  '(-o --output)'{-o,--output}'[Output image file]:file:_files' \
  '(-p --projection)'{-p,--projection}'[projection in EPSG format (leave blank to copy from input file, use EP]:value:' \
  '(-e --extent)'{-e,--extent}'[get boundary from extent from polygons in vector file]:value:' \
  '(-ulx --ulx)'{-ulx,--ulx}'[Upper left x value bounding box (in geocoordinates if georef is true)]:value:' \
  '(-uly --uly)'{-uly,--uly}'[Upper left y value bounding box (in geocoordinates if georef is true)]:value:' \
  '(-lrx --lrx)'{-lrx,--lrx}'[Lower right x value bounding box (in geocoordinates if georef is true)]:value:' \
  '(-lry --lry)'{-lry,--lry}'[Lower right y value bounding box (in geocoordinates if georef is true)]:value:' \
  '(-b --band)'{-b,--band}'[band index to crop (-1\: crop all bands)]:value:' \
  '(-ot --otype)'{-ot,--otype}'[Data type for output image ({Byte/Int16/UInt16/UInt32/Int32/Float32/Fl]:value:' \
  '(-of --oformat)'{-of,--oformat}'[Output image format (see also gdal_translate). Empty string\: inherit f]:value:' \
  '(-ct --ct)'{-ct,--ct}'[color table (file with 5 columns\: id R G B ALFA (0\: transparent, 255\:]:file:_files' \
  '(-dx --dx)'{-dx,--dx}'[Output resolution in x (in meter) (0.0\: keep original resolution)]:value:' \
  '(-dy --dy)'{-dy,--dy}'[Output resolution in y (in meter) (0.0\: keep original resolution)]:value:' \
  '(-co --co)'{-co,--co}'[options\: NAME=VALUE \[-co COMPRESS=LZW\] \[-co INTERLEAVE=BAND\]]:value:' \
  '(-f --flag)'{-f,--flag}'[Flag value to put in image if out of bounds.]' \
  '(-r --resample)'{-r,--resample}'[Resampling method (0\: nearest neighbour, 1\: bi-linear interpolation).]:value:' \
  '--description[Set image description]:value:' \
  '(-m --mrule)'{-m,--mrule}'[Mosaic rule for mosaic (0\: overwrite, 1\: max ndvi, 2\: max Band, 3\: min]:value:' \
  '(-rb --rband)'{-rb,--rband}'[band index used for the rule (for ndvi, use –ruleBand=redBand –ruleBan]:value:' \
  '(-vb --validBand)'{-vb,--validBand}'[valid band index(es)]:value:' \
  '(-t --invalid)'{-t,--invalid}'[invalid value for valid band]:value:' \
  '(-min --min)'{-min,--min}'[flag values smaller or equal to this value as invalid.]' \
  '(-max --max)'{-max,--max}'[flag values larger or equal to this value as invalid.]' \
  '(-file --file)'{-file,--file}'[write number of observations for each pixels as additional layer in mo]:value:' \
  '(-w --weight)'{-w,--weight}'[Weights (type\: short) for the mosaic, use one weight for each input fi]:value:' \
  '(-c --class)'{-c,--class}'[classes for multi-band output image\: each band represents the number o]:value:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '*:file:_files' && ret=0

return ret
