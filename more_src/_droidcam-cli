#compdef droidcam-cli
# Documentation: https://github.com/dev47apps/droidcam-linux-client
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a[enable audio streaming]' \
  '-v[enable video streaming]' \
  '-vflip[vertical flip]' \
  '-hflip[horizontal flip]' \
  '-dev=[v4l2loopback device path]:device:_files -g "/dev/video*"' \
  '-size=[video size WxH]:size:(320x240 640x480 1280x720 1920x1080)' \
  '-nocontrols[disable interactive controls / stdin reading]' \
  '-l+[listen on port for incoming connection]:port:' \
  '*::args:->args' && ret=0

if [[ "$state" == "args" ]]; then
  if (( CURRENT == 2 )); then
    _values 'mode' 'adb' 'ios' 'ip' && ret=0
  elif (( CURRENT == 3 )); then
    if [[ "$line[1]" == "adb" || "$line[1]" == "ios" ]]; then
      _message 'port' && ret=0
    else
      _hosts && ret=0
    fi
  elif (( CURRENT == 4 )); then
    _message 'port' && ret=0
  fi
fi

return ret
