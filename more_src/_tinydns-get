#compdef tinydns-get
# _tinydns-get — djbdns tinydns-get (offline tinydns query tool; reads data.cdb in the current directory and prints the synthetic packet that tinydns(8) would return for one query)
# upstream: https://github.com/dterweij/ndjbdns
# Source: tinydns-get.c on tip; argv is TYPE NAME [IP].

_tinydns-get() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '1:type:(A AAAA NS MX TXT SRV SOA CNAME PTR ANY DS DNSKEY RRSIG NSEC NSEC3 NSEC3PARAM CAA TLSA AXFR)' \
        '2:name:_hosts' \
        '3:client-ip:'
}

_tinydns-get "$@"
