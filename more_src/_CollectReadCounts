#compdef CollectReadCounts
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/CollectReadCounts.java
# Collects read counts at specified intervals

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'[Output file for read counts.]:value:_files' \
  '--format=[Output file format.]:value:' \
  '*:argument:_files' && ret=0

return ret
