#compdef flash

# hypriot/flash releases (bash); Homebrew: Formula/f/flash.rb

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[usage]' \
  '(-v)'{-v,--version}'[version]' \
  '(-C)'{-C+,--bootconf=}'[copy to /boot/config.txt]:file:_files' \
  '(-c)'{-c+,--config=}'[copy to /boot/device-init.yaml]:file:_files' \
  '(-n)'{-n+,--hostname=}'[Pi hostname]:hostname:' \
  '(-s)'{-s+,--ssid=}'[WiFi SSID]:ssid:' \
  '(-p)'{-p+,--password=}'[WiFi password]:password:' \
  '(-l)'{-l+,--clusterlab=}'[Cluster-Lab on boot]:bool:(true false)' \
  '(-d)'{-d+,--device=}'[disk device]:device:(/dev/disk2 /dev/sdb)' \
  '(-f)'{-f,--force}'[skip confirmation]' \
  '(-u)'{-u+,--userdata=}'[cloud-init user-data]:file:_files' \
  '(-m)'{-m+,--metadata=}'[cloud-init meta-data]:file:_files' \
  '(-F)'{-F+,--file=}'[copy arbitrary file to /boot]:file:_files' \
  '*::image file:_files -g "*.img"' && ret=0
return ret
