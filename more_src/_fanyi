#compdef fanyi

# https://www.npmjs.com/package/fanyi — MEOW/Yargs (`fanyi --help`)
_arguments -s -S \
  '--help[help]' \
  '--version[version]' \
  '(-c --color)'{-c,--color}'[color output]' \
  '(-i --iciba)'{-i,--iciba}'[force iciba engine]' \
  '(-s --sentence)'{-s,--sentence}'[sentence mode]' \
  '*:English words/phrases:_default'
