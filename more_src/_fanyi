#compdef fanyi
# Documentation: https://github.com/afc163/fanyi/blob/main/bin/fanyi.mjs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:configure global options'
  'list:view query history'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t cmds 'fanyi command' commands
    _message 'English/Chinese word or phrase'
    ret=0
    ;;
  (args)
    case $line[1] in
      (config)
        _arguments \
          '1:subcommand:(list set)' \
          '*::config args:' && ret=0 ;;
      (list)
        _arguments \
          {-d+,--someDay=}'[show queries for a specific day]:day:' \
          {-r+,--recentDays=}'[show queries from recent N days]:n:' \
          '--show-file=[show data file location]:bool:(true false)' && ret=0 ;;
    esac ;;
esac

return ret
