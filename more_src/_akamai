#compdef akamai
# Documentation: https://man.archlinux.org/search?q=akamai
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show basic usage info and available commands'
  'list:list available commands'
  'install:download and install a command package'
  'uninstall:remove an installed package'
  'update:update an installed package'
  'upgrade:upgrade Akamai CLI to the latest version'
  'search:search packages published on developer.akamai.com'
  'config:view or modify CLI configuration'
  'completion:generate shell completion'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--edgerc=[path to .edgerc file]:file:_files' \
  '--section=[section in .edgerc to use]:section:' \
  '--accountkey=[Akamai account switch key]:key:' \
  '--bash[generate Bash completion]' \
  '--zsh[generate Zsh completion]' \
  '--proxy=[HTTP/HTTPS proxy URL]:url:' \
  '--daemon[start as daemon]' \
  '--debug[debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'akamai command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '--force[force reinstall]' \
          '*::package_or_url:' && ret=0 ;;
      (uninstall|update)
        _arguments '*::package:' && ret=0 ;;
      (search)
        _arguments '*::query:' && ret=0 ;;
      (config)
        local -a config_subs=(
          'get:get configuration value'
          'set:set configuration value'
          'list:list configuration'
          'unset:unset configuration value'
          'reset:reset configuration to defaults'
        )
        _describe -t cfgcmds 'config subcommand' config_subs && ret=0 ;;
      (help)
        _arguments '*::command:' && ret=0 ;;
    esac ;;
esac

return ret
