#compdef gravfft
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/potential/gravfft.html
# Source: GenericMappingTools/gmt supplements/potential — FFT-based gravity / geoid / VGG / admittance / coherence.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-C[theoretical admittance curves only]' \
    '-D+[density contrast across surface]:value:_default' \
    '-E+[Parker expansion terms (max 10)]:n:_default' \
    '-F+[field type]:type:(f b g v n)' \
    '-I+[admittance/coherence between two grids]:opts:_default' \
    '-M+[gravity value at 45° latitude for geoid]:value:_default' \
    '-N+[FFT dim / detrending control]:opts:_default' \
    '-Q[output flexural topography (Moho)]' \
    '-S[gravity from subplate load]' \
    '-T+[elastic plate params (thickness/densities/depth)]:opts:_default' \
    '-W+[water depth / observation height]:depth:_default' \
    '-Z+[Moho + swell compensation depths]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '*:input grid file(s):_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
