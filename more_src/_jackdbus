#compdef jackdbus
# Documentation: https://man.archlinux.org/search?q=jackdbus
# Reference accessed: 2026-05-16

# jackdbus: JACK server as a D-Bus service
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-S[run as system bus service]' \
  '*::jackdbus args:_files' && ret=0
return ret
