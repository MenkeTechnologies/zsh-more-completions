#compdef putout

_arguments -s -S \
  '--fix[apply fixes to source files]' \
  '--fixCount[number of fix iterations]:count:' \
  '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files -g "*.json"' \
  '--no-config[disable configuration file lookup]' \
  '--no-ci[disable CI-specific behavior]' \
  '--no-cache[disable caching]' \
  '--fresh[clear cache before running]' \
  '--rulesdir[path to directory with custom rules]:directory:_files -/' \
  '(-f --format)'{-f,--format}'[set output format]:format:(codeframe dump json stream progress-bar)' \
  '--enable[enable specified rule]:rule name:' \
  '--disable[disable specified rule]:rule name:' \
  '--enable-all[enable all available rules]' \
  '--disable-all[disable all rules]' \
  '--match[set match pattern for files]:glob pattern:' \
  '--no-match[set exclusion pattern for files]:glob pattern:' \
  '--plugins[list of plugins to use]:plugins:' \
  '--transform[transform code using specified plugin]:transform plugin:' \
  '--staged[process only git staged files]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:files:_files -g "*.{js,jsx,ts,tsx,mjs,cjs}"'
