#compdef rigctl

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --model)'{-m,--model}'[set rig model number]:model number' \
  '(-r --rig-file)'{-r,--rig-file}'[set device of the rig]:device:_files' \
  '(-p --ptt-file)'{-p,--ptt-file}'[set device of the PTT]:device:_files' \
  '(-d --dcd-file)'{-d,--dcd-file}'[set device of the DCD]:device:_files' \
  '(-P --ptt-type)'{-P,--ptt-type}'[set type of the PTT device]:PTT type:(RIG DTR RTS PARALLEL CM108 GPIO GPION NONE)' \
  '(-D --dcd-type)'{-D,--dcd-type}'[set type of the DCD device]:DCD type:(RIG DSR CTS CD PARALLEL CM108 GPIO GPION NONE)' \
  '(-s --serial-speed)'{-s,--serial-speed}'[set serial port speed]:baud rate:(300 1200 2400 4800 9600 19200 38400 57600 115200)' \
  '(-c --civaddr)'{-c,--civaddr}'[set CI-V address]:CI-V address' \
  '(-t --send-cmd-term)'{-t,--send-cmd-term}'[set send command terminator]:terminator' \
  '(-C --set-conf)'{-C,--set-conf}'[set configuration parameter]:key=value' \
  '(-l --list)'{-l,--list}'[list all rig model numbers]' \
  '(-u --dump-caps)'{-u,--dump-caps}'[dump rig capabilities]' \
  '(-L --show-conf)'{-L,--show-conf}'[show configuration parameters]' \
  '(-n --no-restore-ai)'{-n,--no-restore-ai}'[do not restore auto information state]' \
  '-o[enable VFO mode]' \
  '(-v --verbose)'{-v,--verbose}'[set verbose mode]' \
  '-Z[enable VFO mode]'
