#compdef etcdadm

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize first etcd member'
  'join:join an existing etcd cluster'
  'reset:reset etcd state'
  'info:print etcd cluster info'
  'version:print version'
)

_arguments -C \
  '(-l --log-level)'{-l,--log-level}'=[log level]:level:(debug info warn error fatal panic)' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

local -a init_args
init_args=(
  '--name=[etcd member name]:name:'
  '--version=[etcd version]:ver:'
  '--release-url=[etcd release URL]:url:'
  '--certs-dir=[certs dir]:dir:_files -/'
  '--bind-address=[bind address]:addr:'
  '*--server-cert-extra-sans=[server cert SAN]:san:'
  '--install-dir=[install dir]:dir:_files -/'
  '--snapshot=[snapshot file]:file:_files'
  '--skip-hash-check[skip release hash check]'
  '--download-connect-timeout=[download connect timeout]:duration:'
  '--disk-priorities=[disk priorities]:list:'
  '--init-system=[init system]:sys:(systemd kubelet)'
  '--image-repository=[image repository]:repo:'
  '--data-dir=[data directory]:dir:_files -/'
  '--kubelet-pod-manifest-path=[kubelet manifest path]:path:_files'
)

case $state in
  (subcommand)
    _describe -t subcommands 'etcdadm subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (init)
        _arguments $init_args && ret=0
        ;;
      (join)
        _arguments $init_args '--retry[retry on failure]' '*:endpoint:' && ret=0
        ;;
      (reset)
        _arguments \
          '--skip-remove-member[do not remove from cluster]' \
          '--install-dir=[install dir]:dir:_files -/' \
          '--certs-dir=[certs dir]:dir:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
