#compdef sukfrac
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/sukfrac.c
# apply FRACtional powers of i|k| to data, with phase shift

local ret=1

_arguments -s -S \
  'power=[power]:power:' \
  'sign=[sign]:sign:' \
  'd1=[d1]:d1:' \
  'd2=[d2]:d2:' \
  'phasefac=[phasefac]:phasefac:' \
  'phase=[phase]:phase:' \
  'angle=[angle]:angle:' \
  '*:file:_files' && ret=0

return ret
