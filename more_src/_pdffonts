#compdef pdffonts
# Documentation: https://man.archlinux.org/man/pdffonts.1.en
# Reference accessed: 2026-05-30
# pdffonts — list fonts used in a PDF file (poppler tools).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[show usage help]' \
  '(- *)-v[show copyright and version]' \
  '-f+[first page to analyze]:page:' \
  '-l+[last page to analyze]:page:' \
  '-subst[list substitute fonts poppler will use for non-embedded fonts]' \
  '-opw+[owner password (bypasses security restrictions)]:password:' \
  '-upw+[user password]:password:' \
  '*:PDF file (or "-" for stdin):_files -g "*.(pdf|PDF)"' \
  && ret=0

return ret
