#compdef bytebase

# Zsh completion for bytebase - Database DevOps platform

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--port=[server port]:port:' \
  '--data=[data directory]:directory:_directories' \
  '--host=[server host]:host:' \
  '--external-url=[external URL for Bytebase]:url:' \
  '--pg=[PostgreSQL connection string]:connection string:' \
  '--readonly[run in read-only mode]' \
  '--demo[run with demo data]' \
  '--debug[enable debug mode]' \
  '--disable-sample[disable sample data]' && ret=0

return ret
