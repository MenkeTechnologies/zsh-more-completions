#compdef ntpstat
# Documentation: https://github.com/mlichvar/ntpstat/blob/master/ntpstat.1
# Reference accessed: 2026-05-19
# Verified: upstream ntpstat.1 manpage.

# ntpstat: show NTP synchronisation status
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-m[max acceptable clock error (ms)]:ms:' && ret=0
return ret
