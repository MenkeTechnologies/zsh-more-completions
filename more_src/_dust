#compdef dust
# Documentation: https://github.com/bootandy/dust
# Source: bootandy/dust — more intuitive du(1) successor (Rust).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[show full path of subdirectories]' \
    '-s[show file length (not disk allocation)]' \
    '-n[number of directories to show]:n:' \
    '-d[depth of subdirectories to show]:n:' \
    '(-D -F)-D[show only directories]' \
    '(-D -F)-F[show only files (largest)]' \
    '-r[reverse output order]' \
    '-o[print sizes in custom format/powers]:format:(b k m g t si)' \
    '*-X[ignore files/directories with name]:name:' \
    '-x[only show same filesystem]' \
    '(-b -B)-b[no percentages or ASCII bars]' \
    '(-b -B)-B[percent bars on the right]' \
    '-i[do not show hidden files]' \
    '(-c -C)-c[monochrome (no colors)]' \
    '(-c -C)-C[force colors]' \
    '-f[count files instead of disk space]' \
    '-t[group by filetype]' \
    '-z[only include files larger than size]:size:' \
    '-e[include only files matching regex]:regex:' \
    '-v[exclude files matching regex]:regex:' \
    '-L[treat symlinks as directories]' \
    '-P[disable progress indicator]' \
    '-R[screen-reader mode (no bars/symbols, adds depth col)]' \
    '-S[custom stack size]:size:' \
    '--skip-total[do not display total row]' \
    '-j[print JSON representation]' \
    '--files0-from=[read NUL-terminated paths from FILE]:file:_files' \
    '--files-from=[read newline-terminated paths from FILE]:file:_files' \
    '*--collapse=[keep folder collapsed in display]:folder:_directories' \
    '*:path:_files' \
    && ret=0

return ret
