#compdef gh-milestone
# Documentation: https://github.com/valeriobelli/gh-milestone
# gh-milestone - GitHub CLI extension for managing milestones

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(create list ls edit view delete)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      create)
        _arguments -s -S \
          '--title=[milestone title]:title:' \
          '--description=[milestone description]:description:' \
          '--due-date=[due date YYYY-MM-DD]:date:' \
          '(-R --repo)'{-R,--repo}'=[target repository]:repo:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      list|ls)
        _arguments -s -S \
          '--state=[filter by state]:state:(open closed all)' \
          '(-R --repo)'{-R,--repo}'=[target repository]:repo:' \
          '--query=[search by a pattern]:query:' \
          '--first=[limit results to N milestones]:n:' \
          '--all[retrieve every milestone regardless of count]' \
          '--orderBy.field=[sort field]:field:(created_at due_date issues number title updated_at)' \
          '--orderBy.direction=[sort direction]:direction:(asc desc)' \
          '--json=[output JSON with the given fields]:fields:' \
          '--jq=[filter JSON output using a jq expression]:expression:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      edit)
        _arguments -s -S \
          '--title=[milestone title]:title:' \
          '--description=[milestone description]:description:' \
          '--due-date=[due date YYYY-MM-DD]:date:' \
          '--state=[milestone state]:state:(open closed)' \
          '(-R --repo)'{-R,--repo}'=[target repository]:repo:' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:milestone number:' && ret=0
        ;;
      view)
        _arguments -s -S \
          '(-R --repo)'{-R,--repo}'=[target repository]:repo:' \
          '--json=[output JSON with the given fields]:fields:' \
          '--jq=[filter JSON output using a jq expression]:expression:' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:milestone number:' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(-R --repo)'{-R,--repo}'=[target repository]:repo:' \
          '--confirm[skip interactive confirmation prompts]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:milestone number:' && ret=0
        ;;
    esac
    ;;
esac

return ret
