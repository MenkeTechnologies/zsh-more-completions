#compdef mdpocket
# Documentation: https://github.com/Discngine/fpocket/blob/master/doc/MANUAL.md
# mdpocket - pocket detection over molecular dynamics trajectories.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--trajectory_file=[input trajectory file]:file:_files' \
  '--trajectory_format=[trajectory format]:fmt:(dcd xtc netcdf crd crdbox dtr trr)' \
  '(-f --file)'{-f+,--file=}'[topology PDB file]:file:_files' \
  '-L+[file listing snapshot PDB paths]:file:_files' \
  '--selected_pocket=[PDB file defining pocket region]:file:_files' \
  '(-o)-o+[output file prefix]:prefix:' \
  '-S[score using druggability]' \
  '*:file:_files' && ret=0

return ret
