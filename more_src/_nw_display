#compdef nw_display
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: graphical (ASCII/SVG) tree display.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-s[output SVG instead of ASCII text]' \
  '-S[suppress scale bar]' \
  '-r[draw radial tree (SVG only)]' \
  '-t[set scale zero at maximum depth instead of root]' \
  '-e+[text graph style: raw/commas/slashes/vt100/utf8]:style:(raw commas slashes vt100 utf8)' \
  '-w+[output width]:width:' \
  '-v+[vertical leaf spacing in px (SVG)]:px:' \
  '-b+[CSS for branch length labels (SVG)]:css:' \
  '-c+[CSS map file for clade styling (SVG)]:file:_files' \
  '-d+[CSS for plain tree nodes (SVG)]:css:' \
  '-i+[CSS for inner node labels (SVG)]:css:' \
  '-l+[CSS for leaf node labels (SVG)]:css:' \
  '-I+[inner label position: l/m/r]:pos:(l m r)' \
  '-n+[nudge node labels horizontally (px, SVG)]:px:' \
  '-o+[ornament map file (SVG)]:file:_files' \
  '-R+[root edge pixel length (0 suppresses)]:px:' \
  '-U+[URL map file for clickable labels (SVG)]:file:_files' \
  '-W+[leaf label char width estimate (px, SVG)]:px:' \
  '-a+[rotate all labels by radians (SVG radial)]:rad:' \
  '-A+[rotate left-side labels by radians (SVG radial)]:rad:' \
  '-u+[unit name for scale bar]:unit:' \
  '*:newick file:_files' && ret=0

return ret
