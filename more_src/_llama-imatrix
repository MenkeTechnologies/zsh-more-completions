#compdef llama-imatrix

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-m+[model path]:model file:_files -g "*.gguf"' \
  '--model=[model path]:model file:_files -g "*.gguf"' \
  '-f+[input file for computing importance matrix]:input file:_files' \
  '--file=[input file for computing importance matrix]:input file:_files' \
  '-o+[output file]:output file:_files -g "*.dat"' \
  '--output=[output file]:output file:_files -g "*.dat"' \
  '-ofreq=[output frequency in chunks]:frequency' \
  '--output-frequency=[output frequency in chunks]:frequency' \
  '-ow[overwrite output file]' \
  '--output-overwrite[overwrite output file]' \
  '-c+[context size]:size' \
  '--ctx-size=[context size]:size' \
  '-b+[batch size]:size' \
  '--batch-size=[batch size]:size' \
  '-t+[number of threads]:threads' \
  '--threads=[number of threads]:threads' \
  '-ngl+[number of GPU layers]:layers' \
  '--gpu-layers=[number of GPU layers]:layers' \
  '--chunks=[number of chunks to process]:chunks' \
  '--no-mmap[do not memory-map model]' \
  '--mlock[force system to keep model in RAM]' \
  '--seed=[RNG seed]:seed' \
  '--verbosity=[verbosity level]:level' && ret=0

return ret
