#compdef kubemcsa
# Documentation: https://github.com/admiraltyio/multicluster-service-account/blob/master/README.md
# Admiralty multicluster-service-account CLI - import remote Kubernetes service accounts

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'bootstrap:bootstrap mutual service-account import between two clusters'
      'export:export a service account as a kubeconfig secret manifest'
      'help:help about any command'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (bootstrap)
        _arguments -s -S \
          '--target-context=[target cluster context]:context' \
          '--source-context=[source cluster context]:context' \
          '--target-kubeconfig=[target kubeconfig file]:file:_files' \
          '--source-kubeconfig=[source kubeconfig file]:file:_files' \
          '--target-name=[rename the target cluster]:name' \
          '--source-name=[rename the source cluster]:name' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (export)
        _arguments -s -S \
          '--kubeconfig=[kubeconfig file for the source cluster]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:service account:' && ret=0
        ;;
    esac
    ;;
esac

return ret
