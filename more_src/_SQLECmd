#compdef SQLECmd
# Documentation: https://github.com/EricZimmerman/SQLECmd
# SQLECmd - SQLite database forensic parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[file to process]:file:_files' \
  '-d[directory to recursively process]:directory:_directories' \
  '--csv=[directory to save CSV results to]:directory:_directories' \
  '--json=[directory to save JSON results to]:directory:_directories' \
  '--blobdir=[directory to save blob data to]:directory:_directories' \
  '--maps=[path where SQL maps are located]:directory:_directories' \
  '--dedupe=[deduplicate files based on SHA-1]:bool:(true false)' \
  '--hunt=[look at all files by header not name]:bool:(true false)' \
  '--noblob=[disable blob extraction]:bool:(true false)' \
  '--sync=[download latest maps from GitHub]:bool:(true false)' \
  '--debug=[show debug information]:bool:(true false)' \
  '--trace=[show trace information]:bool:(true false)' && ret=0

return ret
