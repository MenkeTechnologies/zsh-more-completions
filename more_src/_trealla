#compdef trealla
# Documentation: https://github.com/trealla-prolog/trealla/blob/main/README.md
# trealla - compact, efficient Prolog interpreter written in C (binary: tpl)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '*-f+[load file (.tplrc not loaded)]:file:_files' \
  '*-l+[load file (.tplrc loaded)]:file:_files' \
  '(-g --goal)'{-g+,--goal=}'[query goal (only used once)]:goal' \
  '--library=-[set library path (alt to TPL_LIBRARY_PATH)]:path:_files -/' \
  '(-t --trace)'{-t,--trace}'[trace]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode (no banner)]' \
  '(-d --daemonize)'{-d,--daemonize}'[daemonize]' \
  '(-w --watchdog)'{-w,--watchdog}'[create watchdog]' \
  '(-O0 --noopt)'{-O0,--noopt}'[no optimization]' \
  '--autofail[autofail queries at the toplevel]' \
  '--consult[consult from STDIN]' \
  '--nolimit[no memory limit]' \
  '*:file:_files' && ret=0

return ret
