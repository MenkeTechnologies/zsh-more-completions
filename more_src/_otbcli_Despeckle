#compdef otbcli_Despeckle
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_Despeckle.html
# Orfeo ToolBox: reduce speckle noise in a SAR image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input SAR image]:image:_files' \
  '-out[output image]:output:_files' \
  '-filter[speckle filtering method]:filter:(lee frost gammamap kuan)' \
  '-filter.lee.rad[Lee window radius in pixels]:value:' \
  '-filter.lee.nblooks[Lee number of looks]:value:' \
  '-filter.frost.rad[Frost window radius in pixels]:value:' \
  '-filter.frost.deramp[Frost exponential weighting factor]:value:' \
  '-filter.gammamap.rad[GammaMap window radius in pixels]:value:' \
  '-filter.gammamap.nblooks[GammaMap number of looks]:value:' \
  '-filter.kuan.rad[Kuan window radius in pixels]:value:' \
  '-filter.kuan.nblooks[Kuan number of looks]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
