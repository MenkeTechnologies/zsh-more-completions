#compdef hunspell
# Documentation: hunspell -h
# Source: hunspell — successor to MySpell; LibreOffice / Firefox / Thunderbird default spell checker.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-1[check only first tab-delimited field]' \
    '-a[Ispell pipe interface]' \
    '--check-url[check URLs, e-mail addresses and directory paths]' \
    '--check-apostrophe[check Unicode typographic apostrophe]' \
    '-d+[dictionaries d[,d2,...] to use]:dicts:' \
    '(- *)-D[show available dictionaries]' \
    '-G[print only correct words / lines]' \
    '(- *)'{-h,--help}'[show help and exit]' \
    '(-H -n -O -t -X)-H[HTML input file format]' \
    '-i+[input encoding]:enc:' \
    '(-l -L -G)-l[print misspelled words]' \
    '(-l -L -G)-L[print lines with misspelled words]' \
    '-m[analyze the words]' \
    '(-H -n -O -t -X)-n[nroff/troff input file format]' \
    '(-H -n -O -t -X)-O[OpenDocument (ODF / Flat ODF) input format]' \
    '-p+[custom personal dictionary]:dict:_files' \
    '-r[warn of potential mistakes (rare words)]' \
    '-P+[password for encrypted dictionaries]:password:' \
    '-s[stem the words of the input text]' \
    '-S[suffix words of the input text]' \
    '(-H -n -O -t -X)-t[TeX/LaTeX input file format]' \
    '(- *)'{-v,--version}'[print version]' \
    '(- *)-vv[print Ispell-compatible version]' \
    '-w[print misspelled words (one-per-line input)]' \
    '(-H -n -O -t -X)-X[XML input file format]' \
    '*:file:_files' \
    && ret=0

return ret
