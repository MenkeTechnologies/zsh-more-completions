#compdef frida-portal
# Documentation: https://github.com/frida/frida-core/blob/main/portal/portal.vala
# Frida portal - relay connecting nodes and controllers

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[output version information and exit]' \
  '--cluster-endpoint=[expose cluster endpoint on ADDRESS]:address' \
  '--cluster-certificate=[enable TLS on cluster endpoint using CERTIFICATE]:certificate:_files' \
  '--cluster-token=[require authentication on cluster endpoint using TOKEN]:token' \
  '--control-endpoint=[expose control endpoint on ADDRESS]:address' \
  '--control-certificate=[enable TLS on control endpoint using CERTIFICATE]:certificate:_files' \
  '--control-origin=[only accept control requests with matching Origin header]:origin' \
  '--control-token=[require authentication on control endpoint using TOKEN]:token' \
  '--control-asset-root=[serve static files inside ROOT on control endpoint]:root:_files -/' \
  '(-D --daemonize)'{-D,--daemonize}'[detach and become a daemon]' && ret=0

return ret
