#compdef cadence-cassandra-tool
# _cadence-cassandra-tool — Cadence Cassandra schema management tool (cadence-workflow/cadence)
# upstream: https://github.com/cadence-workflow/cadence
# Subcommands from tools/cassandra/main.go (urfave/cli/v2).

_cadence-cassandra-tool() {
    local context state state_descr line
    typeset -A opt_args
    local -a common=(
        '(-ep --endpoint)'{-ep+,--endpoint=}'[cassandra host]:host:_hosts'
        '(-p --port)'{-p+,--port=}'[cassandra port]:port:'
        '(-u --user)'{-u+,--user=}'[cassandra user]:user:'
        '(-pw --password)'{-pw+,--password=}'[cassandra password]:pw:'
        '(-k --keyspace)'{-k+,--keyspace=}'[cassandra keyspace]:name:'
        '(-q --quiet)'{-q,--quiet}'[do not return error if quiet]'
        '--datacenter=[NetworkTopologyStrategy datacenter]:dc:'
        '--tls[enable TLS]'
        '--tls-cert-file=[TLS cert file]:file:_files'
        '--tls-key-file=[TLS key file]:file:_files'
        '--tls-ca-file=[TLS CA file]:file:_files'
    )

    _arguments -C \
        $common \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                setup-schema:'setup initial schema'
                setup:'setup initial schema'
                update-schema:'update schema to a specific version'
                update:'update schema to a specific version'
                create-Keyspace:'create a keyspace'
                create:'create a keyspace'
                drop-Keyspace:'drop a keyspace'
                drop:'drop a keyspace'
                validate-health:'validate cassandra health'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                setup-schema|setup)
                    _arguments $common \
                        '(-v --version)'{-v+,--version=}'[initial schema version]:ver:' \
                        '(-f --schema-file)'{-f+,--schema-file=}'[CQL schema file]:file:_files' \
                        '--disable-versioning[disable schema versioning]' \
                        '--overwrite[drop and recreate the schema]' ;;
                update-schema|update)
                    _arguments $common \
                        '(-d --schema-dir)'{-d+,--schema-dir=}'[directory of schema upgrades]:dir:_files -/' \
                        '(-v --version)'{-v+,--version=}'[target schema version]:ver:' \
                        '--dryrun[do not run, only print plan]' ;;
                create-Keyspace|create)
                    _arguments $common \
                        '(-k --keyspace)'{-k+,--keyspace=}'[keyspace name]:name:' \
                        '--replication-factor=[replication factor]:n:' ;;
                drop-Keyspace|drop)
                    _arguments $common \
                        '(-k --keyspace)'{-k+,--keyspace=}'[keyspace name]:name:' \
                        '(-f --force)'{-f,--force}'[do not prompt]' ;;
            esac
            ;;
    esac
}

_cadence-cassandra-tool "$@"
