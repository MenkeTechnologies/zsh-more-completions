#compdef claude-dev cline
# _claude-dev — Saoud Rizwan claude-dev now Cline VS Code extension CLI for autonomous AI coding agent with terminal/browser/file tool use using Claude API (cline team, TypeScript); commander.js
# upstream: https://github.com/cline/cline

_claude-dev() {
    local -a sub=(
        'login:set API key'
        'logout:clear API key'
        'status:show status'
        'task:run autonomous task'
        'config:show config'
        'set-model:set model'
        'set-provider:set provider'
        'set-temperature:set temperature'
        'set-max-tokens:set max tokens'
        'history:show task history'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--provider=+[p]:p:(anthropic openai openrouter bedrock vertex azure ollama lmstudio gemini deepseek mistral qwen)' \
        '--model=+[m]:m:(claude-opus-4-7 claude-sonnet-4-6 claude-haiku-4-5 claude-3-7-sonnet claude-3-5-sonnet claude-3-opus gpt-5 gpt-4o gpt-4-turbo o1 o3 gemini-2.5-pro gemini-2.5-flash deepseek-chat deepseek-coder)' \
        '--temperature=+[F]:f:' \
        '--max-tokens=+[N]:n:' \
        '--max-iterations=+[N]:n:' \
        '--workspace=+[dir]:dir:_files -/' \
        '--auto-approve[auto approve actions]' \
        '--no-stream[no stream]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'claude-dev subcommand' sub ;;
        args)
            case $words[1] in
                task) _arguments \
                    '--prompt=+[prompt]:str:' \
                    '--file=+[file]:file:_files' \
                    '--mcp-server=+[server]:str:' \
                    '*:task description:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_claude-dev "$@"
