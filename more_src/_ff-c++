#compdef ff-c++
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/ff-c++.1.html
# compile FreeFem++ dynamic loadable plugins from C++ source

local ret=1

_arguments -s -S \
  '-auto[automatically build dependencies]' \
  '-n[dry-run: display commands without executing]' \
  '-g[compile with debug symbols enabled]' \
  '-c[compile source file only without linking]' \
  '-mpi[enable MPI support]' \
  '-cygwin[target Cygwin/Win32 environment]' \
  '-win32[target Win32 OS (default under Cygwin)]' \
  '*-l+[include additional files in linking]:lib' \
  '*-I+[add directory to C++ include search path]:dir:_directories' \
  '-b[specify alternate installation directory]:dir:_directories' \
  '-dll[add DLL and copy file to installation directory]:file:_files' \
  '-o[set output filename (without extension)]:file:_files' \
  '*:source file:_files -g "*.(cpp|cp|cxx|c|f|F)"' && ret=0

return ret
