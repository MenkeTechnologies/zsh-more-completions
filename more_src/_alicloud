#compdef aliyun
# _alicloud — Alibaba Cloud Aliyun CLI (Alibaba Cloud, Go); call Alibaba Cloud OpenAPI from command line
# upstream: https://github.com/aliyun/aliyun-cli

_alicloud() {
    local -a sub=(
        'auto-completion:enable auto-completion'
        'configure:configure profile'
        'help:show help'
        'oss:Object Storage Service'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--mode+[auth mode]:mode:(AK StsToken RamRoleArn EcsRamRole External CredentialsURI ChainableRamRoleArn ExternalCredentials)' \
        '--profile+[profile]:profile:' \
        '-p+[profile]:profile:' \
        '--region+[region]:region:' \
        '--access-key-id+[access key id]:str:' \
        '--access-key-secret+[access key secret]:str:' \
        '--sts-token+[STS token]:str:' \
        '--ram-role-name+[RAM role name]:str:' \
        '--ram-role-arn+[RAM role ARN]:arn:' \
        '--role-session-name+[role session name]:str:' \
        '--language+[language]:lang:(en zh)' \
        '--config-path+[config path]:file:_files' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--retry-count+[retry count]:n:' \
        '--retry-timeout+[retry timeout]:duration:' \
        '--read-timeout+[read timeout]:duration:' \
        '--connect-timeout+[connect timeout]:duration:' \
        '--vpc-endpoint+[VPC endpoint]:url:_urls' \
        '--endpoint+[endpoint]:url:_urls' \
        '--insecure[skip TLS verify]' \
        '--skip-secure-verify[skip TLS verify]' \
        '--force[force]' \
        '--output+[output format]:fmt:(json table cols=col1,col2)' \
        '--version+[API version]:v:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aliyun subcommand' sub ;;
        args)
            case $words[1] in
                configure) _arguments \
                    '1:configure cmd:(get list set add delete switch)' \
                    '*:args:' ;;
                oss) _arguments \
                    '1:oss cmd:(config ls mb rm cp mkdir cat get put append-file restore probe stat hash sign create-symlink read-symlink lock-version listVersion enableEncryption disableEncryption getEncryption setEncryption listEnchanced)' \
                    '*:args:' ;;
            esac
            ;;
    esac
}

_alicloud "$@"
