#compdef nix-shell

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--packages[install packages into shell environment]' \
  '-p[install packages into shell environment]' \
  '(-A --attr)'{-A,--attr}'[select attribute from top-level expression]:attribute' \
  '--command[command to run in shell]:command' \
  '--run[command to run in shell then exit]:command' \
  '--exclude[packages to exclude]:package' \
  '--pure[clear environment before entering shell]' \
  '--impure[allow impure environment]' \
  '-i[path to interpreter for shebang]:interpreter:_files' \
  '-I[add path to Nix expression search path]:path:_files' \
  '--option[set a Nix option]:name: :value' \
  '--arg[pass argument to Nix expression]:name: :value' \
  '--argstr[pass string argument to Nix expression]:name: :value' \
  '--max-jobs[maximum number of parallel build jobs]:jobs' \
  '--cores[number of CPU cores per build]:cores' \
  '--keep-going[keep going on build failure]' \
  '--keep-failed[keep build directory on failure]' \
  '--fallback[fall back to building from source]' \
  '--no-build-output[suppress build log output]' \
  '--show-trace[show Nix expression evaluation trace]' \
  '-v[increase verbosity level]' \
  '*:Nix expression or package:_files' && ret=0

return ret