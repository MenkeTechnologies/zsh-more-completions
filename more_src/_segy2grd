#compdef segy2grd
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/segy — convert SEGY data to a GMT grid

local ret=1

_arguments -s \
  '-G+[output grid filename]:file:_files' \
  '-I+[grid spacing dx/dy]:spacing:_default' \
  '-R+[region west/east/south/north]:region:_default' \
  '-A+[aggregation method sum|count per node]:mode:(n z)' \
  '-D+[netCDF metadata names/units/scaling]:meta:_default' \
  '-L+[override sample count per trace]:n:_default' \
  '-M+[number of traces to read]:n:_default' \
  '-Q+[coordinate scaling or sample interval]:opts:_default' \
  '-S+[variable spacing from header]:mode:_default' \
  '*-V[verbose (stackable)]' \
  '-di+[replace nodata with NaN]:nodata:_default' \
  '-r[pixel registration]' \
  '*:input segy file:_files' \
  && ret=0

return ret
