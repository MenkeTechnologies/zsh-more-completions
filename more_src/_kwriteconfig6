#compdef kwriteconfig6
# Documentation: https://invent.kde.org/frameworks/kconfig/-/blob/master/src/kconf_update/kwriteconfig.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kwriteconfig6: write a key-value pair to a KConfig file (Plasma 6).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--file=[config file]:file:_files' \
  '*--group=[KConfig group (repeatable)]:group:' \
  '--key=[KConfig key]:key:' \
  '--type=[value type]:type:(bool path string color int)' \
  '--delete[delete the entry]' \
  '--notify[notify KDE of config change]' \
  '*:value:' && ret=0
return ret
