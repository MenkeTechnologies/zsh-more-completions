#compdef kwriteconfig6
# Documentation: https://man.archlinux.org/search?q=kwriteconfig6
# Reference accessed: 2026-05-16

# kwriteconfig6: write a key-value pair to a KConfig file (Plasma 6)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--file=[config file]:file:_files' \
  '--group=[KConfig group (repeatable)]:group:' \
  '--key=[KConfig key]:key:' \
  '--type=[value type]:type:(bool path string color int)' \
  '--delete[delete the entry]' \
  '--notify[notify KDE config changed]' \
  '*:value:' && ret=0
return ret
