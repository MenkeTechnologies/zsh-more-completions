#compdef drillbit drillbit.sh
# Documentation: https://man.archlinux.org/search?q=drillbit
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--config=[config directory]:dir:_files -/' \
  '1:command:(start stop graceful_stop status restart autorestart)' && ret=0

return ret
