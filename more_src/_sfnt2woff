#compdef sfnt2woff woff2sfnt
# Documentation: upstream sfnt2woff(1) / woff2sfnt(1) man pages
# (these are the original Mozilla WOFF1 utilities; the bramstein
# zopfli-recompression variants sfnt2woff-zopfli / woff2sfnt-zopfli
# are covered in `more_src/_sfnt2woff-zopfli`).
# Reference accessed: 2026-05-30 via WebFetch of the related
# manpages.debian.org/bookworm/sfnt2woff-zopfli/ man pages (the
# original sfnt2woff / woff2sfnt utilities share the same flag
# surface but use stock zlib for compression instead of zopfli, so
# the `-n iterations` flag is absent from the original; otherwise
# identical).
# Mozilla WOFF1 R116 — 2-stem multi-binary harvest of the original
# (non-zopfli) WOFF1 bidirectional converters. Sister to
# _sfnt2woff-zopfli (2-stem zopfli variants), _ttf2woff2 (covering
# Google's ttf2woff2 + woff2_compress WOFF2 compressors), and
# _woff2_decompress (Google's WOFF2 decoder).

case $service in

  sfnt2woff)
    # Convert an SFNT-flavored font (OTF/TTF) into WOFF1 format
    # using the original Mozilla zlib-based compressor.
    _arguments -s -S \
      '-v+[font version (major.minor)]:version:' \
      '-m+[metadata XML file (not validated)]:file:_files -g "*.xml"' \
      '-p+[private data block file]:file:_files' \
      '*:input SFNT font file:_files -g "*.(otf|ttf)"'
    ;;

  woff2sfnt)
    # Decompress a WOFF1 file back to SFNT (OTF/TTF) format, or
    # extract individual blocks. The 3 extract modes are mutually
    # exclusive: only one of -v/-m/-p may be used at a time.
    _arguments -s -S \
      '(-v -m -p)-v[write font version to stdout]' \
      '(-v -m -p)-m[write WOFF metadata block to stdout]' \
      '(-v -m -p)-p[write private data block to stdout]' \
      '*:input WOFF file:_files -g "*.woff"'
    ;;

esac
