#compdef ttf2woff2 woff2_compress
# Documentation: https://man.archlinux.org/search?q=ttf2woff2
# Reference accessed: 2026-05-16

# ttf2woff2: convert TrueType/OpenType to WOFF2 (Google compression)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:input TTF/OTF font file:_files -g "*.(ttf|otf)"' && ret=0
return ret
