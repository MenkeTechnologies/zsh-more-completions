#compdef pktvisord
# pktvisor network observability daemon analyzing traffic into metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-d[daemonize; fork and run in the background]' \
  '-v[enable verbose log output]' \
  '--no-track[do not send anonymous usage metrics]' \
  '--version[show version information]' \
  '-l+[run web server on the given host or IP]:host:_hosts' \
  '-p+[run web server on the given port]:port' \
  '--tls[enable TLS on the web server]' \
  '--tls-cert=[TLS cert file]:file:_files' \
  '--tls-key=[TLS private key file]:file:_files' \
  '--admin-api[enable administrative REST API]' \
  '--geo-city=[GeoLite2 City database for IP to Geo mapping]:file:_files' \
  '--geo-asn=[GeoLite2 ASN database for IP to ASN mapping]:file:_files' \
  '--geo-cache-size=[GeoLite2 LRU cache size, 0 to disable]:size' \
  '--default-geo-city=[default GeoLite2 City database]:file:_files' \
  '--default-geo-asn=[default GeoLite2 ASN database]:file:_files' \
  '--config=[YAML config for options, Taps and Collection Policies]:file:_files -g "*.(yaml|yml)"' \
  '--cp-disable[disable crashpad collector]' \
  '--cp-token=[crashpad token]:token' \
  '--cp-url=[crashpad server URL]:url' \
  '--cp-custom=[crashpad user-defined field]:userdef' \
  '--cp-path=[crashpad handler binary path]:path:_files' \
  '--module-list[list all loaded modules]' \
  '--module-dir=[module load path for dynamic discovery]:dir:_files -/' \
  '--log-file=[log to the given output file]:file:_files' \
  '--syslog[redirect logging output to syslog]' \
  '--prometheus[legacy flag (Prometheus always enabled)]' \
  '--prom-instance=[set the instance label to given ID]:id' \
  '--iana-service-port-registry=[IANA service port registry CSV]:file:_files' \
  '--default-service-registry=[default IANA service port registry CSV]:file:_files' \
  '--max-deep-sample=[never deep sample more than N% of streams]:percent' \
  '--periods=[hold this many 60-second periods of history]:periods' \
  '-b+[filter packets using a tcpdump-compatible BPF expression]:bpf' \
  '-H+[subnets to consider HOST, comma separated CIDR]:hostspec' && ret=0

return ret
