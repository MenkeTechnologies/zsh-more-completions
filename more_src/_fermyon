#compdef fermyon

# Zsh completion for Fermyon CLI
# https://fermyon.com

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:Authenticate with Fermyon Cloud'
  'logout:Remove local credentials'
  'deploy:Deploy a Spin application'
  'cloud:Manage Fermyon Cloud resources'
)

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'fermyon command' commands && ret=0
    ;;
esac

return ret
