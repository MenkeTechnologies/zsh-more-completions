#compdef idevicedevmodectl
# _idevicedevmodectl — manage Developer Mode on iOS 16+ devices (libimobiledevice/libimobiledevice)
# upstream: https://github.com/libimobiledevice/libimobiledevice
# Subcommands + flags from tools/idevicedevmodectl.c.

_idevicedevmodectl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-u --udid)'{-u+,--udid=}'[target the specific device by UDID]:udid:' \
        '(-n --network)'{-n,--network}'[connect to a network-attached device]' \
        '(-d --debug)'{-d,--debug}'[enable communication debugging]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_idevicedevmodectl_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                list|enable|arm|confirm|reveal) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_idevicedevmodectl_commands] )) ||
_idevicedevmodectl_commands() {
    local -a commands
    commands=(
        'list:print Developer Mode status of all connected devices (or one with --udid)'
        'enable:enable Developer Mode (reboots the device, then confirms after boot)'
        'arm:arm Developer Mode (device reboots; must be confirmed after)'
        'confirm:confirm enabling of Developer Mode after arming'
        'reveal:reveal the Developer Mode menu on the device'
    )
    _describe -t commands 'idevicedevmodectl command' commands
}

_idevicedevmodectl "$@"
