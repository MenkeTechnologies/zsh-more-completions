#compdef hiera
# Documentation: https://github.com/puppetlabs/hiera/blob/main/bin/hiera
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Note: standalone `hiera` CLI is deprecated; `puppet lookup` replaces it.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-V,--version}'[show version]' \
  {-d,--debug}'[show debugging output]' \
  {-a,--array}'[return values as array]' \
  {-h,--hash}'[return values as hash]' \
  {-c+,--config=}'[hiera config file]:file:_files -g "*.(yaml|yml)"' \
  {-j+,--json=}'[JSON scope file]:file:_files -g "*.json"' \
  {-y+,--yaml=}'[YAML scope file]:file:_files -g "*.(yaml|yml)"' \
  {-m+,--mcollective=}'[mcollective node identity]:identity:' \
  {-i+,--inventory_service=}'[inventory service node identity]:identity:' \
  {-f+,--format=}'[output format]:format:(ruby yaml json)' \
  '1:lookup key:' \
  '*:scope var or default:' && ret=0

return ret
