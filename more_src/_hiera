#compdef hiera

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-d,--debug}'[debug output]' \
  {-c+,--config=}'[hiera config file]:file:_files -g "*.(yaml|yml)"' \
  {-a,--array}'[return array of merged values]' \
  {-h-,--hash}'[return hash of merged values]' \
  '--explain[show full lookup hierarchy]' \
  {-j+,--json=}'[JSON scope file]:file:_files -g "*.json"' \
  {-y+,--yaml=}'[YAML scope file]:file:_files -g "*.(yaml|yml)"' \
  {-i+,--inventory=}'[inventory.yaml file]:file:_files -g "*.(yaml|yml)"' \
  {-m+,--mcollective=}'[mcollective node identity]:identity:' \
  '*--render-as=[render output as]:format:(s yaml json binary)' \
  '*-o+[scope variable]:var=value:' \
  '1:lookup key:' \
  '*:default value:' && ret=0

return ret
