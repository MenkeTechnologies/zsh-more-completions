#compdef CalculateContamination
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/contamination/CalculateContamination.java
# Calculate the fraction of reads coming from cross-sample contamination

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--input -I)'{--input,-I}'[The input table]:value:_files' \
  '(--matched-normal -matched)'{--matched-normal,-matched}'[The matched normal input table]:value:' \
  '(--output -O)'{--output,-O}'[The output table]:value:_files' \
  '(--tumor-segmentation -segments)'{--tumor-segmentation,-segments}'[The output table containing segmentation of the tumor by minor allele fraction]:value:' \
  '--low-coverage-ratio-threshold=[The minimum coverage relative to the median.]:value:' \
  '--high-coverage-ratio-threshold=[The maximum coverage relative to the mean.]:value:' \
  '*:argument:_files' && ret=0

return ret
