#compdef dagit
# Documentation: https://man.archlinux.org/search?q=dagit
# Reference accessed: 2026-05-16

# dagit: legacy Dagster web UI command
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-w[workspace file]:file:_files' \
  '-p[python file]:file:_files -g "*.py"' \
  '-m[module name]:module:' \
  '-d[working directory]:dir:_files -/' \
  '-a[attribute]:attribute:' \
  '-P[port]:port:' \
  '-h[bind host]:host:' \
  '--read-only[read-only mode]' \
  '*::dagit args:_files' && ret=0
return ret
