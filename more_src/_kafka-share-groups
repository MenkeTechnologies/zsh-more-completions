#compdef kafka-share-groups
# Documentation: https://kafka.apache.org/documentation/ (kafka-share-groups.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--all-groups[Apply to all share groups]'
    '--all-topics[Consider all topics assigned to a share group in reset-offsets]'
    '--bootstrap-server[REQUIRED: The server(s) to connect to]:host\:port:'
    '--command-config[Property file containing configs to be passed to Admin Client]:file:_files'
    '--delete[Delete share group]'
    '--delete-offsets[Delete offsets of share group]'
    '--describe[Describe share group, members and offset information]'
    '--dry-run[Only show results without executing changes (reset-offsets)]'
    '--execute[Execute operation (reset-offsets)]'
    '--group[The share group we wish to act on]:group:'
    '--help[Print usage information]'
    '--list[List all share groups]'
    '--members[Describe members of the group (with --describe only)]'
    '--offsets[Describe the group and list all topic partitions with offsets]'
    '--reset-offsets[Reset offsets of share group]'
    "--state[Includes/filters by the state of the group]::state:(Empty Stable Dead)"
    '--timeout[Timeout in ms used e.g. when describing the group]:ms:'
    '--to-datetime[Reset offsets to offset from datetime (YYYY-MM-DDThh:mm:ss.sss)]:datetime:'
    '--to-earliest[Reset offsets to earliest offset]'
    '--to-latest[Reset offsets to latest offset]'
    '--topic[The topic whose offset information to delete or include]:topic:'
    '--verbose[Provide additional information when describing the group]'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
