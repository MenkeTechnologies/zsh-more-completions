#compdef dconf
# Documentation: https://manpages.debian.org/dconf
# Source: GNOME/dconf bin/dconf.c — GNOME configuration system CLI (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '1:command:(help read list list-locks write reset compile update watch dump load blame complete _complete _complete_zsh)' \
    '*::command args:->cmdargs' \
    && ret=0

case $state in
    cmdargs)
        case $line[1] in
            read|watch|list|list-locks)
                _arguments '-d[show default values]' '1:KEY/DIR:_default'
                ;;
            write)
                _arguments '1:KEY:_default' '2:VALUE:_default'
                ;;
            reset)
                _arguments '-f[reset entire dir tree without prompt]' '1:KEY/DIR:_default'
                ;;
            compile)
                _arguments '1:output db:_files' '2:input dir:_files -/'
                ;;
            dump|load)
                _arguments '1:DIR:_default'
                ;;
            blame)
                _arguments
                ;;
        esac
        ;;
esac

return ret
