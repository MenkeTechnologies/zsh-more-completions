#compdef rsbackup
# _rsbackup — Richard Kettlewell rsbackup CLI for the rsync-based backup tool managing per-host per-volume backups with hardlink-based deduplication retention age-based pruning prune-incomplete email reports (ewxrjk team, C++); getopt
# upstream: https://github.com/ewxrjk/rsbackup

_rsbackup() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.conf rsbackup.conf"' \
        '--config=+[config file]:file:_files -g "*.conf rsbackup.conf"' \
        '-b[backup only]' \
        '--backup[backup only]' \
        '-p[prune only]' \
        '--prune[prune only]' \
        '--prune-incomplete[prune incomplete]' \
        '-r[report only]' \
        '--report[report only]' \
        '-d+[device names]:str:' \
        '--devices=+[device names]:str:' \
        '-D+[disabled hosts]:str:' \
        '--disable-hosts=+[disabled hosts]:str:' \
        '-T+[devices to retire]:str:' \
        '--retire-devices=+[devices to retire]:str:' \
        '--retire=+[volumes to retire]:str:' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '-w+[warn priority]:p:(low normal high)' \
        '--warn-priority=+[warn priority]:p:(low normal high)' \
        '--no-act[no act]' \
        '--text=+[file]:file:_files' \
        '--html=+[file]:file:_files' \
        '--email[email report]' \
        '--no-email[no email]' \
        '--check[check config]' \
        '-l+[log dir]:dir:_files -/' \
        '--logs=+[log dir]:dir:_files -/' \
        '--prune-policy=+[name]:str:' \
        '*:volumes:'
}

_rsbackup "$@"
