#compdef snapraid

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'status:print state summary'
  'smart:print SMART report'
  'probe:print disk power state'
  'up:spin up disks'
  'down:spin down disks'
  'diff:list modified files since last sync'
  'sync:update parity information'
  'scrub:check for silent errors'
  'fix:fix files and parity'
  'check:verify files and parity'
  'list:list files in array'
  'dup:list duplicate files'
  'pool:create pooled view'
  'devices:print low-level devices'
  'touch:set timestamps on files'
  'rehash:schedule rehash of array'
  'locate:locate files in parity'
)

_arguments -C \
  '(-c --conf)'{-c,--conf=}'[config file]:file:_files' \
  '*'{-f,--filter=}'[filter pattern]:pattern:' \
  '*'{-d,--filter-disk=}'[filter disk]:disk:' \
  '(-m --filter-missing)'{-m,--filter-missing}'[filter missing]' \
  '(-e --filter-error)'{-e,--filter-error}'[filter error]' \
  '(-p --plan)'{-p,--plan=}'[scrub plan]:plan:(bad new full)' \
  '(-o --older-than)'{-o,--older-than=}'[older than days]:days:' \
  '(-a --audit-only)'{-a,--audit-only}'[audit only]' \
  '(-h --pre-hash)'{-h,--pre-hash}'[pre-hash]' \
  '(-i --import)'{-i,--import=}'[import directory]:dir:_files -/' \
  '(-s --spin-down-on-error)'{-s,--spin-down-on-error}'[spin down on error]' \
  '(-w --bw-limit)'{-w,--bw-limit=}'[bandwidth limit]:rate:' \
  '(-t --tail)'{-t,--tail=}'[tail size]:size:' \
  '(-A --stats)'{-A,--stats}'[show stats]' \
  '(-Z --force-zero)'{-Z,--force-zero}'[force zero]' \
  '(-E --force-empty)'{-E,--force-empty}'[force empty]' \
  '(-U --force-uuid)'{-U,--force-uuid}'[force UUID]' \
  '(-D --force-device)'{-D,--force-device}'[force device]' \
  '(-N --force-nocopy)'{-N,--force-nocopy}'[force no copy]' \
  '(-F --force-full)'{-F,--force-full}'[force full]' \
  '(-R --force-realloc)'{-R,--force-realloc}'[force realloc]' \
  '(-W --force-realloc-tail)'{-W,--force-realloc-tail=}'[force realloc tail]:size:' \
  '(-l --log)'{-l,--log=}'[log file]:file:_files' \
  '(-L --error-limit)'{-L,--error-limit=}'[error limit]:n:' \
  '(-S --start)'{-S,--start=}'[start block]:n:' \
  '(-B --count)'{-B,--count=}'[block count]:n:' \
  '(-C --gen-conf)'{-C,--gen-conf=}'[generate config]:content:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(- *)'{-H,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'snapraid subcommand' subcommands && ret=0
    ;;
esac

return ret
