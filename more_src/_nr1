#compdef nr1

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'nerdpack:build/serve/publish/clone Nerdpacks'
  'nerdlet:Nerdlet operations'
  'launcher:launcher operations'
  'subscription:Nerdpack subscription operations'
  'catalog:catalog operations'
  'profiles:manage CLI profiles (add/list/remove/default)'
  'plugins:manage CLI plugins'
  'autocomplete:setup shell autocomplete'
  'create:scaffold new artifact (nerdpack/nerdlet/launcher/catalog)'
  'help:show help for any command'
  'update:update nr1 CLI'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--profile=[CLI profile name]:profile:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nr1 command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (nerdpack)
        local -a np_subs=(
          'build:build the Nerdpack'
          'serve:serve Nerdpack for development'
          'publish:publish a Nerdpack to the registry'
          'deploy:deploy a Nerdpack version to a tag'
          'undeploy:remove a Nerdpack version from a tag'
          'tag:tag a Nerdpack version'
          'untag:remove a tag from a Nerdpack version'
          'clone:clone a Nerdpack from git'
          'info:show Nerdpack info from the registry'
          'uuid:show or regenerate Nerdpack UUID'
          'validate:validate a Nerdpack'
          'clean:clean local build artifacts'
        )
        _describe -t npcmds 'nerdpack subcommand' np_subs && ret=0
        _arguments \
          '(-V --verbose)'{-V,--verbose}'[verbose]' \
          '(-a --all)'{-a,--all}'[show all versions]' \
          '(-t --tag)'{-t+,--tag=}'[Nerdpack tag]:tag:' \
          '--remote[query the registry]' && ret=0 ;;
      (nerdlet|launcher|catalog)
        _arguments '*::sub:(create generate)' && ret=0 ;;
      (create)
        _arguments \
          '(-t --type)'{-t+,--type=}'[artifact type]:type:(nerdpack nerdlet launcher catalog)' \
          '(-n --name)'{-n+,--name=}'[artifact name]:name:' && ret=0 ;;
      (subscription)
        _arguments '*::sub:(set unset list)' && ret=0 ;;
      (profiles)
        _arguments '*::sub:(add list remove default whoami)' && ret=0 ;;
      (plugins)
        _arguments '*::sub:(install link uninstall update)' && ret=0 ;;
      (autocomplete)
        _arguments '*::shell:(bash zsh fish)' && ret=0 ;;
    esac ;;
esac

return ret
