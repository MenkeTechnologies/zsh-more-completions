#compdef nr1
# Documentation: https://docs.newrelic.com/docs/new-relic-solutions/build-nr-ui/nr1-cli/nr1-common/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (nr1-common, nr1-nerdpack pages).

local curcontext="$curcontext" state line ret=1
local -a commands

# Top-level commands per upstream nr1-common reference.
commands=(
  'autocomplete:display autocomplete installation instructions'
  'create:create a new component from a template'
  'help:show all nr1 commands or details about each command'
  'nrql:fetch data using NRQL'
  'profiles:manage the profiles you use to run CLI commands'
  'update:update to the latest version of the CLI'
  'nerdpack:build/serve/publish/clone Nerdpacks'
  'nerdlet:Nerdlet operations'
  'launcher:launcher operations'
  'subscription:Nerdpack subscription operations'
  'catalog:catalog operations'
  'plugins:manage CLI plugins'
  'config:manage CLI configuration'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--profile=[CLI profile name]:profile:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nr1 command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (nerdpack)
        local -a np_subs=(
          'build:build the Nerdpack'
          'serve:serve Nerdpack for development'
          'publish:publish a Nerdpack to the registry'
          'tag:tag a Nerdpack version (alias deploy)'
          'untag:remove a tag (alias undeploy)'
          'clone:clone a Nerdpack from git'
          'info:show Nerdpack info from the registry'
          'uuid:show or regenerate Nerdpack UUID'
          'validate:validate a Nerdpack (alias ls/val)'
          'clean:remove all built artifacts'
        )
        _describe -t npcmds 'nerdpack subcommand' np_subs && ret=0
        _arguments \
          '(-V --verbose)'{-V,--verbose}'[verbose]' \
          '(-a --all)'{-a,--all}'[show all versions]' \
          '(-t --tag)'{-t+,--tag=}'[Nerdpack tag]:tag:' \
          '--remote[query the registry]' && ret=0 ;;
      (create)
        _arguments \
          '(-t --type)'{-t+,--type=}'[artifact type]:type:(nerdpack nerdlet launcher catalog)' \
          '(-n --name)'{-n+,--name=}'[artifact name]:name:' && ret=0 ;;
      (subscription)
        _arguments '*::sub:(set unset list)' && ret=0 ;;
      (profiles)
        _arguments '*::sub:(add list remove default)' && ret=0 ;;
      (plugins)
        _arguments '*::sub:(add link remove update list)' && ret=0 ;;
      (config)
        _arguments '*::sub:(get set list delete)' && ret=0 ;;
      (catalog)
        _arguments '*::sub:(info submit)' && ret=0 ;;
      (autocomplete)
        _arguments '*::shell:(bash zsh)' && ret=0 ;;
    esac ;;
esac

return ret
