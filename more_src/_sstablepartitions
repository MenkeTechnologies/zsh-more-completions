#compdef sstablepartitions
# Documentation: https://cassandra.apache.org/doc/latest/cassandra/managing/tools/sstable/sstablepartitions.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  {-t+,--min-size=}'[partition size threshold (bytes or e.g. 10KiB)]:size:' \
  {-w+,--min-rows=}'[minimum row count threshold]:n:' \
  {-c+,--min-cells=}'[minimum cell count threshold]:n:' \
  {-o+,--min-tombstones=}'[minimum tombstone count threshold]:n:' \
  '*'{-k+,--key=}'[target specific partition key]:key:' \
  '*'{-x+,--exclude-key=}'[exclude specific partition key]:key:' \
  {-r,--recursive}'[scan for sstables recursively]' \
  {-b,--backups}'[include backups in directory scan]' \
  {-s,--snapshots}'[include snapshots in directory scan]' \
  {-u+,--current-timestamp=}'[unix timestamp for TTL expired calculation]:timestamp:' \
  {-y,--partitions-only}'[only brief partition info]' \
  {-m,--csv}'[CSV output]' \
  '*:sstable file or directory:_files' && ret=0

return ret
