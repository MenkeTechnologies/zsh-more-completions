#compdef sstablepartitions

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  {-b,--backups}'[include backups in recursive scan]' \
  {-c+,--min-cells=}'[partition cell count threshold]:n:' \
  '*'{-k+,--key=}'[partition keys to include]:key:' \
  {-m,--csv}'[CSV output]' \
  {-o+,--min-tombstones=}'[partition tombstone count threshold]:n:' \
  {-r,--recursive}'[scan for sstables recursively]' \
  {-s+,--min-size=}'[partition size threshold]:size:' \
  {-t+,--min-rows=}'[partition row count threshold]:n:' \
  {-u+,--current-timestamp=}'[unix timestamp]:timestamp:' \
  '*:sstable file or directory:_files' && ret=0

return ret
