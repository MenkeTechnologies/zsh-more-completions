#compdef jupyter-lab
# Documentation: https://github.com/jupyterlab/jupyterlab/blob/main/jupyterlab/labapp.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Corrected from prior file: added real LabApp flags (--skip-dev-build,
# --splice-source, --custom-css) and fixed malformed --log-level value.

local -a arguments

arguments=(
    '--no-browser[Do not open a browser window]'
    '--autoreload[Auto-reload the webapp in debug mode]'
    '--no-autoreload[Do not auto-reload the webapp]'
    '--debug[Set log level to logging.DEBUG]'
    '--generate-config[Generate default config file]'
    '-y[Answer yes to any prompts]'
    '--allow-root[Allow the server to be run as root]'
    '--ip=[Set the IP address the server listens on]:ip address'
    '--port=[Set the port the server listens on]:port number'
    '--port-retries=[Number of ports to retry]:retries'
    '--keyfile=[SSL/TLS private key file]:key file:_files'
    '--certfile=[SSL/TLS certificate file]:cert file:_files'
    '--client-ca=[SSL/TLS CA certificate file]:ca file:_files'
    '--notebook-dir=[Set the root directory to serve from]:directory:_directories'
    '--browser=[Browser to use]:browser'
    '--pylab=[DISABLED, use %pylab or %matplotlib in the notebook]'
    '--config=[Load this config file]:config file:_files'
    '--log-level=[Set the log level]:level:(DEBUG INFO WARN ERROR CRITICAL)'
    '--app-dir=[The app directory to launch JupyterLab from]:directory:_directories'
    '--core-mode[Start the app in core mode]'
    '--dev-mode[Start the app in dev mode for running the JS from source]'
    '--skip-dev-build[Skip the initial build in dev mode]'
    '--watch[Start the app in watch mode]'
    '--splice-source[Splice source packages into app directory]'
    '--expose-app-in-browser[Expose the global app instance to browser via window.jupyterlab]'
    '--extensions-in-dev-mode[Load prebuilt extensions in dev mode]'
    '--collaborative[DEPRECATED, use jupyter-collaboration]'
    '--custom-css[Load custom CSS in template html files]'
    '--ServerApp.token=[Set token for authentication]:token'
    '*:files:_files'
)

_arguments -s -S $arguments
