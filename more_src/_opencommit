#compdef opencommit oco
# Documentation: https://github.com/di-sukharev/opencommit
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'config:manage opencommit configuration'
  'hook:manage prepare-commit-msg git hook'
  'models:display available models for current provider'
  'commitlint:manage commitlint configuration'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--yes[skip confirmation and commit automatically]' \
  '--fgm[use full GitMoji specification]' \
  '--no-verify[bypass git hooks]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'opencommit command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments '1:subcommand:(set describe)' '*:key=value:' && ret=0 ;;
      (hook)
        _arguments '1:subcommand:(set unset)' && ret=0 ;;
      (models)
        _arguments \
          '--refresh[refresh cached model list]' \
          '--provider=[show models for provider]:provider:' && ret=0 ;;
      (commitlint)
        _arguments '1:subcommand:(force get)' && ret=0 ;;
    esac ;;
esac

return ret
