#compdef java-config
# Gentoo Java configuration tool

local ret=1

_arguments -s -S \
  '-L[list available JVMs]' \
  '--list-available-vms[list available JVMs]' \
  '-j[show active JVM]' \
  '--java[show active JVM path]' \
  '-J[show active JVM home]' \
  '--jdk-home[show active JDK home]' \
  '-R[show active JRE home]' \
  '--jre-home[show active JRE home]' \
  '-O[show active JAVA_HOME]' \
  '-v[show active JVM version]' \
  '--select-vm=[select JVM]:JVM name:' \
  '-f[show active JVM flags]' \
  '-c[show classpath for package]:package name:' \
  '--classpath=[show classpath for package]:package name:' \
  '-l[list installed packages]' \
  '--list-available-packages[list installed packages]' \
  '-p[show package environment]:package name:' \
  '-S[set system VM]:JVM name:' \
  '--set-system-vm=[set system VM]:JVM name:' \
  '-s[set user VM]:JVM name:' \
  '--set-user-vm=[set user VM]:JVM name:' \
  '-h[show help]' \
  '--help[show help]' && ret=0

return ret
