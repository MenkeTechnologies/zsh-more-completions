#compdef 3dAutomask
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dAutomask.html
# AFNI generate a brain mask automatically from an EPI dataset

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-prefix[output mask dataset prefix]:prefix' \
  '-apply_prefix[apply mask to input and save]:prefix' \
  '-clfrac[clip level fraction 0.1-0.9]:cc' \
  '-nograd[use fixed clip level]' \
  '-peels[erode then dilate to remove protrusions]:pp' \
  '-NN1[NN1 neighbor definition]' \
  '-NN2[NN2 neighbor definition (default)]' \
  '-NN3[NN3 neighbor definition]' \
  '-nbhrs[minimum neighbors to prevent erosion]:nn' \
  '-q[suppress progress messages]' \
  '-eclip[remove exterior voxels below clip threshold]' \
  '-dilate[expand mask outward N times]:nd' \
  '-erode[contract mask inward N times]:ne' \
  '-SI[remove voxels below inferior distance in mm]:hh' \
  '-depth[generate depth dataset of peel operations]:dep' \
  '*:dataset:_files' && ret=0

return ret
