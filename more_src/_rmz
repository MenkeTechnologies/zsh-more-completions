#compdef rmz
# Documentation: https://man.archlinux.org/search?q=rmz
# Reference accessed: 2026-05-16

# supercilex/fuc/rmz — clap `Rmz` struct

local ret=1
_arguments -s -S \
  '(*)--help[long help]' \
  '(- *)'{-h,-\?}'[short help]' \
  '(- *)'{-V,--version}'[version]' \
  '(-f)'{-f,--force}'[ignore missing paths]' \
  '--preserve-root[refuse to remove / (default)]' \
  '--no-preserve-root[allow removing /]' \
  '*:paths:_files' && ret=0
return ret
