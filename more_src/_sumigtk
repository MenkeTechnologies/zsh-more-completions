#compdef sumigtk
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/migration_inversion/sumigtk.c
# Migration via T-K (omega-k) domain method for zero-offset SU data

local ret=1

_arguments -s -S \
  'dxcdp=[distance between successive cdps]:dxcdp' \
  'fmax=[maximum frequency]:fmax' \
  'tmig=[times corresponding to interval velocities in vmig]:tmig' \
  'vmig=[interval velocities corresponding to times in tmig]:vmig' \
  'vfile=[binary file containing velocities v(t)]:file:_files' \
  'nxpad=[number of cdps to pad with zeros before FFT]:nxpad' \
  'ltaper=[length of linear taper for left and right edges]:ltaper' \
  'verbose=[1 for diagnostic print]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
