#compdef ultralist

_ultralist_commands() {
  local -a commands=(
    'init:Initialize a new todolist'
    'add:Add a new todo (alias: a)'
    'list:List todos (alias: l)'
    'complete:Complete a todo (alias: c)'
    'uncomplete:Uncomplete a todo (alias: uc)'
    'delete:Delete a todo (alias: d)'
    'edit:Edit a todo (alias: e)'
    'archive:Archive completed todos (alias: ar)'
    'unarchive:Unarchive a todo (alias: uar)'
    'prioritize:Prioritize a todo (alias: p)'
    'unprioritize:Unprioritize a todo (alias: up)'
    'notes:Manage notes on a todo (alias: n)'
    'status:Set a todo status (alias: s)'
    'sync:Sync with ultralist.io'
    'web:Open in web browser'
    'version:Print version'
  )
  _describe 'command' commands
}

_ultralist() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help[Show help]' \
    '1:command:_ultralist_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        list|l)
          _arguments \
            '--completed[Show completed]' \
            '--archived[Show archived]' \
            '--due[Filter by due]:when:(today tomorrow thisweek overdue agenda none)' \
            '--status[Filter by status]:status:' \
            '--project[Filter by project]:project:' \
            '--context[Filter by context]:context:' \
            '--priority[Show only prioritized]' \
            '--notes[Show notes]' \
            '*:filter:'
          ;;
        add|a)
          _arguments '*:todo text:'
          ;;
        complete|c|uncomplete|uc|delete|d|archive|ar|unarchive|uar|prioritize|p|unprioritize|up)
          _arguments '1:todo id:'
          ;;
        edit|e)
          _arguments \
            '1:todo id:' \
            '*:new text:'
          ;;
        notes|n)
          local -a note_cmds=(
            'add:Add a note'
            'delete:Delete a note'
            'edit:Edit a note'
          )
          _describe 'notes command' note_cmds
          ;;
        status|s)
          _arguments \
            '1:todo id:' \
            '2:status:'
          ;;
      esac
      ;;
  esac
}

_ultralist "$@"
