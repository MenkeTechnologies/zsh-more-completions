#compdef ceph
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c+[specify config file]:file:_files' \
  '--conf=[specify config file]:file:_files' \
  '-n+[client name for authentication]:name' \
  '--name=[client name for authentication]:name' \
  '--cluster=[cluster name]:name' \
  '--admin-daemon=[connect to admin socket]:path:_files' \
  '--admin-socket=[connect to admin socket]:path:_files' \
  '-s[show cluster status]' \
  '--status[show cluster status]' \
  '-w[watch live cluster changes]' \
  '--watch[watch live cluster changes]' \
  '-W+[watch a specific channel]:channel:(cluster audit cephadm \*)' \
  '--watch-channel=[watch a specific channel]:channel:(cluster audit cephadm \*)' \
  '-o+[output file]:file:_files' \
  '--out-file=[output file]:file:_files' \
  '-i+[input file (payload)]:file:_files' \
  '--in-file=[input file (payload)]:file:_files' \
  '-k+[keyring file]:file:_files' \
  '--keyring=[keyring file]:file:_files' \
  '--id=[client id]:id' \
  '--user=[client id]:id' \
  '--setuser=[apply user ownership to output files]:user:_users' \
  '--setgroup=[apply group ownership to output files]:group:_groups' \
  '-f+[output format]:format:(json json-pretty xml xml-pretty plain yaml)' \
  '--format=[output format]:format:(json json-pretty xml xml-pretty plain yaml)' \
  '--verbose[increase verbosity]' \
  '--concise[reduce verbosity]' \
  '--block[block until scrub/deep-scrub completion]' \
  '--connect-timeout=[connection timeout in seconds]:seconds' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'osd:manage OSDs'
      'mon:manage monitors'
      'mds:manage metadata servers'
      'mgr:manage manager daemon'
      'pg:manage placement groups'
      'pool:manage pools'
      'auth:manage authentication'
      'config:manage configuration'
      'dashboard:manage dashboard'
      'device:manage devices'
      'df:show usage'
      'fs:manage CephFS'
      'health:show health'
      'orch:manage orchestrator'
      'quorum_status:show quorum status'
      'status:show cluster status'
      'tell:send command to daemon'
      'version:show version'
      'balancer:manage balancer'
      'crash:manage crash reports'
    )
    _describe 'command' commands && ret=0
    ;;
esac

return ret
