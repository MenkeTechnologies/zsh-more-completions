#compdef subtomosetup
# Documentation: https://bio3d.colorado.edu/imod/doc/man/subtomosetup.html
# subtomosetup - set up extraction of subvolumes for subtomogram averaging

local ret=1

_arguments -s -S \
  '-float[float subvolumes to a common range]' \
  '(-proc)-proc[number of processing units (CPUs or GPUs)]:count' \
  '(-root)-root[root name of dataset]:name' \
  '(-center)-center[model or point coordinate file of centers]:file:_files' \
  '(-volume)-volume[image volume in which points were selected]:file:_files' \
  '(-raw)-raw[name of raw image stack]:file:_files' \
  '(-axis)-axis[angle the tilt axis is rotated from vertical]:angle' \
  '(-objects)-objects[subset of objects to use from the model]:objects' \
  '(-size)-size[final size of subvolumes in X, Y, Z]:x,y,z' \
  '(-dir)-dir[directory to place subvolumes into]:dir:_files -/' \
  '(-chunk)-chunk[directory to place command files into]:dir:_files -/' \
  '(-skip)-skip[skip subvolumes near the border of the tomogram]' \
  '(-stackvols)-stackvols[stack subvolumes into MRC volume stacks]:value' \
  '(-com)-com[starting command file for running Tilt]:file:_files' \
  '(-binali)-binali[make a new aligned stack with the given binning]:binning' \
  '(-newstcom)-newstcom[command file for making a new aligned stack]:file:_files' \
  '(-unaligned)-unaligned[use the raw unaligned stack for CTF and reconstruction]' \
  '(-reduce)-reduce[reduce the raw stack by the given factor]:factor' \
  '(-zlevels)-zlevels[number of Z depths for CTF correction]:count' \
  '(-extent)-extent[maximum depth in Z to use one CTF correction]:value' \
  '(-invert)-invert[invert the sign of the offset in Z]:value' \
  '-adjust[adjust for Z shift of the tomogram]' \
  '(-ctfcom)-ctfcom[command file for CTF correction]:file:_files' \
  '-erase[run a command file to erase gold]' \
  '(-goldcom)-goldcom[command file for erasing gold]:file:_files' \
  '-filter[filter images in 2-D]' \
  '(-gpu)-gpu[override the default GPU behavior]:value' \
  '(-pixel)-pixel[pixel size of raw image stack in nanometers]:size' \
  '(-xform)-xform[file with the linear transformations]:file:_files' \
  '(-reorient)-reorient[type of reorientation to use]:value' \
  '(-runs)-runs[number of Tilt runs per command file]:count' \
  '(-help -h)'{-help,-h}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
