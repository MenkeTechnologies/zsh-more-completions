#compdef kubectl-debug_pdb
# Documentation: https://github.com/dhenkel92/kubectl-debug-pdb
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[kubeconfig context name]:context:' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '1:command:->cmds' \
  '*::arg:_default' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'cover:show which PDBs cover a workload'
      'create:create a new PDB for a given workload'
      'evict:evict a pod from a node'
      'pods:list pods covered by a given PDB'
      'completion:generate autocompletion script'
      'help:help about any command'
    )
    _describe -t commands 'kubectl-debug_pdb command' cmds && ret=0
    ;;
esac

return ret
