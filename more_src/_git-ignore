#compdef git-ignore
# Documentation: https://man.archlinux.org/search?q=git-ignore
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/git-ignore — Fetch .gitignore templates

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
