#compdef git-ignore
# Documentation: https://github.com/laggardkernel/git-ignore
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# git-ignore: fetch .gitignore templates from gitignore.io / github/gitignore

_arguments -s -S \
  '(-l --list)'{-l,--list}'[list all available templates]' \
  '(-s --search)'{-s,--search}'[search templates by keyword]:keyword:' \
  '(-u --update)'{-u,--update}'[initialize or update local templates]' \
  '(-c --clean)'{-c,--clean}'[remove local gitignore templates repository]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*::template:' && return 0
