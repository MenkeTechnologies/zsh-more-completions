#compdef xcconfigkit xcc xcconfig-cli
# _xcconfigkit — XcconfigKit Xcode .xcconfig generator/inspector CLI alias (community, Swift); custom argparse
# upstream: https://github.com/XcodeKit/XcconfigKit

_xcconfigkit() {
    local -a sub=(
        'generate:generate xcconfig'
        'inspect:inspect xcconfig'
        'diff:diff two xcconfigs'
        'merge:merge xcconfigs'
        'validate:validate xcconfig'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--project=+[xcodeproj]:file:_files -g "*.xcodeproj"' \
        '-p+[xcodeproj]:file:_files -g "*.xcodeproj"' \
        '--target=+[target]:str:' \
        '-t+[target]:str:' \
        '--scheme=+[scheme]:str:' \
        '-s+[scheme]:str:' \
        '--configuration=+[configuration]:c:(Debug Release)' \
        '-c+[configuration]:c:(Debug Release)' \
        '--output=+[output file]:file:_files -g "*.xcconfig"' \
        '-o+[output file]:file:_files -g "*.xcconfig"' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xcconfigkit subcommand' sub ;;
        args)
            case $words[1] in
                generate|inspect|validate) _arguments '*:file:_files -g "*.xcconfig *.xcodeproj"' ;;
                diff) _arguments '*:files:_files -g "*.xcconfig"' ;;
                merge) _arguments \
                    '--output=+[output file]:file:_files -g "*.xcconfig"' \
                    '-o+[output file]:file:_files -g "*.xcconfig"' \
                    '*:files:_files -g "*.xcconfig"' ;;
            esac
            ;;
    esac
}

_xcconfigkit "$@"
