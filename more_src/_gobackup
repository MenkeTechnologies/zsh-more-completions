#compdef gobackup
# Documentation: https://man.archlinux.org/search?q=gobackup
# Reference accessed: 2026-05-16

# Zsh completion for gobackup backup tool

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '*::model targets: _message "see gobackup --help"' && ret=0

return ret
