#compdef ghunt
# Documentation: https://github.com/mxrch/GHunt
# OSINT: investigate Google accounts with email, gaia id, drive, etc.

local ret=1
local -a subcmds

subcmds=(
  'login:authenticate GHunt to Google'
  'email:get information on an email address'
  'gaia:get information on a Gaia ID'
  'drive:get information on a Drive file or folder'
  'geolocate:geolocate a BSSID'
  'spiderdal:find assets using Digital Assets Links'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json=[export results in JSON format]:file:_files' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds) _describe -t commands 'ghunt command' subcmds && ret=0 ;;
esac

return ret
