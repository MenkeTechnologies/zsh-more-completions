#compdef tasm

# TASM: Borland Turbo Assembler (DOS x86)
# Documentation: https://en.wikipedia.org/wiki/Turbo_Assembler
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[alphabetical segment order]' \
  '-c[create cross-reference]' \
  '-d[define symbol]:symbol:' \
  '-e[emulate floating point]' \
  '-h[show help]' \
  '-i[include path]:dir:_files -/' \
  '-j[directive]:directive:' \
  '-kh[max symbols]:n:' \
  '-l[create listing]' \
  '-m[passes]:n:' \
  '-ml[case sensitive]' \
  '-mu[upper-case symbols]' \
  '-mx[case-sensitive globals]' \
  '-n[suppress symbol table in listing]' \
  '-p[check for impure protected mode]' \
  '-q[suppress copyright]' \
  '-r[real instructions]' \
  '-s[sequential segment order]' \
  '-t[suppress messages]' \
  '-u[set target version]:ver:' \
  '-v[verbose]' \
  '-w[warning level]:n:' \
  '-x[include false conditionals]' \
  '-z[show source line on error]' \
  '*:source file:_files -g "*.asm"' && ret=0
return ret
