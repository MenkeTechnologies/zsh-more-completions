#compdef git-chain
# Documentation: https://github.com/dashed/git-chain
# git-chain - tool for rebasing a chain of local git branches

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:(setup init list move rename rebase merge backup push first last next prev prune remove)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '--before=[position current branch before specified branch]:branch:' \
          '--after=[position current branch after specified branch]:branch:' \
          '--first[position current branch first in chain]' && ret=0
        ;;
      move)
        _arguments -s -S \
          '--before=[move branch before specified position]:branch:' \
          '--after=[move branch after specified position]:branch:' \
          '--chain=[move to different chain]:chain:' && ret=0
        ;;
      rebase)
        _arguments -s -S \
          '(-s --step)'{-s,--step}'[rebase one branch at a time]' \
          '(-i --ignore-root)'{-i,--ignore-root}'[skip rebasing first branch onto root]' \
          '--continue[resume after resolving conflicts]' \
          '--skip[skip conflicted branch and continue]' \
          '--abort[roll back the entire chain rebase]' \
          '--status[display progress of ongoing chain rebase]' \
          '--cleanup-backups[delete backup branches after successful rebase]' \
          '--squashed-merge=[handle squashed merges]:mode:(reset skip rebase)' && ret=0
        ;;
      merge)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[detailed output during merging]' \
          '(-i --ignore-root)'{-i,--ignore-root}'[skip merging root branch into first]' \
          '--stay[remain on last merged branch]' \
          '--chain=[operate on specific chain]:chain:' \
          '(-s --simple)'{-s,--simple}'[use simple merge mode]' \
          '(-f --fork-point)'{-f,--fork-point}'[enable fork-point detection]' \
          '--no-fork-point[disable fork-point detection]' \
          '--ff[allow fast-forward if possible]' \
          '--no-ff[always create a merge commit]' \
          '--ff-only[only allow fast-forward merges]' \
          '--squash[create a single commit instead of a merge]' \
          '--strategy=[git merge strategy]:strategy:' \
          '--strategy-option=[strategy-specific option]:option:' \
          '--squashed-merge=[handle squashed merges]:mode:(reset skip merge)' \
          '--report-level=[output detail level]:level:(minimal standard detailed)' \
          '--no-report[suppress merge summary report]' \
          '--detailed-report[same as --report-level=detailed]' && ret=0
        ;;
      push)
        _arguments -s -S \
          '--force[use force-with-lease when pushing]' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '--chain=[remove specific named chain]:chain:' \
          '--chain[remove entire chain instead of single branch]' && ret=0
        ;;
    esac
    ;;
esac

return ret
