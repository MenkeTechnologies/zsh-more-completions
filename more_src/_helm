#compdef helm
# Documentation: https://helm.sh/docs/helm/helm/
# Source: helm/helm — Kubernetes package manager.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '--burst-limit=[client-side default throttling limit]:n:' \
    '--debug[verbose output]' \
    '--kube-apiserver=[Kubernetes API server address]:server:_hosts' \
    '--kube-as-group=[group to impersonate (repeatable)]:group:' \
    '--kube-as-user=[user to impersonate]:user:_users' \
    '--kube-ca-file=[Kubernetes CA bundle]:file:_files' \
    '--kube-context=[kubeconfig context]:context:' \
    '--kube-insecure-skip-tls-verify[skip API-server cert verification]' \
    '--kube-token=[bearer token for auth]:token:' \
    '--kubeconfig=[kubeconfig file]:file:_files' \
    '(-n --namespace)'{-n+,--namespace=}'[release namespace]:namespace:' \
    '--registry-config=[OCI registry login config]:file:_files' \
    '--repository-cache=[chart repository cache]:dir:_directories' \
    '--repository-config=[chart repository config]:file:_files' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'completion:generate autocompletion script'
            'create:create a new chart with the given name'
            'dependency:manage a chart'\''s dependencies'
            'env:helm client environment info'
            'get:download extended info of a release'
            'history:fetch release history'
            'install:install a chart'
            'lint:examine a chart for possible issues'
            'list:list releases'
            'package:package a chart directory into an archive'
            'pull:download a chart from a repository'
            'repo:add / list / remove / update / index chart repositories'
            'rollback:roll back a release to a previous revision'
            'search:search for a keyword in charts'
            'show:show information of a chart'
            'status:display the status of the named release'
            'template:locally render templates'
            'test:run tests for a release'
            'uninstall:uninstall a release'
            'upgrade:upgrade a release'
            'verify:verify a signed chart'
            'version:print helm version info'
        )
        _describe -t subcmds 'helm command' subcmds && ret=0
        ;;
    args)
        _default
        ;;
esac

return ret
