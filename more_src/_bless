#compdef bless
# Documentation: bless --help (macOS 26)
# Source: set or query the bless state of a volume / file / device.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--info=-[print blessing info for volume]::dir:_files -/' \
    '--getBoot[print active boot volume]' \
    '--plist[plist representation of output]' \
    '--verbose[verbose output]' \
    '--file=[blessed boot file]:file:_files' \
    '--folder=[blessed directory]:dir:_files -/' \
    '--setBoot[set firmware to boot from this volume]' \
    '--create-snapshot[create APFS snapshot of this volume]' \
    '--snapshot=[set snapshot by UUID]:uuid:' \
    '--snapshotname=[set snapshot by name]:name:' \
    '--last-sealed-snapshot[revert to previous signed APFS snapshot]' \
    '--mount=[mountpoint to use with --setBoot]:dir:_files -/' \
    '--device=[block device to use with --setBoot]:device:_files -g "/dev/disk*"' \
    && ret=0

return ret
