#compdef vip-manager
# Documentation: https://github.com/cybertec-postgresql/vip-manager
# Manage a virtual IP based on the state of a Patroni/DCS leader key

local ret=1

_arguments -s -S \
  '--help[display available flags]' \
  '--version[show version information]' \
  '--config=[path to YAML configuration file]:file:_files' \
  '--ip=[virtual IP address to manage]:ip' \
  '--netmask=[network mask for the VIP subnet]:netmask' \
  '--interface=[local network interface for IP binding]:interface' \
  '--trigger-key=[DCS key to monitor]:key' \
  '--trigger-value=[expected DCS value]:value' \
  '--manager-type=[manager type]:type:(basic hetzner)' \
  '--dcs-type=[DCS type]:type:(etcd consul patroni)' \
  '*--dcs-endpoints=[DCS/API endpoint URL]:endpoint' \
  '--etcd-user=[username for etcd authentication]:user' \
  '--etcd-password=[password for etcd authentication]:password' \
  '--consul-token=[authentication token for Consul]:token' \
  '--interval=[main loop sleep duration in ms]:ms' \
  '--retry-after=[delay before retries in ms]:ms' \
  '--retry-num=[number of retry attempts]:num' \
  '--etcd-ca-file=[CA file for etcd]:file:_files' \
  '--etcd-cert-file=[client certificate for etcd]:file:_files' \
  '--etcd-key-file=[private key for client certificate]:file:_files' \
  '--verbose[enable detailed logging]' && ret=0

return ret
