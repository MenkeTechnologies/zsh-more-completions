#compdef markdownlint-cli2
# Documentation: https://github.com/DavidAnson/markdownlint-cli2
# Reference accessed: 2026-05-17
# Verified: DavidAnson/markdownlint-cli2 README.
# Removed from prior file: bogus man.archlinux.org search URL;
# missing --configPointer, --format, --no-globs.

# markdownlint-cli2: lint Markdown files with the markdownlint library
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--config=[base configuration file]:file:_files' \
  '--configPointer=[JSON Pointer into config object]:pointer:' \
  '--fix[apply fixes in place]' \
  '--format[read stdin, fix, write stdout]' \
  '--no-globs[ignore top-level globs property]' \
  '*:file or glob:_files -g "*.(md|markdown)(-.)"' && ret=0
return ret
