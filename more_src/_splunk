#compdef splunk

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start Splunk daemon'
  'stop:stop Splunk daemon'
  'restart:restart Splunk daemon'
  'status:show daemon status'
  'version:show Splunk version'
  'help:show help'
  'login:authenticate to a Splunk instance'
  'logout:remove cached credentials'
  'search:run a search'
  'rtsearch:run a real-time search'
  'dispatch:dispatch a search'
  'edit:edit a Splunk object'
  'add:add a Splunk object'
  'remove:remove a Splunk object'
  'list:list Splunk objects'
  'show:show details of a Splunk object'
  'set:set a config value'
  'enable:enable a feature'
  'disable:disable a feature'
  'reload:reload configuration'
  'refresh:refresh deployment client'
  'clean:clean a Splunk index'
  'find:find files'
  'package:create a deployment app package'
  'install:install an app or shcluster bundle'
  'anonymize:anonymize log data'
  'diag:collect diagnostic data'
  'fsck:repair index buckets'
  'btool:dump and verify configuration'
  'classify:classify a sourcetype'
  'train:train a learned model'
  'validate:validate configuration'
  'apply:apply shcluster-bundle/cluster-bundle'
  'export:export data'
  'import:import data'
  'rolling-restart:rolling restart of a cluster'
  'offline:bring a peer offline'
  'hot-bucket-roller:roll hot buckets'
  'list-licenser-pools:list licenser pools'
  'send-hep-event:send a HEP event'
  'http-debug:debug HTTP requests'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--accept-license[accept license]' \
  '--answer-yes[answer yes to all prompts]' \
  '--no-prompt[no prompts]' \
  '--auto-ports[auto-allocate ports]' \
  '-auth=[username:password]:auth:' \
  '-uri=[Splunk REST URI]:uri:' \
  '-app=[app context]:app:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'splunk subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (btool)
        _values 'btool action' 'check' 'list' && ret=0
        ;;
      (fsck)
        _values 'fsck action' \
          'scan' 'repair' 'clear-bloomfilter' 'check-integrity' 'generate-hash-files' && ret=0
        ;;
      (clean)
        _values 'clean target' \
          'all' 'eventdata' 'globaldata' 'inputdata' 'kvstore' 'userdata' && ret=0
        ;;
      (train)
        _values 'train target' 'sourcetype' && ret=0
        ;;
      (apply)
        _values 'apply target' 'shcluster-bundle' 'cluster-bundle' && ret=0
        ;;
    esac
    ;;
esac

return ret
