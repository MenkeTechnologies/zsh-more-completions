#compdef scrunch
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Rebin a spectrum to a linear or logarithmic wavelength scale

local ret=1

_arguments -s -S \
  'SPECTRUM=[spectrum or spectra to be scrunched]:spectrum:_files' \
  'WSTART=[wavelength of centre of first output bin]:wstart:' \
  'WEND=[wavelength of last bin or increment]:wend:' \
  'BINS=[number of elements in output spectrum]:bins:' \
  'OUTPUT=[resulting scrunched data file]:output:_files' \
  'INCREMENT=[treat WEND as an increment]:increment:(TRUE FALSE)' \
  'FINAL=[treat WEND as the final wavelength]:final:(TRUE FALSE)' \
  'LOG=[bin to a logarithmic wavelength scale]:log:(TRUE FALSE)' \
  'LINEAR=[use linear interpolation]:linear:(TRUE FALSE)' \
  'QUAD=[use quadratic interpolation]:quad:(TRUE FALSE)' \
  'FLUX=[conserve flux during rebinning]:flux:(TRUE FALSE)' \
  'MEAN=[conserve mean value during rebinning]:mean:(TRUE FALSE)' \
  '*:NDF data file:_files' && ret=0

return ret
