#compdef cuobjdump
# Documentation: https://docs.nvidia.com/cuda/cuda-binary-utilities/
# Reference accessed: 2026-05-16
# Verified: NVIDIA CUDA Binary Utilities manual.
# Removed from prior file: bogus man.archlinux.org search URL.

# cuobjdump: CUDA object file dump
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(--all-fatbin -all)'{--all-fatbin,-all}'[extract all fatbin sections]' \
  '(--dump-elf -elf)'{--dump-elf,-elf}'[dump ELF info]' \
  '(--dump-elf-symbols -symbols)'{--dump-elf-symbols,-symbols}'[dump ELF symbols]' \
  '(--dump-ptx -ptx)'{--dump-ptx,-ptx}'[dump PTX]' \
  '(--dump-sass -sass)'{--dump-sass,-sass}'[dump SASS]' \
  '(--dump-resource-usage -res-usage)'{--dump-resource-usage,-res-usage}'[dump resource usage]' \
  '(--extract-elf -xelf)'{--extract-elf=,-xelf=}'[extract ELF for arch]:arch:' \
  '(--extract-ptx -xptx)'{--extract-ptx=,-xptx=}'[extract PTX for arch]:arch:' \
  '(--extract-text -xtext)'{--extract-text=,-xtext=}'[extract text section]:section:' \
  '(--function -fun)'{--function=,-fun=}'[function name]:name:' \
  '(--function-index -findex)'{--function-index=,-findex=}'[function by index]:n:' \
  '(--gpu-architecture -arch)'{--gpu-architecture=,-arch=}'[GPU architecture]:arch:' \
  '(--list-elf -lelf)'{--list-elf,-lelf}'[list ELF sections]' \
  '(--list-ptx -lptx)'{--list-ptx,-lptx}'[list PTX sections]' \
  '(--list-text -ltext)'{--list-text,-ltext}'[list text sections]' \
  '(--sort-functions -sort)'{--sort-functions,-sort}'[sort functions]' \
  '*:CUDA binary:_files' && ret=0
return ret
