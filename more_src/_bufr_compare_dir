#compdef bufr_compare_dir
# Documentation: https://confluence.ecmwf.int/display/ECC/bufr_compare_dir
# Source: ecmwf/eccodes tools/bufr_compare_dir — shell wrapper comparing BUFR dirs via bufr_compare/bufr_index_build.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '1::bufr_compare option (e.g. -2):_default' \
    '2:directory 1:_files -/' \
    '3:directory 2:_files -/' \
    && ret=0

return ret
