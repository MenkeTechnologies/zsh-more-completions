'-C+[Run as if fleche was started in this directory]:PATH:_files' \
'--directory=[Run as if fleche was started in this directory]:PATH:_files' \
'--debug[Enable verbose SSH output for debugging connection issues]' \
'--json[Output results as JSON (for scripting and AI agents)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_fleche_commands" \
"*::: :->fleche" \
&& ret=0
    case $state in
    (fleche)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:fleche-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
'--command=[Override or provide command (if job name given)]:COMMAND:_default' \
'--ntfy=[Send push notifications via ntfy.sh on state changes]:TOPIC:_default' \
'*--env=[Set environment variable (repeatable)]:ENV_VARS:_default' \
'*--tag=[Add tag for filtering/organization (repeatable)]:TAGS:_default' \
'--partition=[Override Slurm partition]:PARTITION:_default' \
'--time=[Override wall time]:TIME:_default' \
'--gpus=[Override GPU count]:GPUS:_default' \
'--cpus=[Override CPU count]:CPUS:_default' \
'--memory=[Override memory]:MEMORY:_default' \
'--constraint=[Override constraint]:CONSTRAINT:_default' \
'--nodes=[Override nodes]:NODES:_default' \
'--exclude=[Override exclude]:EXCLUDE:_default' \
'--after=[Run after another job completes successfully]:AFTER:_default' \
'--host=[Run on specific host ("local" for local execution)]:HOST:_default' \
'--retry=[Retry failed jobs with exponential backoff (e.g., --retry 3)]:RETRY:_default' \
'--note=[Add a note/annotation to the job]:NOTE:_default' \
'-C+[Run as if fleche was started in this directory]:PATH:_files' \
'--directory=[Run as if fleche was started in this directory]:PATH:_files' \
'--bg[Run in background (don'\''t stream output)]' \
'--notify[Send terminal notification when job completes (useful with --bg)]' \
'--dry-run[Print generated sbatch script without submitting]' \
'--exec[Run directly via SSH instead of submitting to Slurm]' \
'--debug[Enable verbose SSH output for debugging connection issues]' \
'--json[Output results as JSON (for scripting and AI agents)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::job_or_command -- Job name from config, or command to run (in quotes):_default' \
&& ret=0
;;
(exec)
_arguments "${_arguments_options[@]}" : \
'*--env=[Set environment variable (repeatable)]:ENV_VARS:_default' \
'--host=[Run on specific host ("local" for local execution)]:HOST:_default' \
'-C+[Run as if fleche was started in this directory]:PATH:_files' \
