(( $+functions[_fleche_commands] )) ||
_fleche_commands() {
    local commands; commands=(
'run:Run a job on the remote cluster via Slurm' \
'exec:Execute a command directly via SSH (no Slurm)' \
'status:Show status of jobs' \
'logs:Fetch and display job logs' \
'download:Download output files from remote to local' \
'cancel:Cancel a running or pending job' \
'clean:Archive or delete finished jobs' \
'jobs:List available jobs from configuration' \
'tags:List all unique tags across jobs' \
'rerun:Re-run a previous job with the same settings' \
'init:Create a starter fleche.toml in current directory' \
'check:Validate configuration without running anything' \
'skill:Print or install the fleche skill for AI coding agents' \
'doctor:Comprehensive diagnostic for troubleshooting' \
'ping:Check cluster health by pinging the Slurm controller' \
'wait:Wait for a job to complete' \
'completions:Generate shell completions' \
'stats:Show resource usage statistics for jobs' \
'note:Add or view a note on a job' \
'compare:Compare two jobs side-by-side' \
'proxy:Run a command through a SOCKS proxy tunnel to the remote host' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'fleche commands' commands "$@"
}
