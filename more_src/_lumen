#compdef lumen
# Documentation: https://github.com/jnsahaj/lumen
# Source: jnsahaj/lumen — Rust single-binary git diff viewer + AI commit/explain helpers.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _lm_cmds
_lm_cmds=(
    'diff:interactive side-by-side diff viewer (works without AI)'
    'draft:generate a commit message from staged changes'
    'operate:translate natural language to git commands'
    'explain:explain commit / branch / staged changes via AI'
    'configure:interactive AI provider/api-key/model setup'
    'help:show help'
)

_arguments -C \
    '-p+[AI provider]:provider:(openai claude gemini groq ollama)' \
    '-k+[API key]:key:_default' \
    '-m+[model]:model:_default' \
    '--config=[custom config file path]:file:_files' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'lumen command' _lm_cmds && ret=0
        ;;
    args)
        case $line[1] in
            diff)
                _arguments -s -S \
                    '--pr=[GitHub PR number]:n:_default' \
                    '--file=[filter to file]:file:_files' \
                    '--watch[auto-refresh on file changes]' \
                    '--stacked[review commits one at a time]' \
                    '--focus=[jump to a specific file]:file:_files' \
                    '--theme=[colour theme]:theme:(dracula catppuccin-mocha catppuccin-latte gruvbox tokyo-night)' \
                    && ret=0
                ;;
            draft)
                _arguments -s -S \
                    '(-c --context)'{-c+,--context=}'[intent context for the commit]:text:_default' \
                    && ret=0
                ;;
            explain)
                _arguments -s -S \
                    '--staged[explain staged changes]' \
                    '--query=[ask a specific question]:text:_default' \
                    '--list[interactive commit selection (requires fzf)]' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
