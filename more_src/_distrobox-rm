#compdef distrobox-rm

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --force)'{-f,--force}'[force removal]' \
  '(-Y --yes)'{-Y,--yes}'[do not ask confirmation]' \
  '--all[remove all containers]' \
  '(-v --verbose)'{-v,--verbose}'[show more verbosity]' \
  '*:container name:' && ret=0

return ret
