#compdef otf2-print otf2-snapshots otf2-marker otf2-config otf2-estimator otf2-template otf2
# _otf2 — Score-P consortium Open Trace Format 2 OTF2 highly-scalable trace files for HPC and parallel programs (score-p team, C); custom argparse
# upstream: https://www.vi-hps.org/projects/score-p/

_otf2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-A[print all]' \
        '--all[print all]' \
        '-G[print global definitions]' \
        '--global-defs[print global definitions]' \
        '-d[print local definitions]' \
        '--local-defs[print local definitions]' \
        '-e[print events]' \
        '--events[print events]' \
        '-M[print metric values]' \
        '--metrics[print metric values]' \
        '-L+[location id]:n:' \
        '--location=+[location id]:n:' \
        '-t+[start time]:n:' \
        '--start=+[start time]:n:' \
        '-T+[stop time]:n:' \
        '--stop=+[stop time]:n:' \
        '-S+[snapshot id]:n:' \
        '--snapshot=+[snapshot id]:n:' \
        '-r+[ranks regex]:str:' \
        '--ranks=+[ranks regex]:str:' \
        '-s[silent]' \
        '--silent[silent]' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '-x[parser only]' \
        '--print-error[print error]' \
        '--print-warnings[print warnings]' \
        '*:trace file:_files -g "*.otf2"'
}

_otf2 "$@"
