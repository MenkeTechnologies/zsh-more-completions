#compdef pdns_util pdnsutil

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config-dir=[configuration directory]:directory:_directories' \
  '--config-name=[configuration name]:name:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'activate-zone-key:activate a zone key'
      'add-record:add a DNS record'
      'add-zone-key:add a zone key'
      'b2b-migrate:migrate data between backends'
      'bench-db:benchmark database'
      'check-all-zones:check all zones'
      'check-zone:check a zone'
      'clear-zone:clear all records in a zone'
      'create-bind-db:create BIND zone file'
      'create-secondary-zone:create a secondary zone'
      'create-zone:create a zone'
      'deactivate-zone-key:deactivate a zone key'
      'delete-rrset:delete a record set'
      'delete-tsig-key:delete a TSIG key'
      'delete-zone:delete a zone'
      'disable-dnssec:disable DNSSEC for a zone'
      'edit-zone:edit a zone'
      'export-zone-dnskey:export zone DNSKEY'
      'export-zone-ds:export zone DS records'
      'export-zone-key:export zone key'
      'generate-tsig-key:generate a TSIG key'
      'generate-zone-key:generate a zone key'
      'get-meta:get zone metadata'
      'hash-password:hash a password'
      'hash-zone-record:hash a record for NSEC3'
      'import-tsig-key:import a TSIG key'
      'import-zone-key:import a zone key'
      'increase-serial:increase zone serial'
      'list-all-zones:list all zones'
      'list-keys:list DNSSEC keys'
      'list-tsig-keys:list TSIG keys'
      'list-zone:list zone records'
      'load-zone:load zone from file'
      'rectify-all-zones:rectify all zones'
      'rectify-zone:rectify a zone'
      'remove-zone-key:remove a zone key'
      'replace-rrset:replace a record set'
      'secure-all-zones:secure all zones'
      'secure-zone:secure a zone with DNSSEC'
      'set-kind:set zone kind'
      'set-meta:set zone metadata'
      'set-nsec3:set NSEC3 parameters'
      'set-presigned:mark zone as pre-signed'
      'show-zone:show zone details'
      'test-schema:test database schema'
      'unset-nsec3:remove NSEC3 parameters'
      'unset-presigned:mark zone as not pre-signed'
    )
    _describe -t commands 'pdnsutil command' commands && ret=0
    ;;
  args)
    case $line[1] in
      check-zone|create-zone|delete-zone|edit-zone|list-zone|secure-zone|show-zone|rectify-zone)
        _arguments -s -S \
          '1:zone name:' && ret=0
        ;;
      add-record)
        _arguments -s -S \
          '1:zone name:' \
          '2:record name:' \
          '3:record type:(A AAAA CNAME MX NS PTR SOA SRV TXT CAA TLSA)' \
          '4:TTL:' \
          '*:content:' && ret=0
        ;;
      create-secondary-zone)
        _arguments -s -S \
          '1:zone name:' \
          '*:master IPs:' && ret=0
        ;;
      set-kind)
        _arguments -s -S \
          '1:zone name:' \
          '2:kind:(master slave native)' && ret=0
        ;;
      load-zone)
        _arguments -s -S \
          '1:zone name:' \
          '2:zone file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
