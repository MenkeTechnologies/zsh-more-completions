#compdef gopls
# _gopls-cli — Go official language server (Go team, Rob Pike + Robert Findley); LSP backend for Go editors
# upstream: https://pkg.go.dev/golang.org/x/tools/gopls

_gopls-cli() {
    local -a sub=(
        'serve:run as LSP server (default)'
        'api-json:print gopls API descriptions'
        'call_hierarchy:print call hierarchy'
        'check:show diagnostics for a file'
        'codeaction:list applicable code actions'
        'codelens:list code lenses'
        'definition:go to definition'
        'execute:execute server command'
        'fix:apply suggested fixes'
        'folding_ranges:list folding ranges'
        'format:format a file'
        'help:show help'
        'implementation:list implementations'
        'imports:format imports'
        'inspect:print server inspection info'
        'licenses:show license info'
        'links:list document links'
        'mcp:run MCP integration'
        'modules:show known modules'
        'prepare_rename:check if symbol is renameable'
        'references:find references to symbol'
        'remote:remote inspection'
        'rename:rename a symbol'
        'semtok:print semantic tokens for a file'
        'signature:print signature at pos'
        'stats:print gopls stats'
        'symbols:list workspace symbols'
        'version:show version'
        'workspace:print workspace info'
        'workspace_symbol:search workspace symbols'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-vv[very verbose]' \
        '-debug+[debug addr]:addr:' \
        '-listen+[listen addr]:addr:' \
        '-listen.timeout+[listen timeout]:duration:' \
        '-logfile+[log file]:file:_files' \
        '-mode+[server mode]:mode:(local stdio tcp websocket pipe)' \
        '-port+[port]:port:' \
        '-profile.alloc+[alloc profile]:file:_files' \
        '-profile.block+[block profile]:file:_files' \
        '-profile.cpu+[CPU profile]:file:_files' \
        '-profile.mem+[mem profile]:file:_files' \
        '-profile.trace+[trace file]:file:_files' \
        '-remote+[remote address]:addr:' \
        '-remote.debug+[remote debug]:addr:' \
        '-remote.listen.timeout+[remote listen timeout]:duration:' \
        '-remote.logfile+[remote log file]:file:_files' \
        '-rpc.trace[trace RPCs]' \
        '-verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gopls subcommand' sub ;;
        args)
            case $words[1] in
                check|format|imports|definition|references|rename|implementation|folding_ranges|signature|symbols) _arguments '*:file:_files' ;;
                workspace_symbol) _arguments '1:query:' ;;
            esac
            ;;
    esac
}

_gopls-cli "$@"
