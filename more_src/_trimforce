#compdef trimforce
# Documentation: https://man.archlinux.org/search?q=trimforce
# Reference accessed: 2026-05-16

local -a subcommands

subcommands=(
    'enable:Enable TRIM on third-party SSDs'
    'disable:Disable TRIM on third-party SSDs'
    'status:Display TRIM status'
)

_arguments -s -S \
    '1:subcommand:->subcmd' && return

case $state in
    subcmd)
        _describe 'trimforce subcommand' subcommands
        ;;
esac
