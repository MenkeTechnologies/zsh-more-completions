#compdef hgGcPercent
# UCSC kent: calculate GC percentage in windows and load into database

local ret=1

_arguments -s -S \
  '-win[change window size (default 20000)]:size' \
  '-noLoad[do not load MySQL table, create a bed file]' \
  '-file[output to filename (stdout OK, implies -noLoad)]:file:_files' \
  '-chr[process only chrN from the nibDir]:chr' \
  '-noRandom[ignore random chromosomes from the nibDir]' \
  '-noDots[do not display ... progress]' \
  '-doGaps[process gaps correctly]' \
  '-wigOut[output wiggle ASCII data ready for wigEncode]' \
  '-overlap[overlap windows by N bases (default 0)]:n' \
  '-verbose[display details to stderr]:n' \
  '-bedRegionIn[read a bed file for GC content in specific regions]:file:_files -g "*.bed"' \
  '-bedRegionOut[write a bed file of GC content in specific regions]:file:_files' \
  '1:database:' \
  '2:nib directory:_files -/' && ret=0

return ret
