#compdef helm-adopt
# Documentation: https://github.com/HamzaZo/helm-adopt
# helm adopt: adopt existing k8s resources into a new generated Helm chart

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug-mode[show the generated manifests on STDOUT]' \
  '--dry-run[print what resources will be adopted]' \
  '(-c --kube-context)'{-c,--kube-context}'=[name of the kubeconfig context to use]:context:' \
  '(-k --kubeconfig)'{-k,--kubeconfig}'=[path to the kubeconfig file]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this request]:namespace:' \
  '(-o --output)'{-o,--output}'=[chart directory of loaded yaml files]:dir:_files -/' \
  '(-r --release)'{-r,--release}'=[specify the release name]:release:' \
  '1:command:(resources)' \
  '*::arg:_files' && ret=0

return ret
