#compdef kbluetoothd
# Documentation: https://github.com/KDE/bluedevil
# Reference accessed: 2026-05-19
# Verified: KDE/bluedevil — kbluetoothd is the KDE Plasma Bluetooth
# daemon (GUI/D-Bus service), no documented CLI flags. STUB:
# reduced to KDE/Qt standard KAboutData options only. Removed the
# unverifiable --quit flag and bogus man.archlinux search URL.

# kbluetoothd: KDE Plasma Bluetooth daemon (GUI/D-Bus service)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show Qt-specific options as well]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--style=[set the Qt widget style]:style:' \
  '--platform=[set the Qt Platform Abstraction plugin]:platform:' && ret=0
return ret
