#compdef kbluetoothd
# Documentation: https://man.archlinux.org/search?q=kbluetoothd
# Reference accessed: 2026-05-16

# kbluetoothd: KDE Bluetooth daemon launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--quit[ask running daemon to quit]' \
  '*::kbluetoothd args:_files' && ret=0
return ret
