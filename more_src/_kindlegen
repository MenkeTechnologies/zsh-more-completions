#compdef kindlegen
# Documentation: https://wiki.mobileread.com/wiki/KindleGen
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Corrected from prior file: removed fabricated -rcss, -dont_append_source
# (the documented switch is -donotaddsource, which replaced the old
# -dont_append_source) and the invented -locale enum. Added documented
# switches -preserve_img, -image64K, -image128K, -allscript,
# -noparseback, -genhdcontainers. Single-dash long switches per upstream.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-c0[no compression]' \
  '-c1[standard PalmDOC compression]' \
  '-c2[Kindle Huffdic compression]' \
  '-verbose[verbose output]' \
  '-western[forced Windows-1252 output]' \
  '-gif[GIF image conversion (no JPEG)]' \
  '-preserve_img[preserve original image size]' \
  '-image64K[restrict max image size to 64K]' \
  '-image128K[restrict max image size to 128K]' \
  '-allscript[authorize all scripting]' \
  '-noparseback[do not build parse back]' \
  '-donotaddsource[do not add source files]' \
  '-genhdcontainers[build eMM with given resolutions]' \
  '-locale[display messages in selected language]:locale:' \
  '-o+[output file name]:file:' \
  '*:input:_files -g "*.{opf,html,htm,epub,xml}"' && ret=0

return ret
