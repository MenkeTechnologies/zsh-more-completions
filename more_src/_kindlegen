#compdef kindlegen
# Documentation: https://man.archlinux.org/search?q=kindlegen
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c0[no compression]' \
  '-c1[standard DOC compression]' \
  '-c2[Kindle huffdic compression]' \
  '-verbose[verbose output]' \
  '-western[output Latin-1]' \
  '-gif[use GIF instead of JPEG]' \
  '-locale+[locale]:locale:(en de fr es it zh ja pt ru nl)' \
  '-o+[output file name]:file:' \
  '-dont_append_source[no source append]' \
  '-rcss[load remote CSS]' \
  '*:input:_files -g "*.{opf,html,htm,epub,mobi}"' && ret=0

return ret
