_gritty_commands() {
    local commands; commands=(
'connect:Smart session\: attach if exists, create if not' \
'c:Smart session\: attach if exists, create if not' \
'tail:Tail a session'\''s output (read-only, like tail -f)' \
't:Tail a session'\''s output (read-only, like tail -f)' \
'list-sessions:List active sessions' \
'ls:List active sessions' \
'list:List active sessions' \
'kill-session:Kill a session' \
'kill-server:Kill the server and all sessions' \
'restart:Restart the server (and tunnel, for remote hosts). One-shot recovery for protocol version upgrades\: kills the daemon (tolerant of a mismatched handshake), tears down the tunnel, and starts both back up' \
'rename:Rename a session' \
'send:Send files to a paired receiver' \
'receive:Receive files from a paired sender' \
'open:Open a URL on the local machine (for use inside gritty sessions)' \
'copy:Copy stdin to the client clipboard (for use inside gritty sessions)' \
'local-forward:Forward a port from the session to the client (listen on session, connect on client)' \
'lf:Forward a port from the session to the client (listen on session, connect on client)' \
'remote-forward:Forward a port from the client to the session (listen on client, connect on session)' \
'rf:Forward a port from the client to the session (listen on client, connect on session)' \
'tunnel-create:Set up SSH tunnel to a remote host (backgrounds by default)' \
'tunnel-destroy:Tear down an SSH tunnel by connection name' \
'bootstrap:Install gritty on a remote host (downloads release via install script)' \
'tunnels:List active SSH tunnels' \
'tun:List active SSH tunnels' \
'server:Start the server (backgrounds by default, use -f to stay in foreground)' \
's:Start the server (backgrounds by default, use -f to stay in foreground)' \
'info:Show diagnostics (paths, server status, tunnels)' \
'config:Open config file in \$VISUAL/\$EDITOR/vi (creates from template if missing)' \
'doctor:Check for common issues (stale processes, orphaned sockets, config errors)' \
'completions:Generate shell completions' \
'socket-path:Print the default socket path' \
'socket:Print the default socket path' \
'protocol-version:Print the protocol version number' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'gritty commands' commands "$@"
}
