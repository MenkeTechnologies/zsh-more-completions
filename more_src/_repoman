#compdef repoman
# Gentoo ebuild QA tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'commit:commit changes to CVS'
  'ci:commit changes to CVS'
  'fix:fix trivial QA issues'
  'full:full scan of repository'
  'help:show help'
  'manifest:generate Manifest files'
  'scan:scan for QA issues'
)

_arguments -s -S \
  '1:command:->command' \
  '-a[ask mode]' \
  '-d[debug mode]' \
  '-f[force commit]' \
  '-I[ignore masked packages]' \
  '-m[specify commit message]:message:' \
  '-M[specify committer]:committer:' \
  '-p[pretend mode]' \
  '-q[quiet mode]' \
  '-S[straight mode (no revbump)]' \
  '-v[verbose mode]' \
  '-x[xmllint check]' \
  '--force[force commit]' \
  '--help[show help]' \
  '--version[show version]' \
  '--include-arches=[include specific arches]:arches:' \
  '--without-mask[ignore package.mask]' \
  '--ignore-default-opts[ignore REPOMAN_DEFAULT_OPTS]' \
  '*:ebuild:_files -g "*.ebuild"' && ret=0

case $state in
  (command)
    _describe -t commands 'repoman command' commands && ret=0
    ;;
esac

return ret
