autoload -U is-at-least

_stakk() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--config=[Path to a config file (overrides automatic discovery).]:CONFIG:_files' \
'--bookmarks-revset=[Revset passed to \`jj bookmark list -r <REVSET>\` to discover bookmarks for graph construction.]:BOOKMARKS_REVSET:_default' \
'--heads-revset=[Revset passed to \`jj log -r <REVSET>\` to discover unbookmarked head changes for graph construction.]:HEADS_REVSET:_default' \
'--pr-mode=[Whether new pull requests are created as regular or draft PRs.]:PR_MODE:((regular\:"Create pull requests as regular (non-draft) PRs"
draft\:"Create pull requests as drafts"))' \
'--remote=[Git remote to push to]:REMOTE:_default' \
'--template=[Path to a custom minijinja template for stack comments.]:TEMPLATE:_default' \
'--stack-placement=[Where to place the stack comment on each pull request.]:STACK_PLACEMENT:((comment\:"Place the stack comment as a separate PR comment (issue comment)"
body\:"Place the stack content in a fenced section of the PR body"))' \
'--sync-pr-content=[Controls whether existing PR titles and/or bodies are updated from jj commit descriptions on every submit.]:SYNC_PR_CONTENT:((none\:"Do not sync. Title and body are only set on PR creation"
title\:"Sync only the PR title from the first line of the commit description"
body\:"Sync only the PR body from the commit description"
all\:"Sync both the PR title and body"))' \
'--trailers=[Whether to keep or strip git commit trailers in PR bodies.]:TRAILERS:((keep\:"Leave trailers in the PR body verbatim"
strip\:"Strip the trailer block (Signed-off-by, Co-authored-by, Refs, etc.) from the PR body"))' \
'--auto-prefix=[Prefix for auto-generated bookmark names.]:AUTO_PREFIX:_default' \
'--bookmark-command=[Shell command for generating custom bookmark names.]:BOOKMARK_COMMAND:_default' \
'--dry-run[Show what would be done without actually doing it]' \
'--draft[Shortcut for --pr-mode=draft. Overrides --pr-mode if both are given]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::bookmark -- The bookmark to submit as a pull request. If omitted, shows an interactive selection:_default' \
":: :_stakk_commands" \
"*::: :->stakk" \
&& ret=0
    case $state in
    (stakk)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:stakk-command-$line[2]:"
        case $line[2] in
            (submit)
_arguments "${_arguments_options[@]}" : \
'--bookmarks-revset=[Revset passed to \`jj bookmark list -r <REVSET>\` to discover bookmarks for graph construction.]:BOOKMARKS_REVSET:_default' \
'--heads-revset=[Revset passed to \`jj log -r <REVSET>\` to discover unbookmarked head changes for graph construction.]:HEADS_REVSET:_default' \
'--pr-mode=[Whether new pull requests are created as regular or draft PRs.]:PR_MODE:((regular\:"Create pull requests as regular (non-draft) PRs"
draft\:"Create pull requests as drafts"))' \
'--remote=[Git remote to push to]:REMOTE:_default' \
'--template=[Path to a custom minijinja template for stack comments.]:TEMPLATE:_default' \
'--stack-placement=[Where to place the stack comment on each pull request.]:STACK_PLACEMENT:((comment\:"Place the stack comment as a separate PR comment (issue comment)"
body\:"Place the stack content in a fenced section of the PR body"))' \
'--sync-pr-content=[Controls whether existing PR titles and/or bodies are updated from jj commit descriptions on every submit.]:SYNC_PR_CONTENT:((none\:"Do not sync. Title and body are only set on PR creation"
title\:"Sync only the PR title from the first line of the commit description"
body\:"Sync only the PR body from the commit description"
all\:"Sync both the PR title and body"))' \
'--trailers=[Whether to keep or strip git commit trailers in PR bodies.]:TRAILERS:((keep\:"Leave trailers in the PR body verbatim"
strip\:"Strip the trailer block (Signed-off-by, Co-authored-by, Refs, etc.) from the PR body"))' \
'--auto-prefix=[Prefix for auto-generated bookmark names.]:AUTO_PREFIX:_default' \
'--bookmark-command=[Shell command for generating custom bookmark names.]:BOOKMARK_COMMAND:_default' \
'--config=[Path to a config file (overrides automatic discovery).]:CONFIG:_files' \
'--dry-run[Show what would be done without actually doing it]' \
'--draft[Shortcut for --pr-mode=draft. Overrides --pr-mode if both are given]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::bookmark -- The bookmark to submit as a pull request. If omitted, shows an interactive selection:_default' \
&& ret=0
;;
(auth)
_arguments "${_arguments_options[@]}" : \
'--config=[Path to a config file (overrides automatic discovery).]:CONFIG:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
":: :_stakk__subcmd__auth_commands" \
"*::: :->auth" \
&& ret=0

    case $state in
    (auth)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:stakk-auth-command-$line[1]:"
        case $line[1] in
            (test)
_arguments "${_arguments_options[@]}" : \
'--config=[Path to a config file (overrides automatic discovery).]:CONFIG:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(setup)
_arguments "${_arguments_options[@]}" : \
'--config=[Path to a config file (overrides automatic discovery).]:CONFIG:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_stakk__subcmd__auth__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:stakk-auth-help-command-$line[1]:"
        case $line[1] in
            (test)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(setup)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(show)
_arguments "${_arguments_options[@]}" : \
'--bookmarks-revset=[Revset passed to \`jj bookmark list -r <REVSET>\` to discover bookmarks for graph construction.]:BOOKMARKS_REVSET:_default' \
'--heads-revset=[Revset passed to \`jj log -r <REVSET>\` to discover unbookmarked head changes for graph construction.]:HEADS_REVSET:_default' \
'--config=[Path to a config file (overrides automatic discovery).]:CONFIG:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--config=[Path to a config file (overrides automatic discovery).]:CONFIG:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- The shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_stakk__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:stakk-help-command-$line[1]:"
        case $line[1] in
            (submit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(auth)
_arguments "${_arguments_options[@]}" : \
":: :_stakk__subcmd__help__subcmd__auth_commands" \
"*::: :->auth" \
&& ret=0

    case $state in
    (auth)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:stakk-help-auth-command-$line[1]:"
        case $line[1] in
            (test)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(setup)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_stakk_commands] )) ||
_stakk_commands() {
    local commands; commands=(
'submit:Submit bookmarks as GitHub pull requests (default when no command given)' \
'auth:Manage authentication' \
'show:Show repository status and bookmark stacks' \
'completions:Generate shell completions for the given shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'stakk commands' commands "$@"
}
(( $+functions[_stakk__subcmd__auth_commands] )) ||
_stakk__subcmd__auth_commands() {
    local commands; commands=(
'test:Test that authentication is working' \
'setup:Print instructions for setting up authentication' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'stakk auth commands' commands "$@"
}
