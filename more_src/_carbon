#compdef carbon
# Documentation: https://github.com/carbon-language/carbon-lang (toolchain/driver/driver.cpp + compile_subcommand.cpp)
# Reference accessed: 2026-05-29
# Carbon language toolchain (Google).

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'build-runtimes:build target-specific runtimes'
  'clang:invoke bundled Clang'
  'compile:compile Carbon source to binary, IR, or assembly'
  'config:show or set toolchain configuration'
  'format:format Carbon source code'
  'language-server:run the LSP language server'
  'link:link compiled artifacts'
  'lld:invoke bundled LLD linker'
  'llvm:invoke bundled LLVM tools'
  'help:show help for a subcommand'
)

local -a _global_flags
_global_flags=(
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging to stderr]'
  '--runtimes-cache=[custom location for runtimes cache]:dir:_directories'
  '--prebuilt-runtimes=[path to prebuilt runtimes tree]:dir:_directories'
  '--build-runtimes[enable on-demand runtime building (default on)]'
  '--no-build-runtimes[disable on-demand runtime building]'
  '--fuzzing[configure command line for fuzzing]'
  '--include-diagnostic-kind[include diagnostic kind in output]'
  '--threads[use threads when building runtimes (default on)]'
  '--no-threads[disable threading when building runtimes]'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -C \
  $_global_flags \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'carbon subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      compile)
        _arguments \
          $_global_flags \
          '--phase=[compilation phase to run]:phase:(lex parse check lower optimize codegen)' \
          '*--clang-arg=[argument passed to Clang]:arg:' \
          '(-o --output)'{-o,--output=}'[output filename (- = stdout)]:file:_files' \
          '--optimize=[optimization level]:level:(none debug speed size)' \
          '--asm-output[write textual assembly instead of binary]' \
          '--force-obj-output[force binary output even with --output=-]' \
          '--stream-errors[stream errors to stderr as generated]' \
          '--dump-shared-values[dump shared values]' \
          '--dump-tokens[dump lexed tokens to stdout]' \
          '--omit-file-boundary-tokens[exclude file boundary tokens from --dump-tokens]' \
          '--dump-parse-tree[dump parse tree to stdout]' \
          '--preorder-parse-tree[reorder parse tree to preorder]' \
          '--dump-raw-sem-ir[dump raw JSON SemIR to stdout]' \
          '--dump-sem-ir[dump full SemIR to stdout]' \
          '--dump-cpp-ast[dump full C++ AST to stdout]' \
          '--dump-sem-ir-ranges=[handle SemIR range markers]:mode:(if-present only ignore)' \
          '--builtin-sem-ir[include builtin SemIR in dumps]' \
          '--dump-llvm-ir[dump LLVM IR after lowering]' \
          '--dump-asm[dump generated assembly after codegen]' \
          '--dump-mem-usage[dump memory usage statistics]' \
          '--dump-timings[dump phase duration for each unit]' \
          '--prelude-import[use implicit prelude import (default on)]' \
          '--no-prelude-import[disable implicit prelude import]' \
          '--custom-core[use custom Core package]' \
          '--exclude-dump-file-prefix=[exclude files matching prefix from dumps]:prefix:' \
          '--debug-info[emit DWARF debug information (default on)]' \
          '--no-debug-info[disable DWARF debug information]' \
          '--output-last-input-only[output only the last input file]' \
          '--verify-llvm-ir[run LLVM verifier on modules (default on)]' \
          '--sem-ir-crash-dump=[path for SemIR dump on crash]:file:_files' \
          '--mangle-string-fingerprint[use string form of fingerprint]' \
          '*:Carbon source file:_files -g "*.carbon"' && ret=0
        ;;
      format)
        _arguments \
          $_global_flags \
          '*:Carbon source file:_files -g "*.carbon"' && ret=0
        ;;
      language-server)
        _arguments $_global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
