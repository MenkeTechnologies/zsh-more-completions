#compdef bgpd
# Documentation: https://docs.frrouting.org/en/latest/bgp.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Note: FRR bgpd daemon; flags drawn from FRR Common Invocation Options + bgpd-specific.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[daemonize]' \
  '(-f --config_file)'{-f,--config_file}'+[config file]:file:_files' \
  '(-i --pid_file)'{-i,--pid_file}'+[pid file]:file:_files' \
  '(-z --socket)'{-z,--socket}'+[zebra socket]:file:_files' \
  '(-A --vty_addr)'{-A,--vty_addr}'+[VTY address]:addr:' \
  '(-P --vty_port)'{-P,--vty_port}'+[VTY port]:port:' \
  '(-r --retain)'{-r,--retain}'[retain routes after exit]' \
  '(-p --bgp_port)'{-p,--bgp_port}'+[BGP port]:port:' \
  '(-l --listenon)'{-l,--listenon}'+[listen on address]:addr:' \
  '(-N --pathspace)'{-N,--pathspace}'+[namespace]:ns:' \
  '(-S --skip_runas)'{-S,--skip_runas}'[skip setuid]' \
  '(-u --user)'{-u,--user}'+[user]:user:_users' \
  '(-g --group)'{-g,--group}'+[group]:group:_groups' \
  '(-K --graceful_restart)'{-K,--graceful_restart}'+[graceful restart sec]:sec:' \
  '(-y --routerid)'{-y,--routerid}'+[router-id]:id:' \
  '(-X --io-pthread)'{-X,--io-pthread}'+[I/O threads]:n:' && ret=0

return ret
