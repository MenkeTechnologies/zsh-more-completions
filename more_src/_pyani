#compdef pyani average_nucleotide_identity.py
# _pyani — Leighton Pritchard pyani CLI calculating Average Nucleotide Identity ANI ANIb ANIm TETRA between bacterial genome assemblies using BLAST+ MUMmer NUCmer pairwise alignment producing tabular percentage-identity coverage matrices for prokaryotic species classification (Leighton Pritchard team, Python); argparse
# upstream: https://github.com/widdowquinn/pyani

_pyani() {
    local -a sub=(
        'index:index input genomes'
        'createdb:create empty SQLite database'
        'anim:run ANI using MUMmer NUCmer'
        'anib:run ANI using BLAST+ blastn'
        'aniblastall:run ANI using legacy BLAST'
        'tetra:run TETRA correlation'
        'report:generate report from analysis'
        'plot:generate plots'
        'classify:classify analysed genomes'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-l+[log file]:file:_files' \
        '--logfile=+[file]:file:_files' \
        '--debug[debug]' \
        '--scheduler=+[s]:s:(multiprocessing sge slurm)' \
        '--workers=+[N]:n:' \
        '--dbpath=+[file]:file:_files -g "*.db *.sqlite"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pyani subcommand' sub ;;
        args)
            case $words[1] in
                anim|anib|aniblastall|tetra) _arguments \
                    '-i+[input dir]:dir:_files -/' \
                    '-o+[output dir]:dir:_files -/' \
                    '--name=+[name]:str:' \
                    '--classes=+[file]:file:_files' \
                    '--labels=+[file]:file:_files' ;;
                report) _arguments \
                    '-o+[output dir]:dir:_files -/' \
                    '--formats=+[fmt]:f:(html tab excel json csv)' \
                    '--run_results[show run results]' \
                    '--runs[show runs]' \
                    '--genomes[show genomes]' ;;
                plot) _arguments \
                    '-o+[output dir]:dir:_files -/' \
                    '--formats=+[fmt]:f:(png pdf svg)' \
                    '--method=+[m]:m:(mpl seaborn)' ;;
            esac
            ;;
    esac
}

_pyani "$@"
