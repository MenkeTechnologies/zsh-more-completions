#compdef ip-rule
# Documentation: https://man.archlinux.org/man/ip-rule.8.en
# ip rule - routing policy database management

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip rule command' \
      'add[insert new rule]' 'del[delete rule]' 'flush[clear all rules]' \
      'show[list rules]' 'save[export rules]' 'restore[import rules]' \
      'from[source address prefix]' 'to[destination address prefix]' \
      'iif[incoming interface]' 'oif[outgoing interface]' \
      'tos[type of service]' 'dsfield[type of service]' \
      'dscp[DSCP field]' 'fwmark[firewall mark]' 'uidrange[user ID range]' \
      'ipproto[IP protocol number]' 'sport[source port]' 'dport[destination port]' \
      'priority[rule priority]' 'flowlabel[IPv6 flow label]' \
      'tun_id[tunnel identifier]' 'l3mdev[layer 3 device flag]' 'not[negate selector]' \
      'table[routing table id]' 'lookup[routing table id]' \
      'protocol[routing protocol id]' 'nat[NAT address]' 'realms[realm values]' \
      'goto[jump to rule by priority]' \
      'suppress_prefixlength[reject shorter prefixes]' \
      'suppress_ifgroup[reject interface group]' && ret=0
    ;;
esac

return ret
