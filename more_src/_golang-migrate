#compdef golang-migrate
# Documentation: https://github.com/golang-migrate/migrate/tree/master/cmd/migrate
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create migration files'
  'goto:migrate to a specific version'
  'up:apply N (or all) up migrations'
  'down:roll back N (or all) down migrations'
  'drop:drop everything in the database'
  'force:set version manually (clears dirty)'
  'version:show current version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-help,--help}'[show help]' \
  '(- *)'{-version,--version}'[show version]' \
  '-source+[migration source URL]:url:' \
  '-path+[migration directory]:dir:_files -/' \
  '-database+[database connection URL]:url:' \
  '-prefetch+[prefetch N migrations]:n:' \
  '-lock-timeout+[advisory lock timeout]:duration:' \
  '-verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'migrate command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '-ext+[migration file extension]:ext:(sql)' \
          '-dir+[migration files directory]:dir:_files -/' \
          '-format+[date format]:fmt:' \
          '-seq[generate sequential versions]' \
          '-digits+[sequential version width]:n:' \
          '-tz+[time zone]:tz:' \
          '*:migration_name:' && ret=0 ;;
      (up|down)
        _arguments '*::n:' && ret=0 ;;
      (goto|force)
        _arguments '*::version:' && ret=0 ;;
    esac ;;
esac

return ret
