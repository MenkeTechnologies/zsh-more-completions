#compdef ldnsd
# _ldnsd — NLnet Labs ldns ldnsd (example mini authoritative DNS server in the ldns examples directory; -c config file, -d daemonize, -p port, -P pidfile, -4 IPv4 only, -6 IPv6 only, -v verbose, -V version; positional argument is the zone file to serve)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from NLnetLabs/ldns examples/ldnsd.c on tip.

_ldnsd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-d[daemonize]' \
        '-p+[port]:port:' \
        '-P+[pidfile]:file:_files' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-v[verbose]' \
        '1:zone file:_files'
}

_ldnsd "$@"
