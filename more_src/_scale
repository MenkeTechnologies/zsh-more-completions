#compdef scale
# Documentation: https://csound.com/docs/manual/
# Csound utility to rescale the amplitude of a soundfile

local ret=1

_arguments -s -S \
  '-F+[gain factor or breakpoint filename]:gain' \
  '-M+[scale so max absolute displacement equals value]:maxamp' \
  '-P+[scale so max displacement is percent of 0dB]:percent' \
  '-A[AIFF output format]' \
  '-W[WAV output format]' \
  '-h[no header on output]' \
  '-c[8-bit signed char samples]' \
  '-a[A-law samples]' \
  '-u[U-law samples]' \
  '-s[short integer samples]' \
  '-l[long (32-bit) integer samples]' \
  '-f[floating point samples]' \
  '-R[continuously rewrite header during writing]' \
  '-H+[progress indicator style]:style:(1 2 3)' \
  '-N[notify when complete]' \
  '-o+[output filename]:output:_files' \
  '*:soundfile:_files' && ret=0

return ret
