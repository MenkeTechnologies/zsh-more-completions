#compdef CollectJumpingLibraryMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectJumpingLibraryMetrics
# Picard: collect jumping-library metrics for mate-pair sequencing data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  '*'{-I=,--INPUT=}'[BAM file(s) of reads with duplicates marked]:bam:_files -g "*.bam"' \
  {-O=,--OUTPUT=}'[file to which metrics should be written]:file:_files' \
  {-MQ=,--MINIMUM_MAPPING_QUALITY=}'[mapping quality minimum cutoff]:int:' \
  {-T=,--TAIL_LIMIT=}'[stop when tail bins contain fewer than mode/TAIL_LIMIT items]:int:' \
  '--CHIMERA_KB_MIN=[minimum jump size considered a chimera]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.bam"' && ret=0

return ret
