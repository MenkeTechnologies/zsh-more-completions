#compdef beluga
# =============================================================================
# beluga — the Beluga programming language compiler and type checker.
#          Beluga is a functional dependently-typed programming language
#          designed at McGill University by Brigitte Pientka and her group
#          for specifying and proving properties of formal systems
#          (programming languages, logics, type systems).  Beluga's core
#          innovation is CONTEXTUAL TYPES — first-class support for
#          higher-order abstract syntax (HOAS) representations of programs
#          and proofs through dependent contextual modal type theory.
#          Beluga is used in formal verification research at McGill, INRIA,
#          and Microsoft Research Cambridge.
#
# Author:  Brigitte Pientka, Andrew Cave, Joshua Dunfield, Jacob Errington,
#          Clare Jang, Marcel Goh, et al. (McGill CompSci)
# Source:  https://github.com/Beluga-lang/Beluga
# CLI:     src/beluga/main.ml (entry point, hand-rolled +/- prefix parser)
# Library: hand-rolled OCaml flag dispatch (tri-prefix +/- option convention)
# License: GPL-3.0
# Status:  Active research project — 213+ stars, primary tool in
#          contextual-modal-type-theory and HOAS research, with multiple
#          PhD theses and active publications at POPL/ICFP/LICS using it.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — BELUGA IS NOW LANGUAGE 45
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy crosses from
# 44 to 45 documented languages.  Beluga joins the canonical roster alongside:
# Rust, Go, TypeScript-Node, Python, Ruby, Perl, C, C++, Lua, Java, Kotlin,
# Scala, Haskell, OCaml, Elixir, Erlang, Clojure, Common Lisp, Scheme/Racket,
# Julia, Crystal, Pony, Nim, Zig, V, Swift, R, Dart, Fortran, Tcl, Ada, Janet,
# D, Picat, BQN, Frege, Lobster, Curry, Mercury, Wren, Idris2, F#, Jakt,
# Ur/Web, and now Beluga.  beluga is documented as the FIRST Beluga CLI
# library variant in the taxonomy (hand-rolled OCaml tri-prefix +/- flag
# parser) — bringing the total to 199 cross-language CLI library variants.
# -----------------------------------------------------------------------------
#
# WHAT IS BELUGA AND WHY DOES IT WARRANT ITS OWN CLI LIBRARY DOCUMENTATION CATEGORY?
#
# Beluga is a programming language and proof environment for METALANGUAGE
# RESEARCH.  It was developed at McGill University by Brigitte Pientka and
# her PhD students (Andrew Cave, Joshua Dunfield, Jacob Thomas Errington,
# Clare Jang, Marcel Goh, and others) as a successor to the Twelf logical
# framework, with the goal of making it ergonomic to prove theorems about
# programming languages and logics.
#
# Beluga is implemented in OCaml and ships two binaries:
#
#   * `beluga`  — the main compiler / type checker that loads .bel signature
#                 files, elaborates them through Beluga's bidirectional type
#                 checking pipeline, and runs the proof goals to completion.
#                 Used in non-interactive mode for batch verification.
#
#   * `harpoon` — the interactive proof assistant that runs on top of the
#                 same elaboration kernel.  Harpoon provides a small set of
#                 tactics (intros, split, by, ?, etc.) for incremental
#                 development of Beluga proofs.  Inspired by Coq's tactics
#                 and the Twelf interactive mode.
#
# Beluga is distinct from every other language documented in the corpus
# because:
#
#   * It is the FIRST documented language with FIRST-CLASS CONTEXTS as a
#     type-level construct.  A Beluga type can mention not just a syntactic
#     object but the ENTIRE TYPING CONTEXT in which it lives, allowing
#     specifications like `[gamma |- term]` where `gamma` ranges over all
#     possible typing contexts.  This is the technical content of
#     "contextual modal type theory" (Nanevski, Pfenning, Pientka 2008).
#   * It is the FIRST documented language with FIRST-CLASS HOAS
#     (Higher-Order Abstract Syntax).  In Beluga, lambda-binding in the
#     OBJECT language (the language being specified) maps directly to
#     OCaml-level lambda-binding in the META language (Beluga itself),
#     handling alpha-renaming, substitution, and capture-avoidance for
#     free.  Other documented languages with HOAS support (Twelf, Coq with
#     PHOAS, Agda with parametric HOAS) either lack first-class contexts
#     (Twelf) or require encodings (Coq/Agda).
#   * It uses CONTEXTUAL SCHEMA CHECKING — Beluga can prove that a given
#     context conforms to a SCHEMA (a syntactic specification of what
#     bindings are allowed in the context) at compile time.
#   * It has DEPENDENT PATTERN MATCHING WITH COVERAGE CHECKING that
#     accounts for context structure.  A case-split on a term whose type
#     mentions a context generates separate cases for each context shape.
#   * It is implemented in OCAML and uses a custom in-house applicative-
#     combinator parser library (Optparser) for harpoon — distinct from
#     OCaml's stdlib Arg or third-party Cmdliner — but the MAIN beluga
#     binary uses a HAND-ROLLED TRI-PREFIX +/- FLAG PARSER, documented
#     below.
#
# -----------------------------------------------------------------------------
# BELUGA'S CLI LIBRARY — HAND-ROLLED OCAML TRI-PREFIX +/- FLAG PARSER
# -----------------------------------------------------------------------------
#
# The main `beluga` binary uses a HAND-ROLLED OCaml flag parser in
# src/beluga/main.ml.  This is the FIRST documented "TRI-PREFIX +/- FLAG"
# CLI convention in the corpus's cross-language taxonomy.
#
# The defining convention:
#
#   * Flags prefixed with `+` are GENERALLY ENABLING — they turn a feature
#     ON.  Examples from Beluga: `+d` (debug printing), `+t` (timing info),
#     `+tfile` (timing to file), `+implicit` (print implicit args),
#     `+printSubord` (print subordination relations), `+print` (turn
#     printing ON), `+test` (test-harness mode), `+html` (HTML output),
#     `+annot` (annotation file generation).
#
#   * Flags prefixed with `-` are GENERALLY DISABLING or PARAMETERIZING —
#     they turn a feature OFF or set a value.  Examples: `-print` (turn
#     printing OFF, opposite of `+print`), `-logic` (disable logic engine),
#     `-width nnn` (set output width), `-s=debruijn` (substitution style).
#
#   * The flag pair `-print` / `+print` is the canonical illustration: the
#     same feature can be both enabled and disabled from the command line
#     by switching the prefix.  This is a CONVENTION ABSENT FROM POSIX/GNU
#     getopt, where flags are typically single-direction switches.
#
# HISTORICAL CONTEXT — WHERE DOES TRI-PREFIX +/- FLAG CONVENTION COME FROM?
#
# The +/- prefix convention is descended from the COMPILER FLAG TRADITION
# of Standard ML compilers (SML/NJ, Mlton, MoscowML), OCaml itself
# (`-rectypes`, `+ocamlfind`), Haskell's GHC (`-Wall`, `+RTS`/`-RTS` blocks
# for runtime options), and various theorem provers (Twelf, Coq's
# `-print-X`/`+print-X`, Agda's `--show-implicit`/`--no-show-implicit`).
# Within the ML lineage, +/- prefixes encode the intuition that command-
# line flags are TOGGLES on internal compiler state, and toggling can
# go EITHER DIRECTION.  Beluga inherits this convention from its OCaml
# host language and Twelf ancestor.
#
# THE PARSER IMPLEMENTATION (verbatim from src/beluga/main.ml):
#
#     let is_option argument =
#       let first = String.get argument 0 in
#       first = '-' || first = '+'
#
#     let process_option arg rest =
#       let with_arg_for arg k =
#         match rest with
#         | [] -> bailout (arg ^ " requires an argument")
#         | a :: rest -> k a rest
#       in
#       match arg with
#       | "+d"            -> Debug.enable (); rest
#       | "-s=debruijn"   -> PC.substitutionStyle := PC.DeBruijn; rest
#       | "+implicit"     -> PC.printImplicit := true; rest
#       | "+t"            -> Monitor.on := true; rest
#       | "+tfile"        -> Monitor.onf := true; rest
#       | "+printSubord"  -> Subord.dump := true; rest
#       | "+test"         -> Chatter.level := 0;
#                            Syncom.Error.disable_colored_output (); rest
#       | "-print"        -> Chatter.level := 0; rest
#       | "+print"        -> Chatter.level := 2; rest
#       | "+html"         -> Options.Html.enabled := true; rest
#       | "-width"        -> with_arg_for "-width" (fun arg rest ->
#                              let width = try int_of_string arg
#                                          with Failure _ -> bailout "..." in
#                              Format.set_margin (max 40 width); rest)
#       | "-logic"        -> Logic.Options.enableLogic := false; rest
#       | "+annot"        -> Typeinfo.generate_annotations := true; rest
#       | "-I"            -> Beli.run rest
#       | _               -> usage ()
#
#     let rec process_options = function
#       | [] -> []
#       | arg :: rest ->
#           if is_option arg
#           then process_options (process_option arg rest)
#           else arg :: rest
#
# Distinctive properties of Beluga's hand-rolled flag parser:
#
#   * NO FLAG REGISTRATION TABLE — every flag is a literal string match in
#     a giant `match arg with ...` expression.  Adding a flag requires
#     editing main.ml and adding a case.  This is the absolute minimal CLI
#     parsing pattern — no library, no abstraction, no type safety beyond
#     OCaml's match exhaustiveness (which here is not exploited because
#     the wildcard `_` catches all unknowns).
#   * IMMEDIATE EFFECTFUL EXECUTION — each flag's handler runs INSIDE the
#     parser, mutating global compiler state via OCaml refs.  There is no
#     "parsed flags result" passed around — the only output of parsing is
#     the list of NON-FLAG positional arguments (the source files).
#   * STRING-EMBEDDED VALUES — `-s=debruijn` carries its value in the flag
#     string itself (joined by `=`), distinct from `-width 80` which uses a
#     separated value (consumed via `with_arg_for`).  The choice between
#     these two forms is per-flag and inconsistent within Beluga itself,
#     reflecting organic growth over time.
#   * SUBCOMMAND DISPATCH VIA `-I [beli-options]` — the `-I` flag triggers
#     Beluga's INTERACTIVE MODE (Beli REPL) by passing the remaining argv
#     to `Beli.run`, which has its OWN hand-rolled parser for `beli-options`
#     like `-emacs`.  This is sub-parsing without a subcommand object.
#   * IS_OPTION DETECTOR — flags are detected by checking if the FIRST
#     CHARACTER is `-` or `+`; this is what makes the tri-prefix convention
#     work uniformly with the parser.  POSIX-style `--long` flags also work
#     because `--long` starts with `-`, but Beluga's flag table doesn't
#     actually define any `--long` flags — all flags are single-prefix.
#   * NO HELP GENERATION FROM TABLE — the help text in `usage ()` is a
#     hand-typed string literal that must be kept in sync with the parser
#     by hand.  This is the cost of having no flag registration table.
#
# CONTRAST WITH OTHER OCaml CLI PARSERS
#
#   * OCaml stdlib `Arg`              — list of (name, action, doc) triples
#   * Cmdliner                        — applicative combinator library
#                                       (Daniel Bünzli, the most popular
#                                       OCaml CLI library)
#   * ocaml-cmdliner-stdlib (a-la-carte)
#   * Beluga's own `Optparser`        — applicative combinator (used by
#                                       harpoon, NOT by main beluga binary)
#   * Beluga's main.ml hand-rolled    — THIS — match expression dispatch
#   * Twelf's hand-rolled             — similar match dispatch in SML
#   * Agda's GHC hand-rolled          — System.Console.GetOpt + custom
#   * Coq's hand-rolled               — match expression in OCaml
#
# Beluga's beluga binary parser is closest in spirit to Twelf and Coq —
# all three are PROOF ASSISTANTS with mature codebases where the original
# author wrote a hand-rolled parser before any OCaml CLI library was
# popular, and the parser was never rewritten because it works.  The
# tri-prefix +/- convention is what distinguishes Beluga's specifically.
#
# -----------------------------------------------------------------------------
# BELUGA'S CLI SURFACE (verbatim from src/beluga/main.ml usage () function)
# -----------------------------------------------------------------------------
#
# USAGE:
#   beluga [options] file.(bel|cfg)
#
# Beluga loads either a single .bel signature file or a .cfg configuration
# file that lists multiple .bel files in dependency order.
#
# Options:
#   +d                    Turn all debugging printing on (interactive mode
#                         pipes to debug.out)
#   -s=debruijn           Print substitutions in deBruijn-ish style
#   +implicit             Print implicit arguments
#   +t                    Print timing information
#   +tfile                Print timing information to file "time.txt"
#   +printSubord          Print subordination relations (experimental)
#   -print                Turn printing OFF
#   +print                Turn printing ON
#   -width <nnn>          Set output width (default 86; minimum 40)
#   -logic                Turn off logic programming engine
#   +test                 Make output suitable for test harness (implies -print)
#   +html                 Generate an HTML page of the source Beluga code
#   +annot                Generate a .annot file for use in emacs
#   -I [beli-options]     Invoke interactive Beli mode (optional signature path)
#       beli-options:
#         -emacs          Mode for Emacs interaction (not recommended on CLI)
#
# =============================================================================

_beluga() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a flags subst_styles beli_opts

    flags=(
        '+d[turn on all debug printing]'
        '-s=debruijn[print substitutions in deBruijn-ish style]'
        '+implicit[print implicit arguments]'
        '+t[print timing information]'
        '+tfile[print timing information to time.txt]'
        '+printSubord[print subordination relations (experimental)]'
        '-print[turn printing OFF]'
        '+print[turn printing ON]'
        '-width[set output width (default 86; min 40)]:width:'
        '-logic[turn off logic programming engine]'
        '+test[output suitable for test harness (implies -print)]'
        '+html[generate HTML page of source Beluga code]'
        '+annot[generate .annot file for Emacs]'
        '-I[invoke interactive Beli mode]:beli-options or signature:->beli'
        '*:beluga signature or config:_files -g "*.(bel|cfg)"'
    )

    subst_styles=(
        'debruijn:de Bruijn-ish substitution style'
    )

    beli_opts=(
        '-emacs:Emacs interaction mode (not recommended on CLI)'
    )

    _arguments -s $flags && ret=0

    case $state in
        (beli)
            _alternative \
                'beli-opts:beli options:(($beli_opts))' \
                'beli-sig:beluga signature:_files -g "*.(bel|cfg)"' \
                && ret=0
            ;;
    esac

    return ret
}

_beluga "$@"
