#compdef diagram
# Documentation: https://man.archlinux.org/search?q=diagram
# Reference accessed: 2026-05-16

# esimov/diagram main.go (flag package); Homebrew: Formula/d/diagram.rb

local ret=1
_arguments -s \
  '-in+[source ASCII file]:file:_files' \
  '-out+[destination image]:file:_files' \
  '-font+[font file]:font:_files' \
  '-preview[show preview window]' && ret=0
return ret
