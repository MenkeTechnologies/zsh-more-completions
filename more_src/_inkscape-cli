#compdef inkscape
# Documentation: https://man.archlinux.org/search?q=inkscape
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(--app-id-tag)--app-id-tag=[app id tag]:t:' \
  '(--debug-info)--debug-info[debug info]' \
  '(--system-data-directory)--system-data-directory[show system data dir]' \
  '(--user-data-directory)--user-data-directory[show user data dir]' \
  '(-p --pipe)'{-p,--pipe}'[read SVG from stdin]' \
  '(-o --export-filename)'{-o+,--export-filename=}'[output file]:file:_files' \
  '(--export-overwrite)--export-overwrite[overwrite]' \
  '(--export-type)--export-type=[type csv]:list:(svg png ps eps pdf emf wmf xaml)' \
  '(--export-extension)--export-extension=[extension id]:e:' \
  '(-d --export-dpi)'{-d+,--export-dpi=}'[DPI]:n:' \
  '(-w --export-width)'{-w+,--export-width=}'[width px]:n:' \
  '(-h --export-height)'{-h+,--export-height=}'[height px]:n:' \
  '(--export-id)--export-id=[export only id]:id:' \
  '(--export-id-only)--export-id-only[only id]' \
  '(--export-area)--export-area=[area x0:y0:x1:y1]:a:' \
  '(--export-area-page)--export-area-page[area=page]' \
  '(--export-area-drawing)--export-area-drawing[area=drawing]' \
  '(--export-area-snap)--export-area-snap[snap area]' \
  '(--export-margin)--export-margin=[margin]:m:' \
  '(--export-background)--export-background=[bg color]:c:' \
  '(--export-background-opacity)--export-background-opacity=[bg opacity 0-1]:n:' \
  '(--export-png-color-mode)--export-png-color-mode=[png color mode]:m:(Gray_1 Gray_2 Gray_4 Gray_8 Gray_16 RGB_8 RGB_16 GrayAlpha_8 GrayAlpha_16 RGBA_8 RGBA_16)' \
  '(--export-png-use-dithering)--export-png-use-dithering=[dithering]:b:(true false)' \
  '(--export-text-to-path)--export-text-to-path[text to path]' \
  '(--export-ps-level)--export-ps-level=[PS level]:l:(2 3)' \
  '(--export-pdf-version)--export-pdf-version=[PDF version]:v:(1.4 1.5)' \
  '(--export-latex)--export-latex[also export LaTeX]' \
  '(--export-ignore-filters)--export-ignore-filters[ignore filters]' \
  '(--export-make-paths)--export-make-paths[make paths]' \
  '(--actions)*--actions=[actions semicolon list]:list:' \
  '(--actions-list)--actions-list[list actions]' \
  '(--query-id)--query-id=[query id]:id:' \
  '(--query-x)--query-x[print X]' \
  '(--query-y)--query-y[print Y]' \
  '(--query-width)--query-width[print width]' \
  '(--query-height)--query-height[print height]' \
  '(--query-all)--query-all[print all]' \
  '(--vacuum-defs)--vacuum-defs[vacuum defs]' \
  '(--shell)--shell[interactive shell]' \
  '(-z --no-gui)'{-z,--no-gui}'[no GUI]' \
  '(-g --with-gui)'{-g,--with-gui}'[with GUI]' \
  '(--display)--display=[X display]:d:' \
  '(--inkscape-file-deprecated)*: :_files -g "*.svg *.svgz *.ai *.cdr *.cmx *.dia *.emf *.fig *.gif *.jpg *.png *.pdf *.ps *.eps *.tif *.tiff *.wmf *.xpm"' && ret=0

return ret
