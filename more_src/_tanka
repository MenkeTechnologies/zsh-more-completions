#compdef tk tanka

# Zsh completion for tanka (tk) - Grafana Tanka, the Jsonnet-based Kubernetes config tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'apply:Apply the configuration to the cluster'
  'diff:Show differences between the configuration and the cluster'
  'show:Show the evaluated Jsonnet as YAML'
  'eval:Evaluate the Jsonnet and print the result'
  'export:Export the evaluated Jsonnet to files'
  'fmt:Format Jsonnet code'
  'init:Create the directory structure for a new project'
  'env:Manage environments'
  'status:Display the current status'
  'tool:Utilities for working with Tanka'
  'completion:Generate shell completion scripts'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'tanka command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      apply)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--force[skip the confirmation dialog]' \
          '--auto-approve[skip the confirmation dialog]' \
          '--dry-run=[dry run mode]:mode:(none server client)' \
          '--dangerous-allow-redirect[allow redirects]' \
          '(-n --name)'{-n,--name}'[selectively apply by name]:name' \
          '--ext-str=[set external variable from string]:key=value' \
          '--ext-code=[set external variable from code]:key=code' \
          '--tla-str=[set top-level argument from string]:key=value' \
          '--tla-code=[set top-level argument from code]:key=code' \
          '1:path:_directories' && ret=0
        ;;
      diff|show)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-n --name)'{-n,--name}'[selectively process by name]:name' \
          '--ext-str=[set external variable from string]:key=value' \
          '--ext-code=[set external variable from code]:key=code' \
          '--tla-str=[set top-level argument from string]:key=value' \
          '--tla-code=[set top-level argument from code]:key=code' \
          '1:path:_directories' && ret=0
        ;;
      eval)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--ext-str=[set external variable from string]:key=value' \
          '--ext-code=[set external variable from code]:key=code' \
          '--tla-str=[set top-level argument from string]:key=value' \
          '--tla-code=[set top-level argument from code]:key=code' \
          '1:path:_directories' && ret=0
        ;;
      export)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--format=[output format]:format' \
          '--ext-str=[set external variable from string]:key=value' \
          '--ext-code=[set external variable from code]:key=code' \
          '--tla-str=[set top-level argument from string]:key=value' \
          '--tla-code=[set top-level argument from code]:key=code' \
          '1:output directory:_directories' \
          '2:path:_directories' && ret=0
        ;;
      fmt)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--test[test if files are formatted]' \
          '*:file:_files' && ret=0
        ;;
      env)
        local -a env_cmds=(
          'add:Add a new environment'
          'list:List environments'
          'remove:Remove an environment'
          'set:Set environment parameters'
        )
        _describe -t env_cmds 'env command' env_cmds && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
