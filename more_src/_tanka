#compdef tk tanka
# Documentation: https://github.com/grafana/tanka/tree/main/cmd/tk
# Reference accessed: 2026-05-21
# Verified: upstream cmd/tk/{main,workflow}.go.

# Zsh completion for tanka (tk) - Grafana Tanka, the Jsonnet-based Kubernetes config tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'apply:apply the configuration to the cluster'
  'diff:show differences between the configuration and the cluster'
  'show:show the evaluated Jsonnet as YAML'
  'prune:delete resources removed from the configuration'
  'delete:delete the environment from the cluster'
  'env:manage environments'
  'status:display the current status'
  'export:export the evaluated Jsonnet to files'
  'eval:evaluate the Jsonnet and print the result'
  'fmt:format Jsonnet code'
  'lint:lint Jsonnet code'
  'init:create the directory structure for a new project'
  'tool:utilities for working with Tanka'
  'completion:generate shell completion scripts'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--log-level=[log level]:level:(disabled fatal error warn info debug trace)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'tanka command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      apply)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--validate[validate before apply]' \
          '--apply-strategy=[apply strategy]:strategy:' \
          '--diff-strategy=[diff strategy]:strategy:' \
          '1:path:_directories' && ret=0
        ;;
      diff)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--diff-strategy=[diff strategy]:strategy:' \
          '(-s --summarize)'{-s,--summarize}'[summarize the diff]' \
          '(-p --with-prune)'{-p,--with-prune}'[include prune in diff]' \
          '(-z --exit-zero)'{-z,--exit-zero}'[exit 0 even if differences exist]' \
          '--list-modified-envs[list modified envs]' \
          '1:path:_directories' && ret=0
        ;;
      show)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--dangerous-allow-redirect[allow redirects]' \
          '1:path:_directories' && ret=0
        ;;
      prune|delete)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:path:_directories' && ret=0
        ;;
      eval)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:path:_directories' && ret=0
        ;;
      export)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--format=[output format]:format:' \
          '1:output directory:_directories' \
          '2:path:_directories' && ret=0
        ;;
      fmt)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--test[test if files are formatted]' \
          '*:file:_files' && ret=0
        ;;
      lint)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:file:_files' && ret=0
        ;;
      env)
        local -a env_cmds=(
          'add:add a new environment'
          'list:list environments'
          'remove:remove an environment'
          'set:set environment parameters'
        )
        _describe -t env_cmds 'env command' env_cmds && ret=0
        ;;
      tool)
        local -a tool_cmds=(
          'jpath:print the jpath'
          'imports:list imports'
          'charts:vendor and export Helm charts'
        )
        _describe -t tool_cmds 'tool command' tool_cmds && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
