#compdef nixdoc
# Documentation: https://github.com/nix-community/nixdoc
# generate reference documentation for Nix library functions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --file)'{-f,--file}'[Nix file to process]:file:_files -g "*.nix"' \
  '(-c --category)'{-c,--category}'[name of the function category]:category:' \
  '(-d --description)'{-d,--description}'[description of the function category]:description:' \
  '(-p --prefix)'{-p,--prefix}'[prefix for the category]:prefix:' \
  '--anchor-prefix=[prefix for generated anchors]:prefix:' \
  '(-j --json-output)'{-j,--json-output}'[output JSON]' \
  '(-l --locs)'{-l,--locs}'[file containing location data as JSON]:file:_files -g "*.json"' && ret=0

return ret
