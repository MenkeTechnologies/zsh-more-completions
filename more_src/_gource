#compdef gource

# Zsh completion for gource - software version control visualization

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--start-date=[show entries from date]:date (YYYY-MM-DD):' \
  '--stop-date=[show entries until date]:date (YYYY-MM-DD):' \
  '--start-position=[begin at position in log]:position (0.0-1.0):' \
  '--stop-position=[stop at position in log]:position (0.0-1.0):' \
  '--stop-at-time=[stop after specified seconds]:seconds:' \
  '--stop-at-end[stop at end of the log]' \
  '--loop[loop back to the start of the log]' \
  '--loop-delay-seconds=[seconds to delay before looping]:seconds:' \
  '(-s --seconds-per-day)'{-s,--seconds-per-day}'=[speed in seconds per day]:seconds:' \
  '--realtime[realtime playback speed]' \
  '(-a --auto-skip-seconds)'{-a,--auto-skip-seconds}'=[auto skip to next entry if nothing for seconds]:seconds:' \
  '--file-idle-time=[time files remain idle before being removed]:seconds:' \
  '--file-idle-time-at-end=[time files remain idle at end]:seconds:' \
  '--key[show file extension key]' \
  '--title=[set a title]:title:' \
  '--font-file=[font file path]:file:_files' \
  '--font-scale=[scale of font]:scale:' \
  '--font-colour=[font colour in hex]:colour:' \
  '(-b --background-colour)'{-b,--background-colour}'=[background colour in hex]:colour:' \
  '--background-image=[set a background image]:file:_files' \
  '--logo=[logo image file]:file:_files' \
  '--logo-offset=[offset position of logo]:offset (XxY):' \
  '--date-format=[strftime format string for date]:format:' \
  '--log-format=[specify format of the log]:format:(git svn hg bzr cvs2cl cvs-exp apache custom)' \
  '(-c --camera-mode)'{-c,--camera-mode}'=[camera mode]:mode:(overview track)' \
  '--crop=[crop display]:crop:(vertical horizontal)' \
  '--multi-sampling[enable multi-sampling]' \
  '--no-vsync[disable vsync]' \
  '--bloom-multiplier=[adjust bloom effect]:multiplier:' \
  '--bloom-intensity=[intensity of bloom effect]:intensity:' \
  '--elasticity=[elasticity of nodes]:value:' \
  '--max-files=[max number of files or 0 for no limit]:number:' \
  '--max-file-lag=[max time files take to appear]:seconds:' \
  '--max-user-speed=[max speed users can travel per second]:speed:' \
  '--user-friction=[time users take to stop]:seconds:' \
  '--user-scale=[change scale of user avatars]:scale:' \
  '--user-image-dir=[directory containing user avatars]:directory:_directories' \
  '--default-user-image=[default user image file]:file:_files' \
  '--colour-images[colourize user images]' \
  '--highlight-dirs[highlight the names of all directories]' \
  '--highlight-colour=[font colour for highlighted names]:colour:' \
  '--highlight-all-users[highlight the names of all users]' \
  '*--hide=[hide elements]:element:(bloom date dirnames files filenames mouse progress root tree users usernames)' \
  '(-o --output-ppm-stream)'{-o,--output-ppm-stream}'=[output a PPM image stream to file]:file:_files' \
  '--output-framerate=[framerate of output]:fps:' \
  '--output-custom-log=[output a custom format log file]:file:_files' \
  '--viewport=[set viewport size]:size (WIDTHxHEIGHT):' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen mode]' \
  '--window-position=[initial window position]:position (XxY):' \
  '--frameless[frameless window]' \
  '--transparent[make the background transparent]' \
  '(-p --path)'{-p,--path}'=[path to a log file or a directory]:path:_files' \
  '*:log file or directory:_files'
