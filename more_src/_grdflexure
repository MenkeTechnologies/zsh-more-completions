#compdef grdflexure
# GMT supplements/potential — compute flexural deformation from topographic loads

local ret=1

_arguments -s \
  '-D+[densities mantle/load/infill/water]:densities:_default' \
  '-E+[elastic plate thickness or rigidity]:Te:_default' \
  '-G+[output grid filename]:file:_files' \
  '-A+[in-plane compressional/extensional forces]:forces:_default' \
  '-C+[Poisson ratio or Young modulus]:opts:_default' \
  '-F+[firmoviscous model parameters]:opts:_default' \
  '-H+[variable load density grid]:file:_files' \
  '-L+[write grid names and times to file]:file:_files' \
  '-M+[viscoelastic Maxwell time]:time:_default' \
  '-N+[FFT grid dimensions and detrending]:opts:_default' \
  '-Q[evaluate transfer functions only]' \
  '-S+[starved moat fraction 0-1]:frac:_default' \
  '-T+[time sequence]:times:_default' \
  '-W+[water depth]:depth:_default' \
  '-Z+[obs to undeformed surface distance]:dist:_default' \
  '*-V[verbose (stackable)]' \
  '-f+[I/O column data types]:types:_default' \
  '-h+[header records]:n:_default' \
  '*:input load grid:_files' \
  && ret=0

return ret
