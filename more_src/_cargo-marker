#compdef cargo-marker
# Documentation: https://github.com/rust-marker/marker
# Source: rust-marker/marker cargo-marker/src/cli.rs — cargo subcommand for Marker lint framework (Rust, clap).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _marker_cmds
_marker_cmds=(
    'check:run Marker on the current package'
    'setup:setup the rustc driver for Marker'
)

_arguments -C \
    '(-l --lints)*'{-l+,--lints=}'[specify lint crates to use]:crate:_default' \
    '--forward-rust-flags[forward current RUSTFLAGS during lint compilation]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[print version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'cargo-marker command' _marker_cmds && ret=0
        ;;
    args)
        case $line[1] in
            check)
                _arguments \
                    '(-l --lints)*'{-l+,--lints=}'[specify lint crates to use]:crate:_default' \
                    '--forward-rust-flags[forward current RUSTFLAGS during lint compilation]' \
                    '*::cargo args:_default' \
                    && ret=0
                ;;
            setup)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
