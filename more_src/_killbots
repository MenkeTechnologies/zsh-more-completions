#compdef killbots
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man6/killbots.6.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--display=+[X display]:disp:' && ret=0

return ret
