#compdef astscript-fits-view
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astscript_002dfits_002dview.html
# astscript-fits-view — view FITS images in DS9 and tables in TOPCAT based on contents

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra information in stdout]' \
  '--cite[show BibTeX citation for this program]' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input data]:HDU' \
  '(-g --ds9geometry)'{-g,--ds9geometry}'[DS9 window size (e.g. 800x1000)]:geometry' \
  '(-e --ds9extra)'{-e,--ds9extra}'[extra options to pass to DS9]:options' \
  '(-s --ds9scale)'{-s,--ds9scale}'[custom value for DS9 -scale option]:scale' \
  '(-c --ds9center)'{-c,--ds9center}'[center coordinates for DS9 window]:center' \
  '(-O --ds9mode)'{-O,--ds9mode}'[coordinate system for center interpretation]:mode:(img wcs)' \
  '(-m --ds9colorbarmulti)'{-m,--ds9colorbarmulti}'[separate color bars for each loaded image]' \
  '(-p --prefix)'{-p,--prefix}'[directory containing DS9 or TOPCAT executables]:dir:_files -/' \
  '*:input:_files' && ret=0

return ret
