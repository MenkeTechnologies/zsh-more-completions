#compdef git-fresh
# Documentation: https://man.archlinux.org/search?q=git-fresh
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/git-fresh — Prune stale local branches

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
