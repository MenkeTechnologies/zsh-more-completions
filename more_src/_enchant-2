#compdef enchant-2

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-a,--pipe}'[talk to another program through a pipe, like Ispell]' \
  {-l,--errors-only}'[list only the misspellings]' \
  {-d+,--dictionary=}'[use the given dictionary]:dictionary:' \
  {-p+,--pwl=}'[use the given personal word list]:file:_files' \
  {-L,--show-lines}'[display line numbers]' \
  '*:file:_files' && ret=0

return ret
