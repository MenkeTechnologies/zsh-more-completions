#compdef ldns-notify
# _ldns-notify — NLnet Labs ldns-notify (send a DNS NOTIFY packet to one or more secondary servers, optionally TSIG-signed)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-notify.c usage on tip; -z and at least one server are required.

_ldns-notify() {
    _arguments \
        '-h[show help]' \
        '-v[show version and exit]' \
        '-d[verbose debug output]' \
        '-z+[zone name (required)]:zone:' \
        '-I+[source address to query from]:ip:' \
        '-s+[SOA version to include in NOTIFY]:n:' \
        '-y+[TSIG name:key[:algo]]:tsigspec:' \
        '-p+[destination port]:port:' \
        '-r+[max retries]:n:' \
        '*:server:_hosts'
}

_ldns-notify "$@"
