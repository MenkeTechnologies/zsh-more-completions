_lemmy_server() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '--disable-scheduled-tasks[do not run scheduled tasks]' \
        '--disable-http-server[disable the HTTP server]' \
        '--disable-activity-sending[disable sending outgoing ActivityPub messages]' \
        '--federate-process-index=[index of this outgoing federation process (default 1)]:n:' \
        '--federate-process-count=[total outgoing federation process count (default 1)]:n:' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _ls_cmds=(
                'migration:do something with diesel schema migrations, then exit'
            )
            _describe -t commands 'lemmy_server command' _ls_cmds && ret=0
            ;;
        args)
            case $words[1] in
                migration)
                    if (( CURRENT == 2 )); then
                        local -a _mig=(
                            'run:run up.sql for pending migrations, oldest to newest'
                            'revert:run down.sql for non-pending migrations, newest to oldest'
                        )
                        _describe -t sub 'migration sub' _mig && ret=0
                    fi
                    _arguments \
                        '--all[stop after there are no remaining migrations]' \
                        '--number=[stop after N migrations (default 1)]:n:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_lemmy_server "$@"
