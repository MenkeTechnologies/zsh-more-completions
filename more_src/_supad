#compdef supad
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/windowing_sorting_muting/supad.c
# pad zero traces

local ret=1

_arguments -s -S \
  'min=[trace key start]:min' \
  'max=[trace key end]:max' \
  'key1=[panel key]:key' \
  'key2=[trace key]:key' \
  'key3=[flag key]:key' \
  'val3=[value assigned to padded traces]:val3' \
  'd=[trace key spacing]:d' \
  '*:file:_files' && ret=0


return ret
