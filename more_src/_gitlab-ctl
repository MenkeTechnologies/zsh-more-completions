#compdef gitlab-ctl
# Documentation: https://docs.gitlab.com/omnibus/maintenance/
# GitLab Omnibus service control command

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(start stop restart restart-except status show-config check-config hup tail deploy-page)' \
  '*::arg:_default' && ret=0

return ret
