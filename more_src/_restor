#compdef restor
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/restor.html
# MIRIAD: restore clean components to make a CLEAN map

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'model=[deconvolved model cube]:model:_files' \
  'beam=[input dirty beam]:beam:_files' \
  'map=[input dirty cube]:map:_files' \
  'mode=[operation type]:mode:(clean residual convolve dirty)' \
  'fwhm=[restoring beam size in arcsec]:fwhm:' \
  'pa=[restoring beam position angle in degrees]:pa:' \
  'options=[mfs]:options:(mfs)' \
  'out=[output restored image]:out:_files' \
  '*:image:_files' && ret=0

return ret
