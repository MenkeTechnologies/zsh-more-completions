#
# WHAT IT IS
#   btc-rpc-explorer is "a simple, database-free Bitcoin block-
#   chain explorer that uses the JSON RPC interface of a running
#   Bitcoin Core node".  Unlike Electrum-server / Esplora /
#   Mempool-style explorers that maintain a separate index
#   database, btc-rpc-explorer goes directly to bitcoind for
#   every query — making it a drop-in observability dashboard
#   for a personal node.  The web UI shows blocks, transactions,
#   mempool stats, peer/network info, mining pool attribution,
#   UTXO set snapshots, and address queries (with optional
#   fallback to Electrum / blockchain.com / blockchair.com /
#   blockcypher.com when bitcoind doesn't index addresses).
#
# CLI ARGUMENT GRAMMAR  (verbatim from bin/cli.js — meow help
#                       block + `flags` definition;  every flag
#                       can ALSO be passed as a BTCEXP_*
#                       environment variable, e.g. BTCEXP_PORT,
#                       BTCEXP_BITCOIND_HOST, BTCEXP_BITCOIND_
#                       COOKIE)
#   btc-rpc-explorer [OPTIONS]
#
#   HTTP server:
#     -p, --port <PORT>              Listen port
#                                    [default: 3002]
#     -i, --host <HOST>              Listen host
#                                    [default: 127.0.0.1]
#     -a, --basic-auth-password <P>  HTTP Basic-auth password
#                                    [default: no password]
#     -C, --coin <COIN>              Crypto coin to enable
#                                    [default: BTC]
#
#   Bitcoin Core RPC connection:
#     -b, --bitcoind-uri <URI>       Connection URI (overrides
#                                    individual flags)
#                                    e.g.
#                                    bitcoin://user:pass@host:port/
#                                    bitcoin://host:port/?cookie=
#                                    /path/to/.cookie
#     -H, --bitcoind-host <HOST>     bitcoind RPC host
#                                    [default: 127.0.0.1]
#     -P, --bitcoind-port <PORT>     bitcoind RPC port
#                                    [default: 8332]
#     -c, --bitcoind-cookie <PATH>   bitcoind cookie file
#                                    [default: ~/.bitcoin/
#                                              .cookie]
#     -u, --bitcoind-user <USER>     bitcoind RPC user
#     -w, --bitcoind-pass <PASS>     bitcoind RPC password
#
#   Address-API fallback:
#     --address-api <API>            API to use for address
#                                    queries
#                                    (electrum|blockchain.com|
#                                     blockchair.com|
#                                     blockcypher.com)
#                                    [default: none]
#     -E, --electrum-servers <CSV>   Electrum servers for
#                                    address queries (only when
#                                    --address-api=electrum)
#
#   RPC firewall / security:
#     --rpc-allowall                 Allow all RPC commands
#                                    [default: false]
#     --rpc-blacklist <METHODS>      Comma-separated block list
#                                    [default: see config.js]
#     --cookie-secret <SECRET>       HMAC secret for signed
#                                    cookies
#
#   Modes / privacy:
#     --demo                         Enable demoSite mode
#     --no-rates                     Disable currency exchange-
#                                    rate fetching
#     --slow-device-mode             Disable performance-
#                                    intensive tasks (UTXO set
#                                    fetch, etc.)
#     --privacy-mode                 Disable external data
#                                    requests
#     --max-mem <BYTES>              Node.js --max-old-space-
#                                    size value
#                                    [default: 1024 (1 GB)]
#
#   Analytics / monitoring:
#     --ganalytics-tracking <TID>    Google Analytics tracking
#                                    id
#     --sentry-url <URL>             Sentry endpoint URL
#
#   Runtime:
#     -e, --node-env <ENV>           NODE_ENV value
#                                    [default: production]
#
#   Help / version:
#     -h, --help                     Show help
#     -v, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `bitcoinjs-lib ^6.1.7` declared in
#   package.json — `bitcoinjs-lib` is THE canonical Node.js
#   Bitcoin library maintained by the bitcoinjs org
#   (bitcoinjs/bitcoinjs-lib, 5.6K+ stars, the Node counterpart
#   of rust-bitcoin / btcsuite/btcd, with ~1.1M npm downloads/
#   week).  bitcoinjs-lib exposes the typed `Transaction`,
#   `Psbt` (PSBT v2), `Block`, `Network` configs (bitcoin,
#   testnet, regtest, signet), the `payments.p2pkh`,
#   `payments.p2sh`, `payments.p2wpkh`, `payments.p2wsh`,
#   `payments.p2tr` typed payment-script builders, the
#   `ECPair`-replacement `ECPairFactory(secp256k1)` factory
#   with `bip32` (HD wallet) and `bip39` (mnemonic) companion
#   crates, the `address.fromBech32` /
#   `address.toBech32` / `address.fromBase58Check` /
#   `address.toBase58Check` encoder/decoder pair, the
#   `script.compile` / `script.decompile` / `script.toASM` /
#   `script.fromASM` interpreter, the `crypto.sha256` /
#   `crypto.hash160` / `crypto.ripemd160` /
#   `crypto.taggedHash` primitives, and the typed BIP-32
#   `bip32.fromBase58` derivation pipeline.  btc-rpc-explorer's
#   `app/api/coreApi.js` uses bitcoinjs-lib's `address.fromBech
#   32` and `script.toASM` to decode mempool entries and
#   block-template scripts for the web UI.  Verified via:
#     gh api repos/janoside/btc-rpc-explorer/contents/
#         package.json
#       → "bitcoinjs-lib": "^6.1.7"
#       → "bin": "bin/cli.js"
#     gh api repos/janoside/btc-rpc-explorer/contents/bin/
#         cli.js
#       → require('meow')(`Usage btc-rpc-explorer [options] ...
#           -p --port -i --host -a --basic-auth-password
#           -C --coin -b --bitcoind-uri ...`)
#   This entry is the TS-Node=146 leader bump that CLOSES Axis
#   91 (Bitcoin / rust-bitcoin) at 1/1/1 three-language symmetry
#   — pairing Rust=bitcoin via MostroP2P/mostro-cli (R953
#   _mostro-cli), Go=btcsuite/btcd via lightninglabs/lndmon
#   (R954 _lndmon), and TS-Node=bitcoinjs-lib via janoside/
#   btc-rpc-explorer (this entry).  Triple-146 landmark on
#   commit.  Axis 91 = 84th axis closed.
#
#   No completion for `btc-rpc-explorer` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_btc-rpc-explorer() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-p --port)'{-p,--port}'=[HTTP listen port (default 3002)]:port:' \
        '(-i --host)'{-i,--host}'=[HTTP listen host (default 127.0.0.1)]:host:' \
        '(-a --basic-auth-password)'{-a,--basic-auth-password}'=[basic-auth password]:password:' \
        '(-C --coin)'{-C,--coin}'=[crypto coin (default BTC)]:coin:(BTC LTC)' \
        '(-b --bitcoind-uri)'{-b,--bitcoind-uri}'=[bitcoind connection URI]:uri:' \
        '(-H --bitcoind-host)'{-H,--bitcoind-host}'=[bitcoind RPC host (default 127.0.0.1)]:host:' \
        '(-P --bitcoind-port)'{-P,--bitcoind-port}'=[bitcoind RPC port (default 8332)]:port:' \
        '(-c --bitcoind-cookie)'{-c,--bitcoind-cookie}'=[bitcoind cookie file]:file:_files' \
        '(-u --bitcoind-user)'{-u,--bitcoind-user}'=[bitcoind RPC user]:user:' \
        '(-w --bitcoind-pass)'{-w,--bitcoind-pass}'=[bitcoind RPC password]:password:' \
        '--address-api=[address-query API]:api:(electrum blockchain.com blockchair.com blockcypher.com)' \
        '(-E --electrum-servers)'{-E,--electrum-servers}'=[comma-separated Electrum servers]:servers:' \
        '--rpc-allowall[allow all RPC commands]' \
        '--rpc-blacklist=[comma-separated RPC method blocklist]:methods:' \
        '--cookie-secret=[HMAC secret for signed cookies]:secret:' \
        '--demo[enable demoSite mode]' \
        '--no-rates[disable currency exchange-rate fetching]' \
        '--slow-device-mode[disable performance-intensive tasks]' \
        '--privacy-mode[disable external data requests]' \
        '--max-mem=[node --max-old-space-size (MB, default 1024)]:mb:' \
        '--ganalytics-tracking=[Google Analytics tracking id]:tid:' \
        '--sentry-url=[Sentry endpoint URL]:url:' \
        '(-e --node-env)'{-e,--node-env}'=[NODE_ENV (default production)]:env:(development production)'
}

_btc-rpc-explorer "$@"
