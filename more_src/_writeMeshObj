#compdef writeMeshObj
# For mesh debugging: writes mesh as separate OBJ files

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-patchFaces[write patch faces edges]' \
  '-patchEdges[write patch boundary edges]' \
  '-cell+[write points for the specified cell]:int:' \
  '-face+[write specified face]:int:' \
  '-point+[write specified point]:int:' \
  '-cellSet+[write points for specified cellSet]:name:' \
  '-faceSet+[write points for specified faceSet]:name:' \
  '-region+[specify alternative mesh region]:region:' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' && ret=0

return ret
