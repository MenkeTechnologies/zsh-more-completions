#compdef gitsub
# Documentation: https://man.archlinux.org/search?q=gitsub
# Reference accessed: 2026-05-16
# Source: https://github.com/5nik7/gitsub/blob/da821d2211ab26c892bce13a828b8bc486b9537c/gitsub
# Repository: 5nik7/gitsub (gitsub)
#!/usr/bin/env bash

set -u

canon_dir() {
	(
		cd "$1" 2>/dev/null && pwd -P
	)
}

usage() {
	cat <<'EOF'
Usage: gitsub [options] [path]

Check whether the current directory, or an optional provided path, is inside a
Git repository that is a submodule of one or more parent Git repositories
located higher on the same filesystem path.

This version walks the full upward path, discovers every Git repository root
on that path, and verifies adjacent parent/child submodule relationships.
That makes nested submodule chains work correctly.

Arguments:
  path
      Optional path to inspect. Defaults to the current working directory.

Options:
  -q, --quiet
      Print nothing; use exit status only

  -e, --exists-only
      Same as --quiet; useful for scripting

  --status
      Print explicit status text:
        submodule
        not-submodule

  -r, --raw
      Print raw absolute paths instead of replacing $HOME with ~

  -p, --parent
      Print the immediate parent repository root

  -o, --outermost, --toplevel
      Print the outermost parent repository root in the verified submodule chain

  --chain
      Print the verified repository chain from outermost parent to current repo,
      one repository root per line

  -a, --array
      Print the verified repository chain as a shell array literal

  --chain-paths
      Print the verified relative submodule path for each chain hop,
      one path per line

  -s, --path
      Print the submodule path relative to the reference selected by
      --relative-to (default: parent)

  --path-parent
      Print the path relative to the immediate parent repository

  -O, --path-outermost
      Print the path relative to the outermost parent repository

  --relative-to parent|outermost|current
      Select how --path and %S are resolved (default: parent)

  -c, --current
      Print the current submodule repository root

  --parent-dirname
      Print the dirname of the outermost parent repository root

  --parent-basename
      Print the basename of the outermost parent repository root

  --submodule-prefix
      Print the path from the outermost parent repository root to, but not
      including, the current submodule repository root basename

  --submodule-basename
      Print the basename of the current submodule repository root

  --cwd-prefix
      Print the path from the current submodule repository root to the
      inspected path (equivalent to git rev-parse --show-prefix with trailing
      slash removed)

  -j, --json
      Print JSON output

  -f, --format FORMAT
      Print custom formatted output using tokens:

        %P  immediate parent repository root
        %O  outermost parent repository root
        %S  path relative to reference selected by --relative-to
        %T  path relative to outermost parent repository
        %C  current submodule repository root
        %D  dirname of outermost parent repository root
        %M  basename of outermost parent repository root
        %G  path from outermost parent root to, but not including,
            the submodule root basename
        %B  basename of current submodule repository root
        %W  path from current submodule root to inspected path
        %L  verified repo chain length
        %%  literal percent sign

  --completion bash|zsh
      Print completion script for the selected shell

  -h, --help
      Show this help message

Default output:
  yes   if the current repo is part of a verified submodule chain
  no    otherwise

Exit codes:
  0  current repo is part of a verified submodule chain
  1  current repo is not part of a verified submodule chain
  2  not inside a git repository / usage error
EOF
}

print_bash_completion() {
	cat <<'EOF'
_gitsub() {
	local cur prev
	cur="${COMP_WORDS[COMP_CWORD]}"
	prev="${COMP_WORDS[COMP_CWORD-1]}"

	local opts=(
		-q --quiet
		-e --exists-only
		--status
		-r --raw
		-p --parent
		-o --outermost
		--toplevel
		--chain
		-a --array
		--chain-paths
		-s --path
		--path-parent
		-O --path-outermost
		--relative-to
		-c --current
		--parent-dirname
		--parent-basename
		--submodule-prefix
		--submodule-basename
		--cwd-prefix
		-j --json
		-f --format
		--completion
		-h --help
	)

	case "$prev" in
		--relative-to)
			COMPREPLY=( $(compgen -W "parent outermost current" -- "$cur") )
			return 0
			;;
		--completion)
			COMPREPLY=( $(compgen -W "bash zsh" -- "$cur") )
			return 0
			;;
		-f|--format)
			COMPREPLY=()
			return 0
			;;
	esac

	if [[ "$cur" == -* ]]; then
		COMPREPLY=( $(compgen -W "${opts[*]}" -- "$cur") )
		return 0
	fi

	COMPREPLY=()
}

complete -F _gitsub gitsub
EOF
}

print_zsh_completion() {
	cat <<'EOF'

_gitsub() {
	local -a opts
	opts=(
		'-q[Print nothing; use exit status only]'
		'--quiet[Print nothing; use exit status only]'
		'-e[Same as --quiet; useful for scripting]'
		'--exists-only[Same as --quiet; useful for scripting]'
		'--status[Print explicit status text]'
		'-r[Print raw absolute paths instead of replacing $HOME with ~]'
		'--raw[Print raw absolute paths instead of replacing $HOME with ~]'
		'-p[Print the immediate parent repository root]'
		'--parent[Print the immediate parent repository root]'
		'-o[Print the outermost parent repository root]'
		'--outermost[Print the outermost parent repository root]'
		'--toplevel[Alias for --outermost]'
		'--chain[Print verified repository chain]'
		'-a[Print verified repository chain as a shell array literal]'
		'--array[Print verified repository chain as a shell array literal]'
		'--chain-paths[Print verified chain hop paths]'
		'-s[Print path according to --relative-to]'
		'--path[Print path according to --relative-to]'
		'--path-parent[Print the path relative to the immediate parent repository]'
		'-O[Print the path relative to the outermost parent repository]'
		'--path-outermost[Print the path relative to the outermost parent repository]'
		'--relative-to[Select how --path and %S are resolved]:reference:(parent outermost current)'
		'-c[Print the current submodule repository root]'
		'--current[Print the current submodule repository root]'
		'--parent-dirname[Print dirname of outermost parent repository root]'
		'--parent-basename[Print basename of outermost parent repository root]'
		'--submodule-prefix[Print path to but not including submodule basename]'
		'--submodule-basename[Print basename of current submodule repository root]'
		'--cwd-prefix[Print path from submodule root to inspected path]'
		'-j[Print JSON output]'
		'--json[Print JSON output]'
		'-f[Print custom formatted output]:format string: '
		'--format[Print custom formatted output]:format string: '
		'--completion[Print completion script]:shell:(bash zsh)'
		'-h[Show help message]'
		'--help[Show help message]'
		'*:path:_files'
	)

	_arguments -s $opts
