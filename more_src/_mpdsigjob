#compdef mpdsigjob
# Documentation: https://man.archlinux.org/search?q=mpdsigjob
# Reference accessed: 2026-05-16

# mpdsigjob: signal all processes in an MPD job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '-v[verbose]' \
  '-f[hosts file]:file:_files' \
  '*::mpdsigjob args:_files' && ret=0
return ret
