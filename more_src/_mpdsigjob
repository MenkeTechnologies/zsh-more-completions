#compdef mpdsigjob
# Documentation: https://www.mpich.org/static/downloads/1.2.1p1/mpich2-1.2.1p1-README.txt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. MPICH2 MPD daemon tool
# (legacy, replaced by Hydra). Syntax: mpdsigjob sigtype job_id.
# Removed from prior file: fabricated -V/-v/-f flags (do not exist).

# mpdsigjob: signal all processes of an MPD job (legacy MPICH MPD)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[print usage information]' \
  '1:signal:_signals -s' \
  '2:job_id:' && ret=0
return ret
