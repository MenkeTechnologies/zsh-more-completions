#compdef djvumake
# Documentation: https://manpages.debian.org/bookworm/djvulibre-bin/djvumake.1.en.html
# Reference accessed: 2026-05-30
# djvumake — Yann Le Cun & Léon Bottou's DjVu chunk assembler. Builds a DjVu
# file from raw chunk fragments (INFO, Sjbz, BG44, FGbz, etc). Each argument
# after the output filename is a `CHUNKID=value` pair, NOT a traditional flag.

local curcontext="$curcontext" state line ret=1

local -a _chunks
_chunks=(
  'INFO=:initial info chunk (W,H,DPI; default 300 dpi)'
  'Sjbz=:JB2 foreground mask chunk (from JB2 or DjVu)'
  'Smmr=:MMR/G4 foreground mask chunk'
  'BG44=:IW44 background chunk(s) (file[:N] for N chunks)'
  'BGjp=:JPEG-encoded background chunk'
  'BG2k=:JPEG-2000 background chunk'
  'FGbz=:foreground colour chunk (file or {#color[:x,y,w,h]})'
  'FG44=:IW44 foreground colour chunk'
  'FGjp=:JPEG foreground colour chunk'
  'FG2k=:JPEG-2000 foreground colour chunk'
  'INCL=:DjVu3 include chunk (multipage)'
  'Djbz=:JB2 shape-dictionary chunk'
  'PPM=:emit IW44 BG + FG colour chunks from a PPM'
)

_arguments -s -S \
  '(- *)-h[show help]' \
  '1:output djvu file:_files -g "*.djvu"' \
  '*:chunk spec (CHUNKID=value):->chunk' \
  && ret=0

case $state in
  chunk)
    _describe -t chunks 'DjVu chunk id' _chunks -S '' && ret=0
    ;;
esac

return ret
