#compdef virt-pki-query virt-pki-validate
# Documentation: https://manpages.debian.org/bookworm/libvirt-clients/virt-pki-validate.1.en.html
# Reference accessed: 2026-05-16
# Verified: no `virt-pki-query` binary exists in libvirt-clients. The
# correct upstream tool is `virt-pki-validate`; this completion appears
# to be a misnomer. Both names are accepted via #compdef so existing
# `virt-pki-query` invocations still complete.
# Removed from prior file: bogus man.archlinux.org search URL.

# virt-pki-validate: validate libvirt PKI configuration on a host
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0
return ret
