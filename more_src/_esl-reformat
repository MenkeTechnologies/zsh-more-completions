#compdef esl-reformat

# Easel esl-reformat: read sequence or alignment file, write in new format
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-d[describe sequences only]' \
  '-l[change to lowercase]' \
  '-u[change to uppercase]' \
  '-n[number all residues 1..L]' \
  '-o[output file]:file:_files' \
  '-r[reverse-complement DNA/RNA]' \
  '-x[gap chars to use in output]:chars:' \
  '--small[smaller memory output mode]' \
  '--informat[input format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--gapsym[gap character to use in output]:char:' \
  '--rna[treat as RNA]' \
  '--dna[treat as DNA]' \
  '--keeprf[keep #=GC RF when reformatting]' \
  '--mingap[strip all-gap columns]' \
  '--ignore[characters to ignore in input]:chars:' \
  '--acceptx[characters to accept as X]:chars:' \
  '--rename[rename each sequence with prefix]:prefix:' \
  '*:output format and input file:_files' && ret=0
return ret
