#compdef ranger
# _ranger — ranger (curses-based text file manager with miller columns and vi-style bindings; -d selects a dir, --cmd executes a ranger command at startup, --selectfile cursors over a file, --copy-config copies default configs, --choosefile/--choosefiles/--choosedir prints picks to a file and exits)
# upstream: https://github.com/ranger/ranger
# Flags from ranger ranger/__main__.py on tip.

_ranger() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-d+[start at directory]:dir:_files -/' \
        '--cmd=*[ranger command at startup]:command:' \
        '*--selectfile=*[cursor over file]:file:_files' \
        '--copy-config=*[copy config files]:cfg:(all rc commands commands_full rifle scope)' \
        '--list-unused-keys[list unused keys]' \
        '--list-tagged-files=*[tag mark]:tag:' \
        '--choosefile=*[write chosen file path]:file:_files' \
        '--choosefiles=*[write chosen files paths]:file:_files' \
        '--choosedir=*[write chosen dir path]:file:_files' \
        '--show-only-dirs[only dirs visible]' \
        '--cachedir=*[cache dir]:dir:_files -/' \
        '--profile[profile startup]' \
        '--debug[debug]' \
        '--clean[do not load user config]' \
        '*:start path:_files'
}

_ranger "$@"
