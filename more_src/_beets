#compdef beet beets
# Documentation: https://beets.readthedocs.io/en/stable/reference/cli.html
# Reference accessed: 2026-05-16
# Verified: upstream beets CLI reference (global flags + subcommand
# tables).
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'import:add new music to library'
  'list:query the library (alias ls)'
  'ls:query the library'
  'remove:remove items from library (alias rm)'
  'rm:remove items from library'
  'modify:change items metadata (alias mod)'
  'mod:change items metadata'
  'move:move or copy items (alias mv)'
  'mv:move or copy items'
  'update:rescan files for tag changes'
  'write:write tags from db to files'
  'stats:show library statistics'
  'fields:list all available fields'
  'config:show or edit configuration'
  'version:show beets version'
  'help:show help on subcommand'
)

_arguments -C \
  '-l[library db file]:db:_files' \
  '-d[library root directory]:dir:_files -/' \
  '-v[verbose]' \
  '-c[config file overlay]:file:_files' \
  '-p[plugins to enable]:plugins:' \
  '-P[plugins to disable]:plugins:' \
  '(- *)-h[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'beets subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (import)
        _arguments \
          '-m[move files]' \
          '-C[do not copy]' \
          '-W[do not write tags]' \
          '-A[no autotag]' \
          '-l[log file]:file:_files' \
          '-q[quiet]' \
          '-p[resume]' \
          '-P[no resume]' \
          '-i[incremental]' \
          '-s[singletons]' \
          '-t[timid]' \
          '--flat[treat tree as one album]' \
          '--group-albums[group by album]' \
          '--pretend[dry run]' \
          '--from-scratch[discard prior tags]' \
          '*--set=[FIELD=VAL]:set:' \
          '-L[reimport query]:query:' \
          '*:path:_files' && ret=0
        ;;
      (list|ls)
        _arguments \
          '-a[albums]' \
          '-p[show paths]' \
          '-f[format]:format:' && ret=0
        ;;
      (remove|rm)
        _arguments \
          '-a[albums]' \
          '-d[delete files]' \
          '-f[force]' && ret=0
        ;;
      (modify|mod)
        _arguments \
          '-a[albums]' \
          '-I[no inherit]' \
          '--noinherit[no inherit]' \
          '-M[no move]' \
          '-w[write tags]' \
          '-W[no write tags]' \
          '-y[yes]' && ret=0
        ;;
      (move|mv)
        _arguments \
          '-c[copy]' \
          '-a[albums]' \
          '-e[export]' \
          '-d[destination]:dir:_files -/' \
          '-p[pretend]' \
          '-t[timid]' && ret=0
        ;;
      (update)
        _arguments \
          '*-F[exclude field]:field:' \
          '*-e[fields]:field:' \
          '-M[no move]' \
          '-p[pretend]' && ret=0
        ;;
      (write)
        _arguments \
          '-p[preview]' \
          '-f[force]' && ret=0
        ;;
      (stats)
        _arguments \
          '-e[exact]' \
          '--exact[exact]' && ret=0
        ;;
      (config)
        _arguments \
          '-p[show path]' \
          '--path[show path]' \
          '-d[show defaults]' \
          '--default[show defaults]' \
          '-c[show clear of secrets]' \
          '--clear[clear secrets]' \
          '-e[edit]' \
          '--edit[edit]' && ret=0
        ;;
    esac
    ;;
esac

return ret
