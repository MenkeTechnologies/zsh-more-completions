#compdef join-cli
# _join-cli — GNU coreutils join join lines of two files on common field CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_join-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[which file]:n:(1 2)' \
        '-e+[empty replacement]:str:' \
        '-i[ignore case]' \
        '--ignore-case[ignore case]' \
        '-j+[field]:n:' \
        '-o+[output format]:str:' \
        '-t+[separator]:str:' \
        '-v+[only print non-pairable lines from file n]:n:(1 2)' \
        '-1+[field of file 1]:n:' \
        '-2+[field of file 2]:n:' \
        '--check-order[check input is sorted]' \
        '--nocheck-order[no check input sorted]' \
        '--header[treat first line as header]' \
        '-z[NUL terminator]' \
        '--zero-terminated[NUL terminator]' \
        '*:file1 file2:_files'
}

_join-cli "$@"
