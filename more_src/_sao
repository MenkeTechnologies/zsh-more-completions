#compdef sao
# Documentation: https://github.com/saojs/sao/blob/master/src/cli-engine.ts
# SAO - framework-agnostic project scaffolding tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display CLI usages]' \
  '--version[display SAO version]' \
  '--npm-client=[use a specific npm client]:client:(yarn npm pnpm)' \
  '(-u --update)'{-u,--update}'[update cached generator]' \
  '(-c --clone)'{-c,--clone}'[clone repository instead of archive download]' \
  '(-y --yes)'{-y,--yes}'[use the default value for all prompts]' \
  '--registry=[use a custom registry for package manager]:registry:' \
  '--debug[display debug logs]' \
  '1:template:' \
  '2:out-dir:_files -/' && ret=0

return ret
