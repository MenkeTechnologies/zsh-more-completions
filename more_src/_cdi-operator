#compdef cdi-operator
# _cdi-operator — CDI top-level operator that reconciles the CDI custom resource and deploys CDI components
# upstream: https://github.com/kubevirt/containerized-data-importer
# Flags from cmd/cdi-operator/operator.go on tip; config primarily via env vars (DEPLOY_CLUSTER_RESOURCES, OPERATOR_VERSION, CONTROLLER_IMAGE, IMPORTER_IMAGE, CLONER_IMAGE, APISERVER_IMAGE, UPLOAD_PROXY_IMAGE, UPLOAD_SERVER_IMAGE, VERBOSITY, PULL_POLICY, MONITORING_NAMESPACE).

_cdi-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[log to stderr and files]' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files'
}

_cdi-operator "$@"
