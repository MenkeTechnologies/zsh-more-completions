#compdef pipx-cli
# _pipx-cli — pipx isolated Python tool installer CLI alias (PyPA, Python); argparse
# upstream: https://github.com/pypa/pipx

_pipx-cli() {
    local -a sub=(
        'install:install a package as a CLI tool'
        'install-all:install all from spec'
        'uninject:remove injected dependency'
        'inject:inject deps into a tool venv'
        'pin:pin tool to current version'
        'unpin:unpin tool'
        'upgrade:upgrade a tool'
        'upgrade-all:upgrade all tools'
        'upgrade-shared:upgrade shared pipx libs'
        'uninstall:uninstall a tool'
        'uninstall-all:uninstall all tools'
        'reinstall:reinstall a tool'
        'reinstall-all:reinstall all tools'
        'list:list installed tools'
        'interpreter:manage interpreter'
        'run:run a tool from a temp env'
        'runpip:run pip in tool venv'
        'ensurepath:ensure PATH set'
        'environment:print env info'
        'completions:show completion instructions'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--global[global install]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pipx subcommand' sub ;;
        args)
            case $words[1] in
                install|install-all) _arguments \
                    '--include-deps[include dep CLIs]' \
                    '--force[force reinstall]' \
                    '-f[force reinstall]' \
                    '--editable[editable]' \
                    '-e[editable]' \
                    '--system-site-packages[system site packages]' \
                    '--index-url=+[index url]:url:_urls' \
                    '-i+[index url]:url:_urls' \
                    '--pip-args=+[pip args]:str:' \
                    '--suffix=+[suffix]:str:' \
                    '--python=+[python]:str:' \
                    '--preinstall=+[preinstall]:str:' \
                    '--global[global install]' \
                    '*:package:' ;;
                inject|uninject) _arguments \
                    '1:tool-name:' \
                    '*:dep:' ;;
                upgrade|uninstall|reinstall|pin|unpin) _arguments \
                    '*:tool:' ;;
                upgrade-all|uninstall-all|reinstall-all|list|environment|ensurepath|completions|upgrade-shared) _arguments '*:arg:' ;;
                run) _arguments \
                    '--no-cache[no cache]' \
                    '--python=+[python]:str:' \
                    '--spec=+[spec]:str:' \
                    '--pip-args=+[pip args]:str:' \
                    '--path[treat first arg as path]' \
                    '*:arg:' ;;
                runpip) _arguments \
                    '1:tool:' \
                    '*:pip-arg:' ;;
                interpreter) _arguments \
                    '1:cmd:(list prune upgrade)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_pipx-cli "$@"
