#compdef proton-server
# Documentation: https://docs.timeplus.com/proton
# Timeplus Proton server (ClickHouse server fork)

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-C+,--config-file=}'[server config file]:file:_files -g "*.(xml|yaml|yml)"' \
  '--pid-file=[pid file path]:file:_files' \
  '--daemon[run in daemon mode]' \
  '--logger.level=[log level]:level:(trace debug information warning error fatal none)' \
  '--logger.log=[log file]:file:_files' \
  '--logger.errorlog=[error log file]:file:_files' \
  '--logger.console[log to console]' \
  '--http_port=[HTTP port]:port' \
  '--tcp_port=[TCP port]:port' \
  '--listen_host=[listen address]:host' \
  '--path=[data path]:dir:_files -/' \
  '--tmp_path=[temp path]:dir:_files -/' && ret=0

return ret
