#compdef vmauth

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-auth.config=[auth config file]:file:_files -g "*.(yaml|yml)"' \
  '-httpListenAddr=[HTTP listen addr]:addr:' \
  '-httpInternalListenAddr=[internal HTTP listen addr]:addr:' \
  '-tls[enable TLS]' \
  '-tlsCertFile=[TLS cert]:file:_files' \
  '-tlsKeyFile=[TLS key]:file:_files' \
  '-backend.tlsInsecureSkipVerify[skip backend TLS verify]' \
  '-backend.tlsCAFile=[backend TLS CA]:file:_files' \
  '-backend.tlsCertFile=[backend TLS cert]:file:_files' \
  '-backend.tlsKeyFile=[backend TLS key]:file:_files' \
  '-backend.tlsServerName=[backend TLS server name]:name:' \
  '-reloadAuthKey=[reload auth key]:key:' \
  '-flagsAuthKey=[flags auth key]:key:' \
  '-metricsAuthKey=[metrics auth key]:key:' \
  '-pprofAuthKey=[pprof auth key]:key:' \
  '-httpAuthHeader=[HTTP auth header]:header:' \
  '-mtls[enable mTLS]' \
  '-mtlsCAFile=[mTLS CA file]:file:_files' \
  '-loadBalancingPolicy=[load balancing policy]:policy:(least_loaded round_robin first_available)' \
  '-discoverBackendIPs[discover backend IPs]' \
  '-mergeQueryArgs[merge query args]' \
  '-maxConcurrentRequests=[max concurrent requests]:n:' \
  '-maxConcurrentPerUserRequests=[max concurrent requests per user]:n:' \
  '-maxQueueDuration=[max queue duration]:duration:' \
  '-requestBufferSize=[request buffer size]:size:' \
  '-retryStatusCodes=[retry status codes]:codes:' \
  '-configCheckInterval=[config check interval]:duration:' \
  '-httpRealIPHeader=[real IP header]:header:' \
  '-loggerLevel=[log level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '-loggerFormat=[log format]:format:(default json)'
