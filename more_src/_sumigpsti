#compdef sumigpsti
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/migration_inversion/sumigpsti.c
# MIGration by Phase Shift for TI media with turning rays

local ret=1

_arguments -s -S \
  'dt=[dt]:dt:' \
  'dx=[dx]:dx:' \
  'ffil=[ffil]:ffil:' \
  'tmig=[tmig]:tmig:' \
  'vnmig=[vnmig]:vnmig:' \
  'vmig=[vmig]:vmig:' \
  'etamig=[etamig]:etamig:' \
  'vnfile=[vnfile]:vnfile:' \
  'vfile=[vfile]:vfile:' \
  'etafile=[etafile]:etafile:' \
  'nxpad=[nxpad]:nxpad:' \
  'ltaper=[ltaper]:ltaper:' \
  'verbose=[verbose]:verbose:' \
  '*:file:_files' && ret=0

return ret
