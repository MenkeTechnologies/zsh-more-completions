#compdef nimbus_beacon_node nimbus
# Documentation: https://nimbus.guide/options.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '--data-dir=[Nimbus database directory]:directory:_directories' \
  '--network=[Built-in network name]:network:' \
  '--web3-url=[Execution layer JSON-RPC endpoint]:url:' \
  '--jwt-secret=[JWT secret file for Engine API]:file:_files' \
  '--rest-port=[REST API TCP port]:port:' \
  '--metrics-port=[Prometheus exporter port]:port:' \
  '--tcp-port=[Libp2p listen port]:port:' \
  '--udp-port=[Discovery UDP port]:port:' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '*::arguments: _default'
