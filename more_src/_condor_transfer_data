#compdef condor_transfer_data
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_transfer_data.html
# transfer spooled data of jobs submitted with -spool

local ret=1

_arguments -s -S \
  '-help[display usage information]' \
  '-version[display version information]' \
  '-pool[specify a pool by central manager host name and optional port]:hostname:_hosts' \
  '-name[send the command to the named schedd]:scheddname' \
  '-addr[send the command to the machine at the given address]:address' \
  '-constraint[transfer spooled data for jobs matching the constraint]:expression' \
  '-all[transfer all spooled data]' \
  '*:job or user:_default' && ret=0

return ret
