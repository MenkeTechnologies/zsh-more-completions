#compdef coverage2 coverage3 coverage-cli
# _coverage2 — Ned Batchelder coverage.py CLI command-line frontend for the Python coverage measurement tool tracking line branch coverage during pytest unittest nose test runs producing HTML XML JSON LCOV report annotate combine erase debug subcommand for downstream CI-integration code-coverage threshold gating (Ned Batchelder team, Python); argparse
# upstream: https://coverage.readthedocs.io/

_coverage2() {
    local -a sub=(
        'run:run a Python script with coverage'
        'report:report on previously measured coverage'
        'html:produce HTML report'
        'xml:produce XML report'
        'json:produce JSON report'
        'lcov:produce LCOV report'
        'annotate:annotate source files with coverage'
        'combine:combine data files'
        'erase:erase previously collected data'
        'debug:provide diagnostic information'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--debug=+[opts]:str:' \
        '--rcfile=+[file]:file:_files -g "*.cfg *.toml *.ini"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coverage2 subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '-a[append data]' \
                    '--append[append data]' \
                    '--branch[branch coverage]' \
                    '--concurrency=+[c]:c:(thread gevent eventlet greenlet multiprocessing)' \
                    '--context=+[name]:str:' \
                    '--data-file=+[file]:file:_files' \
                    '-L[also include third-party]' \
                    '--include=+[patterns]:str:' \
                    '--omit=+[patterns]:str:' \
                    '-p[parallel]' \
                    '--parallel-mode[parallel mode]' \
                    '--source=+[paths]:str:' \
                    '--timid[timid tracer]' \
                    '*:script:_files -g "*.py"' ;;
                report|html|xml|json|lcov|annotate) _arguments \
                    '--data-file=+[file]:file:_files' \
                    '--include=+[patterns]:str:' \
                    '--omit=+[patterns]:str:' \
                    '--fail-under=+[N]:n:' \
                    '--contexts=+[patterns]:str:' \
                    '--precision=+[N]:n:' \
                    '-m[show missing lines]' \
                    '--show-missing[show missing lines]' \
                    '--skip-covered[skip 100% covered files]' \
                    '--skip-empty[skip files with no code]' \
                    '--sort=+[s]:s:(Name Stmts Miss Cover Branch BrPart)' \
                    '-o+[output file]:file:_files' \
                    '-d+[output dir]:dir:_files -/' ;;
                combine) _arguments \
                    '-a[append data]' \
                    '--append[append data]' \
                    '*:data files:_files' ;;
            esac
            ;;
    esac
}

_coverage2 "$@"
