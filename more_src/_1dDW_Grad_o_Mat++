#compdef 1dDW_Grad_o_Mat++
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dDW_Grad_o_Mat++.html
# Manipulate DW gradient vector files, b-value files, and b/g-matrices

local ret=1

_arguments -s -S \
  '-in_row_vec[input file of 3 rows of gradients]:file:_files' \
  '-in_col_vec[input file of 3 columns of gradients]:file:_files' \
  '-in_col_matA[input 6 columns AFNI diagonal-first format]:file:_files' \
  '-in_col_matT[input 6 columns TORTOISE row-first format]:file:_files' \
  '-out_row_vec[output file of 3 rows of gradients]:file:_files' \
  '-out_col_vec[output file of 3 columns of gradients]:file:_files' \
  '-out_col_matA[output 6 columns AFNI diagonal-first format]:file:_files' \
  '-out_col_matT[output 6 columns TORTOISE row-first format]:file:_files' \
  '-in_bvals[input file containing b-values]:file:_files' \
  '-out_col_bval[include b-values as first column in output]' \
  '-out_row_bval_sep[output b-values to separate file in single row]:file:_files' \
  '-out_col_bval_sep[output b-values to separate file in single column]:file:_files' \
  '-flip_x[change sign of x-component]' \
  '-flip_y[change sign of y-component]' \
  '-flip_z[change sign of z-component]' \
  '-no_flip[do not change gradient signs]' \
  '-unit_mag_out[scale vectors/matrices to unit or zero magnitude]' \
  '-bref_mean_top[place mean of b0 reference values in top row]' \
  '-put_zeros_top[add zero row at top of output]' \
  '-bmax_ref[b-value threshold for reference images]:thresh' \
  '-check_abs_min[allow small negative diagonal elements below threshold]:vvv' && ret=0

return ret
