#compdef cpupower-monitor
# _cpupower-monitor — Linux CPU idle-state monitor (torvalds/linux tools/power/cpupower/)
# upstream: https://github.com/torvalds/linux/blob/master/tools/power/cpupower/utils/idle_monitor/cpupower-monitor.c
# Flags from utils/idle_monitor/cpupower-monitor.c (getopt "+lci:m:").

_cpupower-monitor() {
    _arguments \
        '-l[list available monitors]' \
        '-c[wake all idle CPUs first]' \
        '-i+[sampling interval in seconds]:secs:' \
        '-m+[monitors to use (comma-separated)]:monitors:' \
        '*::command:_command_names -e'
}

_cpupower-monitor "$@"
