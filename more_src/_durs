#compdef durs
# Documentation: https://github.com/rust-rs/durs
# durs - fast, intuitive disk usage analyzer in Rust

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-p[show full path of subdirectories]' \
  '-s[show apparent size instead of disk usage]' \
  '-n[number of directories to show]:count:' \
  '-d[number of subdirectory levels to show]:depth:' \
  '-D[show only directories]' \
  '-F[show only files]' \
  '-r[reverse order of output]' \
  '-o[output size format]:format:(si b kb kib mb mib gb gib)' \
  '-X[ignore files and directories with this name]:name:' \
  '-x[only show directories on the same filesystem]' \
  '-b[do not show percentages or draw ASCII bars]' \
  '-B[move percent bars to right side of screen]' \
  '-i[do not show hidden files]' \
  '-c[no colors, monochrome]' \
  '-C[force colors]' \
  '-f[count files instead of disk space]' \
  '-t[group by filetype]' \
  '-z[minimum size filter, e.g. 10M]:min-size:' \
  '-e[only include files matching this regex]:regex:' \
  '-v[exclude files matching this regex]:regex:' \
  '-L[dereference links, treat symlinks as directories]' \
  '-P[disable the progress indicator]' \
  '-R[screen reader mode]' \
  '-S[custom stack size]:size:' \
  '--skip-total[do not display the total row]' \
  '-j[print JSON representation of directories]' \
  '--files0-from=[read null-terminated file paths from FILE, - for stdin]:file:_files' \
  '*:directory:_files -/' && ret=0

return ret
