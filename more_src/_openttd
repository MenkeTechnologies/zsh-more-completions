#compdef openttd
# Documentation: https://man.archlinux.org/search?q=openttd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-D[dedicated server]' \
  '-f[no fork]' \
  '-c+[config file]:file:_files' \
  '-x[do not save config]' \
  '-X[do not save autosave]' \
  '-g+[load game]:file:_files -g "*.{sav,ttd,ttdp,ssg}"' \
  '-G+[random seed]:n:' \
  '-l+[language]:lang:' \
  '-m+[music driver]:driver:' \
  '-M+[music volume]:vol:' \
  '-n+[connect to server]:srv:' \
  '-r+[resolution WxH]:res:' \
  '-s+[sound driver]:driver:' \
  '-S+[sound volume]:vol:' \
  '-t+[year start]:year:' \
  '-v+[video driver]:driver:(opengl sdl null dedicated)' \
  '-q+[quick query newgrf]:file:_files' \
  '-d+[debug level]:lvl:' \
  '-b+[blitter]:blit:' \
  '-Z[print AI cmds]' && ret=0

return ret
