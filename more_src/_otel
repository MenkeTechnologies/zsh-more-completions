#compdef otel
# _otel — OpenTelemetry generic short binary alias for otel-cli / otelcol wrappers (OpenTelemetry, Go)
# upstream: https://github.com/open-telemetry

_otel() {
    local -a sub=(
        'exec:run a child and emit span'
        'span:emit a span via OTLP'
        'event:emit an event via OTLP'
        'status:show collector status'
        'shutdown:shutdown collector'
        'config:dump collector config'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[collector config]:file:_files -g "*.yaml *.yml"' \
        '--endpoint=+[OTLP endpoint]:url:_urls' \
        '--protocol=+[OTLP protocol]:proto:(grpc http/protobuf http/json)' \
        '--service-name=+[service name]:str:' \
        '--insecure[insecure OTLP]' \
        '--headers=+[OTLP headers]:str:' \
        '--timeout=+[OTLP timeout]:dur:' \
        '--otlp-blocking[block until OTLP succeeds]' \
        '--otlp-keep-alive=+[keepalive interval]:dur:' \
        '--no-tls-verify[skip TLS verify]' \
        '--tls-ca-cert=+[CA cert]:file:_files' \
        '--tls-cert=+[client cert]:file:_files' \
        '--tls-key=+[client key]:file:_files' \
        '--otlp-blocking-on-cancel[block on cancel]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'otel subcommand' sub ;;
        args)
            case $words[1] in
                exec) _arguments \
                    '--name=+[span name]:str:' \
                    '--service=+[service name]:str:' \
                    '--kind=+[span kind]:k:(internal client server producer consumer)' \
                    '--attrs=+[span attrs]:str:' \
                    '--tp-print[print traceparent]' \
                    '--tp-export[export traceparent env]' \
                    '*:cmd:_command_names -e' ;;
                span) _arguments \
                    '--name=+[span name]:str:' \
                    '--service=+[service name]:str:' \
                    '--kind=+[span kind]:k:(internal client server producer consumer)' \
                    '--status-code=+[span status]:code:(unset ok error)' \
                    '--status-description=+[status description]:str:' \
                    '--start=+[start timestamp]:str:' \
                    '--end=+[end timestamp]:str:' \
                    '--attrs=+[attrs]:str:' \
                    '--force-trace-id=+[trace id]:str:' \
                    '--force-span-id=+[span id]:str:' ;;
                event) _arguments \
                    '--name=+[event name]:str:' \
                    '--time=+[timestamp]:str:' \
                    '--attrs=+[attrs]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_otel "$@"
