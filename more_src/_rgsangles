#compdef rgsangles
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/rgsangles/node4.html
# Correct CCD pixel positions of an event for changes in spacecraft pointing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--mergedset=[input/output data set with RGS raw events]:file:_files' \
  '--srclist=[input dataset with RGS source list]:file:_files' \
  '--nbetabins=[number of bins along the beta angle axis]:n' \
  '--betabinning=[method for binning beta angles]:method:(Range binSize)' \
  '--betamin=[lower boundary of first beta bin in radians]:value' \
  '--betamax=[upper boundary of last beta bin in radians]:value' \
  '--betabinref=[reference point for beta binning]:value' \
  '--betabinwidth=[width of BETA_CHANNEL bin in radians]:value' \
  '--nxdispbins=[number of cross-dispersion direction bins]:n' \
  '--lambdabinref=[reference wavelength for lambda channel one]:value' \
  '--lambdabinwidth=[wavelength bin width in Angstroms]:value' \
  '--nlambdabins=[number of wavelength bins]:n' \
  '--xdispbinning=[cross-dispersion binning method]:method:(Range binSize)' \
  '--xdispmin=[lower boundary for cross-dispersion bins]:value' \
  '--xdispmax=[upper boundary for cross-dispersion bins]:value' \
  '--xdispbinref=[reference point for cross-dispersion binning]:value' \
  '--xdispbinwidth=[width of XDSP_CHANNEL bin in radians]:value' \
  '--withpointingcolumn=[include spacecraft pointing RA/DEC columns]:bool:(Yes No)' \
  '--withmlambdacolumn=[produce column with m*lambda]:bool:(Yes No)' \
  '--withheliocentriccorr=[apply heliocentric velocity correction]:bool:(Yes No)' \
  '--withsunanglecorr=[apply Sun angle correction]:bool:(Yes No)' \
  '*:param=value:_default' && ret=0

return ret
