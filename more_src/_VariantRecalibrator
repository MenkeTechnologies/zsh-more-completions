  '--max-attempts=[Number of attempts to build a model before failing]:value:' \
  '--dont-run-rscript[Disable the RScriptExecutor to allow RScript to be generated but not run]' \
  '--trust-all-polymorphic[Trust that all the input training sets'\'' unfiltered records contain only polymorphic...]' \
