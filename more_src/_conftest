#compdef conftest

_conftest_subcommands() {
  local -a subcmds=(
    'fmt:Format Rego source files'
    'parse:Parse structured configuration files'
    'pull:Download policies from a registry'
    'push:Upload policies to a registry'
    'test:Test structured configuration files'
    'verify:Verify Rego unit tests'
    'plugin:Manage conftest plugins'
    'completion:Generate shell completion scripts'
  )
  _describe -t commands 'conftest subcommand' subcmds
}

_conftest() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-v,--version}'[Show version]' \
    '1:subcommand:_conftest_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        test)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            {-p,--policy}'[Policy directory or file]:path:_files' \
            {-d,--data}'[Data directory or file]:path:_files' \
            {-i,--input}'[Input type]:type:(json yaml toml hcl1 hcl2 cue ini dockerfile edn vcl xml jsonnet textproto spdx cyclonedx)' \
            {-o,--output}'[Output format]:format:(stdout json tap table github junit)' \
            '--combine[Combine input files]' \
            '--fail-on-warn[Fail on warnings]' \
            '--update[Pull policies before testing]' \
            '--trace[Enable tracing]' \
            '--strict[Enable strict mode]' \
            '--all-namespaces[Use all namespaces]' \
            '--namespace[Rego namespace]:namespace:' \
            '--no-color[Disable color output]' \
            '--no-fail[Always exit with 0]' \
            '--proto-file-dirs[Protobuf file directories]:dir:_directories' \
            '--capabilities[Path to capabilities file]:file:_files' \
            '--quiet[Suppress output]' \
            '--show-builtin-errors[Show built-in function errors]' \
            '*:file:_files'
          ;;
        parse)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            {-i,--input}'[Input type]:type:(json yaml toml hcl1 hcl2 cue ini dockerfile edn vcl xml jsonnet textproto spdx cyclonedx)' \
            '--combine[Combine input files]' \
            '*:file:_files'
          ;;
        pull)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            {-p,--policy}'[Policy directory]:dir:_directories' \
            '1:url:'
          ;;
        push)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            {-p,--policy}'[Policy directory]:dir:_directories' \
            '1:url:'
          ;;
        verify)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            {-p,--policy}'[Policy directory or file]:path:_files' \
            {-d,--data}'[Data directory or file]:path:_files' \
            {-o,--output}'[Output format]:format:(stdout json tap table github junit)' \
            '--no-color[Disable color output]' \
            '--trace[Enable tracing]' \
            '--report[Include full report]'
          ;;
        fmt)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--check[Check if files are formatted]' \
            '*:file:_files -g "*.rego"'
          ;;
      esac
      ;;
  esac
}

_conftest "$@"
