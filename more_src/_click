#compdef click
# Documentation: https://github.com/databricks/click
# Reference accessed: 2026-05-16
# Verified: databricks/click (Rust REPL for Databricks SQL warehouses).
# NOT the Python click framework (which has no CLI binary).
# Removed from prior file: bogus man.archlinux.org search URL.

# click: Databricks SQL REPL
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '(-p --profile)'{-p+,--profile=}'[Databricks config profile]:profile:' \
  '(-s --server-hostname)'{-s+,--server-hostname=}'[workspace host]:host:' \
  '(-t --http-path)'{-t+,--http-path=}'[SQL warehouse HTTP path]:path:' \
  '*:SQL or subcommand:_default' && ret=0
return ret
