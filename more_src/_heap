#compdef heap
# Documentation: man heap(1) (macOS)
# Source: macOS heap — list all malloc-allocated buffers in a process's heap.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s -sortBySize)'{-s,-sortBySize}'[sort by total size of class instances]' \
    '(-z -zones)'{-z,-zones}'[show output by malloc zone]' \
    '(-H -humanReadable)'{-H,-humanReadable}'[human-readable unit suffixes (K/M/G/T)]' \
    '-guessNonObjects[heuristically guess non-object allocations]' \
    '-sumObjectFields[fold non-object sizes into object entries]' \
    '-showSizes[show distribution of malloc sizes per object]' \
    '-addresses+[list addresses for class pattern or "all"]:pattern:(all)' \
    '-noContent[omit memory-content descriptions]' \
    '1:pid / partial-name / memgraph file:_files' \
    && ret=0

return ret
