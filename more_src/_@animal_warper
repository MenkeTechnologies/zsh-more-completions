#compdef @animal_warper
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@animal_warper.html
# Align animal anatomical data to a template and map followers

local ret=1

_arguments -s \
  '-input[input dataset to align (source)]:dataset:_files' \
  '-base[template dataset for alignment]:dataset:_files' \
  '-atlas[atlas datasets in base space]:dataset:_files' \
  '-atlas_followers[atlas datasets in base space]:dataset:_files' \
  '-seg_followers[integer segmentation datasets in base]:dataset:_files' \
  '-template_followers[non-integer datasets in base space]:dataset:_files' \
  '-dset_followers[datasets in input space to template]:dataset:_files' \
  '-roidset_followers[integer ROI datasets in input space]:dataset:_files' \
  '-outdir[output directory]:dir:_files -/' \
  '-skullstrip[brain mask in base space]:dataset:_files' \
  '-input_abbrev[abbreviation for input naming]:label' \
  '-base_abbrev[abbreviation for base naming]:label' \
  '-atlas_abbrevs[abbreviations for atlas followers]:labels' \
  '-template_abbrevs[abbreviations for template followers]:labels' \
  '-seg_abbrevs[abbreviations for seg followers]:labels' \
  '-dset_abbrevs[abbreviations for dset followers]:labels' \
  '-roidset_abbrevs[abbreviations for roidset followers]:labels' \
  '-use_known_abbrev_base[auto-guess base abbreviation]' \
  '-use_known_abbrev_atlas[auto-guess atlas abbreviations]' \
  '-use_known_abbrev_template[auto-guess template abbreviations]' \
  '-use_known_abbrev_ALL[auto-guess all abbreviations]' \
  '-align_centers_meth[center alignment method or OFF]:method' \
  '-aff_move_opt[affine alignment movement options]:opt' \
  '-cost[cost function for alignment]:cost' \
  '-maxlev[max nonlinear warp level 0-11]:level' \
  '-no_surfaces[skip surface generation]' \
  '-feature_size[feature size mm for affine align]:size' \
  '-supersize[allow up to 50% size difference]' \
  '-init_scale[initial scale ratio]:ratio' \
  '-mode_smooth_size[modal smoothing kernel voxels]:size' \
  '-mode_smooth_replacement_off[disable modal smoothing replacement]' \
  '-center_out[center output native or shifted]:mode' \
  '-align_type[alignment level]:type:(rigid rigid_equiv affine all)' \
  '-extra_qw_opts[extra options for 3dQwarp]:opts' \
  '-keep_temp[retain temporary files]' \
  '-ok_to_exist[reuse existing datasets]' \
  '-echo[display all commands]' \
  '-ver[display version]' && ret=0

return ret
