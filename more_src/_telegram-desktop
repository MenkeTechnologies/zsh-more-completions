#compdef telegram-desktop Telegram
# _telegram-desktop — Telegram Desktop (Qt client; -- separates Telegram args from URL handler args, -workdir picks an alternate data directory, -autostart silent-launch, -startintray boot minimized, -no-start-minimized override, -enable-features chromium features)
# upstream: https://github.com/telegramdesktop/tdesktop
# Flags from tdesktop Telegram/SourceFiles/core/launcher.cpp on tip.

_telegram-desktop() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-workdir+[data directory]:dir:_files -/' \
        '-autostart[launch silently]' \
        '-noautostart[do not silent-launch]' \
        '-fromautostart[treat as autostart launch]' \
        '-startintray[start in tray]' \
        '-no-start-minimized[do not start minimized]' \
        '-quit[quit if instance already running]' \
        '-many[allow multiple instances]' \
        '-debug[debug logging]' \
        '-key+[debug key]:key:' \
        '-enable-features+[chromium features]:features:' \
        '-disable-features+[chromium features]:features:' \
        '*::URL or args:'
}

_telegram-desktop "$@"
