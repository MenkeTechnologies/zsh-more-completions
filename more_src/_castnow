#compdef castnow
# Zsh completion for castnow - Chromecast CLI media player
# https://github.com/xat/castnow

_arguments -s -S \
  '(- *)--help[show help]' \
  '--address=[set Chromecast IP address]:address:_hosts' \
  '--device=[set Chromecast device name]:device name:' \
  '--myip=[set local IP address]:IP address:' \
  '--port=[set local server port]:port:' \
  '--subtitle=[load subtitle file]:subtitle file:_files -g "*.srt *.vtt *.sub(-.)"' \
  '--subtitle-scale=[scale subtitle size]:scale factor:' \
  '--subtitle-color=[set subtitle color]:color:' \
  '--subtitle-port=[set subtitle server port]:port:' \
  '--tomp4[convert with ffmpeg before streaming]' \
  '--ffmpeg-args=[additional ffmpeg arguments]:ffmpeg args:' \
  '--transcode[force transcoding with VLC]' \
  '--loop[loop playlist]' \
  '--shuffle[shuffle playlist]' \
  '--recursive[recursively add media from directories]' \
  '--volume=[set initial volume (0.0-1.0)]:volume:' \
  '--seek=[start at time offset]:time (seconds):' \
  '--command=[send a command]:command:(play pause stop mute unmute status)' \
  '--exit[exit after casting]' \
  '--quiet[suppress output]' \
  '*:media file or URL:_files -g "*.{mp4,mkv,avi,webm,mp3,m4a,flac,ogg,wav}(-.)"'
