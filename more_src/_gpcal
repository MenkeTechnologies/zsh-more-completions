#compdef gpcal
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/gpcal.html
# MIRIAD gpcal - gain and polarization calibration

local ret=1

_arguments -s -S \
  'vis=[input visibility data file]:vis:_files' \
  'select=[uv selection criteria]:select' \
  'line=[line-type specification]:line' \
  'flux=[I,Q,U,V Stokes parameter values]:flux' \
  'spec=[reference freq GHz, spectral index, higher terms]:spec' \
  'refant=[reference antenna]:refant' \
  'minants=[minimum antenna count for a solution]:minants' \
  'interval=[solution interval(s) in minutes]:interval' \
  'nfbin=[number of frequency bins]:nfbin' \
  'tol=[convergence error tolerance]:tol' \
  'xyphase=[initial XY phase estimates per antenna]:xyphase' \
  'options=[xyvary,qusolve,oldflux,nopol,noxy,nopass,noamphase,linear,circular,reset,xyref,polref,vsolve]:options' \
  '*:visibility data:_files' && ret=0

return ret
