#compdef klaviyo-cli klaviyo
# _klaviyo-cli — Klaviyo klaviyo-cli CLI command-line frontend wrapping the Klaviyo email and SMS marketing automation REST API managing profiles events lists segments campaigns flows templates metrics catalog reviews coupons subscriptions push tokens images forms data-privacy-suppression (Klaviyo team, Go); cobra
# upstream: https://www.klaviyo.com/

_klaviyo-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'profile:profile operations'
        'event:event operations'
        'list:list operations'
        'segment:segment operations'
        'campaign:campaign operations'
        'flow:flow operations'
        'template:template operations'
        'metric:metric operations'
        'catalog:catalog operations'
        'review:review operations'
        'coupon:coupon operations'
        'subscription:subscription operations'
        'form:form operations'
        'image:image upload'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--company-id=+[id]:str:' \
        '--revision=+[date]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'klaviyo-cli subcommand' sub ;;
        args)
            case $words[1] in
                profile|event|list|segment|campaign|flow|template|metric|catalog|review|coupon|subscription|form|image) _arguments '1:op:(list get create update delete send trigger pause resume archive)' '*:id:' ;;
            esac
            ;;
    esac
}

_klaviyo-cli "$@"
