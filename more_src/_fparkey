#compdef fparkey
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fparkey.txt
# Write a parameter value to a FITS header keyword

local ret=1

_arguments -s \
  "value=[value to write to the keyword]:" \
  "fitsfile=[FITS file and extension]:file:_files" \
  "keyword=[name of keyword to write]:" \
  "comm=[keyword comment]:" \
  "add=[add keyword if not present]:bool:(yes no)" \
  "insert=[insert before this keyword]:" \
  "*:FITS file:_files" && ret=0

return ret
