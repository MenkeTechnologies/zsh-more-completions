#compdef openra
# Documentation: https://man.archlinux.org/search?q=openra
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--list-mods[list available mods]' \
  '--mod=+[mod]:mod:(ra cnc d2k ts)' \
  '--engine=+[engine]:engine:' \
  '--game=+[game]:game:' \
  '--server[start dedicated server]' \
  '--name=+[player name]:name:' \
  '--port=+[server port]:port:' \
  '--password=+[server password]:pw:' \
  '*:replay:_files -g "*.orarep"' && ret=0

return ret
