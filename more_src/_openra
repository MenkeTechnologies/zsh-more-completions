#compdef openra
# Documentation: https://github.com/OpenRA/OpenRA/wiki/Command-line-options
# Reference accessed: 2026-05-16
# Verified: upstream OpenRA wiki "Command line options" page; OpenRA
# uses key=value style for all settings (not --foo=val).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --mod, --engine, --game, --server, --name, --port,
# --password, --list-mods flags (none exist in this form).

# openra: open-source real-time strategy engine (RA/CnC/D2K/TS/TD)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:setting:->settings' && ret=0
case $state in
  (settings)
    _values 'key=value' \
      'Game.Mod[mod to launch (ra/cnc/d2k/ts/td)]' \
      'Engine.EngineDir[engine directory]' \
      'Engine.ContentDir[content directory]' \
      'Engine.LaunchPath[launcher executable path]' \
      'Launch.Connect[host:port to connect to]' \
      'Launch.Password[server password]' \
      'Launch.Replay[replay file to play]' \
      'Launch.Benchmark[run benchmark]' \
      'Server.Name[dedicated server name]' \
      'Server.ListenPort[server listen port]' \
      'Server.AdvertiseOnline[advertise to master server]' \
      'Server.Password[server password]' \
      'Server.Map[default map]' \
      'Server.EnableSingleplayer[allow single player]' \
      'Server.DiscoverNatDevices[UPnP NAT discovery]' \
      'Server.AllowPortForward[allow port forwarding]' \
      'Server.Dedicated[run dedicated server]' \
      'Server.DedicatedLoop[loop dedicated server]' && ret=0
    ;;
esac
return ret
