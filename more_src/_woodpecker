#compdef woodpecker

_woodpecker_commands() {
  local -a commands=(
    'build:Manage builds'
    'log:Manage build logs'
    'deploy:Trigger a deployment'
    'exec:Execute a local pipeline'
    'info:Show pipeline info'
    'registry:Manage registries'
    'secret:Manage secrets'
    'repo:Manage repositories'
    'user:Manage users'
    'lint:Lint a pipeline config'
    'cron:Manage cron jobs'
    'loglevel:Get or set log level'
    'org:Manage organizations'
    'pipeline:Manage pipelines'
    'setup:Setup the CLI'
  )
  _describe 'command' commands
}

_woodpecker() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-s --server)'{-s,--server}'[Server address]:url:' \
    '(-t --token)'{-t,--token}'[Authentication token]:token:' \
    '--log-level[Log level]:level:(trace debug info warn error fatal panic)' \
    '--help[Show help]' \
    '--version[Print version]' \
    '1:command:_woodpecker_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        build|pipeline)
          local -a subcmds=(
            'ls:List builds'
            'last:Show last build'
            'info:Show build info'
            'stop:Stop a build'
            'start:Start a build'
            'approve:Approve a build'
            'decline:Decline a build'
            'queue:Show build queue'
            'ps:Show build steps'
            'create:Create a build'
          )
          _describe 'build subcommand' subcmds
          ;;
        log)
          local -a subcmds=(
            'purge:Purge logs'
          )
          _describe 'log subcommand' subcmds
          ;;
        secret)
          local -a subcmds=(
            'add:Add a secret'
            'rm:Remove a secret'
            'ls:List secrets'
            'info:Show secret info'
            'update:Update a secret'
          )
          _describe 'secret subcommand' subcmds
          ;;
        repo)
          local -a subcmds=(
            'ls:List repositories'
            'info:Show repository info'
            'add:Add a repository'
            'update:Update repository settings'
            'rm:Remove a repository'
            'sync:Sync repositories'
            'chown:Change repository owner'
            'repair:Repair a repository'
          )
          _describe 'repo subcommand' subcmds
          ;;
        cron)
          local -a subcmds=(
            'add:Add a cron job'
            'rm:Remove a cron job'
            'ls:List cron jobs'
            'info:Show cron job info'
            'update:Update a cron job'
          )
          _describe 'cron subcommand' subcmds
          ;;
        exec)
          _arguments \
            '--backend[Backend engine]:backend:(auto-detect docker local ssh)' \
            '--timeout[Timeout duration]:timeout:' \
            '--volumes[Mount volumes]:volumes:' \
            '--network[Network]:network:' \
            '--privileged[Run in privileged mode]' \
            '--local[Run local pipeline]' \
            '*:pipeline file:_files -g "*.yml *.yaml"'
          ;;
        deploy)
          _arguments \
            '--branch[Branch]:branch:' \
            '--event[Event]:event:(push tag deployment)' \
            '--format[Output format]:format:' \
            '--param[Parameters]:param:' \
            '--status[Status]:status:' \
            '1:repo:' \
            '2:build number:' \
            '3:environment:'
          ;;
        lint)
          _arguments '1:pipeline file:_files -g "*.yml *.yaml"'
          ;;
        user)
          local -a subcmds=(
            'ls:List users'
            'info:Show user info'
            'add:Add a user'
            'rm:Remove a user'
          )
          _describe 'user subcommand' subcmds
          ;;
      esac
      ;;
  esac
}

_woodpecker "$@"
