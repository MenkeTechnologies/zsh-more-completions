#compdef 3dGroupInCorr
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dGroupInCorr.html
# AFNI: group interactive correlation analysis

local ret=1

_arguments -s -S \
  '-setA[primary dataset collection setup file]:file:_files' \
  '-setB[secondary dataset collection]:file:_files' \
  '-Apair[use setA twice with different seeds]' \
  '-labelA[label for setA sub-bricks]:label:' \
  '-labelB[label for setB sub-bricks]:label:' \
  '-pooled[pooled variance for unpaired t-tests]' \
  '-unpooled[unpooled variance for unpaired t-tests]' \
  '-paired[two-sample paired t-test]' \
  '-nosix[suppress 1-sample sub-bricks in 2-sample]' \
  '-covariates[dataset-level covariate values from file]:file:_files' \
  '-center[control covariate centering]:mode:' \
  '-seedrad[average seed time series within radius mm]:radius:' \
  '-sendall[also transmit individual subject results]' \
  '-donocov[also compute results without covariates]' \
  '-dospcov[Spearman correlation with covariates]' \
  '-clust[3dClustSim results for clustering]:prefix:' \
  '-read[read data into memory not memory-map]' \
  '-ztest[test input for all-zero values]' \
  '-ah[connect to AFNI/SUMA on remote host]:host:' \
  '-np[port offset]:port:' \
  '-npq[port offset, reduced verbosity]:port:' \
  '-npb[port offset bloc]:bloc:' \
  '-max_port_bloc[display max port bloc]' \
  '-max_port_bloc_quiet[display max port bloc quietly]' \
  '-num_assigned_ports[report number of assigned ports]' \
  '-num_assigned_ports_quiet[report assigned port count quietly]' \
  '-NOshm[disable shared memory; use TCP/IP]' \
  '-suma[route communication to SUMA]' \
  '-quiet[suppress informational messages]' \
  '-verb[additional informational messages]' \
  '-VERB[extensive informational messages]' \
  '-debug[activate internal testing mode]' \
  '-scale[dataset-level scale factors from file]:file:_files' \
  '-SCALE[scale factors with sqrt(X-3) transform]:file:_files' \
  '-batch[batch processing method and command file]:method:' \
  '-batchRAND[random seed points for batch]:n:' \
  '-batchGRID[regular grid seed points for batch]:n:' \
  '*:file:_files' && ret=0

return ret
