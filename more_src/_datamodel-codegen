#compdef datamodel-codegen
# Documentation: https://man.archlinux.org/search?q=datamodel-codegen
# Reference accessed: 2026-05-16

# Zsh completion for datamodel-codegen
# https://github.com/k-kan/datamodel-code-generator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--input=[input file or directory]:file:_files' \
  '--output=[output file]:file:_files' \
  '--input-file-type=[input file type]:type:(openapi jsonschema json graphql)' \
  '--output-model-type=[output model type]:type:(pydantic_v1 pydantic_v2 dataclasses msgspec)' \
  '--target-python-version=[target Python version]:version:(3.7 3.8 3.9 3.10 3.11 3.12)' \
  '--base-class=[base class for models]:class:' \
  '--custom-template-dir=[custom template directory]:dir:_directories' \
  '--use-standard-collections[use standard collections]' \
  '--use-union-operator[use union operator (Python 3.10+)]' \
  '--allow-population-by-field-name[allow population by field name]' \
  '--enable-empty-tuples[enable empty tuples]' \
  '--version[show version]' \
  '--help[show help]' && ret=0

return ret
