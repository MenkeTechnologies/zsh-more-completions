#compdef axolotl

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'train:fine-tune a model with the given config'
  'preprocess:preprocess the dataset before training'
  'inference:run inference with a fine-tuned model'
  'merge-lora:merge a LoRA adapter with the base model'
  'shard:shard a fine-tuned model'
  'evaluate:evaluate a model'
  'fetch:fetch example configs and datasets'
  'lm-eval:run lm-eval-harness'
  'vllm-serve:serve a model via vllm'
  'delinearize-llama4:de-linearize Llama 4 weights'
  'config-schema:dump the configuration JSON schema'
  'agent-docs:print agent-facing docs'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'axolotl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (train|preprocess|inference|evaluate|shard|vllm-serve|lm-eval)
        _arguments \
          '--debug[debug logging]' \
          '--debug-num-examples=[number of examples to debug]:n:' \
          '--prompter=[prompter override]:prompter:' \
          '--seed=[random seed]:seed:' \
          '--use-tracker=[tracking provider]:t:(wandb mlflow comet aim)' \
          '--cloud-bucket=[upload artifacts to bucket]:url:' \
          '--main-process-port=[main process port]:port:' \
          '--num-processes=[number of processes]:n:' \
          '--gpu-ids=[CUDA_VISIBLE_DEVICES]:ids:' \
          '*--cfg=[set config key=value]:kv:' \
          '*::config_yaml:_files -g "*.{yml,yaml}"' && ret=0 ;;
      (merge-lora)
        _arguments \
          '--lora-model-dir=[LoRA adapter dir]:dir:_files -/' \
          '--output-dir=[merged model output]:dir:_files -/' \
          '*::config_yaml:_files -g "*.{yml,yaml}"' && ret=0 ;;
      (fetch)
        _arguments \
          '--dest=[destination directory]:dir:_files -/' \
          '*::which:(examples deepspeed_configs configs)' && ret=0 ;;
      (agent-docs)
        _arguments '*::topic:(sft grpo preference_tuning rl multimodal datasets evaluation config_options)' && ret=0 ;;
    esac ;;
esac

return ret
