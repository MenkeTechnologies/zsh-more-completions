#compdef mkdocs
# Documentation: https://www.mkdocs.org/user-guide/cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: mkdocs completion variant tuned for mkdocs-material theme.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build the documentation site'
  'gh-deploy:deploy documentation to GitHub Pages'
  'new:create a new MkDocs project'
  'serve:run the development server'
  'get-deps:show required PyPI packages'
)

_arguments -s -S \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[silence warnings]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'mkdocs command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      build)
        _arguments \
          '(-c --clean --dirty)'{-c,--clean}'[clean build directory first]' \
          '(-c --clean --dirty)--dirty[only rebuild changed pages]' \
          '(-f --config-file)'{-f+,--config-file=}'[config file]:file:_files -g "*.yml"' \
          '(-s --strict --no-strict)'{-s,--strict}'[enable strict mode]' \
          '(-s --strict --no-strict)--no-strict[disable strict mode]' \
          '(-t --theme)'{-t+,--theme=}'[theme]:theme:(material mkdocs readthedocs)' \
          '(--use-directory-urls --no-directory-urls)--use-directory-urls[use directory URLs]' \
          '(--use-directory-urls --no-directory-urls)--no-directory-urls[do not use directory URLs]' \
          '(-d --site-dir)'{-d+,--site-dir=}'[output directory]:directory:_files -/'
        ;;
      serve)
        _arguments \
          '(-a --dev-addr)'{-a+,--dev-addr=}'[development server address]:address' \
          '(-f --config-file)'{-f+,--config-file=}'[config file]:file:_files -g "*.yml"' \
          '(-s --strict --no-strict)'{-s,--strict}'[enable strict mode]' \
          '(-s --strict --no-strict)--no-strict[disable strict mode]' \
          '(-t --theme)'{-t+,--theme=}'[theme]:theme:(material mkdocs readthedocs)' \
          '(--use-directory-urls --no-directory-urls)--use-directory-urls[use directory URLs]' \
          '(--use-directory-urls --no-directory-urls)--no-directory-urls[do not use directory URLs]' \
          '--no-livereload[disable live reload]' \
          '(-c --clean --dirty)'{-c,--clean}'[rebuild all pages]' \
          '(-c --clean --dirty)--dirty[only rebuild changed pages]' \
          '--watch-theme[watch theme directory for changes]' \
          '*'{-w+,--watch=}'[watch additional path]:path:_files'
        ;;
      new)
        _arguments \
          '1:project directory:_files -/'
        ;;
      gh-deploy)
        _arguments \
          '(-c --clean --dirty)'{-c,--clean}'[clean build directory first]' \
          '(-c --clean --dirty)--dirty[only rebuild changed pages]' \
          '(-f --config-file)'{-f+,--config-file=}'[config file]:file:_files -g "*.yml"' \
          '(-m --message)'{-m+,--message=}'[commit message]:message' \
          '(-b --remote-branch)'{-b+,--remote-branch=}'[branch to deploy to]:branch' \
          '(-r --remote-name)'{-r+,--remote-name=}'[remote name]:remote' \
          '--force[force push]' \
          '--ignore-version[ignore version check]' \
          '--no-history[do not preserve history]' \
          '--shell[use shell for git commands]'
        ;;
      get-deps)
        _arguments \
          '(-f --config-file)'{-f+,--config-file=}'[config file]:file:_files -g "*.yml"' \
          '(-p --projects-file)'{-p+,--projects-file=}'[projects file]:file:_files'
        ;;
    esac
    ;;
esac

return ret
