#compdef 3dCM
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dCM.html
# AFNI compute center of mass of a dataset

local ret=1

_arguments -s -S \
  '-mask[mask dataset; nonzero voxels only]:mask:_files' \
  '-automask[automatically generate a mask]' \
  '-set[adjust origin so center of mass aligns x y z]:x:' \
  '-local_ijk[report results as (i,j,k) in local orientation]' \
  '-roi_vals[center of mass per ROI voxel value]:vals:' \
  '-all_rois[process all regions of interest]' \
  '-Icent[compute internal center]' \
  '-Dcent[compute distance center]' \
  '-rep_xyz_orient[orientation for coordinate reporting]:orient:' \
  '*:dataset:_files' && ret=0

return ret
