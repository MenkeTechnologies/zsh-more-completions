#compdef aviocat
# Documentation: https://github.com/FFmpeg/FFmpeg/blob/master/tools/aviocat.c
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b+[bytes per second]:bytes:' \
  '-d+[duration]:seconds:' \
  '-oi+[input AVOptions (key=value, :-separated)]:options:' \
  '-oo+[output AVOptions (key=value, :-separated)]:options:' \
  '-v[verbose]' \
  '1:input URL:_files' \
  '2:output URL:_files' && ret=0

return ret
