#compdef cosmoaddr2line
# Documentation: https://github.com/jart/cosmopolitan/blob/master/tool/cosmocc/bin/cosmoaddr2line
# Reference accessed: 2026-05-27
# Verified: upstream tool/cosmocc/bin/cosmoaddr2line shell script

# Zsh completion for cosmoaddr2line.
# Thin wrapper that prepends "-apifCe" and forwards to either
# x86_64-linux-cosmo-addr2line or aarch64-linux-cosmo-addr2line (or
# $ADDR2LINE if set). Accepts the standard GNU binutils addr2line flags.

local arguments

arguments=(
  '(-a --addresses)'{-a,--addresses}'[show addresses in output]'
  '(-b --target)'{-b+,--target=}'[set the binary file format]:bfdname:'
  '(-C --demangle)'{-C,--demangle=-}'[demangle function names]::style:(none auto gnu-v3 java gnat dlang rust)'
  '(-e --exe)'{-e+,--exe=}'[set the input file name]:file:_files'
  '(-f --functions)'{-f,--functions}'[show function names]'
  '(-i --inlines)'{-i,--inlines}'[unwind inlined functions]'
  '(-j --section)'{-j+,--section=}'[read section-relative offsets instead of addresses]:section:'
  '(-p --pretty-print)'{-p,--pretty-print}'[make output human friendly]'
  '(-s --basenames)'{-s,--basenames}'[strip directory names from filenames]'
  '(-r --no-recurse-limit)'{-r,--no-recurse-limit}'[disable a recursion limit when demangling]'
  '(-R --recurse-limit)'{-R,--recurse-limit}'[enable the recursion limit when demangling (default)]'
  '--help[display help and exit]'
  '(-v --version)'{-v,--version}'[print version information]'
  '*:address:'
)

_arguments -s $arguments
