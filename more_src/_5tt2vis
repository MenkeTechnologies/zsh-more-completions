#compdef 5tt2vis
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/5tt2vis.html
# Source: MRtrix3/mrtrix3 cmd/5tt2vis.cpp — collapse 5TT image to 3D for visualisation (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-bg+[background intensity (0.0-1.0)]:value:_default' \
    '-cgm+[cortical grey matter intensity]:value:_default' \
    '-sgm+[sub-cortical grey matter intensity]:value:_default' \
    '-wm+[white matter intensity]:value:_default' \
    '-csf+[CSF intensity]:value:_default' \
    '-path+[pathological tissue intensity]:value:_default' \
    '1:input (4D 5TT image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:output (3D visualisation image):_files' \
    && ret=0

return ret
