#compdef zfind

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-t=[filter by type]:type:(f d l b c p s)' \
  '-name=[match file name pattern]:pattern' \
  '-iname=[match file name pattern case-insensitive]:pattern' \
  '-path=[match path pattern]:pattern' \
  '-ipath=[match path pattern case-insensitive]:pattern' \
  '-regex=[match path with regex]:regex' \
  '-iregex=[match path with regex case-insensitive]:regex' \
  '-size=[filter by size]:size' \
  '-empty[match empty files and directories]' \
  '-newer=[match files newer than]:file:_files' \
  '-newermt=[match files newer than timestamp]:timestamp' \
  '-maxdepth=[maximum depth]:depth' \
  '-mindepth=[minimum depth]:depth' \
  '-delete[delete matched files]' \
  '-ls[list matched files in ls-like format]' \
  '-print0[print NUL-delimited output]' \
  '-exec[execute command on each match]:command' \
  '-j=[number of parallel jobs]:jobs' \
  '-L[follow symlinks]' \
  '-z[search inside compressed files]' \
  '*:directory:_directories'
