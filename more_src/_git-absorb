#compdef git-absorb

# Zsh completion for git absorb (automatically absorb staged changes)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-r --and-rebase)'{-r,--and-rebase}'[run rebase after absorbing]' \
  '--base[reference commit to find the stack]:commit:' \
  '(-n --dry-run)'{-n,--dry-run}'[show what would be absorbed without doing it]' \
  '(-f --force)'{-f,--force}'[skip safety checks]' \
  '(-v --verbose)'{-v,--verbose}'[display more output]' \
  '(-w --whole-file)'{-w,--whole-file}'[match whole files rather than hunks]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
