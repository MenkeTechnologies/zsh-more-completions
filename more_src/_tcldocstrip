#compdef tcldocstrip
# Documentation: https://core.tcl-lang.org/tcllib/doc/trunk/embedded/md/tcllib/files/apps/tcldocstrip.md
# Reference accessed: 2026-05-21
# Verified: upstream tcllib docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-guards[show all guards in file]' \
  '-metaprefix[string replacing %% metacomment prefix]:prefix:' \
  '-onerror[error handling mode]:mode:(ignore puts throw)' \
  '-trimlines[remove trailing spaces before processing]:bool:(true false)' \
  '-preamble[user content for file preamble]:text:' \
  '-postamble[user content for file postamble]:text:' \
  '-nopreamble[deactivate file preambles]' \
  '-nopostamble[deactivate file postambles]' \
  '*:input/output file:_files' && ret=0

return ret
