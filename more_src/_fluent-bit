#compdef fluent-bit

# Zsh completion for fluent-bit - Fluent Bit log processor

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[configuration file]:file:_files' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '(-f --flush)'{-f,--flush}'[flush timeout in seconds]:seconds:' \
  '(-g --grace)'{-g,--grace}'[grace period in seconds for shutdown]:seconds:' \
  '--http[enable built-in HTTP server]' \
  '(-P --port)'{-P,--port}'[set HTTP server TCP port]:port:' \
  '(-H --hot-reload)'{-H,--hot-reload}'[enable hot reload]' \
  '*'{-i,--input}'[set input plugin]:plugin:' \
  '*'{-F,--filter}'[set filter plugin]:plugin:' \
  '(-m --match)'{-m,--match}'[set tag match pattern]:pattern:' \
  '(-M --match-tag)'{-M,--match-tag}'[set tag match pattern]:pattern:' \
  '*'{-o,--output}'[set output plugin]:plugin:' \
  '(-R --parser)'{-R,--parser}'[parsers configuration file]:file:_files' \
  '*'{-p,--prop}'[set plugin property]:key=value:' \
  '(-e --plugin)'{-e,--plugin}'[load external plugin]:file:_files' \
  '(-l --logfile)'{-l,--logfile}'[log file path]:file:_files' \
  '(-v --log_level)'{-v,--log_level}'[set logging verbosity]:level:(off error warn info debug trace)' \
  '(-w --workdir)'{-w,--workdir}'[set working directory]:directory:_directories' \
  '(-S --storage-path)'{-S,--storage-path}'[set storage path for stream processing]:directory:_directories' \
  '--enable-chunk-trace[enable chunk tracing]' \
  '--dry-run[test configuration and exit]' \
  '--sosreport[print system report]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, suppress output]' && ret=0

return ret
