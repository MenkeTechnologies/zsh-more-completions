#compdef kubefirst
# Documentation: upstream cmd/ tree at github.com/konstructio/kubefirst
# Reference accessed: 2026-05-30 via gh api inspection of every
# cmd/*/command.go AddCommand list.
# kubefirst R62 — multi-cloud GitOps platform installer
# (konstructio/kubefirst). Cobra Go CLI with deep nested subcommand
# tree across 9 cloud-provider sub-state-machines + 8 utility commands.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'aws:create/destroy/manage the kubefirst platform on AWS'
  'akamai:create/destroy/manage the kubefirst platform on Akamai'
  'azure:create/destroy/manage the kubefirst platform on Azure'
  'civo:create/destroy/manage the kubefirst platform on Civo'
  'digitalocean:create/destroy/manage the kubefirst platform on DigitalOcean'
  'google:create/destroy/manage the kubefirst platform on Google Cloud'
  'vultr:create/destroy/manage the kubefirst platform on Vultr'
  'k3d:local k3d-based kubefirst platform'
  'k3s:k3s-based kubefirst platform'
  'local:local k3d-based kubefirst platform (alias of k3d)'
  'generate:code generator helpers'
  'info:provides general Kubefirst setup data'
  'launch:console + api instance lifecycle'
  'letsencrypt:interact with LetsEncrypt certificates for a domain'
  'logs:kubefirst real time logs'
  'reset:remove local kubefirst content to provision a new platform'
  'terraform:interact with terraform'
  'version:show version'
  'help:show help'
)

# Provider subcommand families
local -a _aws_subs _civo_subs _k3d_subs _common_subs _launch_subs
_aws_subs=(
  'create:create the kubefirst platform running in aws'
  'destroy:destroy the kubefirst platform'
  'quota:check aws quota status'
  'root-credentials:retrieve root authentication information for platform components'
)
_civo_subs=(
  'backup-ssl:backup SSL certificates'
  'create:create the kubefirst platform running in civo'
  'destroy:destroy the kubefirst platform'
  'quota:check civo quota status'
  'root-credentials:retrieve root authentication information for platform components'
)
_k3d_subs=(
  'create:create the kubefirst platform running locally on k3d'
  'destroy:destroy the kubefirst platform'
  'mkcert:create local certificates trusted by the host system'
  'root-credentials:retrieve root authentication information for platform components'
  'unseal-vault:unseal the running vault instance'
)
_common_subs=(
  'create:create the kubefirst platform'
  'destroy:destroy the kubefirst platform'
  'root-credentials:retrieve root authentication information for platform components'
)
_launch_subs=(
  'up:launch new console and api instance'
  'down:remove console and api instance'
  'cluster:interact with clusters created by the Kubefirst console'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[kubefirst config file]:file:_files' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'kubefirst subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      aws)
        _arguments -C \
          '(-): :->aws_sub' \
          '(-)*:: :->aws_sub_args' && ret=0
        case $state in
          aws_sub) _describe -t commands 'kubefirst aws subcommand' _aws_subs && ret=0 ;;
        esac
        ;;
      civo)
        _arguments -C \
          '(-): :->civo_sub' \
          '(-)*:: :->civo_sub_args' && ret=0
        case $state in
          civo_sub) _describe -t commands 'kubefirst civo subcommand' _civo_subs && ret=0 ;;
        esac
        ;;
      k3d|local)
        _arguments -C \
          '(-): :->k3d_sub' \
          '(-)*:: :->k3d_sub_args' && ret=0
        case $state in
          k3d_sub) _describe -t commands "kubefirst $words[1] subcommand" _k3d_subs && ret=0 ;;
        esac
        ;;
      akamai|azure|digitalocean|google|k3s|vultr)
        _arguments -C \
          '(-): :->prov_sub' \
          '(-)*:: :->prov_sub_args' && ret=0
        case $state in
          prov_sub) _describe -t commands "kubefirst $words[1] subcommand" _common_subs && ret=0 ;;
        esac
        ;;
      launch)
        _arguments -C \
          '(-): :->launch_sub' \
          '(-)*:: :->launch_sub_args' && ret=0
        case $state in
          launch_sub) _describe -t commands 'kubefirst launch subcommand' _launch_subs && ret=0 ;;
          launch_sub_args)
            case $words[1] in
              cluster)
                _arguments \
                  '1:cluster action:(list delete)' \
                  '2:cluster name:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      terraform)
        _arguments \
          '1:terraform subcommand:((set-env\:retrieve\ data\ from\ a\ target\ vault\ secret\ and\ format\ it\ for\ use\ in\ the\ local\ shell\ via\ environment\ variables))' \
          && ret=0
        ;;
      letsencrypt)
        _arguments \
          '1:letsencrypt subcommand:((status\:check\ usage\ statistics\ for\ a\ LetsEncrypt\ certificate))' \
          && ret=0
        ;;
      generate)
        _arguments \
          '1:generate subcommand:((app-scaffold\:scaffold\ the\ gitops\ application\ repo))' \
          && ret=0
        ;;
      info|logs|reset|version|help)
        _arguments '*:positional:' && ret=0
        ;;
    esac
    ;;
esac

return ret
