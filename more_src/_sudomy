#compdef sudomy
# Documentation: https://github.com/screetsec/Sudomy/blob/master/sudomy
# Subdomain enumeration and automated reconnaissance tool

local ret=1

_arguments -s -S \
  '(-d --domain)'{-d,--domain}'[specify the target domain to scan]:domain' \
  '(-a --all)'{-a,--all}'[execute all enumeration without nmap and gobuster]' \
  '(-b --bruteforce)'{-b,--bruteforce}'[brute-force subdomains using Gobuster with SecList wordlists]' \
  '(-o --outfile)'{-o,--outfile}'[designate output file upon completion]:file:_files' \
  '(-s --sources)'{-s,--sources}'[select specific enumeration sources]:sources' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output mode]' \
  '(-aI --apps-identifier)'{-aI,--apps-identifier}'[identify web technologies]:tool' \
  '(-dP --db-port)'{-dP,--db-port}'[collect port data from third-party APIs]' \
  '(-eP --extract-params)'{-eP,--extract-params}'[harvest URL parameters from search engines]' \
  '(-tO --takeover)'{-tO,--takeover}'[scan for subdomain takeover vulnerabilities]' \
  '(-wS --websocket)'{-wS,--websocket}'[check WebSocket connectivity]' \
  '(-cF --cloudfare)'{-cF,--cloudfare}'[verify IP ownership by Cloudflare]' \
  '(-pS --ping-sweep)'{-pS,--ping-sweep}'[identify active hosts via ping sweep]' \
  '(-rS --resolver)'{-rS,--resolver}'[convert domain lists to IP addresses, removing duplicates]' \
  '(-sC --status-code)'{-sC,--status-code}'[retrieve HTTP status codes and responses]' \
  '(-nT --nmap-top)'{-nT,--nmap-top}'[execute port scanning on top ports using nmap]' \
  '(-sS --screenshot)'{-sS,--screenshot}'[capture website screenshots]' \
  '(-nP --no-passive)'{-nP,--no-passive}'[skip passive subdomain enumeration]' \
  '(-gW --gwordlist)'{-gW,--gwordlist}'[generate wordlists from collected URL resources]' \
  '--httpx[run httpx probers with retryablehttp]' \
  '--dnsx[perform DNS queries using dnsx]' \
  '--no-probe[disable httprobe functionality]' \
  '--html[generate HTML-formatted reports]' \
  '--graph[create network graph visualization]' \
  '--slack[send Slack notifications upon completion]' \
  '(-h --help)'{-h,--help}'[display help message]' && ret=0

return ret
