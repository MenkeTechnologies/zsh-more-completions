#compdef opa

_opa_commands() {
  local -a commands=(
    'bench:Benchmark a Rego query'
    'build:Build an OPA bundle'
    'check:Check Rego source files'
    'capabilities:Print capabilities'
    'completions:Generate shell completions'
    'deps:Analyze Rego query dependencies'
    'eval:Evaluate a Rego query'
    'exec:Execute against input files'
    'fmt:Format Rego source files'
    'inspect:Inspect OPA bundle(s)'
    'parse:Parse Rego source file'
    'run:Start OPA in interactive or server mode'
    'sign:Generate an OPA bundle signature'
    'test:Execute Rego test cases'
    'version:Print the version of OPA'
    'help:Help about any command'
  )
  _describe 'command' commands
}

_opa() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[help for opa]' \
    '1:command:_opa_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        eval)
          _arguments \
            '(-b --bundle)'{-b,--bundle}'=[load bundle]:path:_files' \
            '(-d --data)'{-d,--data}'=[load data]:path:_files' \
            '(-f --format)'{-f,--format}'=[output format]:format:(json bindings values pretty source raw)' \
            '(-i --input)'{-i,--input}'=[input file]:file:_files' \
            '--fail[exit with non-zero on undefined/empty result]' \
            '--fail-defined[exit with non-zero on defined result]' \
            '--import=[set query import]:import' \
            '--instrument[enable instrumentation]' \
            '--metrics[report metrics]' \
            '--package=[set query package]:package' \
            '--partial[perform partial evaluation]' \
            '--profile[enable profiling]' \
            '--profile-limit=[set profile limit]:limit' \
            '--profile-sort=[profile sort order]:order' \
            '--schema=[set schema]:file:_files' \
            '--stdin[read query from stdin]' \
            '--stdin-input[read input from stdin]' \
            '--strict-builtin-errors[treat builtin errors as fatal]' \
            '--unknowns=[set partial evaluation unknowns]:unknowns' \
            '*:query'
          ;;
        run)
          _arguments \
            '(-a --addr)'{-a,--addr}'=[listening address]:address' \
            '--authentication=[authentication scheme]:scheme:(off token)' \
            '--authorization=[authorization scheme]:scheme:(off basic)' \
            '(-b --bundle)'{-b,--bundle}'[load bundle]' \
            '--config-file=[config file]:file:_files' \
            '--diagnostic-addr=[diagnostic address]:address' \
            '(-f --format)'{-f,--format}'=[shell output format]:format:(json pretty)' \
            '--h2c[enable H2C]' \
            '--history=[history file]:file:_files' \
            '--log-format=[log format]:format:(text json json-pretty)' \
            '--log-level=[log level]:level:(debug info warn error)' \
            '--max-errors=[max errors]:count' \
            '(-s --server)'{-s,--server}'[start as server]' \
            '--set=[override config value]:key=value' \
            '--set-file=[override config from file]:key=path' \
            '--tls-ca-cert-file=[TLS CA cert]:file:_files' \
            '--tls-cert-file=[TLS cert]:file:_files' \
            '--tls-private-key-file=[TLS key]:file:_files' \
            '(-w --watch)'{-w,--watch}'[watch for changes]' \
            '*:paths:_files'
          ;;
        test)
          _arguments \
            '(-b --bundle)'{-b,--bundle}'[load bundle]' \
            '--bench[run benchmarks]' \
            '--count=[number of times to repeat]:count' \
            '(-f --format)'{-f,--format}'=[output format]:format:(pretty json)' \
            '--ignore=[ignore files matching pattern]:pattern' \
            '--max-errors=[max errors]:count' \
            '(-r --run)'{-r,--run}'=[filter test cases]:regex' \
            '--threshold=[coverage threshold]:percent' \
            '--timeout=[test timeout]:timeout' \
            '(-v --verbose)'{-v,--verbose}'[set verbose output]' \
            '(-c --coverage)'{-c,--coverage}'[report coverage]' \
            '*:paths:_files'
          ;;
        build)
          _arguments \
            '(-b --bundle)'{-b,--bundle}'[build bundle]' \
            '(-d --debug)'{-d,--debug}'[enable debug output]' \
            '--entrypoint=[set entrypoint]:entrypoint' \
            '(-O --optimize)'{-O,--optimize}'=[optimization level]:level:(0 1 2)' \
            '(-o --output)'{-o,--output}'=[output file]:file:_files' \
            '(-r --revision)'{-r,--revision}'=[set revision]:revision' \
            '--target=[set target]:target:(rego wasm plan)' \
            '*:paths:_files'
          ;;
        fmt)
          _arguments \
            '(-d --diff)'{-d,--diff}'[only display diff]' \
            '--fail[exit with non-zero on diff]' \
            '(-l --list)'{-l,--list}'[list files that would change]' \
            '(-w --write)'{-w,--write}'[overwrite source files]' \
            '--rego-v1[format as Rego v1]' \
            '*:file:_files'
          ;;
        check)
          _arguments \
            '(-b --bundle)'{-b,--bundle}'[load bundle]' \
            '(-f --format)'{-f,--format}'=[output format]:format:(json pretty)' \
            '--max-errors=[max errors]:count' \
            '--strict[enable strict checks]' \
            '*:file:_files'
          ;;
        inspect)
          _arguments \
            '(-f --format)'{-f,--format}'=[output format]:format:(json pretty)' \
            '*:bundle:_files'
          ;;
        completions)
          _arguments \
            '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_opa "$@"
