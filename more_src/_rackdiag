#compdef rackdiag
# Documentation: http://blockdiag.com/en/nwdiag/
# rackdiag - generate rack-structure diagram images from text

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --antialias)'{-a,--antialias}'[pass diagram image to anti-alias filter]' \
  '(-c --config)'{-c,--config}'[read configurations from FILE]:config:_files' \
  '--debug[enable debug mode]' \
  '-o[write diagram to FILE]:output:_files' \
  '(-f --font)'{-f,--font}'[use FONT to draw diagram]:font:_files' \
  '--fontmap=[use FONTMAP file to draw diagram]:fontmap:_files' \
  '--no-transparency[do not make transparent background (PNG only)]' \
  '--size=[size of diagram (ex. 320x240)]:size' \
  '-T[output diagram as TYPE format]:type:(SVG PNG PDF)' \
  '--nodoctype[do not output doctype definition tags (SVG only)]' \
  '1:input file:_files' && ret=0

return ret
