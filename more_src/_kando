#compdef kando
# Documentation: https://docs.kanister.io/tooling.html
# Kanister object storage and phase-output tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --profile)'{-p,--profile=}'[Profile as JSON string]:profile' \
  '(-s --path)'{-s,--path=}'[path suffix]:path' \
  '1:command:(location output)' \
  '*::arg:_default' && ret=0

return ret
