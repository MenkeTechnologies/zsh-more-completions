#compdef gautomatch
# Documentation: https://hpc.nih.gov/apps/gautomatch.html
# gautomatch - GPU automatic particle picking for cryo-EM (Kai Zhang)

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--apixM[pixel size of the micrograph]:apix' \
  '--diameter[particle diameter in Angstrom]:diam' \
  '--boxsize[box size in pixels]:n' \
  '--min_dist[minimum distance between particles]:dist' \
  '--speed[picking speed (0 slow/accurate - 3 fast)]:speed' \
  '--ang_step[angular step for template matching]:step' \
  '--T[template stack file]:file:_files' \
  '--apixT[pixel size of the template]:apix' \
  '--dont_invertT[do not invert template contrast]:val' \
  '--lave_D[diameter for local average density estimation]:d' \
  '--lave_min[local average minimum cutoff]:val' \
  '--lave_max[local average maximum cutoff]:val' \
  '--lsigma_D[diameter for local sigma estimation]:d' \
  '--lsigma_cutoff[local sigma cutoff (1.2-1.5)]:val' \
  '--cc_cutoff[cross-correlation cutoff]:val' \
  '--lp[low-pass filter for picking, Angstrom]:res' \
  '--hp[high-pass filter for picking, Angstrom]:res' \
  '--do_pre_filter[pre-filter micrographs before picking]:val' \
  '--pre_lp[low-pass for pre-filtering, Angstrom]:res' \
  '--pre_hp[high-pass for pre-filtering, Angstrom]:res' \
  '--detect_ice[detect ice/contamination]:val' \
  '--T_norm_type[template normalization type]:t' \
  '--do_bandpass[apply bandpass filter]:val' \
  '--exclusive_picking[exclusive picking mode]:val' \
  '--excluded_suffix[suffix of excluded-region box files]:suffix' \
  '--global_excluded_box[global excluded box file]:file:_files' \
  '--write_ccmax_mic[write cross-correlation max micrograph]:val' \
  '--write_pref_mic[write pre-filtered micrograph]:val' \
  '--write_bg_mic[write background micrograph]:val' \
  '--write_bgfree_mic[write background-subtracted micrograph]:val' \
  '--write_lsigma_mic[write local-sigma micrograph]:val' \
  '--write_mic_mask[write micrograph mask]:val' \
  '--gid[GPU device id]:gid' \
  '*:micrograph:_files' && ret=0

return ret
