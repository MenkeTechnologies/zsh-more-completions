#compdef m3em_agent
# Documentation: https://github.com/m3db/m3/tree/master/src/cmd/services/m3em_agent
# M3 environment manager agent (runs M3 binaries on remote hosts for testing)

local ret=1

_arguments -s -S \
  '(-f --config-file)'{-f,--config-file}'[configuration file]:config file:_files' && ret=0

return ret
