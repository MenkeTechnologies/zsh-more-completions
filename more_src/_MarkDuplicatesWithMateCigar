#compdef MarkDuplicatesWithMateCigar
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#MarkDuplicatesWithMateCigar
# Picard: mark duplicate reads using the MC (mate cigar) tag in a single pass

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  '*'{-I=,--INPUT=}'[input SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output file with duplicates marked]:bam:_files -g "*.(bam|sam)"' \
  {-M=,--METRICS_FILE=}'[file to write duplication metrics to]:file:_files' \
  '--REMOVE_DUPLICATES=[remove duplicate reads instead of marking them]:bool:(true false)' \
  '--ASSUME_SORTED=[assume input is coordinate sorted]:bool:(true false)' \
  '--DUPLICATE_SCORING_STRATEGY=[strategy for scoring duplicates]:strategy:(SUM_OF_BASE_QUALITIES TOTAL_MAPPED_REFERENCE_LENGTH RANDOM)' \
  '--READ_NAME_REGEX=[regex for parsing read names for optical duplicates]:regex:' \
  '--OPTICAL_DUPLICATE_PIXEL_DISTANCE=[max pixel distance for optical duplicates]:int:' \
  '--MINIMUM_DISTANCE=[buffer distance to account for 5-prime clipping]:int:' \
  '--BLOCK_SIZE=[block size for the coordinate-sorted record buffer]:int:' \
  '--PROGRAM_RECORD_ID=[program record ID for the SAM header]:id:' \
  '*--COMMENT=[comment to add to the output header]:comment:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
