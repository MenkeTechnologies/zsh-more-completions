#compdef glaredb
# Documentation: https://github.com/GlareDB/glaredb/blob/main/crates/glaredb/src/main.rs
# GlareDB: a light and fast SQL database for analytics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--init=[execute a file containing SQL statements and continue]:file:_files' \
  '*'{-f,--files}'=[execute a file containing SQL statements then exit]:file:_files' \
  '*'{-c,--commands}'=[execute SQL commands then exit]:sql' \
  '*:file:_files' && ret=0

return ret
