#compdef seq66 qseq66
# Documentation: https://man.archlinux.org/search?q=seq66
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --manual-ports)'{-m,--manual-ports}'[manual ports]' \
  '(-a --auto-ports)'{-a,--auto-ports}'[auto ports]' \
  '(-s --showmidi)'{-s,--showmidi}'[show midi events]' \
  '(-J --jack-transport)'{-J,--jack-transport}'[JACK transport]' \
  '(-M --jack-master)'{-M,--jack-master}'[JACK master]' \
  '(-C --jack-master-cond)'{-C,--jack-master-cond}'[conditional JACK master]' \
  '(-Z --jack-start-mode)'{-Z,--jack-start-mode}'+[jack start mode]:mode:(live song)' \
  '(-i --interaction-method)'{-i,--interaction-method}'+[mouse method]:m:' \
  '(-H --home)'{-H,--home}'+[home dir]:dir:_files -/' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-P --pass-sysex)'{-P,--pass-sysex}'[pass sysex]' \
  '*:midi file:_files -g "*.{midi,mid}"' && ret=0

return ret
