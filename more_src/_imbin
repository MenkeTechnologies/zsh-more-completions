#compdef imbin
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imbin.html
# MIRIAD imbin - bin up (average or sum) an image

local ret=1

_arguments -s -S \
  'in=[input image file (wildcards allowed)]:in:_files' \
  'region=[region of interest within the image]:region' \
  'bin=[spatial increment and binning size in pixels per axis]:bin' \
  'out=[output image file]:out:_files' \
  'options=[sum produces totals rather than averages]:options:(sum)' \
  '*:image:_files' && ret=0

return ret
