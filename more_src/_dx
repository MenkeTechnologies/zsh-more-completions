#compdef dx

# Zsh completion for dx (Dioxus CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'new:create a new Dioxus project'
      'init:initialize a Dioxus project in current directory'
      'build:build the project'
      'serve:serve the project'
      'bundle:bundle the project for distribution'
      'clean:clean build artifacts'
      'translate:translate HTML to RSX'
      'fmt:format RSX code'
      'check:check the project'
      'config:manage Dioxus configuration'
      'link:link to a running project'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      build|serve)
        _arguments -s -S \
          '--release[build in release mode]' \
          '--target=[target platform]:platform:(web desktop)' \
          '--features=[cargo features]:features' \
          '--example=[build an example]:example' \
          '--platform=[target platform]:platform:(web desktop fullstack liveview)' \
          '--port=[port to serve on]:port' \
          '--hot-reload[enable hot reloading]' \
          '--verbose[verbose output]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      new)
        _arguments -s -S \
          '--template=[project template]:template:(default)' \
          '--platform=[target platform]:platform:(web desktop fullstack)' \
          '(- *)'{-h,--help}'[show help]' \
          '1:project name' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '--check[check if formatted]' \
          '--file=[specific file]:file:_files -g "*.rs"' \
          '--raw=[raw RSX string]:rsx' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      translate)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'[input file]:file:_files' \
          '--raw=[raw HTML string]:html' \
          '--component[output as a component]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
