#compdef bsetroot
# Documentation: https://manpages.debian.org/bookworm/blackbox/bsetroot.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm bsetroot(1) manpage. X11-style single-dash long
# options, not GNU --form.
# Removed from prior file: fabricated --help/--version flags and bogus
# man.archlinux.org search URL.

# bsetroot: set Blackbox root window background
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[print version and short help]' \
  '-display[X display]:display:' \
  '-solid[set root window to color]:color:' \
  '-mod[modula pattern (x y)]:x y:' \
  '-gradient[texture string]:texture:' \
  '(-background)-bg[background color]:color:' \
  '(-bg)-background[background color]:color:' \
  '(-foreground)-fg[foreground color]:color:' \
  '(-fg)-foreground[foreground color]:color:' \
  '-from[gradient start color]:color:' \
  '-to[gradient end color]:color:' && ret=0
return ret
