#compdef bestcryptve2john kdcdump2john lion2john lion2john-alt mac2john-alt mcafee_epo2john money2john mozilla2john multibit2john neo2john
# Documentation: https://github.com/openwall/john (bleeding-jumbo branch)
#                — sources read directly from run/*.py and run/*.pl
# Reference accessed: 2026-05-30
# John the Ripper *2john helpers, round 5. Extends rounds 144-147 with 10
# more hash extractors covering Jetico BestCrypt Volume, Kerberos KDC dump,
# OS X 10.7 Lion (two variants), OS X / macOS 10.8+ (-alt Python 2 variant),
# McAfee ePolicy Orchestrator, MS Money 2002-2007, Mozilla key3.db,
# MultiBit (Classic / HD), and Neo wallet .db3.
# Surfaces transcribed from upstream source rather than from Debian
# dyn-redirect manpages (which 404).

local curcontext="$curcontext" state line ret=1

case $service in

  bestcryptve2john)
    # run/bestcryptve2john.py — Jetico BestCrypt Volume encryption extractor.
    # Argparse-driven: -h/--help + optional --offset N + 1 required positional.
    _arguments -s -S \
      '(- *)-h[show help and exit]' \
      '(- *)--help[show help and exit]' \
      '--offset=[byte offset to BestCrypt partition (default 0)]:N:' \
      '1:disk or partition image:_files' \
      && ret=0
    ;;

  kdcdump2john)
    # run/kdcdump2john.py — Kerberos KDC dump → JtR converter.
    # Single positional. Identifies format types 23 (RC4-HMAC) and 18 (AES256).
    _arguments -s -S \
      '1:Kerberos KDC dump file:_files' \
      && ret=0
    ;;

  lion2john)
    # run/lion2john.pl — OS X 10.7 Lion salted SHA-512 plist extractor.
    # Reads up to 1 MB per file. Substitutes "UNKNOWN_USERNAME" when the
    # username field cannot be parsed.
    _arguments -s -S \
      '*:OS X Lion .plist file:_files -g "*.plist"' \
      && ret=0
    ;;

  lion2john-alt)
    # run/lion2john-alt.pl — alternative OS X Lion plist parser.
    # Same surface as lion2john (1+ plist files, no flags).
    _arguments -s -S \
      '*:OS X Lion .plist file:_files -g "*.plist"' \
      && ret=0
    ;;

  mac2john-alt)
    # run/mac2john-alt.py — Python 2 variant of mac2john for OS X / macOS
    # 10.8+ ShadowHashData. The companion src/_mac2john covers the
    # Python 3 mainline; this stem covers the legacy Python 2 alternative.
    _arguments -s -S \
      '*:macOS .plist file:_files -g "*.plist"' \
      && ret=0
    ;;

  mcafee_epo2john)
    # run/mcafee_epo2john.py — McAfee ePO OrionUsers CSV converter.
    # 1+ positionals; arg "-" reads stdin instead of a file.
    # CSV columns: 1=username, 2=AuthURI; default separator comma.
    _arguments -s -S \
      '*:dbo.OrionUsers CSV extract (or "-" for stdin):_files -g "*.csv"' \
      && ret=0
    ;;

  money2john)
    # run/money2john.py — MS Money 2002-2007 / Money Plus encrypted DB.
    # Output type byte: 1 = SHA1, 0 = MD5.
    _arguments -s -S \
      '*:MS Money encrypted database:_files' \
      && ret=0
    ;;

  mozilla2john)
    # run/mozilla2john.py — Mozilla key3.db master-password extractor.
    _arguments -s -S \
      '*:Mozilla key3.db file:_files -g "key3.db|*.db"' \
      && ret=0
    ;;

  multibit2john)
    # run/multibit2john.py — MultiBit Classic or HD wallet extractor.
    # Accepts .key (Classic key backup), .wallet (Classic), or
    # mbhd.wallet.aes (HD).
    _arguments -s -S \
      '*:MultiBit wallet file:_files -g "*.(key|wallet|aes)"' \
      && ret=0
    ;;

  neo2john)
    # run/neo2john.py — Neo wallet .db3 SQLite extractor. Queries Key table
    # for rows where the first column equals 'PasswordHash'.
    _arguments -s -S \
      '*:Neo wallet .db3 file:_files -g "*.db3"' \
      && ret=0
    ;;

esac

return ret
