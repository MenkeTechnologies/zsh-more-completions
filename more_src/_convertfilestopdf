#compdef convertfilestopdf
# Documentation: http://www.leptonica.org/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above; positional args from
# `convertfilestopdf` usage output (leptonica 1.87.0).

# Syntax: convertfilestopdf dirin substr res scalefactor encoding_type quality title fileout

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:input directory:_files -/' \
  '2:substring (allfiles for all):' \
  '3:input resolution (DPI):' \
  '4:scale factor:' \
  '5:encoding type:((0\:default 1\:jpeg 2\:g4 3\:flate 4\:jp2k))' \
  '6:quality (jpeg 1-100 / jp2k 27-45 / 0=default):' \
  '7:title (none to omit):' \
  '8:output file:_files -g "*.pdf"' && ret=0

return ret
