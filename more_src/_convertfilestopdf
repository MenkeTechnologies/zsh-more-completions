#compdef convertfilestopdf
# Documentation: https://man.archlinux.org/search?q=convertfilestopdf
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:input directory:_files -/' \
  '2:substring (allfiles for all):' \
  '3:input resolution (DPI):' \
  '4:scale factor:' \
  '5:encoding type:(default jpeg g4)' \
  '6:quality:' \
  '7:title:' \
  '8:output file:_files -g "*.pdf"' && ret=0

return ret
