#compdef git-jump

local curcontext="$curcontext" state line ret=1
local -a modes

modes=(
  'diff:jump to changes not yet staged'
  'merge:jump to merge conflicts'
  'grep:jump to all matches of a pattern'
)

_arguments -C \
  '--stdout[print listing instead of opening editor]' \
  '--cached[diff: show staged changes]' \
  '-i[grep: case-insensitive]' \
  '1: :->mode' \
  '*::arg:->args' && ret=0

case $state in
  (mode)
    _describe -t modes 'git-jump mode' modes && ret=0
    ;;
esac

return ret
