#compdef bandit bandit-baseline bandit-config-generator

local curcontext="$curcontext" state line ret=1

case $service in
  (bandit)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '*'{-r,--recursive}'[scan recursively]' \
      '(-a --aggregate)'{-a+,--aggregate=}'[aggregate by]:m:(file vuln)' \
      '(-n --number)'{-n+,--number=}'[context lines]:n:' \
      '(-c --configfile)'{-c+,--configfile=}'[config file]:file:_files -g "*.yml *.yaml"' \
      '(-p --profile)'{-p+,--profile=}'[profile]:p:' \
      '(-t --tests)*'{-t+,--tests=}'[tests csv]:list:' \
      '(-s --skip)*'{-s+,--skip=}'[skip tests csv]:list:' \
      '(-l --level)*'{-l,--level}'[severity level]' \
      '(-i --confidence)*'{-i,--confidence}'[confidence level]' \
      '(--severity-level)--severity-level=[severity]:l:(low medium high all)' \
      '(--confidence-level)--confidence-level=[confidence]:l:(low medium high all)' \
      '(-f --format)'{-f+,--format=}'[output format]:f:(csv custom html json screen txt xml yaml sarif)' \
      '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-d --debug)'{-d,--debug}'[debug]' \
      '(-q --quiet --silent)'{-q,--quiet,--silent}'[silent]' \
      '(--ignore-nosec)--ignore-nosec[ignore nosec]' \
      '(-x --exclude)'{-x+,--exclude=}'[exclude paths csv]:list:' \
      '(-b --baseline)'{-b+,--baseline=}'[baseline file]:file:_files' \
      '(--ini)--ini=[ini config]:file:_files' \
      '(--exit-zero)--exit-zero[exit 0]' \
      '(--msg-template)--msg-template=[message template]:t:' \
      '(-w --tests-properties)--tests-properties=[test props]:s:' \
      '*: :_files' && ret=0 ;;
  (bandit-baseline)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-c --configfile)'{-c+,--configfile=}'[config file]:file:_files' \
      '(-f --format)'{-f+,--format=}'[format]:f:(csv html json screen txt xml yaml)' \
      '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
      '*: :_files' && ret=0 ;;
  (bandit-config-generator)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-l --show-defaults)'{-l,--show-defaults}'[show defaults]' \
      '(-o --out)'{-o+,--out=}'[output file]:file:_files' \
      '(-t --tests)*'{-t+,--tests=}'[tests csv]:list:' \
      '(-s --skips)*'{-s+,--skips=}'[skips csv]:list:' \
      '*: :_files' && ret=0 ;;
esac

return ret
