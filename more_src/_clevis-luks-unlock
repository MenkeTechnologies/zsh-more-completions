#compdef clevis-luks-unlock
# Documentation: https://github.com/latchset/clevis/blob/master/src/luks/clevis-luks-unlock
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# clevis luks unlock: unlock clevis-bound LUKS volume
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-d[LUKS device]:device:_files' \
  '-n[mapped device name]:name:' \
  '-t[test passphrase for a given slot without unlocking]:slot:' \
  '-o[options passed to cryptsetup]:opts:' && ret=0
return ret
