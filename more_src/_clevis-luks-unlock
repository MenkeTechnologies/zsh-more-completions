#compdef clevis-luks-unlock
# Documentation: https://man.archlinux.org/search?q=clevis-luks-unlock
# Reference accessed: 2026-05-16

# clevis luks unlock: unlock clevis-bound LUKS volume
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-d[LUKS device]:device:_files' \
  '-n[mapped device name]:name:' \
  '-s[LUKS keyslot]:slot:' \
  '*:LUKS device:_files' && ret=0
return ret
