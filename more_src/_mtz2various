#compdef mtz2various
# Documentation: https://www.ccp4.ac.uk/html/mtz2various.html
# mtz2various — convert MTZ reflection data to various ASCII formats (CCP4)

local ret=1

_arguments -s -S \
  'HKLIN[input MTZ]:file:_files -g "*.mtz"' \
  'HKLOUT[output ASCII reflections]:file:_files' \
  'OUTPUT[output format]:fmt:(MULTAN SHELX SHELXDiff TNT CIF XPLOR CNS MAIN SCAL USER)' \
  'LABIN[input column assignments]:labels:' \
  'RESOLUTION[resolution range]:lim:' \
  'FSQUARED[convert F/SIGF to I/SIGI]' \
  'SCALE[scaling factor]:scale:' \
  'FORMAT[user FORTRAN format]:fmt:' \
  'INCLUDE[include reflections matching criteria]:opt:' \
  'EXCLUDE[exclude reflections]:opt:' \
  'FREEVAL[free-R test set value]:n:' \
  'MISS[output value for missing data]:valm:' \
  'MONITOR[print every nth reflection]:n:' \
  'END[terminate input]' \
  '*:argument:_files' && ret=0

return ret
