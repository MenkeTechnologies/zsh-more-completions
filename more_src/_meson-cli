#compdef meson
# _meson-cli — Meson next-gen build system (Jussi Pakkanen + Meson community, Python); generator for Ninja with Python DSL
# upstream: https://github.com/mesonbuild/meson

_meson-cli() {
    local -a sub=(
        'compile:compile a project'
        'configure:reconfigure project'
        'devenv:run command in developer env'
        'dist:generate release tarball'
        'env2mfile:convert env to mfile'
        'format:format Meson files'
        'help:show help'
        'init:create new project'
        'install:install built project'
        'introspect:print introspection info'
        'rewrite:rewrite Meson files'
        'setup:configure project (build)'
        'subprojects:subprojects'
        'test:run tests'
        'version:show version'
        'wrap:wrap commands'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'meson subcommand' sub ;;
        args)
            case $words[1] in
                setup) _arguments \
                    '--prefix+[prefix]:dir:_files -/' \
                    '--bindir+[bindir]:dir:_files -/' \
                    '--libdir+[libdir]:dir:_files -/' \
                    '--includedir+[includedir]:dir:_files -/' \
                    '--datadir+[datadir]:dir:_files -/' \
                    '--mandir+[mandir]:dir:_files -/' \
                    '--sysconfdir+[sysconfdir]:dir:_files -/' \
                    '--sharedstatedir+[sharedstatedir]:dir:_files -/' \
                    '--localstatedir+[localstatedir]:dir:_files -/' \
                    '--auto-features+[auto features]:val:(enabled disabled auto)' \
                    '--backend+[backend]:backend:(ninja vs vs2010 vs2012 vs2013 vs2015 vs2017 vs2019 vs2022 xcode)' \
                    '--buildtype+[buildtype]:type:(plain debug debugoptimized release minsize custom)' \
                    '--debug[debug]' \
                    '--optimization+[optimization]:level:(plain 0 g 1 2 3 s)' \
                    '--default-library+[default library]:type:(shared static both)' \
                    '--strip[strip]' \
                    '--unity+[unity build]:val:(on off subprojects)' \
                    '--werror[treat warnings as errors]' \
                    '--warnlevel+[warn level]:n:' \
                    '--cross-file+[cross-compile file]:file:_files' \
                    '--native-file+[native file]:file:_files' \
                    '-D+[set option]:KEY=VAL:' \
                    '--Dx+[set option]:KEY=VAL:' \
                    '--wipe[wipe build dir]' \
                    '--reconfigure[reconfigure]' \
                    '-Dwerror=+[werror]:bool:(true false)' \
                    '*:dir:_files -/' ;;
                compile) _arguments \
                    '--clean[clean before build]' \
                    '-j+[parallel jobs]:n:' \
                    '--jobs+[parallel jobs]:n:' \
                    '-l+[load average]:f:' \
                    '--load-average+[load average]:f:' \
                    '--verbose[verbose]' \
                    '-v[verbose]' \
                    '-C+[builddir]:dir:_files -/' \
                    '*:target:' ;;
                test) _arguments \
                    '--repeat+[repeat]:n:' \
                    '--timeout-multiplier+[timeout mult]:f:' \
                    '-q[quiet]' \
                    '--quiet[quiet]' \
                    '-v[verbose]' \
                    '--verbose[verbose]' \
                    '--print-errorlogs[print error logs]' \
                    '--list[list tests]' \
                    '--no-rebuild[no rebuild]' \
                    '--gdb[run under gdb]' \
                    '--num-processes+[parallel]:n:' \
                    '--suite+[suite]:str:' \
                    '--no-suite+[no suite]:str:' \
                    '--logbase+[log basename]:str:' \
                    '--wrapper+[test wrapper]:cmd:_command_names -e' \
                    '-C+[builddir]:dir:_files -/' \
                    '*:test:' ;;
                install) _arguments \
                    '--no-rebuild[no rebuild]' \
                    '--only-changed[only changed]' \
                    '--quiet[quiet]' \
                    '--dry-run[dry run]' \
                    '-n[dry run]' \
                    '--destdir+[destdir]:dir:_files -/' \
                    '--strip[strip]' \
                    '--skip-subprojects+[skip subprojects]:str:' \
                    '--tags+[tags]:str:' \
                    '-C+[builddir]:dir:_files -/' ;;
                subprojects) _arguments \
                    '1:subprojects cmd:(checkout download foreach packagefiles purge update)' \
                    '*:subproject:' ;;
                init) _arguments \
                    '--language+[language]:lang:(c cpp d fortran java rust objc objcpp vala cython)' \
                    '--name+[name]:str:' \
                    '--executable+[executable]:str:' \
                    '--deps+[deps]:str:' \
                    '--type+[project type]:type:(executable library)' \
                    '--builddir+[builddir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_meson-cli "$@"
