#compdef carla-discovery carla-discovery-native carla-discovery-posix32 carla-discovery-posix64 carla-discovery-win32 carla-discovery-win64
# Documentation: https://man.archlinux.org/search?q=carla-discovery
# Reference accessed: 2026-05-16

# Carla plugin discovery - scan a plugin and print its metadata
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:plugin type:(internal ladspa dssi lv2 vst2 vst3 clap au sfz sf2 jsfx)' \
  '*:plugin path:_files' && ret=0
return ret
