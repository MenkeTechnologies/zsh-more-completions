# Carla plugin discovery: scan a plugin file and print its metadata.
# Usage: carla-discovery <type> </path/to/plugin>

local curcontext="$curcontext" ret=1
_arguments -C \
  '1:plugin type:(internal ladspa dssi lv2 vst2 vst3 clap au sfz sf2 jsfx)' \
  '2:plugin path:_files' && ret=0
return ret
