#compdef ldapcompare
# _ldapcompare — OpenLDAP Foundation ldapcompare LDAP compare attribute value tool over LDAPv3 (openldap team, C); custom argparse
# upstream: https://www.openldap.org

_ldapcompare() {
    _arguments \
        '-h+[LDAP server]:host:_hosts' \
        '-H+[LDAP URI]:url:_urls' \
        '-p+[LDAP port]:port:_ports' \
        '-V[show version]' \
        '-?[show help]' \
        '-d+[debug level]:n:' \
        '-n[show what would be done]' \
        '-v[verbose mode]' \
        '-x[simple authentication]' \
        '-D+[bind DN]:str:' \
        '-w+[bind password]:str:' \
        '-W[prompt for bind password]' \
        '-y+[password file]:file:_files' \
        '-Y+[SASL mechanism]:str:' \
        '-U+[SASL authcid]:str:' \
        '-X+[SASL authzid]:str:' \
        '-R+[SASL realm]:str:' \
        '-O+[SASL security properties]:str:' \
        '-I[SASL prompt mode]' \
        '-N[no reverse DNS]' \
        '-Q[SASL quiet]' \
        '-Z[StartTLS]' \
        '-ZZ[require StartTLS]' \
        '-o+[option=value]:str:' \
        '-e+[criticality]:str:' \
        '-E+[extension]:str:' \
        '-M[manage DSA IT]' \
        '-MM[require manage DSA IT]' \
        '-z[quiet]' \
        '*:DN attr:val:'
}

_ldapcompare "$@"
