#compdef conda-index
# Documentation: https://conda.github.io/conda-index/cli.html
# conda-index: generate repodata.json and channel index for a conda channel directory

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--output=[output repodata to given directory]:dir:_files -/' \
  '*--subdir=[subdir to index]:subdir:' \
  '(-n --channel-name)'{-n,--channel-name}'=[channel name listed in index.html]:name:' \
  '--patch-generator=[path to Python file with patch instructions]:file:_files' \
  '--channeldata[generate channeldata.json]' \
  '--no-channeldata[do not generate channeldata.json]' \
  '--rss[write rss.xml (requires channeldata)]' \
  '--no-rss[do not write rss.xml]' \
  '--bz2[write repodata.json.bz2]' \
  '--no-bz2[do not write repodata.json.bz2]' \
  '--zst[write repodata.json.zst]' \
  '--no-zst[do not write repodata.json.zst]' \
  '--run-exports[write run_exports.json]' \
  '--no-run-exports[do not write run_exports.json]' \
  '--compact[output JSON as one line]' \
  '--no-compact[pretty-print JSON output]' \
  '(-m --current-index-versions-file)'{-m,--current-index-versions-file}'=[YAML file for current_index.json version filtering]:file:_files' \
  '--base-url=[URL of directory tree holding packages]:url:' \
  '--update-cache[refresh available packages list]' \
  '--no-update-cache[do not refresh available packages list]' \
  '--update-only[add local files without complete package set]' \
  '--no-update-only[require complete package set]' \
  '--upstream-stage=[generate example repodata from test database]:stage:' \
  '--current-repodata[generate current_repodata.json]' \
  '--no-current-repodata[do not generate current_repodata.json]' \
  '--threads=[number of threads to use]:threads:' \
  '--verbose[enable debug logging]' \
  '--write-monolithic[write all metadata in single file]' \
  '--no-write-monolithic[do not write monolithic metadata]' \
  '--write-shards[write sharded repodata per CEP-16]' \
  '--no-write-shards[do not write sharded repodata]' \
  '--db=[database backend (sqlite3 or postgresql)]:backend:(sqlite3 postgresql)' \
  '--db-url=[SQLAlchemy database URL for PostgreSQL]:url:' \
  '--html-dependencies[include dependency popups in HTML]' \
  '--no-html-dependencies[exclude dependency popups in HTML]' \
  '--repodata-next[write v3 repodata layout (experimental)]' \
  '--no-repodata-next[do not write v3 repodata layout]' \
  '*:dir:_files -/' && ret=0

return ret
