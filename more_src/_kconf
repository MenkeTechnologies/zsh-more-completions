#compdef kconf

# Zsh completion for kconf (kubeconfig manager)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'add:add a kubeconfig file'
      'remove:remove a context from kubeconfig'
      'list:list available contexts'
      'use:switch to a context'
      'view:view kubeconfig for a context'
      'namespace:set default namespace for a context'
      'export:export a context to a file'
      'help:show help for a subcommand'
    )
    _describe -t commands 'kconf subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      add)
        _files && ret=0
        ;;
      remove|use|view|namespace|export)
        _message 'context name' && ret=0
        ;;
    esac
    ;;
esac

return ret
