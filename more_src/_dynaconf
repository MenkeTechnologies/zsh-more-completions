#compdef dynaconf
# Documentation: https://www.dynaconf.com/cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dynaconf: Configuration Management for Python (click-based CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-i --instance)'{-i,--instance}'=[LazySettings instance reference]:instance:' \
  '--version[show version]' \
  '--docs[open documentation in browser]' \
  '--banner[show ASCII banner]' \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Inits a dynaconf project'
      'get:Returns the raw value for a settings key'
      'inspect:Inspect the loading history of a settings key (tech preview)'
      'list:Lists all defined config values'
      'write:Writes data to a specific source'
      'validate:Validates settings against rules defined in validators'
    )
    _describe -t commands 'dynaconf command' commands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'=[file format]:format:(ini toml yaml json py env)' \
          '(-p --path)'{-p,--path}'=[project root]:path:_files -/' \
          '(-v --vars)'{-v,--vars}'=[extra config values]:vars:' \
          '(-s --secrets)'{-s,--secrets}'=[secret key=value]:secrets:' \
          '-y[no confirmation]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      get)
        _arguments -s -S \
          '(-d --default)'{-d,--default}'=[default value]:default:' \
          '(-e --env)'{-e,--env}'=[filter by environment]:env:' \
          '(-u --unparse)'{-u,--unparse}'[add markers like @none, @int]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:key:' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '(-k --key)'{-k,--key}'=[filter by key]:key:' \
          '(-e --env)'{-e,--env}'=[filter by environment]:env:' \
          '(-f --format)'{-f,--format}'=[output format]:format:(yaml json json-compact)' \
          '(-m --report-mode)'{-m,--report-mode}'=[inspect mode]:mode:(inspect debug)' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-e --env)'{-e,--env}'=[filter by environment]:env:' \
          '(-k --key)'{-k,--key}'=[filter single key]:key:' \
          '(-o --output)'{-o,--output}'=[export to json file]:file:_files' \
          '(-a --all)'{-a,--all}'[include internal dynaconf vars]' \
          '(-l --loader)'{-l,--loader}'=[filter by loader]:loader:' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      write)
        _arguments -s -S \
          '(-v --vars)'{-v,--vars}'=[config values]:vars:' \
          '(-s --secrets)'{-s,--secrets}'=[secret values]:secrets:' \
          '(-p --path)'{-p,--path}'=[output file path]:path:_files' \
          '(-e --env)'{-e,--env}'=[target environment]:env:' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:source:(toml yaml json ini py env redis vault)' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '(-p --path)'{-p,--path}'=[validators file path]:path:_files' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
