#compdef dynaconf

# Zsh completion for dynaconf
# Upstream: Configuration Management for Python
# Conservative fallback — run `dynaconf --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
