#compdef myrescue
# _myrescue — myrescue (failing-disk rescue tool; copies blocks from src to dest with retry + skip strategy via blockmap; -B blockmap, -b block size, -r retries before skip, -R retries after skip, -A retries on second pass, -s start, -e end, -S skip-pass mode, -m max-stable seconds)
# upstream: https://github.com/jorre/myrescue
# Flags from myrescue myrescue.c on tip.

_myrescue() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-B+[blockmap file]:file:_files' \
        '-b+[block size bytes]:bytes:' \
        '-r+[retries before skip]:n:' \
        '-R+[retries after skip]:n:' \
        '-A+[retries on second pass]:n:' \
        '-s+[start block]:block:' \
        '-e+[end block]:block:' \
        '-S+[skip-pass strategy]:mode:(min max alt)' \
        '-m+[max stable seconds]:seconds:' \
        '-d[direct IO]' \
        '1:source:_files' \
        '2:destination:_files'
}

_myrescue "$@"
