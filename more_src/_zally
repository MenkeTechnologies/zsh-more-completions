#compdef zally
# Documentation: https://schweizerischebundesbahnen.github.io/zally/documentation/usage.html
# Minimalistic OpenAPI 2 and 3 linter (Zalando)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --linter-service)'{-l,--linter-service}'=[linter service URL]:url' \
  '(-t --token)'{-t,--token}'=[OAuth2 token]:token' \
  '--format=[output format]:format:(pretty markdown text)' \
  '--skip-ssl-verification[skip SSL certificate verification]' \
  '1:command:(lint rules)' \
  '*:spec:_files' && ret=0

return ret
