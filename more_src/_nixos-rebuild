#compdef nixos-rebuild

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--fast[skip building Nix]' \
  '--upgrade[fetch latest version of NixOS channel]' \
  '--upgrade-all[fetch latest version of all channels]' \
  '--install-bootloader[reinstall the bootloader]' \
  '--no-build-nix[do not build Nix before building system]' \
  '--rollback[roll back to previous configuration]' \
  '--builders[remote builders]:builders' \
  '--profile-name[profile name]:name' \
  '-p[profile name]:name' \
  '--build-host[host to build on]:host:_hosts' \
  '--target-host[host to activate on]:host:_hosts' \
  '--use-remote-sudo[use sudo on remote host]' \
  '--flake[flake URI]:flake URI' \
  '--no-flake[do not use flake]' \
  '--override-input[override flake input]:input: :flake URI' \
  '--show-trace[show evaluation trace on error]' \
  '--keep-going[keep going on build failure]' \
  '--keep-failed[keep build directory on failure]' \
  '--max-jobs[maximum parallel build jobs]:jobs' \
  '--cores[CPU cores per build]:cores' \
  '--option[set a Nix option]:name: :value' \
  '-I[add path to Nix expression search path]:path:_files' \
  '-v[increase verbosity level]' \
  '--impure[allow impure evaluation]' \
  '1: :->command' && ret=0

case $state in
  command)
    local -a commands=(
      'switch:build, activate, and update boot loader'
      'boot:build and update boot loader without activating'
      'test:build and activate without updating boot loader'
      'build:build without activating'
      'dry-build:show what would be built'
      'dry-activate:show what would change on activation'
      'edit:open NixOS configuration in editor'
      'build-vm:build a VM running the configuration'
      'build-vm-with-bootloader:build a VM with boot loader'
      'list-generations:list system generations'
    )
    _describe -t commands 'nixos-rebuild command' commands
    ;;
esac

return ret