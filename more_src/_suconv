#compdef suconv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/convolution_correlation/suconv.c
# SUCONV - convolution with user-supplied filter

local ret=1

_arguments -s -S \
  'sufile=[file containing SU trace to use as filter]:f:_files' \
  'filter=[user-supplied convolution filter (ascii)]:f:_files' \
  'panel=[use only first trace of sufile]:p:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
