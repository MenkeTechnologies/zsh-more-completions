#compdef sfewefd3d
# Documentation: https://raw.githubusercontent.com/ahay/src/master/user/psava/Mewefd3d.c
# Madagascar: 3D elastic time-domain finite-difference modeling

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'verb=[verbosity flag (y/n)]:flag:(y n)' \
  'snap=[wavefield snapshots (y/n)]:flag:(y n)' \
  'free=[free surface (y/n)]:flag:(y n)' \
  'ssou=[stress source (y/n)]:flag:(y n)' \
  'dabc=[absorbing boundary condition (y/n)]:flag:(y n)' \
  'opot=[output potentials (y/n)]:flag:(y n)' \
  'nbell=[bell size]:n:' \
  'jdata=[data sampling interval]:interval:' \
  'jsnap=[wavefield snapshot interval]:interval:' \
  'nqz=[depth samples in output]:n:' \
  'nqx=[x samples in output]:n:' \
  'nqy=[y samples in output]:n:' \
  'nb=[absorbing boundary thickness]:n:' \
  'oqz=[depth origin of output]:o:' \
  'oqx=[x origin of output]:o:' \
  'oqy=[y origin of output]:o:' \
  '*:RSF file:_files' && ret=0

return ret
