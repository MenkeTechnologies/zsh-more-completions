#compdef htcacheclean
# Documentation: htcacheclean (Apache httpd)
# Source: clean Apache mod_cache_disk on-disk cache.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-D -v -r)-d+[daemonize, repeat every INTERVAL minutes]:minutes:' \
    '(-d)-D[dry run]' \
    '(-d)-v[verbose statistics]' \
    '(-d)-r[clean thoroughly (assumes httpd down)]' \
    '-n[be nice (slower)]' \
    '-t[delete empty directories]' \
    '-p+[root directory of disk cache]:path:_files -/' \
    '-P+[pid file]:file:_files' \
    '-R+[round sizes up to]:bytes:' \
    '-l+[disk cache size limit]:limit:' \
    '-L+[disk cache inode limit]:limit:' \
    '-i[intelligent: only run when needed]' \
    '-A[list URLs in cache only]' \
    '-S[show statistics only]' \
    '-a[list URLs in cache with attributes]' \
    '*:url:_urls' \
    && ret=0

return ret
