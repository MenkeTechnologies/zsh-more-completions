#compdef dinfdistdown DinfDistDown
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/DInfinityDistanceDown.html
# TauDEM: D-infinity distance down to stream

local ret=1

_arguments -s -S \
  '-ang[input Dinf flow direction grid]:angfile:_files' \
  '-fel[input pit-filled elevation grid]:felfile:_files' \
  '-src[input stream raster grid]:srcfile:_files' \
  '-wg[input weight path grid]:weightfile:_files' \
  '-dd[output distance down grid]:ddfile:_files' \
  '-m[statistical and distance method]:method:(ave min max h v p s)' \
  '-nc[disable edge contamination checking]' \
  '*:file:_files' && ret=0

return ret
