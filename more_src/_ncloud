#compdef ncloud
# Documentation: https://cli.ncloud-docs.com/docs/en/guide-userguide
# NAVER Cloud Platform Ncloud CLI

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--read-timeout=[read timeout in seconds]:seconds' \
  '--connect-timeout=[connect timeout in seconds]:seconds' \
  '--output=[output format]:format:(json xml)' \
  '*:command:((server\:"Server service" loadbalancer\:"Load Balancer service" vserver\:"Server VPC service" vloadbalancer\:"Load Balancer VPC service" configure\:"configure credentials"))' && ret=0

return ret
