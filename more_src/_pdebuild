#compdef pdebuild
# pbuilder way of building Debian packages

local ret=1

_arguments -s -S \
  '--buildsourceroot=[fakeroot command for dpkg-source]:command:_command_names -e' \
  '--pbuilder=[specify pbuilder binary]:pbuilder:_command_names -e' \
  '--architecture=[specify architecture]:architecture:' \
  '--auto-debsign[automatically sign package]' \
  '--debsign-k=[specify GPG key]:key id:' \
  '--buildresult=[result directory]:directory:_files -/' \
  '--configfile=[specify config file]:file:_files' \
  '--debbuildopts=[extra dpkg-buildpackage options]:options:' \
  '--use-pdebuild-internal[use internal build method]' \
  '--logfile=[specify log file]:file:_files' \
  '-h[show help]' \
  '--help[show help]' && ret=0

return ret
