#compdef gojq

# Zsh completion for gojq - Go implementation of jq

_arguments \
  '(-)'{-h,--help}'[display help information]' \
  '(-)'{-v,--version}'[display version information]' \
  {-r,--raw-output}'[output raw strings]' \
  {-R,--raw-input}'[read raw strings as input]' \
  {-s,--slurp}'[read entire input into array]' \
  {-n,--null-input}'[use null as input]' \
  {-c,--compact-output}'[compact output]' \
  {-j,--join-output}'[no newline after each output]' \
  {-e,--exit-status}'[set exit status based on output]' \
  {-S,--sort-keys}'[sort object keys]' \
  '--indent[set indentation level]:spaces' \
  '--tab[use tab for indentation]' \
  '*--arg[set variable to string value]:name:value' \
  '*--argjson[set variable to JSON value]:name:json value' \
  '*--slurpfile[set variable to contents of file]:name:file:_files' \
  '*--rawfile[set variable to raw contents of file]:name:file:_files' \
  '--jsonargs[remaining args are JSON values]' \
  '--args[remaining args are string values]' \
  '--yaml-input[read YAML input]' \
  '--yaml-output[output YAML]' \
  {-f,--from-file}'[read filter from file]:file:_files' \
  '-L[directory for modules]:directory:_directories' \
  '*:file:_files'
