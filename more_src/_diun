#compdef diun

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[configuration file]:config file:_files' \
  '--log-level=[log level]:level:(trace debug info warn error fatal)' \
  '--log-json[output logs in JSON format]' \
  '--log-caller[add file and line number to log]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'serve:start the notification server'
      'image:manage images'
      'notif:manage notifications'
      'completion:generate shell completion'
    )
    _describe -t commands 'diun command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      image)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list inspect)' && ret=0
        ;;
      notif)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(test)' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
