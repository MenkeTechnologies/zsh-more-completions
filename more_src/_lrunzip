#compdef lrunzip

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --check)'{-c,--check}'[check integrity]' \
  '(-d --decompress)'{-d,--decompress}'[decompress]' \
  '(-D --delete)'{-D,--delete}'[delete after decompress]' \
  '(-f --force)'{-f,--force}'[force overwrite]' \
  '(-k --keep)'{-k,--keep}'[keep input file]' \
  '(-o --outfile)'{-o,--outfile}'+[output file]:file:_files' \
  '(-O --outdir)'{-O,--outdir}'+[output dir]:dir:_files -/' \
  '(-p --threads)'{-p,--threads}'+[threads]:n:' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-S --suffix)'{-S,--suffix}'+[suffix]:suf:' \
  '(-t --test)'{-t,--test}'[test integrity]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-w --maxram)'{-w,--maxram}'+[max ram MB]:mb:' \
  '*:file:_files -g "*.lrz"' && ret=0

return ret
