#compdef create-rn-app
# Documentation: https://www.npmjs.com/package/create-rn-app
# Reference accessed: 2026-05-24
# Verified: npx create-rn-app --help.

# Zsh completion for create-rn-app - React Native app scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-V --version)'{-V,--version}'[show version]' \
  '--ts[initialize as TypeScript project]' \
  '--typescript[initialize as TypeScript project]' \
  '--js[initialize as JavaScript project]' \
  '--javascript[initialize as JavaScript project]' \
  '--eslint[initialize with ESLint config]' \
  '--src-dir[initialize inside src/ directory]' \
  '--import-alias=[import alias]:alias:' \
  '--use-navigation[bootstrap with React Navigation]' \
  '--use-expo-modules[bootstrap with Expo modules]' \
  '--use-npm[use npm as package manager]' \
  '--use-yarn[use Yarn as package manager]' \
  '--use-bun[use Bun as package manager]' \
  '(-e --example)'{-e,--example=}'[example name or GitHub URL]:example:' \
  '--example-path=[path within example repo]:path:' \
  '--reset-preferences[reset stored CLI preferences]' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':project directory:_directories' && ret=0

return ret
