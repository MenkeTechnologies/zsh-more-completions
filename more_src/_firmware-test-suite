#compdef firmware-test-suite

# firmware-test-suite (fwts): firmware compliance/regression tests
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-a[run all tests]' \
  '-b[batch mode (auto-yes to prompts)]' \
  '-d[show test data]' \
  '-f[force run even on errors]' \
  '-i[interactive mode]' \
  '-j[JSON output file]:file:_files' \
  '-l[log filename]:file:_files' \
  '-L[log filter]:filter:' \
  '-q[quiet mode]' \
  '-s[show test summary]' \
  '-t[run specified test only]:test:' \
  '-v[verbose output]' \
  '--show-progress[print progress dots]' \
  '--klog[kernel log file]:file:_files' \
  '--dmidecode[run dmidecode tests]' \
  '--acpidump[run acpidump test]' \
  '--acpi-tests[run all ACPI tests]' \
  '*::fwts test list:_files' && ret=0
return ret
