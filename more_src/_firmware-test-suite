#compdef firmware-test-suite fwts

# fwts: Firmware Test Suite (BIOS/ACPI/UEFI conformance)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a tests=(
  'acpitests:run all ACPI tests'
  'cpu:CPU specific tests'
  'dmicheck:DMI/SMBIOS sanity'
  'esrt:EFI System Resource Table tests'
  'uefitests:run UEFI specific tests'
  'uefibootpath:check UEFI boot path'
  'uefirtmisc:misc UEFI runtime tests'
  'uefivarinfo:show EFI variable info'
  'bios:BIOS tests'
  'all:run all tests'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-b[run batch tests]' \
  '-i[run interactive tests]' \
  '-r[run results test only]' \
  '-q[quiet output]' \
  '-d[dump tables only]' \
  '-f[output format]:fmt:(plain html json xml)' \
  '--show-tests[list known tests]' \
  '--show-tests-full[list known tests with descriptions]' \
  '--log-fields=[log fields]:fields:' \
  '--log-format=[log format]:fmt:' \
  '--log-type=[log type]:type:(plain html json xml)' \
  '--log-file=[log file]:file:_files' \
  '--results-output=[output file]:file:_files' \
  '--results-no-separators[no separator lines in results]' \
  '-w[ignore klog warnings]' \
  '--klog=[kernel log file]:file:_files' \
  '--lspci=[path to lspci]:file:_files' \
  '--acpi-table=[load ACPI table from file]:file:_files' \
  '*: :->tests' && ret=0
case $state in
  tests) _describe -t fwts 'fwts test' tests && ret=0 ;;
esac
return ret
