'--width=[Force a specific width]:WIDTH:_default' \
'-f+[The resampling filter to use]:FILTER:_default' \
'--filter=[The resampling filter to use]:FILTER:_default' \
'--raster-theme=[Background theme for rasterized PNG output]:RASTER_THEME:_default' \
'-r+[Rotate the image. Omit a value to animate a continuous 360° spin; provide 90, 180, or 270 for a one-shot static rotation]::DEGREES:_default' \
'--rotate=[Rotate the image. Omit a value to animate a continuous 360° spin; provide 90, 180, or 270 for a one-shot static rotation]::DEGREES:_default' \
