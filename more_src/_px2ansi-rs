;;
(show)
_arguments "${_arguments_options[@]}" : \
'--style=[]:STYLE:_default' \
'--color-mode=[Color output mode\: truecolor, ansi256, or none]:COLOR_MODE:_default' \
'--density=[]:DENSITY:_default' \
