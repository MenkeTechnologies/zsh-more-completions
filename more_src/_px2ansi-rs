;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_px2ansi-rs__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:px2ansi-rs-help-command-$line[1]:"
        case $line[1] in
            (convert)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(index)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_px2ansi-rs_commands] )) ||
_px2ansi-rs_commands() {
    local commands; commands=(
'convert:Convert a single image to ANSI/Unicode/Fade/Braille/Kanji/Full-block/Ascii' \
'index:Create a JSON index of a directory' \
'show:Display a sprite from the index' \
'list:List entries in the index' \
'completions:Generate shell completions and add to your shell config. Example\: \`px2ansi-rs completions bash >> ~/.bashrc\`' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'px2ansi-rs commands' commands "$@"
}
