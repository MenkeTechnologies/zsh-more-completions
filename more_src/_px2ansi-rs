'-a+[Spin axis for --rotate animation. z = canvas spin, y = coin-flip (horizontal mirror), x = cartwheel (vertical mirror)]:AXIS:((z\:"Spin flat on the canvas plane — 0° → 90° → 180° → 270°. (default)"
y\:"Coin-flip illusion on the vertical axis\: the image squishes and reveals its horizontal mirror as the "back face""
x\:"Cartwheel illusion on the horizontal axis\: the image squishes and reveals its vertical mirror as the "back face""))' \
'--axis=[Spin axis for --rotate animation. z = canvas spin, y = coin-flip (horizontal mirror), x = cartwheel (vertical mirror)]:AXIS:((z\:"Spin flat on the canvas plane — 0° → 90° → 180° → 270°. (default)"
