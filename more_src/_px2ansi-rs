'-o+[Path to save the JSON index]:OUTPUT:_files' \
'--output=[Path to save the JSON index]:OUTPUT:_files' \
'-I+[Path to the JSON index file (overrides config file setting)]:INDEX:_default' \
'--index=[Path to the JSON index file (overrides config file setting)]:INDEX:_default' \
'-l[Show timing and execution metadata]' \
'--latency[Show timing and execution metadata]' \
'-h[Print help]' \
'--help[Print help]' \
':dir -- Directory to scan:_files' \
