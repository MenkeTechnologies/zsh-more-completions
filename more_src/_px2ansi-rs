_arguments "${_arguments_options[@]}" : \
'-c+[Number of entries to show (omit to show all)]:COUNT:_default' \
'--count=[Number of entries to show (omit to show all)]:COUNT:_default' \
'-I+[Path to the JSON index file (overrides config file setting)]:INDEX:_default' \
