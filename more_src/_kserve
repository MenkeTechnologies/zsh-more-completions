#compdef kserve kfserving
# _kserve — Kubeflow KServe formerly KFServing CLI for Kubernetes model serving creating InferenceService deploying TensorFlow PyTorch XGBoost SKLearn ONNX PMML Triton custom predictors (kserve team, Go); cobra
# upstream: https://github.com/kserve/kserve

_kserve() {
    local -a sub=(
        'list:list inference services'
        'get:get inference service'
        'create:create inference service'
        'apply:apply manifest'
        'delete:delete inference service'
        'predict:run prediction'
        'explain:run explanation'
        'logs:show pod logs'
        'port-forward:port forward'
        'status:show status'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-n+[namespace]:str:' \
        '--namespace=+[namespace]:str:' \
        '--context=+[ctx]:str:' \
        '--kubeconfig=+[file]:file:_files' \
        '--server=+[url]:str:' \
        '--token=+[token]:str:' \
        '--output=+[fmt]:f:(json yaml text wide name)' \
        '-o+[fmt]:f:(json yaml text wide name)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kserve subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--name=+[name]:str:' \
                    '--storage-uri=+[uri]:str:' \
                    '--runtime=+[r]:r:(tensorflow pytorch sklearn xgboost onnx triton lightgbm pmml paddle huggingface mlserver)' \
                    '--canary-traffic-percent=+[N]:n:' \
                    '--min-replicas=+[N]:n:' \
                    '--max-replicas=+[N]:n:' \
                    '--container-concurrency=+[N]:n:' \
                    '--service-account=+[sa]:str:' \
                    '--image-pull-secret=+[secret]:str:' ;;
                predict|explain) _arguments \
                    '--data=+[file]:file:_files -g "*.json *.txt"' \
                    '--model-name=+[name]:str:' \
                    '--protocol=+[p]:p:(v1 v2 grpc-v2)' \
                    '*:service name:' ;;
                logs) _arguments \
                    '--container=+[container]:c:(kserve-container queue-proxy storage-initializer)' \
                    '--follow[follow]' \
                    '*:service name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kserve "$@"
