#compdef asciidoctor-multipage
# Documentation: https://github.com/owenh000/asciidoctor-multipage
# Convert AsciiDoc documents to multiple chunked HTML pages

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-D --destination-dir)'{-D,--destination-dir}'[output directory]:dir:_directories' \
  '(-o --out-file)'{-o,--out-file}'[output file]:file:_files' \
  '(-B --base-dir)'{-B,--base-dir}'[base directory]:dir:_directories' \
  '(-r --require)'{-r,--require}'[require library before processing]:library' \
  '*'{-a,--attribute}'[set document attribute]:attribute=value' \
  '(-S --safe-mode)'{-S,--safe-mode}'[set safe mode level]:mode:(unsafe safe server secure)' \
  '*:asciidoc file:_files -g "*.{adoc,asc,asciidoc}"' && ret=0

return ret
