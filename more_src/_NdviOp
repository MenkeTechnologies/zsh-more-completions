#compdef NdviOp
# Documentation: https://raw.githubusercontent.com/senbox-org/optical-toolbox/master/opttbx-radiometric-indices/src/main/java/eu/esa/opt/radiometry/NdviOp.java
# ESA SNAP gpt NdviOp operator - compute Normalized Difference Vegetation Index

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PredFactor=[multiplier for the red source band]:factor' \
  '-PnirFactor=[multiplier for the NIR source band]:factor' \
  '-PredSourceBand=[the red band for NDVI computation]:band' \
  '-PnirSourceBand=[the near-infrared band for NDVI computation]:band' \
  '*:graph xml:_files' && ret=0

return ret
