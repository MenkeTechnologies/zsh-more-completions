#compdef pppoe-discovery
# _pppoe-discovery — Roaring Penguin pppoe-discovery (PADI helper: broadcasts PPPoE Active Discovery Initiation packets on an interface and prints every Active Discovery Offer it gets back, listing AC names + service tags; -I interface, -T timeout seconds, -V verbose, -A service name filter, -S session id, -U use unicast)
# upstream: https://github.com/dfskoll/rp-pppoe
# Flags from rp-pppoe src/pppoe-discovery.c on tip.

_pppoe-discovery() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-I+[interface]:interface:_net_interfaces' \
        '-T+[timeout seconds]:seconds:' \
        '-A+[service name]:service:' \
        '-S+[session id]:id:' \
        '-U[use unicast]' \
        '-v[verbose]' \
        '-Q[quiet]'
}

_pppoe-discovery "$@"
