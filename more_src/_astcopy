#compdef astcopy
# Documentation: http://www.starlink.ac.uk/docs/sun211.htx/sun211.html
# ATOOLS: makes a copy of an AST Object

local ret=1

_arguments -s \
  'THIS=[input AST Object]:object:_files' \
  'RESULT=[output copy of the Object]:result:_files' \
  'CLASS=[class of Object to extract from a FrameSet]:class' \
  'FMT=[output format for the result]:fmt' \
  '*:object:_files' && ret=0

return ret
