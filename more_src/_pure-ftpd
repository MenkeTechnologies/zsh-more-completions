  '(-x --prohibitdotfileswrite)'{-x,--prohibitdotfileswrite}'[block dot-file write]' \
  '(-X --prohibitdotfilesread)'{-X,--prohibitdotfilesread}'[block dot-file read]' \
  '(-y --peruserlimits)'{-y,--peruserlimits=}'[per-user limits]:user\:anon:' \
