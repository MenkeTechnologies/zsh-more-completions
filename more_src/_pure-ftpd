  '(-p --passiveportrange)'{-p,--passiveportrange=}'[PASV port range]:first\:last:' \
  '(-P --forcepassiveip)'{-P,--forcepassiveip=}'[force PASV IP]:ip:' \
  '(-q --anonymousratio)'{-q,--anonymousratio=}'[anon ratio]:up\:dn:' \
  '(-Q --userratio)'{-Q,--userratio=}'[user ratio]:up\:dn:' \
  '(-r --autorename)'{-r,--autorename}'[auto-rename]' \
  '(-R --nochmod)'{-R,--nochmod}'[disable CHMOD]' \
