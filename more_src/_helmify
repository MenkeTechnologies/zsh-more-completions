#compdef helmify

# Zsh completion for helmify (create Helm charts from Kubernetes YAML)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-crd --cert-manager-as-subchart)'{-crd,--cert-manager-as-subchart}'[add cert-manager as subchart]' \
  '(-r --chart-dir)'{-r,--chart-dir}'[chart output directory]:directory:_files -/' \
  '(-n --chart-name)'{-n,--chart-name}'[chart name]:name' \
  '(-v --chart-version)'{-v,--chart-version}'[chart version]:version' \
  '(-image --image-pull-secrets)'{-image,--image-pull-secrets}'[add image pull secrets]' \
  '(-vv --verbose)'{-vv,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-o --original-name)'{-o,--original-name}'[use original resource names]' \
  '*:kubernetes yaml:_files -g "*.{yaml,yml}"' && ret=0

return ret
