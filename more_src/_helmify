#compdef helmify
# Documentation: https://github.com/arttor/helmify
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for helmify (create Helm charts from Kubernetes YAML).
# Note: helmify uses Go-flag style single-dash long flags (e.g. -version,
# -crd-dir), so each flag is its own option (no GNU short/long pairing).
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-help[show help]' \
  '-version[show helmify version]' \
  '-f[specify file source (directory or file); repeatable]:source:_files' \
  '-r[enable recursive directory scanning (with -f)]' \
  '-v[verbose output (WARN and INFO)]' \
  '-vv[very verbose output (includes DEBUG)]' \
  '-crd-dir[place CRDs in their own folder per Helm 3 docs]' \
  '-image-pull-secrets[use existing secrets as imagePullSecrets]' \
  '-original-name[use original resource names instead of release-name prefix]' \
  '-preserve-ns[preserve original namespace instead of common namespace]' \
  '-cert-manager-as-subchart[install cert-manager as a subchart]' \
  '-cert-manager-version=[cert-manager subchart version]:version:' \
  '-cert-manager-install-crd[install cert-manager CRD with subchart]' \
  '-add-webhook-option[add enable/disable option for webhook installation]' \
  '-optional-crds[enable optional CRD installation through values]' \
  '*:chart name or kubernetes yaml:_files -g "*.(yaml|yml)"' && ret=0

return ret
