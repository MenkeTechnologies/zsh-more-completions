#compdef conda-devenv
# Documentation: https://conda-devenv.readthedocs.io/en/stable/usage.html
# conda-devenv: work with multiple conda-environment-like yaml files in dev mode

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --file)'{-f,--file}'=[devenv file to process]:file:_files' \
  '(-n --name)'{-n,--name}'=[conda environment name]:name:' \
  '--print[output the rendered file to stdout]' \
  '--print-full[output the rendered file including environment variables]' \
  '--no-prune[do not pass --prune to conda-env]' \
  '--output-file=[destination filename for the generated environment file]:file:_files' \
  '--quiet[suppress progress output]' \
  '*'{-e,--env-var}'=[define or override an environment variable]:var:' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--version[show version and exit]' \
  '(-m --env-manager)'{-m,--env-manager}'=[environment manager to use]:manager:(conda mamba)' \
  '--lock[generate lock files for reproducible environments]' \
  '--use-locks=[control lock file usage]:mode:(auto yes no)' \
  '*--update-locks=[update specified packages in lock files]:package:' && ret=0

return ret
