#compdef kdigger
# Documentation: https://github.com/quarkslab/kdigger
# Reference accessed: 2026-05-17
# Verified: quarkslab/kdigger upstream cobra command surface (dig,
# list, color, completion, version, help) and global flags
# (--active, --color auto|never|always, -c/--config, --human-readable,
# --kubeconfig, --namespace, --output json|human, -h/--help).
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'dig:run buckets (default)'
  'list:list available buckets'
  'color:color test'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--active[enable active buckets]' \
  '--color=[colorize output]:when:(auto never always)' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '--human-readable[human readable output]' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--namespace=[namespace]:namespace:' \
  '--output=[output format]:format:(json human)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kdigger command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (dig)
        _arguments \
          '*::bucket:' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
