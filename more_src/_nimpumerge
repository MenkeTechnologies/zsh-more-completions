#compdef nimpumerge
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/nimpumerge.html
# Merge per-MPU NICER event files into a single calibrated event file

local ret=1

_arguments -s -S \
  'infiles=[input files or @filename.lis list]:infiles:_files' \
  'outfile=[output merged event file]:outfile:_files' \
  'mpulist=[MPU slices to process]:mpulist:' \
  'timesort=[sort output by TIME ascending]:timesort:(yes no)' \
  'timefile=[GTI filtering file, or NONE]:timefile:_files' \
  'filtexpr=[event screening expression, or NONE]:filtexpr:' \
  'mpugtimerge=[combine per-MPU GTIs AND or OR]:mpugtimerge:(AND OR)' \
  'mpupat=[regex to extract MPU slice from filename]:mpupat:' \
  'cleanup=[remove temporary files]:cleanup:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
