#compdef uflow uflow-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/lib/uflow.py argparse)
# Reference accessed: 2026-05-29
# uflow — print method call flow tree for high-level languages via USDT (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --language)'{-l,--language=}'[language to trace]:lang:(java perl php python ruby tcl)' \
  '(-M --method)'{-M,--method=}'[trace only calls to methods starting with this prefix]:prefix:' \
  '(-C --class)'{-C,--class=}'[trace only calls to classes starting with this prefix]:prefix:' \
  '(-v --verbose)'{-v,--verbose}'[verbose: print the BPF program (for debugging)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:pid (process id to attach to):_pids' \
  && ret=0

return ret
