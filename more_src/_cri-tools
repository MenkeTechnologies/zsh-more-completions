#compdef crictl critest

# kubernetes-sigs/cri-tools — docs/crictl.md (command list) + main.go global flags
# critest is the CRI validation suite; surface differs — delegate to _normal after globals

if [[ $service == critest ]]; then
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[help]' \
    '(-v --version)'{-v,--version}'[version]' \
    '(-r --runtime-endpoint)'{-r,--runtime-endpoint}'[CRI runtime]:socket:' \
    '(-i --image-endpoint)'{-i,--image-endpoint}'[image service]:socket:' \
    '(-t --timeout)'{-t,--timeout}'[gRPC timeout]' \
    '(-D --debug)'{-D,--debug}'[debug]' \
    '*:critest args:_normal'
  return
fi

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'attach:attach to a running container'
  'checkpoint:checkpoint containers'
  'completion:shell completion'
  'config:crictl client configuration'
  'create:create container in pod sandbox'
  'events:stream container events'
  'exec:exec in container'
  'help:help for command'
  'imagefsinfo:image filesystem usage'
  'images:list images'
  'info:runtime information'
  'inspect:container status'
  'inspecti:image status'
  'inspectp:pod status'
  'logs:fetch logs'
  'metricdescs:CRI metric descriptors'
  'metricsp:pod metrics'
  'pods:list pods'
  'port-forward:port forward to pod'
  'ps:list containers'
  'pull:pull image'
  'rm:remove containers'
  'rmi:remove images'
  'rmp:remove pods'
  'run:create and start container'
  'runp:create pod sandbox'
  'runtime-config:fetch runtime config'
  'start:start created containers'
  'stats:container resource stats'
  'statsp:pod stats'
  'stop:stop containers'
  'stopp:stop pods'
  'update:update container resources'
  'update-runtime-config:update runtime config'
  'version:CRI version'
)

_arguments -s -S -C \
  '(-c --config)'{-c,--config}'[crictl YAML]:file:_files' \
  '(-r --runtime-endpoint)'{-r,--runtime-endpoint}'[CRI runtime]:endpoint:' \
  '(-i --image-endpoint)'{-i,--image-endpoint}'[image service]:endpoint:' \
  '(-t --timeout)'{-t,--timeout}'[connect timeout]' \
  '(-D --debug)'{-D,--debug}'[debug]' \
  '--enable-tracing[OpenTelemetry tracing]' \
  '--tracing-sampling-rate-per-million=[sampling rate]:N:' \
  '--tracing-endpoint=[OTLP collector]:host:port:' \
  '--profile-cpu=[CPU pprof output]:file:_files' \
  '--profile-mem=[heap pprof output]:file:_files' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'crictl subcommand' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
