#compdef cmpdylib
# Documentation: https://www.unix.com/man-page/osx/1/cmpdylib/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cmpdylib compares two versions of a dynamic shared library
# Synopsis: cmpdylib oldLibrary newLibrary
local curcontext="$curcontext" state line ret=1

_arguments \
  '1:old dylib:_files -g "*.dylib"' \
  '2:new dylib:_files -g "*.dylib"' && ret=0

return ret
