#compdef composio
# Documentation: https://docs.composio.dev/docs/cli
# Reference accessed: 2026-05-22
# Verified: ts/packages/cli/src/commands/root-help.ts BASIC and ADVANCED commands.

# Zsh completion for composio - Composio agent toolkit CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--install-skill[install composio skill for agent]:agent:(claude codex openclaw):' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'composio command' \
      'search[search tools by query]' \
      'execute[execute a tool by slug]' \
      'link[link a toolkit account]' \
      'run[run inline or file TS/JS workflow]' \
      'listen[listen to a trigger]' \
      'proxy[proxy HTTP request via toolkit auth]' \
      'login[log in to Composio]' \
      'logout[log out from Composio]' \
      'whoami[show current account]' \
      'generate[generate integration code]' \
      'version[show CLI version]' \
      'upgrade[upgrade CLI]' \
      'config[view or manage CLI config]' \
      'orgs[manage organization context]' \
      'projects[manage project context]' \
      'files[manage session files]' \
      'tools[toolkit tool commands]' \
      'triggers[trigger commands]' \
      'connections[list or remove connections]' \
      'artifacts[session artifact paths]' && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _arguments \
          '--toolkits[filter toolkit slugs]:toolkits:' \
          '--limit[maximum results]:n:' \
          '--human[human-readable output]' \
          '*:query:' && ret=0
        ;;
      execute)
        _arguments \
          '(-d --data)'{-d,--data}'[JSON args, @file, or - for stdin]:data:' \
          '--user-id[user ID]:id:' \
          '(-p --parallel)'{-p,--parallel}'[parallel tool calls]' \
          '--file[read args from file]:file:_files' \
          '--dry-run[validate without executing]' \
          '--get-schema[print input schema]' \
          '1:slug:' && ret=0
        ;;
      link)
        _arguments '1:toolkit:(github gmail slack notion linear jira)' && ret=0
        ;;
      run)
        _arguments \
          '(-f --file)'{-f,--file}'[run TS/JS file]:file:_files' \
          '--dry-run[preview execute calls only]' \
          '1:code or file:' \
          '*:args:' && ret=0
        ;;
      listen)
        _arguments \
          '(-p --params)'{-p,--params}'[trigger params JSON]:json:' \
          '--max-events[max events]:n:' \
          '--timeout[timeout]:duration:' \
          '--stream[stream events]' \
          '1:trigger slug:' && ret=0
        ;;
      proxy)
        _arguments \
          '--toolkit[toolkit slug]:toolkit:' \
          '(-X --method)'{-X,--method}'[HTTP method]:method:(GET POST PUT DELETE PATCH)' \
          '(-H --header)*'{-H,--header}'[header Name: value]:header:' \
          '(-d --data)'{-d,--data}'[request body]:data:' \
          '1:url:' && ret=0
        ;;
      tools)
        case $line[2] in
          list)
            _arguments '1:toolkit:' && ret=0
            ;;
          info)
            _arguments '1:slug:' && ret=0
            ;;
          *)
            _values 'tools command' list info && ret=0
            ;;
        esac
        ;;
      triggers)
        case $line[2] in
          list)
            _arguments '1:toolkit:' && ret=0
            ;;
          info)
            _arguments '1:slug:' && ret=0
            ;;
          *)
            _values 'triggers command' list info && ret=0
            ;;
        esac
        ;;
      connections)
        _values 'connections command' list remove && ret=0
        ;;
      artifacts)
        _values 'artifacts command' cwd && ret=0
        ;;
      config|orgs|projects|files|login|logout|whoami|generate|version|upgrade)
        _arguments '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
