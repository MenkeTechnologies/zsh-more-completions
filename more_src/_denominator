#compdef denominator
# Documentation: https://man.archlinux.org/search?q=denominator
# Reference accessed: 2026-05-16

# Zsh completion for denominator
# Upstream: Portable Java library for manipulating DNS clouds
# Conservative fallback — run `denominator --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
