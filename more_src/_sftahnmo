#compdef sftahnmo
# Documentation: http://www.ahay.org/RSF/sftahnmo.html
# Madagascar: normal moveout on trace-and-header (tah) data

local ret=1

_arguments -s \
  'tnmo=[list of NMO times for the vnmo velocities]:tnmo' \
  'vnmo=[list of NMO velocities for the tnmo times]:vnmo' \
  'vfile=[velocity file]:file:_files' \
  'iline=[trace header key to index into vfile]:iline' \
  'xline=[trace header key to index into vfile]:xline' \
  'offset=[header key to use for offset]:offset' \
  'inv=[y for inverse nmo, n for forward]:flag:(y n)' \
  'lmute=[length of the mute zone in seconds]:lmute' \
  'str=[maximum stretch allowed]:str' \
  'verbose=[print level: 0 terse 1 info 2 chatty 3 debug]:level:(0 1 2 3)' \
  '*:rsf file:_files' && ret=0

return ret
