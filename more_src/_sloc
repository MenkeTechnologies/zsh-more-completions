#compdef sloc

_sloc() {
    local -a args
    args=(
        '(-h --help)'{-h,--help}'[Output usage information]'
        '(-V --version)'{-V,--version}'[Output the version number]'
        '(-e --exclude)'{-e,--exclude}'[Exclude specific files and folders]:regex'
        '(-i --include)'{-i,--include}'[Include specific files and folders]:regex'
        '(-f --format)'{-f,--format}'[Format output]:format:(json csv cli-table)'
        '--format-option[Add specific options for the chosen formatter]:option'
        '(-k --keys)'{-k,--keys}'[Report only numbers for given keys]:keys'
        '(-d --details)'{-d,--details}'[Report statistics for each analyzed file]'
        '(-a --alias)'{-a,--alias}'[Alias a custom extension]:alias'
        '*:file or directory:_files'
    )

    _arguments -s -S $args
}

_sloc "$@"
