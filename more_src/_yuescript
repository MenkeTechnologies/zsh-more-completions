#compdef yuescript yue yuec
# _yuescript — Pigpigyyp Yuescript MoonScript-compatible Lua language CLI (Pigpigyyp / yuescript team, C++/Lua); custom argparse
# upstream: https://github.com/pigpigyyp/yuescript

_yuescript() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-e+[execute Yuescript code]:str:' \
        '-c[compile (default)]' \
        '-t+[target directory]:dir:_files -/' \
        '-T[tree mode]' \
        '-w[watch and recompile]' \
        '-r[require yue]' \
        '-l[list ast and exit]' \
        '-p[print compiled lua]' \
        '-o+[output file]:file:_files' \
        '-d[debug]' \
        '-q[quiet]' \
        '-s[source map]' \
        '-i[implicit return root]' \
        '-m[implicit return root]' \
        '-a[allow include]' \
        '-x[exit code on error]' \
        '*:file:_files -g "*.yue *.moon"'
}

_yuescript "$@"
