#compdef ndb_mgm
# NDB Cluster management client

local ret=1

_arguments -s -S \
  '(-? --help --usage)'{-\?,--help,--usage}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --connect-string --ndb-connectstring)'{-c,--connect-string,--ndb-connectstring}'+[connect string for ndb_mgmd]:string:' \
  '(-e --execute)'{-e,--execute}'+[execute command and exit]:command:' \
  '(-t --try-reconnect)'{-t,--try-reconnect}'+[number of connection retries]:num:' \
  '--connect-retries=[number of retry attempts]:num:' \
  '--connect-retry-delay=[seconds between connection attempts]:secs:' \
  '--ndb-nodeid=[set node ID]:id:' \
  '--backup-password-from-stdin[read backup decryption password from stdin]' \
  '--encrypt-backup[encrypt backups on START BACKUP]' \
  '--defaults-file=[read default options from specified file only]:file:_files' \
  '--defaults-extra-file=[read file after global files]:file:_files' \
  '--no-defaults[do not read default options from any file]' \
  '--print-defaults[print argument list and exit]' && ret=0

return ret
