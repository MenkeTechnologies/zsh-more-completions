#compdef basedmypy basedmypyc
# _basedmypy — basedmypy: based fork of mypy with sane defaults and intersection types
# upstream: https://github.com/KotlinIsland/basedmypy
# Flag surface is a superset of mypy's; based-specific flags listed first.

_basedmypy() {
    local -a args
    args=(
        '--default-return[infer return type as `None` when annotation omitted (based default)]'
        '--no-default-return[disable the based default-return inference]'
        '--bare-literals[enable bare literal types in based mode]'
        '--ignore-any-from-error[ignore Any inferred from errors]'
        '--strict-baseline[strict baseline mode]'
        '--baseline-file=[baseline file path (default .mypy/baseline.json)]:file:_files'
        '--write-baseline[write a baseline of current errors and exit]'
        '--auto-baseline[update baseline automatically when error set shrinks]'
        '--no-baseline[disable baseline]'
        '--bytecode-compatible[verify bytecode of compiled module matches source]'
        '--strict[enable all optional error checks (umbrella flag)]'
        '--check-untyped-defs[type-check the bodies of unannotated functions]'
        '--disallow-untyped-defs[error on any function missing annotations]'
        '--disallow-incomplete-defs[error on partially-annotated functions]'
        '--disallow-untyped-calls[error on calls to functions without annotations]'
        '--disallow-untyped-decorators[error on decorators without types]'
        '--disallow-any-generics[error on generics used without type parameters]'
        '--disallow-subclassing-any[error on subclassing Any]'
        '--warn-redundant-casts[warn on no-op casts]'
        '--warn-unused-ignores[warn on unused # type: ignore comments]'
        '--warn-unreachable[warn on statically unreachable code]'
        '--warn-return-any[warn on returning Any from a typed function]'
        '--no-implicit-optional[require explicit Optional for default-None args]'
        '--strict-equality[disallow equality between non-overlapping types]'
        '--strict-optional[enable strict optional checks]'
        '--no-strict-optional[disable strict optional checks]'
        '--ignore-missing-imports[silently treat missing imports as Any]'
        '--follow-imports=[how to follow imports]:mode:(normal silent skip error)'
        '--namespace-packages[support PEP 420 namespace packages]'
        '--explicit-package-bases[do not infer package bases]'
        '--python-version=[target Python version (e.g. 3.12)]:version:'
        '--python-executable=[path to a Python interpreter for stub discovery]:bin:_files'
        '--platform=[target sys.platform]:platform:(linux darwin win32)'
        '--show-error-codes[show error codes after each message]'
        '--show-error-context[show context note for each error]'
        '--show-column-numbers[show column numbers in error messages]'
        '--show-traceback[show internal tracebacks on failure]'
        '--no-color-output[disable colored output]'
        '--pretty[pretty-print error messages]'
        '--no-pretty[disable pretty error output]'
        '--cache-dir=[directory to write the incremental cache to]:dir:_files -/'
        '--no-incremental[disable incremental mode]'
        '--sqlite-cache[use the sqlite-backed incremental cache]'
        '--config-file=[path to mypy.ini / pyproject.toml]:file:_files'
        '--package=[type-check the given package]:package:'
        '--module=[type-check the given module]:module:'
        '-p+[type-check the given package]:package:'
        '-m+[type-check the given module]:module:'
        '-c+[type-check program text passed in]:program:'
        '--install-types[install missing third-party type stubs from typeshed]'
        '--non-interactive[answer yes to all prompts (for --install-types)]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '*:file or directory:_files'
    )
    _arguments -s -S $args
}

_basedmypy "$@"
