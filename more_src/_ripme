#compdef ripme
# Documentation: https://github.com/RipMeApp/ripme
# ripme - album ripper / bulk media downloader

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print the help]' \
  '(-u --url)'{-u,--url}'[URL of album to rip]:url' \
  '(-t --threads)'{-t,--threads}'[number of download threads per rip]:threads' \
  '(-w --overwrite)'{-w,--overwrite}'[overwrite existing files]' \
  '(-r --rerip)'{-r,--rerip}'[re-rip all ripped albums]' \
  '(-R --rerip-selected)'{-R,--rerip-selected}'[re-rip all selected albums]' \
  '(-d --saveorder)'{-d,--saveorder}'[save the order of images in album]' \
  '(-D --nosaveorder)'{-D,--nosaveorder}'[do not save order of images]' \
  '(-4 --skip404)'{-4,--skip404}'[do not retry after a 404 error]' \
  '(-l --ripsdirectory)'{-l,--ripsdirectory}'[rips directory (default: ./rips)]:directory:_files -/' \
  '(-n --no-prop-file)'{-n,--no-prop-file}'[do not create properties file]' \
  '(-f --urls-file)'{-f,--urls-file}'[rip URLs from a file]:file:_files' \
  '(-v --version)'{-v,--version}'[show current version]' \
  '(-s --socks-server)'{-s,--socks-server}'[use socks server ([user:password]@host[:port])]:server' \
  '(-p --proxy-server)'{-p,--proxy-server}'[use HTTP proxy server ([user:password]@host[:port])]:server' \
  '(-j --update)'{-j,--update}'[update ripme]' \
  '(-a --append-to-folder)'{-a,--append-to-folder}'[append a string to the output folder name]:string' \
  '(-H --history)'{-H,--history}'[set history file location]:file:_files' && ret=0

return ret
