#compdef pypeit_chk_alignments
# Documentation: https://pypeit.readthedocs.io/en/release/scripts.html
# Display Alignment image and the trace data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '--chname=[channel name for image in Ginga]:name' \
  '--try_old[attempt to load old datamodel versions]' \
  '*:Alignment file:_files -g "*.fits"' && ret=0

return ret
