#compdef mri_surfcluster
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_surfcluster
# FreeSurfer: find clusters of activation on a surface

local ret=1

_arguments -s -S \
  '--in[input data to cluster]:inputfile:_files' \
  '--subject[surface values subject]:subjectid' \
  '--hemi[cortical hemisphere]:hemi:(lh rh)' \
  '--surf[surface for talairach coords (default white)]:surface' \
  '--annot[report cortical annotation]:annotationname' \
  '--frame[zero-based frame number]:frameno' \
  '--thmin[minimum intensity threshold]:minthresh' \
  '--thmax[maximum intensity threshold]:maxthresh' \
  '--sign[threshold sign]:sign:(pos neg abs)' \
  '--no-adjust[disable threshold adjustment for one-tailed tests]' \
  '--fdr[set thmin via False Discovery Rate]:FDR' \
  '--csd[load Cluster Simulation Data file]:csdfile:_files' \
  '--cwsig[save cluster-wise significance map]:map:_files' \
  '--csdpdf[compute and save CSD PDF/CDF]:csdpdffile:_files' \
  '--csdpdf-only[write only CSD PDF file]' \
  '--minarea[minimum surface area mm2]:area' \
  '--clabel[constrain cluster search to label]:label file:_files' \
  '--mask-inv[constrain search outside mask/clabel]' \
  '--sum[output summary text file]:summaryfile:_files' \
  '--o[output filtered surface values]:outputid:_files' \
  '--ocn[output cluster numbers per vertex]:ocnid:_files' \
  '--olab[save clusters as label files]:outlabelbase' \
  '--xfm[transform file for talairach coords]:xfmfile:_files' \
  '--fixmni[apply MNI talairach fix (default)]' \
  '--nofixmni[disable MNI talairach fix]' \
  '--sd[subjects directory]:dir:_files -/' \
  '*:argument:_files' && ret=0

return ret
