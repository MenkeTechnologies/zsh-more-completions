#compdef boogie
# =============================================================================
# boogie — the Boogie verification engine and language driver.  Boogie is
#          Microsoft Research's INTERMEDIATE VERIFICATION LANGUAGE (IVL) —
#          a small imperative language used as a back-end for high-level
#          verification tools.  Boogie programs consist of procedures with
#          preconditions, postconditions, and loop invariants; the Boogie
#          engine generates verification conditions, hands them to an SMT
#          solver (typically Z3), and reports any failing obligations.
#          Boogie is the back-end for Dafny, VCC (Verifying C Compiler),
#          Chalice, Spec#, HAVOC, Vale, GPUVerify, and many other
#          academic + industrial verification tools.
#
# Author:  Microsoft Research (lead: Rustan Leino)
# Source:  https://github.com/boogie-org/boogie
# CLI:     Source/BoogieDriver/BoogieDriver.cs +
#          Source/ExecutionEngine/CommandLineOptionEngine.cs +
#          Source/ExecutionEngine/CommandLineOptions.cs
# Library: Microsoft.Boogie.CommandLineOptionEngine
#          (in-house C# class-inheritance CLI parser)
# License: MIT
# Status:  Active development at Microsoft Research and ETH Zurich —
#          584+ stars.  Boogie underlies the Dafny verification ecosystem
#          (3,418 stars on dafny-lang/dafny) and is cited in 1,000+
#          peer-reviewed verification papers since 2008.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — BOOGIE IS NOW LANGUAGE 51
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy crosses from
# 50 to 51 documented languages.  Boogie joins the canonical roster alongside:
# Rust, Go, TypeScript-Node, Python, Ruby, Perl, C, C++, Lua, Java, Kotlin,
# Scala, Haskell, OCaml, Elixir, Erlang, Clojure, Common Lisp, Scheme/Racket,
# Julia, Crystal, Pony, Nim, Zig, V, Swift, R, Dart, Fortran, Tcl, Ada, Janet,
# D, Picat, BQN, Frege, Lobster, Curry, Mercury, Wren, Idris2, F#, Jakt,
# Ur/Web, Beluga, REBOL, Io, Pure, Yeti, Whiley, and now Boogie.  boogie is
# documented as the FIRST Boogie CLI library variant in the taxonomy
# (in-house Microsoft.Boogie.CommandLineOptionEngine C# class-inheritance
# CLI parser with /flag slash-prefix Microsoft convention) — bringing the
# total to 212 cross-language CLI library variants.
# -----------------------------------------------------------------------------
#
# WHAT IS BOOGIE AND WHY DOES IT WARRANT ITS OWN CLI LIBRARY DOCUMENTATION CATEGORY?
#
# Boogie is BOTH a programming language and a verification engine.  As a
# language, Boogie (.bpl files) is a small imperative IVL with:
#
#   * PROCEDURES with explicit `requires` (precondition), `ensures`
#     (postcondition), `modifies` (frame), `free` modifiers
#   * IMPERATIVE STATEMENTS: assignment, if/while/havoc, call, assert, assume
#   * MATHEMATICAL FUNCTIONS and AXIOMS as separate declarations
#   * MAPS as the primary structured datatype (`[int]bool`, `[int,int]int`)
#   * GENERIC POLYMORPHIC TYPES via `<T>` type parameters
#   * BIVARIANT MODIFIES CLAUSES tracking heap effects
#
# As a VERIFICATION ENGINE, the `boogie` binary:
#
#   1. Parses .bpl input
#   2. Type-checks it
#   3. Generates VERIFICATION CONDITIONS (VCs) — first-order logic formulas
#      whose validity is equivalent to the original procedure satisfying
#      its specification
#   4. Hands the VCs to an SMT solver (Z3 by default; can use CVC4, CVC5,
#      Yices, MathSAT)
#   5. Reports SAT/UNSAT/UNKNOWN per verification condition
#   6. If a VC is UNSAT (counter-example), Boogie pretty-prints a trace
#      through the procedure showing what values lead to the violation
#
# Boogie is distinct from every other language documented in the corpus
# because:
#
#   * It is the FIRST documented INTERMEDIATE VERIFICATION LANGUAGE (IVL)
#     — a language designed to be the OUTPUT of higher-level verifiers
#     rather than a language humans write directly.  Dafny compiles to
#     Boogie; VCC translates C+annotations to Boogie; Spec# (the failed
#     Microsoft C# extension) compiled to Boogie.  Boogie occupies the
#     same architectural niche as LLVM IR for compilers — a target IR
#     for an entire family of source languages.
#   * It uses HOARE-STYLE TRIPLES at the procedure level as the unit of
#     verification.  Coq/Agda/Idris2 use dependent types as the unit;
#     Whiley (R469) uses extended static checking on a Java-like language;
#     Boogie uses pure Hoare logic + SMT.
#   * Its VC GENERATION ALGORITHM (weakest-precondition with
#     verification-condition splitting) is one of the most-published
#     pieces of academic verification infrastructure, with the original
#     paper (Barnett, Chang, DeLine, Jacobs, Leino 2005) having over
#     1,000 citations.
#   * It is the FIRST language documented whose ENTIRE PURPOSE is to be
#     a target for OTHER verification tools.  Boogie is rarely written
#     directly by application programmers; instead, it's emitted by
#     Dafny/VCC/Spec#/Chalice/HAVOC/Vale/etc. as their proof-obligation
#     output format.
#
# -----------------------------------------------------------------------------
# BOOGIE'S CLI LIBRARY — Microsoft.Boogie.CommandLineOptionEngine
# -----------------------------------------------------------------------------
#
# Boogie's CLI parser is a CLASS-INHERITANCE-BASED in-house C# library at
# `Source/ExecutionEngine/CommandLineOptionEngine.cs` with concrete
# subclass `Source/ExecutionEngine/CommandLineOptions.cs`.  It is the
# FIRST documented "Microsoft-research-style /flag CLI parser with class
# inheritance extension pattern" in the corpus's cross-language taxonomy.
#
# THE PARSER ARCHITECTURE (verbatim from CommandLineOptionEngine.cs):
#
#     public class CommandLineOptionEngine {
#         public TextWriter OutputWriter { get; set; }
#         public string ToolName { get; set; }
#         public string DescriptiveToolName { get; set; }
#         public IList<string> Files { get; }  // non-option positional args
#         public bool VersionRequested = false;
#         public bool HelpRequested = false;
#         public bool AttributeHelpRequested = false;
#
#         protected virtual bool ParseOption(string name, CommandLineParseState ps) {
#             if (ps.CheckBooleanFlag("version", ref VersionRequested) ||
#                 ps.CheckBooleanFlag("help", ref HelpRequested) ||
#                 ps.CheckBooleanFlag("?", ref HelpRequested) ||
#                 ps.CheckBooleanFlag("attrHelp", ref AttributeHelpRequested)) {
#                 return true;
#             }
#             return false; // unrecognized — subclass overrides for tool-specific flags
#         }
#
#         protected virtual string HelpHeader => "Usage: ...";
#         protected virtual string HelpBody => "";
#         public virtual bool Parse(string[] args) { ... }
#     }
#
# THE BOOGIE-SPECIFIC SUBCLASS (CommandLineOptions.cs):
#
#     public class CommandLineOptions : CommandLineOptionEngine, ExecutionEngineOptions {
#         protected override bool ParseOption(string name, CommandLineParseState ps) {
#             // 100+ Boogie-specific flags dispatched here via:
#             ps.CheckBooleanFlag("trace", ref Trace);
#             ps.CheckBooleanFlag("quiet", ref Quiet);
#             ps.CheckBooleanFlag("noVerify", ref NoVerify);
#             ps.CheckBooleanFlag("printUnstructured", ref PrintUnstructured);
#             ps.CheckIntFlag("timeLimit", ref TimeLimit);
#             ps.CheckIntFlag("proverWarnings", ref ProverWarnings);
#             ps.GetStringOption("proverOpt", ref ProverOptions);
#             ps.GetStringOption("xml", ref XmlFileName);
#             ...
#             return base.ParseOption(name, ps);  // fall back to base flags
#         }
#     }
#
# DISTINCTIVE PROPERTIES OF Microsoft.Boogie.CommandLineOptionEngine:
#
#   1. /FLAG SLASH-PREFIX SYNTAX — Boogie inherits the MICROSOFT/WINDOWS
#      CLI convention of using `/flag value` instead of `--flag value`.
#      This is shared with cl.exe (MSVC), csc.exe (C# compiler), MSBuild,
#      and most pre-2010 Microsoft tools.  Modern Microsoft tools (dotnet
#      CLI, PowerShell Core) use `--flag` GNU convention; Boogie retains
#      the legacy slash form because it's been around since 2003.  This
#      is the FIRST documented "slash-prefix CLI" in the corpus's
#      cross-language taxonomy (Beluga R460 uses +/- tri-prefix; REBOL
#      R462 uses --/-/+ tri-prefix; Boogie uses pure / prefix).
#
#   2. CLASS-INHERITANCE EXTENSION PATTERN — to add tool-specific flags,
#      subclasses override `ParseOption(string name, CommandLineParseState ps)`
#      and dispatch on the name.  This is OO-style extension; compare
#      to clap-derive (R275, Rust) which uses struct fields, Kong (R465, Go)
#      which uses struct tags, or stricli (R466, TS-Node) which uses
#      plain object data.  Boogie's class inheritance is uncommon in
#      modern CLI library designs but was idiomatic in 2003-era C#.
#
#   3. CommandLineParseState AS MUTABLE STATE OBJECT — flag dispatch uses
#      methods on a `CommandLineParseState ps` object that holds the
#      current position in argv, the flag name being matched, and
#      bookkeeping data.  Subclass methods call
#      `ps.CheckBooleanFlag("name", ref field)` which returns true if
#      the flag matched AND was a boolean.  This is closer to GNU
#      getopt's `optarg` global than to modern declarative APIs.
#
#   4. REF-FIELD ASSIGNMENT VIA CheckBooleanFlag/CheckIntFlag/GetStringOption
#      — each flag-checking method takes a `ref` parameter to the actual
#      field that should be mutated.  This is a C# idiom (`out`/`ref`
#      parameters) for treating fields as first-class assignment targets.
#      Most modern CLI libraries return parsed values; Boogie mutates
#      pre-existing fields.
#
#   5. VIRTUAL HelpHeader / HelpBody — usage text is built up by string
#      concatenation in virtual properties that subclasses override.
#      Each Boogie tool variant (the base BoogieDriver, plus Dafny's
#      override, etc.) has its own help block constructed via this
#      template-method pattern.
#
#   6. AUTO-CAPTURED Environment STRING — `Environment` field captures
#      the full command line as a single space-joined string, which is
#      later written to log files for reproducibility.  Boogie's
#      verification logs include the exact invocation so failed VCs can
#      be re-run.
#
#   7. ATTRIBUTE HELP DISTINCT FROM REGULAR HELP — Boogie has a separate
#      `/attrHelp` flag that prints help on Boogie's PROCEDURE-LEVEL
#      ATTRIBUTES (e.g., `{:bvbuiltin}`, `{:inline 1}`, `{:smtoption}`).
#      This is unusual — most CLI libraries have one help system; Boogie
#      has two (CLI flags vs Boogie-language attributes).
#
# CONTRAST WITH OTHER .NET CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * Argu (F#, R456)              — discriminated-union compile-time
#   * System.CommandLine (R459)    — runtime builder Microsoft official
#   * Whiley wycc.util.OptArg (R469) — Java in-house constructor overload
#   * Boogie CommandLineOptionEngine (THIS) — C# class-inheritance virtual
#                                            method override
#
# Boogie's library is closest in spirit to early ASP.NET configuration
# system (virtual methods on a base class) and to MSBuild's task model.
# It is DISTINCTIVE in being a STANDALONE CLI parser baked into a single
# verification tool's source tree rather than published as a separate
# NuGet package.  This is intentional: Boogie's CLI is designed to be
# subclassed by Dafny, VCC, etc. — those tools pull in the full Boogie
# library and override `ParseOption` to add their own flags ON TOP OF
# Boogie's existing flag set, gaining all of Boogie's 100+ verification
# flags for free.
#
# -----------------------------------------------------------------------------
# BOOGIE CLI SURFACE (selected from CommandLineOptions.cs — total ~150 flags)
# -----------------------------------------------------------------------------
#
# USAGE:
#   boogie [ /flag ... ] [ filename.bpl ... ]
#
# Help / version:
#   /version              Print version and exit
#   /help, /?             Print general help
#   /attrHelp             Print help on Boogie procedure attributes
#
# Tracing / output:
#   /trace                Enable trace output during verification
#   /quiet                Suppress non-essential output
#   /silent               Suppress all non-error output
#   /traceTimes           Print timing of each phase
#   /tracePOs             Print proof obligations as they're checked
#   /xml:<file>           Write XML report to file
#   /wait                 Wait for user keypress after verification
#
# Parsing / type-checking:
#   /noResolve            Skip resolution phase
#   /noTypecheck          Skip type-check phase
#   /overlookTypeErrors   Continue past type errors (best effort)
#   /forceBplErrors       Force errors as BoogiePL syntax errors
#
# Verification control:
#   /noVerify             Skip verification (just parse + type-check)
#   /traceverify          Trace verification details
#   /alwaysAssumeFreeLoopInvariants
#                         Assume free invariants without proving
#   /soundLoopUnrolling   Sound loop unrolling
#   /checkInfer           Check inferred invariants
#   /restartProver        Restart SMT solver between procedures
#   /verifySeparately     Verify each procedure in isolation
#   /timeLimit:<seconds>  Per-procedure timeout for SMT solver
#   /processTimeLimit:<s> Whole-process timeout
#   /procsToCheck:<re>    Only verify procedures matching regex
#
# Prover (SMT solver) configuration:
#   /prover:<name>        Choose SMT solver (z3, cvc4, cvc5, yices, smt)
#   /proverOpt:<k>=<v>    Pass option to SMT solver (repeatable)
#   /proverLog:<file>     Log SMT queries to file
#   /proverLogAppend      Append to prover log instead of overwriting
#   /proverWarnings:<n>   Show first N prover warnings
#   /proverHelp           Print prover-specific help
#
# Output formats (debugging):
#   /printUnstructured    Print unstructured form of program
#   /printDesugared       Print desugared form
#   /printLambdaLifting   Print lambda-lifted form
#   /printPassive         Print passified form
#   /printInstrumented    Print instrumented form
#   /printInlined         Print inlined form
#   /printWithUniqueIds   Print with unique identifiers
#   /printAssignment      Print procedure-level assignments
#
# Contract inference (Houdini):
#   /contractInfer        Run Houdini contract inference
#   /explainHoudini       Explain Houdini decisions
#   /reverseHoudiniWorklist  Reverse worklist order
#   /crossDependencies    Compute cross-procedure dependencies
#
# Misc analysis:
#   /smoke                Run smoke-test analysis
#   /vcsDumpSplits        Dump VC splits for debugging
#   /inferModifies        Infer modifies clauses automatically
#   /runDiagnosticsOnTimeout  Run diagnostic mode on timeout
#   /trackVerificationCoverage  Track verification coverage
#   /warnVacuousProofs    Warn on vacuous proofs
#   /useArrayAxioms       Use array axiomatization
#
# =============================================================================

_boogie() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a provers print_forms

    provers=(
        'z3:Microsoft Z3 (default)'
        'cvc4:CVC4 solver'
        'cvc5:CVC5 solver'
        'yices:Yices solver'
        'smt:generic SMT-LIB2 solver'
    )

    _arguments -s \
        '/version[print version and exit]' \
        '/help[print general help]' \
        '/?[print general help]' \
        '/attrHelp[print help on Boogie attributes]' \
        '/trace[enable trace output]' \
        '/quiet[suppress non-essential output]' \
        '/silent[suppress all non-error output]' \
        '/traceTimes[print phase timings]' \
        '/tracePOs[print proof obligations]' \
        '/xml:-[write XML report]:xml file:_files' \
        '/wait[wait for user keypress after verification]' \
        '/noResolve[skip resolution phase]' \
        '/noTypecheck[skip type-check phase]' \
        '/overlookTypeErrors[continue past type errors]' \
        '/forceBplErrors[force errors as BoogiePL syntax errors]' \
        '/noVerify[skip verification]' \
        '/traceverify[trace verification details]' \
        '/alwaysAssumeFreeLoopInvariants[assume free invariants]' \
        '/soundLoopUnrolling[sound loop unrolling]' \
        '/checkInfer[check inferred invariants]' \
        '/restartProver[restart SMT solver between procedures]' \
        '/verifySeparately[verify each procedure in isolation]' \
        '/timeLimit:-[per-procedure SMT timeout (seconds)]:seconds:' \
        '/processTimeLimit:-[whole-process timeout (seconds)]:seconds:' \
        '/procsToCheck:-[only verify procedures matching regex]:regex:' \
        '/prover:-[SMT solver backend]:prover:->prover' \
        '*/proverOpt:-[pass option to SMT solver]:key=value:' \
        '/proverLog:-[log SMT queries to file]:log file:_files' \
        '/proverLogAppend[append to prover log]' \
        '/proverWarnings:-[show first N prover warnings]:N:' \
        '/proverHelp[print prover-specific help]' \
        '/printUnstructured[print unstructured form]' \
        '/printDesugared[print desugared form]' \
        '/printLambdaLifting[print lambda-lifted form]' \
        '/printPassive[print passified form]' \
        '/printInstrumented[print instrumented form]' \
        '/printInlined[print inlined form]' \
        '/printWithUniqueIds[print with unique IDs]' \
        '/printAssignment[print procedure-level assignments]' \
        '/contractInfer[run Houdini contract inference]' \
        '/explainHoudini[explain Houdini decisions]' \
        '/reverseHoudiniWorklist[reverse worklist order]' \
        '/crossDependencies[compute cross-procedure dependencies]' \
        '/smoke[run smoke-test analysis]' \
        '/vcsDumpSplits[dump VC splits for debugging]' \
        '/inferModifies[infer modifies clauses automatically]' \
        '/runDiagnosticsOnTimeout[run diagnostic mode on timeout]' \
        '/trackVerificationCoverage[track verification coverage]' \
        '/warnVacuousProofs[warn on vacuous proofs]' \
        '/useArrayAxioms[use array axiomatization]' \
        '*:Boogie source:_files -g "*.bpl"' \
        && ret=0

    case $state in
        (prover)
            _describe -t provers 'SMT solver backend' provers && ret=0
            ;;
    esac

    return ret
}

_boogie "$@"
