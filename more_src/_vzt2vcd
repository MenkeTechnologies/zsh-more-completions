#compdef vzt2vcd
# Documentation: https://verilator.org/guide/latest/
# Convert VZT dumpfiles to VCD

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help then exit]' \
  '(-v --vztname)'{-v+,--vztname=}'[specify VZT input filename]:file:_files -g "*.vzt"' \
  '(-o --output)'{-o+,--output=}'[specify optional VCD output filename]:file:_files -g "*.vcd"' \
  '(-f --flatearth)'{-f,--flatearth}'[emit flattened hierarchies]' \
  '(-c --coalesce)'{-c,--coalesce}'[coalesce bitblasted vectors]' \
  '(-n --notruncate)'{-n,--notruncate}'[do not shorten bitvectors]' \
  '*:VZT file:_files -g "*.vzt"' && ret=0

return ret
