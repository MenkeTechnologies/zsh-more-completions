#compdef pgbackrest

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'archive-get:fetch a WAL segment from the archive'
  'archive-push:push a WAL segment to the archive'
  'backup:perform a backup'
  'check:check the configuration'
  'expire:expire backups'
  'help:show help'
  'info:retrieve info about backups'
  'repo-create:create a stanza repo'
  'restore:restore a database cluster'
  'server:run a TLS server'
  'server-ping:ping a TLS server'
  'stanza-create:create a stanza'
  'stanza-delete:delete a stanza'
  'stanza-upgrade:upgrade a stanza'
  'start:allow operations'
  'stop:stop operations'
  'verify:verify backup contents'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*--config=[config file]:file:_files -g "*.conf"' \
  '*--config-include-path=[config include path]:dir:_files -/' \
  '*--config-path=[config path]:dir:_files -/' \
  '*--no-config[skip config]' \
  '*--log-level-console=[log level console]:l:(off error warn info detail debug trace)' \
  '*--log-level-file=[log level file]:l:(off error warn info detail debug trace)' \
  '*--log-level-stderr=[log level stderr]:l:' \
  '*--log-path=[log path]:dir:_files -/' \
  '*--log-subprocess[log subprocess]' \
  '*--log-timestamp[log timestamp]' \
  '*--no-log-timestamp[no log timestamp]' \
  '*--neutral-umask[neutral umask]' \
  '*--no-neutral-umask[no neutral umask]' \
  '(--stanza)--stanza=[stanza]:s:' \
  '*--repo=[repo n]:n:' \
  '*--repo-path=[repo path]:dir:_files -/' \
  '*--repo-host=[repo host]:host:_hosts' \
  '*--repo-host-user=[repo host user]:u:_users' \
  '*--repo-storage-port=[storage port]:port:' \
  '*--repo-cipher-type=[cipher type]:t:(none aes-256-cbc)' \
  '*--repo-cipher-pass=[cipher pass]:p:' \
  '*--repo-retention-archive=[archive retention]:n:' \
  '*--repo-retention-archive-type=[archive retention type]:t:(full diff incr)' \
  '*--repo-retention-full=[full retention]:n:' \
  '*--repo-retention-diff=[diff retention]:n:' \
  '*--pg=[pg n]:n:' \
  '*--pg-path=[pg path]:dir:_files -/' \
  '*--pg-port=[pg port]:port:' \
  '*--pg-host=[pg host]:host:_hosts' \
  '*--pg-user=[pg user]:u:_users' \
  '*--process-max=[process max]:n:' \
  '*--archive-async[archive async]' \
  '*--archive-timeout=[archive timeout s]:s:' \
  '*--start-fast[start fast]' \
  '*--stop-auto[stop auto]' \
  '*--type=[backup type]:t:(full diff incr)' \
  '*--target=[restore target]:t:' \
  '*--target-action=[target action]:a:(pause promote shutdown)' \
  '*--target-timeline=[target timeline]:n:' \
  '*--target-exclusive[target exclusive]' \
  '*--delta[delta restore]' \
  '*--force[force]' \
  '*--set=[backup set]:s:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pgbackrest command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
