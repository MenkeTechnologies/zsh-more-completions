#compdef cyrus-mbpath
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/mbpath.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org mbpath(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-mbpath: print Cyrus mailbox filesystem paths
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '(-l --local-only)'{-l,--local-only}'[only local mailboxes]' \
  '-m[legacy metadata path (use -M)]' \
  '(-q --quiet)'{-q,--quiet}'[suppress error output]' \
  '(-s --stop)'{-s,--stop}'[stop on first error]' \
  '(-u --userids -p --paths)'{-u,--userids}'[arguments are userids]' \
  '(-p --paths -u --userids)'{-p,--paths}'[arguments are UNIX mailbox paths]' \
  '(-A --archive)'{-A,--archive}'[print archive partition path]' \
  '(-D --data)'{-D,--data}'[print data partition path (default)]' \
  '(-M --metadata)'{-M,--metadata}'[print metadata partition path]' \
  '(-S --sieve)'{-S,--sieve}'[print Sieve script path]' \
  '(-U --user-files)'{-U,--user-files}'[print per-user files path]' \
  '(-a --all)'{-a,--all}'[print every applicable path]' \
  '*:mailbox or userid:' && ret=0
return ret
