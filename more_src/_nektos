# Reference accessed: 2026-05-16
# Source: https://github.com/MenkeTechnologies/zsh-more-completions/blob/d278e5f1659fc62ca4671ab34a319c3ceb558a41/src/_nektos
# Repository: MenkeTechnologies/zsh-more-completions (src/_nektos)

# nektos/act - run GitHub Actions locally (alternative binary name)
# The main binary is 'act' which is handled by _act completion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:args' && ret=0

return ret
