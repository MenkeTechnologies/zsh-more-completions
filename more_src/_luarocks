#compdef luarocks

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:build/compile a rock'
  'config:query/set the LuaRocks config'
  'doc:show documentation for a package'
  'download:download a rock from a server'
  'help:show help'
  'init:initialize a project directory'
  'install:install a rock'
  'lint:check syntax of a rockspec'
  'list:list installed rocks'
  'make:compile package using a rockspec'
  'new_version:auto-write a rockspec for a new version'
  'pack:create a rock packing sources/binaries'
  'path:return module path/cpath/PATH for shells'
  'purge:remove all installed rocks from a tree'
  'remove:uninstall a rock'
  'search:search for rocks in repositories'
  'show:show information about a rock'
  'test:run package test suite'
  'unpack:unpack contents of a rock'
  'upload:upload a rockspec to luarocks.org'
  'which:show which file corresponds to a module'
  'write_rockspec:write a template rockspec'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--dev[enable in-development sub-repositories]' \
  '--server=[fetch from this server]:url:' \
  '--only-server=[use only this server]:url:' \
  '--only-sources=[restrict downloads to URLs starting with]:prefix:' \
  '--namespace=[namespace]:namespace:' \
  '--lua-dir=[Lua install prefix]:dir:_files -/' \
  '--lua-version=[Lua version]:version:' \
  '--tree=[rocks tree]:dir:_files -/' \
  '--local[use the user tree]' \
  '--global[use system tree even if local_by_default]' \
  '--no-project[do not auto-detect a luarocks project]' \
  '--force-lock[forcibly take lock]' \
  '--verbose[show detailed output]' \
  '--timeout=[network timeout]:secs:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'luarocks subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (build|install|make|pack|remove|show|test|unpack|download)
        _files
        ret=0
        ;;
    esac
    ;;
esac

return ret
