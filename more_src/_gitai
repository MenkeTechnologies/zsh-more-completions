#compdef gitai
# Documentation: https://github.com/suhailroushan13/gitai
# Reference accessed: 2026-05-23
# Verified: upstream README options (--docs, --help).

# Zsh completion for gitai - interactive Git helper CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --docs)'{-d,--docs}'[show Git reference docs]' \
  'docs[show Git reference docs]' && ret=0

return ret
