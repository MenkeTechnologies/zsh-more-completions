#compdef threshold Threshold
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/StreamDefinitionByThreshold.html
# TauDEM: define stream raster by thresholding an accumulation grid

local ret=1

_arguments -s -S \
  '-ssa[input grid to be thresholded]:ssafile:_files' \
  '-src[output stream raster grid]:srcfile:_files' \
  '-thresh[threshold parameter (default 100.0)]:value:' \
  '-mask[input grid used to mask the output]:maskfile:_files' \
  '*:file:_files' && ret=0

return ret
