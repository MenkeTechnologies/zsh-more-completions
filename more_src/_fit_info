#compdef fit_info
# Documentation: https://docs.u-boot.org/en/latest/usage/fit/signature.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fit_info: U-Boot tool to display info (name, length, offset) about FIT image contents.

_arguments -s \
  '-f+[FIT image file]:file:_files' \
  '-n+[node name (e.g. /images/kernel)]:name:' \
  '-p+[property name (e.g. data)]:name:'
