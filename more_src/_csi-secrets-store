#compdef csi-secrets-store csi-secrets-store-cli secrets-store-csi-driver
# _csi-secrets-store — Kubernetes SIG Storage csi-secrets-store CLI command-line frontend wrapping the Secrets Store CSI Driver mounting external secrets manager secrets AWS Secrets Manager GCP Secret Manager Azure Key Vault Vault provider pods volumes SecretProviderClass syncing-to-K8s-Secrets-CRD-Reconciler-pod-rotation-CSI-driver-installation (Kubernetes team, Go); cobra
# upstream: https://secrets-store-csi-driver.sigs.k8s.io/

_csi-secrets-store() {
    local -a sub=(
        'install:install Secrets Store CSI Driver'
        'uninstall:uninstall Secrets Store CSI Driver'
        'provider:provider management'
        'class:SecretProviderClass operations'
        'list:list pods using the driver'
        'sync:trigger sync'
        'logs:fetch driver logs'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '--provider=+[p]:p:(aws gcp azure vault akeyless conjur doppler hashicorp-vault yandex)' \
        '--sync-K8s-secret=+[bool]:s:(true false)' \
        '--rotation-poll-interval=+[duration]:str:' \
        '--enable-secret-rotation[enable rotation]' \
        '--metrics-addr=+[host:port]:str:' \
        '--metrics-backend=+[b]:b:(opencensus prometheus)' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'csi-secrets-store subcommand' sub ;;
        args)
            case $words[1] in
                provider|class) _arguments '1:op:(list get create update delete)' '*:name:' ;;
            esac
            ;;
    esac
}

_csi-secrets-store "$@"
