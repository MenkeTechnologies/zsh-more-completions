#compdef gocognit
# Documentation: https://man.archlinux.org/search?q=gocognit
# Reference accessed: 2026-05-16

_arguments -s \
  '-over=[show funcs above N]:n:' \
  '-top=[show top N most complex]:n:' \
  '-avg[show average complexity]' \
  '-test[include test files]' \
  '-json[encode output as JSON]' \
  '-d[diagnostic output]' \
  '-f=[output format template]:template:' \
  '-ignore=[regex of files to ignore]:regex:' \
  '*:path:_files'
