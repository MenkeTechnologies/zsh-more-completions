#compdef syncthing-discosrv stdiscosrv
# Documentation: https://docs.syncthing.net/users/stdiscosrv.html
# Reference accessed: 2026-05-16
# Verified: upstream Syncthing stdiscosrv documentation.
# Removed from prior file: fabricated single-dash -V flag and bogus
# man.archlinux.org search URL.

# syncthing-discosrv (stdiscosrv): Syncthing global discovery server
local curcontext="$curcontext" ret=1
_arguments -C \
  '--debug[enable debug output]' \
  '--http[use HTTP instead of HTTPS]' \
  '--version[show version]' \
  '--compression[enable response compression]' \
  '--cert=[certificate file (default ./cert.pem)]:file:_files' \
  '--key=[key file (default ./key.pem)]:file:_files' \
  '--listen=[listen address (default :8443)]:addr:' \
  '--metrics-listen=[metrics listen address]:addr:' \
  '--db-dir=[database directory (default .)]:dir:_files -/' \
  '--db-flush-interval=[database flush interval (default 5m)]:duration:' && ret=0
return ret
