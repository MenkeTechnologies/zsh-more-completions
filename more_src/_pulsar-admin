#compdef pulsar-admin

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--admin-url=[admin service URL]:url:' \
  '--auth-plugin=[auth plugin class name]:class:' \
  '--auth-params=[auth plugin parameters]:params:' \
  '--tls-trust-certs-filepath=[TLS trusted certs file]:file:_files' \
  '--tls-allow-insecure[allow insecure TLS connection]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'brokers:manage brokers'
      'broker-stats:get broker stats'
      'clusters:manage clusters'
      'functions:manage Pulsar Functions'
      'namespaces:manage namespaces'
      'ns-isolation-policy:manage namespace isolation policies'
      'packages:manage packages'
      'persistent:manage persistent topics'
      'non-persistent:manage non-persistent topics'
      'resource-quotas:manage resource quotas'
      'schemas:manage schemas'
      'sinks:manage Pulsar IO sinks'
      'sources:manage Pulsar IO sources'
      'tenants:manage tenants'
      'topics:manage topics'
      'topicPolicies:manage topic policies'
      'transactions:manage transactions'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (topics|persistent|non-persistent)
        _arguments \
          '1:action:(list get-stats create delete partitioned-topic-metadata lookup bundle-range permissions grant-permission revoke-permission get-backlog-quotas set-backlog-quotas get-message-ttl set-message-ttl get-retention set-retention remove-retention get-compaction-threshold set-compaction-threshold get-offload-policies set-offload-policies get-dispatch-rate set-dispatch-rate)' \
          '2:topic:' && ret=0
        ;;
      (namespaces)
        _arguments \
          '1:action:(list create delete get-retention set-retention get-backlog-quota set-backlog-quota policies set-schema-validation-enforce get-message-ttl set-message-ttl get-clusters set-clusters)' \
          '2:namespace:' && ret=0
        ;;
      (tenants)
        _arguments \
          '1:action:(list get create update delete)' \
          '2:tenant:' && ret=0
        ;;
      (clusters)
        _arguments \
          '1:action:(list get create update delete get-peer-clusters update-peer-clusters)' \
          '2:cluster:' && ret=0
        ;;
      (functions)
        _arguments \
          '1:action:(list get create update delete status stats trigger restart stop start)' \
          '--tenant=[tenant]:tenant:' \
          '--namespace=[namespace]:namespace:' \
          '--name=[function name]:name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
