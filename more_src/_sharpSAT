#compdef sharpSAT
# Documentation: https://github.com/marcthurley/sharpSAT
# exact model counter (#SAT)

local ret=1

_arguments -s -S \
  '-noPP[turn off preprocessing]' \
  '-noCC[turn off component caching]' \
  '-noIBCP[turn off implicit BCP]' \
  '-q[quiet mode]' \
  '-t+[set time bound in seconds]:seconds' \
  '-cs+[set max cache size in MB]:mb' \
  '*:dimacs file:_files' && ret=0

return ret
