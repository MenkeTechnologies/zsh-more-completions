#compdef top-cli
# _top-cli — procps top display Linux processes CLI alias (procps team, C); custom argparse
# upstream: https://gitlab.com/procps-ng/procps

_top-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[batch mode]' \
        '-c[command line/program name toggle]' \
        '-d+[delay seconds]:str:' \
        '-E+[summary units]:u:(k m g t p e)' \
        '-e+[task units]:u:(k m g t p)' \
        '-H[threads]' \
        '-i[idle processes toggle]' \
        '-n+[iterations]:n:' \
        '-o+[sort field]:str:' \
        '-O[show field names]' \
        '-p+[pids]:str:' \
        '-S[cumulative time toggle]' \
        '-s[secure mode]' \
        '-U+[real user]:_users' \
        '-u+[user]:_users' \
        '-w+[width]:n:' \
        '-1[single cpu line toggle]' \
        '*:arg:'
}

_top-cli "$@"
