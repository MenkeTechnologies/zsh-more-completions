#compdef net-snmp-create-v3-user
# _net-snmp-create-v3-user — net-snmp net-snmp-create-v3-user (helper script that appends an SNMPv3 user/credential block to /var/lib/snmp/snmpd.conf and /etc/snmp/snmpd.conf so snmpd can later authenticate it; -ro create read-only user, -A auth password, -X priv password, -a auth alg (MD5|SHA), -x priv alg (DES|AES); positional argument is the user name)
# upstream: https://www.net-snmp.org/
# Flags from net-snmp net-snmp-create-v3-user.in on tip.

_net-snmp-create-v3-user() {
    _arguments \
        '-h[show help]' \
        '-ro[read-only user]' \
        '-A+[auth password]:password:' \
        '-X+[priv password]:password:' \
        '-a+[auth alg]:alg:(MD5 SHA SHA-224 SHA-256 SHA-384 SHA-512)' \
        '-x+[priv alg]:alg:(DES AES AES-192 AES-256)' \
        '1:user:_users'
}

_net-snmp-create-v3-user "$@"
