#compdef fabricd
# Documentation: https://docs.frrouting.org/en/latest/fabricd.html
# FRR OpenFabric routing engine daemon

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print a short description of the command line options]' \
  '(-v --version)'{-v,--version}'[print version and build information]' \
  '(-d --daemon)'{-d,--daemon}'[launch the process in background mode]' \
  '(-t --terminal)'{-t,--terminal}'[open an interactive VTY session on the terminal]' \
  '(-f --config_file)'{-f,--config_file}'[specify an alternate configuration file]:config file:_files' \
  '(-C --dryrun)'{-C,--dryrun}'[load and validate the configuration file, then exit]' \
  '(-i --pid_file)'{-i,--pid_file}'[output a process ID file to a non-default location]:pid file:_files' \
  '(-z --socket)'{-z,--socket}'[override the path of the ZAPI socket]:zclient path:_files' \
  '(-N --pathspace)'{-N,--pathspace}'[insert pathspace into default paths]:pathspace:' \
  '(-u --user)'{-u,--user}'[change the user the daemon switches to]:user:_users' \
  '(-g --group)'{-g,--group}'[change the group the daemon switches to]:group:_groups' \
  '(-S --skip_runas)'{-S,--skip_runas}'[skip setting the process effective user and group]' \
  '(-A --vty_addr)'{-A,--vty_addr}'[bind the TCP VTY interface to a specific address]:vty addr:_hosts' \
  '(-P --vty_port)'{-P,--vty_port}'[override the default TCP VTY port]:vty port:' \
  '--vty_socket[override the directory used for VTY sockets]:vty path:_files -/' \
  '(-M --module)'{-M,--module}'[load a dynamically loadable module at startup]:module:' \
  '--moduledir[search for modules in an alternate directory]:module path:_files -/' \
  '--dummy_as_loopback[treat dummy interfaces as loopback interfaces]' && ret=0

return ret
