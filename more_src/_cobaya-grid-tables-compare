#compdef cobaya-grid-tables-compare
# Documentation: https://cobaya.readthedocs.io/en/latest/grids.html
# cobaya: make comparison parameter tables across grid data tags

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*--params=[parameters to compare in the output tables]:param' \
  '*--single_extparams=[single parameter extensions to restrict to]:param' \
  '*--compare=[data tags to compare]:datatag' \
  '--nobestfits[do not quote best-fit values]' \
  '--limit=[sigmas of quoted confidence intervals]:sigmas' \
  '--latex_filename=[name of latex file to produce]:file:_files -g "*.tex"' \
  '--math_columns[include $$ in the output for each column]' \
  '--endline=[end-of-line string]:endline' \
  '--paramNameFile=[parameter name file giving latex labels]:file:_files' \
  '1:grid directory:_files -/' && ret=0

return ret
