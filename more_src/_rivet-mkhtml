#compdef rivet-mkhtml
# Documentation: https://rivet.hepforge.org/
# rivet-mkhtml - make a web page of comparison plots from YODA files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --outputdir)'{-o,--outputdir}'[directory for Web page output]:dir:_files -/' \
  '*'{-c,--config}'[plot config file(s) for rivet-cmphistos]:file:_files' \
  '(-n --num-threads)'{-n,--num-threads}'[number of make-plots threads]:num:' \
  '--ignore-missing[ignore missing YODA files]' \
  '(-i --ignore-unvalidated)'{-i,--ignore-unvalidated}'[ignore unvalidated analyses]' \
  '--dry-run[do not actually plot or build HTML]' \
  '--no-cleanup[keep plotting temporary directory]' \
  '--no-subproc[do not render plots in parallel subprocesses]' \
  '--pwd[append current directory to analysis/data search paths]' \
  '(-t --title)'{-t,--title}'[title displayed on the main web page]:title:' \
  '--reftitle[legend entry for reference data]:title:' \
  '--no-plottitle[do not show the plot title on the plot]' \
  '(-s --single)'{-s,--single}'[display plots on single webpage]' \
  '--no-ratio[do not draw a ratio plot under each main plot]' \
  '(--errs --mcerrs --mc-errs)'{--errs,--mcerrs,--mc-errs}'[plot error bars]' \
  '--offline[generate HTML that does not use external URLs]' \
  '--pdf[use PDF as the vector plot format]' \
  '--ps[use PostScript as the vector plot format (deprecated)]' \
  '--booklet[create booklet]' \
  '--font[font to be used in the plots]:font:' \
  '--remove-options[remove options label from legend]' \
  '*'{-m,--match}'[only write histograms whose path matches regexes]:regex:' \
  '*'{-M,--unmatch}'[exclude histograms whose path matches regexes]:regex:' \
  '*--ana-match[only write histograms from analyses matching regexes]:regex:' \
  '*--ana-unmatch[exclude histograms from analyses matching regexes]:regex:' \
  '(-v --verbose)'{-v,--verbose}'[add extra debug messages]' \
  '*:yodafile:_files' && ret=0

return ret
