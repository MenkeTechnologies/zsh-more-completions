#compdef PotreeConverter
# PotreeConverter — convert point clouds to Potree web viewer format

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-i,--source}'=[input file]:input file:_files -g "*.(las|laz|ptx|ply|xyz|pts|LAS|LAZ)(-.)"' \
  {-o,--outdir}'=[output directory]:output dir:_directories' \
  '--generate-page=[generate HTML viewer page]:page name:' \
  {-p,--format}'=[source point format]:format:(LAS LAZ PTX PLY)' \
  '--spacing=[distance between points at root level]:spacing:' \
  '--levels=[number of levels for octree]:levels:' \
  '--output-format=[output format]:format:(DEFAULT LAS LAZ BINARY CESIUM)' \
  '--projection=[coordinate reference system]:projection:' \
  '--overwrite[overwrite existing output]' \
  '--source=[input source]:source:_files' \
  '--title=[page title for generated HTML]:title:' \
  '--no-additive-point-sizing[disable additive point sizing]' \
  '--scale=[scale factor]:scale:' \
  '--aabb=[axis-aligned bounding box]:bounding box:' \
  '--encoding=[encoding type]:encoding:(DEFAULT UNCOMPRESSED)' \
  '--thread=[number of threads]:threads:' \
  '*:input file:_files -g "*.(las|laz|ptx|ply|xyz|pts)(-.)"' && ret=0

return ret
