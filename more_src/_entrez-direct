#compdef entrez-direct edirect efilter elink epost
# _entrez-direct — NCBI Entrez Direct EDirect Unix-style command line tools for NCBI Entrez programmatic access (NCBI team, Perl/Bash); custom argparse
# upstream: https://www.ncbi.nlm.nih.gov/books/NBK179288/

_entrez-direct() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-db+[database]:d:(pubmed protein nuccore nucleotide gene genome assembly sra biosample bioproject taxonomy structure pmc mesh clinvar dbvar dbsnp dbgap gtr cdd snp omim)' \
        '-query+[query string]:str:' \
        '-id+[uid list]:str:' \
        '-input+[input file]:file:_files' \
        '-output+[output file]:file:_files' \
        '-mode+[mode]:m:(xml asn json text)' \
        '-format+[format]:f:(uid xml abstract medline gb gp fasta gpwithparts ft uilist json)' \
        '-target+[target]:t:(pubmed_gene gene_pubmed protein_nuccore pubmed_protein)' \
        '-cmd+[command]:c:(neighbor neighbor_history acheck llinks llinkslib lcheck ncheck prlinks)' \
        '-name+[name]:str:' \
        '-rettype+[rettype]:r:(uid xml abstract docsum gb gp fasta sequin medline json)' \
        '-retmax+[N]:n:' \
        '-start+[N]:n:' \
        '-stop+[N]:n:' \
        '-sort+[sort]:s:(last+author first+author pub+date relevance journal)' \
        '-pattern+[pattern file]:file:_files' \
        '-element+[element]:str:' \
        '-block+[block]:str:' \
        '-pfx+[prefix]:str:' \
        '-sfx+[suffix]:str:' \
        '-sep+[separator]:str:' \
        '-min+[N]:n:' \
        '-max+[N]:n:' \
        '-debug[debug]' \
        '-timer[print timing]' \
        '-quiet[quiet]' \
        '*:argument:'
}

_entrez-direct "$@"
