#compdef pamcomp
# Documentation: man pamcomp (Netpbm)
# Source: Netpbm pamcomp — composite (overlay) two Netpbm images together.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-align=[horizontal alignment]:align:(left center right beyondleft beyondright)' \
    '-valign=[vertical alignment]:valign:(top middle bottom above below)' \
    '-xoff=[X offset (pixels)]:X:' \
    '-yoff=[Y offset (pixels)]:Y:' \
    '-alpha=[transparency PGM mask file]:alpha-pgmfile:_files -g "*.pgm"' \
    '-invert[invert transparency mask sense]' \
    '-opacity=[overlay opacity (0..1)]:opacity:' \
    '-mixtransparency[alpha-blend transparencies]' \
    '-linear[use linear (not gamma-corrected) blending]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:overlay then optional underlying + output:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
