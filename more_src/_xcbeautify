#compdef xcbeautify

# Zsh completion for xcbeautify - xcodebuild output formatter

local -a arguments

arguments=(
  '(--preserve-unbeautified)--preserve-unbeautified[preserve unbeautified output lines]'
  '(--is-ci)--is-ci[change output for non-TTY environments]'
  '(--disable-logging)--disable-logging[disable internal logging]'
  '(--disable-colored-output)--disable-colored-output[disable colored output]'
  '(-q --quiet)'{-q,--quiet}'[only print tasks that have warnings or errors]'
  '(-qq --quieter)'{-qq,--quieter}'[only print tasks that have errors]'
  '--report[generate the specified report]:report type:(html junit json-compilation-database github-actions-logging slack teamcity)'
  '--report-path[path to place generated reports]:path:_files -/'
  '--renderer[output renderer format]:renderer:(terminal github-actions teamcity azure-devops-pipelines)'
  '--preserve-unbeautified-lines[preserve unbeautified build output]'
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[show xcbeautify version]'
)

_arguments -s -S $arguments
