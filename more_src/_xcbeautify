#compdef xcbeautify
# Documentation: https://github.com/cpisciotta/xcbeautify
# Reference accessed: 2026-05-21
# Verified: Sources/xcbeautify/Xcbeautify.swift (swift-argument-parser):
# --quiet/-q, --quieter (with single-dash -qq), --preserve-unbeautified,
# --is-ci, --disable-colored-output, --disable-logging, --renderer,
# --report (only junit), --report-path, --junit-report-filename.

local -a arguments

arguments=(
  '(-q --quiet)'{-q,--quiet}'[only print tasks that have warnings or errors]'
  '(--quieter -qq)'{--quieter,-qq}'[only print tasks that have errors]'
  '--preserve-unbeautified[preserve unbeautified output lines]'
  '--is-ci[print test results under quiet/quieter]'
  '--disable-colored-output[disable colored output]'
  '--disable-logging[suppress xcbeautify info table on start]'
  '--renderer=[output renderer]:renderer:(terminal github-actions teamcity azure-devops-pipelines)'
  '*--report=[generate the specified report]:report type:(junit)'
  '--report-path=[directory to write reports]:path:_files -/'
  '--junit-report-filename=[JUnit report file name]:name:'
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[show xcbeautify version]'
)

_arguments -s -S $arguments
