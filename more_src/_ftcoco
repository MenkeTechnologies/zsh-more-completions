#compdef ftcoco
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftcoco.html
# Convert coordinates between galactic, equatorial, and ecliptic systems

local ret=1

_arguments -s -S \
  'infile=[input FITS file with coordinates, or NONE]:infile:_files' \
  'outfile=[output file for converted coordinates]:outfile:_files' \
  'incoord=[input coordinate system code]:incoord:(R G E)' \
  'lon1=[input longitude column or value in degrees]:lon1:' \
  'lat1=[input latitude column or value in degrees]:lat1:' \
  'lon2=[output longitude column or keyword name]:lon2:' \
  'lat2=[output latitude column or keyword name]:lat2:' \
  'radecsys=[fundamental coordinate system]:radecsys:(FK4 FK5)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
