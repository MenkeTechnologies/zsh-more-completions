#compdef nxv
# Documentation: https://man.archlinux.org/search?q=nxv
# Reference accessed: 2026-05-16

# https://github.com/utensils/nxv — local/offline nixpkgs version index (see src/cli.rs)

local curcontext="$curcontext" state line ret=1

_nxv_cmds() {
  local -a cmd=(
    'search:search package versions'
    'update:refresh index (and optional self-update)'
    'info:detailed package information'
    'stats:index statistics'
    'history:version timeline for a package'
    'serve:start HTTP API + web UI'
    'completions:emit shell completions'
    'index:build index from nixpkgs checkout (indexer feature)'
    'backfill:fill missing metadata (indexer feature)'
    'reset:reset nixpkgs git worktree (indexer feature)'
    'dedupe:collapse duplicate rows (indexer feature)'
    'publish:emit signed index artifacts (indexer feature)'
    'keygen:generate minisign keypair (indexer feature)'
  )
  _describe -t commands 'nxv command' cmd
}

_arguments -C \
  '--db-path=[path to index DB]:path:_files' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
  '--no-color[disable ANSI colors]' \
  '--api-timeout=[HTTP timeout for remote backend (seconds)]:seconds:' \
  '1: :_nxv_cmds' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      search)
        _arguments -s -S \
          '--desc[search package descriptions (FTS)]' \
          '--license=[filter by SPDX license]:license:' \
          '(-f --format)'{-f,--format}'=[output format]:format:(table json plain)' \
          '--show-platforms[show platform column]' \
          '--sort=[sort key]:key:(date version name)' \
          '(-r --reverse)'{-r,--reverse}'[reverse sort]' \
          '(-n --limit)'{-n,--limit}'=[max rows (0 = unlimited)]:count:' \
          '(-e --exact)'{-e,--exact}'[exact package name match]' \
          '--full[show all commits per package+version]' \
          '--ascii[ASCII table borders]' \
          '(-V --version)'{-V,--version}'=[version prefix filter]:version:' \
          '1:package:' \
          '2::version_prefix' && ret=0
        ;;
      update)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[force full index re-download]' \
          '--manifest-url=[custom manifest URL]:url:' \
          '--skip-verify[skip manifest signature check (INSECURE)]' \
          '--public-key=[minisign public key or path]:key:' \
          '--no-self-update[only refresh index]' && ret=0
        ;;
      info)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'=[output format]:format:(table json plain)' \
          '(-V --version)'{-V,--version}'=[specific version]:version:' \
          '1:package:' \
          '2::version' && ret=0
        ;;
      stats) _message -e 'no arguments' && ret=0 ;;
      history)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'=[output format]:format:(table json plain)' \
          '--full[full commit + metadata details]' \
          '--ascii[ASCII table borders]' \
          '1:package:' \
          '2::version' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(-H --host)'{-H,--host}'=[bind address]:host:' \
          '(-p --port)'{-p,--port}'=[listen port]:port:' \
          '--cors[enable wildcard CORS]' \
          '--cors-origins=[allowed origins (comma)]:origins:' \
          '--rate-limit=[requests per second per IP]:rps:' \
          '--rate-limit-burst=[burst multiplier]:burst:' && ret=0
        ;;
      completions)
        _arguments -s -S '1:shell:(bash elvish fish powershell zsh)' && ret=0
        ;;
      index)
        _arguments -s -S \
          '--nixpkgs-path=[path to nixpkgs git checkout]:path:_directories' \
          '--full[full rebuild from scratch]' \
          '--checkpoint-interval=[commits between checkpoints]:n:' \
          '--systems=[comma-separated systems]:systems:' \
          '--since=[include commits after date]:date:' \
          '--until=[include commits before date]:date:' \
          '--max-commits=[stop after N commits]:n:' && ret=0
        ;;
      backfill)
        _arguments -s -S \
          '--nixpkgs-path=[path to nixpkgs checkout]:path:_directories' \
          '--fields=[comma-separated fields]:fields:' \
          '--limit=[max packages]:n:' \
          '--dry-run[no database writes]' \
          '--history[walk git history for removed packages]' && ret=0
        ;;
      reset)
        _arguments -s -S \
          '--nixpkgs-path=[path to nixpkgs checkout]:path:_directories' \
          '--to=[git ref to reset to]:ref:' \
          '--fetch[git fetch before reset]' && ret=0
        ;;
      dedupe)
        _arguments -s -S '--dry-run[report only]' '--no-vacuum[skip VACUUM]' && ret=0
        ;;
      publish)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'=[output directory]:dir:_directories' \
          '--url-prefix=[manifest URL prefix]:url:' \
          '--sign[minisign manifest]' \
          '--secret-key=[minisign secret key path or raw]:key:' \
          '--min-version=[minimum reader schema version]:ver:' && ret=0
        ;;
      keygen)
        _arguments -s -S \
          '(-s --secret-key)'{-s,--secret-key}'=[secret key output path]:file:_files' \
          '(-p --public-key)'{-p,--public-key}'=[public key output path]:file:_files' \
          '(-c --comment)'{-c,--comment}'=[key comment]:comment:' \
          '(-f --force)'{-f,--force}'[overwrite existing keys]' && ret=0
        ;;
    esac
    ;;
esac

return ret
