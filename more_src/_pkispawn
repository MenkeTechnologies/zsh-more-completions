#compdef pkispawn
# Documentation: https://github.com/dogtagpki/pki/blob/master/docs/manuals/man8/pkispawn.8.md
# Reference accessed: 2026-05-16
# Verified: upstream docs/manuals/man8/pkispawn.8.md.

# pkispawn: install Dogtag PKI subsystem
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-s[PKI subsystem to install]:subsystem:(CA KRA OCSP TKS TPS)' \
  '-f[user configuration file]:file:_files' \
  '--precheck[run preliminary validation only]' \
  '--skip-configuration[skip configuration phase]' \
  '--skip-installation[skip installation phase]' \
  '*-v[verbose output (repeatable)]' && ret=0
return ret
