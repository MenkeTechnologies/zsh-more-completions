#compdef vpncloud
# Documentation: https://man.archlinux.org/search?q=vpncloud
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'genkey:generate key pair'
  'gen-key:generate key pair'
  'wsproxy:run WebSocket proxy'
  'migrate:migrate config'
  'completion:generate shell completion'
  'config:show effective config'
  'install:install vpncloud'
)

_arguments -C \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '(-t --type)'{-t,--type}'=[device type]:type:(tun tap)' \
  '(-d --device)'{-d,--device}'=[device name]:name:_net_interfaces' \
  '--device-path=[device path]:file:_files' \
  '--fix-rp-filter[fix rp_filter]' \
  '(-m --mode)'{-m,--mode}'=[mode]:mode:(normal hub switch router)' \
  '(-l --listen)'{-l,--listen}'=[listen address]:addr:' \
  '*'{-c,--peer,--connect}'=[peer]:peer:' \
  '--peer-timeout=[peer timeout]:s:' \
  '--keepalive=[keepalive]:s:' \
  '--switch-timeout=[switch timeout]:s:' \
  '--ip=[interface IP]:ip:' \
  '*--advertise-addresses=[advertise address]:addr:' \
  '--ifup=[script after up]:cmd:' \
  '--ifdown=[script before down]:cmd:' \
  '(-p --password)'{-p,--password}'=[shared password]:password:' \
  '--key=[private key]:key:' \
  '--private-key=[private key]:key:' \
  '--public-key=[public key]:key:' \
  '*--trust=[trusted key]:key:' \
  '*--trusted-key=[trusted key]:key:' \
  '--algo=[algorithm]:algo:(plain aes128 aes256 chacha20)' \
  '--algorithm=[algorithm]:algo:(plain aes128 aes256 chacha20)' \
  '--beacon-store=[beacon store path]:path:' \
  '--beacon-load=[beacon load path]:path:' \
  '--beacon-interval=[beacon interval]:s:' \
  '--beacon-password=[beacon password]:password:' \
  '--claim=[claim subnet]:subnet:' \
  '--no-auto-claim[disable auto claim]' \
  '--no-port-forwarding[disable UPnP]' \
  '--daemon[run as daemon]' \
  '--pid-file=[pid file]:file:_files' \
  '--stats-file=[stats file]:file:_files' \
  '--statsd-server=[statsd server]:host:port:' \
  '--statsd-prefix=[statsd prefix]:prefix:' \
  '--user=[run as user]:user:_users' \
  '--group=[run as group]:group:_groups' \
  '--log-file=[log file]:file:_files' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(- *)--version[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*--hook=[event hook]:cmd:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'vpncloud subcommand' subcommands && ret=0
    ;;
esac

return ret
