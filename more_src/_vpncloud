#compdef vpncloud
# Documentation: https://github.com/dswd/vpncloud/blob/master/vpncloud.adoc
# Reference accessed: 2026-05-21
# Verified: upstream manpage source at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'genkey:generate key pair'
  'wsproxy:run WebSocket proxy'
  'migrate:migrate config'
  'completion:generate shell completion'
  'config:show effective config'
  'install:install vpncloud'
)

_arguments -C \
  '--config=[load settings from configuration file]:file:_files' \
  '(-t --type)'{-t,--type}'=[network type]:type:(tun tap)' \
  '(-d --device)'{-d,--device}'=[virtual device name]:name:_net_interfaces' \
  '--device-path=[base device inode path]:file:_files' \
  '--fix-rp-filter[mitigate CVE-2019-14899]' \
  '(-m --mode)'{-m,--mode}'=[VPN mode]:mode:(normal hub switch router)' \
  '(-l --listen)'{-l,--listen}'=[listen address/port]:addr:' \
  '*'{-c,--peer}'=[peer address to connect to]:peer:' \
  '--peer-timeout=[peer inactivity timeout in seconds]:s:' \
  '--keepalive=[keep-alive message interval]:s:' \
  '--switch-timeout=[switch table entry timeout]:s:' \
  '--ip=[configure interface with IP/prefix]:ip:' \
  '--ifup=[setup command for interface]:cmd:' \
  '--ifdown=[teardown command for interface]:cmd:' \
  '(-p --password)'{-p,--password}'=[encryption password]:password:' \
  '--key=[private key for encryption]:key:' \
  '--private-key=[private key]:key:' \
  '--public-key=[matching public key]:key:' \
  '*--trust=[trusted peer public key]:key:' \
  '*--trusted-key=[trusted peer public key]:key:' \
  '--algo=[encryption algorithm]:algo:' \
  '--algorithm=[encryption algorithm]:algo:' \
  '--beacon-store=[beacon store path or command]:path:' \
  '--beacon-load=[beacon load path or command]:path:' \
  '--beacon-interval=[beacon interval in seconds]:s:' \
  '--beacon-password=[encrypt beacon data]:password:' \
  '--claim=[local subnet to claim in CIDR]:subnet:' \
  '--no-auto-claim[do not auto-claim interface IP]' \
  '--no-port-forwarding[disable automatic UPnP/NAT-PMP]' \
  '--daemon[run as background process]' \
  '--pid-file=[store process ID]:file:_files' \
  '--stats-file=[statistics output file]:file:_files' \
  '--statsd-server=[StatsD reporting endpoint]:server:' \
  '--statsd-prefix=[StatsD metric prefix]:prefix:' \
  '--user=[drop to specified user]:user:_users' \
  '--group=[drop to specified group]:group:_groups' \
  '--log-file=[log output file]:file:_files' \
  '*-v[debug output]' \
  '*--verbose[debug output]' \
  '(-q --quiet)'{-q,--quiet}'[errors/warnings only]' \
  '(- *)'{-h,--help}'[display help information]' \
  '*--hook=[event hook script]:cmd:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'vpncloud subcommand' subcommands && ret=0
    ;;
esac

return ret
