#compdef grib_get_data
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_get_data
# Source: ecmwf/eccodes tools/grib_get_data.cc — extract lat/lon/value triples from GRIB messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-M[turn off multi-field support]' \
    '-m+[missing value placeholder string]:value:_default' \
    '-p+[keys to print (key[:s/d/i],...)]:keys:_default' \
    '-F+[C-style format for data values (default %.10e)]:format:_default' \
    '-L+[C-style format for lat/lon (default %9.3f%9.3f)]:format:_default' \
    '-w+[where clause filter]:filter:_default' \
    '-s+[key=value pairs to set]:kvs:_default' \
    '-f[force, do not fail on error]' \
    '-G[GRIBEX compatibility mode]' \
    '-7[do not fail on wrong message length]' \
    '-X+[input file offset in bytes]:offset:_default' \
    '(- *)-V[show version]' \
    '*:grib file:_files' \
    && ret=0

return ret
