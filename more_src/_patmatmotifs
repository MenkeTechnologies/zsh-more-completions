#compdef patmatmotifs
# Documentation: https://man.archlinux.org/search?q=patmatmotifs
# Reference accessed: 2026-05-16

# EMBOSS patmatmotifs: scan protein with the full PROSITE motif database
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-full[show full motif/sequence information]' \
  '-prune[remove uninformative motifs from output]' \
  '-outfile=[report output file]:file:_files' \
  '-rformat=[report format]:format:(motif table excel feattable gff3 listfile pir simple swiss tagseq)' \
  '*:protein USA:_files' && ret=0
return ret
