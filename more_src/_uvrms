#compdef uvrms
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvrms.html
# Measure the RMS value of a visibility dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'stokes=[stokes keyword]:stokes:' \
  'select=[select keyword]:select:' \
  'line=[line keyword]:line:' \
  'options=[options keyword]:options:' \
  '*:visibility dataset:_files' && ret=0

return ret
