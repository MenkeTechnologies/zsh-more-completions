#compdef solana

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-u --url)'{-u,--url}'[RPC URL]:url' \
  '-k[keypair path]:file:_files' \
  '--keypair=[keypair path]:file:_files' \
  '--commitment=[commitment level]:level:(processed confirmed finalized)' \
  '--output=[output format]:format:(json json-compact)' \
  '-v[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'account:show account info'
      'address:show keypair address'
      'airdrop:request SOL airdrop'
      'balance:show balance'
      'block:get confirmed block'
      'block-height:get block height'
      'block-production:show block production'
      'block-time:get estimated time for a block'
      'catchup:wait for validator to catch up'
      'close-vote-account:close a vote account'
      'cluster-date:get cluster date'
      'cluster-version:get cluster version'
      'completion:generate shell completions'
      'config:manage CLI configuration'
      'confirm:confirm transaction'
      'create-address-with-seed:create derived address'
      'create-nonce-account:create nonce account'
      'create-stake-account:create stake account'
      'create-vote-account:create vote account'
      'deactivate-stake:deactivate stake'
      'decode-transaction:decode transaction'
      'delegate-stake:delegate stake'
      'deploy:deploy a program'
      'epoch:get current epoch'
      'epoch-info:get epoch info'
      'feature:manage runtime features'
      'fees:show current fees'
      'first-available-block:get first available block'
      'genesis-hash:get genesis hash'
      'gossip:show gossip network nodes'
      'inflation:show inflation info'
      'largest-accounts:get largest accounts'
      'leader-schedule:show leader schedule'
      'logs:stream transaction logs'
      'merge-stake:merge stake accounts'
      'new-nonce:advance nonce'
      'ping:submit transactions for latency'
      'program:manage on-chain programs'
      'rent:calculate rent-exempt minimum'
      'slot:get current slot'
      'split-stake:split a stake account'
      'stake-account:show stake account'
      'stake-authorize:authorize staker or withdrawer'
      'stake-history:show stake history'
      'stakes:show stake accounts'
      'supply:get total supply'
      'transaction-history:show transaction history'
      'transfer:transfer SOL'
      'validator-info:manage validator info'
      'validators:show cluster validators'
      'vote-account:show vote account'
      'vote-authorize-voter:authorize new voter'
      'vote-update-commission:update vote commission'
      'vote-update-validator:update validator identity'
      'wait-for-max-stake:wait for max stake'
      'withdraw-from-nonce-account:withdraw from nonce'
      'withdraw-from-vote-account:withdraw from vote'
      'withdraw-stake:withdraw stake'
    )
    _describe -t commands 'solana command' commands && ret=0
    ;;
  args)
    case $line[1] in
      transfer)
        _arguments \
          '1:recipient address' \
          '2:amount' \
          '--from=[sender keypair]:file:_files' \
          '--allow-unfunded-recipient[allow unfunded recipient]' && ret=0
        ;;
      airdrop)
        _arguments '1:amount' '2:address' && ret=0
        ;;
      balance)
        _arguments '1:address' && ret=0
        ;;
      deploy)
        _arguments \
          '1:program file:_files -g "*.so"' \
          '--program-id=[program keypair]:file:_files' && ret=0
        ;;
      config)
        _arguments '1:action:(get set)' && ret=0
        ;;
      program)
        _arguments '1:action:(deploy show dump close write-buffer set-buffer-authority set-upgrade-authority)' && ret=0
        ;;
      account)
        _arguments '1:address' && ret=0
        ;;
      logs)
        _arguments \
          '--filter=[filter logs]:filter' \
          '1:address' && ret=0
        ;;
    esac
    ;;
esac

return ret
