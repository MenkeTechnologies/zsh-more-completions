#compdef mkvextract

# Zsh completion for mkvextract - MKVToolNix track extraction tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'tracks:extract tracks from a Matroska file'
  'tags:extract tags from a Matroska file'
  'attachments:extract attachments from a Matroska file'
  'chapters:extract chapters from a Matroska file'
  'cuesheet:extract a CUE sheet from a Matroska file'
  'timestamps_v2:extract timestamps from a Matroska file'
  'cues:extract cue information from a Matroska file'
)

_arguments -s -S \
  '1:source file:_files -g "*.mkv *.mka *.mks *.mk3d *.webm"' \
  '2:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress status output]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--ui-language=[interface language]:language' \
  '--gui-mode[enable GUI mode]' \
  '--flush-on-close[flush buffers on close]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mkvextract command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (tracks)
        _arguments -s -S \
          '(-c --cuesheet)'{-c,--cuesheet}'[also output CUE sheets for tracks]' \
          '--blockadd=[level of BlockAdditional]:level' \
          '--raw[extract raw data]' \
          '--fullraw[extract full raw data with CodecPrivate]' \
          '*:track spec (TID\:outfile)' && ret=0
        ;;
      (tags)
        _arguments -s -S \
          '--all[extract all tags]' \
          '*:output file:_files -g "*.xml"' && ret=0
        ;;
      (attachments)
        _arguments -s -S \
          '*:attachment spec (AID\:outfile)' && ret=0
        ;;
      (chapters)
        _arguments -s -S \
          '(-s --simple)'{-s,--simple}'[export simple format chapters]' \
          '--simple-language=[extract only chapters in language]:language' \
          '*:output file:_files -g "*.xml *.txt"' && ret=0
        ;;
      (cuesheet)
        _arguments -s -S \
          '*:output file:_files -g "*.cue"' && ret=0
        ;;
      (timestamps_v2)
        _arguments -s -S \
          '*:track spec (TID\:outfile)' && ret=0
        ;;
      (cues)
        _arguments -s -S \
          '*:track spec (TID\:outfile)' && ret=0
        ;;
    esac
    ;;
esac

return ret
