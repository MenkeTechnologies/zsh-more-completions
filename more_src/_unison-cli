#compdef ucm

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '--codebase-create[create codebase if missing]' \
  '--codebase=[codebase path]:dir:_files -/' \
  '-C+[codebase path]:dir:_files -/' \
  '--no-base[no base library]' \
  '--port=[language server port]:port:' \
  '-p+[language server port]:port:' \
  '--token=[auth token]:t:' \
  '--host=[language server host]:h:_hosts' \
  '--no-tui[no TUI]' \
  '--proxy=[proxy URL]:url:' \
  '*--ucm-test-input[test input]' \
  '*: :_files' && ret=0

local -a commands
commands=(
  'init:create new codebase (deprecated)'
  'transcript:run transcript files'
  'transcript.fork:fork transcript'
  'run:run a unison project main'
  'run.compiled:run compiled .uc binary'
  'run.file:run file'
  'compile:compile to UCM binary'
  'help:show help'
  'version:show version'
)
_describe -t cmds 'ucm command' commands && ret=0

return ret
