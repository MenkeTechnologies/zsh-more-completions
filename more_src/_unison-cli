#compdef ucm
# Documentation: https://github.com/unisonweb/unison
# Reference accessed: 2026-05-21
# Verified: upstream Main.hs flag declarations.

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'run:execute code from various sources'
  'transcript:run transcript files'
  'mcp-server:start the Model Context Protocol server'
)

_arguments -C \
  '--version[show version]' \
  '--codebase=[open existing codebase at path]:dir:_files -/' \
  '--codebase-create=[create new codebase at path]:dir:_files -/' \
  '--headless[run codebase API server without interactive CLI]' \
  '--no-watch[disable file watching]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ucm command' commands && ret=0 ;;
  (args) _files && ret=0 ;;
esac

return ret
