#compdef oidnDenoise
# Documentation: https://github.com/RenderKit/oidn/blob/master/apps/oidnDenoise.cpp
# Intel Open Image Denoise: command-line denoising tool

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-d -dev -device)'{-d,-dev,-device}'+[device type or physical device index]:device' \
  '(-f -filter)'{-f,-filter}'+[filter type]:filter:(RT RTLightmap)' \
  '-hdr+[load HDR color image]:file:_files' \
  '-ldr+[load LDR color image]:file:_files' \
  '-srgb[input color image is encoded with the sRGB curve]' \
  '-dir+[load directional image]:file:_files' \
  '(-alb -albedo)'{-alb,-albedo}'+[load albedo auxiliary image]:file:_files' \
  '(-nrm -normal)'{-nrm,-normal}'+[load normal auxiliary image]:file:_files' \
  '(-o -out -output)'{-o,-out,-output}'+[output image filename]:file:_files' \
  '(-r -ref -reference)'{-r,-ref,-reference}'+[reference output image for verification]:file:_files' \
  '(-is -input_scale)'{-is,-input_scale}'+[scale factor for input]:scale' \
  '(-clean_aux -clean-aux)'{-clean_aux,-clean-aux}'[auxiliary images are noise-free]' \
  '(-t -type)'{-t,-type}'+[data type]:type:(float half)' \
  '(-q -quality)'{-q,-quality}'+[filter quality]:quality:(default high balanced fast)' \
  '(-w -weights)'{-w,-weights}'+[custom filter weights file]:file:_files' \
  '-n+[number of benchmark runs]:n' \
  '-threads+[number of threads to use]:n' \
  '-affinity+[set CPU affinity]:affinity' \
  '-maxmem+[maximum memory usage in MB]:mb' \
  '-inplace[process in-place]' \
  '-buffer+[buffer storage mode]:mode:(host device managed)' \
  '-maxerror+[maximum allowed error for verification]:error' \
  '(-v -verbose)'{-v,-verbose}'+[verbosity level]:level:(0 1 2 3)' \
  '(-ld -list_devices)'{-ld,-list_devices}'[list available devices]' && ret=0

return ret
