#compdef imheq
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imheq.html
# MIRIAD imheq - apply histogram equalization to an image

local ret=1

_arguments -s -S \
  'in=[input image file (required)]:in:_files' \
  'out=[output image file (required)]:out:_files' \
  'nbins=[number of bins for the image histogram (default 128)]:nbins' \
  'range=[intensity min and max values for histogram binning]:range' \
  'options=[global uses statistics across all planes]:options:(global)' \
  'device=[PGPLOT device for displaying histogram plots]:device' \
  '*:image:_files' && ret=0

return ret
