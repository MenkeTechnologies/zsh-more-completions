#compdef groq-code-cli
# Documentation: https://github.com/build-with-groq/groq-code-cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-t --temperature)'{-t+,--temperature=}'[generation temperature (default 1)]:temp:' \
  '(-s --system)'{-s+,--system=}'[custom system message]:message:' \
  '(-d --debug)'{-d,--debug}'[enable debug logging to debug-agent.log]' \
  '(-p --proxy)'{-p+,--proxy=}'[proxy URL (http/https/socks5)]:url:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*::args: _default' && ret=0

return ret
