#compdef groq-code-cli
# Documentation: https://man.archlinux.org/search?q=groq-code-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*::args: _default' && ret=0

return ret
