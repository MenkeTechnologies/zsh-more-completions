#compdef susynvxz
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/synthetics_waveforms_testpatterns/susynvxz.c
# Synthetic seismograms of common offset V(X,Z) media via Kirchhoff modeling

local ret=1

_arguments -s -S \
  'nx=[number of x samples (2nd dimension)]:nx' \
  'nz=[number of z samples (1st dimension)]:nz' \
  'nxb=[band centered at midpoint]:nxb' \
  'nxd=[skipped number of midpoints]:nxd' \
  'dx=[x sampling interval (m)]:dx' \
  'fx=[first x sample]:fx' \
  'dz=[z sampling interval (m)]:dz' \
  'nt=[number of time samples]:nt' \
  'dt=[time sampling interval (sec)]:dt' \
  'ft=[first time (sec)]:ft' \
  'nxo=[number of offsets]:nxo' \
  'dxo=[offset sampling interval (m)]:dxo' \
  'fxo=[first offset (m)]:fxo' \
  'nxm=[number of midpoints]:nxm' \
  'dxm=[midpoint sampling interval (m)]:dxm' \
  'fxm=[first midpoint (m)]:fxm' \
  'fpeak=[peak frequency of symmetric Ricker wavelet (Hz)]:fpeak' \
  'ref=[reflector(s): amplitude:x1,z1;x2,z2;...]:ref' \
  'smooth=[=1 for smooth (piecewise cubic spline) reflectors]:smooth:(0 1)' \
  'ls=[=1 for line source; default is point source]:ls:(0 1)' \
  'tmin=[minimum time of interest (sec)]:tmin' \
  'ndpfz=[number of diffractors per Fresnel zone]:ndpfz' \
  'verbose=[=1 to print some useful information]:verbose:(0 1)' \
  '*:vfile:_files' && ret=0

return ret
