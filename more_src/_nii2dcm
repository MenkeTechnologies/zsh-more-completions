#compdef nii2dcm
# Documentation: https://github.com/tomaroberts/nii2dcm
# nii2dcm: NIfTI to DICOM creation with Python

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-v --version)'{-v,--version}'[show version information and exit]' \
  '(-d --dicom_type --dicom-type)'{-d,--dicom_type,--dicom-type}'=[output DICOM modality (e.g. MR, SVR)]:type:(MR SVR)' \
  '(-r --ref_dicom --ref-dicom)'{-r,--ref_dicom,--ref-dicom}'=[reference DICOM file for attribute transfer]:dicom:_files -g "*.dcm"' \
  '1:input NIfTI file:_files -g "*.nii *.nii.gz"' \
  '2:output DICOM directory:_files -/' && ret=0

return ret
