#compdef pkgroll
# _pkgroll — Zero-config npm package bundler using esbuild and rollup
# upstream: https://github.com/privatenumber/pkgroll

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--src=[source directory]:directory:_directories' \
  '--dist=[output directory]:directory:_directories' \
  '--minify[minify output]' \
  '--target=[ECMAScript target]:target:(es2015 es2016 es2017 es2018 es2019 es2020 es2021 es2022 esnext node12 node14 node16 node18 node20)' \
  '--sourcemap[generate source maps]' \
  '--env.NODE_ENV=[set NODE_ENV]:env:(development production)' \
  '--export-condition=[custom export condition]:condition' \
  '(-w --watch)'{-w,--watch}'[watch mode for development]' \
  '--clean-dist[clean dist directory before build]' && ret=0

return ret
