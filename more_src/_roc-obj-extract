#compdef roc-obj-extract
# Documentation: https://manpages.ubuntu.com/manpages/questing/man1/roc-obj-extract.1.html
# roc-obj-extract - ROCm code object extraction tool

local ret=1

_arguments -s -S \
  '-h[show help message]' \
  '-v[verbose output to STDOUT]' \
  '-o[path for output ("-" prints code object to STDOUT)]:path:_files' \
  '*:uri:_files' && ret=0

return ret
