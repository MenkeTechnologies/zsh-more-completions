#compdef osqueryi

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--flagfile=[read flags from file]:file:_files' \
  '--config_path=[config file]:file:_files -g "*.{json,conf}"' \
  '--config_plugin=[config plugin]:plugin:(filesystem tls)' \
  '--json[output JSON]' \
  '--csv[output CSV]' \
  '--line[output line mode]' \
  '--list[output list mode]' \
  '--header=[show header]:enabled:(true false)' \
  '--separator=[column separator]:separator' \
  '--nullvalue=[null value string]:string' \
  '--verbose[verbose output]' \
  '--debug[debug mode]' \
  '--database_path=[database path]:directory:_directories' \
  '--extensions_socket=[extensions socket]:socket:_files' \
  '--pack=[load query pack]:pack name' \
  '--A[select a table]:table' \
  '-L[list all tables]' \
  '.schema[show schema]' \
  '*:query' && ret=0

return ret
