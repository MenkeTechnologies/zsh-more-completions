#compdef porchctl
# Documentation: https://docs.nephio.org/docs/porch/using-porch/porchctl-cli-guide/
# Porch Package Orchestration CLI for managing repositories and package revisions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for the request]:namespace' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '*:command:((
    repo\:"manage package repositories"
    rpkg\:"manage package revisions"
    completion\:"generate shell autocompletion script"
    version\:"print the version number of porchctl"
  ))' && ret=0

return ret
