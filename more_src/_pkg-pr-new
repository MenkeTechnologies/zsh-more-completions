#compdef pkg-pr-new stackblitz
# _pkg-pr-new — continuous releases via pkg.pr.new (stackblitz-labs/pkg.pr.new)
# upstream: https://github.com/stackblitz-labs/pkg.pr.new
# Flags from packages/cli/index.ts (citty).

_pkg-pr-new() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'publish:publish packages from current repo to pkg.pr.new'
                'link:get install command link for a published package'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                publish)
                    _arguments \
                        '--compact[use shortest URL form (default)]' \
                        '--peerDeps[handle peer deps via workspace versions]' \
                        '--pnpm[use pnpm pack]' \
                        '--yarn[use yarn pack]' \
                        '--bun[use bun pm pack]' \
                        '--template=[generate stackblitz templates from dirs]:list:' \
                        '--comment=[PR comment mode]:mode:(off create update)' \
                        '--commentWithSha[use commit SHA instead of PR number]' \
                        '--commentWithDev[use dev URL in comments]' \
                        '--json[output as JSON]' \
                        '--packageManager=[manifest package manager]:pm:(npm pnpm yarn bun)' \
                        '--bin=[publish only the binary for these packages]:list:' \
                        '*:package dir:_files -/'
                    ;;
            esac
            ;;
    esac
}

_pkg-pr-new "$@"
