#compdef mythbackend
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythbackend/mythbackend_commandlineparser.cpp
# Reference accessed: 2026-05-16
# Verified: upstream mythbackend_commandlineparser.cpp.

# mythbackend: MythTV recording/streaming backend
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --daemon)'{-d,--daemon}'[fork into background]' \
  '(-O --override-setting)'{-O,--override-setting=}'[override setting KEY=VAL]:KEY=VAL:' \
  '--override-settings-file=[settings override file]:file:_files' \
  '--noupnp[disable UPnP]' \
  '--dvbv3[use legacy DVBv3 API]' \
  '(-p --pidfile)'{-p,--pidfile=}'[write PID to file]:file:_files' \
  '--user=[drop permissions to user]:user:_users' \
  '--printsched[print upcoming scheduled recordings]' \
  '--testsched[run scheduler test]' \
  '--printexpire=[print recordings to expire]:set:(ALL)' \
  '--setverbose=[change running backend debug mask]:mask:' \
  '--setloglevel=[change running backend log level]:level:' \
  '--webonly[start in web-server-only mode]' \
  '--nosched[disable scheduler (debug)]' \
  '--nojobqueue[disable job queue (debug)]' \
  '--nohousekeeper[disable housekeeper (debug)]' \
  '--noautoexpire[disable auto-expire (debug)]' \
  '--upgradedbonly[upgrade DB and exit (debug build)]' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[reduce logging]' \
  '--loglong[long log format]' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' && ret=0
return ret
