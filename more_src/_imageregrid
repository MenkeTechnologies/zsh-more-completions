#compdef imageregrid
# Documentation: https://casacore.github.io/casacore/
# casacore: regrid a casacore image to a new coordinate system

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage]' \
  'in=[input image name]:image:_files' \
  'out=[output image name]:image:_files' \
  'decimate=[decimation factor]:factor' \
  'dirref=[MDirection type]:type' \
  'projection=[projection]:proj' \
  'shape=[output image shape]:shape' \
  'refval=[new center of the image in degrees (reference value)]:refval' \
  'interpolation=[interpolation method]:method:(linear nearest cubic lanczos)' \
  'debug=[debug level]:level' \
  '*:argument: ' && ret=0

return ret
