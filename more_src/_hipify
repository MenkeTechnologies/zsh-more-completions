#compdef hipify hipify-clang hipify-perl
# _hipify — ROCm HIPIFY automatic CUDA C/C++ source to HIP portable code translator clang-based and perl-based (ROCm team, C++/Perl); custom argparse
# upstream: https://github.com/ROCm/HIPIFY

_hipify() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i+[input file]:file:_files -g "*.cu *.cuh *.h *.hpp *.cpp *.c"' \
        '--input=+[input file]:file:_files -g "*.cu *.cuh *.h *.hpp *.cpp *.c"' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--inplace[modify file in place]' \
        '-inplace[modify file in place]' \
        '-no-output[no output]' \
        '-print-stats[print stats]' \
        '-print-stats-csv[print stats as CSV]' \
        '-roc[ROC mode]' \
        '-roc-only[ROC only mode]' \
        '-experimental[experimental mode]' \
        '-cuda-path=+[CUDA path]:dir:_files -/' \
        '-hip-path=+[HIP path]:dir:_files -/' \
        '-includes=+[include dirs csv]:str:' \
        '-default-preprocessor[default preprocessor]' \
        '-amap[apply mapping file]' \
        '-debug[debug output]' \
        '-D+[macro]:str:' \
        '-I+[include dir]:dir:_files -/' \
        '-no-warnings[suppress warnings]' \
        '-quiet-warnings[quiet warnings]' \
        '-skip-excluded-preprocessor-conditional-blocks[skip excluded]' \
        '-warn-on-unsupported[warn on unsupported]' \
        '-print-output[print output]' \
        '-bench-mode[benchmark mode]' \
        '-set+[options]:str:' \
        '*:source file:_files -g "*.cu *.cuh *.h *.hpp *.cpp *.c"'
}

_hipify "$@"
