#compdef abidw
# Documentation: https://sourceware.org/libabigail/manual/abidw.html
# libabigail tool to serialize the ABI of an ELF binary to XML

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --out-file)'{-o,--out-file}'[write XML output to file]:file:_files' \
  '--noout[build internal representation without emitting XML]' \
  '(-d --debug-info-dir)'{-d,--debug-info-dir}'[debug info directory]:dir:_files -/' \
  '--check-alternate-debug-info[check alternate debug info availability]' \
  '--btf[extract ABI from BTF debug info]' \
  '--ctf[extract ABI from CTF debug info]' \
  '--headers-dir[filter types to those in public headers]:dir:_files -/' \
  '--header-file[public header file]:file:_files' \
  '--drop-private-types[exclude types not in headers]' \
  '*--suppressions[suppression specification file]:file:_files' \
  '--load-all-types[include all types not just reachable ones]' \
  '--no-corpus-path[omit path attribute from ABI corpus]' \
  '--no-elf-needed[exclude DT_NEEDED dependencies]' \
  '--annotate[add human-readable comments to XML]' \
  '--no-show-locs[omit file/line/column information]' \
  '--no-parameter-names[exclude function parameter names]' \
  '--abidiff[compare reloaded ABI against original]' \
  '--debug-abidiff[run abidiff with detailed error reporting]' \
  '--stats[output internal statistics]' \
  '--verbose[enable verbose logging]' \
  '*:file:_files' && ret=0

return ret
