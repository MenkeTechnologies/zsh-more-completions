_curlconverter() {
    local -a langs
    langs=(
        ansible c cfml clojure csharp dart elixir go har http httpie
        java java-httpurlconnection java-jsoup java-okhttp
        javascript javascript-jquery javascript-xhr
        json julia kotlin lua matlab
        node node-axios node-fetch node-got node-http node-ky
        node-jquery node-request node-superagent node-xhr
        nodejs nodejs-axios nodejs-fetch nodejs-got nodejs-http
        nodejs-ky nodejs-jquery nodejs-request nodejs-superagent nodejs-xhr
        objc objectivec objective-c ocaml perl
        php php-curl php-guzzle php-requests
        powershell powershell-restmethod powershell-webrequest
        python python-http python-httpclient
        r r-httr r-httr2 ruby ruby-httparty rust swift wget
    )

    _arguments -s \
        '(-h --help)'{-h,--help}'[show help and exit]' \
        '(-V --version)'{-V,--version}'[print version and exit]' \
        '(-v --verbose)'{-v,--verbose}'[print warnings and error tracebacks]' \
        '(-l --language)'{-l+,--language=}'[target language / HTTP library (default python)]:language:->lang' \
        '*:curl options or - for stdin:'

    case $state in
        lang)
            _describe -t languages 'curlconverter target language' langs
            ;;
    esac
}

_curlconverter "$@"
