#compdef azcopy
# _azcopy-cli — AzCopy Azure Storage data movement CLI (Microsoft Azure, Go); bulk copy to/from Azure Blob/File/Table
# upstream: https://github.com/Azure/azure-storage-azcopy

_azcopy-cli() {
    local -a sub=(
        'bench:run benchmark'
        'completion:print shell completion'
        'copy:copy data'
        'cp:alias for copy'
        'doc:generate docs'
        'env:print env'
        'help:show help'
        'jobs:job commands'
        'list:list path contents'
        'ls:list path contents'
        'login:login to Azure'
        'logout:logout from Azure'
        'make:create container/share'
        'mkdir:alias for make'
        'remove:remove data'
        'rm:alias for remove'
        'set-properties:set properties'
        'sync:sync source -> destination'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--cap-mbps+[mbps cap]:f:' \
        '--log-level+[log level]:level:(NONE FATAL ERROR WARNING INFO DEBUG)' \
        '--output-type+[output type]:type:(text json)' \
        '--output-level+[output level]:level:(default quiet essential)' \
        '--trusted-microsoft-suffixes+[trusted suffixes]:suffixes:' \
        '--skip-version-check[skip version check]' \
        '--application-id+[application id]:str:' \
        '--certificate-path+[cert path]:file:_files' \
        '--identity-client-id+[managed identity client id]:str:' \
        '--identity-object-id+[managed identity object id]:str:' \
        '--identity-resource-id+[managed identity resource id]:str:' \
        '--service-principal+[service principal]:str:' \
        '--tenant-id+[tenant id]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'azcopy subcommand' sub ;;
        args)
            case $words[1] in
                copy|cp|sync) _arguments \
                    '*::src dst:_files' \
                    '--recursive[recursive]' \
                    '-r[recursive]' \
                    '--include-pattern+[include pattern]:pattern:' \
                    '--exclude-pattern+[exclude pattern]:pattern:' \
                    '--include-path+[include path]:path:' \
                    '--exclude-path+[exclude path]:path:' \
                    '--include-after+[include after time]:str:' \
                    '--exclude-blob-type+[exclude blob type]:type:' \
                    '--block-size-mb+[block size MB]:n:' \
                    '--blob-type+[blob type]:type:(BlockBlob PageBlob AppendBlob None)' \
                    '--from-to+[direction]:dir:(LocalBlob BlobLocal BlobBlob)' \
                    '--preserve-info+[preserve info]:bool:(true false)' \
                    '--preserve-smb-permissions+[preserve SMB permissions]:bool:(true false)' \
                    '--preserve-smb-info+[preserve SMB info]:bool:(true false)' \
                    '--preserve-permissions+[preserve permissions]:bool:(true false)' \
                    '--preserve-owner+[preserve owner]:bool:(true false)' \
                    '--decompress[decompress]' \
                    '--md5-validation+[md5 validation]:mode:(NoCheck LogOnly FailIfDifferent FailIfDifferentOrMissing)' \
                    '--put-md5[upload md5]' \
                    '--check-md5+[check md5]:mode:(NoCheck LogOnly FailIfDifferent FailIfDifferentOrMissing)' \
                    '--check-length+[check length]:bool:(true false)' \
                    '--cache-control+[cache control]:str:' \
                    '--content-disposition+[content disposition]:str:' \
                    '--content-encoding+[content encoding]:str:' \
                    '--content-language+[content language]:str:' \
                    '--content-type+[content type]:str:' \
                    '--metadata+[metadata]:k=v:' \
                    '--overwrite+[overwrite]:mode:(true false prompt ifSourceNewer)' \
                    '--force-if-read-only[force if read only]' \
                    '--page-blob-tier+[page blob tier]:tier:' \
                    '--block-blob-tier+[block blob tier]:tier:' \
                    '--delete-destination+[delete dest]:bool:(true false prompt)' \
                    '--mirror-mode[mirror mode]' \
                    '--dry-run[dry run]' \
                    '--cap-mbps+[mbps cap]:f:' ;;
                remove|rm) _arguments '*:url:' \
                    '--recursive[recursive]' \
                    '--include-pattern+[include pattern]:pattern:' \
                    '--exclude-pattern+[exclude pattern]:pattern:' ;;
                list|ls) _arguments '*:url:' \
                    '--properties[show properties]' \
                    '--running-tally[running tally]' \
                    '--machine-readable[machine readable]' ;;
                jobs) _arguments '1:jobs cmd:(list resume show clean remove)' '*:job id:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_azcopy-cli "$@"
