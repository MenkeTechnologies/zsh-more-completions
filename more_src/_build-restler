#compdef build-restler.py build-restler
# _build-restler — build the RESTler fuzzer drop (microsoft/restler-fuzzer)
# upstream: https://github.com/microsoft/restler-fuzzer
# Flags from build-restler.py (argparse).

_build-restler.py() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--repository_root_dir=[root of rest.fuzzing repository]:dir:_files -/' \
        '--dest_dir=[destination drop directory]:dir:_files -/' \
        '--configuration=[build configuration]:cfg:(release debug)' \
        '--python_path=[python command for compilation]:cmd:_command_names -e' \
        '--compile_type=[components to build]:type:(all engine compiler resultsAnalyzer)' \
        '--dotnet_package_source=[override dotnet package source]:source:'
}

_build-restler.py "$@"
