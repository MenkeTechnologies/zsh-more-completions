#compdef 3dDFT
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dDFT.html
# AFNI: discrete Fourier transform along the time axis

local ret=1

_arguments -s -S \
  '-prefix[output file prefix]:prefix:' \
  '-abs[output absolute value of the DFT]' \
  '-nfft[DFT length (>= number of time points)]:N:' \
  '-detrend[remove linear drift before DFT]' \
  '-taper[Hamming taper fraction (0..1)]:f:' \
  '-inverse[perform inverse DFT]' \
  '*:dataset:_files' && ret=0

return ret
