#compdef firewall-config firewall-applet
# _firewall-config — firewalld GUI front-end CLI alias (Red Hat firewalld team, Python); argparse
# upstream: https://github.com/firewalld/firewalld

_firewall-config() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '*:arg:'
}

_firewall-config "$@"
