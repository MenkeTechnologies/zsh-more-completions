#compdef bookworm com.github.babluboy.bookworm
# Documentation: https://github.com/babluboy/bookworm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable debug output]' \
  '*:ebook:_files -g "*.{epub,mobi,pdf,fb2,cbr,cbz}"' && ret=0

return ret
