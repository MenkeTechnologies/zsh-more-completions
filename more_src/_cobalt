#compdef cobalt

# Zsh completion for cobalt - Static site generator

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_cobalt_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '(-c --config)'{-c,--config}'[config file path]:file:_files'
  '(-s --source)'{-s,--source}'[source directory]:directory:_directories'
  '(-d --destination)'{-d,--destination}'[destination directory]:directory:_directories'
  '(-D --drafts)'{-D,--drafts}'[include drafts]'
  '--log-level=[log level]:level:(Off Error Warn Info Debug Trace)'
  '--dump=[dump internal data]:type:(config default url)'
  '--quiet[suppress output]'
  '--trace[enable trace output]'
)

_arguments -s -S -C \
  "${_cobalt_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'init:Create a new site'
      'new:Create a new post or page'
      'build:Build the site'
      'serve:Build and serve the site locally'
      'watch:Watch for changes and rebuild'
      'import:Import from another site generator'
      'clean:Clean the destination directory'
      'completions:Generate shell completions'
    )
    _describe -t commands 'cobalt commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      init)
        _arguments -s -S \
          "${_cobalt_global_flags[@]}" \
          '1:directory:_directories' && ret=0
        ;;
      new)
        _arguments -s -S \
          "${_cobalt_global_flags[@]}" \
          '--title=[post title]:title:' \
          '1:filename:' && ret=0
        ;;
      build)
        _arguments -s -S \
          "${_cobalt_global_flags[@]}" && ret=0
        ;;
      serve)
        _arguments -s -S \
          "${_cobalt_global_flags[@]}" \
          '--port=[port to listen on]:port:' \
          '--host=[host to bind to]:host:' \
          '--open[open in browser]' && ret=0
        ;;
      watch)
        _arguments -s -S \
          "${_cobalt_global_flags[@]}" && ret=0
        ;;
      import)
        _arguments -s -S \
          "${_cobalt_global_flags[@]}" \
          '--import-format=[format to import from]:format:(wordpress)' \
          '1:import file:_files' && ret=0
        ;;
      clean)
        _arguments -s -S \
          "${_cobalt_global_flags[@]}" && ret=0
        ;;
      completions)
        _arguments -s -S \
          "${_cobalt_global_flags[@]}" \
          '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
