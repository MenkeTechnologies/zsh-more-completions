#compdef i3-dump-log
# Documentation: https://man.archlinux.org/search?q=i3-dump-log
# Reference accessed: 2026-05-16

# i3-dump-log: dump i3 shared-memory log to stdout
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '-f[follow new messages]' \
  '--follow[follow new messages]' \
  '*::i3-dump-log args:_files' && ret=0
return ret
