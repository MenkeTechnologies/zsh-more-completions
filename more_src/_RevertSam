#compdef RevertSam
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/RevertSam.java
# Picard: revert SAM/BAM/CRAM records to their pre-alignment state

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM to revert]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output file or directory]:file:_files' \
  '(-OM --OUTPUT_MAP)'{-OM,--OUTPUT_MAP}'=[read-group to output path map]:file:_files' \
  '(-OBR --OUTPUT_BY_READGROUP)'{-OBR,--OUTPUT_BY_READGROUP}'=[output each read group separately]:b:(true false)' \
  '(-RHC --RESTORE_HARDCLIPS)'{-RHC,--RESTORE_HARDCLIPS}'=[restore hard-clipped reads from XB/XQ tags]:b:(true false)' \
  '(-OBRFF --OUTPUT_BY_READGROUP_FILE_FORMAT)'{-OBRFF,--OUTPUT_BY_READGROUP_FILE_FORMAT}'=[per-read-group output file format]:fmt:(SAM BAM CRAM dynamic)' \
  '(-SO --SORT_ORDER)'{-SO,--SORT_ORDER}'=[output sort order]:order:(queryname coordinate unsorted)' \
  '(-UO --RESTORE_ORIGINAL_QUALITIES)'{-UO,--RESTORE_ORIGINAL_QUALITIES}'=[restore original qualities from OQ field]:b:(true false)' \
  '--REMOVE_DUPLICATE_INFORMATION=[remove duplicate read flags]:b:(true false)' \
  '--REMOVE_ALIGNMENT_INFORMATION=[remove all alignment information]:b:(true false)' \
  '*--ATTRIBUTE_TO_CLEAR=[SAM tag to remove when clearing alignment]:tag:' \
  '*'{-RV,--ATTRIBUTE_TO_REVERSE}'=[attribute to reverse on negative strand]:tag:' \
  '*'{-RC,--ATTRIBUTE_TO_REVERSE_COMPLEMENT}'=[attribute to reverse complement]:tag:' \
  '--SANITIZE=[discard problematic reads for consistent output]:b:(true false)' \
  '--MAX_DISCARD_FRACTION=[max fraction of reads discarded in sanitize]:f:' \
  '--KEEP_FIRST_DUPLICATE=[keep first of duplicate read names in sanitize]:b:(true false)' \
  '(-SM --SAMPLE_ALIAS)'{-SM,--SAMPLE_ALIAS}'=[override sample alias in all read groups]:sm:' \
  '(-LB --LIBRARY_NAME)'{-LB,--LIBRARY_NAME}'=[override library name in all read groups]:lb:' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
