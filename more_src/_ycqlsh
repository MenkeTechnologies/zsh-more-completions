#compdef ycqlsh ysqlsh
# Documentation: https://man.archlinux.org/search?q=ycqlsh
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (ycqlsh)
    _arguments -C \
      '(- *)--help[show help]' \
      '(-h)-h+[host]:host:_hosts' \
      '(-p)-p+[port]:port:' \
      '(-u)-u+[user]:user:_users' \
      '(-w)-w+[password]:pass:' \
      '(-k)-k+[keyspace]:keyspace:' \
      '(-f)-f+[execute file]:file:_files -g "*.cql"' \
      '(-e)-e+[execute commands]:cmd:' \
      '(--debug)--debug[debug]' \
      '(--ssl)--ssl[use SSL]' \
      '(--no-color)--no-color[disable color]' \
      '(--encoding)--encoding=[encoding]:enc:(utf-8 ascii)' \
      '(--cqlversion)--cqlversion=[CQL version]:v:' \
      '(--protocol-version)--protocol-version=[protocol version]:v:' \
      '(--browser)--browser=[help browser]:b:' \
      '(--cqlshrc)--cqlshrc=[cqlshrc file]:file:_files' \
      '(--coverage)--coverage[coverage]' \
      '(--connect-timeout)--connect-timeout=[connect timeout]:s:' \
      '(--request-timeout)--request-timeout=[request timeout]:s:' \
      '(-t --tty)'{-t,--tty}'[force TTY]' \
      '*: :' && ret=0 ;;
  (ysqlsh)
    _arguments -C \
      '(- *)'{-?,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-h --host)'{-h+,--host=}'[host]:host:_hosts' \
      '(-p --port)'{-p+,--port=}'[port]:port:' \
      '(-U --username)'{-U+,--username=}'[username]:user:_users' \
      '(-d --dbname)'{-d+,--dbname=}'[database]:db:' \
      '(-W --password)'{-W,--password}'[force password prompt]' \
      '(-w --no-password)'{-w,--no-password}'[no password]' \
      '(-c --command)'{-c+,--command=}'[execute command]:cmd:' \
      '(-f --file)'{-f+,--file=}'[execute file]:file:_files -g "*.sql"' \
      '(-l --list)'{-l,--list}'[list databases]' \
      '*'{-v+,--set=}'[set variable]:var:' \
      '(-X --no-psqlrc)'{-X,--no-psqlrc}'[no psqlrc]' \
      '(-1 --single-transaction)'{-1,--single-transaction}'[single transaction]' \
      '(-a --echo-all)'{-a,--echo-all}'[echo all]' \
      '(-e --echo-queries)'{-e,--echo-queries}'[echo queries]' \
      '(-E --echo-hidden)'{-E,--echo-hidden}'[echo hidden]' \
      '(-A --no-align)'{-A,--no-align}'[unaligned output]' \
      '(-H --html)'{-H,--html}'[HTML output]' \
      '(-t --tuples-only)'{-t,--tuples-only}'[tuples only]' \
      '(-T --table-attr)'{-T+,--table-attr=}'[table attrs]:attr:' \
      '(-x --expanded)'{-x,--expanded}'[expanded output]' \
      '(-z --field-separator-zero)'{-z,--field-separator-zero}'[null field sep]' \
      '*: :' && ret=0 ;;
esac

return ret
