#compdef gdalmanage
# Documentation: https://gdal.org/programs/gdalmanage.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a verbs

verbs=(
  'identify:list data format of file(s)'
  'copy:create a copy of the dataset file with a new name'
  'rename:change the name of the dataset file'
  'delete:delete dataset file(s)'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '-r[recursively scan for dataset files]' \
  '-fr[force recursion into folders recognized as formats]' \
  '-u[report failures if file type is unidentified]' \
  '-f+[file format]:format:' \
  '1: :->verb' \
  '*:file:_files' && ret=0

case $state in
  (verb)
    _describe -t verbs 'gdalmanage verb' verbs && ret=0
    ;;
esac

return ret
