#compdef gdalmanage

local curcontext="$curcontext" state line ret=1
local -a verbs

verbs=(
  'identify:identify file format and report attributes'
  'copy:copy a raster file (with renaming)'
  'rename:rename a raster file (and any associated files)'
  'delete:delete a raster file (and any associated files)'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-r[recursive (only with identify)]' \
  '-fr[recursive (only with identify, do not consider hidden files)]' \
  '-u+[report files of unrecognized format]' \
  '-f+[file format]:format:' \
  '1: :->verb' \
  '*:file:_files' && ret=0

case $state in
  (verb)
    _describe -t verbs 'gdalmanage verb' verbs && ret=0
    ;;
esac

return ret
