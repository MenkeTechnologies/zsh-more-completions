#compdef topsysproc
# Documentation: https://keith.github.io/xcode-man-pages/topsysproc.1m.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '-C[do not clear the screen]' \
  '-s[print per second values]' \
  '1::interval (seconds, default 1):' \
  '2::count:' && ret=0

return ret
