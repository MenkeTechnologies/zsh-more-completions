#compdef backup-driver
# _backup-driver — Velero vSphere plugin backup-driver controller (cobra; subcommands install/server)
# upstream: https://github.com/vmware-tanzu/velero-plugin-for-vsphere
# Subcommands from pkg/cmd/backupdriver/backupdriver.go on tip; server flags from pkg/cmd/backupdriver/cli/server/server.go.

_backup-driver() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                install:'install the backup-driver into a cluster'
                server:'run the backup-driver controller'
            )
            _describe -t commands 'backup-driver subcommand' subs
            ;;
        args)
            case $line[1] in
                server)
                    _arguments \
                        '--client-burst=[max k8s API requests in a short period]:n:' \
                        '--profiler-address=[pprof profiler address]:addr:' \
                        '--master=[Kubernetes API URL (out-of-cluster only)]:url:_urls' \
                        '--kubeconfig=[absolute path to kubeconfig (out-of-cluster only)]:file:_files' \
                        '--backup-workers=[concurrency for processing backup requests]:n:'
                    ;;
            esac
            ;;
    esac
}

_backup-driver "$@"
