#compdef braket amazon-braket
# _braket — Amazon Web Services Braket quantum computing SDK CLI for AWS Braket service IonQ Rigetti Oxford QC OQC (aws team, Python); argparse
# upstream: https://github.com/amazon-braket/amazon-braket-sdk-python

_braket() {
    local -a sub=(
        'devices:list available quantum devices'
        'circuits:run a quantum circuit'
        'tasks:task subcommands'
        'jobs:hybrid job subcommands'
        'simulators:list available simulators'
        'run:run a circuit'
        'cost:show cost estimate'
        'configure:configure credentials'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--profile=+[AWS profile]:str:' \
        '--region=+[AWS region]:r:(us-east-1 us-west-1 us-west-2 eu-west-2 eu-west-3 eu-north-1 ap-northeast-1)' \
        '--device-arn=+[device ARN]:str:' \
        '-d+[device ARN]:str:' \
        '--shots=+[shots]:n:' \
        '-s+[shots]:n:' \
        '--s3-bucket=+[bucket]:str:' \
        '--s3-folder=+[folder]:str:' \
        '--poll-timeout=+[seconds]:n:' \
        '--poll-interval=+[seconds]:n:' \
        '--tags=+[key=value csv]:str:' \
        '--no-progress[no progress bar]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'braket subcommand' sub ;;
        args)
            case $words[1] in
                devices) _arguments \
                    '--type=+[type]:t:(QPU SIMULATOR)' \
                    '--provider=+[provider]:p:(amazon ionq rigetti quera oqc quantinuum)' \
                    '--status=+[status]:s:(ONLINE OFFLINE RETIRED)' ;;
                tasks) _arguments '1:tasks cmd:(get list cancel result)' ;;
                jobs) _arguments '1:jobs cmd:(create get list cancel metrics logs)' ;;
                run) _arguments \
                    '--circuit=+[circuit file]:file:_files -g "*.json *.qasm *.py *.proto"' \
                    '--input-data=+[file]:file:_files' \
                    '--algorithm-params=+[JSON]:str:' \
                    '--device-parameters=+[JSON]:str:' \
                    '--max-runtime=+[seconds]:n:' \
                    '--max-attempts=+[N]:n:' ;;
                configure) _arguments \
                    '--access-key-id=+[key]:str:' \
                    '--secret-access-key=+[secret]:str:' \
                    '--session-token=+[token]:str:' \
                    '--default-bucket=+[bucket]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_braket "$@"
