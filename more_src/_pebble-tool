#compdef pebble pebble-tool
# Documentation: https://man.archlinux.org/search?q=pebble
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'analyze-size:analyze size of compiled binary'
  'build:build the project'
  'clean:clean the project'
  'convert-project:convert an SDK project'
  'data-logging:work with data logging'
  'emu-accel:emulator: send accel data'
  'emu-app-config:emulator: open app config'
  'emu-battery:emulator: set battery state'
  'emu-bt-connection:emulator: bluetooth state'
  'emu-compass:emulator: set compass orientation'
  'emu-control:emulator: control session'
  'emu-launch:emulator: launch'
  'emu-set-time:emulator: set time'
  'emu-tap:emulator: simulate a tap'
  'emu-time-format:emulator: set time format'
  'gdb:debug with GDB'
  'install:install the app to a watch'
  'kill:kill running emulator'
  'list:list pebble watches'
  'login:log in to developer portal'
  'logs:tail logs'
  'new-project:create a new project'
  'package:package commands'
  'ping:ping the watch'
  'rebbleStore:Rebble store commands'
  'repl:start a REPL session'
  'screenshot:take a screenshot'
  'sdk:SDK management'
  'transcribe:transcribe voice'
  'wipe:wipe persistent state'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[debug output]' \
  '--debug-phone[debug phone communication]' \
  '--debug-libpebble[debug libpebble]' \
  '--no-color[disable color]' \
  '--no-auto-token[do not auto-load token]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pebble command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sdk)
        _values 'subcmd' install activate uninstall list && ret=0 ;;
      (install)
        _arguments \
          '--logs[stream logs after install]' \
          '--phone=[phone host:port]:host:' \
          '--emulator=[emulator platform]:platform:(aplite basalt chalk diorite)' && ret=0 ;;
      (build)
        _arguments \
          '--rebuild[full rebuild]' && ret=0 ;;
    esac ;;
esac

return ret
