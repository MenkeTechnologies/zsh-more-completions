#compdef fzn-cbc
# Documentation: https://docs.minizinc.dev/en/stable/fzn-spec.html
# COIN-OR CBC FlatZinc solver

local ret=1

_arguments -s \
  '-a[report all solutions / intermediate solutions]' \
  '-n[stop after reporting i solutions]:count' \
  '-i[print intermediate solutions of increasing quality]' \
  '-f[conduct a free search, ignoring search annotations]' \
  '-s[print statistics during/after search]' \
  '-v[print verbose log messages to standard error]' \
  '-p[run with i parallel threads]:threads' \
  '-r[use i as the random seed]:seed' \
  '-t[wall time limit in milliseconds]:ms' \
  '*:file:_files -g "*.fzn"' && ret=0

return ret
