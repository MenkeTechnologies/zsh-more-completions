#compdef bltool
# Documentation: https://github.com/ToxicFrog/bltool
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ToxicFrog/bltool: CLI for managing a Backloggery game collection.
_arguments -s -S \
  '--help[show help]' \
  '--from=[input format]:format:(backloggery steam xbox360 xboxlive text json edn html)' \
  '--to=[output format]:format:(backloggery steam xbox360 xboxlive text json edn html)' \
  '--input=[input file path]:file:_files' \
  '--output=[output file path]:file:_files' \
  '--steam-name=[Steam Community profile name]:name:' \
  '--steam-platform=[default platform for Steam imports]:platform:' \
  '--xbox-name=[Xbox Live GamerTag]:tag:' \
  '--xbox-360-platform=[default platform for Xbox 360 games]:platform:' \
  '--xbox-one-platform=[default platform for Xbox One games]:platform:' \
  '--bl-name=[Backloggery username]:user:' \
  '--bl-pass=[Backloggery password]:pass:' \
  '--bl-region=[region for new games]:region:' \
  '--bl-stealth[use stealth mode for updates]' \
  '--no-bl-stealth[disable stealth mode]' \
  '--filter-from=[source for filtering games]:source:' \
  '--filter-input=[filter file path]:file:_files' \
  '--name=[include only games matching substring]:name:' \
  '*:file:_files'
