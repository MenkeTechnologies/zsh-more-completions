#compdef bwrap

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '*--ro-bind[bind mount source to destination read-only]:source:_files:destination:_files' \
  '*--bind[bind mount source to destination]:source:_files:destination:_files' \
  '*--dev-bind[bind mount device node]:source:_files:destination:_files' \
  '*--tmpfs[mount tmpfs at destination]:destination:_files' \
  '*--proc[mount procfs at destination]:destination:_files' \
  '*--dev[mount devtmpfs at destination]:destination:_files' \
  '*--dir[create directory at destination]:destination:_files' \
  '*--file[copy from file descriptor to destination]:fd:destination:_files' \
  '*--bind-data[copy from fd and bind mount]:fd:destination:_files' \
  '*--ro-bind-data[copy from fd and bind mount read-only]:fd:destination:_files' \
  '*--symlink[create symlink]:source:destination:_files' \
  '*--remount-ro[remount path read-only]:destination:_files' \
  '*--lock-file[take a lock on file]:file:_files' \
  '*--sync-fd[keep this fd open while sandbox is running]:fd' \
  '--chdir[change directory in sandbox]:directory:_files' \
  '*--setenv[set environment variable]:variable:value' \
  '*--unsetenv[unset environment variable]:variable' \
  '--clearenv[unset all environment variables]' \
  '--uid[set custom user id]:uid' \
  '--gid[set custom group id]:gid' \
  '--hostname[set custom hostname]:hostname' \
  '--unshare-user[create new user namespace]' \
  '--unshare-user-try[create new user namespace if possible]' \
  '--unshare-ipc[create new IPC namespace]' \
  '--unshare-pid[create new PID namespace]' \
  '--unshare-net[create new network namespace]' \
  '--unshare-uts[create new UTS namespace]' \
  '--unshare-cgroup[create new cgroup namespace]' \
  '--unshare-cgroup-try[create new cgroup namespace if possible]' \
  '--unshare-all[unshare all possible namespaces]' \
  '--share-net[retain the network namespace]' \
  '--userns[use existing user namespace]:fd' \
  '--userns2[use existing user namespace after setup]:fd' \
  '--pidns[use existing PID namespace]:fd' \
  '--exec-label[set SELinux exec label]:label' \
  '--file-label[set SELinux file label]:label' \
  '*--cap-add[add capability]:capability' \
  '*--cap-drop[drop capability]:capability' \
  '--new-session[create a new terminal session]' \
  '--die-with-parent[kill sandbox when parent dies]' \
  '--as-pid-1[do not install a PID 1 process reaper]' \
  '--seccomp[load and use seccomp rules from fd]:fd' \
  '--block-fd[block on fd before starting command]:fd' \
  '--userns-block-fd[block on fd before setting up user namespace]:fd' \
  '--info-fd[write namespace info to fd]:fd' \
  '--json-status-fd[write status to fd in JSON format]:fd' \
  '--args[read arguments from fd]:fd' \
  '*::command:_normal' \
  && ret=0

return ret
