#compdef vmap
# _vmap — Mentor Siemens EDA ModelSim/Questa vmap CLI mapping a logical Verilog/VHDL library name to a physical library directory writing to modelsim.ini editing LIBRARY MAPPING section unmapping listing existing mappings (Siemens team, C++); custom argparse
# upstream: https://eda.sw.siemens.com/en-US/ic/questa/simulation/advanced-simulator/

_vmap() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-modelsimini=+[ini file]:file:_files -g "*.ini"' \
        '-c[copy library]' \
        '-del[delete mapping]' \
        '-quiet[quiet]' \
        '-verbose[verbose]' \
        '-skipsoftvmap[skip soft vmap]' \
        '-stats=+[s]:s:(none all)' \
        '-link[link library]' \
        '*:library:'
}

_vmap "$@"
