#compdef coderet
# Documentation: https://man.archlinux.org/search?q=coderet
# Reference accessed: 2026-05-16

# EMBOSS coderet: extract CDS/translation/mRNA sequences from EMBL entries
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-seqall=[EMBL/GenBank entry sequence(s)]:sequence USA:_files' \
  '-cdsoutseq=[CDS output sequence file]:file:_files' \
  '-mrnaoutseq=[mRNA output sequence file]:file:_files' \
  '-translationoutseq=[translation output sequence file]:file:_files' \
  '-restoutseq=[any-other-feature output sequence file]:file:_files' \
  '-outfile=[report output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
