#compdef pg_repack

# Zsh completion for pg_repack - PostgreSQL table repacking tool

_arguments -s -S \
  '(-a --all)'{-a,--all}'[repack all databases]' \
  '(-t --table)'{-t,--table}'=[table to repack]:table:' \
  '(-I --parent-table)'{-I,--parent-table}'=[parent table to repack]:table:' \
  '(-s --schema)'{-s,--schema}'=[schema to repack]:schema:' \
  '(-S --tablespace)'{-S,--tablespace}'=[move repacked tables to tablespace]:tablespace:' \
  '--moveidx[move indexes to specified tablespace too]' \
  '(-o --order-by)'{-o,--order-by}'=[order by columns (for CLUSTER)]:columns:' \
  '(-n --no-order)'{-n,--no-order}'[do VACUUM FULL instead of CLUSTER]' \
  '(-N --no-kill-backend)'{-N,--no-kill-backend}'[do not kill conflicting backends]' \
  '(-j --jobs)'{-j,--jobs}'=[number of parallel jobs]:jobs:' \
  '(-i --index)'{-i,--index}'=[index to rebuild]:index:' \
  '(-x --only-indexes)'{-x,--only-indexes}'[only repack indexes]' \
  '(-T --wait-timeout)'{-T,--wait-timeout}'=[timeout for waiting on locks in seconds]:seconds:' \
  '(-D --no-superuser-check)'{-D,--no-superuser-check}'[skip superuser check]' \
  '(-Z --no-analyze)'{-Z,--no-analyze}'[skip ANALYZE after repack]' \
  '(-k --no-superuser-check)'{-k,--no-superuser-check}'[skip superuser check]' \
  '(-e --echo)'{-e,--echo}'[echo queries sent to server]' \
  '--elevel=[error level]:level:' \
  '--dry-run[show what would be done]' \
  '(-d --dbname)'{-d,--dbname}'=[database name]:database:' \
  '(-h --host)'{-h,--host}'=[database server host]:host:_hosts' \
  '(-p --port)'{-p,--port}'=[database server port]:port:' \
  '(-U --username)'{-U,--username}'=[database user name]:user:_users' \
  '(-w --no-password)'{-w,--no-password}'[never prompt for password]' \
  '(-W --password)'{-W,--password}'[force password prompt]'
