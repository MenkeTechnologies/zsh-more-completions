#compdef mri_aparc2aseg
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_aparc2aseg
# mri_aparc2aseg - map cortical parcellation labels into the aseg volume

local ret=1

_arguments -s -S \
  '--s[recon-ed subject in SUBJECTS_DIR]:subject:' \
  '--o[output segmentation volume]:file:_files' \
  '--a2005[use aparc.a2005 instead of aparc]' \
  '--ribbon[use mri/hemi.ribbon.mgz as cortex mask]' \
  '--annot[use specified label file instead of aparc]:annot:' \
  '--version[display version information and exit]' && ret=0

return ret
