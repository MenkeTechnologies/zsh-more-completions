#compdef box-cli
# _box-cli — box-project Box phar builder CLI alias (humbug/box, PHP); symfony console
# upstream: https://github.com/box-project/box

_box-cli() {
    local -a sub=(
        'compile:compile phar from config'
        'composer:check:check composer config'
        'composer:vendor-dir:get vendor dir'
        'diff:diff two phars'
        'extract:extract phar contents'
        'info:show phar info'
        'list:list commands'
        'namespace:show namespaces in phar'
        'process:process file through compactors'
        'sign:sign existing phar'
        'validate:validate box config'
        'verify:verify phar signature'
        'completion:dump completion'
        'help:show help'
        'self-update:self update'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'box subcommand' sub ;;
        args)
            case $words[1] in
                compile) _arguments \
                    '--config=+[config file]:file:_files -g "box.json*"' \
                    '-c+[config file]:file:_files -g "box.json*"' \
                    '--working-dir=+[dir]:dir:_files -/' \
                    '-d+[dir]:dir:_files -/' \
                    '--no-parallel[no parallel]' \
                    '--no-restart[no restart without xdebug]' \
                    '--with-docker[generate dockerfile]' \
                    '--dev[dev mode]' \
                    '--debug[debug]' \
                    '--no-config[no config]' ;;
                info|namespace) _arguments '1:phar:_files -g "*.phar"' \
                    '--list[list contents]' \
                    '-l[list contents]' \
                    '--metadata[show metadata]' \
                    '--mode=+[mode]:m:(indent flat)' \
                    '-m+[mode]:m:(indent flat)' \
                    '--depth=+[depth]:n:' \
                    '-D+[depth]:n:' ;;
                diff) _arguments \
                    '1:phar A:_files -g "*.phar"' \
                    '2:phar B:_files -g "*.phar"' \
                    '--list-diff[list diff]' \
                    '--diff[diff]' \
                    '--check[check identical]' \
                    '-c[check identical]' ;;
                extract) _arguments \
                    '1:phar:_files -g "*.phar"' \
                    '2:output:_files -/' ;;
                validate) _arguments \
                    '1:config file:_files -g "box.json*"' \
                    '--ignore-recommendations-and-warnings[ignore warnings]' \
                    '-i[ignore warnings]' ;;
                verify|sign) _arguments '1:phar:_files -g "*.phar"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_box-cli "$@"
