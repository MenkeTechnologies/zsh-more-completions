#compdef pkgctl

# Zsh completion for pkgctl - Arch Linux devtools package control

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authenticate with infrastructure'
  'build:build packages inside a clean chroot'
  'db:pacman database modification'
  'diff:compare package files'
  'release:release step to upload build artifacts'
  'repo:manage package repositories'
  'search:search for packages'
  'version:show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'pkgctl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build)
        _arguments \
          '--arch[build for architecture]:arch' \
          '--repo[target repo]:repo:(core extra multilib testing)' \
          '--staging[target staging repo]' \
          '--testing[target testing repo]' \
          '(-s --staging)'{-s,--staging}'[use staging]' \
          '(-t --testing)'{-t,--testing}'[use testing]' \
          '(-o --offload)'{-o,--offload}'[build on remote server]' \
          '--worker[worker to use]:worker' \
          '(-w --worker)'{-w,--worker}'[number of workers]:count' \
          '--rebuild[rebuild packages]' \
          '--edit[edit PKGBUILD before building]' \
          '--inspect[inspect chroot]:when:(always never failure)' \
          '*:package directory:_files -/' && ret=0
        ;;
      repo)
        local -a repo_cmds=(
          'clone:clone a package repository'
          'configure:configure a package repository'
          'create:create a new package repository'
          'switch:switch to a branch'
          'web:open repository web page'
        )
        _describe -t commands 'repo command' repo_cmds && ret=0
        ;;
      db)
        local -a db_cmds=(
          'move:move packages between repos'
          'remove:remove packages from repos'
          'update:update package database'
        )
        _describe -t commands 'db command' db_cmds && ret=0
        ;;
      search)
        _arguments '*:search term' && ret=0
        ;;
    esac
    ;;
esac

return ret
