#compdef bitwarden bitwarden-cli
# _bitwarden — Bitwarden password manager bw CLI alias (Bitwarden Inc., TypeScript); commander
# upstream: https://github.com/bitwarden/clients

_bitwarden() {
    local -a sub=(
        'login:login'
        'logout:logout'
        'lock:lock vault'
        'unlock:unlock vault'
        'sync:sync vault'
        'list:list items/folders/collections/orgs/org-collections/org-members'
        'get:get item/folder/collection'
        'create:create item/folder/attachment/org-collection'
        'edit:edit item/folder/collection'
        'delete:delete item/folder/attachment'
        'restore:restore deleted item'
        'share:share item to org'
        'send:Bitwarden Send'
        'receive:receive a Send'
        'confirm:confirm org-member'
        'import:import vault data'
        'export:export vault data'
        'generate:generate password'
        'encode:base64-encode stdin'
        'config:configure CLI'
        'update:check for CLI update'
        'completion:generate shell completion'
        'serve:start vault REST API server'
        'status:show vault status'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--nointeraction[no interaction]' \
        '--session=+[session key]:str:' \
        '--pretty[pretty json]' \
        '--raw[raw output]' \
        '--response[response format]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bw subcommand' sub ;;
        args)
            case $words[1] in
                login) _arguments \
                    '--apikey[login via API key]' \
                    '--sso[login via SSO]' \
                    '--method=+[2FA method]:m:(authenticator email duo yubikey u2f)' \
                    '--code=+[2FA code]:str:' \
                    '--passwordenv=+[password env]:str:' \
                    '--passwordfile=+[password file]:file:_files' \
                    '--check[check login state]' \
                    '*:email:' ;;
                unlock) _arguments \
                    '--passwordenv=+[password env]:str:' \
                    '--passwordfile=+[password file]:file:_files' \
                    '--check[check unlock state]' \
                    '--raw[raw output]' ;;
                list) _arguments \
                    '1:object:(items folders collections organizations org-collections org-members)' \
                    '--search=+[search]:str:' \
                    '--organizationid=+[org id]:str:' \
                    '--collectionid=+[collection id]:str:' \
                    '--folderid=+[folder id]:str:' \
                    '--trash[only trash]' \
                    '--url=+[url]:url:_urls' ;;
                get|edit|delete|restore|share) _arguments \
                    '1:object:(item username password uri totp exposed attachment folder collection org-collection organization template fingerprint send)' \
                    '*:id:' ;;
                create) _arguments \
                    '1:object:(item attachment folder org-collection)' \
                    '--itemid=+[item id]:str:' \
                    '--organizationid=+[org id]:str:' \
                    '--file=+[file]:file:_files' ;;
                generate) _arguments \
                    '--length=+[length]:n:' \
                    '-l+[length]:n:' \
                    '--uppercase[uppercase]' \
                    '-u[uppercase]' \
                    '--lowercase[lowercase]' \
                    '-l[lowercase]' \
                    '--number[number]' \
                    '-n[number]' \
                    '--special[special chars]' \
                    '-s[special chars]' \
                    '--passphrase[passphrase]' \
                    '-p[passphrase]' \
                    '--words=+[words]:n:' \
                    '--separator=+[separator]:str:' \
                    '--capitalize[capitalize]' \
                    '--includeNumber[include number]' \
                    '--ambiguous[ambiguous]' \
                    '-a[ambiguous]' ;;
                send|receive) _arguments \
                    '*:arg:' ;;
                serve) _arguments \
                    '--hostname=+[hostname]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '--disable-origin-protection[disable origin protection]' ;;
                config) _arguments \
                    '1:cmd:(server)' \
                    '*:arg:' ;;
                completion) _arguments \
                    '--shell=+[shell]:s:(zsh bash)' ;;
            esac
            ;;
    esac
}

_bitwarden "$@"
