#compdef gamescope

# Zsh completion for gamescope - SteamOS session compositing window manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-w --nested-width)'{-w,--nested-width}'[game width]:width' \
  '(-h --nested-height)'{-h,--nested-height}'[game height]:height' \
  '(-r --nested-refresh)'{-r,--nested-refresh}'[game refresh rate]:Hz' \
  '(-W --output-width)'{-W,--output-width}'[output width]:width' \
  '(-H --output-height)'{-H,--output-height}'[output height]:height' \
  '(-o --prefer-output)'{-o,--prefer-output}'[preferred output name]:output' \
  '--prefer-vrrcapable-output[prefer VRR-capable output]' \
  '(-e --steam)'{-e,--steam}'[enable Steam integration]' \
  '--xwayland-count=[number of Xwayland servers to create]:count' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start in fullscreen mode]' \
  '(-b --borderless)'{-b,--borderless}'[make the window borderless]' \
  '(-n --nested-unfocused-refresh)'{-n,--nested-unfocused-refresh}'[unfocused game refresh rate]:Hz' \
  '(-R --refresh-rate)'{-R,--refresh-rate}'[output refresh rate]:Hz' \
  '--max-scale=[maximum scale factor]:scale' \
  '--scaler=[upscale filter]:filter:(auto integer nearest linear fsr nis pixel)' \
  '--filter=[downscale filter]:filter:(auto linear nearest pixel)' \
  '--sharpness=[FSR/NIS sharpness]:sharpness (0-20)' \
  '--expose-wayland[expose Wayland socket to children]' \
  '--backend=[rendering backend]:backend:(auto drm sdl openvr headless wayland)' \
  '--cursor-scale-height=[cursor scale height]:height' \
  '--hdr-enabled[enable HDR output]' \
  '--sdr-gamut-wideness=[SDR gamut wideness]:wideness (0.0-1.0)' \
  '--hdr-sdr-content-nits=[SDR content brightness in HDR mode]:nits' \
  '--hdr-itm-enable[enable inverse tone mapping]' \
  '--hdr-itm-sdr-nits=[SDR nits for ITM]:nits' \
  '--hdr-itm-target-nits=[target nits for ITM]:nits' \
  '--framerate-limit=[set a framerate limit]:fps' \
  '--mangoapp[launch with MangoHud metrics]' \
  '--force-grab-cursor[always grab the cursor]' \
  '--fade-out-duration=[fade-out duration in ms]:milliseconds' \
  '--force-windows-fullscreen[force all child windows to fullscreen]' \
  '--disable-color-management[disable color management]' \
  '--adaptive-sync[enable adaptive sync / VRR]' \
  '--immediate-flips[enable immediate flips]' \
  '(-T --stats-path)'{-T,--stats-path}'[write statistics to path]:path:_files' \
  '(-C --hide-cursor-delay)'{-C,--hide-cursor-delay}'[hide cursor after milliseconds]:milliseconds' \
  '--ready-fd=[notify readiness on this fd]:fd' \
  '--generate-drm-mode=[how to generate DRM modes]:mode:(fixed cvt)' \
  '--version[show version]' \
  '--help[show help]' \
  '--[end gamescope options]' \
  '*:command and arguments: _normal' && ret=0

return ret
