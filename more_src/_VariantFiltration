#compdef VariantFiltration
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/filters/VariantFiltration.java
# Filter variant calls based on INFO and/or FORMAT annotations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--mask=[Input mask]:value:_files' \
  '(--output -O)'{--output,-O}'[File to which variants should be written]:value:_files' \
  '(--filter-expression -filter)'{--filter-expression,-filter}'[One or more expressions used with INFO fields to filter]:value:' \
  '--filter-name=[Names to use for the list of filters]:value:' \
  '(--genotype-filter-expression -G-filter)'{--genotype-filter-expression,-G-filter}'[One or more expressions used with FORMAT (sample/genotype-level) fields to filter (see...]:value:' \
  '(--genotype-filter-name -G-filter-name)'{--genotype-filter-name,-G-filter-name}'[Names to use for the list of sample/genotype filters (must be a 1-to-1 mapping); this n...]:value:' \
  '(--cluster-size -cluster)'{--cluster-size,-cluster}'[The number of SNPs which make up a cluster. Must be at least 2]:value:' \
  '(--cluster-window-size -window)'{--cluster-window-size,-window}'[The window size (in bases) in which to evaluate clustered SNPs]:value:' \
  '--mask-extension=[How many bases beyond records from a provided '\''mask'\'' should variants be filtered]:value:_files' \
  '--mask-name=[The text to put in the FILTER field if a '\''mask'\'' is provided and overlaps with a v...]:value:_files' \
  '--filter-not-in-mask[Filter records NOT in given input mask.]' \
  '--missing-values-evaluate-as-failing[When evaluating the JEXL expressions, missing values should be considered failing the e...]' \
  '--invalidate-previous-filters[Remove previous filters applied to the VCF]' \
  '(--invert-filter-expression -invfilter)'{--invert-filter-expression,-invfilter}'[Invert the selection criteria for --filter-expression]' \
  '(--invert-genotype-filter-expression -invG-filter)'{--invert-genotype-filter-expression,-invG-filter}'[Invert the selection criteria for --genotype-filter-expression]' \
  '--set-filtered-genotype-to-no-call[Set filtered genotypes to no-call]' \
  '--apply-allele-specific-filters[Set mask at the allele level. This option is not compatible with clustering.]' \
  '--mask-description=[Description to add to the FILTER field in VCF header for the mask filter.]:value:_files' \
  '*:argument:_files' && ret=0

return ret
