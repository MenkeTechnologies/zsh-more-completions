#compdef ioping-cli
# _ioping-cli — Konstantin Khlebnikov ioping disk I/O latency measurement CLI alias (koct9i team, C); custom argparse
# upstream: https://github.com/koct9i/ioping

_ioping-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[stop after n requests]:n:' \
        '-i+[interval seconds]:str:' \
        '-l+[rate kb/s]:str:' \
        '-t+[min valid request time]:str:' \
        '-T+[max valid request time]:str:' \
        '-s+[request size]:str:' \
        '-S+[working set size]:str:' \
        '-o+[offset]:str:' \
        '-w+[deadline seconds]:str:' \
        '-p+[count]:n:' \
        '-P+[count between progress]:n:' \
        '-A[asynchronous I/O]' \
        '-C[use libc cache]' \
        '-D[direct I/O (no cache)]' \
        '-WWW[write mode]' \
        '-WW[write+sync mode]' \
        '-W[write mode (warning)]' \
        '-R[disk reads only]' \
        '-L[sequential read mode]' \
        '-r[random read mode]' \
        '-Y[sync I/O]' \
        '-y[data sync I/O]' \
        '-k[keep working file]' \
        '-G[periodic ping]' \
        '-B[print only statistics]' \
        '-q[quiet]' \
        '*:device or directory:_files'
}

_ioping-cli "$@"
