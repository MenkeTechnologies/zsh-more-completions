#compdef bloaty
# _bloaty-bin — Bloaty McBloatface size profiler for binaries (Google, C++); attribute binary size to sections, segments, symbols
# upstream: https://github.com/google/bloaty

_bloaty-bin() {
    _arguments \
        '(-c --csv)'{-c,--csv}'[csv output]' \
        '--tsv[tsv output]' \
        '(-d --domain)'{-d,--domain}'+[size domain]:domain:(vm file)' \
        '(-n --num-rows)'{-n,--num-rows}'+[rows]:n:' \
        '(-r --diff)'{-r,--diff}'+[diff with file]:file:_files' \
        '(-s --source-filter)'{-s,--source-filter}'+[filter regex]:regex:' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-w --raw)'{-w,--raw}'[raw size mode]' \
        '--debug-file+[debug file]:file:_files' \
        '--debug-vmaddr+[debug VM addr]:addr:' \
        '--debug-fileoff+[debug file offset]:n:' \
        '--list-sources[list source]' \
        '--demangle+[demangle mode]:mode:(none short full)' \
        '--disassemble[disassemble]' \
        '--help[show help]' \
        '*:file:_files'
}

_bloaty-bin "$@"
