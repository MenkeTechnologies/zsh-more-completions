#compdef nats-boot-config nats-pod-bootconfig
# _nats-boot-config — NATS NACK PodVM boot-config helper (looks up the node's external-IP tag and writes nats-server advertise configs into the StatefulSet's emptyDir)
# upstream: https://github.com/nats-io/nack
# Flags from cmd/nats-boot-config/main.go on tip; DEBUG=true env var enables debug logs.

_nats-boot-config() {
    _arguments \
        '(- *)-h[show help]' \
        '-v[show version]' \
        '-f=[output filename for the client advertise address]:file:_files' \
        '-gf=[output filename for the gateway advertise address]:file:_files' \
        '-t=[node tag to look up (e.g. nats.io/node-external-ip)]:tag:'
}

_nats-boot-config "$@"
