#compdef unknown-horizons
# Documentation: https://wiki.unknown-horizons.org/w/Command_line_options
# Reference accessed: 2026-05-16

# Unknown Horizons: 2D real-time strategy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-d[debug mode]' \
  '--debug[debug mode]' \
  '--start-dev-map[start with developer map]' \
  '--start-random-map[start with random map]' \
  '--start-specific-map=[load named map]:map:' \
  '--start-map=[load map by file]:file:_files' \
  '--load-game=[load save]:file:_files' \
  '--load-quicksave[load latest quicksave]' \
  '--mp-master=[master server URL]:url:' \
  '--mp-bind=[local bind address]:host:' \
  '--debug-module=[enable debug for module]:module:' \
  '--no-fife-cache[do not use FIFE cache]' \
  '--no-sound[disable sound]' \
  '--enable-unstable-features[enable unstable features]' \
  '--max-ticks=[max ticks]:n:' \
  '--gui-test=[run a gui test]:name:' \
  '--gui-log=[log gui events]:file:_files' \
  '--profile[run with profiler]' \
  '--unstable-singleplayer[unstable singleplayer]' \
  '--no-atlas-generation[no atlas generation]' \
  '--atlas-generation[force atlas generation]' \
  '*::unknown-horizons args:_files' && ret=0
return ret
