#compdef repquota
# Documentation: man repquota(8) (BSD)
# Source: BSD repquota — summarize quotas for a filesystem.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a)-a[summarize all configured filesystems]' \
    '-g[only group quotas]' \
    '-u[only user quotas]' \
    '-v[print header line before each filesystem]' \
    '*:filesystem:_files -/' \
    && ret=0

return ret
