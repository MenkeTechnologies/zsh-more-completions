#compdef erl

# Zsh completion for Erlang (erl)

_arguments -s -S \
  '-boot[boot script]:file:_files' \
  '-boot_var[set a boot variable]:var dir:' \
  '-config[system config file]:file:_files -g "*.config"' \
  '-connect_all[connect all nodes]:bool:(true false)' \
  '-cookie[Erlang distribution cookie]:cookie:' \
  '-detached[start the system detached from the controlling terminal]' \
  '-emu_args[print the actual arguments sent to the emulator]' \
  '-env[set OS environment variable]:var value:' \
  '-epmd_module[alternative EPMD module]:module:' \
  '-eval[evaluate expression]:expression:' \
  '-extra[pass extra arguments to the emulator]' \
  '-heart[enable heart program]' \
  '-hidden[start as a hidden node]' \
  '-hosts[specify IP addresses for boot file server]:hosts:_hosts' \
  '-init_debug[print debug information during init]' \
  '-instr[use instrumented run-time system]' \
  '-loader[set loader for code loading]:loader:(efile inet)' \
  '-make[run make:all on a set of modules]' \
  '-man[display the manual page for a module]:module:' \
  '-mode[distribution mode]:mode:(interactive embedded)' \
  '-name[set long node name]:name:' \
  '-noinput[ensure the system never reads from standard input]' \
  '-noshell[start without interactive shell]' \
  '-nostick[disable sticky directories]' \
  '-oldshell[start with the old Erlang shell]' \
  '-pa[add directories to code path (before)]:dir:_files -/' \
  '-pz[add directories to code path (after)]:dir:_files -/' \
  '-proto_dist[set distribution protocol module]:module:' \
  '-remsh[remote shell to connect to]:node:' \
  '-rsh[set remote shell program]:program:_command_names' \
  '-run[run a function]:module: :function: :args:' \
  '-s[run a function on startup]:module: :function: :args:' \
  '-setcookie[set magic cookie]:cookie:' \
  '-shutdown_time[shutdown timeout in ms]:ms:' \
  '-smp[SMP support]:mode:(auto enable disable)' \
  '-sname[set short node name]:name:' \
  '-start_epmd[start epmd]:bool:(true false)' \
  '-version[print version information]' \
  '+A[number of async threads]:threads:' \
  '+B[break handling]:mode:(c d i)' \
  '+K[enable kernel poll]:bool:(true false)' \
  '+P[maximum number of processes]:count:' \
  '+Q[maximum number of ports]:count:' \
  '+R[compatibility mode]:version:' \
  '+S[number of schedulers]:schedulers:' \
  '+T[set modified timing level]:level:' \
  '+V[print version and exit]' \
  '+W[warning verbosity]:level:(w i e)' \
  '*:script file:_files -g "*.erl *.escript"' && return 0
