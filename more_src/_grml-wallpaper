#compdef grml-wallpaper
# Source: https://github.com/grml/grml-etc-core/blob/48f12102d51fe38e28439dda0160c060029a6aa9/usr_share_grml/zsh/completion/grml/_grml-wallpaper
# Repository: grml/grml-etc-core (usr_share_grml/zsh/completion/grml/_grml-wallpaper)

local -a dirs

dirs=(. /usr/share/grml/)
_description files expl 'set desktop wallpaper on grml system'
_files "$expl[@]" -W dirs -g '*.{jpg,png}(-.)'
