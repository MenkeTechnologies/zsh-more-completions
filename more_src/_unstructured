#compdef unstructured
# Documentation: https://github.com/Unstructured-IO/unstructured
# Reference accessed: 2026-05-23
# Verified: unstructured --help and unstructured doctor --help.

# Zsh completion for unstructured - Unstructured document processing CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'unstructured command' \
      'doctor[print dependency and capability diagnostics]' && ret=0
    ;;
  args)
    case $line[1] in
      doctor)
        _arguments -C \
          '(-h --help)'{-h,--help}'[show help]' \
          '--for[check readiness for file type or family]:type:' \
          '--file[infer type from path and check readiness]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
