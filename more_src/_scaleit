#compdef scaleit
# scaleit — scale derivative data to native for isomorphous replacement (CCP4)

local ret=1

_arguments -s -S \
  'HKLIN[input MTZ]:file:_files -g "*.mtz"' \
  'HKLOUT[output MTZ]:file:_files -g "*.mtz"' \
  'LABIN[MTZ column labels]:labels:' \
  'AUTO[automatic column selection]' \
  'REFINE[scale-factor refinement type]:t:(SCALE ISOTROPIC ANISOTROPIC WILSON)' \
  'ANALYSE[analyze differences without refining]' \
  'RESOLUTION[resolution range]:lim:' \
  'WEIGHT[weight observations by sigma]' \
  'NOWT[unweighted scale determination]' \
  'EXCLUDE[exclusion criteria]:opt:' \
  'CONVERGE[convergence conditions]:opt:' \
  'SCATTER[scatter plots in logfile]' \
  'SCALE[apply input scales/B-factors]:opt:' \
  'SYMMETRY[override spacegroup]:sg:' \
  'GRAPH[additional analysis axes]:axis:' \
  'TITLE[output title]:title:' \
  'END[terminate input]' \
  '*:argument:_files' && ret=0

return ret
