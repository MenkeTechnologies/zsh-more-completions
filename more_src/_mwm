#compdef mwm
# Documentation: https://man.archlinux.org/search?q=mwm
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '-display+[X display]:display:' \
  '-xrm+[X resource]:resource:' \
  '-multiscreen[manage all screens]' \
  '-name+[application name]:name:' \
  '-screens+[screen names]:screens:' && ret=0

return ret
