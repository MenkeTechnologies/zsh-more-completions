#compdef fastd
# Documentation: https://fastd.readthedocs.io/en/stable/manual/cmdline.html
# fastd - fast and secure tunnelling daemon

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show the fastd version]' \
  '(-d --daemon)'{-d,--daemon}'[run fastd in the background]' \
  '--pid-file=[write fastd PID to the specified file]:file:_files' \
  '--status-socket=[socket to get fastd status]:file:_files' \
  '--log-level=[set stderr logging severity]:level:(fatal error warn info verbose debug debug2)' \
  '--syslog-level=[set the log level for syslog output]:level:(fatal error warn info verbose debug debug2)' \
  '--syslog-ident=[set the syslog identification string]:ident:' \
  '*'{-c,--config}'=[load a config file]:file:_files' \
  '*--config-peer=[load a config file for a single peer]:file:_files' \
  '*--config-peer-dir=[load all files from a directory as peer configs]:dir:_files -/' \
  '(-m --mode)'{-m,--mode}'=[set the interface mode]:mode:(tap multitap tun)' \
  '(-i --interface)'{-i,--interface}'=[set the TUN/TAP interface name]:iface:' \
  '(-M --mtu)'{-M,--mtu}'=[set the MTU (at least 576)]:mtu:' \
  '(-b --bind)'{-b,--bind}'=[set the bind address]:addr:' \
  '(-p --protocol)'{-p,--protocol}'=[set the handshake protocol]:protocol:' \
  '--method=[set the encryption/authentication method]:method:' \
  '--forward[enable forwarding of packets between clients]' \
  '--on-pre-up=[command to execute before interface creation]:command:' \
  '--on-up=[command to execute after interface creation]:command:' \
  '--on-down=[command to execute before interface destruction]:command:' \
  '--on-post-down=[command to execute after interface destruction]:command:' \
  '--on-connect=[command to execute when a handshake is sent]:command:' \
  '--on-establish=[command to execute when a connection is established]:command:' \
  '--on-disestablish=[command to execute when a connection is lost]:command:' \
  '--on-verify=[command to verify unknown peer connections]:command:' \
  '--verify-config[check the configuration and exit]' \
  '--generate-key[generate a new keypair]' \
  '--show-key[show the public key]' \
  '--machine-readable[suppress output of explaining text]' && ret=0

return ret
