#compdef snuffler
# Documentation: https://pyrocko.org/docs/current/apps/snuffler/manual.html
# Pyrocko snuffler: seismogram browser and workbench

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--format=[input data format]:format:(mseed sac kan segy seisan from_extension detect)' \
  '--pattern=[only include files matching regex]:regex:' \
  '--stations=[read stations file]:file:_files' \
  '--stationxml=[read StationXML file]:file:_files' \
  '(--event --events)'{--event=,--events=}'[read event file]:file:_files' \
  '--markers=[read markers file]:file:_files' \
  '--follow=[follow real time with N seconds delay]:seconds:' \
  '--cache=[directory for cache files]:dir:_files -/' \
  '--force-cache[use cache regardless of file mtimes]' \
  '--store-path=[store waveforms to path template]:template:' \
  '--store-interval=[store every N seconds]:seconds:' \
  '--ntracks=[initially show N tracks]:n:' \
  '--opengl[use OpenGL for drawing]' \
  '--qt5[use Qt5 bindings]' \
  '--qt4[use Qt4 bindings]' \
  '--debug[print debugging information]' \
  '*:file:_files' && ret=0

return ret
