#compdef awib
# Documentation: https://github.com/matslina/awib
# Reference accessed: 2026-05-27
# Verified: upstream README.md "Usage" section (matslina/awib)
#
# awib is a brainfuck compiler written in brainfuck. It takes brainfuck
# source on stdin and writes compiled output to stdout. There are no
# command-line flags; the target backend is selected via a "@TARGET"
# directive on the first line of the source (e.g. @386_linux, @lang_c,
# @lang_ruby, @lang_go, @lang_tcl, @lang_java, @lang_rust). Completion
# therefore only suggests file paths for shell-redirected input.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*:brainfuck source file:_files' && ret=0

return ret
