#compdef cnfsstat
# Documentation: man cnfsstat(8)
# Source: InterNetNews/inn frontends/cnfsstat.in — summary tool for CNFS storage (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[print age of oldest article in cycbuff]' \
    '-c+[CNFS class to report]:class:_default' \
    '(- *)-h[show help]' \
    '-i+[initial sleep seconds at startup]:secs:_default' \
    '-l+[loop like vmstat (default 600s)]:secs:_default' \
    '-m+[MRTG-format output for buffer]:buffer:_default' \
    '-p[print MRTG config file]' \
    '-P[write pid file]' \
    '-s[log through syslog]' \
    '-v[consistency checks and print result]' \
    && ret=0

return ret
