#compdef karmada-controller-manager
# Documentation: https://karmada.io/docs/reference/components/karmada-controller-manager/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Removed invented
# --karmada-kubeconfig/--master/--bind-address/--secure-port/--cert-dir/
# --tls-*/--leader-elect-resource-name; added --controllers and
# --cluster-status-update-frequency.

# karmada-controller-manager: Karmada control-plane controller manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--kubeconfig=[path to karmada control plane kubeconfig file]:file:_files' \
  '--leader-elect[enable leader election]' \
  '--leader-elect-lease-duration=[lease duration]:duration:' \
  '--leader-elect-renew-deadline=[renew deadline]:duration:' \
  '--leader-elect-retry-period=[retry period]:duration:' \
  '--leader-elect-resource-namespace=[leader election resource namespace]:ns:' \
  '--controllers=[list of controllers to enable]:controllers:' \
  '--cluster-status-update-frequency=[how often to post cluster status]:duration:' \
  '--cluster-monitor-period=[cluster health monitor period]:duration:' \
  '--concurrent-cluster-syncs=[concurrent cluster syncs]:n:' \
  '--concurrent-resourcebinding-syncs=[concurrent resourcebinding syncs]:n:' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--health-probe-bind-address=[health probe bind address]:addr:' \
  '--enable-cluster-resource-modeling[build resource modeling per cluster]' \
  '--feature-gates=[feature gates]:gates:' \
  '--v=[log level]:n:' \
  '--logtostderr[log to stderr]' \
  '*::karmada-controller-manager args:_files' && ret=0
return ret
