#compdef yara yarac yara-cli

local curcontext="$curcontext" state line ret=1

case $service in
  (yara)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-t --tag)*'{-t+,--tag=}'[only matching tag]:tag:' \
      '(-i --identifier)*'{-i+,--identifier=}'[only matching identifier]:id:' \
      '(-n --negate)'{-n,--negate}'[negate matches]' \
      '(-D --print-module-data)'{-D,--print-module-data}'[print module data]' \
      '(-g --print-tags)'{-g,--print-tags}'[print tags]' \
      '(-m --print-meta)'{-m,--print-meta}'[print meta]' \
      '(-s --print-strings)'{-s,--print-strings}'[print strings]' \
      '(-L --print-string-length)'{-L,--print-string-length}'[print string lengths]' \
      '(-e --print-namespace)'{-e,--print-namespace}'[print namespace]' \
      '(-S --print-stats)'{-S,--print-stats}'[print stats]' \
      '(-r --recursive)'{-r,--recursive}'[recursive]' \
      '(-N --no-follow-symlinks)'{-N,--no-follow-symlinks}'[no follow symlinks]' \
      '(-f --fast-scan)'{-f,--fast-scan}'[fast scan]' \
      '(-w --no-warnings)'{-w,--no-warnings}'[no warnings]' \
      '(-c --count)'{-c,--count}'[print count only]' \
      '(-l --max-rules)'{-l+,--max-rules=}'[max rules]:n:' \
      '(--max-strings-per-rule)--max-strings-per-rule=[max strings/rule]:n:' \
      '(--print-module-deps)*--print-module-deps[print module deps]' \
      '(-a --timeout)'{-a+,--timeout=}'[timeout]:s:' \
      '(-d --define)*'{-d+,--define=}'[define var=val]:def:' \
      '(-x --module-data)'{-x+,--module-data=}'[module data]:m:' \
      '(-p --threads)'{-p+,--threads=}'[threads]:n:' \
      '(-z --stack-size)'{-z+,--stack-size=}'[stack size]:n:' \
      '(-X --skip-larger)'{-X+,--skip-larger=}'[skip larger]:size:' \
      '(--scan-list)'{-A,--scan-list}'[scan files in list]' \
      '*: :_files -g "*.yar *.yara"' && ret=0 ;;
  (yarac)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-d --define)*'{-d+,--define=}'[define var=val]:def:' \
      '(-w --no-warnings)'{-w,--no-warnings}'[no warnings]' \
      '(--fail-on-warnings)--fail-on-warnings[fail on warnings]' \
      '*: :_files -g "*.yar *.yara"' && ret=0 ;;
esac

return ret
