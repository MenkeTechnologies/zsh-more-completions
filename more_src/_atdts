#compdef atdts
# _atdts — generate TypeScript JSON serializers from ATD definitions (ahrefs/atd)
# upstream: https://github.com/ahrefs/atd
# Flags from atdts/src/bin/Atdts_main.ml (cmdliner).

_atdts() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '*:atd file:_files -g "*.atd"'
}

_atdts "$@"
