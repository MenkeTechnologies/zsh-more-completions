#compdef dwiextract
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwiextract.html
# Source: MRtrix3/mrtrix3 cmd/dwiextract.cpp — extract subset of volumes from a DWI series (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-bzero -no_bzero)-bzero[output b=0 volumes only]' \
    '(-bzero -no_bzero)-no_bzero[output non-b=0 volumes only]' \
    '-singleshell[force a single-shell output]' \
    '-shells+[comma-separated b-value shells to extract]:shells:_default' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '-export_grad_mrtrix+[export MRtrix-format gradient table]:file:_files' \
    '-export_grad_fsl+[export FSL bvecs bvals pair]:files:_files' \
    '1:input DWI:_files -g "*.{nii,nii.gz,mif}"' \
    '2:output image:_files' \
    && ret=0

return ret
