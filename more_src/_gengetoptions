#compdef gengetoptions
# Documentation: https://github.com/ko1nksm/getoptions
# gengetoptions: generate getoptions libraries and standalone option parsers

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'gengetoptions command' \
      'library[generate a reusable getoptions library]' \
      'parser[pre-generate a standalone option parser]' \
      'embed[embed generated code into a shell script]' && ret=0
    ;;
  args)
    case $line[1] in
      parser)
        _arguments -s -S \
          '-f[file containing the parser definition]:file:_files' \
          '--optarg=[customize OPTARG variable name]:name' \
          '--optind=[customize OPTIND variable name]:name' \
          '*:argument:' && ret=0
        ;;
      embed)
        _arguments -s -S \
          '--overwrite[modify the target file in place]' \
          '-f[file containing the parser definition]:file:_files' \
          '*:file:_files' && ret=0
        ;;
      library)
        ret=0
        ;;
    esac
    ;;
esac

return ret
