#compdef ykpersonalize
# Documentation: https://developers.yubico.com/yubikey-personalization/Manuals/ykpersonalize.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '-1[target slot 1 (default; sets append-cr)]' \
  '-2[target slot 2]' \
  '-z[delete config in selected slot]' \
  '-s+[save config to file (- for stdout)]:file:_files' \
  '-i+[read config from file (- for stdin)]:file:_files' \
  '-f+[format for save/import]:fmt:(ycfg legacy)' \
  '-a+[AES secret key (hex)]:hex:' \
  '-c+[access code (hex)]:hex:' \
  '*-o+[set option (see OPTIONS)]:option:' \
  '-y[commit without prompting]' \
  '-d[dry-run]' \
  '-v[verbose]' \
  '-N+[use nth YubiKey found]:n:' \
  '-n+[NFC NDEF URI]:uri:' \
  '-t+[NFC NDEF text]:text:' \
  '-m+[device mode]:mode:' \
  '-S+[scanmap (90 hex chars)]:hex:' \
  '-D+[device info (hex)]:hex:' \
  '-u[update existing configuration]' \
  '-x[swap slots 1 and 2]' \
  '(- *)-h[show help]' \
  '(- *)-V[show version]'
