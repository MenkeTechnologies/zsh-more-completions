#compdef ykpersonalize

_arguments -s \
  '-1[target slot 1]' \
  '-2[target slot 2]' \
  '-z[delete config in slot]' \
  '-s+[save config to file]:file:_files' \
  '-i+[read config from file]:file:_files' \
  '-f[format]:fmt:(ycfg legacy)' \
  '-a+[AES secret key hex]:hex:' \
  '-c+[access code hex]:hex:' \
  '*-o[option]:option:' \
  '-y[commit without prompt]' \
  '-d[dry-run]' \
  '-v[verbose]' \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-n+[NDEF URI]:uri:' \
  '-t+[NDEF text]:text:' \
  '-m+[device mode]:mode:(0 1 2 3 4 5 6)' \
  '-S+[scanmap]:hex:' \
  '-D+[device info]:hex:' \
  '-u[update existing config]' \
  '-x[swap slots 1 and 2]'
