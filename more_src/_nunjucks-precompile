#compdef nunjucks-precompile

_arguments -s \
  '(-f --force)'{-f,--force}'[force on error]' \
  '(-a --filters)'{-a,--filters}'=[async filters]:list:' \
  '(-n --name)'{-n,--name}'=[template name]:name:' \
  '*'{-i,--include}'=[include regex]:regex:' \
  '*'{-x,--exclude}'=[exclude regex]:regex:' \
  '(-w --wrapper)'{-w,--wrapper}'=[wrapper]:wrapper:' \
  '(- *)'{-h,--help}'[show help]' \
  '*:path:_files'
