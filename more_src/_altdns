#compdef altdns
# Documentation: https://github.com/infosec-au/altdns
# Reference accessed: 2026-05-17
# Verified: infosec-au/altdns README. Real upstream uses short-only
# flags (-i/-o/-w/-r/-s/-t/-d) — long forms are not all in upstream.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -n flag.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-i,--input}'=[input file with subdomains]:input file:_files' \
  {-o,--output}'=[output file for altered subdomains]:output file:_files' \
  {-w,--wordlist}'=[wordlist for alterations]:wordlist file:_files' \
  {-r,--resolve}'[resolve altered subdomains]' \
  {-s,--save}'=[save resolved results to file]:output file:_files' \
  {-d,--dnsserver}'=[DNS server to use for resolution]:DNS server' \
  {-t,--threads}'=[number of threads]:threads' && ret=0

return ret
