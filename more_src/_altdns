#compdef altdns

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-i,--input}'=[input file with subdomains]:input file:_files' \
  {-o,--output}'=[output file for altered subdomains]:output file:_files' \
  {-w,--wordlist}'=[wordlist for alterations]:wordlist file:_files' \
  {-r,--resolve}'[resolve altered subdomains]' \
  {-s,--save}'=[save resolved results to file]:output file:_files' \
  {-d,--dnsserver}'=[DNS server to use for resolution]:DNS server' \
  {-t,--threads}'=[number of threads]:threads' \
  '-n[do not output to stdout]' && ret=0

return ret
