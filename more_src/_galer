#compdef galer
# Documentation: https://github.com/dwisiswant0/galer
# tool to extract all URLs/links from given a URL using the GoQuery and chromedp

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --url)'{-u,--url}'+[single target URL or list]:url/file:_files' \
  '(-e --extension)'{-e,--extension}'+[show only certain extensions (comma-separated)]:ext' \
  '(-c --concurrency)'{-c,--concurrency}'+[concurrency level]:n' \
  '(-w --wait)'{-w,--wait}'+[wait N seconds before evaluate]:n' \
  '(-d --depth)'{-d,--depth}'+[max depth for crawling]:n' \
  '--same-host[same host only]' \
  '--same-root[same root (eTLD+1) only]' \
  '(-o --output)'{-o,--output}'+[save fetched URLs output into file]:file:_files' \
  '(-T --template)'{-T,--template}'+[format for output template]:template' \
  '(-t --timeout)'{-t,--timeout}'+[max time (seconds) allowed for connection]:n' \
  '(-s --silent)'{-s,--silent}'[silent mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' && ret=0

return ret
