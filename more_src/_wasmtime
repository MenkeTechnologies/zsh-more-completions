#compdef wasmtime

local curcontext="$curcontext" state line ret=1

_wasmtime_commands() {
  local -a commands=(
    'run:Run a WebAssembly module'
    'serve:Serve a WebAssembly component via HTTP'
    'compile:Compile a WebAssembly module ahead-of-time'
    'explore:Explore the compilation of a WebAssembly module'
    'settings:Show Cranelift settings for the current host'
    'wast:Run a WebAssembly test script'
    'config:Manage wasmtime configuration'
  )
  _describe -t commands 'wasmtime command' commands
}

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:_wasmtime_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments -s -S \
          '--invoke[name of function to invoke]:function' \
          '*--env[pass environment variable]:key=value' \
          '*--dir[grant access to directory]:directory:_directories' \
          '*--mapdir[map directory]:guest\:\:host' \
          '--wasi[enable WASI]:module' \
          '--wasm[WebAssembly features]:feature' \
          '--fuel[limit execution fuel]:fuel' \
          '--epoch-interruption[enable epoch-based interruption]' \
          '--disable-cache[disable compiled module cache]' \
          '--cranelift-set[Cranelift setting]:setting' \
          '(-O --optimize)'{-O,--optimize}'[optimization level]:level' \
          '--allow-precompiled[allow precompiled modules]' \
          '*--preload[preload a module]:name=file' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:wasm module:_files -g "*.wasm"' \
          '*:arguments' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '--addr[listening address]:address' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:wasm component:_files -g "*.wasm"' && ret=0
        ;;
      compile)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--target[target triple]:target' \
          '--cranelift-set[Cranelift setting]:setting' \
          '(-O --optimize)'{-O,--optimize}'[optimization level]:level' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:wasm module:_files -g "*.wasm"' && ret=0
        ;;
      explore)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:wasm module:_files -g "*.wasm"' && ret=0
        ;;
      wast)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:wast file:_files -g "*.wast"' && ret=0
        ;;
      config)
        _arguments -s -S \
          '--new[create new configuration]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
