#compdef setSet
# Manipulate a cell/face/point/faceZone/cellZone/pointZone set interactively

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-noVTK[do not write VTK files]' \
  '-loop[execute batch commands for all timesteps]' \
  '-batch+[process in batch mode, using input from specified file]:file:_files' \
  '-noSync[do not synchronise selection across coupled patches]' \
  '-region+[specify alternative mesh region]:region:' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' && ret=0

return ret
