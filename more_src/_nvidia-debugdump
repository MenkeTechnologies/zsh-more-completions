#compdef nvidia-debugdump

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-l[list GPU devices]' \
  '-D+[dump GPU index]:idx:' \
  '-U+[set system UUID]:uuid:' \
  '-f+[dump to file]:file:_files' \
  '-O+[OS-specific dump]:type:' \
  '-z[also include compressed dump]' && ret=0

return ret
