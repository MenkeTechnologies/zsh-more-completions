#compdef kombai
# _kombai — Kombai kombai AI-powered design-to-code tool CLI converting Figma designs to production-ready React Vue Angular and HTML/CSS components (kombai team, TypeScript); commander.js
# upstream: https://kombai.com/

_kombai() {
    local -a sub=(
        'login:login to account'
        'logout:logout'
        'whoami:show current user'
        'init:initialize new project'
        'generate:generate code from Figma URL'
        'gen:generate code from Figma URL'
        'preview:preview generated code'
        'config:show config'
        'set-key:set Figma API key'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kombai subcommand' sub ;;
        args)
            case $words[1] in
                generate|gen) _arguments \
                    '--framework=+[fw]:f:(react vue angular svelte html)' \
                    '-f+[fw]:f:(react vue angular svelte html)' \
                    '--language=+[lang]:l:(typescript javascript)' \
                    '-l+[lang]:l:(typescript javascript)' \
                    '--css-framework=+[c]:c:(tailwind css styled-components emotion material-ui chakra-ui shadcn bootstrap)' \
                    '--output=+[dir]:dir:_files -/' \
                    '-o+[dir]:dir:_files -/' \
                    '--responsive[responsive output]' \
                    '--dark-mode[dark mode variants]' \
                    '--accessibility[accessibility]' \
                    '*:figma url:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_kombai "$@"
