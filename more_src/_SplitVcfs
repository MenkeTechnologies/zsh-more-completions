#compdef SplitVcfs
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#SplitVcfs
# Picard: split a VCF/BCF into two files, one for SNPs and one for indels

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[VCF or BCF input file]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  '--SNP_OUTPUT=[VCF/BCF file to which SNP records are written]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  '--INDEL_OUTPUT=[VCF/BCF file to which indel records are written]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  {-D=,--SEQUENCE_DICTIONARY=}'[index sequence dictionary to use]:dict:_files' \
  '--STRICT=[throw if a record other than SNP or indel is seen]:bool:(true false)' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf file:_files -g "*.(vcf|vcf.gz|bcf)"' && ret=0

return ret
