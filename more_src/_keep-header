#compdef keep-header
# Documentation: https://github.com/eBay/tsv-utils/blob/master/docs/tool_reference/keep-header.md
# keep-header - run a unix command in a header-aware fashion (passes header through unchanged)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version information and exit]' \
  '*:file:_files' && ret=0

return ret
