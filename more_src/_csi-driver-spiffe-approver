#compdef csi-driver-spiffe-approver
# _csi-driver-spiffe-approver — cert-manager SPIFFE CSI driver CertificateRequest approver
# upstream: https://github.com/cert-manager/csi-driver-spiffe
# Flags from internal/approver/app on tip.

_csi-driver-spiffe-approver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --log-level)'{-v,--log-level=}'[log verbosity (0-5)]:n:' \
        '--log-format=[log format]:fmt:(text json)' \
        '--trust-domain=[SPIFFE trust domain to approve for]:domain:' \
        '--issuer-name=[cert-manager Issuer name]:name:' \
        '--issuer-kind=[cert-manager Issuer kind]:kind:(Issuer ClusterIssuer)' \
        '--issuer-group=[cert-manager Issuer API group]:group:' \
        '--certificate-request-duration=[allowed CertificateRequest duration]:dur:' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--kube-api-qps=[max QPS to K8s apiserver]:f:' \
        '--kube-api-burst=[max burst to K8s apiserver]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_csi-driver-spiffe-approver "$@"
