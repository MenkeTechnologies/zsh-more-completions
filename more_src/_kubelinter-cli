#compdef kubelinter-cli kube-linter
# _kubelinter-cli — StackRox Red Hat kubelinter-cli CLI command-line frontend wrapping the KubeLinter open-source static analysis tool that checks Kubernetes YAML files and Helm charts to ensure the applications represented in them adhere to best practices open-source written in Go runs sensible default checks designed to give you useful information about your Kubernetes YAML files and Helm charts run-on-cluster-templates security-and-production-readiness-best-practices checks templates configure include exclude list-checks list-templates lint version (StackRox Red Hat team, Go); cobra
# upstream: https://docs.kubelinter.io/

_kubelinter-cli() {
    local -a sub=(
        'lint:lint Kubernetes manifests'
        'checks:check operations'
        'templates:template operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '--add-all-built-in[add all built-in]' \
        '--do-not-auto-add-defaults[no auto-add defaults]' \
        '--include=+[ids]:str:' \
        '*--include=+[id]:str:' \
        '--exclude=+[ids]:str:' \
        '*--exclude=+[id]:str:' \
        '--ignore-paths=+[paths]:str:' \
        '*--ignore-paths=+[paths]:str:' \
        '--format=+[fmt]:f:(plain json sarif markdown)' \
        '-f+[format]:f:(plain json sarif markdown)' \
        '--fail-if-no-objects-found[fail if no objects]' \
        '--fail-on-invalid-resource[fail on invalid resource]' \
        '--print-objects-with-no-failures[print no-failure objects]' \
        '--output-file=+[file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--verbose-output[verbose output]' \
        '--use-default-checks[use default checks]' \
        '--namespace=+[ns]:str:' \
        '--templates-glob=+[glob]:str:' \
        '--values=+[file]:file:_files -g "*.yaml *.yml"' \
        '--values-set=+[k=v]:str:' \
        '*--values-set=+[k=v]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kube-linter subcommand' sub ;;
        args)
            case $words[1] in
                lint) _arguments '*:file:_files' ;;
                checks) _arguments '1:op:(list)' '*:arg:' ;;
                templates) _arguments '1:op:(list)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kubelinter-cli "$@"
