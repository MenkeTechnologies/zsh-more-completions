#compdef vrrpd
# Documentation: https://manpages.debian.org/testing/vrrpd/vrrpd.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[display short inlined help]' \
  '-n[do not handle the virtual mac address]' \
  '-D[go into background mode, daemonize]' \
  '-i+[interface name to run on]:ifname:_net_interfaces' \
  '-v+[id of the virtual server (1-255)]:vrid:' \
  '-s[switch the preemption mode (enabled by default)]' \
  '-a+[authentication type]:auth:(none pw/hexkey ah/hexkey)' \
  '-p+[priority of this host in the virtual server (dfl: 100)]:prio:' \
  '-f+[directory where the pid file is stored (dfl: /var/run)]:piddir:_files -/' \
  '-d+[advertisement interval in sec (dfl: 1)]:delay:' \
  '-m+[interface(s) to monitor for failure]:ifname:_net_interfaces' \
  '-c+[delta to decrease priority by (dfl: 50)]:delta:' \
  '*:ip address of the virtual server:' && ret=0

return ret
