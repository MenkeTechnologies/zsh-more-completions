#compdef btrbk
# Documentation: https://man.archlinux.org/search?q=btrbk
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run scheduled tasks'
  'dryrun:dry-run scheduled tasks'
  'snapshot:create snapshots'
  'resume:incremental backup'
  'prune:delete old snapshots/backups'
  'archive:archive subvolumes'
  'clean:cleanup'
  'stats:print statistics'
  'list:list snapshots/backups'
  'usage:print disk usage'
  'origin:trace snapshot origin'
  'diff:show diff'
  'config:print configuration'
  'ls:list configs'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*-c+[config file]:file:_files' \
  '*--config=[config file]:file:_files' \
  '*-n[dry run]' \
  '*--dry-run[dry run]' \
  '*-q[quiet]' \
  '*--quiet[quiet]' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '*--progress[show progress]' \
  '*--print-schedule[print schedule]' \
  '*--syslog[log to syslog]' \
  '*-S[no snapshots]' \
  '*--no-snapshot[no snapshots]' \
  '*-l+[loglevel]:l:(error warn info debug trace)' \
  '*--loglevel=[loglevel]:l:(error warn info debug trace)' \
  '*--lockfile=[lock file]:file:_files' \
  '*--override=[k=v]:v:' \
  '*--format=[format]:f:(table long raw)' \
  '*--full[full output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'btrbk command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
