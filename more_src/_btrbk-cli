#compdef btrbk
# Documentation: https://github.com/digint/btrbk/blob/master/doc/btrbk.1.asciidoc
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run scheduled tasks'
  'dryrun:dry-run scheduled tasks'
  'snapshot:create snapshots'
  'resume:incremental backup'
  'prune:delete old snapshots/backups'
  'archive:archive subvolumes'
  'clean:cleanup'
  'stats:print statistics'
  'list:list snapshots/backups'
  'usage:print disk usage'
  'origin:trace snapshot origin'
  'diff:show diff'
  'extents:show extents/space usage'
  'config:print configuration'
  'ls:list subvolumes recursively'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*-c+[config file]:file:_files' \
  '*--config=[config file]:file:_files' \
  '*-n[dry run]' \
  '*--dry-run[dry run]' \
  '*-q[quiet]' \
  '*--quiet[quiet]' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '*--progress[show progress]' \
  '*--print-schedule[print schedule]' \
  '*-S[print schedule]' \
  '*-l+[loglevel]:l:(error warn info debug trace)' \
  '*--loglevel=[loglevel]:l:(error warn info debug trace)' \
  '*--lockfile=[lock file]:file:_files' \
  '*--override=[k=v]:v:' \
  '*--format=[format]:f:(table long raw col)' \
  '*--pretty[pretty output]' \
  '*-t[table output]' \
  '*--table[table output]' \
  '*-L[long output]' \
  '*--long[long output]' \
  '*-1[single column output]' \
  '*--single-column[single column output]' \
  '*-p[preserve]' \
  '*--preserve[preserve]' \
  '*--preserve-snapshots[preserve snapshots]' \
  '*--preserve-backups[preserve backups]' \
  '*--exclude=[exclude filter]:filter:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'btrbk command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
