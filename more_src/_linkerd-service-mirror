#compdef linkerd-service-mirror
# _linkerd-service-mirror — Linkerd2 multicluster service-mirror controller
# upstream: https://github.com/linkerd/linkerd2
# Flags from multicluster/cmd/service-mirror/main.go on tip.

_linkerd-service-mirror() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-kubeconfig=[local-cluster kubeconfig]:file:_files' \
        '-event-requeue-limit=[per-event requeue limit]:n:' \
        '-metrics-addr=[Prometheus metrics bind host\:port]:host\:port:' \
        '-namespace=[namespace holding Link CR + credentials Secret]:ns:' \
        '-endpoint-refresh-period=[endpoint resolution refresh interval]:dur:' \
        '-enable-headless-services[mirror headless services]' \
        '-enable-namespace-creation[create namespaces for mirrored services]' \
        '-enable-pprof[expose pprof on the admin server]' \
        '-local-mirror[watch the local cluster for federated members]' \
        '-federated-service-selector=[label selector for federated members]:sel:' \
        '-excluded-annotations=[comma-sep annotations to drop on mirror]:list:' \
        '-excluded-labels=[comma-sep labels to drop on mirror]:list:' \
        '-probe-service=[target-cluster probe service name]:name:' \
        '-v[klog verbosity level]:n:' \
        '-logtostderr[log to stderr]' \
        '-stderrthreshold=[stderr klog severity threshold]:level:(INFO WARNING ERROR FATAL)' \
        ':link-name:'
}

_linkerd-service-mirror "$@"
