#compdef kicad-cli-nightly
# Documentation: https://docs.kicad.org/9.0/en/cli/cli.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Shares kicad-cli interface.

# kicad-cli-nightly: nightly build of KiCad CLI tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'fp:footprint and footprint library operations'
  'jobset:run a jobset'
  'pcb:PCB operations'
  'sch:schematic operations'
  'sym:symbol and symbol library operations'
  'version:display version information'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'kicad-cli command' commands && ret=0 ;;
esac
return ret
