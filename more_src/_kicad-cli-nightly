#compdef kicad-cli-nightly

# kicad-cli-nightly: nightly build of KiCad CLI tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'fp:footprint commands'
  'pcb:PCB commands'
  'sch:schematic commands'
  'sym:symbol commands'
  'version:print KiCad version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'kicad-cli command' commands && ret=0 ;;
esac
return ret
