#compdef otbcli_GrayScaleMorphologicalOperation
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_GrayScaleMorphologicalOperation.html
# Orfeo ToolBox: perform grayscale morphological operations on an image channel

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image to be filtered]:image:_files' \
  '-out[output filtered image]:output:_files' \
  '-channel[selected channel index]:value:' \
  '-structype[structuring element type]:type:(box ball cross)' \
  '-xradius[structuring element radius along X]:value:' \
  '-yradius[structuring element radius along Y]:value:' \
  '-filter[morphological operation]:op:(dilate erode opening closing)' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
