autoload -U is-at-least

_uu-basename() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s+[remove a trailing SUFFIX; implies -a]:SUFFIX:_default' \
'--suffix=[remove a trailing SUFFIX; implies -a]:SUFFIX:_default' \
'-a[support multiple arguments and treat each as a NAME]' \
'--multiple[support multiple arguments and treat each as a NAME]' \
'-z[end each output line with NUL, not newline]' \
'--zero[end each output line with NUL, not newline]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::name:_files' \
&& ret=0
}

(( $+functions[_uu-basename_commands] )) ||
_uu-basename_commands() {
    local commands; commands=()
    _describe -t commands 'uu-basename commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-basename" ]; then
    _uu-basename "$@"
else
    compdef _uu-basename uu-basename
fi
