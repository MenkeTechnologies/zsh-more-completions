#compdef tune
# Documentation: source-direct extraction from upstream
# pytorch/torchtune torchtune/_cli/tune.py argparse
# `TuneCLIParser` + 6 subcommand classes registered via
# `<Class>.create(subparsers)` (Cat, Copy, Download, List, Run,
# Validate). Per upstream pyproject.toml `[project.scripts] tune
# = "torchtune._cli.tune:main"`, the installed binary is `tune`
# (NOT `torchtune` - that's the Python module name).
# Reference accessed: 2026-05-30 via gh api.
# PyTorch torchtune R153a — Meta's official PyTorch LLM
# fine-tuning library CLI. Sister tool to torchx (PyTorch's job
# launcher; also fresh this round) + torchrun/torchserve already
# in the corpus.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:subcommand:((download\:download-a-model-from-the-Hugging-Face-Hub list\:list-built-in-recipes-and-configs cp\:copy-a-built-in-recipe-or-config-to-a-local-path run\:run-a-recipe validate\:validate-a-config cat\:print-a-recipe-or-config))' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      download)
        # Download a model from the Hugging Face Hub.
        _arguments -s -S \
          '1:repo-id (e.g. meta-llama/Llama-2-7b-hf):' \
          '--hf-token=[Hugging Face Hub auth token]:token:' \
          '--output-dir=[local directory to download into]:dir:_directories' \
          '--ignore-patterns=[file patterns to skip (space-separated)]:patterns:' \
          '--source=[where to download from]:source:(huggingface kaggle)' \
          '--kaggle-username=[Kaggle username (for source=kaggle)]:username:' \
          && ret=0
        ;;
      list|ls)
        # List built-in recipes and configs.
        _arguments -s -S && ret=0
        ;;
      cp)
        # Copy a built-in recipe or config to a local path.
        _arguments -s -S \
          '1:recipe or config name:' \
          '2:destination path:_files' \
          '(-n --no-clobber)'{-n,--no-clobber}'[do NOT overwrite existing files]' \
          '--make-parents[create destination parent directories as needed]' \
          && ret=0
        ;;
      run)
        # Run a recipe (single-device or distributed via torchrun).
        _arguments -s -S \
          '*:recipe + recipe-args (forwarded to the recipe):' \
          && ret=0
        ;;
      validate)
        # Validate a config file before a run.
        _arguments -s -S '1:config file:_files -g "*.(yaml|yml)"' && ret=0
        ;;
      cat)
        # Print a recipe or config to stdout.
        _arguments -s -S \
          '1:recipe or config name or path:' \
          '--show-defaults[also show default values]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
