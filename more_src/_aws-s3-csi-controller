#compdef aws-s3-csi-controller
# _aws-s3-csi-controller — Mountpoint for Amazon S3 CSI driver controller (spawns Mountpoint pods + Headroom pods)
# upstream: https://github.com/awslabs/mountpoint-s3-csi-driver
# Flags from cmd/aws-s3-csi-controller/main.go on tip.

_aws-s3-csi-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--mountpoint-namespace=[namespace to spawn Mountpoint pods in]:ns:' \
        '--mountpoint-version=[version of Mountpoint inside the Mountpoint image]:version:' \
        '--mountpoint-priority-class-name=[priority class name of Mountpoint pods]:name:' \
        '--mountpoint-preempting-priority-class-name=[preempting priority class for Mountpoint pods]:name:' \
        '--mountpoint-headroom-priority-class-name=[priority class for Headroom pods]:name:' \
        '--mountpoint-image=[image of Mountpoint to use for spawned pods]:image:' \
        '--headroom-image=[pause-container image for Headroom pods]:image:' \
        '--mountpoint-image-pull-policy=[image pull policy for Mountpoint images]:policy:(Always Never IfNotPresent)' \
        '--mountpoint-container-command=[entrypoint of the Mountpoint pods]:cmd:' \
        '--mountpoint-pod-labels=[JSON pod labels for Mountpoint pods]:json:' \
        '--mountpoint-headroom-pod-labels=[JSON pod labels for Headroom pods]:json:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_aws-s3-csi-controller "$@"
