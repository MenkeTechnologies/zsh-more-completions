#compdef ck-client
# _ck-client — Cloak client (pluggable transport companion to ck-server) (cbeuw/Cloak)
# upstream: https://github.com/cbeuw/Cloak
# Flags from cmd/ck-client/ck-client.go (flag).

_ck-client() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-v[print version]' \
        '-c+[config file or semicolon-separated options]:file:_files -g "*.json"' \
        '-i+[local bind IP]:ip:_hosts' \
        '-l+[local bind port]:port:' \
        '-s+[remote proxy server IP/hostname]:host:_hosts' \
        '-p+[remote proxy port (usually 443)]:port:' \
        '-u[underlying proxy uses UDP]' \
        '-proxy=[proxy method name (matches ProxyBook)]:method:' \
        '-a+[admin UID to serve the admin API]:uid:' \
        '-verbosity=[log verbosity]:level:(debug info warn error fatal)' \
        '-V[VPN mode (Android, ignored elsewhere)]' \
        '-fast-open[TCP fast open (ignored)]'
}

_ck-client "$@"
