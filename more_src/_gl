#compdef gl

# Zsh completion for Gitless (gl)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'init:create a new Gitless repository'
      'status:show status of repository'
      'track:start tracking changes to files'
      'untrack:stop tracking changes to files'
      'diff:show changes to files'
      'commit:save changes to the repository'
      'checkout:checkout a file to its committed version'
      'history:show commit history'
      'branch:manage branches'
      'switch:switch branches'
      'tag:manage tags'
      'merge:merge a branch into the current branch'
      'fuse:fuse changes from a branch'
      'resolve:mark conflicts as resolved'
      'publish:publish commits upstream'
      'remote:manage remotes'
    )
    _describe -t commands 'gl command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (track|untrack|diff|checkout|resolve)
        _arguments -s -S \
          '*:file:_files' && ret=0
        ;;
      (commit)
        _arguments -s -S \
          '(-m --message)'{-m,--message}'=[commit message]:message' \
          '(-p --partial)'{-p,--partial}'[commit only some changes to files]' \
          '--exclude=[exclude files]:file:_files' \
          '--include=[include files]:file:_files' && ret=0
        ;;
      (history)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose log]' \
          '(-l --limit)'{-l,--limit}'=[number of commits]:count' \
          '*:file:_files' && ret=0
        ;;
      (branch)
        _arguments -s -S \
          '(-c --create)'{-c,--create}'=[create new branch]:branch name' \
          '(-d --delete)'{-d,--delete}'=[delete branch]:branch name' \
          '(-dp --delete-point)'{-dp,--delete-point}'=[branch point for new branch]:commit' \
          '(-l --list)'{-l,--list}'[list branches]' \
          '(-r --remote)'{-r,--remote}'[include remote branches]' && ret=0
        ;;
      (switch)
        _arguments -s -S \
          '1:branch name' && ret=0
        ;;
      (tag)
        _arguments -s -S \
          '(-c --create)'{-c,--create}'=[create tag]:tag name' \
          '(-d --delete)'{-d,--delete}'=[delete tag]:tag name' \
          '(-l --list)'{-l,--list}'[list tags]' && ret=0
        ;;
      (merge|fuse)
        _arguments -s -S \
          '1:source branch' && ret=0
        ;;
      (publish)
        _arguments -s -S \
          '1:remote branch' && ret=0
        ;;
      (remote)
        _arguments -s -S \
          '(-c --create)'{-c,--create}'=[create remote]:remote name' \
          '(-d --delete)'{-d,--delete}'=[delete remote]:remote name' \
          '--url=[remote URL]:url' \
          '(-l --list)'{-l,--list}'[list remotes]' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '1:directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
