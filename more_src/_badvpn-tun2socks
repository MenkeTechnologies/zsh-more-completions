#compdef badvpn-tun2socks
# Documentation: https://github.com/ambrop72/badvpn/blob/master/tun2socks/tun2socks.c
# badvpn TUN device to SOCKS proxy gateway

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--logger[logging destination]:dest:(stdout syslog)' \
  '--syslog-facility[set syslog facility]:facility:' \
  '--syslog-ident[set syslog identity]:ident:' \
  '--loglevel[logging verbosity level]:level:(0 1 2 3 4 5 none error warning notice info debug)' \
  '--channel-loglevel[per-channel loglevel]:channel:' \
  '--tundev[TUN device name]:device:' \
  '--netif-ipaddr[virtual router IP address]:ipaddr:' \
  '--netif-netmask[subnet netmask]:netmask:' \
  '--netif-ip6addr[virtual router IPv6 address]:addr:' \
  '--socks-server-addr[SOCKS server address]:addr:' \
  '--username[SOCKS5 username]:username:' \
  '--password[SOCKS5 password]:password:' \
  '--password-file[file holding SOCKS5 password]:file:_files' \
  '--append-source-to-username[append source addr to username]' \
  '--udpgw-remote-server-addr[UDP gateway server address]:addr:' \
  '--udpgw-max-connections[max UDP gateway connections]:number:' \
  '--udpgw-connection-buffer-size[UDP gateway buffer size]:number:' \
  '--udpgw-transparent-dns[redirect DNS through udpgw]' \
  '--socks5-udp[use SOCKS5 UDP ASSOCIATE for UDP]' && ret=0

return ret
