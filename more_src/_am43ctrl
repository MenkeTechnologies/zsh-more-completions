#compdef am43ctrl
# ============================================================================
# _am43ctrl — zsh completion for am43-ctrl, AM43 BLE blinds-drive controller
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/binsentsu/am43-ctrl
#   Author     : binsentsu
#   License    : (not standard SPDX in repo)
#   Stars      : 44
#   Language   : JavaScript (Node.js)
#   npm        : am43-ctrl
#   Binary     : am43ctrl  (package.json bin → index.js)
#   Last push  : 2024-01-03
#
# WHAT IT IS
#   am43-ctrl is "a Node util for controlling an AM43 Blinds Drive Cover,
#   either over MQTT or via a HTTP API".  AM43 motors are a widely deployed
#   inexpensive BLE-controlled blinds / curtain / roller-shade motor family
#   (Zemismart AM43, Tuya-branded units, etc.).  The tool scans for nearby
#   AM43 devices by MAC address, opens BLE GATT connections via the
#   `@abandonware/noble` central-role library, then bridges the proprietary
#   AM43 control characteristic to either:
#     1. an MQTT broker (Home Assistant auto-discovery topic conventions —
#        the default `--topic homeassistant/` prefix), or
#     2. a built-in Express HTTP API server (when `--express-port` is set).
#   Both channels can be active simultaneously.
#
# CLI ARGUMENT GRAMMAR  (verbatim from index.js yargs builder + .options chain)
#   am43ctrl [OPTIONS] <MAC1> [<MAC2> ...]
#
#   Positional arguments:
#     <MAC>...        AM43 device MAC addresses to connect to (colons
#                     stripped, lowercased internally — both `AB:CD:EF:...`
#                     and `abcdef...` accepted).  Must supply at least one.
#
#   Options (yargs short / long pairs, all env-bindable via AM43_* prefix):
#     -d, --debug                        Enable verbose debug logging
#     -l, --express-port <PORT>          Express HTTP API port  (default off:
#                                        Express does not start if unset)
#         --url, --mqtt-url <URL>        MQTT broker URL (mqtt:// | mqtts:// |
#                                        ws:// | wss://); at least one of
#                                        --url or --express-port is required
#         --topic, --mqtt-base-topic <T> Base topic for MQTT
#                                                       [default homeassistant]
#     -p, --mqtt-password [PASS]        Password for MQTT (if value omitted,
#                                        prompts interactively at startup)
#     -u, --mqtt-username <USER>         Username for MQTT
#     -i, --interval <MINS>              Polling interval in minutes
#                                        (default 0 = random 10..20)
#     -f, --fail-time <SECS>             Seconds-without-successful-connect
#                                        before exit (default 0 = never exit)
#     -h, --help                         yargs auto: show help
#         --version                      yargs auto: show version
#
#   Environment:
#     AM43_*                             yargs env() auto-binds every option
#                                        with this prefix (camelCase mapped
#                                        to UPPER_SNAKE);  e.g.
#                                        AM43_MQTT_URL / AM43_INTERVAL /
#                                        AM43_DEBUG.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `@abandonware/noble ^1.9.2-12` declared in
#   package.json `"dependencies"` block — the canonical Node.js BLE
#   central-role library (originally sandeepmistry/noble, now maintained
#   by the abandonware fork at github.com/abandonware/noble).  noble
#   provides cross-platform BLE peripheral discovery + characteristic
#   GATT operations across Linux/BlueZ, macOS/CoreBluetooth, and
#   Windows.  The CLI loads it as `const noble = require('@abandonware/noble')`
#   then subscribes to `noble.on('stateChange', ...)` / `noble.startScanning()`
#   to enumerate AM43 motors.  Verified via:
#     gh api repos/binsentsu/am43-ctrl/contents/package.json
#       → "@abandonware/noble": "^1.9.2-12"
#     gh api repos/binsentsu/am43-ctrl/contents/index.js
#       → const noble = require('@abandonware/noble')
#   This entry is the TS-Node=117 leader bump that CLOSES Axis 62
#   (Bluetooth Low Energy (BLE) Library) at 1/1/1 three-language symmetry:
#     Rust   = btleplug 0.11.5              (R837, `blendr`,  dmtrKovalenko)
#     Go     = tinygo.org/x/bluetooth 0.11.0 (R838, `ringcli`, smittytone)
#     TS-Node = @abandonware/noble ^1.9.2-12 (R839, `am43ctrl`, binsentsu)
#   Reaches the triple-117 landmark Rust=Go=TS-Node=117.
#
#   No completion for `am43ctrl` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_am43ctrl() {
    _arguments -s \
        '(-d --debug)'{-d,--debug}'[enable verbose debug logging]' \
        '(-l --express-port)'{-l+,--express-port=}'[Express HTTP API port]:port:' \
        '(--url --mqtt-url)'{--url=,--mqtt-url=}'[MQTT broker URL]:url:_urls' \
        '(--topic --mqtt-base-topic)'{--topic=,--mqtt-base-topic=}'[base topic for MQTT (default homeassistant)]:topic:' \
        '(-p --mqtt-password)'{-p,--mqtt-password}'[password for MQTT (interactive prompt if value omitted)]:password:' \
        '(-u --mqtt-username)'{-u+,--mqtt-username=}'[username for MQTT]:user:_users' \
        '(-i --interval)'{-i+,--interval=}'[polling interval in minutes (default 0 = random 10-20)]:minutes:' \
        '(-f --fail-time)'{-f+,--fail-time=}'[seconds since last connect before exit (default 0 = never)]:seconds:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '*:AM43 MAC address:'
}

_am43ctrl "$@"
