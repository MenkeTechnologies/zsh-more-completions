#compdef lsplace
# Documentation: https://man.archlinux.org/search?q=lsplace
# Reference accessed: 2026-05-16

# lsplace: list best LSF hosts to execute a job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-n[max hosts]:n:' \
  '-R[resource req]:expr:' \
  '-K[only local cluster]' \
  '*:host:_hosts' && ret=0
return ret
