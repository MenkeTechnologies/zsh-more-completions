#compdef lsplace
# Documentation: https://www.bsc.es/support/LSF/9.1.2/lsf_command_ref/lsplace.1.html
# Reference accessed: 2026-05-19
# Verified: BSC mirror of Platform LSF 9.1.2 lsplace(1) reference.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -K (only local cluster) — not in upstream lsplace.
# Real upstream flags: -L, -n, -w, -R, -h, -V plus host_name operands.

# lsplace: list best LSF hosts to execute a job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[print usage]' \
  '(- *)-V[print version]' \
  '-L[place tasks on as few hosts as possible]' \
  '-n+[minimum hosts to return]:n:' \
  '-w+[maximum hosts to return]:n:' \
  '-R+[resource requirement expression]:expr:' \
  '*:host:_hosts' && ret=0
return ret
