#compdef fastaFromBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/getfasta.html
# extract sequences from a FASTA for intervals in BED (bedtools getfasta)

local ret=1

_arguments -s -S \
  '-fi[input FASTA file]:file:_files' \
  '-bed[input BED/GFF/VCF file]:file:_files' \
  '-fo[output file name]:file:_files' \
  '-name[use name field and coordinates for FASTA header]' \
  '-name+[use name field and coordinates for FASTA header (deprecated)]' \
  '-nameOnly[use the name field for the FASTA header]' \
  '-tab[report sequences in tab-delimited format]' \
  '-bedOut[report sequences in tab-delimited BED format]' \
  '-s[force strandedness; reverse complement antisense]' \
  '-split[given BED12, extract and concatenate block sequences]' \
  '-fullHeader[use full FASTA header]' \
  '-rna[the FASTA is RNA not DNA]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
