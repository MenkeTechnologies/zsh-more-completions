#compdef 3dZcat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dZcat.html
# AFNI: concatenate datasets along the z (slice) direction

local ret=1

_arguments -s -S \
  '-prefix[output dataset prefix (default zcat)]:prefix:' \
  '-datum[coerce output type]:type:(byte short float)' \
  '-fscale[force scaling of output to integer range]' \
  '-nscale[disable scaling on byte/short datasets]' \
  '-verb[verbose output]' \
  '-frugal[reduce memory usage at cost of I/O]' \
  '*:dataset:_files' && ret=0

return ret
