#compdef mido-serve
# _mido-serve — serve MIDI output ports over a socket (mido/mido)
# upstream: https://github.com/mido/mido
# Flags from mido/scripts/mido_serve.py (argparse).

_mido-serve() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '1:address host\:port:' \
        '*:output port:'
}

_mido-serve "$@"
