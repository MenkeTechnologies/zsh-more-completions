#
# THE tansu CLI — clap derive + jsonschema + apache-avro + tokio
#
# tansu's CLI is in tansu-cli/src/cli.rs.  Uses clap v4
# derive with #[derive(Parser)] root + #[derive(Subcommand)]
# Commands.
#
# Source structure:
#     #[derive(Clone, Debug, Parser)]
#     #[command(name = "tansu", version, about, ...)]
#     pub struct Cli {
#         #[command(subcommand)]
#         command: Option<Command>,
#         #[clap(flatten)]
#         broker: broker::Arg,
#     }
#
#     #[derive(Clone, Debug, Subcommand)]
#     enum Command {
#         Broker(Box<broker::Arg>),
#         Cat { command: cat::Command },
#         Generator(Box<generator::Arg>),
#         Perf(Box<perf::Arg>),
#         Proxy(Box<proxy::Arg>),
#         Topic { command: topic::Command },
#         User { command: user::Command },
#     }
#
# Subcommands (7; broker default if no command):
#   broker       Kafka-compatible broker (default)
#   cat          produce / validate / fetch messages
#                (Avro / JSON / Protobuf)
#   generator    traffic generator for schema-backed topics
#   perf         performance benchmarking
#   proxy        Kafka API proxy
#   topic        topic administration (create / list / delete)
#   user         user management (create / list / delete)
#
# Global broker flags (flattened into root + each subcommand):
#   --broker URL                  Kafka broker URL
#                                 (default tcp://localhost:9092)
#   (additional broker flags vary by subcommand)
#
# Feature flags (compile-time, via Cargo features):
#   delta, dynostore, iceberg, libsql, parquet, postgres,
#   slatedb, turso
#
# jsonschema is used in tansu-schema crate to validate
# JSON-typed topic messages against per-topic schemas
# (alongside apache-avro for Avro topics and protobuf for
# Protobuf topics).
#
# Five-axis distinctness from all previously-documented Rust
# libraries:
#
#   1. JSON SCHEMA VALIDATION ABSTRACTION — distinct from
#      every other Axis.
#
#   2. COMPILED-SCHEMA VALIDATION GRAPH — amortizes parsing
#      cost across multiple instances.
#
#   3. DRAFT 4-2020-12 SUPPORT — auto-detected from $schema.
#
#   4. CUSTOM KEYWORDS — extensible beyond JSON Schema spec.
#
#   5. DMITRY-DYGALO / Stranger6667 ECOSYSTEM PROVENANCE —
#      distinct maintainer.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/tansu-io/tansu/blob/main/tansu-cli/src/cli.rs
# clap v4 derive #[command] + #[derive(Subcommand)] definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _tansu_cmds _tansu_topic_cmds _tansu_user_cmds _tansu_cat_cmds
_tansu_cmds=(
    'broker:Apache Kafka compatible broker (default if no command)'
    'cat:produce / validate / fetch messages'
    'generator:traffic generator for schema-backed topics'
    'perf:performance benchmarking'
    'proxy:Apache Kafka compatible proxy'
    'topic:topic administration (create / list / delete)'
    'user:user management (create / list / delete)'
    'help:show help for a subcommand'
)
_tansu_topic_cmds=(
    'create:create a topic'
    'list:list topics'
    'delete:delete a topic'
)
_tansu_user_cmds=(
    'create:create a user'
    'list:list users'
    'delete:delete a user'
)
_tansu_cat_cmds=(
    'produce:produce messages to a topic'
    'fetch:fetch messages from a topic'
    'validate:validate messages against schema'
)

_arguments -C \
    '--broker=[Kafka broker URL]:url:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'tansu subcommand' _tansu_cmds && ret=0
        ;;
    args)
        case $words[1] in
            topic) _describe -t commands 'topic subcommand' _tansu_topic_cmds && ret=0 ;;
            user)  _describe -t commands 'user subcommand' _tansu_user_cmds && ret=0 ;;
            cat)   _describe -t commands 'cat subcommand' _tansu_cat_cmds && ret=0 ;;
            help)  _describe -t commands 'subcommand' _tansu_cmds && ret=0 ;;
        esac
        ;;
esac

return ret
