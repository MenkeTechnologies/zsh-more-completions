#compdef pdf-stapler
# Documentation: https://github.com/hellerbarde/stapler/blob/master/staplelib/stapler.py
# pdf-stapler - staple, delete, split and shuffle PDF documents

local ret=1

_arguments -s -S \
  '(-o --ownerpw)'{-o,--ownerpw}'=[owner password]:password' \
  '(-u --userpw)'{-u,--userpw}'=[user password]:password' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-f --force)'{-f,--force}'[overwrite existing output files]' \
  '(-d --destdir)'{-d,--destdir}'=[destination directory for output]:dir:_files -/' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'cat:select the given pages/ranges from input files'
      'sel:select the given pages/ranges from input files'
      'del:select all but the given pages/ranges'
      'split:create one file per page in input PDFs'
      'burst:create one file per page in input PDFs'
      'zip:interleave pages from input files'
      'background:overlay pages over a background'
      'info:show document information'
      'list-log:list logical pages'
      'list-logical:list logical pages'
    )
    if (( CURRENT == 1 )); then
      _describe -t commands 'pdf-stapler command' cmds && ret=0
    else
      _files -g '*.pdf' && ret=0
    fi
    ;;
esac

return ret
