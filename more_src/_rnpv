#compdef rnpv
# Documentation: https://man.archlinux.org/search?q=rnpv
# Reference accessed: 2026-05-16

# rnpv: standalone verify tool for RNP
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verify]' \
  '-k[keyring]:dir:_files -/' \
  '-i[input signed file]:file:_files' \
  '-o[output (raw) file]:file:_files' \
  '*::rnpv args:_files' && ret=0
return ret
