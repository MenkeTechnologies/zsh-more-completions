#compdef rednoise
# Documentation: https://github.com/scottransom/presto/blob/master/docs/rednoise.1
# PRESTO: remove red noise from an FFT by dividing out a running median.

local ret=1

_arguments -s -S \
  '-startwidth=[initial windowing size]:n:' \
  '-endwidth=[final windowing size]:n:' \
  '-endfreq=[highest freq where windowing increases]:freq:' \
  '*:input .fft file:_files -g "*.fft"' && ret=0

return ret
