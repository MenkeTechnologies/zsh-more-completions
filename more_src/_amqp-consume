#compdef amqp-consume

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--usage[show usage]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-S --server)'{-S,--server}'+[broker host[:port]]:server:_hosts' \
  '--port=[broker port]:port:' \
  '(-u --url)'{-u,--url}'+[broker URL]:url:' \
  '--vhost=[virtual host]:vhost:' \
  '--username=[username]:user:' \
  '--password=[password]:pw:' \
  '--ssl[use TLS]' \
  '--cacert=[CA certificate]:file:_files' \
  '--cert=[client cert]:file:_files' \
  '--key=[client key]:file:_files' \
  '--verify[verify peer]' \
  '--heartbeat=[heartbeat seconds]:sec:' \
  '(-q --queue)'{-q,--queue}'+[queue name]:name:' \
  '(-A --ack-mode)'{-A,--ack-mode}'+[ack mode]:mode:(auto manual)' \
  '(-c --count)'{-c,--count}'+[max messages]:n:' \
  '(-e --exclusive)'{-e,--exclusive}'[exclusive queue access]' \
  '(-p --prefetch-count)'{-p,--prefetch-count}'+[prefetch count]:n:' \
  '(-d --declare)'{-d,--declare}'[declare queue with defaults]' \
  '(-n --no-ack)'{-n,--no-ack}'[do not ack messages]' \
  '*:command:_command_names' && ret=0

return ret
