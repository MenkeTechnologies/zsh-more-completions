#compdef yr
# Documentation: https://man.archlinux.org/search?q=yr
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'scan:scan files with rules'
  'compile:compile rules to bytecode'
  'check:check rules syntax'
  'dump:dump file structure (PE, ELF, etc.)'
  'fmt:format YARA rules'
  'fix:auto-fix issues'
  'completion:generate shell completion'
  'deps:show rule dependencies'
)

_arguments -C \
  '(-C --config)'{-C,--config}'=[config file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

local compile_args=(
  '*'{-d,--define}'=[define VAR=VAL]:vardef:'
  '*'{-w,--disable-warnings}'=[disable warning]:warning:'
  '*'{-I,--ignore-module}'=[ignore module]:module:'
  '*--include-dir=[include dir]:dir:_files -/'
  '--path-as-namespace[use file path as namespace]'
  '--relaxed-re-syntax[relaxed regex syntax]'
)

case $state in
  (subcommand)
    _describe -t subcommands 'yr subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (scan)
        _arguments \
          $compile_args \
          '(-C --compiled-rules)'{-C,--compiled-rules}'[rules are pre-compiled]' \
          '(-c --count)'{-c,--count}'[count matches only]' \
          '--disable-console-logs[disable console logs]' \
          '--max-matches-per-pattern=[max matches per pattern]:n:' \
          '*'{-x,--module-data}'=[module data]:MODULE=FILE:' \
          '(-n --negate)'{-n,--negate}'[print non-matching files]' \
          '--no-mmap[do not use mmap]' \
          '(-o --output-format)'{-o,--output-format}'=[output format]:fmt:(text ndjson json)' \
          '(-m --print-meta)'{-m,--print-meta}'[print rule metadata]' \
          '(-e --print-namespace)'{-e,--print-namespace}'[print namespace]' \
          '(-s --print-strings)'{-s,--print-strings}'=[print matching strings]:n:' \
          '(-g --print-tags)'{-g,--print-tags}'[print tags]' \
          '--profiling[enable profiling]' \
          '(-r --recursive)'{-r,--recursive}'=[recursive]:depth:' \
          '--scan-list[input is a list of paths]' \
          '(-z --skip-larger)'{-z,--skip-larger}'=[skip files larger than]:bytes:' \
          '*'{-t,--tag}'=[require tag]:tag:' \
          '(-p --threads)'{-p,--threads}'=[threads]:n:' \
          '(-a --timeout)'{-a,--timeout}'=[timeout seconds]:s:' \
          '*:rules and target:_files' && ret=0
        ;;
      (compile)
        _arguments \
          $compile_args \
          '(-o --output)'{-o,--output}'=[output bytecode]:file:_files' \
          '*:rule:_files -g "*.yar*"' && ret=0
        ;;
      (dump)
        _arguments \
          '*'{-m,--module}'=[module]:module:(lnk macho elf pe dotnet crx dex)' \
          '--no-colors[no colors]' \
          '(-o --output-format)'{-o,--output-format}'=[output format]:fmt:(json yaml)' \
          '*:file:_files' && ret=0
        ;;
      (fmt)
        _arguments \
          '(-c --check)'{-c,--check}'[check only]' \
          '(-t --tab-size)'{-t,--tab-size}'=[tab size]:n:' \
          '*:file:_files -g "*.yar*"' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash elvish fish powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
