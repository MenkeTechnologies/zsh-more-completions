#compdef xtables-legacy-multi
# _xtables-legacy-multi — netfilter xtables-legacy-multi binary (single ELF dispatched via argv[0] for the legacy ip(6)tables-legacy / ip(6)tables-legacy-save / ip(6)tables-legacy-restore stems; -h help, -V version; usually invoked indirectly through one of those symlinks rather than directly by name)
# upstream: https://git.netfilter.org/iptables (xtables-legacy)
# Behaviour from netfilter/iptables iptables/xtables-legacy-multi.c on tip.

_xtables-legacy-multi() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '*::command:_command_names -e'
}

_xtables-legacy-multi "$@"
