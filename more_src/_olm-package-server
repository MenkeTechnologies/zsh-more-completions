#compdef olm-package-server package-server
# _olm-package-server — OLMv0 packagemanifests aggregated API server
# upstream: https://github.com/operator-framework/operator-lifecycle-manager
# Flags from cmd/package-server/main.go + pkg/package-server/server/server.go on tip.

_olm-package-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--interval=[default CatalogSource resync interval]:dur:' \
        '--global-namespace=[namespace where global CatalogSources live]:ns:' \
        '--kubeconfig=[kubeconfig for apiserver + kubelets]:file:_files' \
        '--debug[enable debug log level]' \
        '--secure-port=[HTTPS bind port]:port:' \
        '--bind-address=[HTTPS bind address]:ip:' \
        '--tls-cert-file=[TLS server certificate]:file:_files' \
        '--tls-private-key-file=[TLS server private key]:file:_files' \
        '--client-ca-file=[client-cert CA bundle]:file:_files' \
        '--authentication-kubeconfig=[apiserver-to-extension kubeconfig]:file:_files' \
        '--authorization-kubeconfig=[delegated authorization kubeconfig]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_olm-package-server "$@"
