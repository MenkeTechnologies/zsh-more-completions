#compdef gifski-cli
# _gifski-cli — Kornel Lesinski gifski highest-quality GIF encoder CLI alias (ImageOptim/gifski team, Rust); clap-rs
# upstream: https://github.com/ImageOptim/gifski

_gifski-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--output=+[file]:file:_files -g "*.gif"' \
        '-o+[file]:file:_files -g "*.gif"' \
        '--fps=+[fps]:n:' \
        '-r+[fps]:n:' \
        '--fast[fast encoding]' \
        '--extra[high quality]' \
        '--quality=+[1-100]:n:' \
        '-Q+[1-100]:n:' \
        '--motion-quality=+[1-100]:n:' \
        '--lossy-quality=+[1-100]:n:' \
        '--width=+[w]:n:' \
        '-W+[w]:n:' \
        '--height=+[h]:n:' \
        '-H+[h]:n:' \
        '--matte=+[color]:str:' \
        '--once[do not loop]' \
        '--no-loop[do not loop]' \
        '--repeat=+[count]:n:' \
        '--nosort[do not sort filenames]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--quieter[silent]' \
        '*:input files:_files -g "*.{png,jpg,jpeg,bmp,gif,tiff,webp,mp4,mov,mkv,webm,m4v,avi,y4m}"'
}

_gifski-cli "$@"
