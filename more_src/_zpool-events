#compdef zpool-events
# _zpool-events — OpenZFS zpool events (read ZFS Event Daemon (zed) events from the kernel event ring; -c clears after reading, -f follow, -v verbose with payload, -H scriptable; positional pool optionally filters)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_events) on tip.

_zpool-events() {
    _arguments \
        '-c[clear after reading]' \
        '-f[follow]' \
        '-v[verbose payload]' \
        '-H[scriptable output]' \
        '*:pool:'
}

_zpool-events "$@"
