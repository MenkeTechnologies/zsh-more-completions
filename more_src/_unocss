#compdef unocss
# Documentation: https://unocss.dev/integrations/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for unocss - instant on-demand atomic CSS engine CLI

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-v --version)'{-v,--version}'[show unocss version]'
  '(-c --config)'{-c,--config}'[config file path]:file:_files -g "*.(js|ts|mjs|cjs)"'
  '(-o --out-file)'{-o,--out-file}'[output file]:file:_files'
  '(-w --watch)'{-w,--watch}'[watch for file changes]'
  '--preflights[enable preflights]'
  '--no-preflights[disable preflights]'
  '--minify[minify output]'
  '--stdout[emit CSS to stdout]'
  '--write-transformed[write transformed source files]'
  '--cwd[working directory]:path:_files -/'
  '*:glob pattern:'
)

_arguments -s -S $arguments
