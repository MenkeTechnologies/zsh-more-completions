#compdef regctl

# Zsh completion for regctl (container registry client)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Show help]' \
  '--help[Show help]' \
  '--logopt=[Log options]:log option:' \
  '-v+[Log verbosity level]:level:(panic fatal error warn info debug trace)' \
  '--verbosity=[Log verbosity level]:level:(panic fatal error warn info debug trace)' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'artifact:Manage artifacts'
      'blob:Manage blobs/layers'
      'completion:Generate shell completions'
      'config:Manage registry configurations'
      'image:Manage container images'
      'index:Manage index/manifest lists'
      'manifest:Manage manifests'
      'registry:Manage registries'
      'repo:Manage repositories'
      'tag:Manage tags'
      'version:Show version information'
    )
    _describe -t commands 'regctl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      image)
        local -a image_cmds=(
          'copy:Copy images between registries'
          'delete:Delete an image'
          'digest:Show image digest'
          'export:Export image to tar file'
          'import:Import image from tar file'
          'inspect:Inspect image config'
          'manifest:Show image manifest'
          'mod:Modify an image'
          'ratelimit:Show rate limit status'
        )
        _describe -t image-commands 'image command' image_cmds && ret=0
        ;;
      tag)
        local -a tag_cmds=(
          'delete:Delete a tag'
          'ls:List tags in a repository'
        )
        _describe -t tag-commands 'tag command' tag_cmds && ret=0
        ;;
      manifest)
        local -a manifest_cmds=(
          'delete:Delete a manifest'
          'get:Get a manifest'
          'head:Head request for a manifest'
          'put:Push a manifest'
        )
        _describe -t manifest-commands 'manifest command' manifest_cmds && ret=0
        ;;
      repo)
        local -a repo_cmds=(
          'ls:List repositories'
        )
        _describe -t repo-commands 'repo command' repo_cmds && ret=0
        ;;
      registry)
        local -a registry_cmds=(
          'config:Show registry config'
          'login:Login to a registry'
          'logout:Logout from a registry'
          'set:Set registry config'
        )
        _describe -t registry-commands 'registry command' registry_cmds && ret=0
        ;;
      blob)
        local -a blob_cmds=(
          'copy:Copy a blob between repositories'
          'delete:Delete a blob'
          'get:Get a blob'
          'head:Head request for a blob'
          'put:Push a blob'
        )
        _describe -t blob-commands 'blob command' blob_cmds && ret=0
        ;;
      completion)
        _arguments \
          '1:shell:(bash fish powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
