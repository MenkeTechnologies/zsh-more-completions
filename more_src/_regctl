#compdef regctl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'artifact:manage OCI artifacts'
  'blob:manage blobs'
  'config:manage registries configuration'
  'image:manage images'
  'manifest:manage manifests'
  'registry:manage registries'
  'repo:manage repositories'
  'tag:manage tags'
  'version:show version'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--verbosity[log level]:level:(debug info warn error)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'regctl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      image)
        _arguments -s -S \
          '1:action:(copy delete digest export get-file import inspect manifest mod rate-limit)' \
          '*:args:' && ret=0
        ;;
      tag)
        _arguments -s -S \
          '1:action:(delete list)' \
          '*:args:' && ret=0
        ;;
      manifest)
        _arguments -s -S \
          '1:action:(delete get head put)' \
          '*:args:' && ret=0
        ;;
      registry)
        _arguments -s -S \
          '1:action:(config login logout set)' \
          '*:args:' && ret=0
        ;;
      repo)
        _arguments -s -S \
          '1:action:(ls)' \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
