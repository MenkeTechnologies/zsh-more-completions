#compdef regctl
# Documentation: https://regclient.org/cli/regctl/
# Reference accessed: 2026-05-20
# Verified: upstream regclient docs at the URL above.
# Added missing global flags --host/--user-agent and expanded
# image/manifest/repo/blob/artifact/index subcommand lists to match
# upstream documentation.

# Zsh completion for regctl (container registry client)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--logopt=[log options]:log option:' \
  '(-v --verbosity)'{-v+,--verbosity=}'[log verbosity level]:level:(trace debug info warn error)' \
  '*--host=[registry host config]:host:' \
  '--user-agent=[override user agent]:agent:' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'artifact:manage artifacts'
      'blob:manage blobs/layers'
      'completion:generate shell completions'
      'config:manage regctl configurations'
      'image:manage container images'
      'index:manage index/manifest lists'
      'manifest:manage manifests'
      'registry:manage registries'
      'repo:manage repositories'
      'tag:manage tags'
      'version:show version information'
    )
    _describe -t commands 'regctl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      image)
        local -a image_cmds=(
          'check-base:check if base image has been updated'
          'copy:copy images between registries'
          'create:create a new image manifest'
          'delete:delete an image'
          'digest:show image digest'
          'export:export image to tar file'
          'get-file:get a file from an image layer'
          'import:import image from tar file'
          'inspect:inspect image config'
          'manifest:show image manifest'
          'mod:modify an image'
          'ratelimit:show rate limit status'
        )
        _describe -t image-commands 'image command' image_cmds && ret=0
        ;;
      tag)
        local -a tag_cmds=(
          'delete:delete a tag'
          'ls:list tags in a repository'
        )
        _describe -t tag-commands 'tag command' tag_cmds && ret=0
        ;;
      manifest)
        local -a manifest_cmds=(
          'delete:delete a manifest'
          'diff:diff two manifests'
          'get:get a manifest'
          'head:head request for a manifest'
          'put:push a manifest'
        )
        _describe -t manifest-commands 'manifest command' manifest_cmds && ret=0
        ;;
      repo)
        local -a repo_cmds=(
          'copy:copy a repository'
          'ls:list repositories'
        )
        _describe -t repo-commands 'repo command' repo_cmds && ret=0
        ;;
      registry)
        local -a registry_cmds=(
          'config:show registry config'
          'login:login to a registry'
          'logout:logout from a registry'
          'set:set registry config'
          'whoami:show current authenticated user'
        )
        _describe -t registry-commands 'registry command' registry_cmds && ret=0
        ;;
      blob)
        local -a blob_cmds=(
          'copy:copy a blob between repositories'
          'delete:delete a blob'
          'diff-config:diff two config blobs'
          'diff-layer:diff two layer blobs'
          'get:get a blob'
          'get-file:get a file from a blob layer'
          'head:head request for a blob'
          'put:push a blob'
        )
        _describe -t blob-commands 'blob command' blob_cmds && ret=0
        ;;
      artifact)
        local -a artifact_cmds=(
          'get:get an artifact'
          'list:list artifacts'
          'put:push an artifact'
          'tree:show artifact reference tree'
        )
        _describe -t artifact-commands 'artifact command' artifact_cmds && ret=0
        ;;
      index)
        local -a index_cmds=(
          'add:add manifests to an index'
          'create:create a new index'
          'delete:delete manifests from an index'
        )
        _describe -t index-commands 'index command' index_cmds && ret=0
        ;;
      completion)
        _arguments \
          '1:shell:(bash fish powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
