#compdef usnobtofits
# Documentation: http://astrometry.net/doc/build-index.html
# convert the USNO-B1.0 catalog to healpixed FITS binary tables

local ret=1

_arguments -s \
  '-h[show help]' \
  '-o+[output filename template (eg usnob10_%03i.fits)]:output:_files' \
  '-N+[healpix nside (default 8)]:nside:' \
  '*:input file:_files' && ret=0

return ret
