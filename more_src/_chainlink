#compdef chainlink
# _chainlink — Smartcontractkit Chainlink decentralized oracle node CLI for job spec management bridges keys initiator triggers and EVM/non-EVM chain configurations (smartcontractkit team, Go); urfave/cli
# upstream: https://github.com/smartcontractkit/chainlink

_chainlink() {
    local -a sub=(
        'admin:admin operations'
        'attempts:tx attempt operations'
        'blocks:block operations'
        'bridges:bridge type operations'
        'config:print config'
        'jobs:job operations'
        'keys:key management'
        'local:local operations'
        'mailbox:mailbox operations'
        'node:node operations'
        'nodes:nodes operations'
        'help:show help'
        'txs:transaction operations'
        'ocr:OCR operations'
        'ocr2:OCR2 operations'
        'p2p:p2p operations'
        'cosmos:Cosmos operations'
        'solana:Solana operations'
        'starknet:Starknet operations'
        'aptos:Aptos operations'
        'forwarders:forwarder operations'
        'health:health check'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.toml"' \
        '--config=+[config file]:file:_files -g "*.toml"' \
        '-s+[secrets file]:file:_files -g "*.toml"' \
        '--secrets=+[secrets file]:file:_files -g "*.toml"' \
        '--json[json output]' \
        '-j[json output]' \
        '--debug[debug]' \
        '--remote-node-url=+[url]:str:' \
        '--insecure-skip-verify[skip TLS verify]' \
        '--admin-credentials-file=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'chainlink subcommand' sub ;;
        args)
            case $words[1] in
                node) _arguments \
                    '1:node action:(start status stop reboot db p2p import-key)' \
                    '-a+[api credentials]:file:_files' \
                    '-p+[password file]:file:_files' \
                    '--vrfpassword=+[file]:file:_files' ;;
                keys) _arguments \
                    '1:key action:(eth p2p ocr solana cosmos starknet aptos)' \
                    '*:key action args:' ;;
                jobs) _arguments \
                    '1:jobs action:(list show create delete run)' \
                    '*:job:' ;;
                bridges) _arguments \
                    '1:bridges action:(list show create destroy)' \
                    '*:name:' ;;
            esac
            ;;
    esac
}

_chainlink "$@"
