#compdef yubikey yubikey-manager
# _yubikey — Yubico YubiKey Manager GUI/CLI top-level alias (Yubico, Python); custom argparse
# upstream: https://github.com/Yubico/yubikey-manager

_yubikey() {
    local -a sub=(
        'info:show YubiKey info'
        'list:list connected YubiKeys'
        'mode:get/set USB modes (legacy)'
        'config:USB/NFC interface config'
        'fido:FIDO2/U2F commands'
        'oath:OATH (TOTP/HOTP) commands'
        'openpgp:OpenPGP commands'
        'otp:Yubico OTP commands'
        'piv:PIV (Personal Identity Verification) commands'
        'apdu:send raw APDUs'
        'script:run scripts'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--device=+[device serial]:str:' \
        '-d+[device serial]:str:' \
        '--reader=+[smartcard reader]:str:' \
        '-r+[smartcard reader]:str:' \
        '--log-level=+[log level]:level:(ERROR WARNING INFO DEBUG TRAFFIC)' \
        '-l+[log level]:level:(ERROR WARNING INFO DEBUG TRAFFIC)' \
        '--log-file=+[log file]:file:_files' \
        '--diagnose[run diagnostic info]' \
        '--full-help[show full help]' \
        '-f[show full help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ykman subcommand' sub ;;
        args)
            case $words[1] in
                fido) _arguments \
                    '1:cmd:(access info reset credentials fingerprints config)' \
                    '*:arg:' ;;
                oath) _arguments \
                    '1:cmd:(accounts code add delete list rename access info reset uri)' \
                    '*:arg:' ;;
                openpgp) _arguments \
                    '1:cmd:(info reset access keys certificates pin-policy)' \
                    '*:arg:' ;;
                otp) _arguments \
                    '1:cmd:(info swap chalresp hotp static yubiotp settings ndef delete)' \
                    '*:arg:' ;;
                piv) _arguments \
                    '1:cmd:(info reset access keys certificates objects)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(usb nfc set mode)' \
                    '*:arg:' ;;
                apdu) _arguments \
                    '--app=+[applet AID]:str:' \
                    '*:apdu-hex:' ;;
                script) _arguments \
                    '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_yubikey "$@"
