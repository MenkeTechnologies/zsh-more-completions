#compdef staq_mapper
# Documentation: https://github.com/softwareQinc/staq/wiki/The-staq-tool-suite
# staq tool: map OpenQASM circuit onto a physical device

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --device)'{-d,--device}'[target device file]:device file:_files' \
  '-l[layout algorithm (linear,eager,bestfit)]:layout:(linear eager bestfit)' \
  '-m[CX mapping algorithm (swap,steiner)]:mapping:(swap steiner)' && ret=0

return ret
