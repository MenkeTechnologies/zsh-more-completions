#compdef snowsql

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--versions[list available versions]' \
  {-U,--upgrade}'[force upgrade to latest version]' \
  {-a+,--accountname=}'[Snowflake account]:account:' \
  {-u+,--username=}'[username]:user:_users' \
  {-d+,--dbname=}'[default database]:db:' \
  {-s+,--schemaname=}'[default schema]:schema:' \
  {-r+,--rolename=}'[default role]:role:' \
  {-w+,--warehouse=}'[virtual warehouse]:warehouse:' \
  {-c+,--connection=}'[named connection]:name:' \
  '--config=[config file]:file:_files' \
  '*'{-D+,--variable=}'[define SnowSQL variable]:NAME=VALUE:' \
  '*'{-o+,--option=}'[override config option]:KEY=VALUE:' \
  '*'{-q+,--query=}'[SQL query]:query:' \
  {-f+,--filename=}'[SQL file]:file:_files -g "*.sql"' \
  '--query_tags=[query tags]:tags:' \
  '--single-transaction[wrap BEGIN/COMMIT around statements]' \
  {-P,--prompt}'[force interactive password]' \
  {-K,--client-session-keep-alive}'[keep session alive]' \
  '--abort-detached-query[abort query on connection drop]' \
  '--probe-connection[test connectivity]' \
  '--disable-request-pooling[disable connection pooling]' \
  {-m+,--mfa-passcode=}'[MFA second token]:token:' \
  {-M,--mfa-prompt}'[force interactive MFA prompt]' \
  '--authenticator=[auth method]:method:(snowflake externalbrowser oauth username_password_mfa snowflake_jwt)' \
  '--token=[OAuth token]:token:' \
  '--private-key-path=[private key file]:file:_files' && ret=0

return ret
