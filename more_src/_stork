#compdef stork

_stork_cmds() {
    local -a commands=(
        'build:build a search index'
        'search:search an index'
        'test:serve a test web page'
        'help:print help information'
    )
    _describe -t commands 'stork command' commands
}

_stork() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-V --version)'{-V,--version}'[print version]' \
        '1:command:_stork_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                build)
                    _arguments \
                        '--input=[input configuration file]:file:_files' \
                        '--output=[output index file]:file:_files' \
                        '--timing[display timing information]' \
                        '1:config-file:_files'
                    ;;
                search)
                    _arguments \
                        '--index=[path to index file]:file:_files' \
                        '--query=[search query]:query' \
                        '--json[output as JSON]' \
                        '1:index-file:_files' \
                        '2:query'
                    ;;
                test)
                    _arguments \
                        '--port=[port to listen on]:port' \
                        '1:index-file:_files'
                    ;;
            esac
            ;;
    esac
}

_stork "$@"
