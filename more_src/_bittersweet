#compdef bittersweet
# Documentation: https://github.com/0xmachos/dotfiles
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# 0xmachos/dotfiles bittersweet — macOS configuration helper.
# Subcommand list mirrors the BITTERSWEET_SUBCOMMANDS array in the upstream script.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'defaults:write system and application default settings'
  'dotfiles:symlink config files into $HOME'
  'scripts:symlink scripts in bin into /usr/local/bin'
  'sudotouch:enable TouchID for sudo'
  'secretive:install Secretive'
  'sublimetext:install Sublime Text'
  'tower:install Tower'
  'deckset:install Deckset'
  'maccy:install Maccy'
  'texpad:install Texpad (Texifier) and BasicTeX'
  'basictex:install MacTeX BasicTeX distribution'
  'latex:install LaTeX packages via tlmgr'
  'blockblock:install BlockBlock'
  'oversight:install OverSight'
  'dcg:install Destructive Command Guard'
  'dcg-sync:rotate dcg CDHash in Santa FAA policy'
  'danger-verify:build and install danger-verify helper'
  'herald:build and install herald (Bonjour/mDNS browser)'
  'vault-guard:build and install vault-guard daemon'
  'santa-faa:install Santa FAA policy'
  'claude:install Claude Code and dcg'
  'brew:install Homebrew'
  'brewfile:install Homebrew packages from Brewfile'
  'compinit:fix permissions on zsh completion directory'
  'mdmprofile:open System Preferences to install MDM profile'
  'launchagents:install and load LaunchAgents and LaunchDaemons'
  'completions:regenerate .completions/_bittersweet'
  'test:run test suite'
  'hailmary:run every function in order'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    _describe -t commands 'bittersweet command' commands && ret=0
    ;;
esac

return ret
