function sync_dcg_cdhash {
  # sync_dcg_cdhash
  #   Reads the installed dcg binary's CDHash and patches it into the
  #   Santa FAA policy plist, redeploying if changed. No-op if dcg is
  #   not installed or the plist is already in sync.
  #
  #   Why: dcg is Rust linker-signed ad-hoc — no TeamID, and its
  #   SigningID (dcg-<hex>) is derived from LC_UUID so it rotates per
  #   rebuild. The ClaudeCodeConfigResolved rule pins dcg by BinaryPath
  #   + CDHash, so the CDHash must be refreshed after every fresh
  #   install or `sudo dcg update --verify`.
  #
  #   Called from: install_dcg (end of fresh install / early-return
  #   path), bittersweet dcg-sync subcommand (run by jump and
  #   jump-system after `dcg update --verify`).

  local -r dcg_binary="/usr/local/bin/dcg"
  local -r plist="${SCRIPT_DIR}/profiles/santa-faa-policy.plist"
  local -r rule_path=":WatchItems:ClaudeCodeConfigResolved:Processes"

  if [[ ! -x "${dcg_binary}" ]]; then
    return 0
  fi

  if [[ ! -f "${plist}" ]]; then
    echo "[❌] santa-faa-policy.plist not found at ${plist}"
    return 1
  fi

  local current_cdhash
  current_cdhash="$(codesign -dvvv "${dcg_binary}" 2>&1 | awk -F= '/^CDHash=/{print $2; exit}')"
  if [[ -z "${current_cdhash}" ]]; then
    echo "[❌] Failed to extract CDHash from ${dcg_binary}"
    return 1
  fi

  # Walk the Processes array via PlistBuddy (read-only) to locate the dcg
  # entry and read its current CDHash. PlistBuddy's `Set` would re-serialise
  # the whole file (stripping XML comments and normalising indentation), so
  # the write path below uses `sed` instead.
  local i=0
  local binary_path
  local plist_cdhash=""
  local dcg_found=""
  while /usr/libexec/PlistBuddy -c "Print ${rule_path}:${i}" "${plist}" &>/dev/null; do
    binary_path="$(/usr/libexec/PlistBuddy -c "Print ${rule_path}:${i}:BinaryPath" "${plist}" 2>/dev/null || true)"
    if [[ "${binary_path}" == "${dcg_binary}" ]]; then
      dcg_found="1"
      plist_cdhash="$(/usr/libexec/PlistBuddy -c "Print ${rule_path}:${i}:CDHash" "${plist}" 2>/dev/null || true)"
      break
    fi
    (( i += 1 ))
  done

  if [[ -z "${dcg_found}" ]]; then
    echo "[❌] No Process entry with BinaryPath=${dcg_binary} in ${plist}"
    return 1
  fi

  if [[ "${plist_cdhash}" == "${current_cdhash}" ]]; then
    echo "[🍺] dcg CDHash already current in FAA policy"
    return 0
  fi

  echo "[🍺] Rotating dcg CDHash in FAA policy"
  echo "      Old: ${plist_cdhash:-<none>}"
  echo "      New: ${current_cdhash}"

  # Comment-preserving in-place edit: restrict the substitution to the
  # range from the BinaryPath string to the next </dict>, which bounds the
  # dcg entry. Within that range, replace the 40-hex CDHash value. The
  # BinaryPath line itself contains the path (not 40 hex) so the regex
  # skips it; only the CDHash <string> line matches.
  #   \|...|       — custom | delimiter for the address so path slashes
  #                  don't need escaping
  #   [a-f0-9]{40} — CDHash is SHA-256 truncated to 160 bits (40 hex)
  if ! sed -E -i '' "\\|<string>${dcg_binary}</string>|,/<\\/dict>/{
    s|(<string>)[a-f0-9]{40}(</string>)|\\1${current_cdhash}\\2|
  }" "${plist}"; then
    echo "[❌] Failed to update CDHash in ${plist}"
    return 1
  fi
  echo "[✅] Updated CDHash in ${plist}"

  install_santa_faa
}


function install_dcg {
  # install_dcg
  #   Installs Destructive Command Guard (dcg) via GitHub releases API
  #   https://github.com/Dicklesworthstone/destructive_command_guard
  #   Claude Code PreToolUse hook — blocks destructive Bash commands
  #   Not Apple codesigned; verified via SHA256 + Sigstore/cosign

  local -r dcg_binary="/usr/local/bin/dcg"

  if [[ -x "${dcg_binary}" ]]; then
    # Upgrades handled by: sudo dcg update --verify (run by jump/jump-system)
    echo "[🍺] dcg already installed"
    sync_dcg_cdhash
    return 0
  fi

  echo "[🍺] Installing dcg (Destructive Command Guard)"

  local api_response
  local tarball_url
  local tarball_name
  local tarball_path
  local sha_url
  local sha_path
  local sigstore_url
  local sigstore_path

  api_response="$(curl -s "https://api.github.com/repos/Dicklesworthstone/destructive_command_guard/releases/latest")"

  # Find the aarch64-apple-darwin tarball asset
  # plutil array indexing: walk assets to find the right filename
  local i=0
  local asset_name
  tarball_url=""
  while true; do
    asset_name="$(plutil -extract "assets.${i}.name" raw -o - -- - <<< "${api_response}" 2>/dev/null)" || break
    if [[ "${asset_name}" == "dcg-aarch64-apple-darwin.tar.xz" ]]; then
      tarball_url="$(plutil -extract "assets.${i}.browser_download_url" raw -o - -- - <<< "${api_response}")"
      break
    fi
    (( i += 1 ))
  done

  if [[ -z "${tarball_url}" ]]; then
    echo "[❌] Failed to find dcg-aarch64-apple-darwin.tar.xz in GitHub release"
    return 1
  fi

  tarball_name="$(basename "${tarball_url}")"
  tarball_path="${HOME}/Downloads/${tarball_name}"
  sha_url="${tarball_url}.sha256"
  sha_path="${tarball_path}.sha256"
  sigstore_url="${tarball_url}.sigstore.json"
  sigstore_path="${tarball_path}.sigstore.json"

  # Download tarball + SHA256 checksum
  download_application "${tarball_path}" "${tarball_url}"
  download_application "${sha_path}" "${sha_url}"

  # Verify SHA256
  echo "[🍺] Verifying SHA256 checksum"
  if ! (cd "${HOME}/Downloads" && shasum -a 256 -c "${sha_path}" >/dev/null); then
    echo "[❌] SHA256 verification failed for ${tarball_name}"
    rm -f "${tarball_path}" "${sha_path}"
    return 1
  fi
  echo "[✅] SHA256 checksum verified"

  # Verify Sigstore bundle if cosign is available
  if command -v cosign &>/dev/null; then
    download_application "${sigstore_path}" "${sigstore_url}"
    echo "[🍺] Verifying Sigstore bundle with cosign"
    if ! cosign verify-blob "${tarball_path}" --bundle "${sigstore_path}" --certificate-oidc-issuer="https://token.actions.githubusercontent.com" --certificate-identity-regexp="github.com/Dicklesworthstone/destructive_command_guard"; then
      echo "[❌] Sigstore verification failed for ${tarball_name}"
      rm -f "${tarball_path}" "${sha_path}" "${sigstore_path}"
      return 1
    fi
    echo "[✅] Sigstore verification passed"
    rm -f "${sigstore_path}"
  else
    echo "[⚠️ ] cosign not found — skipping Sigstore verification (SHA256 OK)"
  fi

  # Extract and install
  echo "[🍺] Extracting ${tarball_name}"
  if ! tar -xf "${tarball_path}" -C "${HOME}/Downloads"; then
    echo "[❌] Failed to extract ${tarball_name}"
    rm -f "${tarball_path}" "${sha_path}"
    return 1
  fi

  get_sudo "to install dcg to /usr/local/bin"
  if sudo install -m 755 "${HOME}/Downloads/dcg" "${dcg_binary}"; then
    echo "[✅] Successfully installed dcg to ${dcg_binary}"
  else
    echo "[❌] Failed to install dcg to ${dcg_binary}"
    rm -f "${HOME}/Downloads/dcg" "${tarball_path}" "${sha_path}"
    return 1
  fi

  # Cleanup
  rm -f "${HOME}/Downloads/dcg" "${tarball_path}" "${sha_path}"

  sync_dcg_cdhash
}


