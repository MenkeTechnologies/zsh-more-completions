function install_santa_faa {
  # install_santa_faa
  #   Installs Santa FAA policy plist to /Library/Santa/
  #   Root-owned so non-root processes cannot modify the policy itself
  #   Referenced by com.northpolesec.santa.vault.mobileconfig via FileAccessPolicyPlist

  local -r src="${SCRIPT_DIR}/profiles/santa-faa-policy.plist"
  local -r dest="/Library/Santa/faa-policy.plist"

  if ! [[ -f "${src}" ]]; then
    echo "[❌] santa-faa-policy.plist not found at ${src}"
    return 1
  fi

  get_sudo "to install Santa FAA policy to /Library/Santa"

  if ! sudo mkdir -m 755 -p /Library/Santa; then
    echo "[❌] Failed to create /Library/Santa/"
    return 1
  fi

  if sudo install -m 644 -o root -g wheel "${src}" "${dest}"; then
    echo "[✅] Successfully installed FAA policy to ${dest}"
  else
    echo "[❌] Failed to install FAA policy to ${dest}"
    return 1
  fi
}



function install_claude {
  # install_claude
  #   Installs Claude Code via the official native installer
  #   https://claude.ai/install.sh
  #   Downloads the installer to ~/Downloads, executes it, then cleans up
  #   Always calls install_dcg — DCG must be present when Claude Code is

  local -r claude_binary="${HOME}/.local/bin/claude"

  if [[ -x "${claude_binary}" ]]; then
    echo "[🍺] Claude Code already installed"
    install_dcg
    return 0
  fi

  echo "[🍺] Installing Claude Code"

  local -r installer_path="${HOME}/Downloads/claude-install.sh"
  local -r installer_url="https://claude.ai/install.sh"

  download_application "${installer_path}" "${installer_url}"

  echo "[🍺] Running Claude Code installer"
  if bash "${installer_path}"; then
    echo "[✅] Successfully installed Claude Code"
  else
    echo "[❌] Failed to install Claude Code"
    rm -f "${installer_path}"
    install_dcg
    return 1
  fi

  rm -f "${installer_path}"

  # DCG must always be installed alongside Claude Code
  install_dcg
}


