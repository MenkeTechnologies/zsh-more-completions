function _generate_zsh_sidebar_syntax {
  # _generate_zsh_sidebar_syntax OUTPUT_FILE
  #   Scans repo for extensionless zsh scripts and generates a .sublime-syntax
  #   that registers their filenames for Sublime Text sidebar icons.
  local output_file="${1}"
  local -a names=()
  local file basename first_line

  while IFS= read -r -d '' file; do
    basename="${file##*/}"
    [[ "${basename}" == ?*.* ]] && continue
    first_line="$(head -1 "${file}" 2>/dev/null)" || continue
    if [[ "${first_line}" == *'#!'*zsh* ]] || \
       [[ "${first_line}" == '#compdef '* ]] || \
       [[ "${first_line}" == '#autoload'* ]]; then
      names+=("${basename}")
    fi
  done < <(find "${SCRIPT_DIR}" -maxdepth 2 -type f -not -path '*/.git/*' -print0)

  cat > "${output_file}" <<'EOF'
%YAML 1.2
---
name: Zsh (Dotfiles)
scope: source.shell.zsh
version: 2
hidden: true
extends: Packages/ShellScript/Zsh.sublime-syntax

hidden_file_extensions:
EOF

  printf '%s\n' "${names[@]}" | sort -u | while IFS= read -r name; do
    printf '  - %s\n' "${name}" >> "${output_file}"
  done
}


function _generate_bittersweet_completion {
  # _generate_bittersweet_completion OUTPUT_FILE
  #   Writes a #compdef file for bittersweet sourced from
  #   BITTERSWEET_SUBCOMMANDS. Idempotent — safe to overwrite the existing
  #   .completions/_bittersweet on every call. Uses heredocs (quoted EOF) so
  #   every literal in the output passes through verbatim — no expansion, no
  #   linter noise about single-quoted backticks or trailing backslashes.
  local output_file="${1}"
  local entry

  cat > "${output_file}" <<'EOF'

# Auto-generated by `bittersweet completions` — do not edit by hand.
# Source of truth: BITTERSWEET_SUBCOMMANDS in `bittersweet`.
# Drift between this file and the dispatch case statement is caught
# by `./test completions` and the .githooks/pre-commit hook.

local -a subcommands
subcommands=(
EOF

  for entry in "${BITTERSWEET_SUBCOMMANDS[@]}"; do
    printf "  '%s'\n" "${entry}" >> "${output_file}"
  done

  cat >> "${output_file}" <<'EOF'
)

_arguments -C \
  '1:subcommand:->subcmd'

case "${state}" in
  subcmd)
    _describe 'subcommand' subcommands
    ;;
esac
EOF
}


function install_sublime_text {
