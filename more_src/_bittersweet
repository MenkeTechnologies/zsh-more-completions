### Dotfile Helpers ###
# Internal helpers for install_dotfiles. Print only on failure.
# Counters (_dir_count, _link_count, etc.) are declared in install_dotfiles.

function _ensure_dir {
  local dir=${1:?dir not passed to _ensure_dir}
  local mode=${2:-}

  if mkdir -p "${dir}"; then
    (( _dir_count += 1 ))
    [[ -n "${mode}" ]] && chmod "${mode}" "${dir}"
  else
    echo "[❌] Failed to create ${dir}"
    (( _error_count += 1 ))
  fi
}

function _symlink {
  local src=${1:?src not passed to _symlink}
  local dest=${2:?dest not passed to _symlink}

  if [[ ! -e "${src}" ]]; then
    echo "[❌] Source missing: ${src}"
    (( _error_count += 1 ))
    return 0
  fi

  # ln -sfn silently does the wrong thing when dest is a real directory:
  # it creates the symlink *inside* dest instead of replacing it (exit 0).
  if [[ -d "${dest}" && ! -L "${dest}" ]]; then
    echo "[❌] Cannot symlink ${dest##*/}: real directory exists (remove it first)"
    (( _error_count += 1 ))
    return 0
  fi

  if ln -sfn "${src}" "${dest}"; then
    (( _link_count += 1 ))
  else
    echo "[❌] Failed to link ${src} to ${dest}"
    (( _error_count += 1 ))
  fi
}

function _harden {
  local file=${1:?file not passed to _harden}

  if [[ ! -e "${file}" ]]; then
    echo "[❌] Cannot harden (missing): ${file##*/}"
    (( _error_count += 1 ))
    return 0
  fi

  local mode=600
  [[ -d "${file}" ]] && mode=700

  if chmod "${mode}" "${file}"; then
    (( _harden_count += 1 ))
  else
    echo "[❌] Failed to harden permissions on ${file##*/}"
    (( _error_count += 1 ))
  fi
}

