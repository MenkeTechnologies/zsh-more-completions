#!/usr/bin/env zsh
# dotfiles/bittersweet

# bittersweet
#   Configures macOS just the way I like it

set -euo pipefail
umask 077
# -e exit if any command returns non-zero status code
# -u prevent using undefined variables
# -o pipefail force pipelines to fail on first non-zero status code

IFS=$'\n\t'
# Set Internal Field Separator to newlines and tabs
# This makes bash consider newlines and tabs as separating words
# See: http://redsymbol.net/articles/unofficial-bash-strict-mode/

readonly SCRIPT_DIR="${0:A:h}"
# Absolute path to the directory containing this script
# $0  - path used to invoke the script (e.g. /usr/local/bin/bittersweet)
# :A  - resolve symlinks to the real absolute path
# :h  - take the head (parent directory), stripping the filename
# This ensures paths resolve correctly regardless of $PWD

if [[ ! -f "${SCRIPT_DIR}/bittersweet" ]]; then
  echo "[❌] SCRIPT_DIR failed to resolve (got: ${SCRIPT_DIR})"
  echo "    zsh :A cannot follow symlinks with restricted permissions."
  echo "    Run directly from the repo: ~/Documents/Projects/dotfiles/bittersweet"
  exit 1
fi

### Define Colours ###

/usr/bin/tput sgr0;
# reset colors
RESET=$(/usr/bin/tput sgr0);
readonly RESET
BOLD=$(/usr/bin/tput bold);
readonly BOLD
RED=$(/usr/bin/tput setaf 1);
readonly RED

### END Colours ###


### Subcommand Source of Truth ###
# Ordered list of (subcommand:description) pairs in `_describe` format.
# Single source of truth, consumed by:
#   - usage()                          (help text)
#   - _generate_bittersweet_completion (writes .completions/_bittersweet)
#   - tests/completions                (parity check vs dispatch case arms)
# Order is preserved in usage() output and zsh completion suggestions.
# When adding a new subcommand: add an entry here AND a matching dispatch
# arm at the bottom of main(). tests/completions enforces both sides match.
#
# shellcheck disable=SC2016
# Description text contains literal `$HOME` — documentation, not a variable
# reference. Disabling SC2016 array-wide; descriptions are user-facing strings.
typeset -ra BITTERSWEET_SUBCOMMANDS=(
  'defaults:Write new system and application default settings'
  'dotfiles:Symlink various config files into $HOME'
  'scripts:Symlink scripts in bin into /usr/local/bin'
  'sudotouch:Enable TouchID to sudo'
  'secretive:Install Secretive'
  'sublimetext:Install Sublime Text'
  'tower:Install Tower'
  'deckset:Install Deckset'
  'maccy:Install Maccy'
  'texpad:Install Texpad (Texifier) and BasicTeX'
  'basictex:Install MacTeX BasicTeX Distribution'
  'latex:Install LaTeX packages via tlmgr'
  'blockblock:Install BlockBlock'
  'oversight:Install OverSight'
  'dcg:Install Destructive Command Guard (dcg)'
  'dcg-sync:Rotate dcg CDHash in Santa FAA policy after dcg upgrade'
  'danger-verify:Build and install danger-verify Swift helper'
  'herald:Build and install herald (Bonjour/mDNS browser for Matter/Thread debugging)'
  'vault-guard:Build and install vault-guard DA mount approval daemon'
  'santa-faa:Install Santa FAA policy for dotfiles protection'
  'claude:Install Claude Code and dcg'
  'brew:Install Homebrew'
  'brewfile:Install Homebrew packages from Brewfile'
  'compinit:Fix permissions on zsh completion directory'
  'mdmprofile:Open System Preferences to install MDM Profile'
  'launchagents:Install and load LaunchAgents and LaunchDaemon'
  'completions:Regenerate .completions/_bittersweet from BITTERSWEET_SUBCOMMANDS'
  'test:Run test suite'
  'hailmary:Run every function in order'
)
### END Subcommand SOT ###


function usage {

  echo -e "\\nConfigures macOS just the way I like it 🤓\\n"
  echo "Usage:"

  local entry name desc
  for entry in "${BITTERSWEET_SUBCOMMANDS[@]}"; do
    name="${entry%%:*}"
    desc="${entry#*:}"
    if [[ "${name}" == "hailmary" ]]; then
      echo -e "\\n  ${RED}${name}${RESET}              - ${BOLD}${desc}${RESET}"
    else
      printf '  %-22s- %s\n' "${name}" "${desc}"
    fi
  done

  exit 0
}


