      echo "[✅] Successfully installed Sublime Text"
    else
      echo "[❌] Failed to install Sublime Text"
      return 1
    fi
  fi

  # Detect live config directory (ST4 upgrades reuse ST3 dir name)
  local live_st_dir=""
  local candidate
  for candidate in "Sublime Text 3" "Sublime Text"; do
    if [[ -d "${HOME}/Library/Application Support/${candidate}" ]]; then
      live_st_dir="${HOME}/Library/Application Support/${candidate}"
      break
    fi
  done
  # Fresh install: ST4 creates "Sublime Text/" on first launch
  [[ -z "${live_st_dir}" ]] && live_st_dir="${HOME}/Library/Application Support/Sublime Text"

  local _dir_count=0
  local _link_count=0
  local _error_count=0

  _ensure_dir "${live_st_dir}/Packages/User"

  echo "[🍺] Symlinking Sublime Text settings"
  local settings_file filename
  for settings_file in "${SCRIPT_DIR}/Sublime Text/Packages/User"/*.sublime-settings; do
