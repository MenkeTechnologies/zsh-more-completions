function install_dotfiles {
  # install_dotfiles
  #   Create directories in $HOME
  #   Symlink config files from repo into $HOME
  #   Config files for: zsh, git, ssh, Claude Code, VirusTotal, Ghostty, Xcode

  local _dir_count=0
  local _link_count=0
  local _harden_count=0
  local _error_count=0

  local -ar dot_dirs=(.ssh .extra .config/git .config/uv .config/dcg .claude .claude/skills .claude/rules)
  local -ar dot_files=(.zshrc .functions .completions .aliases)
  local -ar ssh_configs=(config .extra_ssh)
  local -ar git_configs=(config ignore allowed_signers)
  local -ar claude_files=(
    "claude/settings.json:settings.json"
    "claude/statusline-command:statusline-command"
    "claude/global-claude.md:CLAUDE.md"
    "claude/lint-hook:lint-hook"
  )
  local -ar sensitive_files=(
    "${SCRIPT_DIR}/.ssh/config"
    "${SCRIPT_DIR}/.ssh/.extra_ssh"
    "${SCRIPT_DIR}/.config/git/config"
    "${SCRIPT_DIR}/.config/git/ignore"
    "${SCRIPT_DIR}/.config/git/allowed_signers"
    "${SCRIPT_DIR}/.functions"
    "${SCRIPT_DIR}/.completions"
    "${SCRIPT_DIR}/.zshrc"
    "${SCRIPT_DIR}/.aliases"
    "${SCRIPT_DIR}/claude/settings.json"
    "${SCRIPT_DIR}/.config/1Password/ssh/agent.toml"
  )

  local dot_dir dot_file ssh_config git_config claude_file sensitive_file
  local src dest

  # Create required directories
  for dot_dir in "${dot_dirs[@]}"; do
    _ensure_dir "${HOME}/${dot_dir}"
  done

  _ensure_dir "${HOME}/.ssh/sockets" 700

  # Symlink general dotfiles into $HOME
  for dot_file in "${dot_files[@]}"; do
    _symlink "${SCRIPT_DIR}/${dot_file}" "${HOME}/${dot_file}"
  done

  # Symlink SSH configs into $HOME/.ssh/
  for ssh_config in "${ssh_configs[@]}"; do
    _symlink "${SCRIPT_DIR}/.ssh/${ssh_config}" "${HOME}/.ssh/${ssh_config}"
  done

  # Symlink git configs into $HOME/.config/git/
  for git_config in "${git_configs[@]}"; do
    _symlink "${SCRIPT_DIR}/.config/git/${git_config}" "${HOME}/.config/git/${git_config}"
  done

  # Symlink uv config into $HOME/.config/uv/
  _symlink "${SCRIPT_DIR}/.config/uv/uv.toml" "${HOME}/.config/uv/uv.toml"

  # Symlink npm config into $HOME/.npmrc (npm hardcodes ~/.npmrc)
  _symlink "${SCRIPT_DIR}/.config/npm/.npmrc" "${HOME}/.npmrc"

  # Symlink dcg config into $HOME/.config/dcg/
  _symlink "${SCRIPT_DIR}/.config/dcg/config.toml" "${HOME}/.config/dcg/config.toml"

  # Copy 1Password SSH agent config (1Password doesn't follow symlinks)
  _ensure_dir "${HOME}/.config/1Password/ssh"
  cp "${SCRIPT_DIR}/.config/1Password/ssh/agent.toml" "${HOME}/.config/1Password/ssh/agent.toml"
  chmod 600 "${HOME}/.config/1Password/ssh/agent.toml"

  # Symlink Claude Code configs into $HOME/.claude/
  for claude_file in "${claude_files[@]}"; do
    src="${claude_file%%:*}"
    dest="${claude_file##*:}"
    _symlink "${SCRIPT_DIR}/${src}" "${HOME}/.claude/${dest}"
  done

  # Symlink custom skills into $HOME/.claude/skills/
  local skill_dir skill_name
  for skill_dir in "${SCRIPT_DIR}"/claude/skills/*/; do
    skill_name="${skill_dir%/}"
    skill_name="${skill_name##*/}"
    _symlink "${skill_dir%/}" "${HOME}/.claude/skills/${skill_name}"
  done

  # Symlink Claude Code rules into $HOME/.claude/rules/
  local rule_file rule_name
  for rule_file in "${SCRIPT_DIR}"/claude/rules/*.md; do
    [[ -f "${rule_file}" ]] || continue
    rule_name="${rule_file##*/}"
    _symlink "${rule_file}" "${HOME}/.claude/rules/${rule_name}"
  done

  # Symlink API wrapper scripts into ~/.local/bin/ (ahead of /opt/homebrew/bin
  # on PATH, so wrappers shadow Homebrew binaries and inject 1Password keys)
  _ensure_dir "${HOME}/.local/bin"
  local -ar op_wrapper_scripts=(vt urlscan)
  local wrapper
  for wrapper in "${op_wrapper_scripts[@]}"; do
    _symlink "${SCRIPT_DIR}/bin/${wrapper}" "${HOME}/.local/bin/${wrapper}"
  done

  # Symlink Ghostty config into macOS Application Support location
  _ensure_dir "${HOME}/Library/Application Support/com.mitchellh.ghostty"
  _symlink "${SCRIPT_DIR}/config" "${HOME}/Library/Application Support/com.mitchellh.ghostty/config"

  # Symlink Xcode file header template into per-user global location
  _ensure_dir "${HOME}/Library/Developer/Xcode/UserData"
  _symlink "${SCRIPT_DIR}/IDETemplateMacros.plist" "${HOME}/Library/Developer/Xcode/UserData/IDETemplateMacros.plist"

  # Enable pre-commit secret scanning via gitleaks
  if git -C "${SCRIPT_DIR}" config --local core.hooksPath .githooks; then
    echo "[✅] Enabled .githooks/pre-commit (gitleaks secret scanning)"
  else
    echo "[❌] Failed to set core.hooksPath"
    (( _error_count += 1 ))
  fi

  # Harden file permissions
  # git clone sets 644 by default; enforce 600 on sensitive files
  # chmod follows symlinks so this works on both the source and linked paths
  for sensitive_file in "${sensitive_files[@]}"; do
    _harden "${sensitive_file}"
  done

  echo "[✅] Dotfiles installed (${_link_count} symlinks, ${_dir_count} dirs, ${_harden_count} hardened)"
  if (( _error_count > 0 )); then
    echo "[⚠️] ${_error_count} operations failed (see above)"
  fi
}


function install_scripts {
  # install_scripts
  #   Symlink dotfiles/bin/ scripts into /usr/local/bin
  #   Create /usr/local/bin
  #   Symlink files in /usr/local/bin
  
  local -ar bin_files=(dns jump-user danger mdview npm-audit-check claude-session-audit)
  local -ar macos_script_bin_files=(c0design)
  
  # Create /usr/local/bin
  if ! [[ -d "/usr/local/bin/" ]]; then 
    get_sudo "to create /usr/local/bin/"
    if sudo mkdir -m 755 -p "/usr/local/bin/"; then
      echo "[✅] Successfully created /usr/local/bin/"
    else
      echo "[❌] Failed to create /usr/local/bin/"
    fi
  fi

  get_sudo "to symlink scripts into /usr/local/bin/"
  
  # Symlink files
  # chmod -h fixes symlink mode after ln: umask 077 produces lrwx------ which
  # blocks readlink(2) for non-root (XNU checks KAUTH_VNODE_READ_DATA on
  # symlinks despite symlink(7) saying permissions are ignored)
  for bin_file in "${bin_files[@]}"; do
    if sudo ln -sfn "${SCRIPT_DIR}/bin/${bin_file}" "/usr/local/bin/${bin_file}"; then
      sudo chmod -h 755 "/usr/local/bin/${bin_file}"
      echo "[✅] Successfully linked ${bin_file} to /usr/local/bin/${bin_file}"
    else
      echo "[❌] Failed to link ${bin_file} to /usr/local/bin/${bin_file}"
    fi
  done

  # Copy jump-system as root-owned (executed by LaunchDaemon, must not be
  # user-writable — symlink would be a local privilege escalation)
  sudo rm -f "/usr/local/bin/jump-system"
  if sudo cp "${SCRIPT_DIR}/bin/jump-system" "/usr/local/bin/jump-system"; then
    sudo chown root:wheel "/usr/local/bin/jump-system"
    sudo chmod 700 "/usr/local/bin/jump-system"
    echo "[✅] Successfully installed jump-system to /usr/local/bin/jump-system (root:wheel 700)"
  else
    echo "[❌] Failed to install jump-system to /usr/local/bin/jump-system"
  fi

  # Symlink bittersweet into /usr/local/bin
  if sudo ln -sfn "${SCRIPT_DIR}/bittersweet" "/usr/local/bin"; then
    sudo chmod -h 755 "/usr/local/bin/bittersweet"
    echo "[✅] Successfully linked bittersweet to /usr/local/bin/bittersweet"
  else
    echo "[❌] Failed to link bittersweet to /usr/local/bin/bittersweet"
  fi

  # Symlink some files in macos-scripts repo into /usr/local/bin
  for macos_script in "${macos_script_bin_files[@]}"; do
    if sudo ln -sfn "$HOME/Documents/Projects/macos-scripts/${macos_script}" "/usr/local/bin/${macos_script}"; then
      sudo chmod -h 755 "/usr/local/bin/${macos_script}"
      echo "[✅] Successfully linked ${macos_script} to /usr/local/bin/${macos_script}"
    else
      echo "[❌] Failed to link ${macos_script} to /usr/local/bin/${macos_script}"
    fi
  done
}


function enable_touchid_sudo {
  # enable_touchid_sudo
  #   As of macOS Sonoma (14.0) this setting can persist OS updates when set in  
  #     /etc/pam.d/sudo_local. See: https://support.apple.com/en-us/HT213893
  #   Check if already enabled in /etc/pam.d/sudo and warn user
  #   Check if /etc/pam.d/sudo_local exists, if not create it
  #   Use vim to insert required text to enable TouchID for sudo into sudo_local
  
  if grep -q 'pam_tid.so' "/etc/pam.d/sudo"; then
    logger -p user.warning -s "Enabling TouchID for sudo in /etc/pam.d/sudo does not persist across updates.\
                              See https://support.apple.com/en-us/HT213893"
  fi

  if [[ -e "/etc/pam.d/sudo_local" ]]; then
    if grep -q 'pam_tid.so' "/etc/pam.d/sudo_local"; then
      logger -p user.info -s "TouchID for sudo already enabled"
      return 0
    fi
  
  else

    get_sudo "to create /etc/pam.d/sudo_local"
    
    if sudo install -m "444" -g "wheel" -o "root" "/dev/null" "/etc/pam.d/sudo_local"; then
      # Use install to create the file /etc/pam.d/sudo_local
      # Copies from /dev/null which creates an empty file
      # Set permissions to read only, group to wheel and owner to root 
      logger -p user.info -s "Created /etc/pam.d/sudo_local"
    else
      logger -p user.error -s "Failed to create /etc/pam.d/sudo_local"
      return 1
    fi

    if sudo ex -s -c '1i|auth       sufficient     pam_tid.so' -c x! -c x! "/etc/pam.d/sudo_local"; then
      # Invoke Vim in ex mode
      # Select line 1, enter insert mode, insert that text write changes and exit
      # Need to exit twice to get passed the read only file warning

      logger -p user.info -s "TouchID sudo Enabled"
      return 0
    else
      logger -p user.error -s "Failed to enable TouchID sudo"
      return 1
  fi
fi
}


