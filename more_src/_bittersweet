function zsh_compinit_fix {
  # zsh_compinit_fix
  #   Secure permissions on zsh completion files at /opt/homebrew/share
  #   https://stackoverflow.com/a/43544733
  #   https://docs.brew.sh/Shell-Completion#configuring-completions-in-zsh
  #   Remove group/other write/execite permissions
  #   Change ownership to $USER:staff

  local -r completions_dir="$(brew --prefix)/share"
  
  echo "[🍺] Fixing zsh completions permissions"

  if ! chmod -R go-wx "${completions_dir}"; then
    echo "[❌] Failed to remove r/x for group & others on /usr/local/share/zsh"
    return 1
  fi
  
  if ! chown -R "${USER}:staff" "${completions_dir}"; then
    echo "[❌] Failed to change owners of ${completions_dir} to ${USER}:staff"
    return 1
  fi

  echo "[✅] Fixed zsh completions permissions"
}


function open_system_preferences_mdm_profile {
  # open_system_preferences_mdm_profile
  # As of macOS Big Sur (11) /usr/bin/profiles can no longer install .mobileconfig profiles
  # MDM Profiles must be installed via the GUI via System Preferences > Profiles
  # However we can semi automate this process
  #   See: https://www.alansiu.net/2021/01/06/semi-automating-profile-installation-in-big-sur/

  for profile in "${SCRIPT_DIR}"/profiles/*.mobileconfig; do
    if ! open "/System/Library/PreferencePanes/Profiles.prefPane" "${profile:?}"; then
      echo "[❌] Failed to open System Preferences > Profiles with ${profile:?}"
      return 1
    fi

    profile_name=$(basename "${profile}")
    echo "[⚠️ ] Go to System Preferences > Profiles and install ${profile_name}"
  done

}


function install_launchagents {
  # install_launchagents
  #   Copy LaunchAgent plists to ~/Library/LaunchAgents/
  #   Copy LaunchDaemon plist to /Library/LaunchDaemons/ (must be owned by root:wheel 644)
  #
  #   Plists are copied, not symlinked. Since macOS Sonoma 14.0, launchd's
  #   automatic login scan of ~/Library/LaunchAgents/ does not follow symlinks.
  #   Symlinked plists are silently skipped — RunAtLoad never fires.
  #   Explicit `launchctl bootstrap` still follows symlinks, but doesn't
  #   survive reboot. Copying is the only reliable approach.

  local -ar launchagent_plists=(
    com.0xmachos.jump-user
    com.0xmachos.vault-guard
    com.0xmachos.imageio-oop
  )

  # LaunchAgents: copy into ~/Library/LaunchAgents/
  if mkdir -p "${HOME}/Library/LaunchAgents"; then
    for plist in "${launchagent_plists[@]}"; do
      if cp "${SCRIPT_DIR}/LaunchAgents/${plist}.plist" "${HOME}/Library/LaunchAgents/${plist}.plist"; then
        chmod 644 "${HOME}/Library/LaunchAgents/${plist}.plist"
        echo "[✅] Successfully installed ${plist}.plist to ~/Library/LaunchAgents/"
      else
        echo "[❌] Failed to install ${plist}.plist"
      fi
    done
  else
    echo "[❌] Failed to create ~/Library/LaunchAgents/"
  fi

  # LaunchDaemon: copy to /Library/LaunchDaemons/ with root:wheel 644
  get_sudo "to install LaunchDaemon"

  if sudo cp "${SCRIPT_DIR}/LaunchDaemons/com.0xmachos.jump-system.plist" "/Library/LaunchDaemons/com.0xmachos.jump-system.plist"; then
    sudo chown root:wheel "/Library/LaunchDaemons/com.0xmachos.jump-system.plist"
    sudo chmod 644 "/Library/LaunchDaemons/com.0xmachos.jump-system.plist"
    echo "[✅] Successfully installed com.0xmachos.jump-system.plist to /Library/LaunchDaemons/"
  else
    echo "[❌] Failed to install com.0xmachos.jump-system.plist"
  fi
}


function load_launchagents {
  # load_launchagents
  #   Load LaunchAgents and LaunchDaemon via launchctl bootstrap/bootout

  local -r uid=$(id -u)

  local -ar launchagent_plists=(
    com.0xmachos.jump-user
    com.0xmachos.vault-guard
    com.0xmachos.imageio-oop
  )

  for plist in "${launchagent_plists[@]}"; do
    launchctl bootout "gui/${uid}/${plist}" 2>/dev/null || true
    if launchctl bootstrap "gui/${uid}" "${HOME}/Library/LaunchAgents/${plist}.plist"; then
      echo "[✅] Successfully loaded ${plist} LaunchAgent"
    else
      echo "[❌] Failed to load ${plist} LaunchAgent"
    fi
  done

  # Verify imageio-oop env var took effect
  if [[ "$(launchctl getenv IIOEnableOOP)" != "1" ]]; then
    echo "[❌] com.0xmachos.imageio-oop loaded but IIOEnableOOP not set in launchd"
  fi

  # LaunchDaemon
  get_sudo "to load LaunchDaemon"

  sudo launchctl bootout "system/com.0xmachos.jump-system" 2>/dev/null || true
  if sudo launchctl bootstrap "system" "/Library/LaunchDaemons/com.0xmachos.jump-system.plist"; then
    echo "[✅] Successfully loaded com.0xmachos.jump-system LaunchDaemon"
  else
    echo "[❌] Failed to load com.0xmachos.jump-system LaunchDaemon"
  fi
}


