#compdef magick

# Zsh completion for ImageMagick 7 (magick - unified CLI)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'convert:convert between image formats'
  'identify:describe the format and characteristics of image files'
  'mogrify:resize an image, blur, crop, despeckle, etc.'
  'composite:overlap one image over another'
  'montage:create a composite image by combining images'
  'compare:compare two images'
  'display:display an image on any X server'
  'animate:animate an image sequence on any X server'
  'import:capture an X server screen'
  'conjure:interpret and execute scripts in MSL'
  'stream:stream one or more pixel components of an image'
)

