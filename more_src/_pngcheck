#compdef pngcheck
# Documentation: https://manpages.debian.org/testing/pngcheck/pngcheck.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '-7[print contents of tEXt chunks, escape chars >=128 (for 7-bit terminals)]' \
  '-c[colorize output (ANSI terminals)]' \
  '-f[force continuation after error]' \
  '(- *)-h[show help]' \
  '-p[print contents of PLTE, tRNS, hIST, sPLT and PPLT (use with -q)]' \
  '-q[test quietly (output only errors)]' \
  '-s[search for PNGs within another file]' \
  '-t[print contents of tEXt chunks (use with -q)]' \
  '-v[test verbosely (print most chunk data)]' \
  '-vv[test very verbosely (decode and print line filters)]' \
  '-w[suppress windowBits test]' \
  '-x[search for PNGs within another file and extract them]' \
  '*:png:_files -g "*.png"'
