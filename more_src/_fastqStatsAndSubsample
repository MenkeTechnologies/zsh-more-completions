#compdef fastqStatsAndSubsample
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# sanity check, collect stats, and subsample a fastq file

local ret=1

_arguments -s -S \
  '-sampleSize=[number of reads to sample (default 100000)]:n' \
  '-seed=[seed for random number generator (default 0)]:n' \
  '-smallOk[allow operation when fewer than sampleSize reads exist]' \
  '-json[output statistics in JSON format]' \
  '1:in fastq:_files -g "*.(fastq|fq)"' \
  '2:out stats:_files' \
  '3:out fastq:_files' && ret=0

return ret
