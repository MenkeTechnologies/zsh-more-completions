#compdef newtmgr
# _newtmgr — Apache Mynewt newtmgr CLI device management protocol client communicating with Mynewt RTOS embedded firmware over BLE GATT serial UART CoAP transports image OTA upload list test confirm config show set log stat fs reset (Apache Mynewt team, Go); cobra
# upstream: https://github.com/apache/mynewt-newtmgr

_newtmgr() {
    local -a sub=(
        'config:read or write a config value on a device'
        'conn:manage connection profiles'
        'crash:send crash command to device'
        'datetime:set or get datetime'
        'echo:send echo command'
        'fs:access device files'
        'help:show help'
        'image:manage images on a device'
        'log:manage logs on a device'
        'mpstat:read memory pool statistics'
        'reset:perform soft reset'
        'run:run tests on a device'
        'stat:read statistics'
        'taskstat:read task statistics'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-c+[conn profile]:str:' \
        '--conn=+[conn profile]:str:' \
        '-l+[loglevel]:l:(panic fatal error warn info debug)' \
        '--loglevel=+[loglevel]:l:(panic fatal error warn info debug)' \
        '-t+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-r+[max retries]:n:' \
        '--tries=+[tries]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'newtmgr subcommand' sub ;;
        args)
            case $words[1] in
                conn) _arguments \
                    '1:op:(add show delete edit)' \
                    '*:name:' ;;
                image) _arguments \
                    '1:op:(confirm erase list test upload coreconvert corelist coreload erase_unused)' \
                    '*:file:_files -g "*.img *.bin"' ;;
                fs) _arguments \
                    '1:op:(upload download)' \
                    '*:path:_files' ;;
                config) _arguments \
                    '*:name=value:' ;;
            esac
            ;;
    esac
}

_newtmgr "$@"
