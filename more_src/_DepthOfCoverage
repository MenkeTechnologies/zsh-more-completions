#compdef DepthOfCoverage
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/coverage/DepthOfCoverage.java
# GATK4: assess sequence coverage by a wide array of metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-I --input)'{-I,--input}'[input BAM/CRAM file]:file:_files -g "*.(bam|cram|sam)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to operate on]:intervals:_files' \
  '(-O --output)'{-O,--output}'[base file location for coverage summary]:file:_files' \
  '--output-format[format of the output file]:format:(CSV TABLE)' \
  '--omit-depth-output-at-each-base[do not output depth at each base]' \
  '*--summary-coverage-threshold[coverage threshold for summarizing statistics]:n:' \
  '(-gene-list --calculate-coverage-over-genes)'{-gene-list,--calculate-coverage-over-genes}'[calculate coverage over this gene list]:file:_files' \
  '*:options:_files' && ret=0

return ret
