#compdef gitmoji-cli gitmoji

_arguments -s \
  '(-i --init)'{-i,--init}'[install commit-msg hook]' \
  '(-r --remove)'{-r,--remove}'[remove commit-msg hook]' \
  '(-g --config)'{-g,--config}'[set preferences]' \
  '(-c --commit)'{-c,--commit}'[interactive commit prompt]' \
  '(-l --list)'{-l,--list}'[list available gitmojis]' \
  '(-s --search)'{-s,--search=}'[search gitmojis]:query:' \
  '(-u --update)'{-u,--update}'[sync gitmoji list]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)--help[show help]' \
  '--title=[commit title]:title:' \
  '--message=[commit message]:msg:' \
  '--scope=[commit scope]:scope:'
