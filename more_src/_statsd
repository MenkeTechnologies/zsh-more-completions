#compdef statsd
# _statsd — Etsy/StatsD network daemon entrypoint (StatsD project, Node.js); reads JSON config
# upstream: https://github.com/statsd/statsd

_statsd() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '*:config-file:_files -g "*.(js|json)"'
}

_statsd "$@"
