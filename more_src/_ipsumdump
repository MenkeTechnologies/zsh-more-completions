#compdef ipsumdump
# _ipsumdump — Eddie Kohler ipsumdump CLI for summarising live or pcap-recorded IP traffic emitting per-packet timestamp address port flag and length fields with anonymising and aggregation modes (kohler team, C++); getopt
# upstream: https://github.com/kohler/ipsumdump

_ipsumdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[interface]:str:' \
        '--interface=+[interface]:str:' \
        '-r+[pcap input]:file:_files -g "*.pcap *.cap *.pcapng"' \
        '--tcpdump-input=+[pcap input]:file:_files -g "*.pcap *.cap *.pcapng"' \
        '--ipsumdump-input=+[file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-f+[BPF filter]:str:' \
        '--filter=+[BPF filter]:str:' \
        '-c+[count limit]:n:' \
        '--limit-packets=+[count limit]:n:' \
        '-t[print timestamps]' \
        '--timestamp[print timestamps]' \
        '-T[print timestamps]' \
        '--first-timestamp[first timestamp]' \
        '-s[print source IP]' \
        '--src[print src IP]' \
        '-d[print dest IP]' \
        '--dst[print dst IP]' \
        '-S[print source port]' \
        '--sport[print src port]' \
        '-D[print dest port]' \
        '--dport[print dst port]' \
        '-l[print length]' \
        '--length[print length]' \
        '-p[print protocol]' \
        '--protocol[print protocol]' \
        '-F[print TCP flags]' \
        '--tcp-flags[print TCP flags]' \
        '-Q[print TCP seq/ack]' \
        '--tcp-seq[print TCP seq]' \
        '--tcp-ack[print TCP ack]' \
        '-w+[write tcpdump]:file:_files -g "*.pcap"' \
        '--write-tcpdump=+[file]:file:_files -g "*.pcap"' \
        '--anonymize[anonymize]' \
        '--no-payload[no payload]' \
        '--multipacket[multipacket]' \
        '--collate[collate]' \
        '*:input file:_files -g "*.pcap *.cap *.pcapng"'
}

_ipsumdump "$@"
