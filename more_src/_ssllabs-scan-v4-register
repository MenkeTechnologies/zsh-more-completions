#compdef ssllabs-scan-v4-register
# Documentation: https://man.archlinux.org/search?q=ssllabs-scan-v4-register
# Reference accessed: 2026-05-16

_arguments -s \
  '--firstName=[first name]:name:' \
  '--lastName=[last name]:name:' \
  '--organization=[organization]:org:' \
  '--email=[email address]:email:' \
  '--registerApiUrl=[registration endpoint]:url:' \
  '(- *)--help[show help]'
