#compdef sensuctl
# Documentation: https://man.archlinux.org/search?q=sensuctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'agent:agent commands'
  'api-key:manage API keys'
  'asset:manage assets'
  'check:manage checks'
  'cluster:manage cluster members'
  'cluster-role:manage cluster roles'
  'cluster-role-binding:manage cluster role bindings'
  'command:manage commands'
  'completion:generate shell completion'
  'config:view CLI config'
  'configure:configure CLI'
  'create:create resources from file'
  'delete:delete resources from file'
  'dump:dump resources'
  'edit:edit resource'
  'entity:manage entities'
  'env:print env settings'
  'event:manage events'
  'filter:manage filters'
  'handler:manage handlers'
  'hook:manage hooks'
  'license:manage license'
  'login:log in'
  'logout:log out'
  'mutator:manage mutators'
  'namespace:manage namespaces'
  'pipeline:manage pipelines'
  'prune:prune stale resources'
  'role:manage roles'
  'role-binding:manage role bindings'
  'secret:manage secrets'
  'silenced:manage silenced entries'
  'tessen:manage tessen'
  'user:manage users'
  'version:print version'
)

_arguments -C \
  '--api-url=[API URL]:url:' \
  '--api-key=[API key]:key:' \
  '--cache-dir=[cache dir]:dir:_files -/' \
  '--config-dir=[config dir]:dir:_files -/' \
  '--insecure-skip-tls-verify[skip TLS verify]' \
  '--namespace=[namespace]:ns:' \
  '--timeout=[request timeout]:duration:' \
  '--trusted-ca-file=[trusted CA file]:file:_files' \
  '--format=[output format]:fmt:(tabular json wrapped-json yaml)' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sensuctl subcommand' subcommands && ret=0
    ;;
esac

return ret
