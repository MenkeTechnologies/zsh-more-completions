#compdef memcached-debug
# Documentation: https://manpages.debian.org/testing/memcached/memcached.1.en.html
# Reference accessed: 2026-05-19
# Verified: memcached-debug is a debug build of memcached and shares the
# memcached(1) flag set. Flags below mirror that man page.

# memcached-debug: debug build of memcached
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-p[TCP port]:port:' \
  '-U[UDP port]:port:' \
  '-s[unix socket]:file:_files' \
  '-a[socket access mask]:octal:' \
  '-l[listen address]:host:_hosts' \
  '-d[daemonize]' \
  '-r[max core size]' \
  '-u[run as user]:user:_users' \
  '-m[max memory MB]:mb:' \
  '-M[error on memory exhaustion]' \
  '-c[max conns]:n:' \
  '-k[lock memory pages]' \
  '-v[verbose]' \
  '-vv[very verbose]' \
  '-vvv[extremely verbose]' \
  '-i[show licence]' \
  '-P[PID file]:file:_files' \
  '-f[chunk size growth factor]:factor:' \
  '-n[min space for key+value+flags]:bytes:' \
  '-L[try to use large memory pages]' \
  '-D[delimiter for stats]:char:' \
  '-t[number of threads]:n:' \
  '-R[max requests per event]:n:' \
  '-C[disable use of CAS]' \
  '-b[set backlog queue limit]:n:' \
  '-B[binding protocol]:proto:(auto ascii binary)' \
  '-I[item size override]:bytes:' \
  '-S[turn on SASL auth]' \
  '-X[disable detailed stats commands]' \
  '-o[extended options]:opts:' \
  '*::memcached-debug args:_files' && ret=0
return ret
