#compdef uniformize-catalog
# Documentation: http://astrometry.net/doc/build-index.html
# uniformize a FITS reference catalog over a healpix grid

local ret=1

_arguments -s \
  '-h[show help]' \
  '-R+[name of RA column in FITS table (default RA)]:ra column:' \
  '-D+[name of DEC column in FITS table (default DEC)]:dec column:' \
  '-S+[column on which to sort]:sort column:' \
  '-f[sort in descending order (eg, FLUX); default ascending (eg, MAG)]' \
  '-H+[big healpix; default is all-sky]:big healpix:' \
  '-s+[big healpix Nside; default 1]:nside:' \
  '-m+[add a margin of N healpixels; default 0]:margin:' \
  '-n+[number of stars per fine healpix grid cell; default 10]:sweeps:' \
  '-N+[fine healpixelization grid; default 100]:nside:' \
  '-d+[deduplication radius in arcseconds; default none]:dedup radius:' \
  '-v[verbose]' \
  '1:input FITS catalog:_files' \
  '2:output FITS catalog:_files' && ret=0

return ret
