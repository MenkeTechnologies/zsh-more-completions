#compdef lacpd
# _lacp — IEEE 802.3ad Link Aggregation Control Protocol daemon (open-source lacpd from Cumulus/Mellanox stacks; -f config file, -d debug, -p priority, -i bond-interface, -m mode (active|passive), -t rate (slow|fast), -K kill running, -l log level, -P pidfile, -v verbose; typically managed via NetworkManager / systemd-networkd LACP units)
# upstream: github mirrors of LACP daemons (Cumulus + Mellanox SwitchSDK)
# Common flag shape from lacpd src/main.c on tip.

_lacp() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f+[config file]:file:_files' \
        '-d[debug]' \
        '-p+[priority]:priority:' \
        '-i+[bond interface]:interface:_net_interfaces' \
        '-m+[mode]:mode:(active passive)' \
        '-t+[rate]:rate:(slow fast)' \
        '-K[kill running]' \
        '-l+[log level]:level:(debug info warning error)' \
        '-P+[pidfile]:file:_files' \
        '-v[verbose]'
}

_lacp "$@"
