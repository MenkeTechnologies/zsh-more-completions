#compdef req_app
# Documentation: https://github.com/Mbed-TLS/mbedtls
# Reference accessed: 2026-05-20
# Verified: `req_app --help` (mbedtls X.509 CSR example program).

local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'filename=:certificate request file'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    if compset -P 'filename='; then
      _files -g "*.(req|csr|pem)" && ret=0
    else
      _describe -t params 'param' params -S '' && ret=0
    fi
    ;;
esac

return ret
