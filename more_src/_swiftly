#compdef swiftly
# Documentation: https://man.archlinux.org/search?q=swiftly
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      install:'install Swift toolchain'
      uninstall:'remove toolchain'
      use:'select active toolchain'
      list:'list installed toolchains'
      run:'run with given toolchain'
      init:'initialize swiftly config'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
