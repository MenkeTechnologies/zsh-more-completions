#compdef swiftly
# Documentation: https://github.com/swiftlang/swiftly
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      'install:install a Swift toolchain'
      'uninstall:remove installed Swift toolchains'
      'use:switch the active Swift toolchain'
      'list:list installed Swift toolchains'
      'list-available:list toolchains available to install'
      'update:update installed toolchains'
      'run:execute a command with a specific toolchain'
      'self-update:upgrade swiftly itself'
      'self-uninstall:remove swiftly from the system'
      'init:initialize swiftly configuration'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
