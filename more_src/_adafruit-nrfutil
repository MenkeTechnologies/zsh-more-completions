#compdef adafruit-nrfutil
# Documentation: https://github.com/adafruit/Adafruit_nRF52_nrfutil/blob/master/README.md
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

local -a _nrfutil_subcommands
_nrfutil_subcommands=(
  'dfu:perform device firmware update operations'
  'keys:key management for DFU signing'
  'pkg:package management for DFU'
  'version:display version information'
)

_arguments -C \
  '(- *)--help[show help message]' \
  '-v[enable verbose output]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'adafruit-nrfutil subcommand' _nrfutil_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      dfu)
        local -a _dfu_subcommands
        _dfu_subcommands=(
          'generate:generate a DFU package'
          'serial:perform DFU over serial port'
        )
        _arguments -C \
          '(- *)--help[show help message]' \
          '1: :->dfu_cmd' \
          '*:: :->dfu_args' && ret=0
        case $state in
          dfu_cmd)
            _describe -t commands 'dfu subcommand' _dfu_subcommands && ret=0
            ;;
          dfu_args)
            case $line[1] in
              generate)
                _arguments -s -S \
                  '(- *)--help[show help message]' \
                  '--application[application hex file]:hex file:_files -g "*.hex"' \
                  '--softdevice[softdevice hex file]:hex file:_files -g "*.hex"' \
                  '--bootloader[bootloader hex file]:hex file:_files -g "*.hex"' \
                  '--hw-version[hardware version]:version:' \
                  '--sd-req[softdevice firmware requirement]:requirement:' \
                  '--key-file[signing key PEM file]:key file:_files -g "*.pem"' \
                  '1:output zip file:_files -g "*.zip"' && ret=0
                ;;
              serial)
                _arguments -s -S \
                  '(- *)--help[show help message]' \
                  '--package[DFU package zip file]:package file:_files -g "*.zip"' \
                  '--port[serial port device]:serial port:_files -W /dev -g "tty*"' \
                  '--baudrate[serial baud rate]:baud rate:(115200 38400 19200 9600)' \
                  '--flowcontrol[enable flow control]' && ret=0
                ;;
              *)
                _default && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      keys)
        _arguments -s -S \
          '(- *)--help[show help message]' \
          'generate:generate a new private key' \
          'display:display public key from private key' && ret=0
        ;;
      pkg)
        _arguments -s -S \
          '(- *)--help[show help message]' \
          'generate:generate a DFU package' && ret=0
        ;;
      version)
        _message 'no more arguments' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
