#compdef fslselectvols
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/utilities/fslutils.html
# FSL: select volumes from a 4D image given a list of volume indices

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[input 4D image]:input:_files' \
  '-o[output image]:output:_files' \
  '--vols=[volumes to select (comma-separated list or file)]:vols:_files' \
  '-m[output mean of selected volumes]' \
  '-v[output variance of selected volumes]' \
  '*:image:_files' && ret=0

return ret
