#compdef mythccextractor
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythccextractor/mythccextractor_commandlineparser.cpp
# Reference accessed: 2026-05-16
# Verified: upstream mythccextractor_commandlineparser.cpp.

# mythccextractor: MythTV closed-caption extractor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --destdir)'{-d,--destdir=}'[destination directory]:dir:_files -/' \
  '(-i --infile)'{-i,--infile=}'[input file]:file:_files' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[reduce logging]' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' && ret=0
return ret
