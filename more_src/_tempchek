#compdef tempchek
# Documentation: https://help.pesthomepage.org/pest-model-communication.html
# PEST template-file checker; can also write a model input file from a template and parameters

local ret=1

_arguments -s \
  '1:template file:_files -g "*.tpl"' \
  '2:model input file to write:_files' \
  '3:parameter value file:_files -g "*.par"' && ret=0

return ret
