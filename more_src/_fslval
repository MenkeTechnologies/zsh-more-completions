#compdef fslval
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/utilities/fslutils.html
# FSL: report a particular header parameter (keyword) from an image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:image:_files' \
  '2:keyword:(dim0 dim1 dim2 dim3 dim4 datatype pixdim0 pixdim1 pixdim2 pixdim3 pixdim4 cal_max cal_min file_type)' && ret=0

return ret
