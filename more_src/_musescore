#compdef musescore

# Zsh completion for musescore - MuseScore music notation

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--long-version[show long version info]' \
  '-d[debug mode]' \
  '--debug[debug mode]' \
  '-D[set MIDI port number]:port' \
  '-e[enable experimental features]' \
  '--experimental[enable experimental features]' \
  '-F[use factory settings]' \
  '--factory-settings[use factory settings]' \
  '-f[force conversion, ignore errors]' \
  '--force[force conversion, ignore errors]' \
  '-I[set MIDI input port]:port' \
  '-i[load a virtual synthesizer soundfont]:soundfont:_files -g "*.sf{2,3}"' \
  '-j[run batch conversion jobs]:job file:_files -g "*.json"' \
  '--job=[run batch conversion jobs]:job file:_files -g "*.json"' \
  '-L[layout debug mode]' \
  '--layout-debug[layout debug mode]' \
  '-M[set MIDI import operations file]:file:_files' \
  '-m[no MIDI]' \
  '--no-midi[no MIDI]' \
  '-n[start with new score]' \
  '--new-score[start with new score]' \
  '-o[export to file]:output file:_files -g "*.{pdf,png,svg,mp3,wav,ogg,flac,mid,midi,musicxml,mxl,mscz,mscx}"' \
  '--export-to=[export to file]:output file:_files -g "*.{pdf,png,svg,mp3,wav,ogg,flac,mid,midi,musicxml,mxl,mscz,mscx}"' \
  '-O[set MIDI export operations file]:file:_files' \
  '-p[plugin to execute on startup]:plugin name' \
  '--plugin=[plugin to execute on startup]:plugin name' \
  '-r[set DPI for image export]:dpi' \
  '--image-resolution=[set DPI for image export]:dpi' \
  '-R[do not use built-in presets]' \
  '-S[use style file]:style file:_files -g "*.mss"' \
  '--style=[use style file]:style file:_files -g "*.mss"' \
  '-s[no internal synthesizer]' \
  '--no-synthesizer[no internal synthesizer]' \
  '-T[set trim margin for PNG/SVG]:margin (pixels)' \
  '--trim-image=[set trim margin for PNG/SVG]:margin (pixels)' \
  '-w[no web view]' \
  '--no-webview[no web view]' \
  '--diff[print diff for score files]' \
  '--score-media=[export score media (images/audio) to JSON]:output file:_files -g "*.json"' \
  '--highlight-config=[set highlight config file]:file:_files -g "*.json"' \
  '--score-parts=[export score parts metadata to JSON]:output file:_files -g "*.json"' \
  '--source-update=[update source info for exported score parts]:file:_files' \
  '--score-transpose=[transpose score]:semitones' \
  '--template-mode[save template mode]' \
  '--run-test-script=[run test script]:file:_files' \
  '*:file:_files -g "*.{mscz,mscx,musicxml,mxl,xml,mid,midi,cap,capx,gtp,gp3,gp4,gp5,gpx,bww,ove,sgu,pdf}"' && ret=0

return ret
