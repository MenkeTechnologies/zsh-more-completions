#compdef scooter
# Documentation: https://github.com/thomasschafer/scooter
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(-s --search-text)'{-s+,--search-text=}'[pre-populate search field]:pattern:' \
  '(-r --replace-text)'{-r+,--replace-text=}'[pre-populate replacement field]:replacement:' \
  '--fixed-strings[search with plain strings instead of regex]' \
  '--files-to-include=[glob patterns for files to include]:glob:' \
  '(-e --interpret-escape-sequences)'{-e,--interpret-escape-sequences}'[interpret \n \t \\ in replacement text]' \
  '(-a --advanced-regex)'{-a,--advanced-regex}'[use full regex features including negative lookahead]' \
  '-U[enable multiline searching by default]' \
  '--hidden[include hidden files]' \
  '(-N --no-tui)'{-N,--no-tui}'[disable TUI mode, write results to stdout]' \
  '--immediate-search[skip search screen and begin searching immediately]' \
  '--print-on-exit[output results when exiting]' \
  '--config-dir=[override config directory location]:dir:_directories' \
  '--editor-command=[override editor command for opening files]:command:' && ret=0

return ret
