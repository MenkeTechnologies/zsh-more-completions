#compdef tij
# Documentation: https://github.com/nakamura-shuta/tij
# Source: nakamura-shuta/tij Text-mode interface for Jujutsu (tig-inspired).
# Reference accessed: 2026-06-01
# Requires jj >= 0.41.0 in PATH; minimal CLI surface (interactive keybindings inside).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:repo path:_files -/' \
    && ret=0

return ret
