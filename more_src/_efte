#compdef efte
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/efte.1.html
# eFTE folding text editor command-line options

local ret=1

_arguments -s \
  '(-h -?)-h[help on command line options]' \
  '(-h -?)-?[help on command line options]' \
  '-![ignore external configuration, use internal]' \
  '-l-[go to line (and column) in next file]:line:' \
  '-m-[set mode for next files]:mode:' \
  '-C-[use specified compiled configuration file]:config:_files' \
  '-D-[load/save desktop from file]:desktop:_files' \
  '-H-[load/save history from file]:history:_files' \
  '-T+[load tagfile at startup]:tagfile:_files' \
  '-t+[lookup tag and display containing file]:tag:' \
  '-noxmb[do not use XMB functions in xefte]' \
  '-font+[X font to use with xefte]:font:' \
  '*:file:_files' && ret=0

return ret
