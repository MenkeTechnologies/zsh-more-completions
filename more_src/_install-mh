#compdef install-mh
# Documentation: man install-mh(1)
# Source: nmh uip/install-mh.c (master) — initialize nmh user profile (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-auto[auto-install with defaults]' \
    '-check[check if installed]' \
    '-version[show version]' \
    '-help[show help]' \
    && ret=0

return ret
