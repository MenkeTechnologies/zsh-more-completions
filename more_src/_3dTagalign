#compdef 3dTagalign
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTagalign.html
# AFNI: align a dataset to a master via tag points

local ret=1

_arguments -s -S \
  '-master[master dataset for alignment]:mset:_files' \
  '-tagset[tagset from .tag file]:tfile:_files' \
  '-nokeeptags[exclude transformed tag locations from output]' \
  '-matvec[write transform matrix and vector to file]:mfile:_files' \
  '-rotate[transform as rotation plus shift (default)]' \
  '-affine[transform as 9-parameter affine map]' \
  '-rotscl[rotation with isotropic scaling]' \
  '-prefix[output dataset prefix (default tagalign)]:prefix:' \
  '-verb[progress reporting]' \
  '-dummy[compute transform without rotating]' \
  '-linear[linear interpolation]' \
  '-cubic[cubic interpolation (default)]' \
  '-NN[nearest-neighbor interpolation]' \
  '-quintic[quintic interpolation]' \
  '*:dataset:_files' && ret=0

return ret
