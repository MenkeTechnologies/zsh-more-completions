#compdef certificate-maker
# _certificate-maker — create root/intermediate/leaf cert chains for Fulcio (sigstore/fulcio)
# upstream: https://github.com/sigstore/fulcio
# Subcommands from cmd/certificate_maker/certificate_maker.go (cobra).

_certificate-maker() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(create:'create a certificate chain')
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                create)
                    _arguments \
                        '--kms-type=[KMS provider type]:type:(awskms gcpkms azurekms hashivault)' \
                        '--aws-region=[AWS KMS region]:region:' \
                        '--azure-tenant-id=[Azure KMS tenant ID]:id:' \
                        '--gcp-credentials-file=[GCP KMS credentials file]:file:_files' \
                        '--vault-token=[HashiVault token]:token:' \
                        '--vault-address=[HashiVault address]:url:_urls' \
                        '--vault-namespace=[HashiVault namespace]:ns:' \
                        '--root-key-id=[KMS root key identifier]:id:' \
                        '--root-template=[root certificate template path]:file:_files' \
                        '--root-cert=[output root certificate path]:file:_files' \
                        '--intermediate-key-id=[KMS intermediate key identifier]:id:' \
                        '--intermediate-template=[intermediate certificate template path]:file:_files' \
                        '--intermediate-cert=[output intermediate certificate path]:file:_files' \
                        '--leaf-key-id=[KMS leaf key identifier]:id:' \
                        '--leaf-template=[leaf certificate template path]:file:_files' \
                        '--leaf-cert=[output leaf certificate path]:file:_files' \
                        '--root-lifetime=[root certificate lifetime]:duration:' \
                        '--intermediate-lifetime=[intermediate certificate lifetime]:duration:' \
                        '--leaf-lifetime=[leaf certificate lifetime]:duration:' \
                        '--existing-root-cert=[existing root PEM to reuse]:file:_files' \
                        '--existing-intermediate-cert=[existing intermediate PEM to reuse]:file:_files' \
                        '1:common name:' ;;
            esac
            ;;
    esac
}

_certificate-maker "$@"
