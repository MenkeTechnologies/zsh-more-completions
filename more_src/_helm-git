#compdef helm-git
# Documentation: https://man.archlinux.org/search?q=helm-git
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--path=[path within Git repo]:path:' \
  '--ref=[Git ref]:ref:' \
  '--timeout=[fetch timeout]:duration:' \
  '1:helm repo URL:'
