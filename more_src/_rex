#compdef rex
# Documentation: https://man.archlinux.org/search?q=rex
# Reference accessed: 2026-05-16

# Zsh completion for rex — remote command runner

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-H --host)'{-H,--host}'[remote host]:host' \
  '(-u --user)'{-u,--user}'[user]:user' \
  '*:command:_default' && ret=0

return ret
