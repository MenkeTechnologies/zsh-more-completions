#compdef capt-controller-manager
# _capt-controller-manager — Cluster API Tinkerbell provider (CAPT)
# upstream: https://github.com/tinkerbell/cluster-api-provider-tinkerbell
# Flags from main.go initFlags() on tip.

_capt-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--enable-leader-election=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--namespace=[restrict CAPT to a single namespace]:ns:' \
        '--watch-filter=[watch-filter label value]:value:' \
        '--profiler-address=[pprof bind host\:port]:host\:port:' \
        '--tinkerbellcluster-concurrency=[TinkerbellCluster concurrent reconciles]:n:' \
        '--tinkerbellmachine-concurrency=[TinkerbellMachine concurrent reconciles]:n:' \
        '--tinkerbellhardware-concurrency=[TinkerbellHardware concurrent reconciles]:n:' \
        '--tinkerbelltemplate-concurrency=[TinkerbellTemplate concurrent reconciles]:n:' \
        '--tinkerbellworkflow-concurrency=[TinkerbellWorkflow concurrent reconciles]:n:' \
        '--sync-period=[informer resync period]:dur:' \
        '--webhook-port=[webhook server bind port]:port:' \
        '--webhook-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--health-addr=[health probe bind host\:port]:host\:port:' \
        '--external-kubeconfig=[external workload-cluster kubeconfig]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_capt-controller-manager "$@"
