#compdef bbe
# Documentation: https://man.archlinux.org/search?q=bbe
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '(-b --block)'{-b,--block}'+[block definition :N or /str/]:block:' \
  '(-e --expression)'{-e,--expression}'+[bbe expression]:expr:' \
  '(-f --file)'{-f,--file}'+[script file with expressions]:file:_files' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-s --suppress)'{-s,--suppress}'[suppress non-matching block output]' \
  '*:file:_files' && ret=0

return ret
