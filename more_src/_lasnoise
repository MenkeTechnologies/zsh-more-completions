#compdef lasnoise
# LAStools: flag or remove noise points in LAS/LAZ files

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[report tool version]' \
  '-gui[start with GUI]' \
  '-demo[run in demo mode]' \
  '-v[verbose output]' \
  '-step+[uniform grid cell size (default 4)]:size' \
  '-step_xy+[horizontal x/y grid spacing]:size' \
  '-step_z+[vertical z grid spacing]:size' \
  '-isolated+[max point count for isolation (default 5)]:n' \
  '-classify_as+[set noise points to classification code]:code' \
  '-remove_noise[delete noise points instead of classifying]' \
  '-flag_as_withheld[mark noise points with withheld flag]' \
  '*-ignore_class+[skip specified classification codes]:code' \
  '-by_flightline[process each flightline separately]' \
  '-feet[horizontal units in feet]' \
  '-elevation_feet[vertical units in feet]' \
  '-cores+[parallel processing on N cores]:n' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output filename suffix]:suffix' \
  '-olas[write LAS format]' \
  '-olaz[write compressed LAZ format]' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
