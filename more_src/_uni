#compdef uni
# Documentation: https://github.com/arp242/uni
# Reference accessed: 2026-05-21
# Verified: upstream uni.go zli.NewFlags() declarations.

# uni — query the Unicode database. Flags can appear anywhere; single-dash long forms.
_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-v -version)'{-v,-version}'[show version]' \
  '(-c -compact -q -quiet)'{-c,-compact,-q,-quiet}'[compact output (suppress header)]' \
  '(-f -format)'{-f+,-format=}'[output column format]:format:' \
  '(-a -as)'{-a+,-as=}'[output style]:mode:(list table json j)' \
  '(-j -json)'{-j,-json}'[alias for -as json]' \
  '(-r -raw)'{-r,-raw}'[raw characters; no graphical variants]' \
  '(-p -pager)'{-p,-pager}'[pipe through $PAGER]' \
  '(-o -or)'{-o,-or}'[OR search terms instead of AND]' \
  '(-t -tone -tones)'{-t+,-tone=,-tones=}'[emoji skin tone (light, medium, dark, all)]:tone:' \
  '(-g -gender -genders)'{-g+,-gender=,-genders=}'[emoji gender (person, man, woman, all)]:gender:' \
  '1:command:(identify i search s print p emoji e)' \
  '*:argument:_message'
