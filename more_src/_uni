#compdef uni

# https://github.com/arp242/uni — flags can appear anywhere; options listed first (-s).
_arguments -s -S \
  '(-h)-h[show short help]' \
  '--help[show full help]' \
  '(-f -format)'{-f,-format}'=-[output column format]' \
  '(-a -as)'{-a,-as}'=-[output style]:mode:(list json table)' \
  '(-c -compact)'{-c,-compact}'[compact output]' \
  '(-r -raw)'{-r,-raw}'[raw characters; no graphical variants / U+25CC prefix]' \
  '(-p -pager)'{-p,-pager}'[pipe through $PAGER]' \
  '(-o -or)'{-o,-or}'[OR search terms instead of AND]' \
  '(-q -quiet)'{-q,-quiet}'[alias for --compact]' \
  '(-j -json)'{-j,-json}'[alias for --as json]' \
  '1:command:(list identify search print emoji)' \
  '*:argument:_message'
