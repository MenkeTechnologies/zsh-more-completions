#compdef vmd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-e+[execute Tcl script]:script:_files -g "*.tcl"' \
  '-python[use Python shell]' \
  '-dispdev+[display device]:device:(text cave freevrpn win none)' \
  '-dist+[display distance]:distance:' \
  '-height+[display height]:height:' \
  '-pos+[window position]:x y:' \
  '-size+[window size]:width height:' \
  '-nt[no title bar]' \
  '-eofexit[exit on EOF]' \
  '-startup+[startup script]:script:_files' \
  '-m[load molecules in separate top molecules]' \
  '-f+[load files into same molecule]:file:_files' \
  '-psf+[load PSF file]:file:_files -g "*.psf"' \
  '-pdb+[load PDB file]:file:_files -g "*.pdb"' \
  '-dcd+[load DCD trajectory]:file:_files -g "*.dcd"' \
  '-coor+[load coordinates]:file:_files' \
  '-namdbin+[load NAMD binary coordinates]:file:_files' \
  '-vel+[load velocities]:file:_files' \
  '-log+[log file]:file:_files' \
  '-args[pass remaining args to scripts]' \
  '*:file:_files -g "*.(pdb|psf|dcd|coor|xyz|gro|mol2|parm7|rst7|cube|dx)"' && ret=0

return ret
