#compdef caja-actions
# Documentation: https://github.com/mate-desktop/caja-actions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# caja-actions: MATE Caja extension for configurable context-menu actions.
# The launcher is a GTK3/GApplication binary that accepts only the standard
# GTK/GApplication options.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options inc GTK]' \
  '(- *)--help-gtk[show GTK-specific options]' \
  '(- *)--help-gapplication[show GApplication options]' \
  '(- *)--version[show version]' \
  '--display=[X display]:display:' \
  '--gtk-debug=[GTK debug flags]:flags:' \
  '--gtk-no-debug=[disable GTK debug flags]:flags:' \
  '--gdk-debug=[GDK debug flags]:flags:' \
  '--gdk-no-debug=[disable GDK debug flags]:flags:' \
  '--gtk-module=[load GTK module]:module:' \
  '--g-fatal-warnings[treat warnings as fatal]' \
  '--name=[set program name]:name:' \
  '--class=[set program class]:class:' \
  '*::caja-actions args:_files' && ret=0
return ret
