#compdef okta-awscli
# Documentation: https://github.com/okta-awscli/okta-awscli
# Reference accessed: 2026-05-19
# Verified: upstream README and PyPI page (pypi.org/project/okta-awscli).
# This is the Python okta-awscli (Okta -> AWS temporary credentials helper).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --profile)'{-p+,--profile=}'[set credentials to a profile in .aws/credentials]:profile' \
  '(-f --force)'{-f,--force}'[ignore STS validation; fetch new credentials]' \
  '(-c --cache)'{-c,--cache}'[cache credentials to ~/.okta-credentials.cache]' \
  '(-o --okta-profile)'{-o+,--okta-profile=}'[use an Okta profile other than default]:okta-profile' \
  '(-t --token)'{-t+,--token=}'[TOTP token from authenticator]:token' \
  '(-r --refresh-role)'{-r,--refresh-role}'[refresh AWS role to be assumed]' \
  '(-l --lookup)'{-l,--lookup}'[lookup AWS account alias for each role]' \
  '--config[add/create new Okta profile configuration]' \
  '(-s --switch)'{-s,--switch}'[switch to an existing profile and update credentials]' \
  '*::aws args:_default'
