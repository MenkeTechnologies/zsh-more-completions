#compdef cvmsh2
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/cvmsh2.1.html
# 2D mesh converter for the FreeFem++ suite

local ret=1

_arguments -s -S \
  '-g[output geometry file]:file:_files' \
  '-thetamax[angular limit for smooth curve in degrees]:deg' \
  '-v[verbosity level (0-99)]:level' \
  ':input mesh file:_files' \
  ':output bd mesh file:_files' && ret=0

return ret
