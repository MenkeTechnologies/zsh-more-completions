#compdef modd
# Documentation: https://github.com/cortesi/modd
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for modd - developer tool that watches files and runs commands

_arguments \
  '-f[path to config file]:config file:_files' \
  '-n[only run specified prep/daemon blocks (comma-separated)]:blocks' \
  '-p[run prep commands only, skip daemons]' \
  '-b[run build steps and exit]' \
  '--bell[ring terminal bell on changes]' \
  '--notify[send desktop notifications]' \
  '--debug[enable debug output]' \
  '(- *)--version[show version]' \
  '(- *)--help[show help]'
