#compdef csv2json csv2json-easy

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --input-file)'{-i+,--input-file=}'[input CSV file]:file:_files -g "*.csv"' \
  '(-o --output-file)'{-o+,--output-file=}'[output JSON file]:file:_files -g "*.json"' \
  '(-p --pretty)'{-p,--pretty}'[pretty-print JSON]' \
  '(-l --limit)'{-l+,--limit=}'[output limit]:n:' \
  '(-s --offset)'{-s+,--offset=}'[start offset]:n:' \
  '(-d --delimiter)'{-d+,--delimiter=}'[CSV delimiter]:char:' \
  '(-q --quote)'{-q+,--quote=}'[CSV quote character]:char:' \
  '(-c --clean)'{-c,--clean}'[drop incomplete lines]' \
  '(-n --noheader)'{-n,--noheader}'[no header (auto-generate names)]' \
  '(-m --minify)'{-m,--minify}'[minify output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--generate-array[wrap output as a JSON array]' \
  '--configuration-file=[mapping config file]:file:_files -g "*.{json,yaml,yml}"' \
  '*::input_file:_files -g "*.csv"' && ret=0

return ret
