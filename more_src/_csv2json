#compdef csv2json
# Documentation: https://sascha-andres.github.io/jsonedit/cmd/csv2json/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (sascha-andres/jsonedit csv2json command).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--input-file=[input CSV file (- for stdin)]:file:_files -g "*.csv"' \
  '--output-file=[output file (- for stdout)]:file:_files' \
  '--separator=[field separator]:char:' \
  '--output-type=[output format]:type:(json yaml toml)' \
  '--configuration-file=[column mapping config file]:file:_files -g "*.{json,yaml,yml,toml}"' \
  '--nested-property-name=[nested property name]:name:' \
  '--generate-array[wrap output as JSON array (vs JSON Lines)]' \
  '--access-by-header[map columns by header name]' \
  '--debug[enable debug output]' \
  '*::input_file:_files -g "*.csv"' && ret=0

return ret
