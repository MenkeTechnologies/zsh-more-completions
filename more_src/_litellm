#compdef litellm
# Documentation: https://docs.litellm.ai/docs/proxy/cli
# Reference accessed: 2026-05-17
# Verified: BerriAI/litellm proxy CLI. Real flags: --host, --port,
# --num_workers, --api_base, --api_version, --model, --alias,
# --add_key, --headers, --save, --debug, --detailed_debug,
# --use_queue, --health, --test, --test_async, --num_requests,
# --config, --config_file, --max_budget, --telemetry,
# --run_gunicorn, --run_hypercorn, --max_requests_before_restart,
# --skip_startup_shutdown, --ssl_keyfile_path, --ssl_certfile_path,
# --local, --version.
# Removed from prior file: bogus man.archlinux.org search URL.

# Zsh completion for LiteLLM - unified LLM API proxy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--model=[model name]:model' \
  '--api_base=[API base URL]:url' \
  '--api_key=[API key]:key' \
  '--port=[port to listen on]:port' \
  '--host=[host to bind to]:host' \
  '--num_workers=[number of workers]:workers' \
  '--config=[config file]:config:_files -g "*.{yaml,yml}"' \
  '--detailed_debug[enable detailed debug]' \
  '--debug[enable debug mode]' \
  '--drop_params[drop unsupported params]' \
  '--add_function_to_prompt[add function to prompt]' \
  '--max_budget=[max budget]:budget' \
  '--telemetry=[enable telemetry]:bool:(True False)' \
  '--logs[enable request logging]' \
  '--health[run health check]' \
  '--test[run test request]' \
  '--alias=[model alias]:alias' && ret=0

return ret
