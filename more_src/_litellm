#compdef litellm
# Documentation: https://docs.litellm.ai/docs/proxy/cli
# Reference accessed: 2026-05-17
# Verified: BerriAI/litellm proxy CLI. Real flags: --host, --port,
# --num_workers, --api_base, --api_version, --model, --alias,
# --add_key, --headers, --save, --debug, --detailed_debug,
# --use_queue, --health, --test, --test_async, --num_requests,
# --config, --config_file, --max_budget, --telemetry,
# --run_gunicorn, --run_hypercorn, --max_requests_before_restart,
# --skip_startup_shutdown, --ssl_keyfile_path, --ssl_certfile_path,
# --local, --version.
# Removed from prior file: bogus man.archlinux.org search URL.

# Zsh completion for LiteLLM - unified LLM API proxy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-m --model)'{-m,--model=}'[model name]:model:' \
  '--api_base=[API base URL]:url:' \
  '--api_version=[API version]:version:' \
  '--port=[port to listen on]:port:' \
  '--host=[host to bind to]:host:' \
  '--num_workers=[number of workers]:workers:' \
  '(-c --config)'{-c,--config=}'[config file]:config:_files -g "*.{yaml,yml}"' \
  '--log_config=[logging config file]:file:_files' \
  '--keepalive_timeout=[keepalive timeout]:seconds:' \
  '--max_requests_before_restart=[max requests before restart]:n:' \
  '--run_gunicorn[run with gunicorn server]' \
  '--run_hypercorn[run with hypercorn server]' \
  '--skip_server_startup[skip server startup]' \
  '--ssl_keyfile_path=[SSL keyfile path]:file:_files' \
  '--ssl_certfile_path=[SSL cert file path]:file:_files' \
  '--ciphers=[SSL ciphers]:ciphers:' \
  '--alias=[model alias]:alias:' \
  '--headers=[request headers]:headers:' \
  '--add_key=[add a key]:key:' \
  '--save[save model config]' \
  '--detailed_debug[enable detailed debug]' \
  '--debug[enable debug mode]' \
  '--local[run locally]' \
  '--drop_params[drop unsupported params]' \
  '--add_function_to_prompt[add function to prompt]' \
  '--max_budget=[max budget]:budget:' \
  '--telemetry=[enable telemetry]:bool:(True False)' \
  '--health[run health check]' \
  '--test[run test request]' \
  '--test_async[run async test request]' \
  '--num_requests=[number of test requests]:n:' \
  '--use_queue[use queue mode]' \
  '--iam_token_db_auth[use IAM token for db auth]' \
  '--use_prisma_db_push[use prisma db push]' \
  '--temperature=[model temperature]:temp:' \
  '--max_tokens=[max tokens]:n:' \
  '--request_timeout=[request timeout]:seconds:' && ret=0

return ret
