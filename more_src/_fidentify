#compdef fidentify
# Documentation: https://www.cgsecurity.org/wiki/Fidentify
# Source: cgsecurity/testdisk man/fidentify.8.in — TestDisk's file-format identifier (uses PhotoRec's signature engine).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--check[check the file format like PhotoRec does]' \
    '--version[output version information]' \
    '*:file:_files' \
    && ret=0

return ret
