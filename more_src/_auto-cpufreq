#compdef auto-cpufreq

# Zsh completion for auto-cpufreq - automatic CPU speed and power optimizer

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)--version[show version information]' \
  '(-m --monitor)'{-m,--monitor}'[monitor CPU frequency and suggest optimizations]' \
  '(-l --live)'{-l,--live}'[monitor and apply CPU optimizations in real time]' \
  '--install[install auto-cpufreq daemon]' \
  '--remove[remove auto-cpufreq daemon]' \
  '--update[update auto-cpufreq to latest release]' \
  '(-s --stats)'{-s,--stats}'[view live stats of CPU optimizations]' \
  '(-f --force)'{-f,--force}'[force set governor override]:governor:(performance powersave)' \
  '(-L --log)'{-L,--log}'[view auto-cpufreq log]' \
  '(-c --config)'{-c,--config}'[use config file]:config file:_files' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '--debug[print debug information]'
