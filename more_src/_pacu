#compdef pacu
# Documentation: https://man.archlinux.org/search?q=pacu
# Reference accessed: 2026-05-16

_arguments -s \
  '--session=[session name]:name:' \
  '--activate-session[activate session]' \
  '--new-session=[create session]:name:' \
  '--set-keys=[alias,id,secret,token]:keys:' \
  '--import-keys=[AWS profile]:profile:' \
  '--module-name=[module]:module:' \
  '--data=[query DB by service]:service:' \
  '--module-args=[module args]:args:' \
  '--list-modules[list modules]' \
  '--pacu-help[help]' \
  '--module-info[module info]' \
  '--exec[execute module]' \
  '*--set-regions=[regions or all]:region:' \
  '--whoami[show IAM user]' \
  '--version[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]'
