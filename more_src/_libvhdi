#compdef vhdiinfo vhdimount
# _libvhdi — libvhdi tools (libyal Microsoft VHD/VHDX virtual-disk parser; vhdiinfo prints metadata for fixed/dynamic/differencing VHD or VHDX disks, vhdimount FUSE-mounts the disk read-only; -h help, -V version, -v verbose, -o image offset, -p password; positional argument is the .vhd/.vhdx file)
# upstream: https://github.com/libyal/libvhdi
# Flags from libyal/libvhdi vhditools/vhdiinfo.c on tip.

_libvhdi() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-p+[password]:password:' \
        '*:VHD/VHDX file:_files -g "*.(vhd|vhdx)"'
}

_libvhdi "$@"
