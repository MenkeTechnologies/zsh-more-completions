#compdef profile profile-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/profile.py argparse)
# Reference accessed: 2026-05-29
# profile — sample on-CPU stack traces at a frequency (BCC/eBPF). Flame-graph-ready folded output.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[profile one or more comma-separated PIDs only]:pids:' \
  '(-L --tid)'{-L,--tid=}'[profile one or more comma-separated TIDs only]:tids:' \
  '(-U --user-stacks-only -K --kernel-stacks-only)'{-U,--user-stacks-only}'[show stacks from user space only (no kernel)]' \
  '(-U --user-stacks-only -K --kernel-stacks-only)'{-K,--kernel-stacks-only}'[show stacks from kernel space only (no user)]' \
  '(-F --frequency -c --count)'{-F,--frequency=}'[sample frequency, Hertz]:hz:' \
  '(-F --frequency -c --count)'{-c,--count=}'[sample period, number of events]:N:' \
  '(-d --delimited)'{-d,--delimited}'[insert delimiter between kernel/user stacks]' \
  '(-a --annotations)'{-a,--annotations}'[add _[k] annotations to kernel frames]' \
  '(-I --include-idle)'{-I,--include-idle}'[include CPU idle stacks]' \
  '(-f --folded)'{-f,--folded}'[output folded format (for flame graphs)]' \
  '--hash-storage-size=[number of hash keys stored (default 40960)]:N:' \
  '--stack-storage-size=[number of unique stack traces stored (default 16384)]:N:' \
  '(-C --cpu)'{-C,--cpu=}'[cpu number to run profile on (default -1=all)]:cpu:' \
  '--cgroupmap=[trace cgroups in this BPF map only]:map:' \
  '--mntnsmap=[trace mount namespaces in this BPF map only]:map:' \
  '(-A --address)'{-A,--address}'[show raw addresses]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:duration (seconds, default unlimited):' \
  && ret=0

return ret
