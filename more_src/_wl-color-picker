#compdef wl-color-picker
# Documentation: https://github.com/jgmdev/wl-color-picker
# A wayland color picker that also works on wlroots

local ret=1

_arguments -s -S \
  '(-h --help help ?)'{-h,--help}'[show help]' \
  '--no-notify[do not show a system notification of copied color]' \
  '1::command:(clipboard help)' && ret=0

return ret
