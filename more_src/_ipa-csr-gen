#compdef ipa-csr-gen
# Documentation: (no standalone CLI in upstream FreeIPA)
# Reference accessed: 2026-05-16
# Verified: no manpage in freeipa upstream install/tools/man/ or client/man/.
# Likely refers to the `ipa cert-request` subcommand. Tool kept per
# "do not delete files" directive with minimal stub.

# ipa-csr-gen: not present in upstream FreeIPA
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*::extra args:_files' && ret=0
return ret
