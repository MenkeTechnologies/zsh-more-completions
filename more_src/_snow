#compdef snow

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'connection:configuration of connections'
  'sql:execute Snowflake queries'
  'app:Native App Framework commands'
  'snowpark:Snowpark Python development'
  'streamlit:Streamlit app development'
  'stage:manage Snowflake stages'
  'spcs:Snowpark Container Services'
  'git:repository integration'
  'helpers:utility helpers'
  'logs:query logs'
  'notebook:Snowflake Notebook commands'
  'dcm:Declarative Content Management'
  'cortex:AI/ML Cortex features'
  'object:Snowflake object management'
  'init:initialize a new project from template'
  'auth:authentication commands'
  'sso:SSO authentication'
  'ws:workspace commands'
  'dbt:dbt workflow integration'
  'pipe:data pipeline commands'
  'task:task management'
  'session:session management'
  'role:role management'
  'warehouse:warehouse management'
  'database:database management'
  'schema:schema management'
  'table:table management'
  'user:user management'
  'function:UDF management'
  'procedure:stored procedure management'
  'service:Snowflake services'
  '--info:print info about CLI'
  '--help:show help'
  '--version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--info[show CLI info]' \
  '--config-file=[path to config TOML]:file:_files -g "*.toml"' \
  '*--silent[suppress verbose output]' \
  '*--verbose[verbose output]' \
  '--debug[debug mode]' \
  '--enable-tracebacks[enable Python tracebacks]' \
  '--disable-tracebacks[disable tracebacks]' \
  '--format=[output format]:format:(TABLE JSON CSV)' \
  '*-c+[connection name]:connection:' \
  '*--connection=[connection name]:connection:' \
  '*--account=[Snowflake account]:account:' \
  '*--user=[Snowflake user]:user:_users' \
  '*--password=[password]:password:' \
  '*--authenticator=[authenticator]:auth:(snowflake externalbrowser oauth username_password_mfa)' \
  '*--private-key-file=[private key]:file:_files' \
  '*--token-file-path=[OAuth token file]:file:_files' \
  '*--warehouse=[warehouse]:wh:' \
  '*--database=[database]:db:' \
  '*--schema=[schema]:schema:' \
  '*--role=[role]:role:' \
  '*--temporary-connection[temporary connection]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'snow subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (connection)
        _values 'connection action' \
          'add' 'list' 'set-default' 'test' 'generate-jwt' && ret=0
        ;;
      (sql)
        _arguments \
          '-q+[query string]:query:' \
          '--query=[query string]:query:' \
          '-f+[script file]:file:_files -g "*.sql"' \
          '--filename=[script file]:file:_files -g "*.sql"' \
          '-i[read from stdin]' \
          '--stdin[read from stdin]' \
          '--variable=[variable]:name=value:' \
          '*-D+[variable]:name=value:' && ret=0
        ;;
      (app)
        _values 'app action' \
          'init' 'deploy' 'install' 'uninstall' 'open' 'run' 'teardown' 'validate' \
          'version' 'package' 'bundle' 'publish' 'release-directive' 'release-channel' && ret=0
        ;;
      (snowpark)
        _values 'snowpark action' \
          'init' 'build' 'deploy' 'execute' 'list' 'package' 'describe' 'drop' 'run' && ret=0
        ;;
      (streamlit)
        _values 'streamlit action' \
          'init' 'deploy' 'share' 'list' 'describe' 'drop' 'get-url' && ret=0
        ;;
      (stage)
        _values 'stage action' \
          'list' 'create' 'remove' 'put' 'get' 'copy' 'describe' 'list-files' 'execute' && ret=0
        ;;
      (spcs)
        _values 'spcs action' \
          'image-registry' 'image-repository' 'compute-pool' 'service' 'job' && ret=0
        ;;
      (git)
        _values 'git action' \
          'setup' 'fetch' 'list-branches' 'list-tags' 'list-files' 'execute' 'copy' && ret=0
        ;;
      (object)
        _values 'object action' 'create' 'describe' 'drop' 'list' 'show' && ret=0
        ;;
      (notebook)
        _values 'notebook action' 'create' 'execute' 'open' 'list' 'describe' 'drop' && ret=0
        ;;
      (cortex)
        _values 'cortex action' \
          'complete' 'extract-answer' 'sentiment' 'summarize' 'translate' 'search' && ret=0
        ;;
      (init)
        _arguments \
          '--template=[project template]:template:' \
          '--template-source=[template source URL]:url:' \
          '*:project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
