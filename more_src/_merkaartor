#compdef merkaartor
# Documentation: https://manpages.debian.org/bookworm/merkaartor/merkaartor.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm merkaartor(1) manpage. OPTIONS section
# explicitly reads "None"; tool is GUI-only.
# Removed from prior file: fabricated -h/--help/-V/--version flags
# and bogus man.archlinux.org search URL.

# merkaartor: Qt OpenStreetMap editor (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:OSM file:_files -g "*.(osm|gpx|nmea)(-.)"' && ret=0
return ret
