#compdef xfce4-screensaver
# Documentation: https://manpages.debian.org/trixie/xfce4-screensaver/xfce4-screensaver.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian trixie xfce4-screensaver(1) manpage OPTIONS section.

# xfce4-screensaver: XFCE screensaver daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show standard command line options]' \
  '--help-all[show all command line options]' \
  '--display=[X display to use]:display:' \
  '--debug[enable debugging messages]' \
  '--version[show version]' && ret=0
return ret
