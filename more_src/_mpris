#compdef mpris playerctl
# _mpris — MPRIS Media Player Remote Interface Specification DBus client playerctl-style CLI dispatcher controlling spotify mpv vlc rhythmbox audacious lollypop strawberry players via DBus org.mpris.MediaPlayer2 interface play pause next previous seek volume metadata loop shuffle status (MPRIS spec team, C); getopt
# upstream: https://specifications.freedesktop.org/mpris-spec/latest/

_mpris() {
    local -a sub=(
        'play:play the player'
        'pause:pause the player'
        'play-pause:toggle play/pause'
        'stop:stop the player'
        'next:skip to next track'
        'previous:skip to previous track'
        'position:get or set track position'
        'volume:get or set volume'
        'status:get player status'
        'metadata:get current metadata'
        'loop:get or set loop status'
        'shuffle:get or set shuffle status'
        'open:open URI in player'
        '-l:list available players'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-p+[player]:str:' \
        '--player=+[player]:str:' \
        '-a[control all players]' \
        '--all-players[all players]' \
        '-i+[ignore player]:str:' \
        '--ignore-player=+[player]:str:' \
        '-l[list players]' \
        '--list-all[list players]' \
        '-s+[select players]:str:' \
        '--select-players=+[players]:str:' \
        '-F+[format]:str:' \
        '--format=+[format]:str:' \
        '-f[follow]' \
        '--follow[follow]' \
        '--no-messages[no messages]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mpris subcommand' sub ;;
        args)
            case $words[1] in
                loop) _arguments '1:status:(None Track Playlist)' ;;
                shuffle) _arguments '1:status:(on off toggle)' ;;
                volume) _arguments '1:level:' ;;
                position) _arguments '1:offset:' ;;
                metadata) _arguments '1:key:(album artist title genre length url)' ;;
                open) _arguments '1:uri:_files' ;;
            esac
            ;;
    esac
}

_mpris "$@"
