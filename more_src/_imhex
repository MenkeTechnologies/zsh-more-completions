#compdef imhex

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'pl:run an ImHex Pattern Language script'
  'help:show help'
  'version:show version'
  'plugins:list loaded plugins'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-plugins[disable all plugins]' \
  '--no-builtin-plugin[disable builtin plugin]' \
  '--reset-settings[reset settings to defaults]' \
  '--debug-mode[enable debug mode]' \
  '--logging-mode=[set logging level]:level:(none info warning error debug)' \
  '--portable[run in portable mode]' \
  '--server-mode[run in server mode]' \
  '--new[open a fresh window]' \
  '--select=[byte range to select]:range (start\:size or start-end):' \
  '--pattern=[pattern file to load on startup]:file:_files -g "*.hexpat"' \
  '--input=[input file]:file:_files' \
  '--output=[output file]:file:_files' \
  '1: :->cmd' \
  '*::file:_files' && ret=0

case $state in
  (cmd)
    if (( ${words[(I)--*]} == 0 )); then
      _describe -t cmds 'imhex subcommand' commands
    fi
    _files
    ret=0 ;;
esac

return ret
