#compdef systemd-manager-tui
# Documentation: https://github.com/matheus-git/systemd-manager-tui
# Reference accessed: 2026-05-21
# Verified: upstream README does not document CLI flags.
# STUB: standard --help/--version only; tool is launched interactively.

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' && ret=0
return ret
