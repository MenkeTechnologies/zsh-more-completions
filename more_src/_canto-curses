#compdef canto-curses
# Documentation: https://man.archlinux.org/search?q=canto-curses
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-D --dir)'{-D,--dir}'+[config directory]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-r --no-remote)'{-r,--no-remote}'[no remote]' \
  '(-a --address)'{-a,--address}'+[daemon address]:addr:' \
  '(-p --port)'{-p,--port}'+[daemon port]:port:' && ret=0

return ret
