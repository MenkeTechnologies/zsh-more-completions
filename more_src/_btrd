#compdef btrd
# Documentation: https://github.com/danobi/btrd
# Source: danobi/btrd src/main.rs — btrfs read-eval-print debugger (Rust, clap).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --debug)'{-d,--debug}'[show debug output]' \
    '(- *)'{-h,--help}'[print help]' \
    '(- *)'{-V,--version}'[print version]' \
    '1::script:_files' \
    && ret=0

return ret
