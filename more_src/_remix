#compdef remix create-remix

# Zsh completion for Remix CLI

_remix() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'build:build your app for production'
    'dev:start the Remix development server'
    'init:initialize a Remix project'
    'routes:list all routes'
    'reveal:reveal entry files'
    'vite:manage the Vite dev server and build'
    'watch:watch for changes and rebuild'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'remix command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        build)
          _arguments -s -S \
            '--sourcemap[generate source maps]' \
            '--mode=[build mode]:mode:(production development)' \
            && ret=0
          ;;
        dev)
          _arguments -s -S \
            '--port=[port to listen on]:port:' \
            '--host=[host to listen on]:host:_hosts' \
            '--manual[enable manual mode]' \
            '--command=[command to start app server]:command:' \
            && ret=0
          ;;
        init)
          _arguments -s -S \
            '1:project directory:_files -/' \
            && ret=0
          ;;
        routes)
          _arguments -s -S \
            '--json[print routes as JSON]' \
            '(-c --config)'{-c,--config}'[config file]:config file:_files' \
            && ret=0
          ;;
        reveal)
          _arguments -s -S \
            '1:entry:(entry.server entry.client)' \
            '--no-typescript[generate JavaScript files]' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[display version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_remix "$@"
