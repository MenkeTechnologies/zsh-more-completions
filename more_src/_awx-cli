#compdef awx-cli
# _awx-cli — Red Hat AWX automation upstream of Ansible Automation Platform CLI alias (ansible team, Python); argparse
# upstream: https://github.com/ansible/awx

_awx-cli() {
    local -a sub=(
        'login:login to AWX'
        'config:show config'
        'me:show current user'
        'metrics:show metrics'
        'ping:ping server'
        'settings:show settings'
        'organizations:list organizations'
        'users:user management'
        'teams:team management'
        'credentials:credential management'
        'credential_types:credential type management'
        'credential_input_sources:credential input sources'
        'inventory:inventory management'
        'inventory_sources:inventory sources'
        'inventory_updates:inventory updates'
        'projects:project management'
        'project_updates:project updates'
        'project_update_events:project update events'
        'job_templates:job template management'
        'jobs:job management'
        'job_events:job events'
        'ad_hoc_commands:ad-hoc command management'
        'system_job_templates:system job templates'
        'system_jobs:system jobs'
        'workflow_job_templates:workflow job templates'
        'workflow_job_template_nodes:workflow nodes'
        'workflow_jobs:workflow jobs'
        'workflow_job_nodes:workflow job nodes'
        'workflow_approvals:workflow approvals'
        'schedules:schedule management'
        'notification_templates:notification template management'
        'notifications:notification management'
        'tokens:token management'
        'access_list:show access list'
        'activity_stream:show activity stream'
        'roles:role management'
        'instance_groups:instance group management'
        'instances:instance management'
        'execution_environments:execution environment management'
        'labels:label management'
        'hosts:host management'
        'groups:group management'
        'help:show help'
        'version:show version'
        'completion:generate completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--conf.host=+[host]:url:_urls' \
        '--conf.username=+[user]:_users' \
        '--conf.password=+[password]:str:' \
        '--conf.token=+[token]:str:' \
        '--conf.insecure[insecure]' \
        '--conf.color=+[bool]:b:(true false)' \
        '--conf.format=+[format]:f:(json yaml human jq)' \
        '-f+[format]:f:(json yaml human jq)' \
        '--format=+[format]:f:(json yaml human jq)' \
        '--filter=+[jq filter]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'awx subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh)' ;;
            esac
            ;;
    esac
}

_awx-cli "$@"
