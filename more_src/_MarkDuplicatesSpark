#compdef MarkDuplicatesSpark
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/spark/transforms/markduplicates/MarkDuplicatesSpark.java
# GATK4: Spark implementation of Picard MarkDuplicates

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-I,--input}'[input BAM/CRAM file]:file:_files -g "*.(bam|cram|sam)"' \
  '(-O --output)'{-O,--output}'[the output bam]:file:_files' \
  '(-M --metrics-file)'{-M,--metrics-file}'[path to write duplication metrics to]:file:_files' \
  '(--remove-all-duplicates --remove-sequencing-duplicates)--duplicate-tagging-policy[how duplicate types are recorded in the DT attribute]:policy:(DontTag OpticalOnly All)' \
  '(--duplicate-tagging-policy --remove-sequencing-duplicates)--remove-all-duplicates[do not write duplicates to the output file]' \
  '(--duplicate-tagging-policy --remove-all-duplicates)--remove-sequencing-duplicates[do not write optical/sequencing duplicates]' \
  '--do-not-mark-unmapped-mates[unmapped mates of duplicate reads are not marked]' \
  '*:options:_files' && ret=0

return ret
