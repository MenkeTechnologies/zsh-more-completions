#compdef mcp-server-chart
# Documentation: https://github.com/antvis/mcp-server-chart
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# AntV chart MCP server

_arguments -s -S \
  '(-t --transport)'{-t,--transport}'+[transport protocol]:transport:(stdio sse streamable)' \
  '(-h --host)'{-h,--host}'+[host for SSE or streamable transport]:host' \
  '(-p --port)'{-p,--port}'+[port for SSE or streamable transport]:port' \
  '(-e --endpoint)'{-e,--endpoint}'+[endpoint (/sse for SSE, /mcp for streamable)]:endpoint' \
  '(-H --help)'{-H,--help}'[display help]' \
  '*::args:_default' && return 0
