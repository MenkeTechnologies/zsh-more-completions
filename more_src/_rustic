#compdef rustic

# Zsh completion for rustic - fast, encrypted, deduplicated backups

_rustic() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a global_flags=(
        '(-r --repository)'{-r,--repository}'=[repository to use]:repository:'
        '--repo-hot=[repository to use as hot storage]:repository:'
        '(-P --password)'{-P,--password}'=[repository password]:password:'
        '--password-file=[file to read the repository password from]:file:_files'
        '--password-command=[command to obtain the repository password]:command:'
        '--no-cache[do not use a local cache]'
        '--cache-dir=[set the cache directory]:directory:_directories'
        '(-v --verbose)'{-v,--verbose}'[be verbose (can be specified multiple times)]'
        '(-n --dry-run)'{-n,--dry-run}'[only show what would be done]'
        '--log-level=[set log level]:level:(off error warn info debug trace)'
    )

    local -a commands=(
        'backup:create a new backup'
        'cat:show the raw data of repository objects'
        'check:check the repository'
        'completions:generate shell completions'
        'config:show or change repository configuration'
        'copy:copy snapshots to another repository'
        'diff:compare two snapshots'
        'dump:dump the contents of a file in a snapshot to stdout'
        'forget:remove snapshots from the repository'
        'init:initialize a new repository'
        'key:manage keys'
        'list:list repository objects'
        'ls:list files in a snapshot'
        'merge:merge snapshots'
        'prune:remove unneeded data from the repository'
        'repair:repair the repository'
        'repoinfo:show general information about the repository'
        'restore:extract the data from a snapshot'
        'self-update:update rustic'
        'show-config:show the current configuration'
        'snapshots:list all snapshots'
        'tag:modify tags on snapshots'
    )

    _arguments -C \
        $global_flags \
        '(- *)'{-h,--help}'[show help]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'rustic command' commands
            ;;
        args)
            case $words[1] in
                backup)
                    _arguments -s -S \
                        $global_flags \
                        '*'{-e,--exclude}'=[exclude a pattern]:pattern:' \
                        '--exclude-caches[exclude cache directories]' \
                        '*--exclude-file=[read exclude patterns from file]:file:_files' \
                        '*--exclude-if-present=[exclude if file is present]:filename:' \
                        '--exclude-larger-than=[max file size to back up]:size:' \
                        '--stdin[read backup from stdin]' \
                        '--stdin-filename=[filename when reading from stdin]:filename:' \
                        '*--tag=[add tags to the snapshot]:tag:' \
                        '--host=[set the hostname]:hostname:_hosts' \
                        '--as-path=[set the backup path in the snapshot]:path:' \
                        '--with-atime[save access time for all files]' \
                        '--ignore-ctime[ignore ctime changes]' \
                        '--ignore-inode[ignore inode changes]' \
                        '(-x --one-file-system)'{-x,--one-file-system}'[exclude other file systems]' \
                        '*:file or directory:_files'
                    ;;
                cat)
                    _arguments -s -S \
                        $global_flags \
                        '1:type:(config index snapshot key tree blob)' \
                        '2:ID:'
                    ;;
                check)
                    _arguments -s -S \
                        $global_flags \
                        '--read-data[read all data blobs]' \
                        '--read-data-subset=[read a subset of data packs]:subset:'
                    ;;
                completions)
                    _arguments -s -S \
                        $global_flags \
                        '1:shell:(bash fish zsh powershell)'
                    ;;
                copy)
                    _arguments -s -S \
                        $global_flags \
                        '--init[initialize target repository if not initialized]' \
                        '*:snapshot ID:'
                    ;;
                diff)
                    _arguments -s -S \
                        $global_flags \
                        '--metadata[print changes in metadata]' \
                        '1:snapshot ID:' \
                        '2:snapshot ID:'
                    ;;
                dump)
                    _arguments -s -S \
                        $global_flags \
                        '1:snapshot ID:' \
                        '2:file path:'
                    ;;
                forget)
                    _arguments -s -S \
                        $global_flags \
                        '--keep-last=[keep last n snapshots]:number:' \
                        '--keep-hourly=[keep last n hourly snapshots]:number:' \
                        '--keep-daily=[keep last n daily snapshots]:number:' \
                        '--keep-weekly=[keep last n weekly snapshots]:number:' \
                        '--keep-monthly=[keep last n monthly snapshots]:number:' \
                        '--keep-yearly=[keep last n yearly snapshots]:number:' \
                        '--keep-within=[keep snapshots within duration]:duration:' \
                        '*--keep-tag=[keep snapshots with this tag]:tag:' \
                        '*--host=[only consider this host]:hostname:_hosts' \
                        '*--tag=[only consider this tag]:tag:' \
                        '--prune[also prune the repository]' \
                        '--group-by=[group by host, paths, and/or tags]:group:' \
                        '*:snapshot ID:'
                    ;;
                init)
                    _arguments -s -S \
                        $global_flags
                    ;;
                key)
                    local -a key_commands=(
                        'add:add a new key'
                        'list:list keys'
                        'remove:remove a key'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:key command:->keycmd'
                    case $state in
                        keycmd)
                            _describe -t key_commands 'key command' key_commands
                            ;;
                    esac
                    ;;
                list)
                    _arguments -s -S \
                        $global_flags \
                        '1:object type:(blobs packs index snapshots keys)'
                    ;;
                ls)
                    _arguments -s -S \
                        $global_flags \
                        '-l[use a long listing format]' \
                        '--recursive[include files in subdirectories]' \
                        '1:snapshot ID:' \
                        '2:path:'
                    ;;
                merge)
                    _arguments -s -S \
                        $global_flags \
                        '*:snapshot ID:'
                    ;;
                prune)
                    _arguments -s -S \
                        $global_flags \
                        '--max-repack-size=[maximum size to repack]:size:' \
                        '--max-unused=[tolerate given limit of unused data]:limit:'
                    ;;
                repair)
                    local -a repair_commands=(
                        'index:rebuild the index'
                        'snapshots:repair snapshots'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:repair command:->repaircmd'
                    case $state in
                        repaircmd)
                            _describe -t repair_commands 'repair command' repair_commands
                            ;;
                    esac
                    ;;
                repoinfo)
                    _arguments -s -S $global_flags
                    ;;
                restore)
                    _arguments -s -S \
                        $global_flags \
                        '*'{-e,--exclude}'=[exclude a pattern]:pattern:' \
                        '*--iexclude=[exclude pattern (case-insensitive)]:pattern:' \
                        '--verify[verify restored files]' \
                        '1:snapshot ID:' \
                        '2:target directory:_directories'
                    ;;
                self-update)
                    _arguments -s -S $global_flags
                    ;;
                show-config)
                    _arguments -s -S $global_flags
                    ;;
                snapshots)
                    _arguments -s -S \
                        $global_flags \
                        '--group-by=[group by host, paths, and/or tags]:group:' \
                        '*--host=[only consider this host]:hostname:_hosts' \
                        '*--tag=[only consider this tag]:tag:' \
                        '--long[use long listing format]' \
                        '*:snapshot ID:'
                    ;;
                tag)
                    _arguments -s -S \
                        $global_flags \
                        '*--add=[tags to add]:tag:' \
                        '*--remove=[tags to remove]:tag:' \
                        '--set=[tags to set]:tag:' \
                        '*:snapshot ID:'
                    ;;
                config)
                    _arguments -s -S $global_flags
                    ;;
            esac
            ;;
    esac
}

_rustic "$@"
