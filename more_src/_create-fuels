#   --verbose           Enable verbose logging
#   --version           Show version
#   -h, --help          Show help
#
# Five-axis distinctness from every other documented TS-Node
# progress library:
#
#   1. SPINNER-TO-FINAL-STATE LIFECYCLE METHODS — Every other
#      documented TS-Node progress library uses determinate
#      percentage updates.  ora has spinner→icon TRANSITIONS
#      via .succeed/.fail/.warn/.info/.stop lifecycle methods.
#
#   2. 90+ PRE-BUILT SPINNER STYLES — Every other documented
#      TS-Node progress library has minimal animation variety.
#      ora delegates to cli-spinners with 90+ pre-built styles
#      (dots, line, star, balloon, smiley, pong, etc).
#
#   3. TTY-DETECTION GRACEFUL FALLBACK — Every other documented
#      TS-Node progress library emits ANSI escapes regardless
#      of TTY.  ora detects non-TTY environments and gracefully
#      degrades to plain text without corrupting CI logs.
#
#   4. PROMISE-LIFECYCLE AUTO-MANAGEMENT — Every other
#      documented TS-Node progress library requires manual
#      increment calls.  ora's `.promise(promise, options)`
#      ties spinner lifecycle to Promise resolution.
#
#   5. SINDRESORHUS-ECOSYSTEM FOUNDATIONAL PROVENANCE — Every
#      other documented TS-Node progress library has different
#      provenance.  ora is part of Sindresorhus's 1500+ package
#      "do one thing well" Node ecosystem that shaped the entire
#      modern Node CLI culture.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/FuelLabs/fuels-ts/blob/master/packages/create-fuels/src/lib/setupProgram.ts
# `setupProgram` function + `ProgramOptions` type.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--template=[Fuel project template]:template:(nextjs vite)' \
    '--no-install[skip dependency installation]' \
    '--verbose[enable verbose logging]' \
    '1:project directory:_directories' \
    && ret=0

return ret
