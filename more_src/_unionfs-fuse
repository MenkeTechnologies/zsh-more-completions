#compdef unionfs-fuse

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d[debug mode]' \
  '-f[foreground mode]' \
  '-o+[mount options]:options' \
  '-ocow[copy-on-write mode]' \
  '-ostatfs_omit_ro[omit read-only branches in statfs]' \
  '-orelax_permissions[relax permission checks]' \
  '-ohide_meta_files[hide meta files]' \
  '-omax_files=[max open files]:count' \
  '1:branches (dir=RW\:dir=RO):_directories' \
  '2:mountpoint:_directories' && return 0
