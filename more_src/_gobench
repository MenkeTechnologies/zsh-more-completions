#compdef gobench
# Documentation: https://github.com/cmpxchg16/gobench
# gobench - HTTP/HTTPS load generator and benchmark tool

local ret=1

_arguments -s -S \
  '-u[URL]:url:_urls' \
  '-r[number of requests per client]:requests:' \
  '-c[number of concurrent clients]:clients:' \
  '-f[URLs file path (line separated)]:file:_files' \
  '-k[do HTTP keep-alive]:keepalive:(true false)' \
  '-d[HTTP POST data file path]:file:_files' \
  '-t[period of time in seconds]:seconds:' \
  '-tw[write timeout in milliseconds]:ms:' \
  '-tr[read timeout in milliseconds]:ms:' \
  '-auth[Authorization header]:header:' && ret=0

return ret
