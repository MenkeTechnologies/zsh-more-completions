#compdef algokey
# _algokey — Algorand algokey CLI for Algorand account key management generate import export sign multisig and rekey operations using Ed25519 keys (algorand team, Go); cobra
# upstream: https://github.com/algorand/go-algorand

_algokey() {
    local -a sub=(
        'generate:generate new account'
        'import:import mnemonic'
        'export:export account'
        'multisig:multisig operations'
        'part:participation key operations'
        'sign:sign a transaction'
        'sign-program:sign a program'
        'tealsign:sign for TEAL'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'algokey subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments \
                    '-f+[outfile]:file:_files' \
                    '-p+[pubout]:file:_files' ;;
                import) _arguments \
                    '-m+[mnemonic]:str:' \
                    '-f+[outfile]:file:_files' ;;
                export) _arguments \
                    '-f+[keyfile]:file:_files' ;;
                multisig) _arguments \
                    '1:action:(append-auth-addr)' \
                    '-t+[txfile]:file:_files' \
                    '-a+[auth addr]:str:' \
                    '-o+[outfile]:file:_files' ;;
                part) _arguments \
                    '1:action:(generate keyreg info reparent)' \
                    '--first=+[round]:n:' \
                    '--last=+[round]:n:' \
                    '--parent=+[addr]:str:' \
                    '--keyfile=+[file]:file:_files' \
                    '--outfile=+[file]:file:_files' ;;
                sign|sign-program) _arguments \
                    '-t+[txfile]:file:_files' \
                    '-o+[outfile]:file:_files' \
                    '-m+[mnemonic]:str:' \
                    '-k+[keyfile]:file:_files' ;;
                tealsign) _arguments \
                    '--data-file=+[file]:file:_files' \
                    '--contract-addr=+[addr]:str:' \
                    '--lsig-file=+[file]:file:_files' ;;
            esac
            ;;
    esac
}

_algokey "$@"
