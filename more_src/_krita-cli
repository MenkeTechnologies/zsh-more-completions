#compdef krita

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--canvasonly[start in canvas-only mode]' \
  '--fullscreen[start in fullscreen]' \
  '--nosplash[disable splash screen]' \
  '--workspace=[load workspace]:w:' \
  '--export[export to specified format]' \
  '--export-filename=[export filename]:file:_files' \
  '--export-sequence[export animation as sequence]' \
  '--file-layer=[load file as layer]:file:_files' \
  '--template=[load template]:t:' \
  '--new-image=[create new image]:s:' \
  '--no-mlt[disable MLT]' \
  '--no-pyqt[no PyQt]' \
  '--debug-eventfilters[debug event filters]' \
  '--debug-events[debug events]' \
  '--debug-resourceloading[debug resource loading]' \
  '*: :_files -g "*.kra *.png *.jpg *.jpeg *.tiff *.tif *.bmp *.psd *.xcf *.svg *.tga *.exr *.webp"' && ret=0

return ret
