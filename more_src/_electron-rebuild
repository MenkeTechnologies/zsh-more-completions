#compdef electron-rebuild

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-e+,--electron-prebuilt-dir=}'[electron-prebuilt directory]:dir:_files -/' \
  {-m+,--module-dir=}'[application directory]:dir:_files -/' \
  {-w+,--which-module=}'[only build specified module(s)]:modules:' \
  {-o+,--only=}'[only build specified module(s)]:modules:' \
  '--types=[only rebuild for these types]:types:(prod dev optional)' \
  {-a+,--arch=}'[target architecture]:arch:(ia32 x64 armv7l arm64)' \
  {-d,--debug}'[build native modules in debug mode]' \
  {-f,--force}'[force rebuild]' \
  {-p,--parallel}'[rebuild modules in parallel]' \
  {-s,--sequential}'[rebuild modules sequentially]' \
  {-b,--build-from-source}'[force build from source]' \
  '--prebuild-tag-prefix=[prebuild-install tag prefix]:prefix:' \
  '--use-electron-clang[use the same Clang Electron used]' \
  {-t+,--target=}'[Electron version to rebuild against]:version:' \
  '--useCache[use prebuilt-binary cache]' && ret=0

return ret
