#compdef electron-rebuild
# Documentation: https://github.com/electron/rebuild
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[Electron version to build against]:version:' \
  {-e+,--electron-prebuilt-dir=}'[path to prebuilt electron module]:dir:_files -/' \
  {-m+,--module-dir=}'[path to node_modules directory]:dir:_files -/' \
  {-w+,--which-module=}'[only build specified module(s)]:modules:' \
  {-o+,--only=}'[only build specified module(s)]:modules:' \
  {-t+,--types=}'[types of dependencies to rebuild]:types:(prod dev optional)' \
  {-a+,--arch=}'[target architecture]:arch:(ia32 x64 armv7l arm64)' \
  {-b,--debug}'[build debug version of modules]' \
  {-f,--force}'[force rebuild even if skip is possible]' \
  {-p,--parallel}'[rebuild modules in parallel]' \
  {-s,--sequential}'[rebuild modules sequentially]' \
  {-d+,--dist-url=}'[custom header tarball URL]:url:' \
  '--prebuild-tag-prefix=[GitHub tag prefix for prebuild-install]:prefix:' \
  '--force-abi=[override ABI version for Electron]:abi:' \
  '--use-electron-clang[use Clang executable Electron used to build]' \
  '--disable-pre-gyp-copy[disable pre-gyp copy step]' \
  '--build-from-source[skip prebuild download and rebuild from source]' && ret=0

return ret
