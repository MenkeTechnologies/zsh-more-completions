#compdef tiged

# Zsh completion for tiged - community fork of degit

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--mode=[clone mode]:mode:(tar git)' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-f --force)'{-f,--force}'[overwrite existing files]' \
  '--disable-cache[disable caching]' \
  '--sub-directory=[subdirectory within repo]:subdirectory:' \
  '1:repo path (user/repo):' \
  '2:destination:_directories'
