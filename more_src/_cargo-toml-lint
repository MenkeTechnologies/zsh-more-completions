#compdef cargo-toml-lint
# _cargo-toml-lint — lint Cargo.toml files (FuelLabs/cargo-toml-lint)
# upstream: https://github.com/FuelLabs/cargo-toml-lint
# Flags from src/main.rs (clap).

_cargo-toml-lint() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--no-cargo-verify[skip cargo-based verification]' \
        '(-D --sort-dependencies)'{-D+,--sort-dependencies=}'[dependency sort]:mode:(none section strict)' \
        '(-T --sort-tests)'{-T+,--sort-tests=}'[sort [[test]] by name]:mode:(enabled disabled)' \
        '(-A --contiguous-object-arrays)'{-A+,--contiguous-object-arrays=}'[group arrays of objects]:mode:(enabled disabled)' \
        '(-N --single-end-of-line)'{-N+,--single-end-of-line=}'[exactly one EOL at EOF]:mode:(enabled disabled)' \
        '(-E --no-trailing-whitespace)'{-E+,--no-trailing-whitespace=}'[no trailing whitespace]:mode:(enabled disabled)' \
        '1:Cargo.toml:_files -g "*.toml"'
}

_cargo-toml-lint "$@"
