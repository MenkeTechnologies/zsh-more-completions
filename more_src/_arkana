#compdef arkana
# _arkana — Rogerluan Arkana iOS encrypted secrets generator CLI (Roger Oba / rogerluan, Ruby); custom argparse
# upstream: https://github.com/rogerluan/arkana

_arkana() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config-filepath=+[config file]:file:_files -g "*.yml *.yaml"' \
        '-c+[config file]:file:_files -g "*.yml *.yaml"' \
        '--env-filepath=+[env file]:file:_files' \
        '-e+[env file]:file:_files' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '*:arg:'
}

_arkana "$@"
