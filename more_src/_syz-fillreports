#compdef syz-fillreports
# _syz-fillreports — backfill missing crash reports on the syzkaller dashboard (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-fillreports/fillreports.go (flag).

_syz-fillreports() {
    _arguments \
        '-dashboard=[dashboard address]:url:_urls' \
        '-client=[API client name]:name:' \
        '-key=[API key]:key:'
}

_syz-fillreports "$@"
