#compdef sefilter
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/sefilter.txt
# Generates filtering expressions for XTE science event FITS files

local ret=1

_arguments -s \
  '-h[display help information]' \
  '-c[enable chatty behavior with detailed updates]' \
  '*:file:_files' && ret=0

return ret
