#compdef vcf2fasta
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcf2fasta.md
# vcflib: generate per-sample FASTA files from a VCF and a reference

local ret=1

_arguments -s -S \
  '(-f --reference)'{-f,--reference}'[use this reference when decomposing samples]:reference:_files' \
  '(-p --prefix)'{-p,--prefix}'[affix this output prefix to each file]:prefix' \
  '(-P --default-ploidy)'{-P,--default-ploidy}'[set a default ploidy for samples lacking info in first record (2)]:N' \
  '-n[set string value to output for missing calls]:value' \
  '*:vcf file:_files' && ret=0

return ret
