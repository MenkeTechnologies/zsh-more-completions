#compdef purr
# Documentation: https://github.com/google/purr/blob/main/README.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for purr Android logcat TUI (google/purr)

local ret=1
_arguments -s -S \
  '-a+[custom adb parameters]:adb args:' \
  '-f+[custom fzf parameters]:fzf args:' \
  '-i[disable instruction preview on launch]' \
  '-q+[default query string]:query:' \
  '-v[show purr version]' \
  '-V[show composite version of purr and dependencies]' \
  '-A+[replace adb with given binary (testing)]:binary:_command_names -e' \
  '-D+[directory for generated files (testing)]:dir:_files -/' \
  '-X[do not execute fzf (testing)]' && ret=0

return ret
