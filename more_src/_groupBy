#compdef groupBy
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/groupby.html
# summarize a dataset by groups of columns (bedtools groupby)

local ret=1

_arguments -s -S \
  '-i[input file to group and summarize]:file:_files' \
  '(-g -grp)'{-g,-grp}'[columns (1-based) to group by]:columns' \
  '(-c -opCol)'{-c,-opCol}'[column (1-based) to summarize]:columns' \
  '(-o -op)'{-o,-op}'[operation to apply to opCol]:operation' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
