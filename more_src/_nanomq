#compdef nanomq
# Documentation: https://nanomq.io/docs/en/latest/toolkit/command-line.html
# nanomq - ultra-lightweight and blazing-fast MQTT broker for IoT edge

local ret=1
local -a cmds

cmds=(
  'start:start the broker'
  'stop:stop the broker'
  'restart:restart the broker'
  'reload:reload the broker configuration'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--conf[configuration file path]:file:_files' \
  '--url[listener URL (nmq-tcp, tls+nmq-tcp, nmq-ws, nmq-wss)]:url:' \
  '--http[enable HTTP server]:bool:(true false)' \
  '(-p --port)'{-p,--port}'[HTTP server port]:port:' \
  '(-t --tq_thread)'{-t,--tq_thread}'[taskq thread count]:n:' \
  '(-T --max_tq_thread)'{-T,--max_tq_thread}'[maximum taskq threads]:n:' \
  '(-n --parallel)'{-n,--parallel}'[outstanding request capacity]:n:' \
  '(-s --property_size)'{-s,--property_size}'[max MQTT user property size]:n:' \
  '(-S --msq_len)'{-S,--msq_len}'[resend message queue length]:n:' \
  '(-D --qos_duration)'{-D,--qos_duration}'[QoS timer interval]:n:' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]:bool:(true false)' \
  '--cacert[CA certificate file]:file:_files' \
  '--cert[certificate file]:file:_files' \
  '--key[private key file]:file:_files' \
  '--keypass[private key password]:password:' \
  '--verify[enable peer certificate verification]' \
  '--fail[fail if no peer certificate]' \
  '--log_level[log level]:level:(trace debug info warn error fatal)' \
  '--log_file[log file path]:file:_files' \
  '--log_stdout[log to stdout]:bool:(true false)' \
  '--log_syslog[log to syslog]:bool:(true false)' \
  '1:command:->cmd' && ret=0

case $state in
  cmd) _describe -t commands 'nanomq command' cmds && ret=0 ;;
esac

return ret
