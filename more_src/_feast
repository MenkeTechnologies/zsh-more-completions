#compdef feast

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'apply:create or update infrastructure for the feature store'
  'configuration:show the current Feast configuration'
  'data-sources:manage data sources'
  'definitions:show feature definitions'
  'delete:delete a feature store object'
  'endpoint:show the registered endpoint'
  'entities:manage entities'
  'feature-services:manage feature services'
  'feature-views:manage feature views'
  'init:initialize a new feature repository'
  'listen:start the feature server (deprecated)'
  'materialize:materialize features to the online store'
  'materialize-incremental:incrementally materialize features'
  'on-demand-feature-views:manage on-demand feature views'
  'permissions:manage permissions'
  'plan:show planned changes'
  'push:push features to the online store'
  'registry-dump:dump the feature store registry'
  'repo-upgrade:upgrade the feature repo schema'
  'saved-datasets:manage saved datasets'
  'serve:start the feature server'
  'serve-offline:start the offline feature server'
  'serve-transformations:start the transformations server'
  'stream-feature-views:manage stream feature views'
  'teardown:tear down feature store infrastructure'
  'ui:start the Feast UI'
  'validation-references:manage validation references'
  'version:show Feast version'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-c --chdir)'{-c,--chdir=}'[change to directory before running]:dir:_files -/' \
  '--feature-store-yaml=[feature_store.yaml path]:file:_files' \
  '--log-level=[log level]:level:(DEBUG INFO WARN ERROR FATAL)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'feast subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (entities|feature-views|feature-services|data-sources|on-demand-feature-views|stream-feature-views|saved-datasets|validation-references|permissions)
        _values 'action' 'list' 'describe' && ret=0
        ;;
    esac
    ;;
esac

return ret
