#compdef git-appraise
# Documentation: https://github.com/google/git-appraise
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git-appraise - distributed code reviews (Google)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'request:request a code review'
      'push:push code reviews to a remote'
      'pull:pull code reviews from a remote'
      'list:list open code reviews'
      'show:show the current review status'
      'comment:comment on a review'
      'accept:accept the changes in a review'
      'submit:submit the current review'
      'abandon:abandon a review'
      'rebase:rebase the current review branch'
      'reject:reject the current review'
      'help:show help'
    )
    _describe -t commands 'git-appraise command' commands && ret=0
    ;;
  args)
    case $line[1] in
      show)
        _arguments -s -S \
          '--diff[show the diff]' \
          '--diff-opts=[options forwarded to git diff]:opts' \
          '1:review hash:' && ret=0
        ;;
      comment)
        _arguments -s -S \
          '-m+[comment message]:message' \
          '-f+[file]:file:_files' \
          '-l+[line number]:line' \
          '1:review hash:' && ret=0
        ;;
      accept)
        _arguments -s -S \
          '-m+[approval message]:message' \
          '1:review hash:' && ret=0
        ;;
      submit)
        _arguments -s -S \
          '--merge[use git merge]' \
          '--rebase[use git rebase]' && ret=0
        ;;
    esac
    ;;
esac

return ret
