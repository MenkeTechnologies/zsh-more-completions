#compdef MergeSamFiles
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/MergeSamFiles.java
# Picard: merge multiple SAM/BAM/CRAM files into one

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-I,--INPUT}'=[input SAM/BAM/CRAM file]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[merged output file]:file:_files' \
  '(-SO --SORT_ORDER)'{-SO,--SORT_ORDER}'=[output sort order]:order:(coordinate queryname unsorted duplicate)' \
  '(-AS --ASSUME_SORTED)'{-AS,--ASSUME_SORTED}'=[assume inputs match requested sort order]:b:(true false)' \
  '(-MSD --MERGE_SEQUENCE_DICTIONARIES)'{-MSD,--MERGE_SEQUENCE_DICTIONARIES}'=[merge sequence dictionaries]:b:(true false)' \
  '--USE_THREADING=[enable background threading for encoding]:b:(true false)' \
  '(-CO --COMMENT)'{-CO,--COMMENT}'=[header comment]:co:' \
  '(-RGN --INTERVALS)'{-RGN,--INTERVALS}'=[interval list of regions to merge]:file:_files' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
