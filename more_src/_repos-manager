#compdef repos-manager
# Source: https://github.com/cirocosta/repos-manager/blob/ac97daf42512906b8cef743e7d4a81c210019889/autocomplete/_repos-manager
# Repository: cirocosta/repos-manager (autocomplete/_repos-manager)
# vim: set syntax=zsh

# to have the completition working, this file
# must be added to zsh's fpath. To do so, in
# your ~/.zshrc add:
#
#   repos_manager_dir=$(readlink $(which repos-manager))
#   fpath=($repos_manager_dir/autocomplete/ $fpath)

_repos-manager () {
  local -a commands
  commands=("${(@f)$(repos-manager compl "$input")}")

  if (( CURRENT == 2)); then
    _describe -t commands 'commands' commands
  fi

  return 0
}

_repos-manager

