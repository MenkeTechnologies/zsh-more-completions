#compdef repos-manager
# Documentation: https://github.com/cirocosta/repos-manager
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above.

# Zsh completion for repos-manager (GitHub organization bulk repo helper).

_repos-manager() {
  local curcontext="$curcontext" state line ret=1
  local -a commands=(
    'show:show repositories and their HEADs'
    'clone:clone all repositories to {ORGANIZATION}_TIMESTAMP'
    'sync-all:fetch from upstream and rebase on master for every repository'
    'fetch:(experimental) fetch latest revisions of each repository'
    'checkout:(experimental) git checkout each repository to a given tag'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'repos-manager command' commands && ret=0
      ;;
    args)
      case ${line[1]} in
        clone)
          _arguments '--shallow[shallow clone with depth 1]' && ret=0
          ;;
        checkout)
          _arguments '1:tag:' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_repos-manager "$@"
