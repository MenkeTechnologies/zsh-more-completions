#compdef tte

local curcontext="$curcontext" state line ret=1

local -a effects=(
  'beams:create beams of light that travel across the terminal'
  'binarypath:display binary strings flowing through the terminal'
  'blackhole:characters are pulled into a black hole'
  'bouncyballs:characters bounce around the terminal like balls'
  'bubbles:characters float upward like bubbles'
  'burn:characters burn away with a fire effect'
  'colorshift:shift through colors across the terminal'
  'crumble:characters crumble apart'
  'decrypt:text appears to be decrypted character by character'
  'errorcorrect:text is corrected character by character'
  'expand:text expands outward from the center'
  'fireworks:characters launch and explode like fireworks'
  'middleout:text appears from the middle outward'
  'orbittingvolley:characters orbit around the terminal'
  'overflow:text overflows from the edges'
  'pour:characters pour down like liquid'
  'print:text is printed character by character'
  'rain:characters rain down the terminal'
  'randomsequence:text appears in random order'
  'rings:characters appear in expanding rings'
  'scattered:characters scatter and reform'
  'slide:text slides in from a direction'
  'spotlights:characters are illuminated by spotlights'
  'spray:characters spray across the terminal'
  'swarm:characters swarm into position'
  'synthgrid:display a synthwave grid effect'
  'unstable:text appears with an unstable glitch effect'
  'vhstape:text appears with VHS tape artifacts'
  'waves:text flows with a wave animation'
  'wipe:text appears with a wipe transition'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--input-file[read input from file]:file:_files' \
  '--xterm-colors[convert output colors to xterm-256]' \
  '--no-color[disable color output]' \
  '--tab-width[set tab width]:width:' \
  '--wrap-text[wrap text at terminal width]' \
  '--frame-rate[set animation frame rate]:fps:' \
  '--no-wrap[disable text wrapping]' \
  '1:effect:->effect' \
  '*::effect args:->effect-args' && ret=0

case $state in
  (effect)
    _describe -t effects 'effect' effects && ret=0
    ;;
  (effect-args)
    _arguments \
      '--animation-rate[animation speed multiplier]:rate:' \
      '--movement-speed[character movement speed]:speed:' \
      '--easing[easing function]:easing:(linear ease-in ease-out ease-in-out)' \
      '--color-single[use a single color]:color:' \
      '--color-gradient[use a color gradient]:colors:' \
      '--final-color-single[final resting color]:color:' \
      '--final-color-gradient[final resting gradient]:colors:' && ret=0
    ;;
esac

return ret
