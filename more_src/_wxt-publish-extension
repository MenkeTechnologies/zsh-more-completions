#compdef wxt-publish-extension
# Documentation: https://github.com/aklinker1/publish-browser-extension
# Reference accessed: 2026-05-23
# Verified: npm view wxt bin; publish-browser-extension README at https://github.com/aklinker1/publish-browser-extension.

# Zsh completion for wxt-publish-extension - publish extensions to browser stores

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize secrets and options for each store'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show version]'   '--dry-run[check authentication without uploading]'   '--chrome-zip=[Chrome extension zip path]:file:_files'   '--chrome-extension-id=[Chrome Web Store extension ID]:id:'   '--chrome-client-id=[Chrome Web Store OAuth client ID]:id:'   '--chrome-client-secret=[Chrome Web Store OAuth client secret]:secret:'   '--chrome-refresh-token=[Chrome Web Store OAuth refresh token]:token:'   '--chrome-publish-target=[Chrome publish target]:target:(default trustedTesters)'   '--chrome-deploy-percentage=[Chrome deploy percentage 1-100]:percent:'   '--chrome-review-exemption[use expedited Chrome review process]'   '--chrome-skip-submit-review[upload Chrome zip without submitting for review]'   '--firefox-zip=[Firefox extension zip path]:file:_files'   '--firefox-sources-zip=[Firefox sources zip path]:file:_files'   '--firefox-extension-id=[Firefox Add-ons extension ID]:id:'   '--firefox-jwt-issuer=[Firefox Add-ons JWT issuer]:issuer:'   '--firefox-jwt-secret=[Firefox Add-ons JWT secret]:secret:'   '--firefox-channel=[Firefox publish channel]:channel:(listed unlisted)'   '--edge-zip=[Edge extension zip path]:file:_files'   '--edge-product-id=[Edge product ID]:id:'   '--edge-client-id=[Edge OAuth client ID]:id:'   '--edge-api-key=[Edge API key]:key:'   '--edge-client-secret=[Edge OAuth client secret (deprecated)]:secret:'   '--edge-access-token-url=[Edge access token URL (deprecated)]:url:'   '--edge-skip-submit-review[upload Edge zip without submitting for review]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'wxt-publish-extension command' commands && ret=0
    ;;
  (args)
    _arguments '*::args:' && ret=0
    ;;
esac

return ret
