#compdef filename
# _filename — print/transform parts of file paths (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from filename.c (single-letter getopt-style).

_filename() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-/[keep one more directory in path]' \
        '-e[append newline after each name]' \
        '-n[prepend directory to name with .]' \
        '-r[return root of filename (no extension)]' \
        '-v[verbose output]' \
        '*:file path:_files'
}

_filename "$@"
