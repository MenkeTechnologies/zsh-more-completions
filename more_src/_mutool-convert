#compdef mutool-convert
# Documentation: https://man.archlinux.org/man/mutool.1.en
# Convert a document from one format to another (mutool convert)

local ret=1

_arguments -s -S \
  '-p[password for an encrypted file]:password:' \
  '-b[use named page box]:box:(MediaBox CropBox BleedBox TrimBox ArtBox)' \
  '-A[anti-aliasing bits to use (default 8)]:bits:' \
  '-W[page width in points for EPUB layout]:width:' \
  '-H[page height in points for EPUB layout]:height:' \
  '-S[font size in points for EPUB layout]:size:' \
  '-U[user CSS stylesheet for EPUB layout]:css file:_files -g "*.css"' \
  '-o[output filename (%d for page numbers)]:output:_files' \
  '-F[enforce output format when using stdout]:format:' \
  '-O[comma separated list of output options]:options:' \
  '1:input file:_files' \
  '2:pages:' && ret=0

return ret
