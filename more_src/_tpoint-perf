#compdef tpoint-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/tpoint.8
# trace a given tracepoint, static tracing (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-d+[trace duration in seconds, use buffers]:secs' \
  '-p+[PID to match on event]:pid:_pids' \
  '-L+[thread ID to match on event]:tid' \
  '-v[view format file, do not trace]' \
  '-H[include column headers]' \
  '-l[list all tracepoints]' \
  '-s[show kernel stack traces]' \
  '1:tracepoint:' \
  '2:filter:' && ret=0

return ret
