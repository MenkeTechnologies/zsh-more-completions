#compdef fennel-ls
# Documentation: https://github.com/sourcehut-mirrors/fennel-ls/blob/main/docs/manual.md
# fennel-ls - a language server for the Fennel programming language

local ret=1

_arguments -s -S \
  '--help[display usage information]' \
  '--lint[print diagnostics for the files given]:*:fnl file:_files -g "*.fnl"' \
  '--fix[apply suggested fixes from linters to files]' \
  '-y[automatically confirm fixes]' \
  '*:fnl file:_files -g "*.fnl"' && ret=0

return ret
