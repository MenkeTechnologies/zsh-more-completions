#compdef actool
# Documentation: https://keith.github.io/xcode-man-pages/actool.1.html
# Source: Apple Xcode — Asset Catalog Tool (compiles .xcassets / .stickerpack into .car).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--output-format=[output format]:fmt:(binary1 xml1 human-readable-text)' \
    '--compile=[compile and write to directory]:dir:_directories' \
    '--warnings[include warnings in plist output]' \
    '--errors[include errors in plist output]' \
    '--notices[include notices in plist output]' \
    '--output-partial-info-plist=[emit partial Info.plist keys/values]:file:_files' \
    '--app-icon=[primary app icon to compile]:icon name:' \
    '--include-all-app-icons[include all app icon assets from named catalogs]' \
    '*--alternate-app-icon=[additional app icon set name]:name:' \
    '--launch-image=[launch image to compile to output directory]:name:' \
    '--accent-color=[target primary accent/tint color]:name:' \
    '--widget-background-color=[widget background color]:name:' \
    '--skip-app-store-deployment[skip App Store-specific behaviors]' \
    '*--include-language=[only include this language]:lang:' \
    '--include-partial-info-plist-localizations[include localization info in partial Info.plist]' \
    '--platform=[target platform]:platform:(iphoneos iphonesimulator macosx appletvos appletvsimulator watchos watchsimulator driverkit xros xrsimulator)' \
    '--minimum-deployment-target=[minimum deployment-target version]:version:' \
    '--standalone-icon-behavior=[loose PNG/ICNS creation]:behavior:(default all none)' \
    '*--target-device=[target device]:device:(iphone ipad mac tv watch carplay)' \
    '--compress-pngs[optimize PNGs for iOS with pngcrush]' \
    '--filter-for-device-model=[filter CAR by device model]:model:' \
    '--filter-for-device-os-version=[filter CAR by OS version]:version:' \
    '--include-sticker-content[include sticker pack content]' \
    '--stickers-icon-role=[icon sizes for Messages-style app icon]:role:(host extension)' \
    '--sticker-pack-identifier-prefix=[sticker pack identifier prefix]:prefix:' \
    '--sticker-pack-strings-file=[localized sticker name strings]:.strings:_files' \
    '--product-type=[product type (deprecated)]:type:' \
    '--enable-on-demand-resources=-[process on-demand resources]:flag:(YES NO)' \
    '--asset-pack-output-specifications=[ODR specifications output]:file:_files' \
    '--print-contents[include catalog content listing]' \
    '(- *)--version[print actool version]' \
    '*:.xcassets / catalog:_files -g "*.(xcassets|stickerpack|stickersiconset)"' \
    && ret=0

return ret
