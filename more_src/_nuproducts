#compdef nuproducts
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/nuproducts.html
# Extract NuSTAR high-level products (light curves, spectra, ARF, RMF)

local ret=1

_arguments -s -S \
  'srcra=[source RA degrees or hh mm ss.s]:srcra:' \
  'srcdec=[source DEC degrees or dd mm ss.s]:srcdec:' \
  'bkgra=[background region center RA]:bkgra:' \
  'bkgdec=[background region center DEC]:bkgdec:' \
  'indir=[input data directory]:indir:_files -/' \
  'outdir=[output products directory]:outdir:_files -/' \
  'instrument=[focal plane module]:instrument:(FPMA FPMB)' \
  'steminputs=[input file name stem]:steminputs:' \
  'srcregionfile=[source region file or DEFAULT]:srcregionfile:_files' \
  'bkgregionfile=[background region file or DEFAULT]:bkgregionfile:_files' \
  'bkgextract=[extract background products]:bkgextract:(yes no)' \
  'srcradius=[circular source region radius pixels]:srcradius:' \
  'bkgradius1=[background annulus inner radius]:bkgradius1:' \
  'bkgradius2=[background annulus outer radius]:bkgradius2:' \
  'binsize=[light curve time bin size seconds]:binsize:' \
  'pilow=[minimum PI channel]:pilow:' \
  'pihigh=[maximum PI channel]:pihigh:' \
  'correctlc=[apply livetime and PSF corrections]:correctlc:(yes no)' \
  'runmkarf=[generate ARF]:runmkarf:(yes no)' \
  'runmkrmf=[generate RMF]:runmkrmf:(yes no)' \
  'barycorr=[apply barycenter time correction]:barycorr:(yes no)' \
  'plotdevice=[output plot format]:plotdevice:(gif ps)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:file:_files' && ret=0

return ret
