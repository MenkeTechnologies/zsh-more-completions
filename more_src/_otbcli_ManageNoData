#compdef otbcli_ManageNoData
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ManageNoData.html
# Orfeo ToolBox: build, change or apply no-data masks on an image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image file]:image:_files' \
  '-out[output image file]:output:_files' \
  '-usenan[treat NaN values as no-data]:bool:(true false)' \
  '-mode[processing mode]:mode:(buildmask changevalue apply)' \
  '-mode.buildmask.inv[output mask value for non no-data pixels]:value:' \
  '-mode.buildmask.outv[output mask value for no-data pixels]:value:' \
  '-mode.changevalue.newv[the new no-data value]:value:' \
  '-mode.apply.mask[mask image to apply]:image:_files' \
  '-mode.apply.ndval[no-data value used with the mask]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
