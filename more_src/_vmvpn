#compdef vmvpn
# Documentation: https://github.com/carrerfe/vm-vpn
# Reference accessed: 2026-05-17
# Verified: carrerfe/vm-vpn upstream script. vmvpn is a Lima-VM wrapper
# that runs FortiClient VPN inside a VM. Subcommand list from the
# script's usage() function.
# Removed from prior file: bogus man.archlinux.org search URL;
# the entire prior file was the upstream vmvpn shell script embedded
# verbatim (a generator bug — not a zsh completion at all).

# vmvpn: VM-based VPN CLI (FortiClient in Lima VM)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'start:create and start the VM'
  'stop:stop the VM'
  'restart:restart the VM'
  'shell:open a shell in the VM'
  'ssh:connect via SSH'
  'status:show VM status'
  'delete:delete the VM completely'
  'vpn-connect:connect to VPN (auto-starts VM and proxies)'
  'vpn-disconnect:disconnect from VPN'
  'vpn-status:show VPN and proxy status'
  'firefox:launch Firefox with VPN proxy profile'
  'firefox-profile:show Firefox profile info'
  'completion:generate shell completion script'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vmvpn command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (completion) _values 'shell' 'bash' 'zsh' && ret=0 ;;
    esac
    ;;
esac
return ret
