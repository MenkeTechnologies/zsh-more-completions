#compdef ceph-deploy

# ceph-deploy: legacy Ceph cluster deployment tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'new:start new ceph cluster'
  'install:install ceph packages'
  'rgw:radosgw management'
  'mgr:mgr management'
  'mds:mds management'
  'mon:mon management'
  'gatherkeys:gather authentication keys'
  'disk:disk management'
  'osd:osd management'
  'admin:push config + admin key to remote'
  'config:push config to remote'
  'uninstall:uninstall ceph'
  'purge:purge ceph from a host'
  'purgedata:purge ceph data from a host'
  'forgetkeys:remove auth keys from local dir'
  'pkg:package install/remove on remote'
  'calamari:calamari'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '--ceph-conf=[ceph.conf to use]:file:_files -g "*.conf"' \
  '--overwrite-conf[overwrite remote ceph.conf]' \
  '--username=[remote username]:user:_users' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ceph-deploy command' commands && ret=0 ;;
esac
return ret
