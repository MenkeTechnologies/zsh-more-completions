#compdef sling
# Documentation: https://man.archlinux.org/search?q=sling
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:execute a data extract and load operation'
  'conns:manage and inspect connections'
  'project:project commands'
  'hub:Sling Hub utilities'
  'update:update sling to the latest version'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[verbose debug output]' \
  '-d[verbose debug output]' \
  '-t[trace output]' \
  '--trace[trace output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sling command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-r --replication)'{-r+,--replication=}'[replication YAML file]:file:_files -g "*.{yaml,yml}"' \
          '(-c --config)'{-c+,--config=}'[task config file]:file:_files' \
          '--src-conn=[source connection name]:connection:' \
          '--src-stream=[source stream/table/query]:stream:' \
          '--src-options=[source options (JSON/YAML)]:options:' \
          '--tgt-conn=[target connection name]:connection:' \
          '--tgt-object=[target table/file path]:object:' \
          '--tgt-options=[target options (JSON/YAML)]:options:' \
          '--select=[column selection/exclusion]:cols:' \
          '--mode=[load mode]:mode:(full-refresh truncate incremental snapshot backfill)' \
          '--primary-key=[primary key column(s)]:keys:' \
          '--update-key=[update key column]:key:' \
          '--limit=[max rows to load]:n:' \
          '--range=[backfill range]:range:' \
          '--columns=[column type casts (k=v)]:cols:' \
          '--transforms=[built-in transforms]:transforms:' \
          '--streams=[specific streams to run]:streams:' \
          '--stdout[output to stdout]' \
          '--env=[env file]:file:_files' && ret=0 ;;
      (conns)
        local -a conn_subs=(
          'set:create or update a connection'
          'list:list all connections'
          'discover:list streams available on a connection'
          'test:test a connection'
          'unset:delete a connection'
          'exec:execute SQL on a connection'
        )
        _describe -t ccmds 'conns subcommand' conn_subs && ret=0 ;;
      (project)
        _arguments '*::sub:(init list)' && ret=0 ;;
      (hub)
        _arguments '*::sub:(login logout list pull push)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
