#compdef flatpak-builder

# Zsh completion for flatpak-builder - build flatpak applications

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--arch[target architecture]:arch' \
  '--ccache[use ccache]' \
  '--delete-build-dirs[delete build dirs after build]' \
  '--disable-cache[disable build cache]' \
  '--disable-download[disable downloading sources]' \
  '--disable-updates[disable updating sources]' \
  '--disable-rofiles-fuse[disable rofiles-fuse]' \
  '--download-only[only download sources]' \
  '--build-only[stop after build phase]' \
  '--finish-only[run finish commands only]' \
  '--export-only[only export build]' \
  '--force-clean[erase previous build directory]' \
  '--from-git[build from git repository]:url' \
  '--from-git-branch[branch to use]:branch' \
  '--gpg-sign[GPG sign]:key id' \
  '--install[install after build]' \
  '--install-deps-from[install dependencies from repo]:repo' \
  '--keep-build-dirs[keep build dirs after build]' \
  '--mirror-screenshots-url[mirror screenshots URL]:url' \
  '--no-shallow-clone[disable shallow clones]' \
  '--rebuild-on-sdk-change[rebuild if SDK changes]' \
  '--repo[repository to export to]:directory:_files -/' \
  '--require-changes[only build if sources changed]' \
  '--run[run command in build environment]:command' \
  '--sandbox[run build sandboxed]' \
  '--show-deps[show build dependencies]' \
  '--show-manifest[show manifest]' \
  '--state-dir[state directory]:directory:_files -/' \
  '--stop-at[stop at module]:module' \
  '--subject[commit subject]:subject' \
  '--user[use user installation]' \
  '1:build directory:_files -/' \
  '2:manifest file:_files -g "*.(json|yaml|yml)"'
