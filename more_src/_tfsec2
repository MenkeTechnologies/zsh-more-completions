#compdef tfsec2
# _tfsec2 — Aqua Security AquaSecurity tfsec2 CLI command-line frontend wrapping the tfsec security scanner for your Terraform code open-source written in Go that uses static analysis of your terraform templates to spot potential security issues additional-framework-customisable-custom-rules-OPA-Rego-JSON CIS-AWS-GCP-Azure-benchmarks include-passed include-ignored exclude excluded-paths checks-config minimum-severity force-all-dirs JSON-CSV-junit-sarif-checkstyle-template-output (Aqua Security AquaSecurity team, Go); cobra
# upstream: https://github.com/aquasecurity/tfsec

_tfsec2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--concise-output[concise output]' \
        '--config-file=+[file]:file:_files -g "*.yml *.yaml *.json"' \
        '--config-file-url=+[url]:str:' \
        '--custom-check-dir=+[dir]:dir:_files -/' \
        '-e+[exclude]:str:' \
        '--exclude=+[ids]:str:' \
        '*-e+[exclude]:str:' \
        '--exclude-downloaded-modules[no downloaded mods]' \
        '--filter-results=+[regex]:str:' \
        '--force-all-dirs[force all dirs]' \
        '--format=+[fmt]:f:(default json csv checkstyle junit sarif text gif lovely markdown html template)' \
        '*--format=+[fmt]:f:(default json csv checkstyle junit sarif text gif lovely markdown html template)' \
        '-f+[format]:f:(default json csv checkstyle junit sarif text gif lovely markdown html template)' \
        '--ignore-hcl-errors[ignore HCL errors]' \
        '--include-ignored[include ignored]' \
        '--include-passed[include passed]' \
        '--minimum-severity=+[s]:s:(LOW MEDIUM HIGH CRITICAL)' \
        '-m+[min severity]:s:(LOW MEDIUM HIGH CRITICAL)' \
        '--no-color[no color]' \
        '--no-colour[no color]' \
        '--out=+[file]:file:_files' \
        '-O+[output]:file:_files' \
        '--print-rego-input[print rego input]' \
        '--rego-only[rego only]' \
        '--rego-policy-dir=+[dir]:dir:_files -/' \
        '-r+[rego dir]:dir:_files -/' \
        '--run-statistics[run statistics]' \
        '--single-thread[single thread]' \
        '--soft-fail[soft fail]' \
        '-s[soft fail]' \
        '--terraform-var-file=+[file]:file:_files -g "*.tfvars *.tfvars.json"' \
        '*--terraform-var-file=+[file]:file:_files -g "*.tfvars *.tfvars.json"' \
        '--update[update tfsec]' \
        '--tfvars-file=+[file]:file:_files -g "*.tfvars"' \
        '--workspace=+[name]:str:' \
        '-w+[workspace]:str:' \
        '--no-module-downloads[no module downloads]' \
        '*:dir:_files -/'
}

_tfsec2 "$@"
