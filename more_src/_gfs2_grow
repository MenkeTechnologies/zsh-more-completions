#compdef gfs2_grow
# Documentation: https://manpages.ubuntu.com/manpages/questing/man8/gfs2_grow.8.html
# Expand a GFS2 filesystem

local ret=1

_arguments -s -S \
  '-D[print debugging information about filesystem layout]' \
  '-h[show usage message]' \
  '-q[quiet; do not print anything]' \
  '-K[do not attempt to discard block device contents]' \
  '-T[test only; do all calculations but do not write to disk]' \
  '-V[print version information]' \
  '*:mountpoint or device:_files' && ret=0

return ret
