#compdef peck
# Documentation: https://github.com/peckphp/peck
# Peck spelling and wording checker for PHP codebases

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--init[create a peck.json configuration file]' \
  '--ignore-all[ignore all currently detected mistakes]' \
  '--config=[path to peck.json configuration file]:file:_files' && ret=0

return ret
