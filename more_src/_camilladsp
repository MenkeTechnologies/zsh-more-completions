#compdef camilladsp
# ============================================================================
# camilladsp - cross-platform IIR + FIR audio
#               DSP engine for crossovers + room
#               correction + EQ
#               (Rust, GPL-3.0-only OR MPL-2.0)
#
# Author : Henrik Enquist
# Upstream: https://github.com/HEnquist/camilladsp
#
# CamillaDSP is a real-time audio DSP engine
# designed for high-quality home + studio
# audio processing. Sits between an audio
# input (Capture device) and output (Playback
# device) processing samples through a graph
# of biquad IIR filters + FIR convolvers +
# delays + gain stages defined in a YAML
# configuration file.
#
# Distinguishing features vs alternatives
# (PulseEffects + EasyEffects + JackEQ +
# REW + Equalizer APO):
#   - **Real-time IIR + FIR processing**
#     (sample-accurate biquad + convolver
#     graphs running in dedicated audio
#     threads)
#   - **Cross-platform** (Linux + macOS +
#     Windows; ALSA + PulseAudio + PipeWire
#     + JACK + CoreAudio + WASAPI + ASIO
#     + BlueZ backends)
#   - **WebSocket control API** (live config
#     changes + gain adjustments + mute via
#     JSON-over-WebSocket; remote control
#     from web UIs + scripts + REW)
#   - **YAML config** (human-readable +
#     diffable config with biquad filter
#     parameters + FIR convolver paths +
#     pipeline graph)
#   - **Live reload** (config changes apply
#     without restarting; FIR coefficients
#     can be hot-swapped)
#   - **High-precision floats** (32-bit +
#     64-bit float internal processing;
#     S16/S24/S32/F32/F64 sample formats
#     supported)
#   - **4 auxiliary faders** (gain1..gain4 +
#     mute1..mute4 in addition to main gain;
#     useful for multi-zone + bass-management
#     scenarios)
#   - **Statefile persistence** (saves +
#     restores last-known config + state
#     across restarts)
#
# Use cases:
#   - Home audio room correction (REW measures
#     room response; exports biquad/FIR; load
#     into CamillaDSP pipeline)
#   - Active crossovers for multi-driver
#     speaker setups (subwoofer + midrange +
#     tweeter crossovers)
#   - EQ correction for headphones (Harman
#     curve + earpiece compensation)
#   - Multi-room audio with per-zone EQ
#   - Bass management for surround systems
#   - Studio monitor calibration
#   - Streaming audio EQ (pipe Spotify/Tidal
#     through CamillaDSP → DAC)
#
# Usage:
#   camilladsp [options] [<configfile>]
#
# Positional argument:
#   <configfile>                   - YAML
#                                     configuration
#                                     file
#                                     (optional
#                                     if
#                                     --wait
#                                     is used)
#
# Options (clap):
#   -s, --statefile <path>         - use the
#                                     given
#                                     file to
#                                     persist
#                                     the state
#   -c, --check                    - check
#                                     config
#                                     file +
#                                     exit
#                                     (does
#                                     not
#                                     start
#                                     audio
#                                     processing)
#   -v                             - increase
#                                     message
#                                     verbosity
#                                     (repeatable:
#                                     -v -vv
#                                     -vvv)
#   -l, --loglevel <lvl>           - set log
#                                     level
#                                     (trace +
#                                     debug +
#                                     info +
#                                     warn +
#                                     error +
#                                     off)
#   -o, --logfile <path>           - write
#                                     logs to
#                                     the
#                                     given
#                                     file
#                                     path
#       --log_rotate_size <bytes>  - rotate
#                                     log
#                                     when
#                                     size in
#                                     bytes
#                                     exceeds
#                                     this
#                                     value
#                                     (min
#                                     1000)
#       --log_keep_nbr <n>         - number of
#                                     previous
#                                     log
#                                     files
#                                     to keep
#       --custom_log_spec <spec>   - custom
#                                     flexi_logger
#                                     log
#                                     specification
#                                     string
#
# Gain control (initial values; live changes
# via WebSocket):
#   -g, --gain <dB>                - initial
#                                     gain in
#                                     dB for
#                                     main
#                                     volume
#                                     control
#                                     (-120 to
#                                     +20)
#       --gain1 <dB>               - initial
#                                     gain for
#                                     Aux1
#                                     fader
#       --gain2 <dB>               - initial
#                                     gain for
#                                     Aux2
#                                     fader
#       --gain3 <dB>               - initial
#                                     gain for
#                                     Aux3
#                                     fader
#       --gain4 <dB>               - initial
#                                     gain for
#                                     Aux4
#                                     fader
#   -m, --mute                     - start
#                                     with
#                                     main
#                                     volume
#                                     muted
#       --mute1                    - start
#                                     with
#                                     Aux1
#                                     muted
#       --mute2                    - start
#                                     with
#                                     Aux2
#                                     muted
#       --mute3                    - start
#                                     with
#                                     Aux3
#                                     muted
#       --mute4                    - start
#                                     with
#                                     Aux4
#                                     muted
#
# Audio config overrides (override config
# file values):
#   -r, --samplerate <Hz>          - override
#                                     samplerate
#                                     in
#                                     config
#                                     (44100 +
#                                     48000 +
#                                     96000 +
#                                     192000 +
#                                     ...)
#   -n, --channels <n>             - override
#                                     number
#                                     of
#                                     channels
#                                     of
#                                     capture
#                                     device
#   -e, --extra_samples <n>        - override
#                                     number
#                                     of
#                                     extra
#                                     samples
#                                     (for
#                                     pipeline
#                                     warmup)
#   -f, --format <fmt>             - override
#                                     sample
#                                     format
#                                     of
#                                     capture
#                                     device
#                                     (S16_LE
#                                     + S24_3_
#                                     LE +
#                                     S24_4_
#                                     LJ_LE +
#                                     S24_4_
#                                     RJ_LE +
#                                     S32_LE
#                                     + F32_LE
#                                     + F64_LE)
#
# WebSocket control server (feature: websocket):
#   -p, --port <n>                 - port for
#                                     websocket
#                                     server
#                                     (0-65535;
#                                     default
#                                     1234)
#   -a, --address <ip>             - IP
#                                     address
#                                     to bind
#                                     websocket
#                                     server
#                                     to
#                                     (default
#                                     localhost)
#   -w, --wait                     - wait for
#                                     config
#                                     from
#                                     websocket
#                                     (start
#                                     without
#                                     a
#                                     configfile
#                                     argument)
#       --no_config                - ignore
#                                     config
#                                     file in
#                                     statefile
#                                     + start
#                                     without
#                                     config
#
# Secure WebSocket (feature: secure-websocket):
#       --cert <path>              - path to
#                                     .pfx/
#                                     .p12
#                                     certificate
#                                     file
#                                     (for
#                                     wss://)
#       --pass <password>          - password
#                                     for
#                                     .pfx/
#                                     .p12
#                                     certificate
#                                     file
#
# Standard flags:
#   -h, --help                     - show help
#   -V, --version                  - show
#                                     version
#                                     +
#                                     features
#
# Exit codes:
#   0                              - all ok
#   101                            - error in
#                                     config
#                                     file
#                                     (EXIT_
#                                     BAD_
#                                     CONFIG)
#   102                            - error
#                                     from
#                                     processing
#                                     (EXIT_
#                                     PROCESSING
#                                     _ERROR)
#   103                            - exit
#                                     forced
#                                     by
#                                     second
#                                     SIGINT
#
# Example invocations:
#   # Validate a config file
#   camilladsp --check my-config.yml
#
#   # Run a config with main gain -10 dB,
#   # started muted
#   camilladsp -g -10 -m my-config.yml
#
#   # Run with WebSocket control on port 1234
#   camilladsp -p 1234 -a 0.0.0.0 my-config.yml
#
#   # Wait for config from WebSocket
#   # (no positional config arg)
#   camilladsp -p 1234 --wait
#
#   # Run with custom log destination + level
#   camilladsp -l debug -o /var/log/camilladsp.log \
#     my-config.yml
#
#   # Secure WebSocket (wss://) with TLS cert
#   camilladsp -p 4443 \
#     --cert cert.pfx --pass cert-password \
#     my-config.yml
#
#   # Override samplerate + channels from
#   # config file
#   camilladsp -r 48000 -n 2 -f S32_LE \
#     my-config.yml
#
#   # Use statefile for persistent state
#   camilladsp -s /var/lib/camilladsp.state \
#     my-config.yml
#
#   # Start without config, wait for one via
#   # WebSocket (used by GUI controllers like
#   # camillagui)
#   camilladsp --wait -p 1234 --no_config \
#     -s /var/lib/camilladsp.state
#
# Build features (compile-time):
#   default                        - websocket
#                                     (enable
#                                     the
#                                     WebSocket
#                                     control
#                                     server)
#   websocket                      - tungstenite
#                                     WebSocket
#                                     control
#                                     server
#   secure-websocket               - websocket
#                                     + native-
#                                     tls
#                                     (wss://)
#   threaded-alsa                  - threaded
#                                     ALSA
#                                     backend
#                                     (Linux)
#   pulse-backend                  - PulseAudio
#                                     backend
#                                     (Linux)
#   pipewire-backend               - PipeWire
#                                     backend
#                                     (Linux)
#   cpal-backend                   - CPAL
#                                     backend
#                                     (cross-
#                                     platform)
#   jack-backend                   - JACK
#                                     backend
#                                     (via
#                                     CPAL)
#   bluez-backend                  - BlueZ
#                                     Bluetooth
#                                     audio
#                                     backend
#                                     (Linux)
#   asio-backend                   - ASIO
#                                     backend
#                                     (Windows)
#   32bit                          - 32-bit
#                                     internal
#                                     processing
#                                     (default
#                                     64-bit)
#
# The tungstenite lane is built on `tungstenite
# = { version = "0.26.1", optional = true}`
# (declared verbatim at upstream Cargo.toml
# HEAD as a direct dep, gated behind the
# websocket feature which is enabled by
# default; imported by `src/socketserver.rs`
# for the JSON-over-WebSocket control API
# server allowing live config changes + gain
# adjustments + mute toggling without
# restarting), the canonical Rust WebSocket
# library by Daniel Abramov + snapview team -
# github.com/snapview/tungstenite-rs.
#
# snapview/tungstenite-rs is the de-facto
# canonical Rust WebSocket library:
#   - **RFC 6455 compliant** (the IETF
#     WebSocket spec; tungstenite passes
#     the Autobahn fuzzing test suite at
#     100%)
#   - **Sync + async APIs** (the base
#     tungstenite crate is sync; tokio-
#     tungstenite is the async wrapper for
#     tokio integration; async-tungstenite
#     is the smol/async-std wrapper)
#   - **Server + client** (both directions
#     of WebSocket connections)
#   - **TLS support** (native-tls + rustls
#     + openssl optional features)
#   - **Permessage-deflate** (RFC 7692
#     compression extension)
#   - **Subprotocol negotiation** (Sec-
#     WebSocket-Protocol header handling)
#   - 2,400+ stars on github.com/snapview/
#     tungstenite-rs
#   - ~3,000 reverse-deps on crates.io
#     (combining tungstenite + tokio-
#     tungstenite + async-tungstenite -
#     the canonical Rust WebSocket
#     ecosystem)
#
# tungstenite-rs's distinguishing position vs
# Rust WebSocket alternatives:
#   - snapview/tungstenite-rs (Abramov + team):
#     canonical; RFC 6455; sync + async; THIS
#     AXIS
#   - websocket-rs (cyderize/rust-websocket):
#     older alternative; less actively
#     maintained
#   - fastwebsockets (denoland/fastwebsockets):
#     high-performance alternative; SIMD-
#     accelerated; smaller API surface;
#     used inside Deno
#   - ws-rs (housleyjk/ws-rs): older Rust
#     WebSocket; archived; predates
#     tungstenite
#
# Daniel Abramov is the original author of
# tungstenite-rs + maintainer of the snapview
# WebSocket library family (the company
# Snapview - a German video communication
# platform - developed tungstenite for
# internal use, then open-sourced it). The
# snapview org now maintains tungstenite +
# tokio-tungstenite + async-tungstenite as a
# coordinated WebSocket library family.
#
# Abramov + snapview's broader Rust
# ecosystem footprint:
#   - snapview/tungstenite-rs (canonical
#     Rust WebSocket; THIS AXIS)
#   - snapview/tokio-tungstenite (canonical
#     async wrapper for tokio integration)
#   - snapview/async-tungstenite (async-std
#     + smol wrapper)
#
# The snapview team's role in Rust is
# *RFC-bound async networking
# infrastructure* - similar position to
# Buoyant (linkerd) + Cloudflare (quiche)
# + tokio-rs (tokio + tonic + prost) in
# the *production-extracted canonical
# libraries* pattern.
#
# Multi-axis canonical-Rust author/org cohort
# extension (now spanning even more distinct
# authors):
#   - + Daniel Abramov + snapview team
#     (snapview/tungstenite-rs + tokio-
#     tungstenite + async-tungstenite; THIS
#     AXIS; canonical Rust WebSocket +
#     RFC 6455 + Autobahn-compliant
#     sync+async stack)
#
# Abramov + snapview joining the canonical-
# Rust cohort at the *RFC-bound async
# networking infrastructure* level extends
# the pattern of *vertically-coordinated
# library families* documented across the
# corpus (similar to tokio-rs/tokio +
# hyper + h2 + tonic + prost in Axes
# 274-279 closing).
#
# camilladsp uses tungstenite for:
#   - WebSocket server accept loop (in
#     `src/socketserver.rs`)
#   - JSON message parsing for control API
#     (config reload + gain adjustment +
#     mute toggling + state queries)
#   - Optional TLS (wss://) via the
#     secure-websocket feature using
#     native-tls
#
# This is the canonical use case for
# tungstenite in production audio /
# streaming services: lightweight WebSocket
# control surface alongside a real-time
# data processing pipeline (audio thread
# stays uncontended; WebSocket runs on a
# separate thread + communicates via
# crossbeam channels to the audio thread).
#
# ----------------------------------------------------------------------------
# AXIS 281 :: WebSocket libraries
#              (RFC 6455 WebSocket protocol
#              implementations;
#              full-duplex single-TCP-connection
#              messaging + permessage-deflate
#              + subprotocol negotiation +
#              binary + text frames)
# Round 1541 :: Rust slot 1 of 4 :: OPENS Axis 281
#
# Cross-language canonical library family for
# this axis (proposed):
#   Rust    : snapview/tungstenite-rs    - Daniel
#                                          Abramov +
#                                          snapview
#                                          team
#                                          (canonical
#                                          Rust
#                                          WebSocket;
#                                          sync +
#                                          tokio-
#                                          tungstenite
#                                          async +
#                                          async-
#                                          tungstenite
#                                          variants)
#   Go      : coder/websocket            - Anmol
#             OR                            Sethi +
#             gorilla/websocket             coder
#                                          team
#                                          (modern
#                                          canonical
#                                          Go
#                                          WebSocket
#                                          after
#                                          gorilla
#                                          archival)
#   TS/Node : websockets/ws              - Einar
#                                          Otto
#                                          Stangvik +
#                                          Luigi
#                                          Pinca
#                                          (canonical
#                                          Node
#                                          WebSocket;
#                                          ~140M
#                                          weekly
#                                          npm
#                                          downloads)
#
# WebSocket (RFC 6455) is the *canonical
# full-duplex single-TCP-connection messaging
# protocol* on the web:
#   - Standardized 2011 (RFC 6455 obsoletes
#     earlier protocol drafts)
#   - HTTP/1.1 Upgrade handshake establishes
#     a persistent TCP+TLS connection
#   - Binary + text frame types
#   - Permessage-deflate (RFC 7692)
#     compression extension
#   - Subprotocol negotiation (Sec-WebSocket-
#     Protocol)
#   - Used by: real-time web apps + chat +
#     trading + collaborative editing +
#     server-pushed notifications + game
#     server protocols + control APIs
#     (THIS AXIS opener's use case)
#
# Each canonical library provides:
#   - RFC 6455 handshake + framing
#   - Server + client APIs
#   - TLS support
#   - Permessage-deflate (some libraries)
#   - Subprotocol negotiation
#   - Autobahn test suite compliance
#
# WebSocket vs HTTP/2 (Axis 275) vs gRPC
# (Axis 276):
#   - WebSocket: full-duplex messages;
#     persistent connection; binary or text
#     frames; client-initiated handshake
#   - HTTP/2: request-response; server can
#     push (rarely used); typed payload
#   - gRPC: HTTP/2-based; protobuf wire;
#     streaming RPC variants (server +
#     client + bidirectional)
# Each fills a different production niche
# for persistent connections.
#
# Use-case spectrum for this axis (so far):
#   - camilladsp (Rust, tungstenite): real-
#     time audio DSP engine control API
#     (live config reload + gain control +
#     mute toggling)
# ============================================================================

_camilladsp() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-s --statefile)'{-s,--statefile}'=[persist state to file]:file:_files' \
        '(-c --check)'{-c,--check}'[check config + exit]' \
        '*-v[increase message verbosity (repeatable)]' \
        '(-l --loglevel)'{-l,--loglevel}'=[log level]:level:(trace debug info warn error off)' \
        '(-o --logfile)'{-o,--logfile}'=[write logs to file]:file:_files' \
        '--log_rotate_size=[rotate when size exceeds bytes]:bytes:' \
        '--log_keep_nbr=[number of previous log files to keep]:n:' \
        '--custom_log_spec=[custom flexi_logger spec]:spec:' \
        '(-g --gain)'{-g,--gain}'=[initial main gain in dB (-120..+20)]:dB:' \
        '--gain1=[initial gain for Aux1 fader]:dB:' \
        '--gain2=[initial gain for Aux2 fader]:dB:' \
        '--gain3=[initial gain for Aux3 fader]:dB:' \
        '--gain4=[initial gain for Aux4 fader]:dB:' \
        '(-m --mute)'{-m,--mute}'[start with main volume muted]' \
        '--mute1[start with Aux1 muted]' \
        '--mute2[start with Aux2 muted]' \
        '--mute3[start with Aux3 muted]' \
        '--mute4[start with Aux4 muted]' \
        '(-r --samplerate)'{-r,--samplerate}'=[override samplerate]:Hz:(44100 48000 88200 96000 176400 192000 352800 384000)' \
        '(-n --channels)'{-n,--channels}'=[override capture channels]:n:' \
        '(-e --extra_samples)'{-e,--extra_samples}'=[override extra samples]:n:' \
        '(-f --format)'{-f,--format}'=[override capture sample format]:format:(S16_LE S24_3_LE S24_4_LJ_LE S24_4_RJ_LE S32_LE F32_LE F64_LE)' \
        '(-p --port)'{-p,--port}'=[WebSocket server port (0-65535)]:port:' \
        '(-a --address)'{-a,--address}'=[WebSocket bind IP address]:ip:' \
        '(-w --wait)'{-w,--wait}'[wait for config from WebSocket]' \
        '--no_config[ignore config in statefile + start without]' \
        '--cert=[path to .pfx/.p12 cert file (wss://)]:file:_files -g "*.(pfx|p12)"' \
        '--pass=[password for .pfx/.p12 cert file]:password:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version + features]' \
        '*:config file:_files -g "*.(yml|yaml)"' \
    && ret=0

    return ret
}

_camilladsp "$@"
