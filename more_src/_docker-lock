#compdef docker-lock
# docker-lock: manage image digests in Dockerfiles, docker-compose files, etc.
# https://github.com/safe-waters/docker-lock

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'generate:generate a lockfile'
      'verify:verify a lockfile'
      'rewrite:rewrite Dockerfiles/docker-compose files with digests from lockfile'
      'version:print version'
    )
    _describe -t commands 'docker-lock command' commands && ret=0
    ;;
  args)
    case $line[1] in
      generate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--base-dir=[base directory]:dir:_directories' \
          '--dockerfile=[path to Dockerfile]:file:_files' \
          '--compose-file=[path to docker-compose file]:file:_files' \
          '--kubeconfig=[path to Kubernetes manifest]:file:_files' \
          '--lockfile-name=[lockfile name]:name' \
          '--ignore-missing-digests[ignore images without digests]' \
          '--update-existing-digests[update existing digests in lockfile]' && ret=0
        ;;
      verify)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--lockfile-name=[lockfile to verify]:file:_files' \
          '--update-existing-digests[update existing digests]' && ret=0
        ;;
      rewrite)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--lockfile-name=[lockfile to use]:file:_files' \
          '--suffix=[suffix for rewritten files]:suffix' \
          '--tempdir=[temp directory]:dir:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
