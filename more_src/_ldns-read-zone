#compdef ldns-read-zone
# _ldns-read-zone — NLnet Labs ldns-read-zone (canonicalize / re-serialize a DNS zonefile; can strip DNSSEC, filter RR types, rewrite SOA serial)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-read-zone.c usage on tip.

_ldns-read-zone() {
    _arguments \
        '-h[show help]' \
        '-0[zeroize timestamps + signatures in RRSIGs]' \
        '-b[include Bubble-Babble encoding of DS records]' \
        '-c[canonicalize all RRs]' \
        '(-d -s)-d[only emit DNSSEC RRs]' \
        '(-d -s)-s[strip DNSSEC data]' \
        '*-e+[exclude RR type (repeatable; mutually exclusive with -E)]:type:(A AAAA NS MX TXT SRV SOA CNAME PTR DS DNSKEY RRSIG NSEC NSEC3 NSEC3PARAM ZONEMD CAA TLSA)' \
        '*-E+[only emit this RR type (repeatable; mutually exclusive with -e)]:type:(A AAAA NS MX TXT SRV SOA CNAME PTR DS DNSKEY RRSIG NSEC NSEC3 NSEC3PARAM ZONEMD CAA TLSA)' \
        '-n[do not emit the SOA record]' \
        '-p[pad SOA serial to exactly ten characters]' \
        '-S+[set or offset SOA serial (number | +/-N | YYYYMMDDxx | unixtime)]:spec:' \
        '-z+[set/replace ZONEMD record (scheme:hash)]:zonemd:' \
        '-v[show version and exit]' \
        '1:zonefile:_files'
}

_ldns-read-zone "$@"
