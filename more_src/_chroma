#compdef chroma
# Documentation: https://github.com/alecthomas/chroma
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# chroma: general-purpose syntax highlighter (Go)

_arguments -s -S \
  '--list[list all lexers, styles, or formatters]' \
  '(-s --style)'{-s,--style}'[style to use]:style:' \
  '(-f --formatter)'{-f,--formatter}'[formatter to use]:formatter:(terminal terminal8 terminal16 terminal256 terminal16m html svg json noop tokens)' \
  '(-l --lexer)'{-l,--lexer}'[lexer to use or XML file path]:lexer:' \
  '--filename[filename for stdin lexer detection]:filename:_files' \
  '--html[shorthand for --formatter=html]' \
  '--html-prefix[HTML CSS class prefix]:prefix:' \
  '--html-styles[output HTML CSS styles]' \
  '--html-all-styles[output all CSS styles including redundant]' \
  '--html-only[output HTML fragment only]' \
  '--html-inline-styles[use inline styles instead of classes]' \
  '--html-tab-width[tab width]:width:' \
  '--html-lines[include line numbers]' \
  '--html-lines-table[use a table for line numbers]' \
  '--html-lines-style[style for line numbers]:style:' \
  '--html-highlight[highlight line ranges]:ranges:' \
  '--html-highlight-style[highlight styling]:style:' \
  '--html-base-line[base line number]:number:' \
  '--html-linkable-lines[make line numbers linkable]' \
  '--html-prevent-surrounding-pre[remove surrounding pre tag]' \
  '--json[shorthand for --formatter=json]' \
  '--svg[shorthand for --formatter=svg]' \
  '--unbuffered[do not buffer output]' \
  '--trace[trace lexer states]' \
  '--check[validate tokenization without formatting]' \
  '--fail[exit with status 1 if no specific lexer found]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:file:_files' && return 0
