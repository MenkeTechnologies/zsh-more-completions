#compdef lmt
# Documentation: https://github.com/sderev/lmterminal
# CLI tool that interacts with OpenAI language models

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '(-m)-m+[switch between models]:model:' \
  '(--system -s)'{--system,-s}'+[assign a persona or system prompt]:system prompt:' \
  '(--template -t)'{--template,-t}'+[invoke a saved template]:template:' \
  '--emoji[add emoji expression to responses]' \
  '--tokens[estimate prompt cost before sending]' \
  '1:command:((key\:"manage the OpenAI API key" templates\:"manage prompt templates"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      key) _values 'subcommand' 'set[configure the OpenAI API key]' ;;
      templates) _values 'subcommand' 'add[generate a new template]' ;;
    esac
    ;;
esac

return ret
