#compdef controlflow
# Documentation: https://github.com/PrefectHQ/ControlFlow
# Reference accessed: 2026-05-22
# Verified: src/controlflow/cli/main.py and dev.py Typer apps.

# Zsh completion for controlflow - ControlFlow agentic workflow CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'controlflow command' \
      'version[show version and environment info]' \
      'dev[development utilities]' && ret=0
    ;;
  args)
    case $line[1] in
      dev)
        if (( CURRENT == 2 )); then
          _values 'dev command' \
            'ai_files[generate AI-oriented file summaries]' \
            'docs[development documentation helpers]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
