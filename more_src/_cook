#compdef cook
# Documentation: https://github.com/cooklang/cookcli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cooklang/cookcli — binary `cook` (Cargo.toml [[bin]] name).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'recipe:parse/display/convert recipes (alias r)'
  'server:local recipe browser (alias s)'
  'build:generate static recipe website'
  'shopping-list:aggregate ingredients (alias sl)'
  'seed:populate with example recipes'
  'search:search collection (alias f)'
  'import:import recipes from URLs (alias i)'
  'report:custom Jinja2 reports'
  'doctor:validate recipes / install'
  'pantry:pantry management'
  'lsp:language server'
  'update:self-update cook'
)

_arguments -s -S -C \
  '*'{-v}'[increase verbosity; repeatable]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'cook subcommand' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
