#compdef cook
# Documentation: https://man.archlinux.org/search?q=cook
# Reference accessed: 2026-05-16

# cooklang/cookcli — binary `cook` (Cargo.toml [[bin]] name); subcommands in src/args.rs Command.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'recipe:parse/display/convert recipes (alias r)'
  'server:local recipe browser (alias s)'
  'shopping-list:aggregate ingredients (alias sl)'
  'seed:apply bundled samples'
  'search:search collection'
  'import:import remote recipes'
  'report:custom reports'
  'doctor:validate install'
  'pantry:pantry management'
  'lsp:language server'
)

_arguments -s -S -C \
  '*'{-v}'[increase verbosity; repeatable]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'cook subcommand' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
