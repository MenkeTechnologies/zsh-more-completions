#compdef coap-cli
# Documentation: source-direct extraction from upstream
# absmach/coap-cli main.go cobra `rootCmd` + 4 method subcommands
# (`get`/`put`/`post`/`delete`) + their `Flags().<TypeVarP>(...)`
# / `PersistentFlags().<TypeVarP>(...)` declarations. Note: there
# are TWO distinct projects called "coap-cli" in the wild
# (coapjs/coap-cli is a Node.js implementation, absmach/coap-cli
# is the Go implementation); this completion targets the Go
# implementation specifically.
# Reference accessed: 2026-05-30 via gh api.
# Abstract Machines coap-cli R145a — CoAP (Constrained Application
# Protocol; RFC 7252) client CLI in Go. CoAP is the
# UDP-based-REST counterpart to HTTP designed for constrained
# IoT devices. Sister to the heavily-covered MQTT family
# (mqtt-cli/mosquitto_pub/mosquitto_sub/emqx).

local curcontext="$curcontext" state line ret=1

# 13 persistent flags shared by all 4 method subcommands.
local -a _coap_persistent
_coap_persistent=(
  '(-H --host)'{-H+,--host=}'[CoAP server host (default localhost)]:host:_hosts'
  '(-p --port)'{-p+,--port=}'[CoAP server port (default 5683)]:port:'
  '(-a --auth)'{-a+,--auth=}'[auth token]:token:'
  '(-c --content-format)'{-c+,--content-format=}'[CoAP content-format code (default 50=application/json)]:code:'
  '*'{-O+,--options=}'[add CoAP option num=text (hex prefix 0x for binary; repeatable)]:NUM=TEXT:'
  '(-k --keep-alive)'{-k+,--keep-alive=}'[ping interval in seconds (0 disables; default 0)]:sec:'
  '(-m --max-retries)'{-m+,--max-retries=}'[max keep-alive ping retries (default 10)]:n:'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '(-C --cert-file)'{-C+,--cert-file=}'[client certificate file]:file:_files'
  '(-K --key-file)'{-K+,--key-file=}'[client key file]:file:_files'
  '(-A --ca-file)'{-A+,--ca-file=}'[client CA file]:file:_files'
  '(-s --use\ DTLS)'{-s,--use\ DTLS}'[use DTLS (note: upstream long-flag literally contains a space - "use DTLS")]'
)

_arguments -C -s -S \
  '1:subcommand:((get\:GET-request put\:PUT-request post\:POST-request delete\:DELETE-request))' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      get)
        _arguments -s -S \
          "${_coap_persistent[@]}" \
          '(-o --observe)'{-o,--observe}'[observe resource (subscribe to changes)]' \
          '1:CoAP resource URL:' && ret=0
        ;;
      put|post|delete)
        _arguments -s -S \
          "${_coap_persistent[@]}" \
          '(-d --data)'{-d+,--data=}'[request payload data]:data:' \
          '1:CoAP resource URL:' && ret=0
        ;;
    esac
    ;;
esac

return ret
