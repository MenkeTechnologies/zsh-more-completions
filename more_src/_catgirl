#compdef catgirl
# Documentation: https://git.causal.agency/catgirl/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# June McEnroe's TLS-only terminal IRC client. Flags per catgirl(1).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-!+[config file lookup]:name:' \
  '-a+[SASL PLAIN authentication user:pass]:auth:' \
  '-c+[TLS client certificate file]:file:_files' \
  '-e[SASL EXTERNAL (CertFP) authentication]' \
  '-g+[generate self-signed TLS client cert to file and exit]:file:_files' \
  '-h+[IRC server host]:host:_hosts' \
  '-i+[ignore patterns (CSV of nick!user@host)]:patterns:' \
  '-j+[channels to join (with optional keys)]:channels:' \
  '-k+[private key file for client cert]:file:_files' \
  '-l[enable per-network message logging]' \
  '-m+[user modes to set on connect]:modes:' \
  '-n+[nicknames (comma-separated fallbacks)]:nick:' \
  '-o[print server certificate chain and exit]' \
  '-p+[server port (default 6697)]:port:' \
  '-q[quiet mode (hide join/part/quit/etc.)]' \
  '-r+[realname for /whois]:realname:' \
  '-s+[save persistent state to file]:file:_files' \
  '-t[trust self-signed certificate from server]' \
  '-u+[IRC username]:user:_users' \
  '-v[verbose protocol logging]' \
  '-w+[server password]:password:' \
  '-C+[copy utility command]:command:' \
  '-H+[seed for nick/channel color hashing]:seed:' \
  '-I+[highlight patterns (CSV of nick!user@host)]:patterns:' \
  '-N+[notification utility command]:command:' \
  '-O+[URL open utility command]:command:' \
  '-R[restrict commands like /copy, /exec, /open]' \
  '-S+[bind to source address]:addr:' \
  '-T[show timestamps in scrollback]' \
  '*:config file:_files' \
  && ret=0

return ret
