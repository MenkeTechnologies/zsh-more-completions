#compdef catgirl

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-V[show version]' \
  '-h+[host name]:host:_hosts' \
  '-p+[port]:port:' \
  '-u+[user]:user:_users' \
  '-n+[real name]:name:' \
  '-N+[nick]:nick:' \
  '-m+[mode flags]:mode:' \
  '-j+[channels and keys]:channels:' \
  '-w+[server password (= for prompt)]:pw:' \
  '-q+[quit message]:msg:' \
  '-l+[log file]:file:_files' \
  '-S+[bind address]:addr:' \
  '-T[allow plain TLS]' \
  '-d+[default highlight nick]:nick:' \
  '-c+[client cert file]:file:_files' \
  '-k+[priv key file]:file:_files' \
  '-K+[client cert with key]:file:_files' \
  '-C+[CA cert file]:file:_files' \
  '-W+[insecure cipher list]:list:' \
  '-i+[ignore patterns csv]:list:' \
  '-I+[only show patterns]:list:' \
  '-A+[SASL auth user]:user:' \
  '-x+[client TLS cert]:file:_files' \
  '-y+[client TLS key]:file:_files' \
  '-Q+[mod keys]:keys:' \
  '-R[reconnect on disconnect]' \
  '-s+[seek pos]:pos:' \
  '-t+[trust file]:file:_files' \
  '-v[verbose]' \
  '*:config:_files' && ret=0

return ret
