#compdef sss_obfuscate

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)--usage[show usage]' \
  '(-s --stdin)'{-s,--stdin}'[read password from stdin]' \
  '(-d --domain)'{-d,--domain}'+[update password for given domain]:domain:' \
  '(-f --file)'{-f,--file}'+[file with sssd.conf]:file:_files' && ret=0

return ret
