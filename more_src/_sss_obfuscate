#compdef sss_obfuscate
# Documentation: https://manpages.debian.org/unstable/sssd-tools/sss_obfuscate.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--usage[show usage]' \
  '(-s --stdin)'{-s,--stdin}'[read password from stdin]' \
  '(-d --domain)'{-d,--domain}'+[update password for given SSSD domain]:domain:' \
  '(-f --file)'{-f,--file}'+[sssd.conf path]:file:_files' && ret=0

return ret
