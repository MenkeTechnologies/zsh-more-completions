#compdef xtables-multi xtables-nft-multi xtables-legacy-multi
# _xtables-multi — netfilter xtables-multi binary (single ELF used by iptables / iptables-save / iptables-restore / iptables-translate / ip6tables / arptables / ebtables via the argv[0] dispatch; usually invoked indirectly through one of those symlinks; -h help, -V version, --modprobe path)
# upstream: https://git.netfilter.org/iptables
# Behaviour from netfilter/iptables iptables/xtables-multi.c on tip.

_xtables-multi() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '--modprobe+[modprobe path]:file:_files' \
        '*::command:_command_names -e'
}

_xtables-multi "$@"
