#compdef slapd

_arguments -s \
  '-4[IPv4 only]' \
  '-6[IPv6 only]' \
  '-T=[tool mode]:tool:(acl add auth cat dn index passwd schema test)' \
  '-d=[debug level]:level:' \
  '-s=[syslog level]:level:' \
  '-n=[service name]:name:' \
  '-l=[syslog facility]:facility:(LOCAL0 LOCAL1 LOCAL2 LOCAL3 LOCAL4 LOCAL5 LOCAL6 LOCAL7 USER DAEMON)' \
  '-f=[config file]:file:_files' \
  '-F=[config directory]:dir:_files -/' \
  '-h=[URL list]:urls:' \
  '-r=[chroot directory]:dir:_files -/' \
  '-u=[user]:user:_users' \
  '-g=[group]:group:_groups' \
  '-c=[syncrepl cookie]:cookie:' \
  '*-o[option]:option=value:'
