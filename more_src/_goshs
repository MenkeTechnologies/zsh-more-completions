#compdef goshs

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p+[port to listen on]:port' \
  '-d+[directory to serve]:directory:_directories' \
  '-u[enable upload]' \
  '-s[use HTTPS]' \
  '-sk+[path to SSL key]:key file:_files' \
  '-sc+[path to SSL certificate]:cert file:_files' \
  '-b+[bind address]:address' \
  '-si[show server information]' \
  '-w[enable webdav]' \
  '-wo[webdav read-only]' \
  '-c[enable clipboard]' \
  '-P+[basic auth username\:password]:credentials' && ret=0

return ret
