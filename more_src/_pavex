#compdef pavex
# Documentation: https://github.com/LukeMathWalker/pavex/blob/main/compiler/pavex_cli/src/command.rs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_pavex_commands() {
  local -a commands=(
    'new:scaffold a new Pavex project'
    'generate:generate the server SDK code for an application blueprint'
    'self:modify the installation of the Pavex CLI'
  )
  _describe -t commands 'pavex command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color=[color output]:when:(auto always never)' \
  '--debug[expose the full error chain when reporting diagnostics]' \
  '--log[emit internal logs to the console]' \
  '--log-filter=[control which logs are emitted]:filter:' \
  '--perf-profile[serialize tracing information to disk]' \
  '1:command:_pavex_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      new)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --template)'{-t+,--template=}'[project template]:template:(api quickstart)' \
          '1:project path:_files -/' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-b --blueprint)'{-b+,--blueprint=}'[source path for serialized blueprint]:file:_files' \
          '(-o --output)'{-o+,--output=}'[output directory for generated SDK]:dir:_files -/' \
          '--diagnostics=[path for diagnostic information]:file:_files' \
          '--check[verify that the generated SDK is up-to-date]' && ret=0
        ;;
      self)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:((update\:download\ and\ install\ newer\ version setup\:prepare\ system\ to\ use\ Pavex\ CLI uninstall\:uninstall\ Pavex\ CLI activate\:activate\ Pavex\ installation))' \
          '*::self-arg:->self-args' && ret=0
        case $state in
          self-args)
            case $words[1] in
              setup)
                _arguments -s -S \
                  '(-w --wizard-key)'{-w+,--wizard-key=}'[activation key]:key:' \
                  '--skip-activation[skip the activation step]' && ret=0
                ;;
              uninstall)
                _arguments -s -S \
                  '(-y)-y[do not ask for confirmation]' && ret=0
                ;;
              activate)
                _arguments -s -S \
                  '1:activation key:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
