#compdef pavex

local curcontext="$curcontext" state line ret=1

_pavex_commands() {
  local -a commands=(
    'new:create a new Pavex project'
    'generate:generate application blueprint'
    'self:manage the pavex CLI itself'
  )
  _describe -t commands 'pavex command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color[color output]:when:(auto always never)' \
  '--debug[enable debug mode]' \
  '--log[enable logging]' \
  '--log-filter[log filter]:filter' \
  '--perf-profile[enable performance profiling]' \
  '1:command:_pavex_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      new)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:project name' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--color[color output]:when:(auto always never)' \
          '--debug[enable debug mode]' \
          '--log[enable logging]' \
          '--log-filter[log filter]:filter' \
          '*:blueprint file:_files' && ret=0
        ;;
      self)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(update setup)' && ret=0
        ;;
    esac
    ;;
esac

return ret
