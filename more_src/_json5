#compdef json5
# Documentation: https://github.com/json5/json5/blob/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --space)'{-s+,--space=}'[number of spaces to indent or "t" for tabs]:s:' \
  '(-o --out-file)'{-o+,--out-file=}'[output file]:file:_files' \
  '(-v --validate)'{-v,--validate}'[validate JSON5 but do not output JSON]' \
  '*: :_files -g "*.json5 *.json"' && ret=0

return ret
