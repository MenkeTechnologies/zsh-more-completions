#compdef dh_installpam dh_installcron dh_installmenu dh_installmime dh_installxfonts dh_installppp dh_installlogrotate dh_installlogcheck dh_installifupdown dh_installtmpfiles dh_installcatalogs dh_installmodules
# Documentation: https://manpages.debian.org/dh_installpam
# Source: Debian/debhelper — install PAM/cron/menu/mime/xfonts/ppp/logrotate/logcheck/ifupdown/tmpfiles/catalogs/modules config (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '*-X+[exclude pattern]:pattern:_default' \
    '--name=-[debhelper file suffix]:name:_default' \
    '--no-act[do not act]' \
    '*-O+[passthrough option]:opt:_default' \
    && ret=0

return ret
