#compdef mpbridge
# Documentation: https://github.com/AmirHmZz/mpbridge
# mpbridge - synchronise and manage files on MicroPython running devices

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:(bridge sync dev clear list)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      sync)
        _arguments -s \
          '--use-hashtable[cache calculated hashes on remote device]' \
          '--dry-run[show actions without applying them]' \
          '*:port or dir:_files' && ret=0
        ;;
      dev)
        _arguments -s \
          '--no-prompt[disable prompt to enter REPL]' \
          '--auto-reset[auto reset device]' \
          '--use-hashtable[cache calculated hashes on remote device]' \
          '--mpy-cross-path=[path to mpy-cross executable]:path:_files' \
          '*:port or dir:_files' && ret=0
        ;;
      bridge|clear)
        _arguments '*:port:_files -g "/dev/tty* /dev/cu*"' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
