#compdef ixfrdist
# Documentation: https://doc.powerdns.com/authoritative/manpages/ixfrdist.1.html
# Transfer zones from an authoritative server and re-serve them via AXFR and IXFR

local ret=1

_arguments -s -S \
  '--help[show all supported options]' \
  '--verbose[log INFO messages]' \
  '--debug[log INFO and DEBUG messages]' \
  '--version[display the version]' \
  '--config[load configuration from a YAML file]:path:_files' && ret=0

return ret
