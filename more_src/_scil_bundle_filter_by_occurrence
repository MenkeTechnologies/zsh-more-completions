#compdef scil_bundle_filter_by_occurrence
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_bundle_filter_by_occurrence.html
# Filter bundles by occurrence across inputs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--ratio_voxels=[threshold ratio for voxels across bundles]:ratio' \
  '--ratio_streamlines=[voting threshold for streamlines]:ratio' \
  '--reference=[reference anatomy for tck/vtk/fib/dpy]:nifti:_files -g "*.nii *.nii.gz"' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[enable overwriting of output files]' \
  '*:in_bundles:_files' && ret=0

return ret
