#                                                  for tables/snapshots)
#
# iceberg is the official Apache Iceberg Go CLI for interacting with
# Iceberg table catalogs and tables.  Supports four catalog backends out
# of the box: REST (the modern recommended catalog server protocol),
# Glue (AWS Glue Data Catalog), Hive (HMS — Hive Metastore Service),
# Hadoop (filesystem-based catalog at hdfs:// or s3://).  Reads/writes
# table data via the Apache Arrow Go parquet/pqarrow stack — pure Go,
# no C dependencies for Parquet I/O.
#
# === AXIS 171 CONTINUES — columnar in-memory data formats (Apache Arrow) =
# Axis position: Go=226 continues Axis 171 (slot 2/0/0).  Canonical Go
# Apache Arrow implementation is `github.com/apache/arrow-go/v18` —
# maintained by the Apache Arrow Go community.  Provides arrow-typed
# in-memory columnar arrays, parquet reader/writer, flight + flight-sql
# RPC clients, gandiva LLVM-based expression eval, CSV/JSON readers, all
# with the canonical Arrow C Data Interface for FFI with arrow-rs /
# pyarrow / arrow-java.  Every Go-native columnar / lakehouse / catalog
# tool standardizes on arrow-go: apache/iceberg-go, apache/datafusion-go,
# motherduckdb/duckdb-go-bindings, cloudquery, redpanda-connect.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=226     _vx                  ← previous round (axis 171 OPENS, 1/0/0)
#   Go=226       ← THIS FILE          (axis 171 continues, slot 2/0/0)
#   TS-Node=226  ← next round         (axis 171 CLOSES at triple-226, 1/1/1)
# ---------------------------------------------------------------------------

_iceberg() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--catalog=[catalog type (default rest)]:catalog type:(rest glue hive hadoop)'
        '--catalog-name=[catalog name from config (default default)]:name:'
        '--uri=[catalog URI (REST endpoint or HMS Thrift URI)]:uri:'
        '--output=[output type (default text)]:format:(json text)'
        '--credential=[credentials for the catalog]:credential:'
        '--token=[OAuth token (skip OAuth flow)]:token:'
        '--warehouse=[warehouse to use]:warehouse:'
        '--scope=[OAuth scope (default catalog)]:scope:'
        '--config=[path to configuration file]:file:_files'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'--version'[print version]' \
        $global_opts \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'list:list tables or namespaces (parent namespace optional positional)'
                'describe:describe a namespace or table (fully qualified identifier required)'
                'schema:get the schema of a table'
                'spec:return the partition spec of a table'
                'uuid:return the UUID of a table'
                'location:return the location of a table'
                'create:create a namespace or table'
                'drop:drop a namespace or table'
                'files:list all files of a table (--history for all snapshots)'
                'rename:rename a table (source → destination identifier)'
                'properties:manage properties on tables/namespaces (get/set/remove)'
                'compact:analyze or run bin-pack compaction (analyze/run)'
                'info:show single-screen table summary'
                'snapshots:list table snapshots (in reverse chronological order)'
                'refs:list snapshot refs (--type branch|tag filter)'
                'partition-stats:list partition statistics files'
                'branch:manage table branches (create)'
                'tag:manage table tags (create)'
                'expire-snapshots:expire old snapshots (--older-than duration / --retain-last N)'
                'clean-orphan-files:remove orphan files older than duration (default 72h)'
                'upgrade:upgrade table format version (e.g. v2 → v3)'
                'rollback:roll back to a previous snapshot by --snapshot-id'
            )
            _describe -t commands 'iceberg command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                list)
                    _arguments \
                        $global_opts \
                        '1:catalog parent namespace:' && ret=0
                    ;;
                describe)
                    _arguments \
                        $global_opts \
                        "1:fully qualified identifier (or 'namespace'/'table'):(namespace table)" \
                        '2:fully qualified namespace or table:' && ret=0
                    ;;
                schema)
                    _arguments \
                        $global_opts \
                        '--show-defaults[show initial-default and write-default values]' \
                        '1:table identifier:' && ret=0
                    ;;
                spec|uuid|location|info)
                    _arguments \
                        $global_opts \
                        '1:table identifier:' && ret=0
                    ;;
                files)
                    _arguments \
                        $global_opts \
                        '--history[show all snapshots]' \
                        '1:table identifier:' && ret=0
                    ;;
                rename)
                    _arguments \
                        $global_opts \
                        '1:source table identifier:' \
                        '2:destination table identifier:' && ret=0
                    ;;
                create)
                    _arguments \
                        '1: :->create_kinds' \
                        '*::arg:->create_args' && ret=0
                    case $state in
                        create_kinds)
                            local -a kinds
                            kinds=(
                                'namespace:create a namespace'
                                'table:create a table'
                            )
                            _describe -t commands 'create kind' kinds && ret=0
                            ;;
                        create_args)
                            case $words[1] in
                                namespace)
                                    _arguments \
                                        $global_opts \
                                        '--description=[description for the namespace]:text:' \
                                        '--location-uri=[location URI for the namespace]:uri:' \
                                        '1:fully qualified namespace:' && ret=0
                                    ;;
                                table)
                                    _arguments \
                                        $global_opts \
                                        '--schema=[table schema in JSON]:json:' \
                                        '--infer-schema=[infer schema from a local data file]:parquet file:_files -g "*.parquet"' \
                                        '--properties=[table properties as key=value pairs]:k=v,k=v...:' \
                                        '--partition-spec=[partition spec as comma-separated field names]:field1,field2,...:' \
                                        '--sort-order=[sort order as field:direction[:null-order]]:spec:' \
                                        '--location-uri=[location URI for the table]:uri:' \
                                        '1:fully qualified table:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                drop)
                    _arguments \
                        '1: :->drop_kinds' \
                        '*::arg:->drop_args' && ret=0
                    case $state in
                        drop_kinds)
                            local -a kinds
                            kinds=(
                                'namespace:drop a namespace'
                                'table:drop a table'
                            )
                            _describe -t commands 'drop kind' kinds && ret=0
                            ;;
                        drop_args)
                            case $words[1] in
                                namespace)
                                    _arguments \
                                        $global_opts \
                                        '1:fully qualified namespace:' && ret=0
                                    ;;
                                table)
                                    _arguments \
                                        $global_opts \
                                        '--purge[physically delete all table files]' \
                                        '1:fully qualified table:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                properties)
                    _arguments \
                        '1: :->props_cmds' \
                        '*::arg:->props_args' && ret=0
                    case $state in
                        props_cmds)
                            local -a subcmds
                            subcmds=(
                                'get:get properties (specific name or all)'
                                'set:set a property to a value'
                                'remove:remove a property'
                            )
                            _describe -t commands 'properties subcommand' subcmds && ret=0
                            ;;
                        props_args)
                            case $words[1] in
                                get)
                                    _arguments \
                                        $global_opts \
                                        "1:type:(namespace table)" \
                                        '2:fully qualified identifier:' \
                                        '3:property name (omit to list all):' && ret=0
                                    ;;
                                set)
                                    _arguments \
                                        $global_opts \
                                        "1:type:(namespace table)" \
                                        '2:fully qualified identifier:' \
                                        '3:property name:' \
                                        '4:property value:' && ret=0
                                    ;;
                                remove)
                                    _arguments \
                                        $global_opts \
                                        "1:type:(namespace table)" \
                                        '2:fully qualified identifier:' \
                                        '3:property name:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                compact)
                    _arguments \
                        '1: :->compact_cmds' \
                        '*::arg:->compact_args' && ret=0
                    case $state in
                        compact_cmds)
                            local -a subcmds
                            subcmds=(
                                'analyze:analyze compaction plan'
                                'run:run bin-pack compaction'
                            )
                            _describe -t commands 'compact subcommand' subcmds && ret=0
                            ;;
                        compact_args)
                            case $words[1] in
                                analyze)
                                    _arguments \
                                        $global_opts \
                                        '--target-file-size=[target output file size in bytes (default 0)]:bytes:' \
                                        '1:table identifier:' && ret=0
                                    ;;
                                run)
                                    _arguments \
                                        $global_opts \
                                        '--target-file-size=[target output file size in bytes (default 0)]:bytes:' \
                                        '--partial-progress[stage each group as a separate snapshot]' \
                                        '--preserve-dead-equality-deletes[keep equality-delete files that are provably dead after rewrite (default drops them — recommended for sustained CDC workloads)]' \
                                        '1:table identifier:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                snapshots)
                    _arguments \
                        $global_opts \
                        '1:table identifier:' && ret=0
                    ;;
                refs)
                    _arguments \
                        $global_opts \
                        '--type=[filter by ref type]:type:(branch tag)' \
                        '1:table identifier:' && ret=0
                    ;;
                partition-stats)
                    _arguments \
                        $global_opts \
                        '--snapshot-id=[filter by snapshot ID]:snapshot ID:' \
                        '--all[show partition statistics for all snapshots]' \
                        '1:table identifier:' && ret=0
                    ;;
                branch)
                    _arguments \
                        '1: :->branch_cmds' \
                        '*::arg:->branch_args' && ret=0
                    case $state in
                        branch_cmds)
                            local -a subcmds
                            subcmds=('create:create a branch')
                            _describe -t commands 'branch subcommand' subcmds && ret=0
                            ;;
                        branch_args)
                            case $words[1] in
                                create)
                                    _arguments \
                                        $global_opts \
                                        '--snapshot-id=[snapshot ID (defaults to current snapshot)]:snapshot ID:' \
                                        '--max-ref-age=[max ref age duration (e.g. 7d, 168h)]:duration:' \
                                        '--max-snapshot-age=[max snapshot age duration]:duration:' \
                                        '--min-snapshots-to-keep=[minimum snapshots to keep]:N:' \
                                        '--yes[skip confirmation prompt]' \
                                        '1:table identifier:' \
                                        '2:branch name:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                tag)
                    _arguments \
                        '1: :->tag_cmds' \
                        '*::arg:->tag_args' && ret=0
                    case $state in
                        tag_cmds)
                            local -a subcmds
                            subcmds=('create:create a tag')
                            _describe -t commands 'tag subcommand' subcmds && ret=0
                            ;;
                        tag_args)
                            case $words[1] in
                                create)
                                    _arguments \
                                        $global_opts \
                                        '--snapshot-id=[snapshot ID (defaults to current snapshot)]:snapshot ID:' \
                                        '--max-ref-age=[max ref age duration (e.g. 7d, 168h)]:duration:' \
                                        '--yes[skip confirmation prompt]' \
                                        '1:table identifier:' \
                                        '2:tag name:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                expire-snapshots)
                    _arguments \
                        $global_opts \
                        '--older-than=[expire snapshots older than duration (e.g. 7d, 168h)]:duration:' \
                        '--retain-last=[minimum number of snapshots to retain]:N:' \
                        '--dry-run[show what would be expired without committing]' \
                        '--yes[skip confirmation prompt]' \
                        '1:table identifier:' && ret=0
                    ;;
                clean-orphan-files)
                    _arguments \
                        $global_opts \
                        '--older-than=[delete files older than duration (default 72h)]:duration:' \
                        '--dry-run[list orphan files without deleting]' \
                        '--yes[skip confirmation prompt]' \
                        '--location=[override location to scan for orphan files]:location:' \
                        '1:table identifier:' && ret=0
                    ;;
                upgrade)
                    _arguments \
                        $global_opts \
                        '--dry-run[show what would change without committing]' \
                        '--yes[skip confirmation prompt]' \
                        '1:table identifier:' \
                        '2:target format version (e.g. 2 3):(2 3)' && ret=0
                    ;;
                rollback)
                    _arguments \
                        $global_opts \
                        '--snapshot-id=[snapshot ID to roll back to (required)]:snapshot ID:' \
                        '--yes[skip confirmation prompt]' \
                        '1:table identifier:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_iceberg "$@"
