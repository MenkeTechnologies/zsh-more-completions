#compdef suremac2d
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/synthetics_waveforms_testpatterns/suremac2d.c
# SUREMAC2D - acoustic 2D Fourier method modeling with REM time integration

local ret=1

_arguments -s -S \
  'opflag=[0 variable density, 1 constant density, 2 non-reflecting]:o:(0 1 2)' \
  'nx=[grid points in horizontal direction]:n:' \
  'nz=[grid points in vertical direction]:n:' \
  'nt=[number of time samples]:n:' \
  'dx=[spatial increment horizontal]:d:' \
  'dz=[spatial increment vertical]:d:' \
  'dt=[time sample interval (seconds)]:d:' \
  'isx=[grid point of horizontal source positions]:i:' \
  'isz=[grid point of vertical source positions]:i:' \
  'fx=[first horizontal coordinate]:f:' \
  'fz=[first vertical coordinate]:f:' \
  'irx=[horizontal grid point of vertical receiver lines]:i:' \
  'irz=[vertical grid point of horizontal receiver lines]:i:' \
  'w=[width of spatial source distribution]:w:' \
  'sflag=[0 user supplied, 1 impulse, 2 Ricker wavelet]:s:(0 1 2)' \
  'fmax=[maximum frequency of Ricker wavelet]:f:' \
  'amps=[amplitudes of sources]:a:' \
  'prec=[1 precompute Bessel coeffs, 2 use precomputed]:p:(0 1 2)' \
  'fsflag=[1 run with free surface boundary condition]:f:(0 1)' \
  'vmaxu=[user-defined maximum velocity]:v:' \
  'dtsnap=[time interval (sec) of wave field snapshots]:d:' \
  'iabso=[apply absorbing boundary conditions (0 none)]:i:(0 1)' \
  'abso=[damping parameter for absorbing boundaries]:a:' \
  'nbwx=[horizontal width of absorbing boundary]:n:' \
  'nbwz=[vertical width of absorbing boundary]:n:' \
  'verbose=[1 show parameters, 2 print max amplitude]:v:(0 1 2)' \
  'velfile=[velocity filename]:f:_files' \
  'densfile=[density filename]:f:_files' \
  'sname=[user supplied source time function filename]:f:_files' \
  'sepxname=[x-direction pressure sections filename]:f:_files' \
  'sepzname=[z-direction pressure sections filename]:f:_files' \
  'snpname=[pressure snapshot filename]:f:_files' \
  'jpfile=[diagnostic output filename]:f:_files' \
  '*:SU file:_files' && ret=0

return ret
