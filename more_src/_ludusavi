#compdef ludusavi
# Documentation: https://man.archlinux.org/search?q=ludusavi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--backup=[Backup output directory]:directory:_directories' \
  '--cloud[Offer cloud sync providers]' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'backup:Copy configured save games'
      'scan:List what would be backed up'
      'cloud:Synchronize cloud saves'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
