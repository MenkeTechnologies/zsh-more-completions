#compdef ffmpeg-tool
# _ffmpeg-tool — FFmpeg multimedia framework CLI alias (FFmpeg team, C); custom argparse
# upstream: https://github.com/FFmpeg/FFmpeg

_ffmpeg-tool() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-formats[show formats]' \
        '-demuxers[show demuxers]' \
        '-muxers[show muxers]' \
        '-devices[show devices]' \
        '-codecs[show codecs]' \
        '-decoders[show decoders]' \
        '-encoders[show encoders]' \
        '-bsfs[show bitstream filters]' \
        '-protocols[show protocols]' \
        '-filters[show filters]' \
        '-pix_fmts[show pixel formats]' \
        '-layouts[show channel layouts]' \
        '-sample_fmts[show sample formats]' \
        '-i+[input file]:file:_files' \
        '-y[overwrite output]' \
        '-n[no overwrite]' \
        '-f+[force format]:str:' \
        '-c+[codec name]:str:' \
        '-codec+[codec name]:str:' \
        '-vcodec+[video codec]:str:' \
        '-acodec+[audio codec]:str:' \
        '-scodec+[subtitle codec]:str:' \
        '-vn[disable video]' \
        '-an[disable audio]' \
        '-sn[disable subtitles]' \
        '-dn[disable data]' \
        '-vf+[video filtergraph]:str:' \
        '-af+[audio filtergraph]:str:' \
        '-filter_complex+[complex filtergraph]:str:' \
        '-filter+[filtergraph]:str:' \
        '-b+[bitrate]:str:' \
        '-ar+[audio rate]:n:' \
        '-ac+[audio channels]:n:' \
        '-vb+[video bitrate]:str:' \
        '-ab+[audio bitrate]:str:' \
        '-r+[frame rate]:str:' \
        '-s+[video size]:str:' \
        '-aspect+[aspect ratio]:str:' \
        '-pix_fmt+[pixel format]:str:' \
        '-t+[duration]:str:' \
        '-to+[stop time]:str:' \
        '-ss+[seek to position]:str:' \
        '-sseof+[seek from end]:str:' \
        '-itsoffset+[input timestamp offset]:str:' \
        '-itsscale+[input timestamp scale]:f:' \
        '-timestamp+[timestamp]:str:' \
        '-metadata+[metadata key=value]:list:' \
        '-disposition+[disposition]:str:' \
        '-map+[stream map]:list:' \
        '-map_metadata+[metadata source]:str:' \
        '-map_chapters+[chapters source]:str:' \
        '-attach+[attachment file]:file:_files' \
        '-streamid+[stream id]:str:' \
        '-program+[program metadata]:str:' \
        '-target+[encoding target]:t:(vcd svcd dvd dv dv50 pal-vcd pal-svcd pal-dvd pal-dv ntsc-vcd ntsc-svcd ntsc-dvd ntsc-dv)' \
        '-pass+[multi pass]:n:' \
        '-passlogfile+[pass logfile]:file:_files' \
        '-stats[print encoding stats]' \
        '-nostats[no encoding stats]' \
        '-loglevel+[log level]:level:(quiet panic fatal error warning info verbose debug trace)' \
        '-v+[log level]:level:(quiet panic fatal error warning info verbose debug trace)' \
        '-report[generate report]' \
        '-progress+[progress URL]:url:_urls' \
        '-hide_banner[hide banner]' \
        '-stream_loop+[stream loop count]:n:' \
        '-loop+[loop]:n:' \
        '-threads+[threads]:n:' \
        '-thread_queue_size+[thread queue size]:n:' \
        '-filter_threads+[filter threads]:n:' \
        '-filter_complex_threads+[filter complex threads]:n:' \
        '-copyts[copy timestamps]' \
        '-copytb+[copy time base]:n:' \
        '-shortest[finish at shortest input]' \
        '-fflags+[format flags]:str:' \
        '-movflags+[mov flags]:str:' \
        '-frames+[frames count]:n:' \
        '-vframes+[video frames]:n:' \
        '-aframes+[audio frames]:n:' \
        '-q:v+[video quality]:n:' \
        '-q:a+[audio quality]:n:' \
        '-crf+[CRF quality]:n:' \
        '-preset+[encoder preset]:p:(ultrafast superfast veryfast faster fast medium slow slower veryslow placebo)' \
        '-tune+[encoder tune]:t:(film animation grain stillimage psnr ssim fastdecode zerolatency)' \
        '-profile:v+[video profile]:str:' \
        '-level+[encoder level]:str:' \
        '-rc_lookahead+[rc lookahead]:n:' \
        '-b:v+[video bitrate]:str:' \
        '-b:a+[audio bitrate]:str:' \
        '-maxrate+[max bitrate]:str:' \
        '-minrate+[min bitrate]:str:' \
        '-bufsize+[rate buffer size]:str:' \
        '-keyint_min+[min keyint]:n:' \
        '-g+[GOP size]:n:' \
        '-sc_threshold+[scene change threshold]:n:' \
        '-deinterlace[deinterlace]' \
        '-hwaccel+[hardware acceleration]:h:(none auto vdpau dxva2 d3d11va vaapi qsv videotoolbox cuvid nvdec)' \
        '-hwaccel_device+[hwaccel device]:str:' \
        '-hwaccel_output_format+[hwaccel output format]:str:' \
        '-init_hw_device+[init hw device]:str:' \
        '-filter_hw_device+[filter hw device]:str:' \
        '*:output:_files'
}

_ffmpeg-tool "$@"
