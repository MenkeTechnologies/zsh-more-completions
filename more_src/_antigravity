#compdef agy antigravity-manager antigravity-usage antigravity-cli
# Documentation: https://man.archlinux.org/search?q=agy
# Reference accessed: 2026-05-16

# Zsh completion for Antigravity ecosystem (lbjlaq)
# https://github.com/lbjlaq/Antigravity-Manager

local curcontext="$curcontext" state line ret=1

if [[ $service == "antigravity-usage" ]]; then
  _arguments -s -S \
    '--all[show usage for all accounts]' \
    '--wakeup[refresh session tokens]' && ret=0
elif [[ $service == "antigravity-cli" ]]; then
  local -a commands=(
    'list-tasks:List all active and historical tasks'
    'show-task:Display task checklist and status'
    'new-task:Initialize a new task folder'
    'get-backup-file:Retrieve versioned backup of an artifact'
  )
  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' && ret=0
  case $state in
    (command)
      _describe -t commands 'antigravity-cli command' commands && ret=0
      ;;
    (args)
      case $words[1] in
        (show-task)
          _arguments -s -S '1:task GUID:' && ret=0
          ;;
        (get-backup-file)
          _arguments -s -S \
            '--artifacttype=[type of artifact]:type:' \
            '--version=[version number]:version:' && ret=0
          ;;
      esac
      ;;
  esac
elif [[ $service == "antigravity-manager" || $service == "agy" ]]; then
  _arguments -s -S \
    '1:subcommand:(sync)' && ret=0
fi

return ret
