#compdef jack-smf-recorder
# Documentation: https://github.com/jackaudio/jack-example-tools
# record JACK MIDI into a standard MIDI file

local ret=1

_arguments -s -S \
  '-a+[automatically connect to named output port]:port' \
  '-V[show version]' \
  '*:MIDI file:_files -g "*.(mid|smf|MID)"' && ret=0

return ret
