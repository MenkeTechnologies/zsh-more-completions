#compdef borgmatic
# Documentation: https://torsion.org/borgmatic/docs/reference/command-line/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for borgmatic

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'repo-create:create a Borg repository'
  'repo-delete:remove a repository'
  'repo-info:show repository information'
  'repo-list:list repositories'
  'create:create a backup archive'
  'prune:prune archives according to retention policy'
  'compact:compact repository to free disk space'
  'check:check repository and archive consistency'
  'extract:extract files from a backup archive'
  'export-tar:export an archive to a tar file'
  'mount:mount an archive as a FUSE filesystem'
  'umount:unmount a FUSE filesystem'
  'restore:restore a database dump from an archive'
  'list:list archive contents'
  'info:show archive information'
  'break-lock:break repository and cache locks'
  'borg:run an arbitrary Borg command'
  'delete:delete archives'
  'diff:compare archives'
  'recreate:rebuild archives with new settings'
  'transfer:transfer archives between repositories'
  'config:manage borgmatic configuration'
  'key-change-passphrase:modify encryption passphrase'
  'key-export:export encryption keys'
  'key-import:import encryption keys'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)--version[show version and exit]' \
  '(-c --config)'{-c,--config}'[configuration file path]:config file:_files' \
  '(-n --dry-run)'{-n,--dry-run}'[go through the motions but do not actually act]' \
  '(-v --verbosity)'{-v,--verbosity}'[log verbosity level]:level:(0 1 2)' \
  '--log-file[write log messages to file]:log file:_files' \
  '--log-file-verbosity[log file verbosity level]:level:(0 1 2)' \
  '--syslog-verbosity[syslog verbosity level]:level:(0 1 2)' \
  '--monitoring-verbosity[monitoring verbosity level]:level:(0 1 2)' \
  '--no-environment-interpolation[do not resolve environment variables in config]' \
  '*:: :->subcmd' && ret=0

case $state in
  subcmd)
    if (( CURRENT == 1 )); then
      _describe -t commands 'borgmatic command' subcommands && ret=0
    fi
    ;;
esac

return ret
