#compdef impacket-filetime
# Documentation: https://github.com/fortra/impacket/blob/master/examples/filetime.py
# File/directory timestamp querying and modification utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-debug[turn DEBUG output ON]' \
  '-hashes=[NTLM hashes, format is LMHASH:NTHASH]:hashes' \
  '-no-pass[don'\''t ask for password (useful for -k)]' \
  '-k[use Kerberos authentication from ccache file]' \
  '-aesKey=[AES key to use for Kerberos authentication (128 or 256 bits)]:hexkey' \
  '(-p --port)'{-p,--port}'=[destination port to connect to the SMB server]:port' \
  '-dc-ip=[IP address of the domain controller]:ip' \
  '-target-ip=[IP address of the target machine]:ip' \
  '(-t --timeout)'{-t,--timeout}'=[set connection timeout (seconds)]:seconds' \
  '1:target (\[\[domain/\]username\[:password\]@\]<host>):' \
  '2:share:' \
  '3:path:' \
  '*::action:((stat\:"show current file/directory timestamps" touch\:"modify file/directory timestamps"))' && ret=0

return ret
