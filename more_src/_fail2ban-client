#compdef fail2ban-client
# Documentation: https://github.com/fail2ban/fail2ban/blob/master/man/fail2ban-client.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# completions for fail2ban-client CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-c+,--conf=}'[configuration directory]:directory:_directories' \
  {-s+,--socket=}'[socket path]:file:_files' \
  {-p+,--pidfile=}'[PID file path]:file:_files' \
  '--pname=[process name identifier]:name:' \
  '-d[dump configuration]' \
  '--dp[dump configuration (pretty)]' \
  '--dump-pretty[dump configuration (pretty)]' \
  '--loglevel=[logging level]:level:(CRITICAL ERROR WARNING NOTICE INFO DEBUG TRACEDEBUG HEAVYDEBUG)' \
  '--logtarget=[log target]:target:(STDOUT STDERR SYSLOG SYSOUT)' \
  '--syslogsocket=[syslog socket]:type:(auto)' \
  '-b[start in background]' \
  '-f[start in foreground]' \
  '-i[interactive mode]' \
  '-x[force execution (remove socket)]' \
  '-v[increase verbosity]' \
  '-q[decrease verbosity]' \
  {-t,--test}'[test configuration]' \
  '--async[start asynchronously]' \
  '--timeout=[timeout for server response]:seconds:' \
  '--str2sec=[convert time abbreviation to seconds]:string:' \
  '*::args:->subcmds' && ret=0

case $state in
  subcmds)
    local -a commands
    commands=(
      'start:start server and jails'
      'restart:restart server and jails'
      'reload:reload configuration'
      'stop:stop all jails and server'
      'status:get current status'
      'ping:test if server is alive'
      'echo:echo arguments back'
      'get:get a configuration value'
      'set:set a configuration value'
      'unban:unban an IP address'
      'banned:list banned IPs'
      'flushlogs:flush log files'
      'statistics:show statistics'
      'version:get server version'
      'add:add a jail'
      'help:show help'
    )
    _describe -t commands 'fail2ban-client command' commands && ret=0
    ;;
esac

return ret
