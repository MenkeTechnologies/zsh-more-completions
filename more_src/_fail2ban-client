#compdef fail2ban-client

# completions for fail2ban-client CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-c+,--conf=}'[configuration directory]:directory:_directories' \
  {-d,--dump}'[dump configuration]' \
  {-p+,--pidfile=}'[PID file path]:file:_files' \
  {-s+,--socket=}'[socket path]:file:_files' \
  '--loglevel=[logging level]:level:(CRITICAL ERROR WARNING NOTICE INFO DEBUG TRACEDEBUG HEAVYDEBUG)' \
  '--logtarget=[log target]:target:(STDOUT STDERR SYSLOG SYSTEMD-JOURNAL)' \
  '--syslogsocket=[syslog socket]:type:(auto udp)' \
  {-b,--background}'[start in background]' \
  {-f,--foreground}'[start in foreground]' \
  '-i[interactive mode]' \
  '--interactive[interactive mode]' \
  {-v,--verbose}'[increase verbosity]' \
  {-t,--test}'[test configuration]' \
  '--async[start asynchronously]' \
  '--timeout=[timeout for server response]:seconds' \
  '*::args:->subcmds' && ret=0

case $state in
  subcmds)
    local -a commands
    commands=(
      'start:start server and jails'
      'restart:restart server and jails'
      'reload:reload configuration'
      'stop:stop all jails and server'
      'status:get current status'
      'ping:test if server is alive'
      'get:get a configuration value'
      'set:set a configuration value'
      'unban:unban an IP address'
      'banned:list banned IPs'
      'flushlogs:flush log files'
      'version:get server version'
    )
    _describe -t commands 'fail2ban-client command' commands && ret=0
    ;;
esac

return ret
