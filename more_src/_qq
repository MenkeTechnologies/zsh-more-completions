#compdef qq
# Documentation: https://github.com/JFryy/qq
# qq - jq-like multi-format (JSON/YAML/TOML/XML/CSV/...) query tool

local ret=1

local formats=(
  json yaml yml toml xml hcl tf csv tsv ini properties gron html
  jsonl ndjson jsonlines jsonc parquet msgpack mpk cbor avro
  base64 b64 txt text proto env
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i+,--input=}'[input format]:format:('"${formats[*]}"')' \
  '(-o --output)'{-o+,--output=}'[output format]:format:('"${formats[*]}"')' \
  '--interactive[launch interactive query builder]' \
  '--stream[streaming mode for large files]' \
  '-s[slurp mode: read multiple inputs into an array]' \
  '-e[exit-status mode for conditionals]' \
  '--monochrome-output[disable colored output]' \
  '*:file:_files' && ret=0

return ret
