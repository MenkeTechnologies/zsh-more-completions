#compdef cbBuild
# Documentation: https://cellbrowser.readthedocs.io/en/master/basic_usage.html
# UCSC Cell Browser - build a cell browser from cellbrowser.conf

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--init[copy sample cellbrowser.conf and desc.conf to current directory]' \
  '(-d --debug)'{-d,--debug}'[show debug messages]' \
  '*'{-i,--inConf=}'[cellbrowser.conf file with labels and input files]:file:_files' \
  '(-o --outDir)'{-o,--outDir=}'[output directory (or set CBOUT env var)]:dir:_files -/' \
  '(-p --port)'{-p,--port=}'[start an http server on this port after build]:port' \
  '(-r --recursive)'{-r,--recursive}'[run in all subdirectories of the current directory]' \
  '--redo=[do not use cached old data]:what:(meta matrix)' && ret=0

return ret
