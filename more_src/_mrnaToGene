#compdef mrnaToGene
# UCSC kent: convert PSL alignments with CDS annotation to genePred

local ret=1

_arguments -s -S \
  '-db=[get PSLs and CDS from this database, psl specifies the table]:db' \
  '-cdsDb=[get CDS from this database, psl is a file]:db' \
  '-cdsFile=[get CDS from this tab-separated file]:file:_files' \
  '-insertMergeSize=[merge inserts no larger than this many bases]:n' \
  '-smallInsertSize=[alias for -insertMergeSize]:n' \
  '-cdsMergeSize=[merge gaps in CDS no larger than this size]:n' \
  '-cdsMergeMod3[only merge CDS gaps if they mod 3]' \
  '-utrMergeSize=[merge gaps in UTR no larger than this size]:n' \
  '-requireUtr[drop sequences lacking both 5 and 3 UTR annotation]' \
  '-genePredExt[create extended genePred, including frame information]' \
  '-allCds[consider PSL to be all CDS]' \
  '-noCds[consider PSL to not contain any CDS]' \
  '-keepInvalid[keep sequences with invalid CDS]' \
  '-quiet[do not print info about dropped sequences]' \
  '-ignoreUniqSuffix[ignore characters after last - in qName when looking up CDS]' \
  '1:psl:_files -g "*.psl"' \
  '2:output genePred:_files' && ret=0

return ret
