#compdef mecab-config
# Documentation: https://manpages.debian.org/testing/libmecab-dev/mecab-config.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--cxx[print C++ compiler]' \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' \
  '--dicdir[print dictionary directory]' \
  '--libexecdir[print libexec directory]' \
  '--sysconfdir[print sysconf directory]' \
  '--libs-only-L[print -L flags only]' \
  '--libs-only-l[print -l flags only]' \
  '--inc-dir[print include directory]' && ret=0

return ret
