#compdef stargzify
# Documentation: https://github.com/google/crfs/blob/master/stargz/stargzify/stargzify.go
# stargzify — convert a remote container image (or tar file) into an equivalent stargz image

local ret=1

_arguments -s -S \
  '(-upgrade)-upgrade[upgrade the image in-place by overwriting the tag]' \
  '(-flatten)-flatten[flatten the image layers into a single layer]' \
  '(-insecure)-insecure[allow HTTP connections to registries prefixed with http://]' \
  '1:input:_files' \
  '2:output:_files' && ret=0

return ret
