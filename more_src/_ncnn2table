#compdef ncnn2table
# Documentation: https://github.com/Tencent/ncnn/wiki/quantized-int8-inference
# Generate an int8 quantization calibration table for an ncnn model

local ret=1

_arguments -s -S \
  '1:ncnn param:_files -g "*.param"' \
  '2:ncnn bin:_files -g "*.bin"' \
  '3:image list:_files' \
  '4:output table:_files -g "*.table"' \
  '*:option (mean= norm= shape= pixel= thread= method=):_default' && ret=0

return ret
