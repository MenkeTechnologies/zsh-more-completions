#compdef sucwt
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/sucwt.c
# generates Continous Wavelet Transform amplitude, regularity

local ret=1

_arguments -s -S \
  'base=[base]:base:' \
  'first=[first]:first:' \
  'expinc=[expinc]:expinc:' \
  'last=[last]:last:' \
  'wtype=[wtype]:wtype:' \
  'nwavelet=[nwavelet]:nwavelet:' \
  'xmin=[xmin]:xmin:' \
  'xcenter=[xcenter]:xcenter:' \
  'xmax=[xmax]:xmax:' \
  'sigma=[sigma]:sigma:' \
  'verbose=[verbose]:verbose:' \
  'holder=[holder]:holder:' \
  'divisor=[divisor]:divisor:' \
  '*:file:_files' && ret=0

return ret
