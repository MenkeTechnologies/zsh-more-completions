#compdef subword-nmt
# Documentation: https://github.com/rsennrich/subword-nmt
# Unsupervised BPE word segmentation for neural MT

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --symbols)'{-s,--symbols}'=[number of merge operations]:n' \
  '--bytes[use bytes as basic units instead of characters]' \
  '--input=[training file(s)]:file:_files' \
  '(-o --output)'{-o,--output}'=[output codes/vocab file]:file:_files' \
  '(-c --codes)'{-c,--codes}'=[BPE codes file to apply]:file:_files' \
  '--vocabulary=[vocabulary file for filtering output]:file:_files' \
  '--vocabulary-threshold=[minimum frequency threshold for vocabulary]:n' \
  '--dropout=[BPE dropout rate]:rate' \
  '--seed=[random seed for reproducibility]:seed' \
  '--glossaries=[subwords/regex patterns to exclude from segmentation]:patterns' \
  '--write-vocabulary=[output vocabulary files]:file:_files' \
  '1:command:(learn-bpe apply-bpe get-vocab learn-joint-bpe-and-vocab)' \
  '*:file:_files' && ret=0

return ret
