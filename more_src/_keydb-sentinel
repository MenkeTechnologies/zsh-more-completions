#compdef keydb-sentinel
# Documentation: https://man.archlinux.org/search?q=keydb-sentinel
# Reference accessed: 2026-05-16

# keydb-sentinel: KeyDB HA sentinel
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--sentinel[sentinel mode (default)]' \
  '*:sentinel.conf:_files -g "*.conf"' && ret=0
return ret
