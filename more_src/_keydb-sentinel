#compdef keydb-sentinel
# Documentation: https://github.com/Snapchat/KeyDB/blob/main/src/server.cpp
# Reference accessed: 2026-05-19
# Verified: keydb-sentinel is keydb-server started in sentinel mode;
# upstream usage() documents "/etc/sentinel.conf --sentinel" plus the
# shared -v/--version, -h/--help options.

# keydb-sentinel: KeyDB HA sentinel (keydb-server in --sentinel mode)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--sentinel[run in sentinel mode]' \
  '1:sentinel config:_files -g "*.conf"' && ret=0
return ret
