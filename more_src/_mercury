#compdef mmc mmake mtags
# Documentation: https://www.mercurylang.org/information/doc-latest/mercury_user_guide/Invocation.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-V[verbose]' \
  '--version[show version]' \
  '-c[compile only - do not link]' \
  '-C[create C source files]' \
  '-O+[optimization level]:level:(0 1 2 3 4 5)' \
  '-d+[debug level]:level:' \
  '-e+[evaluate goal]:goal:' \
  '-g[debug grade]' \
  '-G+[grade]:grade:' \
  '-I+[search dir]:dir:_files -/' \
  '-L+[library dir]:dir:_files -/' \
  '-l+[library]:lib:' \
  '-m+[create static .a library]:name:' \
  '-make[mmake mode]' \
  '-o+[output file]:file:_files' \
  '--make[build via Mmake]' \
  '*:module:_files -g "*.{m,M}"' && ret=0

return ret
