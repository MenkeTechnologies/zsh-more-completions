#compdef MergeMutectStats
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/mutect/MergeMutectStats.java
# GATK4: merge Mutect2 stats files from scattered runs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*--stats=[stats from Mutect2 scatters of a single tumor or tumor-normal pair]:file:_files' \
  '(-O --output)'{-O,--output}'=[output merged stats]:file:_files' \
  '*:options:_files' && ret=0

return ret
