#compdef esedbinfo
# Documentation: https://github.com/libyal/libesedb
# Source: libyal/libesedb manuals/esedbinfo.1 — display info about an Extensible Storage Engine database (.edb).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:ESE database file:_files' \
    && ret=0

return ret
