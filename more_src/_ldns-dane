#compdef ldns-dane
# _ldns-dane — NLnet Labs ldns-dane (DANE/TLSA helper; verify a TLS connection against TLSA records or create TLSA records from a TLS endpoint's certificate)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-dane.c usage on tip.

_ldns-dane() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-v[show version and exit]' \
        '(-4 -6)-4[TLS connect IPv4 only]' \
        '(-4 -6)-6[TLS connect IPv6 only]' \
        '-r+[use resolver at this address]:addr:' \
        '*-a+[connect to this address (skip name resolution)]:addr:' \
        '-b[emit TYPE52 #<size> <hex> generic form]' \
        '-c+[certificate (chain) file for verify/create]:file:_files' \
        '-d[assume DNSSEC valid even when insecure/bogus]' \
        '-f+[CA bundle file]:file:_files' \
        '-i[interact after connecting]' \
        '-k+[trust anchor DNSKEY/DS file (for -S)]:file:_files' \
        '-n[do not verify server name in certificate]' \
        '-o+[select Nth certificate from chain end (-1 = self-signed)]:n:' \
        '-p+[CA directory]:dir:_files -/' \
        '-s[assume PKIX validity]' \
        '-S[chase signatures to a known key]' \
        '-t+[read TLSA records from file (skip DNS)]:file:_files' \
        '-T[exit 2 for PKIX-valid connections lacking secure TLSA]' \
        '-u[UDP transport instead of TCP]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'dane action' '(verify:verify TLS conn / TLSA records create:emit TLSA records from a TLS endpoint)' ;;
        args)
            case $line[1] in
                verify) _arguments '1:name:_hosts' '2:port:' ;;
                create) _arguments '1:name:_hosts' '2:port:' '3:usage:(0 1 2 3 PKIX-TA PKIX-EE DANE-TA DANE-EE)' '4:selector:(0 1 Cert SPKI)' '5:type:(0 1 2 Full SHA2-256 SHA2-512)' ;;
            esac
            ;;
    esac
}

_ldns-dane "$@"
