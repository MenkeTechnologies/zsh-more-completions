#compdef nomad-cli2
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'acl:ACL commands'
  'agent:run a Nomad agent'
  'agent-info:show agent info'
  'alloc:allocation commands'
  'config:CLI config'
  'deployment:deployment commands'
  'eval:evaluation commands'
  'exec:execute in an alloc'
  'fmt:format HCL job spec'
  'job:job commands'
  'login:login via auth method'
  'monitor:stream agent logs'
  'namespace:namespace commands'
  'node:node commands'
  'operator:operator commands'
  'plugin:plugin commands'
  'quota:resource quota commands'
  'recommendation:recommendation commands'
  'scaling:scaling commands'
  'sentinel:sentinel commands'
  'server:server commands'
  'service:service commands'
  'setup:setup commands'
  'status:show status'
  'system:system commands'
  'tls:TLS commands'
  'ui:open Nomad UI'
  'var:variable commands'
  'version:show version'
  'volume:volume commands'
  'help:show help'
  'plan:dry-run a job'
  'run:submit a job'
  'stop:stop a job'
  'validate:validate job spec'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*-address=[Nomad addr]:url:' \
  '*-region=[region]:r:' \
  '*-namespace=[namespace]:n:' \
  '*-no-color[no color]' \
  '*-force-color[force color]' \
  '*-token=[ACL token]:t:' \
  '*-ca-cert=[CA cert]:file:_files' \
  '*-ca-path=[CA path]:dir:_files -/' \
  '*-client-cert=[client cert]:file:_files' \
  '*-client-key=[client key]:file:_files' \
  '*-tls-server-name=[server name]:s:' \
  '*-tls-skip-verify[skip TLS verify]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nomad command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (job)
        _arguments \
          '1:subcommand:(allocs deployments dispatch eval history init inspect periodic plan promote restart revert run scale scaling-events status stop tag validate)' \
          '*: :_files' && ret=0 ;;
      (alloc)
        _arguments \
          '1:subcommand:(checks exec fs logs pause-checks restart resume signal status stop)' \
          '*: :' && ret=0 ;;
      (node)
        _arguments \
          '1:subcommand:(config drain eligibility meta status)' \
          '*: :' && ret=0 ;;
      (server)
        _arguments \
          '1:subcommand:(force-leave join members)' \
          '*: :' && ret=0 ;;
      (operator)
        _arguments \
          '1:subcommand:(api autopilot debug failover gossip metrics raft root scheduler snapshot utilization)' \
          '*: :' && ret=0 ;;
      (acl)
        _arguments \
          '1:subcommand:(auth-method binding-rule bootstrap policy role token)' \
          '*: :' && ret=0 ;;
      (var)
        _arguments \
          '1:subcommand:(get list lock purge put unlock)' \
          '*: :' && ret=0 ;;
      (volume)
        _arguments \
          '1:subcommand:(claim create delete deregister detach init register snapshot status)' \
          '*: :' && ret=0 ;;
      (namespace)
        _arguments \
          '1:subcommand:(apply delete inspect list status)' \
          '*: :' && ret=0 ;;
      (quota)
        _arguments \
          '1:subcommand:(apply delete init inspect list status)' \
          '*: :' && ret=0 ;;
      (deployment)
        _arguments \
          '1:subcommand:(fail list pause promote resume status unblock)' \
          '*: :' && ret=0 ;;
      (eval)
        _arguments \
          '1:subcommand:(delete list status)' \
          '*: :' && ret=0 ;;
      (run)
        _arguments \
          '-check-index=[check index]:n:' \
          '-detach[detach]' \
          '-eval-priority=[priority]:n:' \
          '-output[output JSON]' \
          '-policy-override[policy override]' \
          '-preserve-counts[preserve counts]' \
          '-vault-namespace=[ns]:n:' \
          '-vault-token=[token]:t:' \
          '-verbose[verbose]' \
          '*: :_files -g "*.nomad *.hcl *.json"' && ret=0 ;;
      (plan)
        _arguments \
          '-diff=[diff]:b:(true false)' \
          '-policy-override[policy override]' \
          '-verbose[verbose]' \
          '*: :_files' && ret=0 ;;
      (validate)
        _arguments \
          '-vault-token=[token]:t:' \
          '-vault-namespace=[ns]:n:' \
          '-no-color[no color]' \
          '*: :_files' && ret=0 ;;
      (agent)
        _arguments \
          '-config=[file/dir]:p:_files' \
          '-data-dir=[dir]:dir:_files -/' \
          '-dev[dev mode]' \
          '-dev-connect[dev with connect]' \
          '-bind=[addr]:a:' \
          '-client[client mode]' \
          '-server[server mode]' \
          '-bootstrap-expect=[n]:n:' \
          '-node=[name]:n:' \
          '-region=[region]:r:' \
          '-dc=[datacenter]:dc:' \
          '-state-dir=[dir]:dir:_files -/' \
          '-alloc-dir=[dir]:dir:_files -/' \
          '-encrypt=[key]:k:' \
          '-network-interface=[if]:if:_net_interfaces' \
          '-syslog-facility=[facility]:f:' \
          '-meta=[k=v]:v:' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
