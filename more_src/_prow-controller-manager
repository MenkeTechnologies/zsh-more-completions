#compdef prow-controller-manager
# _prow-controller-manager — Prow controller manager running plank/etc. (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/prow-controller-manager/main.go (flag).

_prow-controller-manager() {
    _arguments \
        '-tot-url=[Tot URL]:url:_urls' \
        '-label-selector=[ProwJob label selector]:selector:' \
        '*-enable-controller=[controller to enable (repeat)]:controller:(plank pipeline)' \
        '-dry-run=[whether to make mutating API calls]:val:(true false)' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls'
}

_prow-controller-manager "$@"
