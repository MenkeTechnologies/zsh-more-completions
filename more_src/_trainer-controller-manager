#compdef trainer-controller-manager training-operator
# _trainer-controller-manager — Kubeflow Training V2 controller manager (kubeflow/training-operator)
# upstream: https://github.com/kubeflow/training-operator
# Flags from cmd/trainer-controller-manager/main.go + controller-runtime zap.Options on tip.

_trainer-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[controller configuration YAML file]:file:_files -g "*.(yml|yaml)(-.)"' \
        '--enable-http2=[allow HTTP/2 on metrics/webhook]:bool:(true false)' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '--zap-stacktrace-level=[stacktrace threshold]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:fmt:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_trainer-controller-manager "$@"
