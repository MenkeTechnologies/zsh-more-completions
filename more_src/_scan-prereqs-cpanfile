#compdef scan-prereqs-cpanfile
# Documentation: https://metacpan.org/pod/release/TOKUHIROM/App-scan_prereqs_cpanfile-1.03/script/scan-prereqs-cpanfile
# scan-prereqs-cpanfile - scan prerequisite modules and generate cpanfile

local ret=1

_arguments -s -S \
  '--version[show version and exit]' \
  '--diff=[compare result with META/cpanfile, show missing only]:file:_files' \
  '--ignore=[ignore some directories]:dir:_files -/' \
  '--ignore-file=[file listing regex patterns to ignore]:file:_files' \
  '--include-empty[allow empty phase blocks in cpanfile]' \
  '--scan-test-requires[include Test::Requires modules as develop requires]' \
  '--dir=[scan modules in specified directory]:dir:_files -/' \
  '--match-versions[match module versions]' && ret=0

return ret
