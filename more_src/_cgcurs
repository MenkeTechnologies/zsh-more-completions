#compdef cgcurs
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/cgcurs.html
# MIRIAD: display images and read values with a cursor

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[one or two input images]:in:_files' \
  'type=[image display type]:type:(pixel contour both)' \
  'region=[region of interest]:region:' \
  'xybin=[spatial increment and binning]:xybin:' \
  'chan=[channel increment and averaging]:chan:' \
  'slev=[contour level scale factor]:slev:' \
  'levs=[contour levels]:levs:' \
  'range=[pixel map range and transfer function]:range:' \
  'device=[PGPLOT device]:device:' \
  'nxy=[subplots in x and y]:nxy:' \
  'labtyp=[spatial label types]:labtyp:(hms dms arcsec arcmin absdeg reldeg abspix relpix abskms relkms absghz relghz absnat relnat)' \
  'options=[cursor,stats,region,fiddle,grid,logfile,mark,nearest,wedge,3value,3pixel]:options:' \
  '3format=[third-axis label format]:3format:' \
  'csize=[character sizes]:csize:' \
  '*:image:_files' && ret=0

return ret
