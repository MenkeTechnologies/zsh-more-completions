#compdef cosmic-randr
# _cosmic-randr — Wayland output configuration tool (pop-os/cosmic-randr)
# upstream: https://github.com/pop-os/cosmic-randr
# Subcommands from cli/src/main.rs (clap derive).

_cosmic-randr() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'disable:disable a display'
                'enable:enable a display'
                'mirror:mirror a display'
                'list:list available output heads and modes'
                'mode:set a mode for a display'
                'position:set position of a display'
                'xwayland:Xwayland compatibility options'
                'kdl:apply output configurations from KDL (stdin)'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                disable|enable) _arguments ':output:' ;;
                mirror) _arguments ':output:' ':source:' ;;
                list)   _arguments '--kdl[output in KDL format]' ;;
                mode)
                    _arguments \
                        '--refresh=[refresh rate (Hz)]:hz:' \
                        '--adaptive-sync=[adaptive sync mode]:mode:(disabled enabled always)' \
                        '--pos-x=[X position]:x:' \
                        '--pos-y=[Y position]:y:' \
                        '--scale=[scale factor]:f:' \
                        '--test[test config without applying]' \
                        '--transform=[output transform]:tx:(normal 90 180 270 flipped flipped-90 flipped-180 flipped-270)' \
                        ':output:' \
                        ':width:' \
                        ':height:'
                    ;;
                position)
                    _arguments \
                        '--test[test config without applying]' \
                        ':output:' \
                        ':x:' \
                        ':y:'
                    ;;
                xwayland)
                    _arguments \
                        '--primary=[set output as primary]:output:' \
                        '--no-primary[unset primary]'
                    ;;
            esac
            ;;
    esac
}

_cosmic-randr "$@"
