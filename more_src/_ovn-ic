#compdef ovn-ic
# _ovn-ic — OVN ovn-ic interconnection controller for multi-AZ stretched OVN deployments (ovn-org team, C); custom argparse
# upstream: https://github.com/ovn-org/ovn

_ovn-ic() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose modules]:str:' \
        '--verbose=+[verbose modules]:str:' \
        '--ovnnb-db=+[NB DB]:str:' \
        '--ovnsb-db=+[SB DB]:str:' \
        '--ovn-ic-nb-db=+[IC NB DB]:str:' \
        '--ovn-ic-sb-db=+[IC SB DB]:str:' \
        '--unixctl=+[unixctl socket]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '--pidfile=+[pid file]:file:_files' \
        '--detach[run as background process]' \
        '--no-chdir[do not chdir to /]' \
        '--monitor[run with monitor]' \
        '--syslog-method=+[method]:m:(libc syslog null udp)' \
        '--syslog-target=+[target]:str:'
}

_ovn-ic "$@"
