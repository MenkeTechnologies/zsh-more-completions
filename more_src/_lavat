#compdef lavat
# Documentation: https://man.archlinux.org/search?q=lavat
# Reference accessed: 2026-05-16

# https://github.com/AngelJumbo/lavat — lava lamp TUI (clap; see release help)
_arguments -s -S \
  '-h[help]' \
  '--help[help]' \
  '-V[version]' \
  '--version[version]' \
  '--fps=-[animation frame rate]:fps:' \
  '--theme=-[color palette name]:theme:' \
  '--scene=-[preset scene]:scene:' \
  '--resolution=-[simulation lattice]:WxH:' \
  '*:ignored:_default'
