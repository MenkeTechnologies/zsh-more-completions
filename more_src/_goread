#compdef goread
# Documentation: https://man.archlinux.org/search?q=goread
# Reference accessed: 2026-05-16

# https://github.com/TypicalAM/goread — cobra RSS TUI (`goread --help`)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '-v[verbose]' \
  '--config=-[config path]:file:_files' \
  '1:command:(read sync import export config version)' \
  '*::arguments:_default'
