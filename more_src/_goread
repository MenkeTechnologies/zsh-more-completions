#compdef goread
# Documentation: https://github.com/TypicalAM/goread
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# TypicalAM/goread — RSS/Atom feed TUI.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--dump_colors[generate a colorscheme file]' \
  '--get_colors=[generate colorscheme from pywal colors.json]:file:_files' \
  '1:command:(edit)' \
  '*::edit args:->editargs' && ret=0

case $state in
  editargs)
    if (( CURRENT == 2 )); then
      _values 'edit target' urls config && ret=0
    fi
    ;;
esac

return ret
