#compdef flux-kvs
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-kvs.html
# access the Flux key-value store

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-N --namespace)'{-N,--namespace=}'[specify alternate namespace]:name' \
  '(-r --raw)'{-r,--raw}'[display or store value raw]' \
  '(-t --treeobj)'{-t,--treeobj}'[interpret value as RFC 11 tree object]' \
  '(-a --at)'{-a,--at=}'[lookup relative to directory reference]:treeobj' \
  '(-l --label)'{-l,--label}'[add key= prefix to output]' \
  '(-W --waitcreate)'{-W,--waitcreate}'[wait until key exists]' \
  '(-w --watch)'{-w,--watch}'[monitor for changes]' \
  '(-c --count)'{-c,--count=}'[display N values then exit]:n' \
  '(-u --uniq)'{-u,--uniq}'[suppress duplicate values]' \
  '(-A --append)'{-A,--append}'[append instead of overwrite]' \
  '(-f --full)'{-f,--full}'[monitor changes with complete accuracy]' \
  '(-S --stream)'{-S,--stream}'[return large values in multiple responses]' \
  '(-R --recursive)'{-R,--recursive}'[operate recursively]' \
  '(-d --directory)'{-d,--directory}'[list directory entries without values]' \
  '(-w --width)'{-w,--width=}'[truncate values to N columns]:n' \
  '(-O --treeobj-root)'{-O,--treeobj-root}'[display new root directory reference]' \
  '(-b --blobref)'{-b,--blobref}'[display root reference as blobref]' \
  '(-s --sequence)'{-s,--sequence}'[display new root sequence number]' \
  '(-n --no-merge)'{-n,--no-merge}'[prevent commit from combining]' \
  '(-F --classify)'{-F,--classify}'[append type indicators]' \
  '(-H --human)'{-H,--human}'[display human-readable form]' \
  '(-L --color)'{-L,--color=}'[colorize output]:when:(always never auto)' \
  '1:subcommand:(get put dir ls unlink link readlink mkdir copy move getroot version wait sync namespace eventlog)' \
  '*::args:_default' && ret=0

return ret
