#compdef git-cal
# Documentation: https://man.archlinux.org/search?q=git-cal
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/git-cal — Git calendar / heatmap commits

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
