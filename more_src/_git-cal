#compdef git-cal
# Documentation: https://github.com/k4rthik/git-cal
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git-cal - calendar/heatmap of commits

_arguments -s -S \
  '--ascii[use ASCII characters instead of ANSI colors]' \
  '--unicode[use Unicode characters instead of ANSI colors]' \
  '--author=[restrict to this author]:author' \
  '--period=[number of weeks to display]:weeks' \
  '--firstdayofweek=[first day of week (0=Sunday)]:day' \
  '--help[show help]' \
  '*:git directory:_files -/' && return 0
