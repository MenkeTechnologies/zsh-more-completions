#compdef covar gmx-covar
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-covar.html
# Calculate and diagonalize the covariance matrix from trajectories

local ret=1

_arguments -s -S \
  '-f+[input trajectory file]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-s+[structure and mass database]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-n+[index file]:index file:_files -g "*.ndx"' \
  '-o+[output eigenvalues]:xvg file:_files -g "*.xvg"' \
  '-v+[output eigenvectors trajectory]:trr file:_files -g "*.(trr|cpt|tng|h5md)"' \
  '-av+[output average structure]:structure:_files -g "*.(gro|g96|pdb|brk|ent|esp)"' \
  '-l+[output log file]:log file:_files -g "*.log"' \
  '-ascii+[output covariance matrix as ASCII]:file:_files -g "*.dat"' \
  '-xpm+[output covariance matrix as XPM]:xpm file:_files -g "*.xpm"' \
  '-xpma+[output atomic covariance matrix as XPM]:xpm file:_files -g "*.xpm"' \
  '-b+[start time ps]:time:' \
  '-e+[end time ps]:time:' \
  '-dt+[frame sampling interval ps]:time:' \
  '-tu+[time unit]:unit:(fs ps ns us ms s)' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-last+[final eigenvector to output]:n:' \
  '-fit[apply reference structure fitting]' \
  '-ref[use structure file deviation instead of average]' \
  '-mwa[apply mass-weighting to analysis]' \
  '-pbc[apply periodic boundary corrections]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
