#compdef vcfleftalign
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfleftalign.md
# vcflib: left-align indels and complex variants against a reference

local ret=1

_arguments -s -S \
  '(-r --reference)'{-r,--reference}'[use this reference as a basis for realignment]:reference:_files' \
  '(-w --window)'{-w,--window}'[use a window of this many bp when left aligning (150)]:N' \
  '*:vcf file:_files' && ret=0

return ret
