#compdef structurizr-cli

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '-id+[Structurizr workspace id]:id:' \
  '-key+[Structurizr API key]:key:' \
  '-secret+[Structurizr API secret]:secret:' \
  '-url+[Structurizr API base URL]:url:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'push:Upload a DSL or JSON workspace'
      'pull:Download remote workspace JSON'
      'lock:Acquire workspace edit lock'
      'unlock:Release workspace edit lock'
      'export:Render diagrams locally'
      'list:List supported export formats'
      'version:Print CLI version'
      'help:Help about any command'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
