#compdef Reproject
# Documentation: https://github.com/senbox-org/snap-engine/blob/master/snap-gpf/src/main/java/org/esa/snap/core/gpf/common/reproject/ReprojectionOp.java
# ESA SNAP gpt Reproject operator - reproject a product into a target CRS

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-PwktFile=-[file containing target CRS in WKT format]:file:_files' \
  '-Pcrs=-[target CRS in WKT or as an authority code]:crs' \
  '-PresamplingName=-[resampling method for floating-point raster data]:method:(Nearest Bilinear Bicubic)' \
  '-PreferencePixelX=-[X-position of the reference pixel]:x' \
  '-PreferencePixelY=-[Y-position of the reference pixel]:y' \
  '-Peasting=-[easting of the reference pixel]:easting' \
  '-Pnorthing=-[northing of the reference pixel]:northing' \
  '-Porientation=-[orientation of the output product in degrees]:degrees' \
  '-PpixelSizeX=-[pixel size in X direction in CRS units]:size' \
  '-PpixelSizeY=-[pixel size in Y direction in CRS units]:size' \
  '-Pwidth=-[width of the target product]:width' \
  '-Pheight=-[height of the target product]:height' \
  '-PtileSizeX=-[tile size in X direction]:size' \
  '-PtileSizeY=-[tile size in Y direction]:size' \
  '-Porthorectify=-[whether the source product should be orthorectified]:bool:(true false)' \
  '-PelevationModelName=-[elevation model for the orthorectification]:dem' \
  '-PnoDataValue=-[value used to indicate no-data]:value' \
  '-PincludeTiePointGrids=-[whether tie-point grids are included in output]:bool:(true false)' \
  '-PaddDeltaBands=-[whether to add delta longitude and latitude bands]:bool:(true false)' \
  '*:source product:_files' && ret=0

return ret
