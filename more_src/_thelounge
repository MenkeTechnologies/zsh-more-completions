#compdef thelounge

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start server'
  'install:install package'
  'uninstall:uninstall package'
  'upgrade:upgrade packages'
  'outdated:check for updates'
  'add:add user'
  'remove:remove user'
  'reset:reset password'
  'edit:edit user config'
  'list:list users'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--home=+[home directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'thelounge command' commands && ret=0 ;;
esac

return ret
