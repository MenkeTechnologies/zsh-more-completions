#compdef twoBitToFa twoBitInfo
# _twoBitToFa — UCSC Kent Lab twoBitToFa convert UCSC 2bit binary genome format to FASTA (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/twoBit.html

_twoBitToFa() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-seq=+[seq name]:str:' \
        '-start=+[start position]:n:' \
        '-end=+[end position]:n:' \
        '-seqList=+[seq list file]:file:_files' \
        '-noMask[no masking]' \
        '-bpt=+[bpt file]:file:_files' \
        '-bed=+[BED file]:file:_files -g "*.bed"' \
        '-bedPos[bed positions]' \
        '-udcDir=+[UDC cache dir]:dir:_files -/' \
        '-chromAliasBb=+[file]:file:_files' \
        '*:in_2bit out_fa:_files -g "*.2bit *.fa *.fasta"'
}

_twoBitToFa "$@"
