#compdef METAL
# Documentation: https://genome.sph.umich.edu/wiki/METAL_Command_Reference
# METAL meta-analysis of genome-wide association scans (script keyword driven)

local ret=1

_values 'METAL command' \
  'SCHEME[meta-analysis scheme SAMPLESIZE or STDERR]' \
  'MARKERLABEL[column header for marker name]' \
  'ALLELELABELS[column headers for alleles]' \
  'EFFECTLABEL[column header for effect size]' \
  'STDERRLABEL[column header for standard error]' \
  'PVALUELABEL[column header for p-value]' \
  'WEIGHTLABEL[column header for weight]' \
  'FREQLABEL[column header for allele frequency]' \
  'STRANDLABEL[column header for strand]' \
  'CHROMOSOMELABEL[column header for chromosome]' \
  'POSITIONLABEL[column header for position]' \
  'DEFAULTWEIGHT[default weight when none given]' \
  'MINWEIGHT[minimum weight filter]' \
  'SEPARATOR[input field separator]' \
  'COLUMNCOUNTING[strict or lenient column counting]' \
  'GENOMICCONTROL[apply genomic control ON OFF or value]' \
  'AVERAGEFREQUENCY[report average allele frequency]' \
  'MINMAXFREQUENCY[report min and max allele frequency]' \
  'CUSTOMVARIABLE[track a custom summed variable]' \
  'LABEL[label a custom variable column]' \
  'ADDFILTER[add a filter on an input column]' \
  'REMOVEFILTERS[remove all filters]' \
  'TRACKPOSITIONS[track chromosome and position]' \
  'USESTRAND[account for strand information]' \
  'FLIP[flip alleles for input file]' \
  'LOGPVALUE[report log10 p-values]' \
  'ZCUTOFF[z-score cutoff]' \
  'OVERLAP[correct for sample overlap]' \
  'MAXWARNINGS[maximum number of warnings]' \
  'EFFECT_PRINT_PRECISION[effect output precision]' \
  'STDERR_PRINT_PRECISION[stderr output precision]' \
  'VERBOSE[verbose output ON or OFF]' \
  'OUTFILE[output filename prefix and suffix]' \
  'PROCESSFILE[process an input file]' \
  'PROCESS[process an input file]' \
  'ANALYZE[run the meta-analysis]' \
  'ANALYSE[run the meta-analysis]' \
  'CLEAR[clear loaded files and settings]' \
  'SOURCE[execute commands from a script file]' \
  'HELP[show help]' \
  'QUIT[exit METAL]' \
  'EXIT[exit METAL]' && ret=0

return ret
