#compdef maas-syslog

# maas-syslog: rsyslog forwarder bundled with MAAS rack controller
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[rsyslog config file]:file:_files' \
  '--pidfile=[PID file]:file:_files' \
  '--no-fork[run in foreground]' \
  '*::maas-syslog args:_files' && ret=0
return ret
