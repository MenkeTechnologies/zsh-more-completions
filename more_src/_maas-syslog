#compdef maas-syslog
# Documentation: https://github.com/maas/maas
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: maas-syslog is the rsyslog wrapper bundled with MAAS rack controller; minimal completion.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[rsyslog config file]:file:_files' \
  '--pidfile=[PID file]:file:_files' \
  '--no-fork[run in foreground]' \
  '*::maas-syslog args:_files' && ret=0
return ret
