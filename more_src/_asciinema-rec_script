#compdef asciinema-rec_script
# Documentation: https://github.com/yertto/asciinema-rec_script
# asciinema-rec_script - record comments and commands from shell scripts

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:script file:_files' \
  '*::asciinema rec args:_files' && ret=0

return ret
