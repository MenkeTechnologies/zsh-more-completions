#compdef fastlane

# Zsh completion for fastlane - mobile app CI/CD automation tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run a fastlane action'
  'action:show information for a specific action'
  'actions:list all available actions'
  'lanes:list all available lanes'
  'list:list all available lanes'
  'init:create a new Fastfile'
  'new_action:create a new custom action'
  'docs:generate documentation for lanes'
  'env:print fastlane environment info'
  'search:search for plugins'
  'enable_auto_complete:enable tab auto completion'
  'pem:generate push notification certificates'
  'produce:create new iOS apps on Apple Developer Portal and App Store Connect'
  'cert:create new iOS code signing certificates'
  'sigh:manage iOS provisioning profiles'
  'snapshot:automate taking localized screenshots'
  'frameit:put device frames around screenshots'
  'deliver:upload screenshots, metadata, and binaries to App Store Connect'
  'supply:upload metadata, screenshots, and binaries to Google Play'
  'screengrab:automate taking localized screenshots on Android'
  'gym:build and package iOS apps'
  'pilot:manage TestFlight builds'
  'match:sync certificates and profiles across teams'
  'precheck:check app metadata before submission'
  'scan:run tests for iOS and Mac apps'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--verbose[print detailed output]' \
  '--capture_output[capture all output]' \
  '--suppress_output[suppress output]' \
  '--env[load a specific environment]:environment:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'fastlane command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':action name:' \
          '*:arguments:' && ret=0
        ;;
      (action|search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':action name:' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
