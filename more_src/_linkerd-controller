#compdef linkerd-controller
# _linkerd-controller — Linkerd2 multiplexed control-plane binary (linkerd/linkerd2)
# upstream: https://github.com/linkerd/linkerd2
# Subcommands from controller/cmd/main.go switch on tip.

_linkerd-controller() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                destination:'gRPC destination/discovery server'
                heartbeat:'periodic anonymous telemetry heartbeat (CronJob)'
                identity:'mTLS identity issuer (SVID signer)'
                proxy-injector:'mutating webhook that injects the sidecar proxy'
                sp-validator:'ServiceProfile validating admission webhook'
                service-mirror:'multicluster service-mirror controller'
            )
            _describe -t commands 'linkerd-controller subcommand' cmds
            ;;
        args)
            case $words[1] in
                destination)
                    _arguments \
                        '-addr=[gRPC server bind host\:port]:host\:port:' \
                        '-metrics-addr=[Prometheus metrics bind host\:port]:host\:port:' \
                        '-kubeconfig=[kubeconfig file]:file:_files' \
                        '-controller-namespace=[Linkerd control-plane namespace]:ns:' \
                        '-outbound-transport-mode=[outbound transport mode]:mode:(transparent original-dst)' \
                        '-enable-h2-upgrade=[allow HTTP/2 upgrade]:bool:(true false)' \
                        '-enable-endpoint-slices=[consume EndpointSlices]:bool:(true false)' \
                        '-enable-ipv6=[enable IPv6 endpoint resolution]:bool:(true false)' \
                        '-identity-trust-domain=[identity trust domain suffix]:domain:' \
                        '-cluster-domain=[Kubernetes cluster domain]:domain:' \
                        '-default-opaque-ports=[default opaque ports (comma-sep)]:ports:' \
                        '-enable-pprof[expose pprof on the admin server]' \
                        '-export-queue-metrics=[export queue metrics]:bool:(true false)' \
                        '-stream-queue-capacity=[per-stream update buffer size]:n:' \
                        '-ext-endpoint-zone-weights[zone-weighted external endpoints]' \
                        '-meshed-http2-client-params=[meshed HTTP/2 client params JSON]:json:'
                    ;;
            esac
            ;;
    esac
}

_linkerd-controller "$@"
