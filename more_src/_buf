#compdef buf

# Zsh completion for buf (Buf CLI for Protocol Buffers)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '--debug[Turn on debug logging]' \
  '--log-format=[Log format]:format:(text color json)' \
  '--timeout=[Timeout duration]:duration' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:Build Protobuf files into a Buf image'
      'breaking:Check for breaking changes'
      'lint:Lint Protobuf files'
      'generate:Generate code stubs from Protobuf files'
      'format:Format Protobuf files'
      'export:Export Protobuf files from a module'
      'curl:Invoke an RPC endpoint'
      'dep:Manage dependencies'
      'mod:Manage buf modules'
      'push:Push a module to the BSR'
      'registry:Manage assets on the BSR'
      'config:Manage buf configuration'
      'convert:Convert a message between binary, JSON, and text'
      'beta:Beta commands (unstable)'
      'alpha:Alpha commands (unstable)'
    )
    _describe -t commands 'buf command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build)
        _arguments -s -S \
          '--path=[Limit to specific files or directories]:path:_files' \
          '--exclude-path=[Exclude specific files or directories]:path:_files' \
          '-o+[Output location]:file:_files' \
          '--output=[Output location]:file:_files' \
          '--as-file-descriptor-set[Output as FileDescriptorSet instead of Image]' \
          '--exclude-imports[Exclude imports from output]' \
          '--exclude-source-info[Exclude source info from output]' \
          '--error-format=[Error format]:format:(text json msvs gnu)' \
          '--config=[Path to buf.yaml]:file:_files' \
          '--disable-symlinks[Do not follow symlinks]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:input:_files' && ret=0
        ;;
      lint)
        _arguments -s -S \
          '--path=[Limit to specific files or directories]:path:_files' \
          '--exclude-path=[Exclude specific files or directories]:path:_files' \
          '--config=[Path to buf.yaml]:file:_files' \
          '--error-format=[Error format]:format:(text json msvs gnu)' \
          '--disable-symlinks[Do not follow symlinks]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:input:_files' && ret=0
        ;;
      breaking)
        _arguments -s -S \
          '--against=[The source to check against]:input' \
          '--against-config=[Config for the against source]:file:_files' \
          '--path=[Limit to specific files or directories]:path:_files' \
          '--exclude-path=[Exclude specific files or directories]:path:_files' \
          '--config=[Path to buf.yaml]:file:_files' \
          '--error-format=[Error format]:format:(text json msvs gnu)' \
          '--exclude-imports[Exclude imports]' \
          '--disable-symlinks[Do not follow symlinks]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:input:_files' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '--template=[Path to buf.gen.yaml]:file:_files' \
          '--path=[Limit to specific files or directories]:path:_files' \
          '--exclude-path=[Exclude specific files or directories]:path:_files' \
          '--config=[Path to buf.yaml]:file:_files' \
          '-o+[Base output directory]:dir:_directories' \
          '--output=[Base output directory]:dir:_directories' \
          '--include-imports[Include imports in generation]' \
          '--include-wkt[Include Well-Known Types in generation]' \
          '--disable-symlinks[Do not follow symlinks]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:input:_files' && ret=0
        ;;
      format)
        _arguments -s -S \
          '--path=[Limit to specific files or directories]:path:_files' \
          '--exclude-path=[Exclude specific files or directories]:path:_files' \
          '--config=[Path to buf.yaml]:file:_files' \
          '-w[Rewrite files in place]' \
          '--write[Rewrite files in place]' \
          '-d[Display diffs instead of rewriting]' \
          '--diff[Display diffs instead of rewriting]' \
          '--exit-code[Exit with non-zero status if files are not formatted]' \
          '--disable-symlinks[Do not follow symlinks]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:input:_files' && ret=0
        ;;
      export)
        _arguments -s -S \
          '-o+[Output directory]:dir:_directories' \
          '--output=[Output directory]:dir:_directories' \
          '--path=[Limit to specific files or directories]:path:_files' \
          '--exclude-path=[Exclude specific files or directories]:path:_files' \
          '--config=[Path to buf.yaml]:file:_files' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:input:_files' && ret=0
        ;;
      curl)
        _arguments -s -S \
          '--data=[Request body data]:data' \
          '-d+[Request body data]:data' \
          '--schema=[Path to schema for request]:input' \
          '--protocol=[RPC protocol]:protocol:(grpc grpcweb connect)' \
          '-H+[Extra header]:header' \
          '--header=[Extra header]:header' \
          '--http2-prior-knowledge[Use HTTP/2 without upgrade]' \
          '-k[Skip TLS certificate verification]' \
          '--insecure[Skip TLS certificate verification]' \
          '--key=[Path to private key for mTLS]:file:_files' \
          '--cert=[Path to client certificate for mTLS]:file:_files' \
          '--cacert=[Path to CA certificate]:file:_files' \
          '-o+[Output file]:file:_files' \
          '--output=[Output file]:file:_files' \
          '-v[Verbose output]' \
          '--verbose[Verbose output]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:URL' && ret=0
        ;;
      dep)
        local -a subcmds=(
          'graph:Print the dependency graph'
          'prune:Prune unused dependencies'
          'update:Update dependencies to latest versions'
        )
        _describe -t subcmds 'dep subcommand' subcmds && ret=0
        ;;
      mod)
        local -a subcmds=(
          'init:Initialize a buf.yaml'
          'ls-breaking-rules:List all breaking rules'
          'ls-lint-rules:List all lint rules'
          'open:Open the module page on the BSR'
          'prune:Prune module unused dependencies'
          'update:Update module dependencies'
        )
        _describe -t subcmds 'mod subcommand' subcmds && ret=0
        ;;
      push)
        _arguments -s -S \
          '--tag=[Associate a tag]:tag' \
          '--label=[Associate a label]:label' \
          '--create[Create the repository if it does not exist]' \
          '--create-visibility=[Visibility for created repository]:vis:(public private)' \
          '--error-format=[Error format]:format:(text json)' \
          '--source-control-url=[Source control URL to associate]:url' \
          '--disable-symlinks[Do not follow symlinks]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:input:_files' && ret=0
        ;;
      convert)
        _arguments -s -S \
          '--type=[Full type name of the message]:type' \
          '--from=[Input format]:format:(bin json txtpb)' \
          '--to=[Output format]:format:(bin json txtpb)' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:input:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
