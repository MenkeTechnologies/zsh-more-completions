#compdef nvgetdtb
# Documentation: https://man.archlinux.org/search?q=nvgetdtb
# Reference accessed: 2026-05-16

# nvgetdtb: retrieve device tree from Tegra device
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-d[device]:dev:' \
  '-c[config]:file:_files' \
  '-i[image]:file:_files' \
  '*::nvgetdtb args:_files' && ret=0
return ret
