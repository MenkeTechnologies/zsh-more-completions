#compdef zcmp
# Documentation: https://man.archlinux.org/man/zcmp.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: zcmp is a wrapper around cmp invoked on gzipped files; passes
# all cmp(1) flags through. Keep positional file completion only.

local -a arguments

arguments=(
    '1:compressed file:_files -g "*.{gz,Z,tgz,bz2,xz,lzma,zst}"'
    '2:compressed file:_files -g "*.{gz,Z,tgz,bz2,xz,lzma,zst}"'
)

_arguments -s -S $arguments
