#compdef conprof
# Documentation: https://github.com/grafana/conprof
# conprof - continuous profiling for pprof-compatible profiles

local ret=1
local -a subcommands=(
  'all:run sampler, storage and web interface together'
  'sampler:collect profiles from configured targets'
  'web:run the web interface'
  'storage:run the profile storage'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config.file=[configuration file path]:file:_files' \
  '--http-address=[HTTP server address]:address:' \
  '--storage.tsdb.path=[storage path for the time-series database]:path:_files -/' \
  '1:command:(($subcommands))' \
  '*::arg:_files' && ret=0

return ret
