#compdef activemq-admin

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start an ActiveMQ broker'
  'stop:stop a running broker'
  'list:list all running brokers in JMX context'
  'query:query JMX context for mbean attributes'
  'bstat:display broker statistics and metrics'
  'browse:browse selected destinations'
  'purge:delete selected destination messages matching selector'
  'dstat:show destination statistics on broker'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--jmxurl=[JMX service URL]:url:' \
  '--jmxuser=[JMX user]:user:_users' \
  '--jmxpassword=[JMX password]:password:' \
  '--jmxlocal[use local JMX connector]' \
  '--all[apply to all matching items]' \
  '--amqurl=[ActiveMQ broker URL]:url:' \
  '--msgsel=[JMS message selector]:selector:' \
  '*-Q+[predefined query]:query:' \
  '*-xQ+[excluded query]:query:' \
  '--objname=[MBean object name]:name:' \
  '--view=[comma-separated attribute view list]:view:' \
  '*-V+[view options for browse]:view:' \
  '*-D+[set system property]:property:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'activemq-admin subcommand' subcommands && ret=0
    ;;
esac

return ret
