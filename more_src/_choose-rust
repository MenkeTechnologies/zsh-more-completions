#compdef choose-rust choose
# Documentation: https://man.archlinux.org/search?q=choose-rust
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --character-wise)'{-c,--character-wise}'[choose fields by character number]' \
  '(-d --debug)'{-d,--debug}'[activate debug mode]' \
  '(-x --exclusive)'{-x,--exclusive}'[use exclusive ranges]' \
  '(-n --non-greedy)'{-n,--non-greedy}'[non-greedy field separators]' \
  '(-f --field-separator)'{-f+,--field-separator=}'[field separator regex]:regex:' \
  '(-i --input)'{-i+,--input=}'[input file]:file:_files' \
  '(-o --output-field-separator)'{-o+,--output-field-separator=}'[output field separator]:sep:' \
  '*::field_range:' && ret=0

return ret
