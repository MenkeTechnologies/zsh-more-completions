#compdef smbios-upflag-ctl
# Documentation: https://man.archlinux.org/man/extra/libsmbios/smbios-upflag-ctl.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# smbios-upflag-ctl: query/set Dell Boot To UP Flag in CMOS
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[display libsmbios version information]' \
  '(--set -s --clear --get -g)'{-s,--set}'[set Boot To UP Flag to true]' \
  '(--set -s --clear --get -g)--clear[set Boot To UP Flag to false]' \
  '(--set -s --clear --get -g -g)'{-g,--get}'[get Boot To UP Flag state]' \
  '(-m --memory_file)'{-m+,--memory_file=}'[memory dump file to use instead of physical memory]:file:_files' \
  '--cmos_file=[CMOS dump file to use instead of physical CMOS]:file:_files' && ret=0
return ret
