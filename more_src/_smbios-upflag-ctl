#compdef smbios-upflag-ctl

# smbios-upflag-ctl: query Dell update-flag in CMOS
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  "--get[get update flag state]" "--set=[set update flag state]:val:(0 1)" \
  '*::smbios-upflag-ctl args:_files' && ret=0
return ret
