#compdef snowflake-broker
# Documentation: https://man.archlinux.org/search?q=snowflake-broker
# Reference accessed: 2026-05-16

# snowflake-broker: pluggable transport broker (matches clients with proxies)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-addr=[listen addr]:addr:' \
  '-acme-cert-cache=[ACME cert cache dir]:dir:_files -/' \
  '-acme-email=[ACME email]:email:' \
  '-acme-hostnames=[ACME hostnames]:hosts:' \
  '-disable-tls[disable TLS termination]' \
  '-cert=[TLS cert]:file:_files' \
  '-key=[TLS key]:file:_files' \
  '-geoipdb=[GeoIP DB]:file:_files' \
  '-geoip6db=[GeoIP6 DB]:file:_files' \
  '-metrics-log=[metrics log file]:file:_files' \
  '-unsafe-logging[unsafe logging]' \
  '-prometheus-cumulative-snowflake-stats[cumulative snowflake stats]' \
  '*::snowflake-broker args:_files' && ret=0
return ret
