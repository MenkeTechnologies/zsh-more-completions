#compdef snowflake-broker

# snowflake-broker: Snowflake matchmaker between clients and proxies
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '-acme-hostnames[hostnames for ACME TLS]:hosts:' \
  '-acme-email[email for ACME registration]:email:' \
  '-addr[HTTP listen address]:host:port:' \
  '-cert[TLS cert file]:file:_files' \
  '-key[TLS key file]:file:_files' \
  '-disable-tls[disable TLS]' \
  '-disable-geoip[disable GeoIP lookup]' \
  '-geoipdb[GeoIP IPv4 database]:file:_files' \
  '-geoip6db[GeoIP IPv6 database]:file:_files' \
  '-metrics-log[metrics log file]:file:_files' \
  '-log[log file]:file:_files' \
  '*::snowflake-broker args:_files' && ret=0
return ret
