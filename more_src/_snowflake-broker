#compdef snowflake-broker
# Documentation: https://gitlab.torproject.org/tpo/anti-censorship/pluggable-transports/snowflake
# Reference accessed: 2026-05-21
# Verified: flags taken directly from broker/broker.go in upstream snowflake repo.

# snowflake-broker: pluggable transport broker (matches clients with proxies)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-acme-email=[contact email for Lets Encrypt notifications]:email:' \
  '-acme-hostnames=[comma-separated hostnames for TLS cert]:hosts:' \
  '-cert=[TLS certificate file]:file:_files' \
  '-key=[TLS private key file]:file:_files' \
  '-acme-cert-cache=[ACME cert cache directory]:dir:_files -/' \
  '-addr=[address to listen on (default :443)]:addr:' \
  '-geoipdb=[IPv4 geoip database path]:file:_files' \
  '-geoip6db=[IPv6 geoip database path]:file:_files' \
  '-bridge-list-path=[bridge list file path]:file:_files' \
  '-allowed-relay-pattern=[allowed relay hostname pattern]:pattern:' \
  '-broker-sqs-name=[broker SQS queue name]:name:' \
  '-broker-sqs-region=[AWS region of broker SQS queue]:region:' \
  '-sqs-profiles=[comma-separated AWS profiles for SQS credentials]:profiles:' \
  '-disable-tls[do not use HTTPS]' \
  '-disable-geoip[disable geoip for stats collection]' \
  '-metrics-log=[metrics logging output path]:file:_files' \
  '-ip-count-prefix=[path prefix for ip count logging output]:prefix:' \
  '-ip-count-interval=[time interval between each chunk (default 1h)]:duration:' \
  '-unsafe-logging[prevent logs from being scrubbed]' \
  '-poll-interval-filepath=[path to file with a poll interval]:file:_files' \
  '*::snowflake-broker args:_files' && ret=0
return ret
