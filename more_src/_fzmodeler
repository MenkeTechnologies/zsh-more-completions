#compdef fzmodeler
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/gsfml — evaluate a synthetic fracture zone model profile

local ret=1

_arguments -s \
  '-A+[asymmetry parameter]:value:_default' \
  '-C+[compression amount 0-1]:value:_default' \
  '-D+[model evaluation domain min/max/inc]:domain:_default' \
  '-G+[plot only component G0|G1|G2]:comp:_default' \
  '-M[interpret domain in degrees latitude]' \
  '-N+[peak-to-trough amplitude]:value:_default' \
  '-O[write PostScript overlay to stdout]' \
  '-P[produce PDF plot of synthetic profile]' \
  '-S+[FZ location shift from origin]:shift:_default' \
  '-T+[output prefix for model profile]:prefix:_default' \
  '-W+[full width of fracture zone]:width:_default' \
  '*-V[verbose (stackable)]' \
  '*:args:_default' \
  && ret=0

return ret
