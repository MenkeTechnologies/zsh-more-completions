#compdef dyndns dyndns-update
# _dyndns — Dynamic DNS update CLI (typical Perl/Python helper that pushes the local public IP to a Dyn / NoIP / Cloudflare / Hetzner / DuckDNS / he.net / FreeDNS service over HTTP; -h help, -V version, -p provider, -u user, -k api key, -n hostname, -i interface to read from, -4/-6 family, --quiet, --verbose, --dry-run, --interval seconds for daemon mode)
# upstream: distro-shipped variations (ddclient, inadyn, dyndns2 helpers)
# Flag shape from ddclient / inadyn on tip.

_dyndns() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-p+[provider]:provider:(dyndns2 noip cloudflare hetzner duckdns freedns he easydns googledns namecheap)' \
        '-u+[user]:user:' \
        '-k+[api key]:key:' \
        '-n+[hostname]:host:' \
        '-i+[interface]:interface:_net_interfaces' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '--quiet[quiet]' \
        '--verbose[verbose]' \
        '--dry-run[dry run]' \
        '--interval+[seconds]:seconds:' \
        '-f+[config file]:file:_files'
}

_dyndns "$@"
