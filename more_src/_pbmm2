#compdef pbmm2

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'align:align PacBio reads'
  'index:create reference index'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'pbmm2 command' commands && ret=0
    ;;
  args)
    case $line[1] in
      align)
        _arguments -s -S \
          '-j[alignment threads]:threads:' \
          '-J[sort threads]:threads:' \
          '-m[sort memory]:memory:' \
          '--preset[preset]:preset:(CCS SUBREAD ISOSEQ UNROLLED)' \
          '--sort[sort output BAM]' \
          '--sample[sample name]:name:' \
          '--log-level[log level]:level:(TRACE DEBUG INFO WARN FATAL)' \
          '--unmapped[include unmapped reads]' \
          '--strip[strip kinetics]' \
          '1:reference:_files -g "*.fa(|sta)(|.gz)(|.mmi)"' \
          '2:input reads:_files' \
          '3:output BAM:_files' \
          '--help[show help]' && ret=0
        ;;
      index)
        _arguments -s -S \
          '--preset[preset]:preset:(CCS SUBREAD ISOSEQ UNROLLED)' \
          '1:reference FASTA:_files -g "*.fa(|sta)(|.gz)"' \
          '2:output MMI:_files' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
