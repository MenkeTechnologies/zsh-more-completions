#compdef mlton-cli mlton2
# _mlton-cli — Stephen Weeks Henry Cejtin MLton mlton-cli CLI command-line frontend wrapping the MLton optimizing compiler for Standard ML SML97 open-source written in Standard ML originally Stephen Weeks Henry Cejtin Suresh Jagannathan Matthew Fluet now MLton team whole-program optimizing compiler for the Standard ML SML programming language formerly called Standard ML of New Jersey extension whole-program optimization native compilation MLBasis MLB ML-Lex ML-Yacc ML-NLFFI FFI multi-precision integers fast garbage collector platform abi codegen target const default-ann diag-pass diag-pass-stmt drop-pass expert export-header keep keep-pass keep-pass-after link-opt llvm-pass max-codegen-size mlb-path-var output prefer-abs profile show-anns show-basis stop tarp profile-time profile-stack output-stub xenable-anns xdisable-anns (Stephen Weeks Henry Cejtin Suresh Jagannathan Matthew Fluet MLton team, Standard ML); custom argparse
# upstream: http://mlton.org/

_mlton-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-verbose+[level]:n:' \
        '-target=+[arch-os]:str:' \
        '-target-arch=+[arch]:str:' \
        '-target-os=+[os]:str:' \
        '-codegen=+[c]:c:(amd64 c llvm x86)' \
        '-abi=+[abi]:str:' \
        '-output=+[file]:file:_files' \
        '-prefer-abs-paths=+[v]:v:(true false)' \
        '-stop=+[s]:s:(f g o tc sml mlb)' \
        '-cc=+[cmd]:str:' \
        '-cc-opt=+[opt]:str:' \
        '*-cc-opt=+[opt]:str:' \
        '-cc-opt-quote=+[opt]:str:' \
        '*-cc-opt-quote=+[opt]:str:' \
        '-link-opt=+[opt]:str:' \
        '*-link-opt=+[opt]:str:' \
        '-link-opt-quote=+[opt]:str:' \
        '*-link-opt-quote=+[opt]:str:' \
        '-runtime=+[opt]:str:' \
        '*-runtime=+[opt]:str:' \
        '-mlb-path-var=+[name=value]:str:' \
        '*-mlb-path-var=+[name=value]:str:' \
        '-mlb-path-map=+[file]:file:_files' \
        '*-mlb-path-map=+[file]:file:_files' \
        '-default-ann=+[ann]:str:' \
        '*-default-ann=+[ann]:str:' \
        '-default-type=+[type]:str:' \
        '*-default-type=+[type]:str:' \
        '-disable-ann=+[ann]:str:' \
        '*-disable-ann=+[ann]:str:' \
        '-as-opt=+[opt]:str:' \
        '*-as-opt=+[opt]:str:' \
        '-as-opt-quote=+[opt]:str:' \
        '*-as-opt-quote=+[opt]:str:' \
        '-llvm-opt=+[opt]:str:' \
        '*-llvm-opt=+[opt]:str:' \
        '-debug[debug build]' \
        '-debug-runtime[debug runtime]' \
        '-keep=+[item]:i:(g o ssa ssa2 rssa sxml xml dot dot-flow dot-loop sxmlPass2 ssaPass ssaShrunk ssaSimplify pass passSimplify mlPass mlPassShrunk ranges xml mark mhPass)' \
        '*-keep=+[item]:i:(g o ssa ssa2 rssa sxml xml dot dot-flow dot-loop sxmlPass2 ssaPass ssaShrunk ssaSimplify pass passSimplify mlPass mlPassShrunk ranges xml mark mhPass)' \
        '-keep-pass=+[regex]:str:' \
        '*-keep-pass=+[regex]:str:' \
        '-show-anns[show annotations]' \
        '-show-basis=+[file]:file:_files' \
        '-show-def-use=+[file]:file:_files' \
        '-show-types=+[v]:v:(true false)' \
        '-prof[profile]' \
        '-profile=+[mode]:m:(no alloc count time call drop)' \
        '-profile-branch=+[v]:v:(true false)' \
        '-profile-il=+[t]:t:(source ssa ssa2)' \
        '-profile-include=+[regex]:str:' \
        '-profile-exclude=+[regex]:str:' \
        '-profile-stack=+[v]:v:(true false)' \
        '-profile-val=+[v]:v:(true false)' \
        '-profile-time=+[m]:m:(alarm prof time)' \
        '-coalesce=+[N]:n:' \
        '-mark-pass[mark passes]' \
        '-show-anns[show anns]' \
        '-static[static link]' \
        '-export-header=+[file]:file:_files -g "*.h"' \
        '-loop-passes=+[N]:n:' \
        '-loop-ssa=+[v]:v:(true false)' \
        '-loop-unroll-limit=+[N]:n:' \
        '-loop-unswitch-limit=+[N]:n:' \
        '-llvm-as=+[cmd]:str:' \
        '-llvm-llc=+[cmd]:str:' \
        '-llvm-opt-as=+[cmd]:str:' \
        '-llvm-opt-llc=+[cmd]:str:' \
        '*:source:_files -g "*.sml *.mlb *.fun *.sig"'
}

_mlton-cli "$@"
