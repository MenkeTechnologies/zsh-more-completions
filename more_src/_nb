#compdef nb

# Zsh completion for nb - CLI note-taking and knowledge base

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'add:Add a new note'
  'bookmark:Manage bookmarks'
  'browse:Browse notes in the terminal or browser'
  'completions:Generate shell completions'
  'copy:Copy a note'
  'count:Print the number of items'
  'delete:Delete a note'
  'do:Mark a todo as done'
  'edit:Edit a note'
  'env:Print environment information'
  'export:Export a note'
  'folders:Manage folders'
  'git:Run git commands in the notebook'
  'help:Show help'
  'history:Show git log for the notebook'
  'import:Import a file'
  'init:Initialize the data directory'
  'list:List notes'
  'ls:List notes with indicators'
  'move:Move a note'
  'notebooks:Manage notebooks'
  'open:Open a note or bookmark'
  'peek:View a note or bookmark'
  'pin:Pin a note'
  'plugins:Manage plugins'
  'remote:Manage remote configuration'
  'rename:Rename a note'
  'run:Run shell commands in the notebook directory'
  'search:Search notes'
  'settings:Manage settings'
  'shell:Start the nb interactive shell'
  'show:Show a note'
  'status:Show the notebook status'
  'subcommands:List available subcommands'
  'sync:Sync the notebook with the remote'
  'tasks:Manage tasks'
  'todo:Manage todos'
  'undo:Mark a todo as not done'
  'unpin:Unpin a note'
  'update:Update nb'
  'use:Switch to a notebook'
  'version:Display version information'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--no-color[disable color output]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'nb command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      add)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --title)'{-t,--title}'=[set the title]:title' \
          '--type=[set the file type]:type:(md txt org rst)' \
          '--content=[set the content]:content' \
          '--filename=[set the filename]:filename' \
          '--folder=[add to a folder]:folder' \
          '--tags=[add tags]:tags' \
          '--encrypt[encrypt the note]' \
          '--password=[encryption password]:password' \
          '(-e --edit)'{-e,--edit}'[open in editor]' \
          '*:file:_files' && ret=0
        ;;
      edit)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--content=[replace content]:content' \
          '--append=[append content]:content' \
          '--prepend=[prepend content]:content' \
          '-e[open in $EDITOR]' \
          '1:note selector' && ret=0
        ;;
      show)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--dump[print to stdout]' \
          '--filename[print filename]' \
          '--id[print id]' \
          '--info-line[print info line]' \
          '--path[print file path]' \
          '--render[render to terminal]' \
          '--title[print title]' \
          '--type[print file type]' \
          '1:note selector' && ret=0
        ;;
      search)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--all[search all notebooks]' \
          '--list[display as list]' \
          '--no-color[disable color]' \
          '(-t --type)'{-t,--type}'=[limit to file type]:type' \
          '--utility=[search utility]:utility:(grep rg ag)' \
          '*:query' && ret=0
        ;;
      list|ls)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-e --excerpt)'{-e,--excerpt}'[show excerpt]' \
          '--filenames[show filenames]' \
          '--no-id[hide IDs]' \
          '--no-indicator[hide indicators]' \
          '(-n --limit)'{-n,--limit}'=[max items to list]:count' \
          '--paths[show full paths]' \
          '--pager[pipe through pager]' \
          '(-s --sort)'{-s,--sort}'[sort alphabetically]' \
          '(-r --reverse)'{-r,--reverse}'[reverse sort]' \
          '(-t --type)'{-t,--type}'=[filter by type]:type:(archive audio bookmark document folder image markdown org text video)' \
          '--tags[list all tags]' && ret=0
        ;;
      notebooks)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(add current delete list rename use)' && ret=0
        ;;
      delete|move|copy|rename)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--force[skip confirmation]' \
          '1:note selector' && ret=0
        ;;
      import)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:file or URL:_files' && ret=0
        ;;
      export)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:note selector' \
          '2:output file:_files' && ret=0
        ;;
      settings)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:setting:(get set unset list)' && ret=0
        ;;
      use)
        _arguments '1:notebook' && ret=0
        ;;
      completions)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
