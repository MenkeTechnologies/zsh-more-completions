#compdef zpool
# _zpool-cli — ZFS storage pool administration; create/import/export/scrub/replace ZFS pools (OpenZFS)
# upstream: https://github.com/openzfs/zfs

_zpool-cli() {
    local -a sub=(
        'create:create a pool'
        'destroy:destroy a pool'
        'add:add devices to a pool'
        'attach:mirror an existing vdev'
        'detach:detach a mirror device'
        'replace:replace a device'
        'remove:remove a device'
        'split:split mirrored pool'
        'online:bring device online'
        'offline:take device offline'
        'clear:clear pool errors'
        'export:export a pool'
        'import:import a pool'
        'reopen:reopen all pool vdevs'
        'list:list pools'
        'status:show pool status'
        'iostat:show I/O stats'
        'scrub:start/stop scrub'
        'trim:start/stop TRIM'
        'resilver:start resilver'
        'sync:sync pool'
        'history:show pool command history'
        'upgrade:upgrade pool version'
        'get:get pool properties'
        'set:set pool properties'
        'labelclear:clear vdev labels'
        'wait:wait for activity'
        'initialize:start/stop initialize'
        'checkpoint:create/clear checkpoint'
        'events:show pool event log'
        'inject:fault injection (test)'
        'reguid:reset pool guid'
        'version:show pool version'
    )
    _arguments -C \
        '-?[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zpool subcommand' sub ;;
        args)
            case $words[1] in
                destroy|export|import|status|scrub|trim|clear|upgrade|history|list|iostat|sync|wait|reopen) _arguments '*:pool:' ;;
            esac
            ;;
    esac
}

_zpool-cli "$@"
