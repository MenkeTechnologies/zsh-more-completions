#compdef drone
# _drone-cli — Drone CI/CD CLI (Harness + Drone community, Go); manage Drone build pipelines + secrets + queue
# upstream: https://github.com/harness/drone-cli

_drone-cli() {
    local -a sub=(
        'autocomplete:install autocomplete'
        'build:build commands'
        'config:config commands'
        'cron:cron job commands'
        'encrypt:encrypt a secret'
        'exec:execute a pipeline locally'
        'info:show server info'
        'lint:lint pipeline yaml'
        'log:logs commands'
        'orgsecret:org secret commands'
        'plugins:plugin commands'
        'queue:queue commands'
        'registry:registry commands'
        'repo:repo commands'
        'secret:secret commands'
        'server:server commands'
        'sign:sign pipeline yaml'
        'starlark:starlark commands'
        'template:template commands'
        'user:user commands'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--token+[Drone token]:str:' \
        '-t+[Drone token]:str:' \
        '--server+[Drone server URL]:url:_urls' \
        '-s+[Drone server URL]:url:_urls' \
        '--skip-verify[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'drone subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments '1:build cmd:(approve cancel create decline export info kill last logs ls promote queue rollback start stop tail update)' '*:owner/repo:' ;;
                repo) _arguments '1:repo cmd:(add chown disable enable info ls repair sync update)' '*:owner/repo:' ;;
                secret) _arguments '1:secret cmd:(add info ls rm update)' '*:owner/repo:' ;;
                exec) _arguments \
                    '--include+[steps to include]:steps:' \
                    '--exclude+[steps to exclude]:steps:' \
                    '--repo.name+[repo name]:str:' \
                    '--repo.namespace+[repo namespace]:str:' \
                    '--repo.fullname+[repo fullname]:str:' \
                    '--commit.branch+[commit branch]:branch:' \
                    '--commit.sha+[commit sha]:sha:' \
                    '--commit.ref+[commit ref]:ref:' \
                    '--build.event+[build event]:event:(push pull_request tag)' \
                    '--secret-file+[secret file]:file:_files' \
                    '*:file:_files' ;;
            esac
            ;;
    esac
}

_drone-cli "$@"
