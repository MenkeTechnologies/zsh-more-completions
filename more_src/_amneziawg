#compdef amneziawg awg
# _amneziawg — Amnezia AmneziaWG awg CLI an obfuscated WireGuard fork CLI for configuring tunnels generating keys peer management with Junk Packet bytes Header bytes and S1 S2 H1 H2 H3 H4 censorship-bypass parameters (amnezia-vpn team, C); getopt
# upstream: https://github.com/amnezia-vpn/amneziawg-tools

_amneziawg() {
    local -a sub=(
        'show:show interface info'
        'showconf:show config'
        'set:set interface parameters'
        'setconf:apply config file'
        'addconf:add to config file'
        'syncconf:sync config'
        'genkey:generate private key'
        'genpsk:generate preshared key'
        'pubkey:derive public key'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amneziawg subcommand' sub ;;
        args)
            case $words[1] in
                show|showconf) _arguments '*:interface:' ;;
                set) _arguments \
                    '*:interface peer params:' ;;
                setconf|addconf|syncconf) _arguments \
                    '*:interface configfile:_files -g "*.conf"' ;;
            esac
            ;;
    esac
}

_amneziawg "$@"
