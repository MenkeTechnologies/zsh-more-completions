#compdef kapp-controller

# kapp-controller: Carvel package management controller for Kubernetes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--enable-leader-election[enable leader election]' \
  '--namespace=[namespace]:ns:' \
  '--api-port=[API port]:port:' \
  '--api-priority-and-fairness[enable API priority and fairness]' \
  '--ca-cert-paths=[CA cert paths]:list:' \
  '--dangerous-stop-on-error[stop on first reconcile error (debug)]' \
  '--max-concurrent-reconciles=[max concurrent reconciles]:n:' \
  '--package-install-min-resync-time=[package install min resync]:duration:' \
  '--package-repository-min-resync-time=[package repo min resync]:duration:' \
  '--app-min-resync-time=[app min resync]:duration:' \
  '--package-min-resync-time=[package min resync]:duration:' \
  '*::kapp-controller args:_files' && ret=0
return ret
