#compdef kubectl-roll
# kubectl-roll (krew plugin): rolling restart of pods by owner
# https://github.com/kangasta/kubectl-roll

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--timeout=[timeout for the operation]:duration' \
  '--interval=[interval between pod restarts]:duration' \
  '(-l --selector)'{-l+,--selector=}'[label selector]:selector' \
  '1:resource type:(deployment statefulset daemonset)' \
  '2:resource name'
