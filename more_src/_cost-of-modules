#compdef cost-of-modules
# _cost-of-modules — find the cost of node_modules in your project (siddharthkp/cost-of-modules)
# upstream: https://github.com/siddharthkp/cost-of-modules
# Flags from src/helpers.js (yargs-parser).

_cost-of-modules() {
    _arguments \
        '--include-dev[include devDependencies in cost calculation]' \
        '--no-install[do not install dependencies before calculating]' \
        '--yarn[use yarn instead of npm for installs]' \
        '--less[show only top 10 modules]'
}

_cost-of-modules "$@"
