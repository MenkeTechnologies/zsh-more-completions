#compdef bigwigAverage
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/bigwigAverage.html
# deepTools: average multiple bigWig files into a single output track

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bigwigs)'{-b,--bigwigs}'[bigWig files]:bw:_files -g "*.bw"' \
  '--scaleFactors[multiply bigwig values by constants (a:b:c)]:factors:' \
  '(--skipNonCoveredRegions --skipNAs)'{--skipNonCoveredRegions,--skipNAs}'[skip regions without scores]' \
  '--version[show version]' \
  '(-bs --binSize)'{-bs,--binSize}'[bin size in bases]:size:' \
  '(-r --region)'{-r,--region}'[genome region to analyze]:region:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[BED/GTF file of excluded regions]:file:_files' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-o --outFileName)'{-o,--outFileName}'[output file name]:file:_files' \
  '(-of --outFileFormat)'{-of,--outFileFormat}'[output format]:format:(bigwig bedgraph)' && ret=0

return ret
