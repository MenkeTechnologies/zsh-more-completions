#compdef yaml-diff
# _yaml-diff — diff two YAML / JSON documents (wwkimball/yamlpath)
# upstream: https://github.com/wwkimball/yamlpath
# Flags from yamlpath/commands/yaml_diff.py (argparse).

_yaml-diff() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[INI config file]:file:_files' \
        '(-A --arrays)'{-A+,--arrays=}'[array compare strategy]:mode:(value position)' \
        '(-O --aoh)'{-O+,--aoh=}'[array-of-hashes compare strategy]:mode:(value position deep)' \
        '(-t --pathsep)'{-t+,--pathsep=}'[YAML Path separator]:sep:(auto dot fslash)' \
        '(-L --left-document-index)'{-L+,--left-document-index=}'[lhs document index for multi-doc]:n:' \
        '(-R --right-document-index)'{-R+,--right-document-index=}'[rhs document index for multi-doc]:n:' \
        '(-j --json-multi-doc)'{-j,--json-multi-doc}'[treat JSON as multi-document]' \
        '(-s --same)'{-s,--same}'[also show same / unchanged values]' \
        '(-o --onlysame)'{-o,--onlysame}'[show only unchanged values]' \
        '(-x --eyaml)'{-x+,--eyaml=}'[eyaml binary path]:path:_files' \
        '(-r --privatekey)'{-r+,--privatekey=}'[EYAML private key file]:file:_files' \
        '(-u --publickey)'{-u+,--publickey=}'[EYAML public key file]:file:_files' \
        '(-E --ignore-eyaml-values)'{-E,--ignore-eyaml-values}'[ignore EYAML value changes]' \
        '--frontmatter[parse Markdown frontmatter]' \
        '(-d --debug)'{-d,--debug}'[debug output]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
        '1:lhs YAML file:_files -g "*.{yml,yaml,json}"' \
        '2:rhs YAML file:_files -g "*.{yml,yaml,json}"'
}

_yaml-diff "$@"
