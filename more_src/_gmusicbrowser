#compdef gmusicbrowser
# Documentation: https://github.com/squentin/gmusicbrowser
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gmusicbrowser: GTK music collection manager / player
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-version[show version]' \
  '-rcfile[config file]:file:_files' \
  '-cache[cache directory]:dir:_files -/' \
  '-no-plugins[disable plugins]' \
  '-server[port]:port:' \
  '-cmd[run command on running instance]:cmd:' \
  '-startfullscreen[start in fullscreen]' \
  '-play[start playback]' \
  '-quit[quit running instance]' \
  '*:files:_files' && ret=0
return ret
