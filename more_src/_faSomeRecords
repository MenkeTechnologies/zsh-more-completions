#compdef faSomeRecords
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# extract multiple fa records

local ret=1

_arguments -s -S \
  '-exclude[output sequences not in the list file]' \
  '1:in fa:_files -g "*.(fa|fasta)"' \
  '2:list file:_files' \
  '3:out fa:_files' && ret=0

return ret
