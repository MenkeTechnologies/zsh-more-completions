#compdef wrc
# Wine resource compiler

local ret=1

_arguments -s -S \
  '-b[specify target byte-order]:order:(n l)' \
  '-D[define preprocessor symbol]:symbol:' \
  '-E[preprocess only]' \
  '-F[set target architecture]:arch:' \
  '-h[show help]' \
  '--help[show help]' \
  '-i[specify input file]:file:_files -g "*.rc"' \
  '-I[specify include path]:directory:_files -/' \
  '-J[specify input format]:format:(rc rc16 res res16 pot)' \
  '-l[set language]:language:' \
  '-m[specify architecture]:arch:(16 32)' \
  '-o[specify output file]:file:_files' \
  '-O[specify output format]:format:(res res16 pot)' \
  '-P[specify po directory]:directory:_files -/' \
  '-r[create .res file]' \
  '-U[undefine preprocessor symbol]:symbol:' \
  '-u[input file is Unicode]' \
  '-v[verbose mode]' \
  '-V[show version]' \
  '--version[show version]' \
  '-W[enable pedantic warnings]' \
  '*:source files:_files -g "*.(rc|res)"' && ret=0

return ret
