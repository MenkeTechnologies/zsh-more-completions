#compdef ow
# Documentation: https://man.archlinux.org/search?q=ow
# Reference accessed: 2026-05-16
# Source: https://github.com/dmytro/zsh-compdef/blob/5b2c600c509cda1fb0a05a6055fdcb035c886616/_ow
# Repository: dmytro/zsh-compdef (_ow)

local expl ret=1

if [[ ${words[CURRENT-1]} = "-o" ]]; then
  _wanted openmethod expl 'open method' compadd "$@" - \
    $(_call_program openm ow -T open) && ret=0
else
  _wanted shortcut expl 'shortcut' compadd "$@" - \
    $(_call_program scs ow -T shortcuts) && ret=0
fi

return ret
