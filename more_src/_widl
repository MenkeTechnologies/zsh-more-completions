#compdef widl
# Wine IDL compiler

local ret=1

_arguments -s -S \
  '-c[generate client stub]' \
  '-C[generate server stub]' \
  '-d[specify dlevel]:level:' \
  '-D[define preprocessor symbol]:symbol:' \
  '-E[preprocess only]' \
  '-h[generate header file]' \
  '-H[specify header filename]:file:_files -g "*.h"' \
  '-I[specify include path]:directory:_files -/' \
  '-N[do not generate format string procedures]' \
  '-o[specify output file]:file:_files' \
  '-O[specify output format]:format:(s i)' \
  '-p[generate proxy]' \
  '-P[specify proxy filename]:file:_files' \
  '-r[generate registration script]' \
  '-s[generate server stub]' \
  '-S[specify server stub filename]:file:_files' \
  '-t[generate typelib]' \
  '-T[specify typelib filename]:file:_files' \
  '-u[generate interface identifiers file]' \
  '-U[specify interface identifiers filename]:file:_files' \
  '-w[suppress warnings]' \
  '-W[enable warnings]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:IDL files:_files -g "*.idl"' && ret=0

return ret
