#compdef nsec3dig
# Documentation: https://doc.powerdns.com/authoritative/manpages/nsec3dig.1.html
# Send DNS queries and validate NSEC3 proofs for a domain and record type

local ret=1

_arguments -s -S \
  '1:ipaddress:_hosts' \
  '2:port:_ports' \
  '3:qname:' \
  '4:qtype:(A AAAA MX NS TXT SOA CNAME SRV PTR ANY)' \
  '5:recurse:(recurse)' && ret=0

return ret
