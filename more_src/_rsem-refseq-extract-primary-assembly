#compdef rsem-refseq-extract-primary-assembly
# Documentation: https://github.com/deweylab/RSEM/blob/master/rsem-refseq-extract-primary-assembly
# RSEM: extract primary assembly sequences from a RefSeq top-level assembly FASTA

local ret=1

_arguments -s -S \
  '1:input top-level assembly fna:_files -g "*.(fna|fa|fasta)"' \
  '2:output primary assembly fna:_files' && ret=0

return ret
