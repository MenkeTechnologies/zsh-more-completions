#compdef factory-cli
# Documentation: https://www.npmjs.com/package/@factory/cli
# Reference accessed: 2026-05-23
# Verified: npx @factory/cli --help (binary: droid; see also _droid).

# Zsh completion for factory-cli - Factory @factory/cli npm package (runs droid)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--settings=[runtime settings file path]:file:_files' \
  '--append-system-prompt=[append to system prompt]:text:' \
  '--append-system-prompt-file=[append file to system prompt]:file:_files' \
  '(-r --resume)'{-r,--resume}'[resume session]' \
  ':session:session:' \
  '--fork=[fork and resume session]:session:' \
  '--cwd=[working directory]:directory:_directories' \
  '(-w --worktree)'{-w,--worktree}'[run in git worktree]:name:' \
  '--worktree-dir=[worktree parent directory]:directory:_directories' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'factory-cli command' \
      'exec[non-interactive execution]' \
      'mcp[manage MCP servers]' \
      'plugin[manage plugins]' && ret=0
    ;;
  args)
    case $line[1] in
      exec)
        _arguments '*:prompt:' && ret=0
        ;;
      mcp)
        if (( CURRENT == 3 )); then
          _values 'mcp action' add remove && ret=0
        fi
        ;;
      plugin)
        if (( CURRENT == 3 )); then
          _values 'plugin action' install uninstall update list marketplace && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
