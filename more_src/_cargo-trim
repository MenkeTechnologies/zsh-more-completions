#compdef cargo-trim
# Documentation: https://github.com/iamsauravsharma/cargo-trim
# Cleanup CARGO_HOME registry & git cache

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[clean up all registry & git crates]' \
  '--clear-empty-index[remove empty index directories]' \
  '(-d --directory)'{-d,--directory}'=[extra Rust project directory]:dir:_files -/' \
  '(-n --dry-run)'{-n,--dry-run}'[preview changes without executing]' \
  '(-g --gc)'{-g,--gc}'=[git compress to reduce .cargo size]:compress' \
  '(-i --ignore)'{-i,--ignore}'=[exclude file/folder names]:name' \
  '(-l --light)'{-l,--light}'[light cleanup keeping future-compile files]' \
  '--no-scan-hidden-folder[skip hidden folders]' \
  '--no-scan-target-folder[skip target folders]' \
  '(-o --old)'{-o,--old}'[remove outdated cache crates]' \
  '(-z --old-orphan)'{-z,--old-orphan}'[clean crates both old and orphan]' \
  '(-x --orphan)'{-x,--orphan}'[clean orphan cache crates]' \
  '(-q --query)'{-q,--query}'[display cache folder sizes]' \
  '--scan-hidden-folder[include hidden folders]' \
  '--scan-target-folder[include target folders]' \
  '(-t --top)'{-t,--top}'=[list largest crates by count]:count' \
  '(-u --update)'{-u,--update}'[refresh Cargo.lock files]' \
  '(-w --wipe)'{-w,--wipe}'=[remove specific folder types]:folder' \
  '*::command:->cmd' && ret=0

case $state in
  cmd)
    _values 'cargo-trim subcommand' \
      'init[initialize working directory for cargo-trim]' \
      'clear[remove directory from cache config]' \
      'config[query configuration file data]' \
      'set[modify config file values]' \
      'unset[remove config file values]' \
      'list[display crates]' \
      'git[git-specific cache operations]' \
      'registry[registry-specific cache operations]' \
      'help[print help]' && ret=0
    ;;
esac

return ret
