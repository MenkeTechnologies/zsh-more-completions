#compdef mri_relabel_hypointensities
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_relabel_hypointensities
# FreeSurfer: relabel white matter hypointensities near the surface

local ret=1

_arguments -s -S \
  '-l[limit calculations to specified label]:label file:_files' \
  '-a[compute properties per label in annotation file]:annotation file:_files' \
  '*:argument:_files' && ret=0

return ret
