#compdef sunszonecsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/statics/sunszonecsv.c
# SUNSZONECSV - near surface zone extract and shift

local ret=1

_arguments -s -S \
  'qin=[input file containing q-records]:f:_files' \
  'apply=[apply option]:a:' \
  'locs=[location names]:l:' \
  'qx=[x coordinate value name]:q:' \
  'qy=[y coordinate value name]:q:' \
  'qvw=[velocity weathering value name]:q:' \
  'qvb=[velocity bedrock value name]:q:' \
  'qvc=[velocity c value name]:q:' \
  'qvd=[velocity d value name]:q:' \
  'qzw=[depth weathering value name]:q:' \
  'qzb=[depth bedrock value name]:q:' \
  'qzc=[depth c value name]:q:' \
  'sdist=[search distance]:s:' \
  'smult=[search distance multiplier]:s:' \
  'tapp=[time apply value]:t:' \
  'tbulk=[bulk time shift]:t:' \
  'tpath=[time path value]:t:' \
  '*:SU file:_files' && ret=0

return ret
