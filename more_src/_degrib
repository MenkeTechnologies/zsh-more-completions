#compdef degrib
# Documentation: https://www.weather.gov/mdl/degrib_home
# decode/convert NDFD GRIB1 and GRIB2 files (MDL)

local ret=1

_arguments -s -S \
  '(-V)-V[print version information]' \
  '-in[input GRIB file]:grib file:_files' \
  '-cfg[read more options from config file]:config file:_files' \
  '-out[output file (or stdout)]:output file:_files' \
  '-log[file to log errors to]:log file:_files' \
  '-I[perform an inventory on the input file]' \
  '-C[convert message(s) from the input file]' \
  '-P[probe a GRIB file at a single lat/lon or set of points]' \
  '-Data[convert NDFD GRIB2 to index file and data cube]' \
  '-DP[probe the data cube at a lat/lon]' \
  '-DC[convert a message from the data cube]' \
  '-refTime[print oldest reference time to stdout]' \
  '-Sector[print sector(s) a point falls in]' \
  '-StormTotal[sum values from several messages into a total]' \
  '-msg[which GRIB message to convert]:message number:' \
  '-nameStyle[file naming style]:style:' \
  '-namePath[directory to put files in]:dir:_files -/' \
  '-Met[create .txt metadata file]' \
  '-nMet[do not create metadata file]' \
  '-Shp[create ESRI .shp files]' \
  '-Shp2[create ESRI .shp files (variant)]' \
  '-nShp[do not create .shp files]' \
  '-Flt[create .flt files]' \
  '-nFlt[do not create .flt files]' \
  '-NetCDF[create NetCDF file of given type]:type:(0 1 2 3)' \
  '-Csv[create comma delimited .csv file]' \
  '-nCsv[do not create .csv file]' \
  '-Grib2[create .grb file repacked in GRIB2]' \
  '-nGrib2[do not create .grb file]' \
  '-IS0[create .IS0 diagnostic text file]' \
  '-MSB[use most significant byte first (UNIX)]' \
  '-nMSB[use least significant byte first (PC)]' \
  '-radEarth[override radius of earth]:value:' \
  '-Unit[convert to native unit]:unit:(none english metric e m)' \
  '-Decimal[number of decimals to store the value]:amount:' \
  '-validMax[maximum expected value]:value:' \
  '-validMin[minimum expected value]:value:' \
  '-lwlf[lower left corner of sub region]:lat,lon:' \
  '-uprt[upper right corner of sub region]:lat,lon:' \
  '-poly[shapefile polygon type]:type:(0 1 2)' \
  '-nMissing[do not store missing values in .shp files]' \
  '-GrADS[create GrADS control file (.ctl)]:type:' \
  '-AscGrid[create ESRI ASCII grid instead of binary]' \
  '-Interp[interpolate to a lat/lon coverage grid]:type:' \
  '-revFlt[create reversed .tlf file]' \
  '-nRevFlt[do not create reversed .tlf file]' \
  '-pnt[geographic location of point to probe]:lat,lon:' \
  '-pntFile[ASCII file with list of points to probe]:file:_files' \
  '-surface[add a column for the surface]:form:(short long)' \
  '-Separator[string to separate probe output columns]:string:' \
  '-tmFormat[time format of the output]:format:' \
  '-Index[index file to create or add entries to]:file:_files -g "*.flx"' \
  '-Cube[store grids to a single file cube]' \
  '-nCube[create a set of .flt files]' \
  '-Append[append data to the given index file]' \
  '-Print[print the index file]' \
  '-sectFile[ASCII file with sector grid specifications]:file:_files' \
  '*:grib file:_files' && ret=0

return ret
