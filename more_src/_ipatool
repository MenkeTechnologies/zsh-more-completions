#compdef ipatool

# https://github.com/majd/ipatool — v2.x cobra (cmd/root.go)

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'auth:App Store authentication'
  'download:download an IPA package'
  'purchase:purchase an app'
  'search:search the App Store'
  'list-versions:list available versions'
  'get-version-metadata:fetch build metadata'
)

_arguments -s -S \
  '--format=[output format]:format:(text json)' \
  '--verbose[verbose logs]' \
  '--non-interactive[no interactive prompts]' \
  '--keychain-passphrase=[unlock keychain]:passphrase:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'ipatool command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
