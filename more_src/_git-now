#compdef git-now
# Documentation: https://man.archlinux.org/search?q=git-now
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/git-now — Quick commit with timestamp message

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
