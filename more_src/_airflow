#compdef airflow

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'cheat-sheet:display cheat sheet'
  'config:show current application configuration'
  'connections:manage connections'
  'dag-processor:start a standalone Dag Processor'
  'dags:manage DAGs'
  'db:manage the metadata database'
  'info:show information about current Airflow'
  'jobs:manage jobs'
  'kerberos:start a kerberos ticket renewer'
  'plugins:list loaded plugins'
  'pools:manage pools'
  'providers:display information about installed providers'
  'roles:manage roles'
  'rotate-fernet-key:rotate all encrypted connection passwords'
  'scheduler:start a scheduler instance'
  'standalone:run an all-in-one copy of Airflow'
  'tasks:manage tasks'
  'triggerer:start a triggerer instance'
  'users:manage users'
  'variables:manage variables'
  'version:show version'
  'webserver:start a webserver instance'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      dags)
        local -a dag_cmds=(
          'backfill:run subsections of a DAG for a specified date range'
          'delete:delete all DB records related to the specified DAG'
          'list:list all the DAGs'
          'list-import-errors:list all the DAGs that have import errors'
          'list-jobs:list the jobs'
          'list-runs:list DAG runs given a DAG id'
          'next-execution:get the next execution datetime of a DAG'
          'pause:pause a DAG'
          'report:show DagBag loading report'
          'reserialize:reserialize all DAGs'
          'show:display DAG or DAG runs in a browser'
          'show-dependencies:display DAG dependencies'
          'state:get the status of a dag run'
          'test:execute one single DagRun'
          'trigger:trigger a DAG run'
          'unpause:resume a paused DAG'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'dags subcommand' dag_cmds && ret=0
        ;;
      tasks)
        local -a task_cmds=(
          'clear:clear a set of task instance'
          'failed-deps:returns the unmet dependencies for a task instance'
          'list:list the tasks within a DAG'
          'render:render a task instance template'
          'run:run a single task instance'
          'state:get the status of a task instance'
          'states-for-dag-run:get the status of all task instances in a dag run'
          'test:test a task instance'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'tasks subcommand' task_cmds && ret=0
        ;;
      connections)
        local -a conn_cmds=(
          'add:add a connection'
          'delete:delete a connection'
          'export:export all connections'
          'get:get a connection'
          'import:import connections from a file'
          'list:list connections'
          'test:test a connection'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'connections subcommand' conn_cmds && ret=0
        ;;
      variables)
        local -a var_cmds=(
          'delete:delete a variable'
          'export:export all variables'
          'get:get a variable'
          'import:import variables from a JSON file'
          'list:list variables'
          'set:set a variable'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'variables subcommand' var_cmds && ret=0
        ;;
      users)
        local -a user_cmds=(
          'create:create a user'
          'delete:delete a user'
          'export:export all users'
          'import:import users'
          'list:list users'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'users subcommand' user_cmds && ret=0
        ;;
      db)
        local -a db_cmds=(
          'check:check if the database can be reached'
          'check-migrations:check for pending migrations'
          'clean:purge old records'
          'downgrade:downgrade the schema'
          'export-archived:export archived data'
          'init:initialize the metadata database'
          'migrate:migrate the database to the latest version'
          'reset:burn down and rebuild the metadata database'
          'shell:run a shell to access the database'
          'upgrade:upgrade the metadata database'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'db subcommand' db_cmds && ret=0
        ;;
      webserver)
        _arguments \
          '(-p --port)'{-p,--port}'[port on which to run the server]:port' \
          '(-w --workers)'{-w,--workers}'[number of workers]:workers' \
          '(-k --workerclass)'{-k,--workerclass}'[worker class]:class:(sync eventlet gevent)' \
          '(-t --worker-timeout)'{-t,--worker-timeout}'[worker timeout in seconds]:seconds' \
          '(-H --hostname)'{-H,--hostname}'[hostname to listen on]:hostname' \
          '--pid=[PID file]:pid file:_files' \
          '-D[daemonize]' \
          '--stderr=[stderr log file]:file:_files' \
          '--stdout=[stdout log file]:file:_files' \
          '--access-logfile=[access log file]:file:_files' \
          '--error-logfile=[error log file]:file:_files' \
          '--access-logformat=[access log format]:format' \
          '-d[use debug mode]' \
          '--ssl-cert=[path to the SSL certificate]:cert file:_files' \
          '--ssl-key=[path to the SSL key]:key file:_files' && ret=0
        ;;
      scheduler)
        _arguments \
          '(-n --num-runs)'{-n,--num-runs}'[set the number of runs to execute]:runs' \
          '(-S --subdir)'{-S,--subdir}'[file location or directory]:path:_files' \
          '(-D --daemon)'{-D,--daemon}'[daemonize instead of running in foreground]' \
          '--pid=[PID file]:pid file:_files' \
          '--stderr=[stderr log file]:file:_files' \
          '--stdout=[stdout log file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
