#compdef greenit
# ============================================================================
# greenit - GreenIT Analysis CLI for web carbon footprint (Node, AGPL-3.0)
#
# Author : Collectif Conception Numerique Responsable (cnumr)
# Upstream: https://github.com/cnumr/GreenIT-Analysis-cli
# npm    : greenit-cli
#
# greenit is a Node CLI wrapper for the GreenIT-Analysis browser
# extension. It drives a headless Chromium via Puppeteer to load each
# URL in a YAML input file, applies the GreenIT-Analysis ruleset
# (compatible with the ADEME / Collectif Conception Numerique
# Responsable methodology for web environmental impact), and emits a
# multi-format report: an XLSX workbook with per-rule + per-URL +
# overall environmental-footprint metrics, an HTML report with the
# same data plus Grafana embed links, and an InfluxDB push for
# time-series dashboards.
#
# The XLSX emission lane is built on `exceljs ^4.4.0` (declared
# verbatim at upstream package.json HEAD), the dominant Node Excel
# library by Guyon Roche + community (github.com/exceljs/exceljs,
# 15000+ stars). exceljs implements the full ECMA-376 OOXML
# spreadsheet schema in pure JavaScript with a fluent builder API:
#
#     const workbook = new ExcelJS.Workbook();
#     const sheet = workbook.addWorksheet('Sheet1');
#     sheet.addRow(['col1', 'col2', 'col3']);
#     sheet.getCell('A1').font = {bold: true};
#     await workbook.xlsx.writeFile(filename);
#
# It supports the full read+write surface, conditional formatting,
# data validation, embedded images, comments, sheet protection,
# pivot tables, formula compilation, and chart rendering. exceljs
# is the Node-side dependency-of-record for every "export to Excel"
# button in the JavaScript ecosystem (admin dashboards, analytics
# tools, financial reporting, lab reports).
#
# ----------------------------------------------------------------------------
# AXIS 200 :: SPREADSHEET (XLSX) READ / WRITE (ECMA-376 OOXML)  [CLOSES]
# Round 1300 :: TS-Node slot 3 of 4 :: CLOSES Axis 200 (193rd axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : calamine + rust_xlsxwriter   [R1298 _excel-cli]
#   Go      : xuri/excelize                [R1299 _nmap-formatter]
#   TS/Node : exceljs/exceljs              [R1300 THIS FILE]
#
# Round-number landmark R1300. All three lanes have landed real
# downstream consumers exercising their canonical OOXML library
# under a non-trivial workload: Rust exercises split read/write via
# excel-cli's TUI + headless JSON modes; Go runs excelize through
# the multi-format Nmap-XML-to-everything emission lane in
# nmap-formatter; Node leverages exceljs as a sustainability /
# carbon-accounting report renderer here in greenit.
#
# The structural picture across the three lanes: Rust 2 crates (one
# read, one write); Go 1 module unified; Node 1 package unified.
# Star counts: excelize 20k+ > exceljs 15k+ >> calamine 2k+ +
# rust_xlsxwriter 500+. The mind-share gap mirrors how long each
# ecosystem has had a single trusted Excel library: Node since
# the late 2010s, Go since 2017, Rust ecosystem still consolidating
# in 2026.
# ============================================================================

_greenit() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--ci[disable progress bar for GitLab CI use]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        '1: :_greenit_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                analyse)        _greenit_analyse ;;
                parseSitemap)   _greenit_parsesitemap ;;
            esac
            ;;
    esac

    return ret
}

_greenit_cmds() {
    local -a cmds
    cmds=(
        'analyse:Run the GreenIT environmental-footprint analysis'
        'parseSitemap:Parse sitemap.xml URL into a YAML URL list'
    )
    _describe -t commands 'greenit command' cmds
}

_greenit_analyse() {
    _arguments -s -S \
        '--grafana_link[Grafana embed link for HTML report]:url:' \
        '(-d --device)'{-d,--device}'[hardware to simulate]:device:(desktop mobile tablet)' \
        '(-f --format)'{-f,--format}'[report format]:format:(xlsx html influxdb influxdbhtml)' \
        '(-h --headers)'{-h,--headers}'[HTTP headers to set on each request]:headers:' \
        '--headless[enable/disable browser headless mode (default true)]:bool:(true false)' \
        '--influxdb_bucket[InfluxDB bucket]:bucket:' \
        '--influxdb_hostname[InfluxDB hostname]:hostname:' \
        '--influxdb_org[InfluxDB organization]:org:' \
        '--influxdb_token[InfluxDB auth token]:token:' \
        '--language[report language]:lang:(fr en)' \
        '(-l --login)'{-l,--login}'[YAML file with login credentials]:file:_files -g "*.yaml"' \
        '--max_tab[max concurrent analyses (default 40)]:num:' \
        '--mobile[connection type: mobile vs wired (default false)]:bool:(true false)' \
        '(-p --proxy)'{-p,--proxy}'[YAML proxy configuration file]:file:_files -g "*.yaml"' \
        '(-r --retry)'{-r,--retry}'[number of retries on failure (default 2)]:num:' \
        '(-t --timeout)'{-t,--timeout}'[per-URL timeout in ms (default 180000)]:ms:' \
        '--worst_pages[number of worst pages to display (default 5)]:num:' \
        '--worst_rules[number of worst rules to display (default 5)]:num:' \
        '(- *)'{-h,--help}'[show help]' \
        '1:URL YAML input file:_files -g "*.yaml"' \
        '2:report output file:_files -g "*.(xlsx|html)"'
}

_greenit_parsesitemap() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[show help]' \
        '1:sitemap.xml URL:' \
        '2:YAML output file:_files -g "*.yaml"'
}

_greenit "$@"
