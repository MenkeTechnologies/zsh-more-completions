#compdef solns2out
# Documentation: https://docs.minizinc.dev/en/stable/command_line.html
# MiniZinc solution output processor (FlatZinc to output)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help message]' \
  '--version[display version information]' \
  '--ozn-file[read output specification from file]:file:_files' \
  '(-o --output-to-file)'{-o,--output-to-file}'[output file]:file:_files' \
  '(-i --ignore-lines)'{-i,--ignore-lines}'[skip initial lines]:n' \
  '(--soln-sep --solution-separator)'{--soln-sep,--solution-separator}'[solution separator string]:sep' \
  '(--soln-comma --solution-comma)'{--soln-comma,--solution-comma}'[solution comma string]:str' \
  '--unsat-msg[unsatisfiable status message]:msg' \
  '--unbounded-msg[unbounded status message]:msg' \
  '--unsatorunbnd-msg[unsatisfiable/unbounded message]:msg' \
  '--unknown-msg[unknown status message]:msg' \
  '--error-msg[error status message]:msg' \
  '--search-complete-msg[search complete message]:msg' \
  '--non-unique[allow duplicate solutions]' \
  '(-c --canonicalize)'{-c,--canonicalize}'[buffer and sort solutions]' \
  '--output-non-canonical[non-buffered output file]:file:_files' \
  '--output-raw[solver raw output file]:file:_files' \
  '--no-output-comments[suppress comments]' \
  '--output-time[print timing information]' \
  '--no-flush-output[disable stream flushing]' \
  '*:file:_files' && ret=0

return ret
