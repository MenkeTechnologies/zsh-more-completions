#compdef lstr

# Zsh completion for lstr directory tree (bgreenwell/lstr)

local curcontext="$curcontext" ret=1

_lstr_first() {
  local -a expl
  compadd interactive i
  _files -/
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--color[when to colorize]:when:(always auto never)' \
  '(-L --level)'{-L,--level}'[max tree depth]:n' \
  '(-d --dirs-only)'{-d,--dirs-only}'[directories only]' \
  '(-s --size)'{-s,--size}'[show file sizes]' \
  '(-p --permissions)'{-p,--permissions}'[show permission bits]' \
  '(-a --all)'{-a,--all}'[include hidden files]' \
  '(-g --gitignore)'{-g,--gitignore}'[honour ignore rules]' \
  '(-G --git-status)'{-G,--git-status}'[git status markers]' \
  '--icons[nerd font icons]' \
  '--expand-level[TUI initial depth]:level' \
  '1:path or interactive:_lstr_first' \
  '*:path:_files -/' && ret=0

return ret
