#compdef molenc_shuf
# ============================================================================
#  _molenc_shuf — molenc_shuf: seedable line-shuffler (cheminformatics
#                 SMILES/SDF/MOL2 dataset prep tool from the MolEnc suite)
#
#  Source-direct extraction from
#    https://github.com/UnixJunkie/molenc/blob/master/src/shuf.ml
#    https://github.com/UnixJunkie/minicli (the Minicli library by
#    Francois "UnixJunkie" Berenger)
#
#  Maintained by Francois Berenger (UnixJunkie/molenc).  21 GH stars.
#  molenc is a MOLECULAR ENCODER for cheminformatics machine learning
#  pipelines — encodes SMILES strings and SDF molecules into numeric
#  fingerprints (atom pairs, ECFP-like signatures, pharmacophores)
#  for ML models like SVM/RF/XGBoost.  The `molenc_shuf` binary is a
#  seedable replacement for GNU `shuf` used in reproducible dataset
#  preparation — shuffles SMILES/SDF dataset lines while preserving
#  reproducibility via `-s SEED`.  Sister tools in the molenc suite:
#  `molenc_e` (encoder), `molenc_d` (decoder), `molenc_filter`,
#  `molenc_cluster` (Butina clustering), `molenc_uniq` (deduplication),
#  `molenc_split` (train/test split), `molenc_dense` (sparse-to-dense
#  fingerprints), `molenc_rank` (similarity ranking), `molenc_ap`
#  (atom pairs), `molenc_mst` (minimum spanning tree), `molenc_pareto`
#  (Pareto front analysis), and others.  Sister bioinformatics tools:
#  RDKit (Python/C++ cheminformatics, IN CORPUS via _rdkit-related),
#  OpenBabel (in corpus), Indigo (commercial), DataWarrior (Java).
#
#  CLI library taxonomy update: 6th OCaml CLI library — Francois
#  Berenger's **Minicli** (UnixJunkie/minicli).  OCaml ecosystem now
#  has 6 documented CLI libraries (R271 Cmdliner + R325 stdlib Arg +
#  R331 Jane Street Core.Command + R339 rbardou/Clap + R369 ocaml-
#  getopt + R391 Minicli) — tied with Python (6) for second-most-
#  documented CLI language behind Rust/Go (9).
#
#  Minicli (UnixJunkie/minicli) is Francois Berenger's MINIMALIST
#  OCaml CLI library — designed for IMPERATIVE single-command
#  scripts where the caller writes the help text manually and uses
#  typed `CLI.get_*` accessors to extract values.  Distinct from
#  R271 OCaml Cmdliner (functional applicative-combinator with auto-
#  generated man pages), R325 OCaml stdlib Arg (spec-list with
#  variant-constructor actions), R331 OCaml Jane Street Core.Command
#  (PPX applicative composition), R339 OCaml rbardou/Clap (imperative
#  consumer calls with global parser state), R369 OCaml ocaml-getopt
#  (GNU getopt_long port with 4-tuple specs) by being ZERO-CEREMONY
#  with `CLI.get_string`/`CLI.get_int`/`CLI.get_float`/`CLI.get_int_opt`
#  typed extractors and manual `CLI.finalize ()` to verify all args
#  consumed.  Used by Francois Berenger's entire OCaml cheminformatics
#  / machine-learning research tool ecosystem: molenc (molecular
#  encoder), ACP4 (anti-cancer peptide predictor), linwrap (liblinear
#  wrapper), svmwrap (libsvm wrapper), oranger (random forest wrapper),
#  orxgboost (XGBoost wrapper), omlr (linear regression), bisec-tree
#  (bisector tree), hts_shrink (HTS shrinking), pardi (partial
#  dependency), dokeysto (Berkeley DB key-value store), consent (
#  consensus tool), MMO, ACP4, carbon, rankers, plus tweag/check_opam_
#  switch and Cjen1/ocaml-tree-diff — Berenger's tools are widely
#  cited in computational chemistry / drug-discovery papers.
#
#  Minicli API:
#    open Printf
#    module CLI = Minicli.CLI
#
#    let main () =
#      let argc, args = CLI.init () in
#      (if argc = 1 then
#         begin
#           eprintf "usage:\n\
#                    %s\n  \
#                    -i <filename>: input file\n  \
#                    -o <filename>: output file\n  \
#                    [-n <int>]: count (default=all)\n  \
#                    [-s <int>]: random seed (default=none)\n"
#            Sys.argv.(0);
#           exit 1
#         end);
#      let input_fn  = CLI.get_string ["-i"] args in
#      let output_fn = CLI.get_string ["-o"] args in
#      let maybe_n   = CLI.get_int_opt ["-n"] args in
#      let maybe_seed = CLI.get_int_opt ["-s"] args in
#      CLI.finalize (); (* verify all args consumed *)
#      (* ... use input_fn, output_fn, maybe_n, maybe_seed ... *)
#
#    let () = main ()
#
#  Minicli distinctive features:
#    - MINIMALIST design — zero ceremony; caller writes help text
#      manually as `eprintf` block when `argc = 1`, then extracts
#      values via typed `CLI.get_*` accessors
#    - `Minicli.CLI` MODULE — typically aliased as `module CLI =
#      Minicli.CLI`
#    - `CLI.init ()` — INITIALIZATION returning `(argc, args)` tuple
#      where `argc: int` is the argument count (including program
#      name) and `args: string list ref` is the mutable arg list
#    - `args: string list ref` — MUTABLE REF holding remaining
#      unprocessed args; each `CLI.get_*` call REMOVES the matched
#      args from the list
#    - TYPED EXTRACTORS:
#      * `CLI.get_string aliases args` — REQUIRED string value
#      * `CLI.get_string_opt aliases args` — OPTIONAL string
#      * `CLI.get_string_def aliases args default` — string with default
#      * `CLI.get_int aliases args` — REQUIRED int with auto-parse
#      * `CLI.get_int_opt aliases args` — OPTIONAL int
#      * `CLI.get_int_def aliases args default` — int with default
#      * `CLI.get_float aliases args` — REQUIRED float
#      * `CLI.get_float_opt aliases args` — OPTIONAL float
#      * `CLI.get_float_def aliases args default` — float with default
#      * `CLI.get_set_bool aliases args` — boolean flag (presence = true)
#      * `CLI.get_set_string aliases args default` — string with auto-set
#    - ALIAS ARRAYS — first argument to `CLI.get_*` is a `string list`
#      of equivalent flag names: `["-i"; "--input"]` accepts both
#      short and long forms
#    - REQUIRED EXTRACTORS — `CLI.get_string` and `CLI.get_int` raise
#      `No_param_for_option` exception if missing
#    - OPTIONAL EXTRACTORS — `CLI.get_*_opt` return `'a option`
#      (None when missing)
#    - DEFAULT EXTRACTORS — `CLI.get_*_def` return value with explicit
#      default fallback
#    - `CLI.finalize ()` — VERIFY ALL ARGS CONSUMED; raises
#      `Unparsed_options` exception if any args remain after all
#      extractors; CRITICAL for catching typos like `--vebrose`
#    - PROCESS EXIT model — caller uses OCaml `exit N` directly; no
#      automatic exit on parse error
#    - NO automatic --help — caller writes help text manually as
#      `eprintf` block when `argc = 1` (zero args means show usage)
#    - NO automatic --version — caller adds via `CLI.get_set_bool
#      ["--version"] args` then checks the flag
#    - NO subcommand support — caller hand-rolls subcommand dispatch
#      (typically check `argv[1]` to dispatch to different `main_*`
#      functions)
#    - IMMEDIATE-MODE — extractors PROCESS ARGS IN ORDER via mutable
#      ref-cell removal; final `CLI.finalize ()` catches typos
#    - NO type coercion machinery — values are parsed by OCaml stdlib
#      `int_of_string`/`float_of_string`; exceptions propagate to caller
#  Distinct from R271 OCaml Cmdliner (functional applicative-combinator
#  with auto-generated man pages, used by majority of opam tools),
#  R325 OCaml stdlib Arg (similar mutable ref-cell binding but with
#  DIFFERENT spec variant constructors like `Arg.Set`/`Arg.String`/
#  `Arg.Int`), R331 OCaml Jane Street Core.Command (PPX `let%map_
#  open.Command` applicative composition), R339 OCaml rbardou/Clap
#  (imperative consumption mechanism with global parser state — CLOSEST
#  analog to Minicli but rbardou/Clap has stateful parser instance vs
#  Minicli's local ref-cell), R369 OCaml ocaml-getopt (GNU getopt_long
#  port with 4-tuple specs and `Getopt.set`/`atmost_once` helpers),
#  R272 C POSIX getopt (C language).  Minicli's approach: MINIMALIST
#  with `CLI.init () -> (argc, args ref)` + TYPED `CLI.get_string`/
#  `CLI.get_int`/`CLI.get_float` REQUIRED extractors + `CLI.get_*_opt`
#  OPTIONAL variants + `CLI.get_*_def` with DEFAULT fallback + `CLI.
#  get_set_bool` flag presence + ALIAS ARRAYS as `string list` (first
#  argument) + MUTABLE REF args mutation (each extractor removes
#  matched args) + `CLI.finalize ()` verify-all-consumed for typo
#  detection + caller-written `eprintf` help text when `argc = 1` +
#  zero ceremony — corpus's **first documented minimalist-zero-
#  ceremony-with-mutable-ref-extractor-removal OCaml CLI library**.
#  Brings cross-language CLI library taxonomy variant count to 130;
#  OCaml ecosystem now has 6 documented CLI libraries — tied with
#  Python (6) for second-most-documented CLI language behind
#  Rust/Go (9).
#
#  Surface (verbatim from `src/shuf.ml` extractor calls):
#
#  Options:
#    -i FILENAME                  Input file (REQUIRED; line-oriented
#                                 SMILES/SDF/MOL2 dataset)
#    -o FILENAME                  Output file (REQUIRED; line-oriented
#                                 output)
#    -n N                         Output at most N lines (default=all;
#                                 OPTIONAL via CLI.get_int_opt)
#    -s SEED                      Random seed for reproducible shuffling
#                                 (default=auto-seed from /dev/urandom
#                                 if omitted; OPTIONAL via CLI.get_int_opt)
#
#  Behavior:
#    - If argc=1 (no args), prints usage and exits 1
#    - After all extractors, CLI.finalize() verifies no unparsed args
#      remain (catches typos like `-J` instead of `-n`)
#    - Reads input file into memory, shuffles via BatRandom.State,
#      writes first N lines (or all if -n omitted) to output
#    - Reproducible: same -s SEED produces identical shuffle output
#      across runs (critical for ML dataset preparation)
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also Minicli users — all from UnixJunkie/Francois Berenger's
#  cheminformatics research tool suite):
#    - molenc_uniq / molenc_split / molenc_e / molenc_d / molenc_filter
#      / molenc_cluster / molenc_dense / molenc_rank / molenc_ap /
#      molenc_mst / molenc_pareto / molenc_indexer / molenc_finder
#      / molenc_apbbad / molenc_split / molenc_sdf_read / molenc_dsmi
#      / molenc_bbad / molenc_AP / molenc_UHD / molenc_get_tag (ALL
#      molenc binaries — also use Minicli; molenc_shuf chosen as
#      canonical Minicli showcase with the cleanest demonstration of
#      get_string + get_int_opt + finalize pattern)
#    - ACP4 (UnixJunkie/ACP4 3 stars — anti-cancer peptide predictor)
#    - linwrap (UnixJunkie/linwrap 7 stars — liblinear wrapper)
#    - svmwrap (UnixJunkie/svmwrap 4 stars — libsvm wrapper)
#    - oranger (UnixJunkie/oranger 7 stars — random forest wrapper)
#    - orxgboost (UnixJunkie/orxgboost 9 stars — XGBoost wrapper)
#    - omlr (UnixJunkie/omlr — OCaml linear regression)
#    - bisec-tree / hts_shrink / pardi / dokeysto / consent / MMO /
#      carbon / rankers (Berenger's other cheminformatics/ML tools)
#    - tweag/check_opam_switch (Tweag tool, 0 stars — uses Minicli)
#    - Cjen1/ocaml-tree-diff (uses Minicli — academic)
# ============================================================================

_molenc_shuf() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '-i[input file (REQUIRED, line-oriented SMILES/SDF/MOL2)]:file:_files' \
    '-o[output file (REQUIRED, line-oriented output)]:file:_files' \
    '-n[output at most N lines (default all)]:n' \
    '-s[random seed for reproducible shuffling]:seed'
}

_molenc_shuf "$@"
