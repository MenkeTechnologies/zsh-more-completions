#compdef btrfsdist btrfsdist-bpfcc
# _btrfsdist — Btrfs operation latency distribution (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/btrfsdist.py (argparse).

_btrfsdist() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-T --notimestamp)'{-T,--notimestamp}'[do not include timestamp on interval output]'
        '(-m --milliseconds)'{-m,--milliseconds}'[output in milliseconds]'
        '(-p --pid)'{-p+,--pid=}'[trace this PID only]:pid:'
        '1:interval (seconds):'
        '2:output count:'
    )
    _arguments $args
}

_btrfsdist "$@"
