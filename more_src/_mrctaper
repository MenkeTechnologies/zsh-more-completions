#compdef mrctaper
# Documentation: https://bio3d.colorado.edu/imod/doc/man/mrctaper.html
# Taper the edges of an MRC image stack

local ret=1

_arguments -s \
  '-i[Taper inside rather than outside]' \
  '-t[of the mean of the X and Y sizes of the image, but at l]' \
  '-z[Operate only on sections from min to max. Sections are ]:value:' \
  '*:file:_files' && ret=0

return ret
