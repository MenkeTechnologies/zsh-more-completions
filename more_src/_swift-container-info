#compdef swift-container-info
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/cli/info.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --swift-dir)'{-d,--swift-dir=}'[location of swift configuration files]:swift dir:_files -/' \
  '--drop-prefixes[drop per-section common prefixes when outputting metadata]' \
  '(-v --verbose)'{-v,--verbose}'[show all shard ranges]' \
  '(-s --sync)'{-s,--sync}'[output contents of incoming/outgoing sync tables]' \
  '*:container db file:_files' && ret=0
return ret
