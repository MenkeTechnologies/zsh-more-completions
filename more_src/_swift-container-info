#compdef swift-container-info
# Documentation: https://man.archlinux.org/search?q=swift-container-info
# Reference accessed: 2026-05-16

# swift-container-info: inspect a container DB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-d[swift_dir]:dir:_files -/' \
  '--swift-dir=[swift_dir]:dir:_files -/' \
  '-p[policy_name]:name:' \
  '--policy-name=[policy name]:name:' \
  '--sync[show sync info]' \
  '*:db or file:_files' && ret=0
return ret
