#compdef pt-slave-restart
# Documentation: https://docs.percona.com/percona-toolkit/pt-replica-restart.html
# pt-slave-restart - symlink to pt-replica-restart; watch and restart MySQL replication after errors

local ret=1

_arguments -s -S \
  '(--help)--help[show help and exit]' \
  '(--version)--version[show version and exit]' \
  '--always[start the replica even when there is no error]' \
  '--ask-pass[prompt for a password when connecting to MySQL]' \
  '--buffer-stdout[buffer stdout]' \
  '--no-buffer-stdout[do not buffer stdout]' \
  '--check-relay-log[check the relay log when an error occurs]' \
  '--no-check-relay-log[do not check the relay log when an error occurs]' \
  '--daemonize[fork to the background and detach]' \
  '--monitor[watch and restart the replica (default)]' \
  '--stop[stop the replica when it starts]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all normal output]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose; print errors and other information]' \
  '--version-check[check for the latest version of tools]' \
  '--no-version-check[do not check for the latest version of tools]' \
  '(-A --charset)'{-A,--charset=}'[default character set]:charset' \
  '*--config=[read this comma-separated list of config files]:files:_files' \
  '(-D --database)'{-D,--database=}'[connect to this database]:database' \
  '(-F --defaults-file)'{-F,--defaults-file=}'[only read MySQL options from this file]:file:_files' \
  '--error-length=[max length of error message to print]:length' \
  '--error-numbers=[restart only on this comma-separated list of errors]:numbers' \
  '--error-text=[restart only on errors matching this pattern]:pattern' \
  '(-h --host)'{-h,--host=}'[connect to host]:host:_hosts' \
  '--log=[print all output to this file when daemonized]:file:_files' \
  '--master-uuid=[deprecated; use --source-uuid]:uuid' \
  '--max-sleep=[max sleep seconds between checks]:seconds' \
  '--min-sleep=[min sleep seconds between checks]:seconds' \
  '(-s --mysql_ssl)'{-s,--mysql_ssl=}'[enable SSL for the connection]:int' \
  '(-p --password)'{-p,--password=}'[password to use when connecting]:password' \
  '--pid=[create the given PID file]:file:_files' \
  '(-P --port)'{-P,--port=}'[port number to use for connection]:port' \
  '--recurse=[number of levels to recurse in the hierarchy]:levels' \
  '*--recursion-method=[preferred recursion method for finding replicas]:method' \
  '--replica-user=[user for connecting to replicas]:user' \
  '--replica-password=[password for connecting to replicas]:password' \
  '--run-time=[time to run before exiting]:time' \
  '--sentinel=[exit if this file exists]:file:_files' \
  '*--set-vars=[set the MySQL variables in this comma-separated list]:vars' \
  '--skip-count=[number of statements to skip when restarting the replica]:count' \
  '--slave-user=[deprecated; use --replica-user]:user' \
  '--slave-password=[deprecated; use --replica-password]:password' \
  '--sleep=[initial sleep seconds between checks]:seconds' \
  '(-S --socket)'{-S,--socket=}'[socket file to use for connection]:socket:_files' \
  '--source-uuid=[restart replication only for this source UUID]:uuid' \
  '--until-master=[deprecated; use --until-source]:file,pos' \
  '--until-relay=[stop at this relay log file and position]:file,pos' \
  '--until-source=[stop at this source log file and position]:file,pos' \
  '(-u --user)'{-u,--user=}'[user for login if not current user]:user:_users' \
  '*::args:_default' && ret=0

return ret
