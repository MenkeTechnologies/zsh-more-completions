#compdef jackhmmer
# Documentation: https://manpages.debian.org/testing/hmmer/jackhmmer.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# HMMER jackhmmer: iterative profile search with a single query sequence.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-N[maximum iterations (default 5)]:n:' \
  '-o[direct output to file]:file:_files' \
  '-A[save final-iteration alignment]:file:_files' \
  '--tblout[per-sequence hits tabular output]:file:_files' \
  '--domtblout[per-domain hits tabular output]:file:_files' \
  '--chkhmm[checkpoint query HMM each iteration]:prefix:' \
  '--chkali[checkpoint alignment each iteration]:prefix:' \
  '--acc[use accessions instead of names]' \
  '--noali[omit alignment section]' \
  '--notextw[unlimit line width]' \
  '--textw[max line width (default 120)]:n:' \
  '--popen[gap-open probability (default 0.02)]:x:' \
  '--pextend[gap-extend probability (default 0.4)]:x:' \
  '--mx[built-in substitution matrix]:matrix:(PAM30 PAM70 PAM120 PAM240 BLOSUM45 BLOSUM50 BLOSUM62 BLOSUM80 BLOSUM90)' \
  '--mxfile[substitution matrix file]:file:_files' \
  '-E[per-sequence E-value threshold (default 10.0)]:x:' \
  '-T[per-sequence bit-score threshold]:x:' \
  '-Z[set # of comparisons for E-value]:x:' \
  '--domE[per-domain E-value threshold (default 10.0)]:x:' \
  '--domT[per-domain bit-score threshold]:x:' \
  '--domZ[set # significant seqs for domain E-value]:x:' \
  '--incE[seq inclusion E-value (default 0.001)]:x:' \
  '--incT[seq inclusion bit-score]:x:' \
  '--incdomE[domain inclusion E-value (default 0.001)]:x:' \
  '--incdomT[domain inclusion bit-score]:x:' \
  '--max[max sensitivity: turn all heuristic filters off]' \
  '--F1[MSV filter P-value threshold (default 0.02)]:x:' \
  '--F2[Viterbi filter P-value threshold (default 0.001)]:x:' \
  '--F3[Forward filter P-value threshold (default 1e-5)]:x:' \
  '--nobias[turn off composition bias filter]' \
  '--fragthresh[fragment length threshold (default 0.5)]:x:' \
  '--wpb[Henikoff position-based weights (default)]' \
  '--wgsc[Gerstein/Sonnhammer/Chothia weights]' \
  '--wblosum[BLOSUM filter weights]' \
  '--wnone[no relative weighting]' \
  '--wid[BLOSUM relative weight identity cutoff (default 0.62)]:x:' \
  '--eent[entropy weighting effective seq # (default)]' \
  '--eclust[single-linkage clustering effective seq #]' \
  '--enone[no effective seq # weighting]' \
  '--eset[set effective seq #]:x:' \
  '--ere[minimum relative entropy/position]:x:' \
  '--esigma[min total relative entropy parameter (default 45.0)]:x:' \
  '--eid[clustering identity cutoff (default 0.62)]:x:' \
  '--pnone[no priors; use observed frequencies]' \
  '--plaplace[use a Laplace +1 prior]' \
  '--EmL[MSV calibration seq length (default 200)]:n:' \
  '--EmN[MSV calibration seq number (default 200)]:n:' \
  '--EvL[Viterbi calibration seq length (default 200)]:n:' \
  '--EvN[Viterbi calibration seq number (default 200)]:n:' \
  '--EfL[Forward calibration seq length (default 100)]:n:' \
  '--EfN[Forward calibration seq number (default 200)]:n:' \
  '--Eft[Forward calibration tail mass (default 0.04)]:x:' \
  '--nonull2[turn off biased composition score corrections]' \
  '--seed[random number seed (default 42)]:n:' \
  '--qformat[query sequence format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--tformat[target database format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--cpu[number of parallel worker threads (default 2)]:n:' \
  '--stall[stall (for attaching debugger to a process)]' \
  '--mpi[run under MPI control]' \
  '*:query sequence and target database:_files' && ret=0
return ret
