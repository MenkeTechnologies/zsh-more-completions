#compdef jackhmmer
# Documentation: https://manpages.debian.org/testing/hmmer/jackhmmer.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# HMMER jackhmmer: iterative JCV-style searches with a query sequence
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-N[number of iterations]:n:' \
  '-o[output file]:file:_files' \
  '-A[save MSA from final iteration]:file:_files' \
  '--tblout[per-target hits table]:file:_files' \
  '--domtblout[per-domain hits table]:file:_files' \
  '--chkhmm[checkpoint HMM after each iteration]:prefix:' \
  '--chkali[checkpoint alignment after each iteration]:prefix:' \
  '--acc[show accessions]' \
  '--noali[no alignment output]' \
  '--textw[max text width]:cols:' \
  '--notextw[no max width]' \
  '--popen[gap-open probability for first iteration]:val:' \
  '--pextend[gap-extend probability for first iteration]:val:' \
  '--mxfile[scoring matrix file]:file:_files' \
  '--mx[built-in scoring matrix]:matrix:(PAM30 PAM70 PAM120 PAM240 BLOSUM45 BLOSUM50 BLOSUM62 BLOSUM80 BLOSUM90)' \
  '-E[reporting E-value]:Eval:' \
  '-T[reporting score threshold]:bits:' \
  '--domE[per-domain E-value]:Eval:' \
  '--domT[per-domain score]:bits:' \
  '--incE[inclusion E-value]:Eval:' \
  '--incT[inclusion score]:bits:' \
  '--incdomE[per-domain inclusion E-value]:Eval:' \
  '--incdomT[per-domain inclusion score]:bits:' \
  '--max[no heuristic filters]' \
  '--F1[MSV threshold]:val:' \
  '--F2[Vit threshold]:val:' \
  '--F3[Fwd threshold]:val:' \
  '--nobias[no bias filter]' \
  '--seed[random seed]:n:' \
  '--qformat[query sequence format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--tformat[target db format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip)' \
  '--cpu[CPU threads]:n:' \
  '*:query sequence and target database:_files' && ret=0
return ret
