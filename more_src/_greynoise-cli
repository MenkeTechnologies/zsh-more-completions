#compdef greynoise greynoise-cli
# _greynoise-cli — GreyNoise greynoise-cli CLI client to the GreyNoise Internet noise enrichment REST API querying IP reputation classification context tags categories quick-quick-lookup bulk-IP-stream RIOT business-service-classification GNQL search facet stats analyze pcap (GreyNoise Intelligence team, Python); click
# upstream: https://greynoise.io/

_greynoise-cli() {
    local -a sub=(
        'setup:configure API key'
        'ip:lookup a single IP'
        'quick:quick IP lookup'
        'ip-multi:lookup multiple IPs'
        'riot:RIOT lookup for trusted IPs'
        'query:GreyNoise Query Language search'
        'stats:facet statistics on a GNQL query'
        'similar:find similar IPs'
        'timeline:IP behaviour over time'
        'feedback:submit feedback'
        'analyze:upload log file for analysis'
        'pcap:extract IP info from pcap'
        'persona:persona endpoint'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-k+[api key]:str:' \
        '--api-key=+[key]:str:' \
        '-f+[format]:f:(json txt xml csv table)' \
        '--format=+[format]:f:(json txt xml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-i+[input file]:file:_files' \
        '--input-file=+[file]:file:_files' \
        '-s+[size]:n:' \
        '--size=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'greynoise-cli subcommand' sub ;;
        args)
            case $words[1] in
                ip|quick|riot|similar|timeline) _arguments '*:ip address:' ;;
                query|stats) _arguments '*:GNQL:' ;;
                analyze) _arguments '1:log file:_files' ;;
                pcap) _arguments '1:pcap file:_files -g "*.pcap *.pcapng"' ;;
            esac
            ;;
    esac
}

_greynoise-cli "$@"
