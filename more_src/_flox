#compdef flox

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[increase verbosity]' \
  '--verbose[increase verbosity]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'activate:activate an environment'
      'auth:manage authentication'
      'containerize:containerize an environment'
      'delete:delete an environment'
      'edit:edit environment configuration'
      'init:initialize an environment'
      'install:install packages'
      'list:list installed packages'
      'pull:pull an environment'
      'push:push an environment'
      'search:search for packages'
      'services:manage services'
      'show:show environment details'
      'uninstall:uninstall packages'
      'update:update environment'
      'upgrade:upgrade packages'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      install)
        _arguments -s -S \
          '(-d --dir)'{-d,--dir}'[environment directory]:directory:_directories' \
          '(-r --remote)'{-r,--remote}'[environment owner/name]:remote' \
          '(- *)'{-h,--help}'[show help]' \
          '*:package' && ret=0
        ;;
      search)
        _arguments -s -S \
          '--all[show all versions]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:search term' && ret=0
        ;;
      activate)
        _arguments -s -S \
          '(-d --dir)'{-d,--dir}'[environment directory]:directory:_directories' \
          '(-r --remote)'{-r,--remote}'[environment owner/name]:remote' \
          '--trust[trust the environment]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:command:_command_names -e' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(-d --dir)'{-d,--dir}'[directory]:directory:_directories' \
          '--name=[environment name]:name' \
          '--auto-setup[auto setup]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '(-d --dir)'{-d,--dir}'[environment directory]:directory:_directories' \
          '(-r --remote)'{-r,--remote}'[environment owner/name]:remote' \
          '(- *)'{-h,--help}'[show help]' \
          '*:package' && ret=0
        ;;
      edit)
        _arguments -s -S \
          '(-d --dir)'{-d,--dir}'[environment directory]:directory:_directories' \
          '(-r --remote)'{-r,--remote}'[environment owner/name]:remote' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
