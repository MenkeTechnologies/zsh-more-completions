_pkdns_server_main() {
    _arguments -s \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --forward)'{-f+,--forward=}'[ICANN fallback DNS server (default 8.8.8.8:53)]:ip\:port:' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-p --pkdns-dir)'{-p+,--pkdns-dir=}'[base data/config directory (default ~/.pkdns)]:directory:_files -/'
}

_pkdns_cli_main() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'publish:publish a signed pkarr DNS zone to the DHT'
        'resolve:resolve a Public Key Domain on the DHT'
        'generate:generate a new Ed25519 seed'
        'publickey:derive zbase32 public key from a seed'
        'help:show help for a subcommand'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'pkdns-cli subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                publish)
                    _arguments \
                        '1:seed file (default ./seed.txt):_files' \
                        '2:zonefile (default ./pkarr.zone):_files -g "*.zone"' && ret=0
                    ;;
                resolve)
                    _arguments '1:public key domain (zbase32):' && ret=0
                    ;;
                publickey)
                    _arguments '1:seed file (default ./seed.txt):_files' && ret=0
                    ;;
                generate|help)
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

case $service in
    pkdns-cli) _pkdns_cli_main "$@" ;;
    *) _pkdns_server_main "$@" ;;
esac
