#compdef emacs25
# Documentation: https://man.archlinux.org/search?q=emacs25
# Reference accessed: 2026-05-16

# GNU Emacs 25.x editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-nw[no window system (terminal mode)]' \
  '-Q[skip site-start, init, splash]' \
  '--quick[skip site-start, init, splash]' \
  '-q[skip user init file]' \
  '--no-init-file[skip user init file]' \
  '--no-site-file[skip site-start.el]' \
  '--no-splash[suppress splash screen]' \
  '--debug-init[enter debugger on init error]' \
  '-batch[run non-interactive batch mode]' \
  '--batch[run non-interactive batch mode]' \
  '-script[run as script]:file:_files' \
  '-l[load lisp file]:file:_files -g "*.el(c|.gz)#"' \
  '--load=[load lisp file]:file:_files -g "*.el(c|.gz)#"' \
  '-f[call lisp function]:func:' \
  '--funcall=[call lisp function]:func:' \
  '--eval=[evaluate lisp expression]:expr:' \
  '--user=[use user init dir]:user:_users' \
  '--terminal=[use terminal device]:device:' \
  '--display=[X display to use]:display:' \
  '-bg[background color]:color:' \
  '-fg[foreground color]:color:' \
  '-fn[font]:font:' \
  '--geometry=[WxH+X+Y]:geometry:' \
  '-T[window title]:title:' \
  '*:file:_files' && ret=0
return ret
