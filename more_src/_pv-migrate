#compdef pv-migrate
# Documentation: https://github.com/utkuozdemir/pv-migrate/blob/main/docs/cli-reference.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'migrate:migrate data between PVCs'
  'backup:back up a PVC to object storage'
  'restore:restore a PVC from object storage'
  'status:show status of a detached operation'
  'cleanup:remove Helm releases left by a detached operation'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--log-level=[log level]:level:(DEBUG INFO WARN ERROR)' \
  '--log-format=[log format]:format:(text json)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pv-migrate command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (migrate)
        _arguments -s -S \
          '(-n --source-namespace)'{-n+,--source-namespace=}'[source namespace]:namespace:' \
          '(-N --dest-namespace)'{-N+,--dest-namespace=}'[dest namespace]:namespace:' \
          '(-c --source-context)'{-c+,--source-context=}'[source kubeconfig context]:context:' \
          '(-C --dest-context)'{-C+,--dest-context=}'[dest kubeconfig context]:context:' \
          '(-k --source-kubeconfig)'{-k+,--source-kubeconfig=}'[source kubeconfig file]:file:_files' \
          '(-K --dest-kubeconfig)'{-K+,--dest-kubeconfig=}'[dest kubeconfig file]:file:_files' \
          '(-p --source-path)'{-p+,--source-path=}'[source filesystem path]:path:' \
          '(-P --dest-path)'{-P+,--dest-path=}'[dest filesystem path]:path:' \
          '(-R --source-mount-read-write)'{-R,--source-mount-read-write}'[mount source read-write]' \
          '(-H --dest-host-override)'{-H+,--dest-host-override=}'[override rsync dest host]:host:' \
          '(-d --dest-delete-extraneous-files)'{-d,--dest-delete-extraneous-files}'[delete extra files on dest]' \
          '(-o --no-chown)'{-o,--no-chown}'[omit chown during rsync]' \
          '--no-compress[disable rsync compression]' \
          '--rsync-extra-args=[extra rsync arguments]:args:' \
          '--rsync-push[push from source side]' \
          '(-a --ssh-key-algorithm)'{-a+,--ssh-key-algorithm=}'[SSH key algorithm]:alg:(rsa ed25519)' \
          '--ssh-reverse-tunnel-port=[reverse tunnel port]:port:' \
          '(-s --strategies)'{-s+,--strategies=}'[comma-separated strategies]:list:' \
          '--loadbalancer-timeout=[LB external IP timeout]:duration:' \
          '--detach[run migration in background]' \
          '--id=[custom operation id]:id:' \
          '(-i --ignore-mounted)'{-i,--ignore-mounted}'[do not fail if mounted]' \
          '(-x --no-cleanup)'{-x,--no-cleanup}'[skip cleanup]' \
          '--no-cleanup-on-failure[skip cleanup on failure]' \
          '(-b --show-progress-bar)'{-b,--show-progress-bar}'[show progress bar]' \
          '--non-root[run containers as non-root]' \
          '(-t --helm-timeout)'{-t+,--helm-timeout=}'[helm timeout]:duration:' \
          '(-f --helm-values)'{-f+,--helm-values=}'[helm values file]:file:_files' \
          '--helm-set=[helm key=value]:kv:' \
          '--helm-set-file=[helm key=filepath]:kf:' \
          '--helm-set-string=[helm string value]:kv:' \
          '1:source PVC:' \
          '2:dest PVC:' && ret=0 ;;
      (backup|restore)
        _arguments -s -S \
          '(-n --source-namespace)'{-n+,--source-namespace=}'[source namespace]:namespace:' \
          '(-N --dest-namespace)'{-N+,--dest-namespace=}'[dest namespace]:namespace:' \
          '*:arg:_default' && ret=0 ;;
      (status|cleanup)
        _arguments '1:operation id:' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
