#compdef dcmprscu
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmprscu.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmpstat/apps/dcmprscu.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmpstat/apps/dcmprscu.cc OFCommandLine setup + docs/man/dcmprscu.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '--noprint[do not create print-out (no n-action-rq)]' \
  '--session-print[send film session n-action-rq (instead of film box)]' \
  '--monochrome1[transmit basic grayscale images in MONOCHROME1]' \
  '(+p --print)'{+p,--print}'[printer mode, print file(s) and terminate (default)]' \
  '(+s --spool)'{+s+,--spool=}'[spooler mode, use job prefix n]:name:' \
  '(-c --config)'{-c+,--config=}'[process using settings from configuration file]:file:_files' \
  '(-p --printer)'{-p+,--printer=}'[printer name from cfg file (default: 1st printer)]:name:' \
  '(+d --dump)'{+d,--dump}'[dump all DIMSE messages]' \
  '--sleep[sleep d seconds between spooler checks (default: 1)]:delay:' \
  '--copies[set number of copies (1..100, default: 1)]:value:' \
  '--medium-type[set medium type]:value:' \
  '--destination[set film destination]:value:' \
  '--label[set film session label]:value:' \
  '--priority[set print priority]:value:' \
  '--owner[set film session owner ID]:value:' \
  '*:dcmfile-in:_files'
