#compdef imagejs
# Documentation: https://github.com/jklmnn/imagejs
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Zsh completion for imagejs - package JavaScript into a valid image file

_arguments -s -S \
  '-l[write image as a line of pixels (BMP only)]' \
  '-i+[embed code into existing image file]:file:_files -g "*.(gif|bmp|webp)"' \
  '1:format:(bmp gif webp pnm pgf)' \
  '2:javascript file:_files -g "*.js"'
