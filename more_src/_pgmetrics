#compdef pgmetrics

# Zsh completion for pgmetrics - PostgreSQL metrics collector

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-o+[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '--format=[output format]:format:(json human)' \
  '--no-color[disable color output]' \
  '--no-pager[disable pager]' \
  '--timeout=[connection timeout]:seconds' \
  '-H+[database host]:host' \
  '--host=[database host]:host' \
  '-p+[database port]:port' \
  '--port=[database port]:port' \
  '-U+[database user]:user' \
  '--username=[database user]:user' \
  '-d+[database name]:database' \
  '--dbname=[database name]:database' \
  '--no-password[never prompt for password]' \
  '--no-sizes[skip collection of table/index sizes]' \
  '--no-statements[skip pg_stat_statements]' \
  '--table=[collect for specific table]:table' \
  '--schema=[collect for specific schema]:schema' \
  '--exclude-schema=[exclude schema]:schema' \
  '--exclude-table=[exclude table]:table' \
  '--input=[read from input file]:file:_files -g "*.json"' \
  '*:connection string' && ret=0

return ret
