#compdef delayed_job
# Documentation: https://github.com/collectiveidea/delayed_job/wiki/Delayed-job-command-details
# database-based asynchronous priority queue worker control

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e --environment)'{-e+,--environment=}'[runtime environment]:env:(development production test)' \
  '(-n --number_of_workers)'{-n+,--number_of_workers=}'[spawn multiple concurrent workers]:count' \
  '(-i --identifier)'{-i+,--identifier=}'[numeric worker identifier]:id' \
  '(-m --monitor)'{-m,--monitor}'[activate monitor process]' \
  '--pid-dir=[custom directory for process IDs]:dir:_directories' \
  '--log-dir=[custom directory for log files]:dir:_directories' \
  '--queue=[target a specific job queue]:queue' \
  '--queues=[target specific job queues]:queues' \
  '--pool=[define worker pool (queue\:count)]:pool' \
  '--min-priority=[minimum job priority]:n' \
  '--max-priority=[maximum job priority]:n' \
  '--sleep-delay=[idle time between job checks]:n' \
  '--read-ahead=[number of queued jobs to evaluate]:n' \
  '(-p --prefix)'{-p+,--prefix=}'[prefix for worker process names]:name' \
  '--exit-on-complete[terminate when job queue exhausts]' \
  '--daemon-options[pass parameters to the daemon gem]' \
  '1:command:(start stop restart run status zap)' && ret=0

return ret
