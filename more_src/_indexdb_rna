#compdef indexdb_rna
# Documentation: https://github.com/sortmerna/sortmerna/blob/master/src/sortmerna/indexdb.cpp
# indexdb_rna - build the index for SortMeRNA reference databases

local ret=1

_arguments -s \
  '-h[help]' \
  '--ref[FASTA reference file,index file (mandatory)]:ref' \
  '--tmpdir[directory where to write temporary files]:dir:_files -/' \
  '-m[amount of memory in Mbytes for building the index (default 3072)]:mb' \
  '-L[seed length (default 18)]:int' \
  '--interval[index every INTth L-mer in the reference database (default 1)]:int' \
  '--max_pos[max positions stored per unique L-mer (default 10000, 0 for all)]:int' \
  '-v[verbose]' \
  '*:file:_files' && ret=0

return ret
