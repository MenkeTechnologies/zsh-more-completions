#compdef 66-scandir
# 66-scandir — manage the 66 scandir (Obarun/s6)

_arguments -s -S \
  '-h[show help]' \
  '-z[use color output]' \
  '-v[set verbosity level]:verbosity:(0 1 2 3 4)' \
  '-c[create the scandir]' \
  '-s[start the scandir]' \
  '-r[rescan the scandir]' \
  '-l[set live directory]:live directory:_files -/'
