#compdef helm-values-schema-json
# Documentation: https://github.com/losisin/helm-values-schema-json
# Generate values.schema.json from one or more Helm values files

local ret=1

_arguments -s -S \
  '*'{-f,--values}'=[input YAML files]:file:_files' \
  '(-o --output)'{-o,--output}'=[output file path]:file:_files' \
  '--draft=[draft version (4, 6, 7, 2019, or 2020)]:draft:(4 6 7 2019 2020)' \
  '--indent=[indentation spaces]:spaces' \
  '--config=[config file for setting defaults]:file:_files' \
  '--bundle[bundle referenced subschemas into a single file inside \$defs]' \
  '--bundle-root=[root directory for local referenced files]:dir:_files -/' \
  '--bundle-without-id[bundle without using \$id for improved compatibility]' \
  '--bundle-cache-min=[minimum cache duration for downloaded schemas]:duration' \
  '--no-additional-properties[default additionalProperties to false]' \
  '--no-default-global[disable automatic global property injection]' \
  '--use-helm-docs[read descriptions from helm-docs comments]' \
  '--k8s-schema-url=[URL template for \$ref k8s alias]:url' \
  '--k8s-schema-version=[version for the k8s-schema-url template]:version' \
  '--schema-root.id=[JSON schema ID]:id' \
  '--schema-root.title=[JSON schema title]:title' \
  '--schema-root.description=[JSON schema description]:desc' \
  '--schema-root.ref=[JSON schema URI reference]:ref' \
  '--schema-root.additional-properties[allow additional properties]' \
  '(-v --version)'{-v,--version}'[version information]' \
  '(-h --help)'{-h,--help}'[help for helm schema]' && ret=0

return ret
