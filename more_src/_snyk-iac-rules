#compdef snyk-iac-rules
# Documentation: https://github.com/snyk/snyk-iac-rules
# snyk-iac-rules - SDK to author and manage custom rules for Snyk IaC

local ret=1
local curcontext="$curcontext" state line

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(template test build push)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      template)
        _arguments -s -S \
          '(-r --rule)'{-r,--rule}'=[provide rule id]:id' \
          '(-f --format)'{-f,--format}'=[provide rule format]:format:(HCL2 JSON YAML TERRAFORM_PLAN)' \
          '(-t --title)'{-t,--title}'=[provide rule title]:title' \
          '(-s --severity)'{-s,--severity}'=[provide rule severity]:severity:(LOW MEDIUM HIGH)' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[set verbose logging mode]' \
          '--explain=[enable query explanations]:mode' \
          '--timeout=[set test timeout]:timeout' \
          '*--ignore=[file and directory names to ignore]:name' \
          '(-r --run)'{-r,--run}'=[run only test cases matching the regular expression]:regex' \
          '*:path:_files' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(-e --entrypoint)'{-e,--entrypoint}'=[set slash separated entrypoint path]:path' \
          '(-o --output)'{-o,--output}'=[set the output filename]:file:_files' \
          '*--ignore=[file and directory names to ignore]:name' \
          '(-t --target)'{-t,--target}'=[set the output bundle target type]:target' \
          '(-c --capabilities)'{-c,--capabilities}'=[set configurable set of OPA capabilities]:file:_files' && ret=0
        ;;
      push)
        _arguments -s -S \
          '(-r --registry)'{-r,--registry}'=[provide container registry]:registry' \
          '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
