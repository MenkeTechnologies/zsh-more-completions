#compdef avropipe
# Documentation: https://github.com/apache/avro/blob/main/lang/c/src/avropipe.c
# avropipe - print each Avro datum as a series of path/value lines (reads stdin if no file)

local ret=1

_arguments -s -S \
  '(-s --separator)'{-s,--separator=}'[path separator character for output (default /)]:separator' \
  ':Avro data file:_files' && ret=0

return ret
