#compdef spiderfoot-cli2 spiderfoot2 sfcli
# _spiderfoot-cli2 — Steve Micallef Intel471 spiderfoot-cli2 CLI command-line frontend wrapping the SpiderFoot open-source OSINT automation reconnaissance recon Internet-facing target intelligence-gathering tool 200-plus modules-from-Shodan-HaveIBeenPwned-VirusTotal-AlienVault-OTX-Cisco-Talos-Greynoise-Hunter-FullHunt-IntelX-Censys-VirusTotal-CIRCL-Spyse-AbuseIPDB-IPInfo-DroneBL-OpenPhish-PhishTank-Pulsedive-FireEye-Mandiant-Domaintools-WhoisXML-DNSDB-SecurityTrails (Steve Micallef Intel471 team, Python); custom argparse
# upstream: https://www.spiderfoot.net/

_spiderfoot-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-l+[listen host:port]:_hosts' \
        '--listen=+[host:port]:_hosts' \
        '-s+[scan target]:str:' \
        '--scan=+[target]:str:' \
        '-t+[event types]:str:' \
        '--types=+[event types]:str:' \
        '-m+[modules]:str:' \
        '--modules=+[mods]:str:' \
        '-u+[use case]:u:(all footprint investigate passive)' \
        '--usecase=+[u]:u:(all footprint investigate passive)' \
        '-S+[max output length]:n:' \
        '--strict=+[N]:n:' \
        '-T+[type list]:str:' \
        '--type-list[list event types]' \
        '-M[list modules]' \
        '--list-modules[list modules]' \
        '-C+[list correlations]:str:' \
        '--correlate[run correlations]' \
        '-L+[list scans]:str:' \
        '--list-scans[list scans]' \
        '-n+[scan name]:str:' \
        '--name=+[name]:str:' \
        '-x+[xml output]:file:_files -g "*.xml"' \
        '-o+[output format]:f:(tab csv json xml)' \
        '--format=+[fmt]:f:(tab csv json xml)' \
        '-H[no header]' \
        '--no-header[no header]' \
        '-r[show source]' \
        '--show-source[show source data]' \
        '*:args:'
}

_spiderfoot-cli2 "$@"
