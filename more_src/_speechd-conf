#compdef speechd-conf
# Configuration utility for Speech Dispatcher

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--create-user-conf[create user configuration]' \
  '--config-dir[configuration directory]:dir:_files -/' \
  '--dont-ask[non-interactive mode]' \
  && return 0
