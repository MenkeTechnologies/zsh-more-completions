#compdef consul_exporter
# Documentation: https://github.com/prometheus/consul_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--consul.server=[address of the Consul server]:address:' \
  '--consul.ca-file=[CA certificate file for Consul]:file:_files' \
  '--consul.cert-file=[client certificate file for Consul]:file:_files' \
  '--consul.key-file=[client private key file for Consul]:file:_files' \
  '--consul.server-name=[server name for SNI in TLS handshake]:name:' \
  '--consul.timeout=[timeout for Consul requests]:duration:' \
  '--consul.insecure[disable TLS certificate verification]' \
  '--consul.require-consistent[require consistent Consul results]' \
  '--consul.allow-stale[allow stale Consul results]' \
  '--consul.health-summary[generate health summary for each service]' \
  '--consul.request-limit=[limit on concurrent requests to Consul]:limit:' \
  '--kv.prefix=[prefix under which to look for KV pairs]:prefix:' \
  '--kv.filter=[regex to filter KV keys]:regexp:' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:address:' \
  '--web.telemetry-path=[path under which to expose metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' && ret=0

return ret
