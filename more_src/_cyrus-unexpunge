#compdef cyrus-unexpunge
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/unexpunge.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org unexpunge(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-unexpunge: restore expunged Cyrus messages
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '(-l --list)'{-l,--list}'[list expunged messages eligible for restore]' \
  '(-t --within-time-interval)'{-t+,--within-time-interval=}'[restore within last interval (m/h/d/w)]:interval:' \
  '(-a --all)'{-a,--all}'[restore all expunged messages]' \
  '(-u --uids)'{-u+,--uids=}'[restore by space-separated UID list]:uids:' \
  '(-d --unset-deleted)'{-d,--unset-deleted}'[unset \\Deleted flag on restored messages]' \
  '(-f --set-flag)'{-f+,--set-flag=}'[set user flag on restored messages]:flag:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:mailbox:' && ret=0
return ret
