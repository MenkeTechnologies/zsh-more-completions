#compdef unrealircd
# Documentation: https://github.com/unrealircd/unrealircd (unrealircd.in control script)
# Reference accessed: 2026-05-21
# Verified: upstream unrealircd.in case branches.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start unrealircd'
  'stop:stop unrealircd'
  'restart:restart unrealircd'
  'rehash:rehash configuration'
  'status:show status'
  'module-status:list active modules'
  'reloadtls:refresh SSL/TLS certificates'
  'configtest:test configuration'
  'croncheck:automated startup check for cron jobs'
  'module:install or manage third-party modules'
  'mkpasswd:hash password'
  'version:show UnrealIRCd version'
  'gencloak:generate cloak keys'
  'backtrace:analyze core dump files'
  'spki:display SPKI fingerprints'
  'spkifp:display SPKI fingerprints'
  'hot-patch:apply patches without full restart'
  'cold-patch:apply patches requiring restart'
  'upgrade:upgrade unrealircd'
  'genlinkblock:generate server link block'
  'coffee:easter egg'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'unrealircd command' commands && ret=0 ;;
esac

return ret
