#compdef unrealircd

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start unrealircd'
  'stop:stop unrealircd'
  'restart:restart unrealircd'
  'reload:reload configuration'
  'rehash:rehash configuration'
  'status:show status'
  'configtest:test configuration'
  'mkpasswd:hash password'
  'gencloak:generate cloak keys'
  'backtrace:print backtrace'
  'upgrade:upgrade unrealircd'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-f+[config file]:file:_files' \
  '-F[fork to background]' \
  '-N[do not fork]' \
  '-x+[debug level]:lvl:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'unrealircd command' commands && ret=0 ;;
esac

return ret
