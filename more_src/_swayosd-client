#compdef swayosd-client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--output-volume[change output volume]:action:(raise lower mute-toggle)' \
  '--input-volume[change input volume]:action:(raise lower mute-toggle)' \
  '--brightness[change brightness]:action:(raise lower)' \
  '--caps-lock[toggle caps lock indicator]' \
  '--num-lock[toggle num lock indicator]' \
  '--scroll-lock[toggle scroll lock indicator]' \
  '--caps-lock-led[set caps lock LED]:device:' \
  '--num-lock-led[set num lock LED]:device:' \
  '--scroll-lock-led[set scroll lock LED]:device:' \
  '--max-volume[set max volume percentage]:percent:' \
  '--device[audio device name]:device:' && ret=0

return ret
