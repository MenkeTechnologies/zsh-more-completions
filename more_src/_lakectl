#compdef lakectl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'actions:manage and explore hook execution runs'
  'annotate:list entries with latest modifying commit information'
  'auth:manage authentication, authorization, users, groups, and policies'
  'branch:create, delete, and manage repository branches'
  'branch-protect:define branch protection rules'
  'cherry-pick:apply changes from an existing commit to a branch'
  'commit:save changes on a given branch'
  'completion:generate shell completion scripts'
  'config:create or update local lakeFS configuration'
  'diff:display changes between commits or uncommitted modifications'
  'doctor:run basic diagnostics on lakeFS configuration'
  'fs:view and manipulate objects in storage'
  'gc:manage garbage collection policies'
  'identity:display configured user information'
  'import:load data from external sources into a branch'
  'local:synchronize local directories with lakeFS paths'
  'log:show commit history for a reference'
  'login:authenticate using a web browser'
  'merge:combine changes from source into destination branch'
  'plugin:manage lakectl plugins'
  'repo:create, delete, and explore repositories'
  'show:display detailed entity information'
  'tag:create and manage repository tags'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--base-uri=[base URI for lakeFS address parsing]:uri:' \
  '(-c --config)'{-c,--config=}'[configuration file]:file:_files' \
  '--log-format=[logging output format]:format:(text json)' \
  '--log-level=[logging verbosity]:level:(trace debug info warn error fatal)' \
  '--log-output=[logging destinations]:dest:' \
  '--no-color[disable colored output]' \
  '--verbose[enable verbose mode]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'lakectl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (repo)
        _values 'repo action' \
          'create' 'list' 'delete' 'create-bare' && ret=0
        ;;
      (branch)
        _values 'branch action' \
          'create' 'delete' 'list' 'show' 'reset' 'revert' && ret=0
        ;;
      (branch-protect)
        _values 'branch-protect action' \
          'list' 'add' 'delete' && ret=0
        ;;
      (tag)
        _values 'tag action' \
          'create' 'delete' 'list' 'show' && ret=0
        ;;
      (auth)
        _values 'auth resource' \
          'users' 'groups' 'policies' && ret=0
        ;;
      (fs)
        _values 'fs action' \
          'cat' 'ls' 'stat' 'upload' 'download' 'rm' 'presign' && ret=0
        ;;
      (local)
        _values 'local action' \
          'init' 'clone' 'pull' 'commit' 'status' 'list' 'checkout' && ret=0
        ;;
      (gc)
        _values 'gc action' \
          'set-config' 'get-config' && ret=0
        ;;
      (actions)
        _values 'actions action' \
          'runs' 'tasks' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
      (plugin)
        _values 'plugin action' \
          'list' 'install' 'remove' && ret=0
        ;;
    esac
    ;;
esac

return ret
