# THE cppfront CLI — custom cmdline_processor flags
#
# cppfront's CLI is in source/cppfront.cpp + source/to_cpp1.h.
# Uses Herb Sutter's custom cmdline_processor::register_flag
# system (a minimal argv parser written in Cpp2-translated
# code).  All flags use `-` (single-dash) prefix in
# UNIX-style; can be abbreviated as long as unambiguous.
#
# Flags (sourced from register_flag calls in cppfront.cpp +
# to_cpp1.h):
#
#   -debug                       emit compiler debug output
#   -quiet                       print only error output
#   -help, -h                    show help
#   -version                     show version
#
# Output flags:
#   -output FILE                 output to FILE (or 'stdout');
#                                default is *.cpp (or *.h)
#   -cwd PATH                    change working directory to
#                                PATH before processing
#   -clean-cpp1                  emit clean Cpp1 without #line
#                                directives
#   -line-paths                  emit absolute paths in #line
#                                directives
#   -emit-cppfront-info          emit cppfront version/build
#                                in Cpp1 output
#
# stdlib integration:
#   -import-std                  use 'import std;' (C++23)
#                                instead of #include
#   -include-std                 #include all std:: headers
#                                (older compilers)
#   -pure-cpp2                   Cpp2 syntax only (no legacy
#                                Cpp1 in same file) - also
#                                sets -import-std
#
# Safety check disabling (all checks enabled by default):
#   -no-null-checks              disable null-pointer-deref
#                                safety checks
#   -no-div-zero-checks          disable integer division-by-
#                                zero safety checks
#   -no-subscript-checks         disable subscript-out-of-
#                                range safety checks
#   -no-comparison-checks        disable mixed-sign comparison
#                                safety checks
#
# C++ feature toggles:
#   -fno-exceptions              disable C++ exceptions
#                                (failed 'as' for variant will
#                                assert instead)
#   -fno-rtti                    disable C++ RTTI (using 'as'
#                                for '*'/'std::any' will assert)
#
# Positional arguments:
#   FILE [FILE...]               .cpp2 input source files
#                                (use 'stdin' for stdin)
#
# Output file behavior:
#   Default output name: derived from input filename:
#     input.cpp2 → input.cpp (or input.h if header)
#   With -output stdout: emit Cpp1 to stdout
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/hsutter/cppfront/blob/main/source/cppfront.cpp
# https://github.com/hsutter/cppfront/blob/main/source/to_cpp1.h
# cmdline_processor::register_flag invocations.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-debug[emit compiler debug output]' \
    '-quiet[print only error output]' \
    '(- *)'{-h,-help}'[show help]' \
    '-version[show version]' \
    '-output+[output to FILE (or stdout)]:file:_files' \
    '-cwd+[change working directory to PATH]:path:_files -/' \
    '-clean-cpp1[emit clean Cpp1 without #line directives]' \
    '-line-paths[emit absolute paths in #line directives]' \
    '-emit-cppfront-info[emit cppfront version/build in Cpp1]' \
    '-import-std[use import std; (C++23) instead of #include]' \
    '-include-std[#include all std:: headers]' \
    '-pure-cpp2[Cpp2 syntax only (no legacy Cpp1)]' \
    '-no-null-checks[disable null-pointer-deref safety checks]' \
    '-no-div-zero-checks[disable integer division-by-zero safety checks]' \
    '-no-subscript-checks[disable subscript-out-of-range safety checks]' \
    '-no-comparison-checks[disable mixed-sign comparison safety checks]' \
    '-fno-exceptions[disable C++ exceptions]' \
    '-fno-rtti[disable C++ RTTI]' \
    '*:Cpp2 source file:_files -g "*.(cpp2|h2)"' \
    && ret=0

return ret
