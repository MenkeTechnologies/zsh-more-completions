#compdef arrow-cli arrow
# _arrow-cli — Apache Arrow arrow-cli CLI command-line frontend wrapping the Apache Arrow columnar memory format and IPC providing schema info dump-record-batch json-roundtrip ipc-file-to-stream stream-to-file integration-tests files-to-batch parquet conversion to columnar Arrow format for analytics zero-copy across languages (Apache Arrow team, C++/Rust); custom argparse
# upstream: https://arrow.apache.org/

_arrow-cli() {
    local -a sub=(
        'schema:show Arrow schema'
        'info:show file info'
        'dump:dump record batches'
        'json-roundtrip:run JSON roundtrip integration test'
        'ipc-file-to-stream:convert IPC file to stream'
        'stream-to-file:convert IPC stream to file'
        'files-to-batch:concatenate files into batches'
        'parquet:Parquet conversion'
        'to-parquet:convert Arrow to Parquet'
        'from-parquet:convert Parquet to Arrow'
        'integration:run integration tests'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--compression=+[c]:c:(uncompressed lz4 zstd snappy)' \
        '--columns=+[list]:str:' \
        '--limit=+[N]:n:' \
        '--memory-pool=+[m]:m:(default system jemalloc mimalloc)' \
        '-o+[output file]:file:_files -g "*.arrow *.feather *.parquet *.csv"' \
        '--output=+[file]:file:_files -g "*.arrow *.feather *.parquet *.csv"' \
        '-f+[format]:f:(arrow json csv parquet feather)' \
        '--format=+[format]:f:(arrow json csv parquet feather)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'arrow-cli subcommand' sub ;;
        args)
            _arguments '*:file:_files -g "*.arrow *.feather *.parquet *.csv *.json"'
            ;;
    esac
}

_arrow-cli "$@"
