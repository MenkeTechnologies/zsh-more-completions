#compdef zpool-resilver
# _zpool-resilver — OpenZFS zpool resilver (restart a resilver to scan all live data with the latest state; useful after device replacement to repair sectors that were not touched by writes during the original resilver; positional argument is the pool)
# upstream: https://github.com/openzfs/zfs
# Argument shape from openzfs cmd/zpool/zpool_main.c (zpool_do_resilver) on tip.

_zpool-resilver() {
    _arguments \
        '*:pool:'
}

_zpool-resilver "$@"
