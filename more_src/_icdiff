#compdef icdiff
# Documentation: https://github.com/jeffkaufman/icdiff
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# icdiff: side-by-side colored diff tool.

_arguments \
  '(-)--help[display help information]' \
  '(-)--version[display version information]' \
  '--cols=[set screen width (auto-detect on Unix)]:cols' \
  '--encoding=[input file character encoding]:encoding' \
  '--color-map=[customize color mapping]:color mapping' \
  '(-E --exclude-lines)'{-E,--exclude-lines=}'[skip lines matching regex]:pattern' \
  '--head=[compare only first N lines]:N' \
  '(-H --highlight)'{-H,--highlight}'[background color for changes]' \
  '(-L --label)'{-L,--label=}'[replace filename with label (use twice)]:label' \
  '(-N --line-numbers)'{-N,--line-numbers}'[include line numbers]' \
  '--no-bold[disable bold colors]' \
  '--no-headers[omit file name labels]' \
  '(-o --output-encoding)'{-o,--output-encoding=}'[set output encoding]:encoding' \
  '(-r --recursive)'{-r,--recursive}'[recursively compare directories]' \
  '(-s --report-identical-files)'{-s,--report-identical-files}'[note when files match]' \
  '--show-all-spaces[highlight non-matching whitespace]' \
  '--strip-trailing-cr[remove trailing carriage returns]' \
  '(-t --truncate)'{-t,--truncate}'[cut long lines rather than wrap]' \
  '--tabsize=[define tab spacing]:tabsize' \
  '(-U --unified)'{-U,--unified=}'[number of context lines]:lines' \
  '(-W --whole-file)'{-W,--whole-file}'[show entire file instead of changes]' \
  '--is-git-diff[input is from git diff]' \
  '-u[short for unified output]' \
  '*:file:_files'
