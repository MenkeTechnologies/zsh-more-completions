#compdef kamel

# https://github.com/apache/camel-k — v2.10.x cobra; persistent flags from pkg/cmd/root.go

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'bind:bind Knative eventing'
  'debug:debug an integration'
  'delete:delete integrations'
  'deploy:deploy an integration'
  'dump:dump integration CRs'
  'get:fetch integrations'
  'kit:manage integration kits'
  'log:fetch integration logs'
  'operator:install/upgrade Camel K operator'
  'promote:promote integrations'
  'rebuild:rebuild integration images'
  'reset:reset CRs / state'
  'run:run integration from source'
  'undeploy:undeploy integrations'
)

_arguments -s -S \
  '--kube-config=[kubeconfig path]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:()' \
  '(-V --verbose)'{-V,--verbose}'[verbose client logs]' \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[client version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'kamel command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
