#compdef mgt
# Documentation: https://github.com/model-graph-tools/tooling
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mgt: WildFly management model graph CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'analyze:analyze WildFly instance or feature pack'
      'push:upload model database image to remote registry'
      'start:start a model container'
      'stop:stop a model container'
      'browse:open Neo4J browser for container'
      'images:list available model images'
      'versions:list supported WildFly versions'
      'feature-packs:list supported feature packs'
      'resolve:convert identifier string to canonical form'
      'ps:show running containers'
      'completions:generate shell completion scripts'
      'update:refresh WildFly and feature pack configuration'
      'help:show help for subcommand'
    )
    _describe -t commands 'mgt commands' commands && ret=0
    ;;
  args)
    case "$line[1]" in
      completions)
        _values 'shell' bash zsh fish powershell elvish && ret=0
        ;;
    esac
    ;;
esac

return ret
