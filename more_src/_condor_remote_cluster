#compdef condor_remote_cluster
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_remote_cluster.html
# manage remote clusters for use with the bosco overlay

local ret=1

_arguments -s -S \
  '-help[print usage information and exit]' \
  '-list[list all installed clusters]' \
  '-remove[remove an already installed cluster]:host:_hosts' \
  '-add[install and add a cluster]:host:_hosts:scheduler:(pbs lsf condor sge slurm)' \
  '-status[query and print the status of an installed cluster]:host:_hosts' \
  '-test[attempt to submit a test job to an installed cluster]:host:_hosts' && ret=0

return ret
