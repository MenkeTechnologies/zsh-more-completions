#compdef mcp-server-gdrive
# Documentation: https://github.com/modelcontextprotocol/servers-archived/tree/main/src/gdrive
# Reference accessed: 2026-05-27
# Verified: upstream src/gdrive/index.ts (process.argv[2] === "auth" triggers OAuth flow; otherwise runs server)

# Zsh completion for mcp-server-gdrive - archived MCP server for Google Drive
# Single optional positional: "auth" subcommand to run the OAuth credential save flow.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:subcommand:((auth\:"run OAuth flow and save credentials"))' && ret=0

return ret
