#compdef reviewdog

# Zsh completion for reviewdog - automated code review tool

_arguments -s -S \
  '-conf=[configuration file]:file:_files' \
  '-name=[tool name]:name:' \
  '-f=[format name]:format:(checkstyle rdjson rdjsonl diff sarif golint govet eslint stylelint clippy dot rustfmt black mypy flake8 cppcheck cpplint gofmt goimports gosec rustsec hadolint scalafmt scalastyle shellcheck staticcheck yamllint)' \
  '-f.diff.strip=[diff strip number]:number:' \
  '-diff=[diff command]:command:' \
  '-runners=[which runners to run]:runners:' \
  '-reporter=[reporter type]:reporter:(local github-pr-check github-pr-review github-check gitlab-mr-discussion gitlab-mr-commit gerrit-change-review bitbucket-code-report)' \
  '-level=[report level]:level:(info warning error)' \
  '-fail-on-error[exit with non-zero status on any reported issue]' \
  '-filter-mode=[filter mode]:mode:(added diff_context file nofilter)' \
  '-tee[append stdin to output]' \
  '-list[list known formats]' \
  '-log-level=[log level]:level:(debug info warn error)' \
  '-efm=[errorformat line]:efm:' \
  '-version[show version]' \
  '-h[show help]'
