#compdef reviewdog
# Documentation: https://github.com/reviewdog/reviewdog
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for reviewdog - automated code review tool.

_arguments -s -S \
  '-conf=[configuration file]:file:_files' \
  '-name=[tool name in review comments]:name:' \
  '-f=[format name (run -list)]:format:' \
  '-f.diff.strip=[strip components from diff filenames]:n:' \
  '-diff=[diff command for local reporters]:command:' \
  '-strip=[strip leading path components from diff]:n:' \
  '-runners=[comma-separated runners to execute]:runners:' \
  '-reporter=[output reporter]:reporter:(local github-pr-check github-pr-review github-check gitlab-mr-discussion gitlab-mr-commit gerrit-change-review bitbucket-code-report)' \
  '-level=[default report level]:level:(info warning error)' \
  '-fail-on-error[(deprecated) use -fail-level]' \
  '-fail-level=[exit non-zero at given level]:level:(any info warning error)' \
  '-filter-mode=[filter mode]:mode:(added diff_context file nofilter)' \
  '-guess[guess pull request ID by branch/commit]' \
  '-tee[output tool results while reporting]' \
  '-list[list known formats]' \
  '-log-level=[log level]:level:(debug info warning error)' \
  '*-efm=[errorformat line]:efm:' \
  '-version[show version]' \
  '-h[show help]'
