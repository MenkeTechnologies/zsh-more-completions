_polygram() {
    case "${service:-${words[1]}}" in
        polygram-doctor)
            _arguments -s \
                '(- *)'{-h,--help}'[show help]' \
                '--bot=[bot name to inspect (required)]:bot:' \
                '--roundtrip[do an outbound round-trip probe (requires --to)]' \
                '--to=[target chat ID for the round-trip probe]:chat-id:' \
                '--json[emit JSON output for monitoring pipelines]' \
                '--strict[treat warnings as failures]' ;;
        polygram-ipc)
            _arguments -s \
                '1:bot name:' ;;
        polygram-split-db)
            _arguments -s \
                '--config=[config JSON file (required)]:path:_files -g "*.json"' \
                '--src=[source bridge.db path (default bridge.db)]:path:_files -g "*.db"' \
                '--dry-run[print migration plan without performing it]' ;;
        polygram|*)
            _arguments -s \
                '(- *)'{-h,--help}'[show help]' \
                '--bot=[bot name (required; must exist in config.bots)]:bot:' \
                '--db=[SQLite database path override (default <bot>.db)]:path:_files -g "*.db"' ;;
    esac
}

_polygram "$@"
