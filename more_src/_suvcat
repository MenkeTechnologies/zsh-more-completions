#compdef suvcat
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/operations/suvcat.c
# SUVCAT - append one data set to another, with or without overlap

local ret=1

_arguments -s -S \
  'taplen=[length of overlap (integer samples)]:t:' \
  'taptype=[type of taper or combination method]:t:(0 1 2 3)' \
  '*:SU file:_files' && ret=0

return ret
