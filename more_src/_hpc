#compdef hpc hpc-ghc-9.14.1
# Documentation: https://downloads.haskell.org/ghc/latest/docs/users_guide/profiling.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above (GHC Haskell Program Coverage).

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:show help for hpc or a specific command'
  'report:output a textual report'
  'markup:output an HTML coverage report'
  'sum:add together one or more .tix files'
  'combine:combine two .tix files in a binary op'
  'map:map a function over a single .tix'
  'show:show what is in a .tix file'
  'overlay:create a .tix file from an overlay file'
  'draft:draft an overlay file'
  'version:display version'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'hpc command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (report|markup|sum|combine|map|show)
        _files -g "*.tix" && ret=0
        ;;
    esac
    ;;
esac

return ret
