#compdef bingo
# Documentation: https://github.com/bwplotka/bingo
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bwplotka/bingo — like `go get` but for Go tools (versioned binaries)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-m --moddir)'{-m,--moddir}'=[separate module dir per binary]:dir:_files -/' \
  '-l[create symlink to tool binary]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'get:add development tools to current project'
      'list:list pinned binaries in this project'
      'version:show bingo version'
      'completion:generate shell autocompletion script'
    )
    _describe -t commands 'bingo command' commands && ret=0
    ;;
  args)
    case $words[1] in
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      get)
        _arguments '*:tool package or binary:' && ret=0
        ;;
    esac
    ;;
esac

return ret
