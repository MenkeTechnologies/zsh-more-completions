#compdef hexer

# hexer: vi-like binary editor
# Documentation: https://devel.ringlet.net/editors/hexer/
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-R[read-only]' \
  '-c[execute initial command]:cmd:' \
  '-C[colorize output]' \
  '-r[recover swap file]:file:_files' \
  '-t[terminal type]:term:' \
  '*:file:_files' && ret=0
return ret
