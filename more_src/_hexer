#compdef hexer
# Documentation: https://manpages.ubuntu.com/manpages/bionic/en/man1/hexer.1.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-R[read-only mode]' \
  '-v[view mode]' \
  '-r[recover file after crash]:file:_files' \
  '-c[execute editor command]:cmd:' \
  '-t[disable termcap ti/te sequences]' \
  '*:file:_files' && ret=0
return ret
