#compdef ansible-rulebook

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-r --rulebook)'{-r,--rulebook=}'[rulebook file]:file:_files -g "*.(yml|yaml)"' \
  '(-e --vars)'{-e,--vars=}'[vars file]:file:_files -g "*.(yml|yaml|json)"' \
  '(-E --env-vars)'{-E,--env-vars=}'[environment variables]:vars:' \
  '*'{-v,--verbose}'[verbose (repeat for more)]' \
  '(-S --source-dir)'{-S,--source-dir=}'[event source plugin directory]:dir:_files -/' \
  '(-F --filter-dir)'{-F,--filter-dir=}'[event filter directory]:dir:_files -/' \
  '(-i --inventory)'{-i,--inventory=}'[inventory file]:file:_files' \
  '(-W --websocket-url --websocket-address)'{-W,--websocket-url=,--websocket-address=}'[WebSocket URL]:url:' \
  '--websocket-ssl-verify=[WebSocket SSL verify]:flag:(yes no true false)' \
  '--websocket-access-token=[WebSocket access token]:token:' \
  '--websocket-refresh-token=[WebSocket refresh token]:token:' \
  '--websocket-token-url=[WebSocket token URL]:url:' \
  '--id=[run id]:id:' \
  '(-w --worker)'{-w,--worker}'[worker mode]' \
  '(-T --project-tarball)'{-T,--project-tarball=}'[project tarball]:file:_files' \
  '--controller-url=[Controller URL]:url:' \
  '--controller-token=[Controller token]:token:' \
  '--controller-username=[Controller username]:user:_users' \
  '--controller-password=[Controller password]:password:' \
  '--controller-ssl-verify=[Controller SSL verify]:flag:(yes no true false)' \
  '--print-events[print events]' \
  '--shutdown-delay=[shutdown delay seconds]:secs:' \
  '--gc-after=[GC after N events]:n:' \
  '--heartbeat=[heartbeat seconds]:secs:' \
  '--execution-strategy=[execution strategy]:strategy:(sequential parallel)' \
  '--hot-reload[hot reload rulebooks]' \
  '--skip-audit-events[skip audit events]' \
  '--vault-password-file=[vault password file]:file:_files' \
  '--vault-id=[vault id]:id:' \
  '--ask-vault-pass[prompt for vault password]' \
  '--persistence-id=[persistence id]:id:'
