#compdef gcov-15

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-a,--all-blocks}'[show information for every basic block]' \
  {-b,--branch-probabilities}'[include branch probabilities]' \
  {-c,--branch-counts}'[output branch counts as numbers]' \
  {-g,--conditions}'[include modified condition/decision coverage]' \
  {-d,--display-progress}'[display progress]' \
  {-f,--function-summaries}'[output summaries for each function]' \
  {-i,--json-format}'[output JSON intermediate format]' \
  {-j,--human-readable}'[human readable numbers]' \
  {-k,--use-colors}'[colorize output]' \
  {-l,--long-file-names}'[use long output file names]' \
  {-m,--demangled-names}'[output demangled function names]' \
  {-n,--no-output}'[do not create output files]' \
  '*'{-o+,--object-directory=}'[search for objects in dir]:dir:_files -/' \
  {-p,--preserve-paths}'[preserve all path components]' \
  {-q,--use-hotness-colors}'[use hotness colors]' \
  {-r,--relative-only}'[only show data for files in current dir]' \
  {-s+,--source-prefix=}'[strip source prefix]:prefix:' \
  {-t,--stdout}'[print to stdout]' \
  {-u,--unconditional-branches}'[show unconditional branches]' \
  {-w,--verbose}'[verbose mode]' \
  {-x,--hash-filenames}'[hash long pathnames]' \
  '*:source or object file:_files' && ret=0

return ret
