#compdef gitmoji

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'commit:interactively commit with an emoji'
      'config:configure gitmoji preferences'
      'hook:manage git hooks'
      'init:initialize gitmoji as a commit hook'
      'list:list all available gitmojis'
      'remove:remove the gitmoji commit hook'
      'search:search gitmojis by keyword'
      'update:sync gitmoji list with the repo'
    )
    _describe -t commands 'gitmoji command' commands && ret=0
    ;;
  args)
    case $line[1] in
      commit)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:search keyword' && ret=0
        ;;
    esac
    ;;
esac

return ret
