#compdef git-quick-stats

# Zsh completion for git-quick-stats (git statistics tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'detailedGitStats:detailed git stats'
  'changelogs:changelogs'
  'changelogsSince:changelogs since a date'
  'myDailyStats:my daily status'
  'branchTree:show branch tree'
  'contributors:list contributors'
  'commitsByAuthor:commits per author'
  'commitsByDay:commits per day'
  'commitsByDayOfWeek:commits per day of week'
  'commitsByHour:commits by hour'
  'commitsByMonth:commits by month'
  'commitsByWeekday:commits by weekday'
  'commitsByYear:commits by year'
  'commitsPerDay:commits per day of year'
  'csvCommitsPerAuthor:CSV of commits per author'
)

_arguments -s -S \
  '(-s --suggest)'{-s,--suggest}'[suggest commands]' \
  '1:command:->command' && ret=0

case $state in
  (command)
    _describe -t commands 'git-quick-stats command' commands && ret=0
    ;;
esac

return ret
