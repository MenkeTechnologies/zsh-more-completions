#compdef cwl-inputs-schema-gen
# Documentation: https://github.com/common-workflow-language/cwl-utils
# Generate a JSON schema for the input parameters of a CWL document

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'=[output file (default stdout)]:file:_files' \
  '*:CWL URL or path:_files -g "*.cwl"' && ret=0

return ret
