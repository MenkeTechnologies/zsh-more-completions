#compdef supervisorctl

# Zsh completion for supervisorctl - supervisor control interface

local curcontext="$curcontext" state line ret=1

# Dynamic completion for process names
_supervisorctl_processes() {
  local -a processes
  processes=(${(f)"$(supervisorctl status 2>/dev/null | awk '{print $1}')"})
  _describe -t processes 'process' processes
}

# Dynamic completion for process groups
_supervisorctl_groups() {
  local -a groups
  groups=(${(f)"$(supervisorctl status 2>/dev/null | awk -F: '{print $1}' | sort -u)"})
  _describe -t groups 'group' groups
}

local -a commands=(
  'add:activate a process/group config'
  'avail:display available process configurations'
  'clear:clear process log files'
  'exit:exit the supervisor shell'
  'fg:connect to process in foreground'
  'help:show help'
  'maintail:tail supervisor main log'
  'open:connect to remote supervisord'
  'pid:get PID of supervisord or process'
  'quit:exit the supervisor shell'
  'reload:restart the remote supervisord'
  'remove:remove a process/group from active config'
  'reread:reload configuration files'
  'restart:restart processes'
  'shutdown:shut the remote supervisord down'
  'signal:send signal to process'
  'start:start processes'
  'status:get process status info'
  'stop:stop processes'
  'tail:tail process log'
  'update:reload config and add/remove as needed'
  'version:show supervisord version'
)

_arguments -s -S \
  '(-c --configuration)'{-c+,--configuration=}'[config file path]:config file:_files' \
  '(-s --serverurl)'{-s+,--serverurl=}'[URL to use for server]:url:' \
  '(-u --username)'{-u+,--username=}'[username for authentication]:username:' \
  '(-p --password)'{-p+,--password=}'[password for authentication]:password:' \
  '(-r --history-file)'{-r+,--history-file=}'[readline history file]:file:_files' \
  '(-i --interactive)'{-i,--interactive}'[start interactive shell]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'supervisorctl command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      start|stop|restart|status|clear|pid|signal)
        _arguments '*:process:_supervisorctl_processes' && ret=0
        ;;
      add|remove)
        _arguments '*:group:_supervisorctl_groups' && ret=0
        ;;
      tail|fg)
        _arguments '1:process:_supervisorctl_processes' && ret=0
        ;;
      open)
        _arguments '1:url:' && ret=0
        ;;
    esac
    ;;
esac

return ret
