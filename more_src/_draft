#compdef draft

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'create:create a new Dockerfile and deployment files'
      'setup-gh:set up GitHub OIDC'
      'generate-workflow:generate GitHub Actions workflow'
      'update:update Draft to the latest version'
      'info:show supported languages and deployment types'
      'validate:validate Draft configuration'
      'completion:generate shell completion'
      'version:show version'
    )
    _describe -t commands 'draft command' commands && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-l+[programming language]:language:(clojure csharp erlang go gomodule gradle java javascript python ruby rust swift)' \
          '--language=[programming language]:language:(clojure csharp erlang go gomodule gradle java javascript python ruby rust swift)' \
          '-d+[deployment type]:deployment:(helm kustomize manifests)' \
          '--deploy-type=[deployment type]:deployment:(helm kustomize manifests)' \
          '-a+[application name]:name:' \
          '--app=[application name]:name:' \
          '-p+[port number]:port:' \
          '--port=[port number]:port:' \
          '--dockerfile-only[generate Dockerfile only]' \
          '--deployment-only[generate deployment files only]' \
          '--skip-file-detection[skip language detection]' \
          '1:destination directory:_directories' && ret=0
        ;;
      setup-gh)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--provider=[cloud provider]:provider:(azure)' \
          '--subscription-id=[Azure subscription ID]:subscription:' \
          '--resource-group=[resource group]:group:' \
          '--gh-repo=[GitHub repository]:repo:' \
          '--app=[application name]:name:' && ret=0
        ;;
      generate-workflow)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-d+[deployment type]:type:(helm kustomize manifests)' \
          '--deploy-type=[deployment type]:type:(helm kustomize manifests)' \
          '--cluster-name=[cluster name]:name:' \
          '--registry-name=[registry name]:name:' \
          '--container-name=[container name]:name:' \
          '--resource-group=[resource group]:group:' \
          '--branch=[git branch]:branch:' \
          '1:destination directory:_directories' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
