#compdef augent
# Source: cargo binstall augent@0.6.6
# Probed via: completions zsh
# Repository: https://github.com/asyrjasalo/augent

autoload -U is-at-least

_augent() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-w+[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--workspace=[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_augent_commands" \
"*::: :->augent" \
&& ret=0
    case $state in
    (augent)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:augent-command-$line[1]:"
        case $line[1] in
            (install)
_arguments "${_arguments_options[@]}" : \
'*-t+[Install only for specific platforms (e.g., --to cursor opencode)]:PLATFORM:_default' \
'*--to=[Install only for specific platforms (e.g., --to cursor opencode)]:PLATFORM:_default' \
'-w+[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--workspace=[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--frozen[Fail if lockfile would change]' \
'--all-bundles[Select all discovered bundles without interactive menu]' \
'--update[Update bundles to latest versions from refs (resolves new SHAs and updates lockfile)]' \
'--dry-run[Show what would be installed without actually installing]' \
'-y[Skip confirmation prompt when uninstalling deselected bundles]' \
'--yes[Skip confirmation prompt when uninstalling deselected bundles]' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'-h[Print help]' \
'--help[Print help]' \
'::source -- Bundle source (path, URL, or github\:author/repo). If not provided, reads from augent.yaml Supports\: @author/repo, github\:author/repo, author/repo, ./local-path, https\://...:_default' \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
'-w+[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--workspace=[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'-y[Skip confirmation prompt]' \
'--yes[Skip confirmation prompt]' \
'--all-bundles[Select all bundles matching the scope without prompting]' \
'--dry-run[Show what would be uninstalled without actually uninstalling]' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Bundle name or scope to uninstall (if omitted, shows interactive menu) Can be a specific bundle name or a scope prefix (e.g., @author/scope):_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-w+[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--workspace=[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--detailed[Show detailed output]' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
'-w+[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--workspace=[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--detailed[Show dependencies from the bundle'\''s augent.yaml]' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Bundle name or scope prefix to show (if omitted, shows interactive menu) Supports scope prefixes like @author/scope to show all matching bundles:_default' \
&& ret=0
;;
(cache)
_arguments "${_arguments_options[@]}" : \
'-w+[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--workspace=[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'-h[Print help]' \
'--help[Print help]' \
":: :_augent__cache_commands" \
"*::: :->cache" \
&& ret=0

    case $state in
    (cache)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:augent-cache-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
'-w+[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--workspace=[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" : \
'--only=[Remove only specific bundle by name (e.g., @author/repo)]:ONLY:_default' \
'-w+[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--workspace=[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_augent__cache__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:augent-cache-help-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(version)
_arguments "${_arguments_options[@]}" : \
'-w+[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--workspace=[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-w+[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'--workspace=[Workspace directory (defaults to current directory)]:WORKSPACE:_files' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell type (bash, elvish, fish, powershell, zsh):_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_augent__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:augent-help-command-$line[1]:"
        case $line[1] in
            (install)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(cache)
_arguments "${_arguments_options[@]}" : \
":: :_augent__help__cache_commands" \
"*::: :->cache" \
&& ret=0

    case $state in
    (cache)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:augent-help-cache-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(version)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_augent_commands] )) ||
_augent_commands() {
    local commands; commands=(
'install:Install bundles from various sources' \
'uninstall:Remove bundles from workspace' \
'list:List installed bundles' \
'show:Show bundle information' \
'cache:Manage cache directory' \
'version:Show version information' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'augent commands' commands "$@"
}
