#compdef ghauri
# Documentation: https://github.com/r0oth3x49/ghauri
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--update[update ghauri from GitHub]' \
  '(-v --verbose)'{-v,--verbose}'=[verbosity level 1-5]:level:(1 2 3 4 5)' \
  '(-u --url)'{-u,--url}'=[target URL]:url:' \
  '-m+[scan multiple targets from file]:bulk file:_files' \
  '(-r --request-file)'{-r,--request-file}'=[HTTP request file]:file:_files' \
  '(-p --param)'{-p,--param}'=[testable parameter]:parameter:' \
  '--data=[POST data string]:data:' \
  '--cookie=[HTTP cookie header]:cookie:' \
  '(-H --header)'{-H,--header}'=[extra header]:header:' \
  '--headers=[extra headers]:headers:' \
  '--host=[HTTP Host header]:host:' \
  '--referer=[HTTP Referer header]:referer:' \
  '(-A --user-agent)'{-A,--user-agent}'=[HTTP User-Agent header]:user-agent:' \
  '--mobile[use smartphone User-Agent]' \
  '--random-agent[use random User-Agent]' \
  '--method=[HTTP method]:method:(GET POST PUT DELETE PATCH)' \
  '--proxy=[HTTP proxy]:proxy:' \
  '--delay=[delay between requests]:seconds:' \
  '--timeout=[connection timeout]:seconds:' \
  '--retries=[number of retries]:count:' \
  '--skip-urlencode[skip URL encoding]' \
  '--confirm[confirm detected injection]' \
  '--batch[batch mode, use defaults]' \
  '--flush-session[flush session files]' \
  '--fresh-queries[ignore previous results]' \
  '--test-filter=[filter tests]:filter:' \
  '--level=[test level (1-3)]:level:(1 2 3)' \
  '--risk=[risk level (1-3)]:risk:(1 2 3)' \
  '--technique=[injection technique]:technique:' \
  '--time-sec=[time-based delay]:seconds:' \
  '--threads=[number of threads]:threads:' \
  '--dbms=[DBMS type]:dbms:(MySQL PostgreSQL Microsoft\ SQL\ Server Oracle SQLite)' \
  '--dbs[enumerate databases]' \
  '--tables[enumerate tables]' \
  '--columns[enumerate columns]' \
  '--dump[dump database table entries]' \
  '--sql-shell[interactive SQL shell]' \
  '-D+[database name]:database:' \
  '-T+[table name]:table:' \
  '-C+[column name]:column:' \
  '--current-user[retrieve current user]' \
  '--current-db[retrieve current database]' \
  '--hostname[retrieve server hostname]' \
  '(-b --banner)'{-b,--banner}'[retrieve DBMS banner]' \
  '-o+[output directory]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
