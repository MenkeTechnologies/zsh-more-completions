#compdef revive

# Zsh completion for revive - Go linter

_arguments -s -S \
  '-config[config file]:file:_files' \
  '-exclude[exclude patterns]:pattern:' \
  '-formatter[output formatter]:formatter:(default friendly json ndjson plain stylish)' \
  '-max_open_files[max open files]:number:' \
  '-set_exit_status[set exit status to 1 if issues found]' \
  '-version[show version]' \
  '*:package:_files -/' && return 0
