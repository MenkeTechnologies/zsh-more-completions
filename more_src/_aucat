#compdef aucat
# _aucat — sndio audio file manipulation tool (OpenBSD)
# upstream: https://man.openbsd.org/aucat.1
# Flags from aucat(1) man page.

_aucat() {
    _arguments \
        '-b+[buffer size in frames (default 7680)]:size:' \
        '-c+[audio file channel count (default 2)]:channels:' \
        '*-d[increase log verbosity]' \
        '-e+[encoding (e.g. s16le, s24le4lsb)]:enc:' \
        '-f+[sndio audio device]:device:' \
        '-g+[start position (samples at device rate)]:position:' \
        '-h+[audio file type]:fmt:(raw wav aiff au auto)' \
        '*-i+[play input file (- for stdin)]:file:_files' \
        '-m+[channel map min:max/min:max]:map:' \
        '-n[off-line mode (process input files without device)]' \
        '*-o+[record output file (- for stdout)]:file:_files' \
        '-p+[file offset position (samples)]:position:' \
        '-q+[MIDI control port]:port:' \
        '-r+[sample rate Hz (default 48000)]:rate:(22050 44100 48000 88200 96000)' \
        '-v+[software volume (1-127)]:volume:'
}

_aucat "$@"
