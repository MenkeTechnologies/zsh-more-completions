#compdef xen-bugtool

# xen-bugtool: gather Xen diagnostic data
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-y[answer yes to prompts]' \
  '-s[silent]' \
  '-d[output directory]:dir:_files -/' \
  '--output=[output filename]:file:_files' \
  '--entries=[entries to include]:entries:' \
  '*::xen-bugtool args:_files' && ret=0
return ret
