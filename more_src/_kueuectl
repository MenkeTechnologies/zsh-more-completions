#compdef kueuectl
# _kueuectl — Kueue CLI (kubernetes-sigs/kueue)
# upstream: https://github.com/kubernetes-sigs/kueue
# Subcommands from cmd/kueuectl/app/cmd.go (cobra + k8s genericclioptions) on tip.

_kueuectl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-n --namespace)'{-n,--namespace=}'[target namespace]:ns:' \
        '--context=[kubeconfig context]:ctx:' \
        '--cluster=[kubeconfig cluster]:cluster:' \
        '--user=[kubeconfig user]:user:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--server=[apiserver URL]:url:_urls' \
        '--token=[bearer token]:token:' \
        '--insecure-skip-tls-verify[skip TLS verification]' \
        '--certificate-authority=[CA cert file]:file:_files' \
        '--client-certificate=[client cert file]:file:_files' \
        '--client-key=[client key file]:file:_files' \
        '--as=[impersonate user]:user:' \
        '*--as-group=[impersonated group]:group:' \
        '--request-timeout=[per-request timeout]:dur:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                create:'create Kueue resources'
                resume:'resume suspended Workloads / ClusterQueues / LocalQueues'
                stop:'stop Workloads / ClusterQueues / LocalQueues'
                list:'list Kueue resources'
                version:'print kueuectl version'
                get:'kubectl-style get for Kueue CRs'
                describe:'kubectl-style describe for Kueue CRs'
                edit:'kubectl-style edit for Kueue CRs'
                delete:'kubectl-style delete for Kueue CRs'
                patch:'kubectl-style patch for Kueue CRs'
                completion:'shell completion scripts'
            )
            _describe -t commands 'kueuectl command' cmds
            ;;
        args)
            case $words[1] in
                create)
                    local -a sub=(
                        clusterqueue:'create a ClusterQueue'
                        localqueue:'create a LocalQueue'
                        resourceflavor:'create a ResourceFlavor'
                        cohort:'create a Cohort'
                    )
                    _describe -t subcommands 'kueuectl create subcommand' sub
                    ;;
                list)
                    local -a sub=(
                        workload:'list Workloads'
                        clusterqueue:'list ClusterQueues'
                        localqueue:'list LocalQueues'
                        resourceflavor:'list ResourceFlavors'
                    )
                    _describe -t subcommands 'kueuectl list subcommand' sub
                    ;;
                stop)
                    local -a sub=(
                        workload:'stop a Workload'
                        clusterqueue:'stop a ClusterQueue'
                        localqueue:'stop a LocalQueue'
                    )
                    _describe -t subcommands 'kueuectl stop subcommand' sub
                    ;;
                resume)
                    local -a sub=(
                        workload:'resume a Workload'
                        clusterqueue:'resume a ClusterQueue'
                        localqueue:'resume a LocalQueue'
                    )
                    _describe -t subcommands 'kueuectl resume subcommand' sub
                    ;;
                completion)
                    _arguments '*::shell:(bash zsh fish powershell)'
                    ;;
            esac
            ;;
    esac
}

_kueuectl "$@"
