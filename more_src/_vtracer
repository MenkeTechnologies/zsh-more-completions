#compdef vtracer
# Documentation: https://man.archlinux.org/search?q=vtracer
# Reference accessed: 2026-05-16

# https://github.com/visioncortex/vtracer — raster → SVG

_arguments -s -S \
  '(-i --input)'{-i,--input}'=[source raster image]:file:_files' \
  '(-o --output)'{-o,--output}'=[output SVG path]:file:_files' \
  '--colormode=[color|bw]:mode:(color bw)' \
  '--hierarchical=[stacked|cutout]:mode:(stacked cutout)' \
  '--preset=[built-in preset]:preset:(bw poster photo)' \
  '(-f --filter_speckle)'{-f,--filter_speckle}'=[drop regions smaller than N px]:n:' \
  '(-p --color_precision)'{-p,--color_precision}'=[significant RGB bits 1-8]:n:' \
  '(-g --gradient_step)'{-g,--gradient_step}'=[layer color delta]:n:' \
  '(-c --corner_threshold)'{-c,--corner_threshold}'=[min corner angle deg]:deg:' \
  '(-l --segment_length)'{-l,--segment_length}'=[max segment length]:len:' \
  '(-s --splice_threshold)'{-s,--splice_threshold}'=[min spline splice angle]:deg:' \
  '(-m --mode)'{-m,--mode}'=[curve fitting]:mode:(pixel polygon spline)' \
  '--path_precision=[decimal places in SVG path]:n:' && return 0
