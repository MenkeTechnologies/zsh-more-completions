#compdef clipper2
# Documentation: https://man.archlinux.org/search?q=clipper2
# Reference accessed: 2026-05-16

# Zsh completion for Clipper2 polygon CLI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:subject and clip path:_files' && ret=0

return ret
