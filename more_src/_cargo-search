#compdef cargo-search
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-search.html
# Reference accessed: 2026-05-17
# Verified: Cargo command reference.
# Removed from prior file: bogus man.archlinux.org search URL.

# Zsh completion for cargo search (search packages in crates.io)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--limit=[Limit the number of results]:limit' \
  '--index=[Registry index URL to search]:url' \
  '--registry=[Registry to search]:registry' \
  '(-v --verbose)'{-v,--verbose}'[Use verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[Do not print cargo log messages]' \
  '--color=[Control when colored output is used]:when:(auto always never)' \
  '--config=[Override a configuration value]:key=value' \
  '-Z+[Unstable (nightly-only) flags]:flag' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '*:query' && ret=0

return ret
