#compdef qemu-system-x86_64 qemu-system-aarch64 qemu-system-arm qemu-system-riscv64 qemu-system-mips qemu-system-ppc64 qemu-system-i386

# Zsh completion for QEMU system emulators

_arguments -s -S \
  '-machine=[select emulated machine]:machine type:' \
  '-cpu=[select CPU model]:cpu model:' \
  '(-m --memory)'-m'+[set RAM size (MB)]:memory size:' \
  '-smp=[set number of CPUs]:cpus:' \
  '-numa=[configure NUMA]:config:' \
  '-hda=[use file as hard disk 0 image]:image file:_files' \
  '-hdb=[use file as hard disk 1 image]:image file:_files' \
  '-hdc=[use file as hard disk 2 image]:image file:_files' \
  '-hdd=[use file as hard disk 3 image]:image file:_files' \
  '-cdrom=[use file as CD-ROM image]:image file:_files' \
  '-fda=[use file as floppy disk A image]:image file:_files' \
  '-fdb=[use file as floppy disk B image]:image file:_files' \
  '-drive=[define a new drive]:drive options:' \
  '-boot=[set boot order]:boot options:' \
  '-bios=[set BIOS filename]:bios file:_files' \
  '-pflash=[parallel flash image]:image file:_files' \
  '-kernel=[use file as kernel image]:kernel file:_files' \
  '-initrd=[use file as initial ramdisk]:initrd file:_files' \
  '-append=[set kernel command line]:command line:' \
  '-dtb=[use file as device tree binary]:dtb file:_files' \
  '-net=[configure network]:network config:' \
  '-netdev=[configure network backend]:backend config:' \
  '-device=[add device]:device config:' \
  '-nic=[configure NIC]:nic config:' \
  '-display=[set display type]:display:(sdl gtk curses none vnc spice-app egl-headless dbus)' \
  '-nographic[disable graphical output]' \
  '-vga=[select type of VGA card]:vga type:(std cirrus vmware qxl tcx cg3 virtio none)' \
  '-vnc=[start VNC server]:display:' \
  '-spice=[enable spice]:spice options:' \
  '-serial=[redirect serial port]:device:' \
  '-parallel=[redirect parallel port]:device:' \
  '-monitor=[redirect monitor]:device:' \
  '-qmp=[enable QMP on chardev]:chardev:' \
  '-enable-kvm[enable KVM full virtualization]' \
  '-accel=[select accelerator]:accelerator:(kvm tcg hvf whpx xen)' \
  '-snapshot[write to temporary files]' \
  '-no-reboot[exit instead of rebooting]' \
  '-no-shutdown[do not exit QEMU on guest shutdown]' \
  '-S[freeze CPU at startup]' \
  '-s[shorthand for -gdb tcp::1234]' \
  '-gdb=[wait for gdb connection]:device:' \
  '-d=[activate logging]:log items:' \
  '-D=[log output file]:log file:_files' \
  '-daemonize[daemonize QEMU after initialization]' \
  '-pidfile=[write PID to file]:pid file:_files' \
  '-name=[set guest name]:name:' \
  '-uuid=[set system UUID]:uuid:' \
  '-rtc=[set RTC start date and clock]:rtc options:' \
  '-soundhw=[enable audio support]:card:(sb16 es1370 ac97 adlib gus cs4231a hda pcspk all)' \
  '-audiodev=[audio device backend]:config:' \
  '-usb[enable USB driver]' \
  '-usbdevice=[add USB device]:device:' \
  '-chardev=[configure character device backend]:chardev config:' \
  '-fsdev=[configure file system device]:fsdev config:' \
  '-virtfs=[configure virtual filesystem]:virtfs config:' \
  '-object=[create new object]:object config:' \
  '-fw_cfg=[add named firmware config]:config:' \
  '-loadvm=[start right away with saved state]:state tag:' \
  '-incoming=[prepare for incoming migration]:uri:' \
  '-sandbox=[enable seccomp mode 2]:mode:(on off)' \
  '-readconfig=[read device configuration]:config file:_files' \
  '-writeconfig=[write device configuration]:config file:_files' \
  '-nodefaults[do not create default devices]' \
  '-runas=[drop privileges to user]:user:_users' \
  '-version[show version]' \
  '-h[show help]' \
  '*:disk image:_files'
