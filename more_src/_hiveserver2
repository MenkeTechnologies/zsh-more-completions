#compdef hiveserver2
# Documentation: https://cwiki.apache.org/confluence/display/Hive/HiveServer2+Clients
# Start the HiveServer2 service (Thrift/JDBC server for Hive)

local ret=1

_arguments -s -S \
  '(-H --help)'{-H,--help}'[display help message]' \
  '*--hiveconf[set a Hive configuration property=value]:property' \
  '--hivevar[set a Hive variable name=value]:variable' \
  '*:arg:_default' && ret=0

return ret
