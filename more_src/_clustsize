#compdef clustsize gmx-clustsize
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-clustsize.html
# gmx clustsize: calculate size distributions of atomic clusters

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-n[index file]:file:_files' \
  '-o[X PixMap matrix file]:file:_files' \
  '-ow[X PixMap matrix file]:file:_files' \
  '-nc[xvgr/xmgr file]:file:_files' \
  '-mc[xvgr/xmgr file]:file:_files' \
  '-ac[xvgr/xmgr file]:file:_files' \
  '-hc[xvgr/xmgr file]:file:_files' \
  '-temp[xvgr/xmgr file]:file:_files' \
  '-mcn[index file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-tu[unit for time values]:unit:(fs ps ns us ms s)' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-cut[largest distance (nm) considered in a cluster]:real:' \
  '-mol[cluster molecules rather than atoms]' \
  '-pbc[use periodic boundary conditions]' \
  '-nskip[number of frames to skip between writing]:int:' \
  '-nlevels[number of levels of grey in xpm output]:int:' \
  '-ndf[number of degrees of freedom for temperature]:int:' \
  '-rgblo[RGB values for lowest occupied cluster size color]:vector:' \
  '-rgbhi[RGB values for highest occupied cluster size color]:vector:' && ret=0

return ret
