# Zsh completion for create-go-app - Go app scaffolder (no build configuration)

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-V --version)'{-V,--version}'[output version number]'   '(-p --prefix)'{-p,--prefix}'[Go module prefix]:prefix:'   '(-h --help)'{-h,--help}'[display help for command]'   ':project name:' && ret=0

