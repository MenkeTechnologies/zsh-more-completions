#compdef commitizen-cli czcli
# _commitizen-cli — Commitizen-python conventional commit toolkit CLI alias (Sentry / commitizen-tools, Python); typer
# upstream: https://github.com/commitizen-tools/commitizen

_commitizen-cli() {
    local -a sub=(
        'init:scaffold .cz config'
        'commit:create commit'
        'c:create commit (alias)'
        'ls:list available commitizens'
        'example:print example'
        'info:print info'
        'schema:print schema'
        'bump:bump version + create changelog'
        'changelog:generate changelog'
        'check:check commit message'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--no-raise=+[exit with 0 instead of given codes]:list:' \
        '--debug[debug]' \
        '-n+[commitizen name]:cz:(cz_conventional_commits cz_jira cz_customize)' \
        '--name=+[commitizen name]:cz:(cz_conventional_commits cz_jira cz_customize)' \
        '--config=+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cz subcommand' sub ;;
        args)
            case $words[1] in
                commit|c) _arguments \
                    '--retry[retry last commit]' \
                    '--dry-run[dry run]' \
                    '--write-message-to-file=+[write message to file]:file:_files' \
                    '--signoff[signoff]' \
                    '-s[signoff]' \
                    '--all[stage all]' \
                    '-a[stage all]' \
                    '--extra-cli-args=+[extra git commit args]:str:' \
                    '*:arg:' ;;
                bump) _arguments \
                    '--dry-run[dry run]' \
                    '--files-only[files only]' \
                    '--local-version[bump local version]' \
                    '--increment=+[force increment]:t:(MAJOR MINOR PATCH)' \
                    '--prerelease=+[prerelease]:p:(alpha beta rc)' \
                    '--check-consistency[check consistency]' \
                    '--no-verify[no verify]' \
                    '--yes[yes]' \
                    '--changelog[generate changelog]' \
                    '--changelog-to-stdout[changelog to stdout]' \
                    '--git-output-to-stderr[git output to stderr]' \
                    '--retry[retry last bump]' \
                    '--annotated-tag[annotated tag]' \
                    '--gpg-sign[gpg sign]' \
                    '--build-metadata=+[build metadata]:str:' \
                    '--message-template=+[message template]:str:' \
                    '--version-scheme=+[version scheme]:s:(semver pep440 semver-2)' \
                    '--changelog-incremental[changelog incremental]' \
                    '--major-version-zero[major version zero]' \
                    '--template=+[changelog template file]:file:_files' \
                    '--extra=+[extra context]:str:' \
                    '*:arg:' ;;
                changelog) _arguments \
                    '--dry-run[dry run]' \
                    '--file-name=+[output file]:file:_files' \
                    '--unreleased-version=+[unreleased version]:str:' \
                    '--incremental[incremental]' \
                    '--start-rev=+[start rev]:str:' \
                    '--merge-prerelease[merge prerelease]' \
                    '--version-scheme=+[version scheme]:s:(semver pep440 semver-2)' \
                    '--template=+[template file]:file:_files' \
                    '--extra=+[extra context]:str:' \
                    '--export-template=+[export template]:file:_files' \
                    '*:rev-range:' ;;
                check) _arguments \
                    '--commit-msg-file=+[commit msg file]:file:_files' \
                    '--rev-range=+[rev range]:str:' \
                    '-m+[message]:str:' \
                    '--message=+[message]:str:' \
                    '--allow-abort[allow abort]' \
                    '--allowed-prefixes=+[allowed prefixes csv]:list:' ;;
            esac
            ;;
    esac
}

_commitizen-cli "$@"
