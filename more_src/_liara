# -----------------------------------------------------------------------------
#
# THE liara CLI — oclif + got + inquirer + ora + ws + async-retry
#
# liara's CLI is structured around @oclif/core 3.27.  Topic
# directories under src/commands/ each contain subcommand files;
# top-level commands are deploy.ts, init.ts, login.ts.
#
# Base flags (every command inherits via src/base.ts):
#   -h, --help              show help
#       --debug             show debug logs
#       --dev               run in dev mode (hidden)
#       --api-token TOKEN   API token for authentication
#       --account NAME      temporarily switch to a different account
#       --team-id ID        your team id
#
# 13 topic groups:
#   account add | list | remove | use <name>
#   app create | delete | list | logs | restart | shell | start | stop
#   bucket create | delete | list
#   db backup (create | download | list) | create | list | remove | resize | start | stop
#   deploy [--path] [--platform] [-a APP] [-p PORT] [-i IMAGE]
#           [--detach] [--no-app-logs] [--args] [--build-arg X=Y]*
#           [-m MSG] [-d DISK]* [--no-cache] [-f DOCKERFILE]
#           [-b iran|germany] [--liara-json FILE]
#   disk create
#   env list | set | unset
#   init
#   login
#   mail create | delete | list | send
#   network create | list
#   plan list
#   vm create | delete | info | list | restart | start | stop
#   zone check | create | delete | get | list
#   zone record create | get | list | remove | update
#
# got is used in src/base.ts:
#   import got, { ExtendOptions, Options } from 'got';
#   ...
#   this.got = got.extend({
#     prefixUrl: REGIONS_API_URL[region],
#     headers: { Authorization: `Bearer ${token}` },
#     hooks: hooks,
#     timeout: { request: 30000 }
#   });
#
# Five-axis distinctness from reqwest (R649) + resty (R650):
#
#   1. PROMISE / fetch-like API — top-level async function; not
#      a builder.  reqwest uses ClientBuilder; resty uses Request
#      builder.
#
#   2. got.extend INSTANCES — pre-configured client factories
#      with default headers/URL/hooks.  reqwest has Client::
#      builder() (once); resty has client.SetX (per-client).
#
#   3. EXPONENTIAL BACKOFF default — retries on network +
#      408/413/429/5xx with exponential delays.  reqwest needs
#      external middleware; resty has SetRetryCount but no
#      default exponential.
#
#   4. 5-PHASE HOOK SYSTEM — init/beforeRequest/beforeRedirect/
#      beforeRetry/beforeError/afterResponse.  reqwest has no
#      built-in hooks; resty has OnBeforeRequest/OnAfterResponse
#      (2 phases).
#
#   5. SINDRE-SORHUS / SORHUS-ECOSYSTEM PROVENANCE — distinct
#      from Sean McArthur (Hyperium / reqwest), Mathew Roy
#      (go-resty), Steve Francia (Cobra/Viper), David Tolnay
#      (serde).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/liara-cloud/cli/blob/master/src/base.ts
# https://github.com/liara-cloud/cli/blob/master/src/commands/deploy.ts
# @oclif/core Flags definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _liara_cmds _liara_account _liara_app _liara_bucket _liara_db
local -a _liara_db_backup _liara_env _liara_mail _liara_network _liara_plan
local -a _liara_vm _liara_zone _liara_zone_record _liara_build_locations
_liara_cmds=(
    'account:manage multiple Liara accounts'
    'app:app lifecycle management'
    'bucket:object-storage bucket management'
    'db:managed database management'
    'deploy:deploy an app'
    'disk:persistent disk management'
    'env:environment variable management'
    'init:initialize liara.json project config'
    'login:authenticate with Liara'
    'mail:managed email service'
    'network:virtual network management'
    'plan:list available plans'
    'vm:virtual machine management'
    'zone:DNS zone management'
    'help:show help for a subcommand'
)
_liara_account=('add:add an account' 'list:list accounts' 'remove:remove an account' 'use:switch current account')
_liara_app=(
    'create:create an app' 'delete:delete an app' 'list:list apps'
    'logs:stream app logs' 'restart:restart an app' 'shell:open shell on app'
    'start:start an app' 'stop:stop an app'
)
_liara_bucket=('create:create a bucket' 'delete:delete a bucket' 'list:list buckets')
_liara_db=(
    'backup:database backup ops' 'create:create a database' 'list:list databases'
    'remove:remove a database' 'resize:resize a database'
    'start:start a database' 'stop:stop a database'
)
_liara_db_backup=('create:create a backup' 'download:download a backup' 'list:list backups')
_liara_env=('list:list env vars' 'set:set env vars' 'unset:unset env vars')
_liara_mail=('create:create a mailbox' 'delete:delete a mailbox' 'list:list mailboxes' 'send:send an email')
_liara_network=('create:create a virtual network' 'list:list virtual networks')
_liara_plan=('list:list available plans')
_liara_vm=(
    'create:create a VM' 'delete:delete a VM' 'info:show VM info' 'list:list VMs'
    'restart:restart a VM' 'start:start a VM' 'stop:stop a VM'
)
_liara_zone=(
    'check:check zone status' 'create:create a zone' 'delete:delete a zone'
    'get:get zone details' 'list:list zones' 'record:DNS record management'
)
_liara_zone_record=(
    'create:create a DNS record' 'get:get a DNS record' 'list:list DNS records'
    'remove:remove a DNS record' 'update:update a DNS record'
)
_liara_build_locations=('iran:Iran build location' 'germany:Germany build location')

local global_flags
global_flags=(
    '(- *)'{-h,--help}'[show help]'
    '--debug[show debug logs]'
    '--api-token=[API token for authentication]:token:_default'
    '--account=[temporarily switch to a different account]:account:_default'
    '--team-id=[your team id]:team:_default'
)

_arguments -C \
    $global_flags \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'liara subcommand' _liara_cmds && ret=0
        ;;
    args)
        case $words[1] in
            account)  _describe -t commands 'account subcommand' _liara_account && ret=0 ;;
            app)      _describe -t commands 'app subcommand' _liara_app && ret=0 ;;
            bucket)   _describe -t commands 'bucket subcommand' _liara_bucket && ret=0 ;;
            db)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'db subcommand' _liara_db && ret=0
                elif [[ $words[2] == backup && CURRENT == 3 ]]; then
                    _describe -t commands 'db backup subcommand' _liara_db_backup && ret=0
                fi
                ;;
            env)      _describe -t commands 'env subcommand' _liara_env && ret=0 ;;
            mail)     _describe -t commands 'mail subcommand' _liara_mail && ret=0 ;;
            network)  _describe -t commands 'network subcommand' _liara_network && ret=0 ;;
            plan)     _describe -t commands 'plan subcommand' _liara_plan && ret=0 ;;
            vm)       _describe -t commands 'vm subcommand' _liara_vm && ret=0 ;;
            zone)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'zone subcommand' _liara_zone && ret=0
                elif [[ $words[2] == record && CURRENT == 3 ]]; then
                    _describe -t commands 'zone record subcommand' _liara_zone_record && ret=0
                fi
                ;;
            deploy)
                _arguments \
                    '--path=[app path in your computer]:path:_files -/' \
                    '--platform=[the platform your app needs to run]:platform:_default' \
                    '(-a --app)'{-a+,--app=}'[app id]:app:_default' \
                    '(-p --port)'{-p+,--port=}'[the port that your app listens to]:port:_default' \
                    '(-i --image)'{-i+,--image=}'[docker image to deploy]:image:_default' \
                    '--detach[run build in background]' \
                    '--no-app-logs[do not stream app logs after deployment]' \
                    '--args=[docker image entrypoint args]:args:_default' \
                    '*--build-arg=[docker image build args]:arg:_default' \
                    '(-m --message)'{-m+,--message=}'[the release message]:message:_default' \
                    '*'{-d+,--disks=}'[mount a disk]:disk:_default' \
                    '--no-cache[do not use cache when building the image]' \
                    '(-f --dockerfile)'{-f+,--dockerfile=}'[name of the Dockerfile]:file:_files' \
                    '(-b --build-location)'{-b+,--build-location=}'[build location]:location:->build_loc' \
                    '--liara-json=[name of the liara config file]:file:_files' \
                    && ret=0
                ;;
            help) _describe -t commands 'subcommand' _liara_cmds && ret=0 ;;
        esac
        case $state in
            build_loc)
                _describe -t locations 'build location' _liara_build_locations && ret=0
                ;;
        esac
        ;;
esac

return ret
