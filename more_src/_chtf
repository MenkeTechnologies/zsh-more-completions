#compdef chtf
# Documentation: https://github.com/tmatilai/chtf
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# chtf: switch between installed Terraform versions
function _chtf() {
    _arguments \
        '(- 1)'{-h,--help,-V,--version} \
        '(-)1:Terraform version:($(chtf | tr -d " *") system)'
}

_chtf
