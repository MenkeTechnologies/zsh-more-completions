#compdef browse
# Documentation: https://docs.browserbase.com/integrations/skills/browserbase-cli
# Reference accessed: 2026-05-23
# Verified: Browse CLI docs (browse open, snapshot, click, cloud, skills).

# Zsh completion for browse - Browserbase browser automation CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'open:open URL'
  'goto:navigate to URL'
  'reload:reload page'
  'back:go back'
  'forward:go forward'
  'snapshot:accessibility snapshot'
  'screenshot:screenshot'
  'click:click element ref'
  'fill:fill input'
  'type:type text'
  'press:press key'
  'select:select option'
  'upload:upload file'
  'wait:wait for condition'
  'get:get element property'
  'eval:evaluate JS'
  'start:start daemon'
  'stop:stop daemon'
  'status:daemon status'
  'env:local or remote mode'
  'cloud:Browserbase cloud APIs'
  'skills:skill management'
  'tab:tab management'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json[JSON output]' \
  '--headless[headless Chrome]' \
  '--headed[headed Chrome]' \
  '--session[session name]:name:' \
  '--local[local browser]' \
  '--remote[Browserbase remote]' \
  '--ws[CDP websocket URL]:url:' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'browse command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (open|goto)
        _arguments \
          '(-t --timeout)'{-t+,--timeout=}'[timeout ms]:ms:' \
          ':url:_urls' && ret=0
        ;;
      (click|fill|select|get|eval|hover)
        _arguments ':ref:' && ret=0
        ;;
      (screenshot)
        _arguments \
          '(-f --full-page)'{-f,--full-page}'[full page]' \
          ':path:_files' && ret=0
        ;;
      (wait)
        _arguments ':condition:(load selector timeout)' && ret=0
        ;;
      (*)
        _arguments '*::args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
