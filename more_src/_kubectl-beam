#compdef kubectl-beam
# Documentation: https://github.com/codeadict/kubectl-beam
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-beam (codeadict/kubectl-beam): connect to BEAM (Erlang VM) nodes.
# Usage: kubectl beam [iex|erl] [flags] [pod-name]

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[display plugin version]' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:' \
  '(-c --container)'{-c+,--container=}'[container name in multi-container pods]:container:' \
  '--observer[launch Erlang Observer GUI]' \
  '(-l --long-names)'{-l,--long-names}'[use long names instead of short names]' \
  '--cookie=[explicit Erlang cookie value]:cookie:' \
  '--cookie-path=[path to cookie file on pod]:path:' \
  '--cookie-env=[environment variable containing cookie]:var:' \
  '1:shell:(iex erl)' \
  '*::pod:_default' && ret=0

return ret
