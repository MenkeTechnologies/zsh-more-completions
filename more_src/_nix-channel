#compdef nix-channel

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--add[add a channel]:url:name' \
  '--remove[remove a channel]:name' \
  '--list[list channels]' \
  '--update[update channels]:name' \
  '--rollback[rollback channel]:generation' && ret=0

return ret
