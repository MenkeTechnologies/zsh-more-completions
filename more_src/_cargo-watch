#compdef cargo-watch
# Documentation: https://github.com/watchexec/cargo-watch
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Watch a Rust project for changes and run cargo commands or arbitrary shell commands.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[Display help]' \
  '(- *)'{-V,--version}'[Display version]' \
  '*'{-x+,--exec=}'[Cargo command(s) to execute on changes]:cargo command:(build check clippy doc fmt run test bench update clean)' \
  '*'{-s+,--shell=}'[Shell command(s) to execute on changes]:shell command:' \
  '(-d --delay)'{-d+,--delay=}'[File updates debounce delay (s, default 0.5)]:seconds:' \
  '*'{-w+,--watch=}'[Watch specific file(s) or folder(s)]:path:_files' \
  '*'{-i+,--ignore=}'[Ignore glob/gitignore-style pattern]:pattern:' \
  '--no-vcs-ignores[Do not use .gitignore files]' \
  '--no-dot-ignores[Do not use .ignore files]' \
  '--ignore-nothing[Ignore nothing, not even target/ and .git/]' \
  '(-c --clear)'{-c,--clear}'[Clear screen before each run]' \
  '(-q --quiet)'{-q,--quiet}'[Suppress cargo-watch output]' \
  '--debug[Show debug output]' \
  '--why[Show paths that changed]' \
  '--skip-local-deps[Do not watch local dependencies]' \
  '(-C --workdir)'{-C+,--workdir=}'[Change working directory]:directory:_directories' \
  '*'{-E+,--env-var=}'[Inject environment variable]:var=value:' \
  '--env-file=[Inject env vars from dotenv-style file]:file:_files' \
  '-B+[Inject RUST_BACKTRACE=value]:value:(0 1 full)' \
  '-L+[Inject RUST_LOG=value]:value:' \
  '*--features=[Features passed to cargo]:features:' \
  '--use-shell=[Use a different shell]:shell:_command_names' \
  '--poll[Force polling for file changes]' \
  '--postpone[Postpone first run until a file changes]' \
  '--no-restart[Do not restart command while still running]' \
  '--watch-when-idle[Ignore events emitted while commands run]' \
  '(-N --notify)'{-N,--notify}'[Send desktop notification on changes (experimental)]' \
  '--no-process-group[Disable process-group behavior]' \
  '*:arguments:' && ret=0

return ret
