#compdef g-dxf
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=g-dxf&sektion=1
# BRL-CAD geometry database to DXF converter

local ret=1

_arguments -s \
  '-v[verbose output]' \
  '-i[output units in inches (default mm)]' \
  '-p[output POLYFACE MESH entities instead of 3DFACE]' \
  '-x[librt debug flag level]:level' \
  '-X[NMG debug flag level]:level' \
  '-D[calculational distance tolerance (mm)]:tolerance' \
  '-a[absolute tessellation tolerance (mm)]:tolerance' \
  '-r[relative error tolerance]:tolerance' \
  '-n[surface normal error tolerance (degrees)]:tolerance' \
  '-P[number of CPUs]:cpus' \
  '-o[output DXF file (default stdout)]:output:_files' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
