#compdef sensors

# Zsh completion for sensors (lm-sensors) - hardware monitoring

_arguments -s -S \
  '(-f --fahrenheit)'{-f,--fahrenheit}'[show temperatures in Fahrenheit]' \
  '(-A --no-adapter)'{-A,--no-adapter}'[do not show adapter for each chip]' \
  '(-u --raw)'{-u,--raw}'[output raw values]' \
  '(-j --json)'{-j,--json}'[output in JSON format]' \
  '--bus-list[generate bus statements for sensors.conf]' \
  '(-s --set)'{-s,--set}'[set limits from config file]' \
  '(-c --config-file)'{-c+,--config-file=}'[config file]:config file:_files' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:chip name:'
