#compdef sensors
# Documentation: https://manpages.debian.org/bookworm/lm-sensors/sensors.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for sensors (lm-sensors) - hardware monitoring

_arguments -s -S \
  '(-f --fahrenheit)'{-f,--fahrenheit}'[show temperatures in Fahrenheit]' \
  '(-A --no-adapter)'{-A,--no-adapter}'[do not show adapter for each chip]' \
  '-u[raw output (for debugging/scripting)]' \
  '-j[JSON output]' \
  '--bus-list[generate bus statements for sensors.conf]' \
  '(-s --set)'{-s,--set}'[evaluate set statements from config (requires root)]' \
  '(-c --config-file)'{-c+,--config-file=}'[config file]:config file:_files' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:chip name:'
