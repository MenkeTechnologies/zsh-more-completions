#compdef xbps-install

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-A[set automatic installation flag]' \
  '(-C --config)'{-C,--config}'[path to confdir]:directory:_directories' \
  '-c[path to cachedir]:directory:_directories' \
  '-D[enable debug messages]' \
  '-d[dry run mode]' \
  '-f[force installation]' \
  '-I[ignore file conflicts]' \
  '-i[ignore unresolved shared libraries]' \
  '-M[ignore repos defined in confdir]' \
  '-n[dry run mode]' \
  '(-R --repository)'{-R,--repository}'[add repository]:repository URL' \
  '-r[rootdir]:directory:_directories' \
  '-S[sync remote repository index]' \
  '-U[only update installed packages]' \
  '-u[update all packages]' \
  '-v[verbose messages]' \
  '-y[assume yes to all questions]' \
  '*:package' && ret=0

return ret
