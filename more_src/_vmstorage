#compdef vmstorage

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-storageDataPath=[storage data path]:dir:_files -/' \
  '-retentionPeriod=[retention period]:duration:' \
  '-httpListenAddr=[HTTP listen addr]:addr:' \
  '-vminsertAddr=[vminsert listen addr]:addr:' \
  '-vmselectAddr=[vmselect listen addr]:addr:' \
  '-storage.minFreeDiskSpaceBytes=[min free disk space]:bytes:' \
  '-storage.maxHourlySeries=[max hourly series]:n:' \
  '-storage.maxDailySeries=[max daily series]:n:' \
  '-storage.vminsertConnsShutdownDuration=[vminsert conns shutdown duration]:duration:' \
  '-rpc.disableCompression[disable RPC compression]' \
  '-tls[enable TLS]' \
  '-tlsCertFile=[TLS cert]:file:_files' \
  '-tlsKeyFile=[TLS key]:file:_files' \
  '-mtls[enable mTLS]' \
  '-mtlsCAFile=[mTLS CA file]:file:_files' \
  '-cluster.tls[enable cluster TLS]' \
  '-cluster.tlsCertFile=[cluster TLS cert]:file:_files' \
  '-cluster.tlsKeyFile=[cluster TLS key]:file:_files' \
  '-cluster.tlsCAFile=[cluster TLS CA]:file:_files' \
  '-loggerLevel=[log level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '-loggerFormat=[log format]:format:(default json)'
