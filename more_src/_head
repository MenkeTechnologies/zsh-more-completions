#compdef head

local -a arguments

arguments=(
  {-c,--bytes}'[print the first K bytes of each file; with the leading -, print all but the last K bytes]:bytes:'
  {-n,--lines}'[print the first K lines instead of the first 10; with the leading -, print all but the last K lines]:lines:'
  {-q,--quiet,--silent}'[never print headers giving file names]'
  {-v,--verbose}'[always print headers giving file names]'
  '--help[display this help and exit]'
  '--version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
