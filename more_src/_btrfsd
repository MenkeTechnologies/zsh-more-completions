#compdef btrfsd
# _btrfsd — Phoronix btrfsd (small daemon that runs periodic maintenance on every mounted btrfs filesystem — automatic balance, scrub, defrag, trim — based on the timeline tuned by btrfs-systemd-timer; -d daemonize, -c config file, -v verbose, -n dry-run, --version)
# upstream: https://github.com/ximion/btrfsd
# Flags from btrfsd src/main.c on tip.

_btrfsd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[daemonize]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '-c+[config file]:file:_files' \
        '--config+[config file]:file:_files' \
        '--state-dir+[state dir]:dir:_files -/' \
        '--once[one cycle then exit]'
}

_btrfsd "$@"
