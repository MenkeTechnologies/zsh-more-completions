#compdef terraformsh
# Documentation: https://github.com/pwillis-els/terraformsh
# A wrapper for Terraform/OpenTofu in Bash

local ret=1

_arguments -s -S \
  '(-h)-h[display help screen]' \
  '*-f[pass a file to terraform -var-file]:var file:_files' \
  '*-b[pass a file to terraform -backend-config]:backend config:_files' \
  '*-C[change to directory]:dir:_files -/' \
  '*-c[specify a .terraformshrc config file]:config:_files' \
  '*-E[evaluate a bash expression]:expr:' \
  '-I[disable automatic loading of parent directory config files]' \
  '-P[disable plan file usage for plan/apply/destroy]' \
  '-D[skip dependency commands such as terraform init]' \
  '-N[dry-run mode, do not execute commands]' \
  '-n[preserve temporary TF_DATA_DIR on exit]' \
  '-v[verbose mode, enable debugging]' \
  '-q[quiet mode, suppress output]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      plan apply plan_destroy destroy refresh validate init get show
      import state taint untaint output console workspace force-unlock
      0.12upgrade 0.13upgrade
      shell clean clean_modules approve aws_bootstrap revgrep env
    )
    _describe -t commands 'terraformsh command' cmds && ret=0
    ;;
esac

return ret
