#compdef zigup

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'fetch:fetch a Zig version'
      'list:list available Zig versions'
      'default:set the default Zig version'
      'clean:remove a Zig version'
      'keep:mark a Zig version to keep'
      'run:run a specific Zig version'
      'help:show help'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (fetch)
        _arguments \
          '--force[force re-fetch even if already installed]' \
          '1:version:' && ret=0
        ;;
      (default)
        _arguments '1:version:' && ret=0
        ;;
      (clean)
        _arguments '1:version:' && ret=0
        ;;
      (keep)
        _arguments '1:version:' && ret=0
        ;;
      (run)
        _arguments \
          '1:version:' \
          '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
