#compdef aurman
# Documentation: https://github.com/polygamma/aurman
# Reference accessed: 2026-05-27
# Verified: upstream src/aurman/parse_args.py pacman_options/pacman_operations tables.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-D --database)'{-D,--database}'[operate on the package database]' \
  '(-F --files)'{-F,--files}'[query the files database]' \
  '(-Q --query)'{-Q,--query}'[query the package database]' \
  '(-R --remove)'{-R,--remove}'[remove packages from the system]' \
  '(-S --sync)'{-S,--sync}'[synchronize packages]' \
  '(-T --deptest)'{-T,--deptest}'[check dependencies]' \
  '(-U --upgrade)'{-U,--upgrade}'[upgrade or add packages from a file]' \
  '(- *)'{-V,--version}'[display version and exit]' \
  '(- *)'{-h,--help}'[display help and exit]' \
  '(-r --root)'{-r+,--root=}'[set alternate installation root]:directory:_directories' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*--cachedir=[set alternate package cache location]:directory:_directories' \
  '--color=[colorize output]:when:(always never auto)' \
  '--debug[display debug messages]' \
  '--gpgdir=[set alternate gpg directory]:directory:_directories' \
  '*--hookdir=[set alternate hook location]:directory:_directories' \
  '--logfile=[set alternate log file]:file:_files' \
  '--noconfirm[do not ask for any confirmation]' \
  '--confirm[always ask for confirmation]' \
  '*--overwrite=[overwrite conflicting files]:glob:' \
  '--asdeps[install packages as non-explicitly installed]' \
  '--asexplicit[install packages as explicitly installed]' \
  '--needed[do not reinstall up to date packages]' \
  '*--ignore=[ignore a package upgrade]:package:' \
  '*--ignoregroup=[ignore a group upgrade]:group:' \
  '(-s --search)'{-s,--search}'[search remote repositories for matching strings]' \
  '(-u --sysupgrade)'{-u,--sysupgrade}'[upgrade installed packages]' \
  '(-y --refresh)'{-y,--refresh}'[download fresh package databases]' \
  '(-c --clean)'{-c,--clean}'[remove old packages from cache]' \
  '(-i --info)'{-i,--info}'[view package information]' \
  '--aur[do things only for aur]' \
  '--repo[do things only for regular repos]' \
  '--domain=[change AUR domain]:domain:' \
  '--keyserver=[keyserver to use for PGP key fetching]:server:' \
  '--noedit[do not prompt to edit PKGBUILDs and install files]' \
  '--always_edit[always prompt to edit PKGBUILDs and install files]' \
  '--show_changes[always show changes to PKGBUILDs and install files]' \
  '--devel[fetch all development packages]' \
  '--devel_skip_deps[skip dependency check on devel packages]' \
  '--deep_search[search dependency graph deeply for solutions]' \
  '--pgp_fetch[fetch needed PGP keys without confirmation]' \
  '--solution_way[show the way the solver chose for installation]' \
  '*--holdpkg=[specify hold packages]:package:' \
  '--holdpkg_conf[append hold packages from pacman.conf]' \
  '--do_everything[perform all operations including sysupgrade]' \
  '--optimistic_versioning[assume dependency satisfied if version unknown]' \
  '--ignore_versioning[ignore versioning during dependency resolution]' \
  '--rebuild[always rebuild AUR packages]' \
  '--skip_news[skip showing aur news]' \
  '--skip_new_locations[skip new locations after package moves]' \
  '--sort_by_name[sort -Ss results by name]' \
  '--sort_by_votes[sort -Ss results by votes]' \
  '--sort_by_popularity[sort -Ss results by popularity]' \
  '--show_unknown[show unknown packages on a single line]' \
  '*:package:' && ret=0

return ret
