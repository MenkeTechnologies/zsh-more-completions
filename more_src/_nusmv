#compdef NuSMV nusmv NuXMV nuxmv
# Documentation: https://man.archlinux.org/search?q=NuSMV
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-h[show help]' \
  '-v+[verbose level]:n:' \
  '-int[interactive shell]' \
  '-quiet[suppress messages]' \
  '-cpp[run cpp on input]' \
  '-pre+[preprocessor]:p:(cpp m4 m4check)' \
  '-load+[command file]:file:_files' \
  '-source+[source command file]:file:_files' \
  '-disable_syntactic_checks[disable syntax checks]' \
  '-keep_single_value_vars[keep single value vars]' \
  '-r[print reachable states]' \
  '-coi[cone of influence]' \
  '-flt[FLTL parsing]' \
  '-AG[AG only]' \
  '-bmc[bounded model checking]' \
  '-bmc_length+[bmc length]:n:' \
  '-sat_solver+[SAT solver]:s:(MiniSat zchaff)' \
  '-dynamic[dynamic var ordering]' \
  '-old[old algorithm]' \
  '-sin+[symbolic init]:m:(0 1)' \
  '-iwls95preorder+[var ordering]:m:(0 1)' \
  '-i+[input order file]:file:_files' \
  '-o+[output order file]:file:_files' \
  '-t+[clusters info]:file:_files' \
  '-reorder[dynamic reorder]' \
  '-mono[monolithic]' \
  '-ofm+[output flat model]:file:_files' \
  '-obm+[output boolean model]:file:_files' \
  '-ctt[print transition cluster]' \
  '-thresh+[clusters threshold]:n:' \
  '-cpp_path+[cpp path]:path:_files -/' \
  '-df[disable forward search]' \
  '-flt_run_simplification[FLT simplification]' \
  '-ic3[IC3 model checking]' \
  '-msat[MathSAT]' \
  '-cs+[case study]:cs:' \
  '*: :_files -g "*.smv"' && ret=0

return ret
