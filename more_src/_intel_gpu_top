#compdef intel_gpu_top
# Documentation: https://gitlab.freedesktop.org/drm/igt-gpu-tools
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-s+[update interval in milliseconds]:interval (ms)' \
  '-l[list available engines]' \
  '-p[show per-PID stats]' \
  '-J[output JSON format]' \
  '-L[list plain output]' \
  '-d+[select device]:device:_files -W /dev/dri' && ret=0

return ret
