#compdef intel_gpu_top
# Documentation: https://man.archlinux.org/search?q=intel_gpu_top
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-s+[update interval in milliseconds]:interval (ms)' \
  '-l[list available engines]' \
  '-p[show per-PID stats]' \
  '-J[output JSON format]' \
  '-L[list plain output]' \
  '-d+[select device]:device:_files -W /dev/dri' && ret=0

return ret
