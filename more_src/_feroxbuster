#compdef feroxbuster

# Zsh completion for feroxbuster - fast, simple, recursive content discovery tool

_arguments -s -S \
  '(-u --url)'{-u,--url}'[target URL]:URL:' \
  '(-w --wordlist)'{-w,--wordlist}'[path to wordlist]:file:_files' \
  '(-t --threads)'{-t,--threads}'[number of concurrent threads]:threads:' \
  '(-d --depth)'{-d,--depth}'[maximum recursion depth]:depth:' \
  '(-r --redirects)'{-r,--redirects}'[allow client to follow redirects]' \
  '(-k --insecure)'{-k,--insecure}'[disable TLS certificate validation]' \
  '(-e --extract-links)'{-e,--extract-links}'[extract links from response body and make requests to those URLs]' \
  '(-g --collect-extensions)'{-g,--collect-extensions}'[collect and use extensions found in response bodies]' \
  '(-I --collect-backups)'{-I,--collect-backups}'[collect backup extensions from each URL]' \
  '(-G --collect-words)'{-G,--collect-words}'[collect words from responses to use in further requests]' \
  '(-l --collect-wordlist)'{-l,--collect-wordlist}'[collect wordlists from target server]' \
  '(-x --extensions)'{-x,--extensions}'[file extension(s) to search for]:extensions:' \
  '(-H --headers)'{-H,--headers}'[specify HTTP header]:header:' \
  '(-b --cookies)'{-b,--cookies}'[specify cookie]:cookie:' \
  '(-Q --query)'{-Q,--query}'[specify URL query parameter]:query:' \
  '(-f --add-slash)'{-f,--add-slash}'[add a forward-slash to each request]' \
  '(-A --user-agent)'{-A,--user-agent}'[sets the User-Agent]:user-agent:' \
  '-a[sets the User-Agent]:user-agent:' \
  '(-m --methods)'{-m,--methods}'[HTTP methods to use]:methods:(GET POST PUT PATCH DELETE HEAD OPTIONS)' \
  '(-d --data)'{-d,--data}'[request body (POST data)]:data:' \
  '(-p --proxy)'{-p,--proxy}'[proxy to use for requests]:proxy:' \
  '(-P --replay-proxy)'{-P,--replay-proxy}'[replay matched request/responses to this proxy]:proxy:' \
  '(-R --replay-codes)'{-R,--replay-codes}'[status codes to replay to proxy]:codes:' \
  '--timeout[number of seconds before a request times out]:seconds:' \
  '-L[limit total number of requests per directory]:N:' \
  '(-s --status-codes)'{-s,--status-codes}'[status codes to include in output]:codes:' \
  '(-C --filter-status)'{-C,--filter-status}'[filter responses with these status codes]:codes:' \
  '(-S --filter-size)'{-S,--filter-size}'[filter responses with this size]:size:' \
  '(-W --filter-words)'{-W,--filter-words}'[filter responses with this many words]:words:' \
  '(-N --filter-lines)'{-N,--filter-lines}'[filter responses with this many lines]:lines:' \
  '(-X --filter-regex)'{-X,--filter-regex}'[filter responses using a regular expression]:regex:' \
  '(-o --output)'{-o,--output}'[output file path]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode - only print urls]' \
  '--json[emit JSON logs to stdout]' \
  '-v[increase verbosity level (use -vv or more for greater effect)]' \
  '--no-state[disable state tracking]' \
  '--no-recursion[do not scan recursively]' \
  '-n[do not scan recursively]' \
  '--parallel[run parallel feroxbuster instances]:N:' \
  '--scan-limit[limit number of concurrent scans]:N:' \
  '--rate-limit[limit number of requests per second]:rate:' \
  '--time-limit[limit amount of time to run (ex: 5m, 30s, 1h10m)]:time:' \
  '--insecure[disable TLS certificate validation]' \
  '--stdin[read urls from STDIN]' \
  '--silent[suppress all output]' \
  '--auto-bail[automatically stop scanning when too many errors encountered]' \
  '--auto-tune[automatically lower scan rate when too many errors encountered]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]'
