#compdef go-earlybird
# Documentation: https://github.com/americanexpress/earlybird/blob/main/docs/USAGE.md
# go-earlybird - American Express secrets and sensitive data scanner for source code.

local ret=1

_arguments -s -S \
  '-config=[directory where configuration files are stored]:dir:_files -/' \
  '-display-confidence=[lowest confidence level to display]:level:(critical high medium low)' \
  '-display-severity=[lowest severity level to display]:level:(critical high medium low)' \
  '*-enable=[enable individual scanning modules]:module:(ccnumber content filename password-secret)' \
  '-fail-confidence=[lowest confidence level at which to fail]:level:(critical high medium low)' \
  '-fail-severity=[lowest severity level at which to fail]:level:(critical high medium low)' \
  '-file=[output file]:file:_files' \
  '-format=[output format]:format:(console json csv)' \
  '-git=[full URL to a git repo to scan]:url:' \
  '-git-branch=[name of branch to be scanned]:branch:' \
  '-git-commit-stream[use stream IO of git commit log as input]' \
  '-git-project=[full URL to a github org or bitbucket project]:url:' \
  '-git-staged[scan only git staged files]' \
  '-git-tracked[scan only git tracked files]' \
  '-git-user=[username for a private git repository]:user:' \
  '-http=[listen IP and port for HTTP API]:addr:' \
  '-http-config=[path to webserver config JSON file]:file:_files' \
  '-https=[listen IP and port for HTTPS/2 API]:addr:' \
  '-https-cert=[certificate file for TLS]:file:_files' \
  '-https-key=[private key file for TLS]:file:_files' \
  '-ignore-failure[avoid exit code 1 on valid findings]' \
  '-ignore-fp-rules[ignore false positive post-process rules]' \
  '-ignorefile=[patterns file for files to ignore]:file:_files' \
  '-max-file-size=[maximum file size to scan in bytes]:bytes:' \
  '-module-config-file=[absolute path to per-module config json or yaml]:file:_files' \
  '-path=[directory to scan, absolute path only]:dir:_files -/' \
  '-show-full-line[display the full line where the match was found]' \
  '-show-rules-only[display rules that would run without scanning]' \
  '-skip-comments[skip scanning comments in files]' \
  '-stream[use stream IO as input instead of files]' \
  '-strict-jks[check for private keys in the JKS file]' \
  '-suppress[suppress reporting of the secret found]' \
  '-update[update module configurations]' \
  '-verbose[report details about file reads]' \
  '-version[display version information and exit]' \
  '-with-console[print findings in console with JSON report]' \
  '-workers=[set number of workers]:int:' \
  '-worksize=[set line wrap length]:int:' && ret=0

return ret
