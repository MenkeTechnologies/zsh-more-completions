#compdef create-nonoise
# Documentation: https://www.npmjs.com/package/create-nonoise
# Reference accessed: 2026-05-24
# Verified: npm view create-nonoise bin; npm readme Options section.

# Zsh completion for create-nonoise - AI-assisted dev workspace scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--workspace=[workspace kind]:workspace:(new existing-single existing-multi)' \
  '--template=[workspace template]:template:(single-project multi-repo)' \
  '--ai=[comma-separated AI tools]:ai:(claude-code copilot codex cursor gemini-cli)' \
  '--user-name=[developer display name]:name:' \
  '--user-locale=[ISO 639-1 locale code]:locale:' \
  '--reverse[enable reverse-engineering config block]' \
  '--no-reverse[disable reverse-engineering config block]' \
  '--no-git[skip git init]' \
  '--upgrade[refresh bundled skills and re-install graphify]' \
  '--graphify-only[only install graphify CLI integration]' \
  '(-y --yes)'{-y,--yes}'[non-interactive defaults]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[print help]' \
  ':target path:_directories' && ret=0

return ret
