#compdef sflowtool

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '-z[show version]' \
  '-k[keep going on error]' \
  '-D[allow DNS]' \
  '-l[line CSV output]' \
  '-g[grep mode]' \
  '-j[JSON compact]' \
  '-J[JSON pretty]' \
  '-H[HTTP CLF]' \
  '-t[pcap samples]' \
  '-T[pcap discards]' \
  '-M[pcap datagrams]' \
  '-x[redact IPv4]' \
  '-e[peer AS]' \
  '-s[no scaling]' \
  '-S[spoof source]' \
  '-4[IPv4 only]' \
  '-6[IPv6 only]' \
  '-A[IPv4 and IPv6]' \
  '-L[fields]:fields:' \
  '-p[UDP listen port]:port:' \
  '-r[read pcap]:file:_files' \
  '-R[1:N sampling]:n:' \
  '-P[playback file]:file:_files' \
  '-c[NetFlow collector]:host:_hosts' \
  '-d[NetFlow port]:port:' \
  '-N[NetFlow version]:version:(5 9)' \
  '-f[forward host/port]:host/port:' \
  '-v[exclude VLANs]:vlans:' \
  '-V[include VLANs]:vlans:' \
  '-b[bind address]:addr:'
