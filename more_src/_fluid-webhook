#compdef fluid-webhook
# _fluid-webhook — Fluid admission webhook (fluid-cloudnative/fluid)
# upstream: https://github.com/fluid-cloudnative/fluid
# Subcommands + flags from cmd/webhook/app/webhook.go on tip.

_fluid-webhook() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start the Fluid admission webhook'
                version:'print version and exit'
            )
            _describe -t commands 'fluid-webhook command' cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--metrics-addr=[metrics bind address]:host\:port:' \
                        '--development=[enable development mode logging]:bool:(true false)' \
                        '--full-go-profile=[enable full Go profile]:bool:(true false)' \
                        '--webhook-port=[admission webhook bind port]:port:' \
                        '--webhook-cert-dir=[admission webhook TLS cert/key dir]:dir:_files -/' \
                        '--pprof-addr=[pprof bind address]:host\:port:' \
                        '--kube-api-burst=[Kubernetes client burst]:n:'
                    ;;
            esac
            ;;
    esac
}

_fluid-webhook "$@"
