#compdef cupsaccept cupsreject
# Documentation: cupsaccept / cupsreject --help (CUPS 26)
# Source: tell a CUPS destination to accept (or reject) new jobs.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[encrypt connection to the server]' \
    '-h+[server[:port]]:server:_hosts' \
    '-r+[reason message]:reason:' \
    '-U+[username for authentication]:user:_users' \
    '*:destination:' \
    && ret=0

return ret
