#compdef wireguard-vanity-keygen

_arguments -s \
  '(-s --summary)'{-s,--summary}'[show search rate summary]' \
  '(-c --case-sensitive)'{-c,--case-sensitive}'[case-sensitive search]' \
  '(-t --threads)'{-t,--threads}'=[threads]:n:' \
  '(-l --limit)'{-l,--limit}'=[max results per pattern]:n:' \
  '(-T --timeout)'{-T,--timeout}'=[timeout]:duration:' \
  '(-u --update)'{-u,--update}'[update binary]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:search prefix: '
