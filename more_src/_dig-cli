#compdef dig-cli
# _dig-cli — ISC dig DNS lookup utility CLI alias (ISC team, C); custom argparse
# upstream: https://github.com/isc-projects/bind9

_dig-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-4[ipv4]' \
        '-6[ipv6]' \
        '-b+[source ip]:str:' \
        '-c+[class]:c:(IN CH HS)' \
        '-f+[batch file]:file:_files' \
        '-i[reverse mapping]' \
        '-k+[tsig key file]:file:_files' \
        '-m[memory usage debug]' \
        '-p+[port]:port:' \
        '-q+[query name]:str:' \
        '-r[do not read resolv.conf]' \
        '-t+[query type]:t:(A AAAA ANY AXFR CAA CNAME DNSKEY DS HTTPS LOC MX NS NSEC NSEC3 PTR RRSIG SOA SRV SSHFP SVCB TXT URI)' \
        '-u[show times in usec]' \
        '-v[verbose]' \
        '-x+[reverse address]:str:' \
        '-y+[tsig keyspec]:str:' \
        '+aaonly[set aa flag]' \
        '+additional[show additional section]' \
        '+adflag[set ad flag]' \
        '+all[show all output]' \
        '+answer[show answer section]' \
        '+authority[show authority section]' \
        '+bufsize=+[size]:n:' \
        '+cd[checking disabled]' \
        '+class[show class]' \
        '+cmd[show command]' \
        '+comments[show comments]' \
        '+crypto[show crypto]' \
        '+defname[apply default search domain]' \
        '+dnssec[request DNSSEC]' \
        '+do[set DO flag]' \
        '+domain=+[domain]:str:' \
        '+edns=+[version]:n:' \
        '+ednsflags=+[flags]:str:' \
        '+ednsnegotiation[edns negotiation]' \
        '+ednsopt=+[options]:str:' \
        '+expire[request expire]' \
        '+fail[do not retry on failure]' \
        '+identify[show source server]' \
        '+ignore[ignore TC bit]' \
        '+keepalive[edns keepalive]' \
        '+keepopen[keep TCP socket open]' \
        '+multiline[multiline output]' \
        '+ndots=+[n]:n:' \
        '+norecurse[disable recursion]' \
        '+nsid[request NSID]' \
        '+nssearch[query SOA from each authoritative server]' \
        '+onesoa[print one SOA on AXFR]' \
        '+opcode=+[opcode]:o:(QUERY IQUERY STATUS NOTIFY UPDATE)' \
        '+padding=+[bytes]:n:' \
        '+qid=+[id]:n:' \
        '+question[show question section]' \
        '+rdflag[set RD flag]' \
        '+recurse[recurse]' \
        '+retry=+[count]:n:' \
        '+rrcomments[show RR comments]' \
        '+search[apply search list]' \
        '+short[short form]' \
        '+showsearch[show search list]' \
        '+sigchase[chase DNSSEC]' \
        '+split=+[width]:n:' \
        '+stats[show stats]' \
        '+subnet=+[client subnet]:str:' \
        '+tcp[force TCP]' \
        '+timeout=+[seconds]:n:' \
        '+tries=+[count]:n:' \
        '+trust[show trust chain]' \
        '+ttlid[show ttl with output]' \
        '+ttlunits[show ttl units]' \
        '+vc[force TCP]' \
        '+yaml[yaml output]' \
        '+zflag[set Z flag]' \
        '+nocomments[no comments]' \
        '+nostats[no stats]' \
        '+noquestion[no question]' \
        '*:queries:'
}

_dig-cli "$@"
