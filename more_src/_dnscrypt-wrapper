#compdef dnscrypt-wrapper
# Documentation: https://man.archlinux.org/search?q=dnscrypt-wrapper
# Reference accessed: 2026-05-16

_arguments -s \
  '--gen-provider-keypair[generate provider key pair]' \
  '--provider-name=[provider name]:name:' \
  '--ext-address=[external server IP]:ip:' \
  '--nolog[no log storage]' \
  '--dnssec[support DNSSEC]' \
  '--show-provider-publickey[display provider public key]' \
  '--provider-publickey-file=[provider public key]:file:_files' \
  '--gen-crypt-keypair[generate time-limited secret key]' \
  '--crypt-secretkey-file=[crypt secret key]:file:_files' \
  '--gen-cert-file[generate certificate]' \
  '--provider-cert-file=[provider certificate]:file:_files' \
  '--provider-secretkey-file=[provider secret key]:file:_files' \
  '--cert-file-expire-days=[cert expiration days]:days:' \
  '--resolver-address=[upstream resolver]:addr:' \
  '--listen-address=[listen address]:addr:' \
  '(-d --daemonize)'{-d,--daemonize}'[run as daemon]' \
  '(-U --unauthenticated)'{-U,--unauthenticated}'[allow unauthenticated DNS]' \
  '--blacklist-file=[blacklist file]:file:_files' \
  '--test=[test cert validity minutes]:minutes:' \
  '--show-provider-publickey-dns-records[show DNS record instructions]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]'
