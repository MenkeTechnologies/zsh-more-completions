#compdef relion_mask_create
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: create soft-edged solvent masks from a 3D map or geometry

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input map to use for thresholding to generate initial binary mask]:file:_files' \
  '--o=[output mask]:file:_files' \
  '--and=[combine: input AND this map above threshold]:file:_files' \
  '--or=[combine: input OR this map above threshold]:file:_files' \
  '--and_not=[combine: input above threshold AND NOT this map]:file:_files' \
  '--or_not=[combine: input above threshold OR NOT this map]:file:_files' \
  '--ini_threshold=[initial threshold for binarization]:value' \
  '--extend_inimask=[extend initial binary mask this number of pixels]:value' \
  '--width_soft_edge=[width (pixels) of soft edge on the binary mask]:value' \
  '--lowpass=[lowpass filter (A) for the input map prior to binarization]:value' \
  '--angpix=[pixel size (A) for the lowpass filter]:value' \
  '--z_percentage=[box length along center Z axis with good information]:value' \
  '--j=[number of threads]:value' \
  '--box_size=[box size of the mask in pixels]:value' \
  '--inner_radius=[inner radius of the masked region in pixels]:value' \
  '--outer_radius=[outer radius of the mask region in pixels]:value' \
  '--center_x=[X coordinate of the center of the mask (pixels)]:value' \
  '--center_y=[Y coordinate of the center of the mask (pixels)]:value' \
  '--center_z=[Z coordinate of the center of the mask (pixels)]:value' \
  '*:file:_files' && ret=0

return ret
