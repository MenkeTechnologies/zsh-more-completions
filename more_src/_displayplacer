#compdef displayplacer

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'list:show current screen info and possible resolutions'
  'help:show help'
  '--version:show version'
)

_arguments -C \
  '1: :->action' \
  '*::arg:->args' && ret=0

case $state in
  (action) _describe -t actions 'displayplacer action' actions && ret=0 ;;
esac

return ret
