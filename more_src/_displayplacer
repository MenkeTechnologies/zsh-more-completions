#compdef displayplacer
# Documentation: https://github.com/jakehilborn/displayplacer
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# displayplacer (jakehilborn/displayplacer) is configured by passing a series of
# screen profile strings on the command line. The only recognized subcommands are
# `list`, `help`, and `--version`; everything else is a `id:... res:... ...` spec.

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'list:show current screen info and possible resolutions'
  'help:show help'
  '--version:show version'
)

_arguments -C \
  '1: :->action' \
  '*::arg:->args' && ret=0

case $state in
  (action) _describe -t actions 'displayplacer action' actions && ret=0 ;;
esac

return ret
