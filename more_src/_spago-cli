#compdef spago-cli
# _spago-cli — PureScript spago package manager and build tool CLI alias (PureScript team, PureScript); custom argparse
# upstream: https://github.com/purescript/spago

_spago-cli() {
    local -a sub=(
        'init:scaffold spago project'
        'install:install dependencies'
        'build:build project'
        'bundle-app:bundle app into single js'
        'bundle-module:bundle module'
        'docs:generate docs'
        'fetch:fetch dependencies'
        'graph:print package graph'
        'ls:list packages'
        'package-set:print package set info'
        'publish:publish package'
        'registry:registry helpers'
        'repl:start REPL'
        'run:run main module'
        'script:run a script'
        'sources:print source globs'
        'test:run tests'
        'upgrade-set:upgrade package set'
        'verify:verify package set'
        'verify-set:verify set integrity'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-color[no color]' \
        '--global-cache=+[global cache]:c:(skip update)' \
        '--no-psa[no psa]' \
        '--psa[use psa]' \
        '--config=+[config file]:file:_files -g "spago.dhall *.dhall spago.yaml *.yaml"' \
        '-x+[config file]:file:_files -g "spago.dhall *.dhall spago.yaml *.yaml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spago subcommand' sub ;;
        args)
            case $words[1] in
                build|test|run|repl|sources) _arguments \
                    '--watch[watch and rebuild]' \
                    '-w[watch and rebuild]' \
                    '--clear-screen[clear screen]' \
                    '--allow-ignored[allow ignored]' \
                    '--purs-args=+[purs args]:str:' \
                    '--main=+[main module]:str:' \
                    '-m+[main module]:str:' \
                    '--node-args=+[node args]:str:' \
                    '-a+[node args]:str:' \
                    '--exec-args=+[exec args]:str:' \
                    '--cache=+[cache]:c:(skip update)' \
                    '--output=+[output dir]:dir:_files -/' \
                    '-o+[output dir]:dir:_files -/' \
                    '*:source:_files' ;;
                install|upgrade-set|verify|verify-set) _arguments '*:package:' ;;
                docs) _arguments \
                    '--format=+[format]:fmt:(markdown html etags ctags)' \
                    '--no-search[no search]' \
                    '--no-open[no open]' \
                    '--output=+[output dir]:dir:_files -/' \
                    '*:arg:' ;;
                bundle-app|bundle-module) _arguments \
                    '--main=+[main module]:str:' \
                    '-m+[main module]:str:' \
                    '--output=+[output file]:file:_files' \
                    '-t+[output file]:file:_files' \
                    '--platform=+[platform]:p:(browser node)' \
                    '--minify[minify]' \
                    '--source-maps[source maps]' \
                    '--no-build[no build]' \
                    '*:arg:' ;;
                publish) _arguments '*:arg:' ;;
                registry) _arguments \
                    '1:cmd:(login publish update transfer)' \
                    '*:arg:' ;;
                ls) _arguments \
                    '1:cmd:(packages deps)' \
                    '*:arg:' ;;
                init) _arguments \
                    '--name=+[project name]:str:' \
                    '--package-set=+[package set]:str:' ;;
            esac
            ;;
    esac
}

_spago-cli "$@"
