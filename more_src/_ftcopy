#compdef ftcopy
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/ftcopy.html
# Copy FITS files while applying optional filtering and transformation to images and tables

local ret=1

_arguments -s -S \
  'infile=[input file with optional HDU/filter in brackets]:infile:_files' \
  'outfile=[output file, prefix ! to overwrite]:outfile:_files' \
  'copyall=[copy all HDUs or just specified one]:copyall:(yes no)' \
  'clobber=[overwrite output if it exists]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
