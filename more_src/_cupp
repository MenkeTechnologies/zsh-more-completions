#compdef cupp cupp.py
# _cupp — Muris Kurgaš cupp Common User Passwords Profiler tool for generating personalized wordlists (Mebus team, Python); argparse
# upstream: https://github.com/Mebus/cupp

_cupp() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i[interactive mode]' \
        '--interactive[interactive mode]' \
        '-w+[improve dictionary]:file:_files' \
        '--improve=+[improve dictionary]:file:_files' \
        '-l[download huge wordlists]' \
        '--lists[download huge wordlists]' \
        '-a[parse default usernames/passwords]' \
        '--alecto[parse default usernames/passwords]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-c+[config file]:file:_files -g "*.cfg *.ini"' \
        '--config=+[config file]:file:_files -g "*.cfg *.ini"' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[no leet substitutions]' \
        '--no-leet[no leet substitutions]'
}

_cupp "$@"
