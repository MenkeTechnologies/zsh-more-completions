#compdef crawpy
# Documentation: https://github.com/morph3/crawpy
# yet another fast asynchronous content discovery tool written in python

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --url)'{-u,--url}'+[target URL]:url:_urls' \
  '(-w --wordlist)'{-w,--wordlist}'+[wordlist]:file:_files' \
  '(-t --threads)'{-t,--threads}'+[size of the semaphore pool]:n' \
  '(-rc --recursive-codes)'{-rc,--recursive-codes}'+[recursive codes to scan recursively]:codes' \
  '(-rp --recursive-paths)'{-rp,--recursive-paths}'+[recursive paths to scan recursively]:paths' \
  '(-rd --recursive-depth)'{-rd,--recursive-depth}'+[recursive scan depth]:n' \
  '(-e --extension)'{-e,--extension}'+[add extensions at the end (comma-separated)]:ext' \
  '(-to --timeout)'{-to,--timeout}'+[timeouts]:n' \
  '(-follow --follow-redirects)'{-follow,--follow-redirects}'[follow redirects]' \
  '(-ac --auto-calibrate)'{-ac,--auto-calibrate}'[automatically calibrate filter stuff]' \
  '(-fc --filter-code)'{-fc,--filter-code}'+[filter status code]:code' \
  '(-fs --filter-size)'{-fs,--filter-size}'+[filter size]:size' \
  '(-fw --filter-word)'{-fw,--filter-word}'+[filter words]:words' \
  '(-fl --filter-line)'{-fl,--filter-line}'+[filter line]:lines' \
  '(-k --ignore-ssl)'{-k,--ignore-ssl}'[ignore untrusted SSL certificate]' \
  '(-m --max-retry)'{-m,--max-retry}'+[max retry]:n' \
  '*'{-H,--headers}'+[set custom headers]:header' \
  '(-o --output)'{-o,--output}'+[output folder]:dir:_files -/' \
  '(-gr --generate-report)'{-gr,--generate-report}'[generate a report]' \
  '(-l --list)'{-l,--list}'+[takes a list of urls as input]:file:_files' \
  '(-lt --list-threads)'{-lt,--list-threads}'+[number of threads when running with list of urls]:n' \
  '(-s --silent)'{-s,--silent}'[make crawpy not produce output]' \
  '(-X --http-method)'{-X,--http-method}'+[HTTP request method]:method' \
  '(-p --proxy)'{-p,--proxy}'+[proxy server]:proxy' && ret=0

return ret
