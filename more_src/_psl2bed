#compdef psl2bed
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/file-management/conversion/psl2bed.html
# convert PSL alignments to sorted BED (bedops)

local ret=1

_arguments -s -S \
  '--keep-header[preserve header data as BED elements named _header]' \
  '--split[split multi-block records into separate BED elements]' \
  '--do-not-sort[do not sort converted output]' \
  '--max-mem[limit sort memory usage]:mem' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
