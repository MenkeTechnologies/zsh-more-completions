#compdef evt
# _evt — event generator for testing tracee (aquasecurity/tracee)
# upstream: https://github.com/aquasecurity/tracee
# Subcommands from cmd/evt/cmd/ (cobra).

_evt() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                trigger:'trigger events to trace'
                t:'trigger events to trace'
                stress:'orchestrate containers running evt trigger commands'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                trigger|t)
                    _arguments \
                        '(-e --event)'{-e+,--event=}'[event to trigger]:event:' \
                        '(-o --ops)'{-o+,--ops=}'[operations to perform]:n:' \
                        '(-s --sleep)'{-s+,--sleep=}'[sleep time between ops]:duration:' \
                        '(-b --bypass-flags)'{-b,--bypass-flags}'[print tracee bypass flags]' \
                        '(-w --wait-signal)'{-w,--wait-signal}'[wait for SIGUSR1 start signal]' \
                        '--signal-timeout=[timeout for signal wait]:duration:' \
                        '(-p --parallel)'{-p+,--parallel=}'[parallel workers]:n:' ;;
                stress)
                    _arguments \
                        '*--trigger=[trigger spec event[:instances[:ops[:sleep]]]]:spec:' \
                        '--container-image=[container image for stress workers]:image:' \
                        '--dry-run[show what would be executed]' \
                        '--tracee-binary=[tracee binary path]:file:_files' \
                        '--tracee-output=[tracee output path]:file:_files' \
                        '--auto-tracee[automatically start tracee]' \
                        '--metrics[enable metrics collection]' \
                        '--pprof[enable pprof profiling]' \
                        '--pyroscope[enable pyroscope profiling]' \
                        '--keep-tracee[keep tracee running after stress]' \
                        '--wait-before-trigger[wait for user input before triggering]' \
                        '--signal-timeout=[container signal-wait timeout]:duration:' \
                        '--tracee-init-cooldown=[cooldown after tracee starts]:duration:' \
                        '--stress-end-cooldown=[cooldown after stress completes]:duration:' ;;
            esac
            ;;
    esac
}

_evt "$@"
