#compdef gpodder gpo

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'subscribe:add a subscription'
  'rename:rename podcast'
  'unsubscribe:unsubscribe from podcast'
  'enable:enable subscription'
  'disable:disable subscription'
  'info:show podcast info'
  'list:list podcasts'
  'update:check for new episodes'
  'youtube:set youtube preferences'
  'sync:sync episodes to MTP/iPod'
  'pending:list pending episodes'
  'episodes:list episodes for podcast'
  'download:download new episodes'
  'fetch:fetch episodes'
  'delete:remove episodes'
  'mark:mark episodes (new/old/played/unplayed)'
  'apply:apply hooks'
  'webui:start web UI'
  'search:search podcast directory'
  'toplist:show toplist'
  'export:export OPML'
  'import:import OPML'
  'rewrite:rewrite podcast URL'
  'patches:apply local patches'
  'stats:show statistics'
  'rss:add an RSS feed'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--close-after-startup[exit once started]' \
  '--config-dir=[config dir]:dir:_files -/' \
  '(-s --subscribe)'{-s+,--subscribe=}'[subscribe to URL]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gpodder command' commands && ret=0 ;;
esac

return ret
