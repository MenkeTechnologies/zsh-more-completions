#compdef sqlitestudio

# SQLiteStudio: SQLite database manager (Qt GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '--debug[enable debug logging]' \
  '*:databases:_files -g "*.(db|sqlite|sqlite3)"' && ret=0
return ret
