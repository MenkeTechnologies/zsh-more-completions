#compdef maas

# MAAS: Metal-as-a-Service CLI - bare-metal lifecycle management
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'login:authenticate against a MAAS server with an API key'
  'logout:remove the API profile'
  'apikey:obtain an API key for a user'
  'createadmin:create the initial admin user'
  'changepassword:change a user'\''s password'
  'config:show or set top-level config'
  'configauth:configure RBAC and Candid authentication'
  'help:show help for subcommands'
  'init:initialise the MAAS database/region'
  'list:list known API profiles'
  'migrate:run pending database migrations'
  'refresh:refresh the cached API description for a profile'
  'status:show MAAS region/rack controller status'
  'sshkeys:upload/manage user SSH keys'
)

_arguments -C \
  '--help[show help]' \
  '-h[show help]' \
  '--debug[show debug output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'maas command' commands && ret=0 ;;
esac
return ret
