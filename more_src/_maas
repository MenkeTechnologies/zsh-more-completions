#compdef maas
# Documentation: https://man.archlinux.org/search?q=maas
# Reference accessed: 2026-05-16

# MAAS (Metal as a Service): admin CLI for bare metal provisioning
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'login:log in to a MAAS region controller'
  'logout:log out of a MAAS profile'
  'list:list configured profiles'
  'refresh:refresh API description for a profile'
  'init:initialise the MAAS region controller'
  'config:show or set region controller config'
  'apikey:obtain an API key for a user'
  'configauth:configure authentication'
  'createadmin:create a MAAS admin user'
  'changepassword:change a MAAS account password'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[print debug tracebacks]' \
  '--debug-http[print HTTP traffic]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'maas command' commands && ret=0 ;;
esac
return ret
