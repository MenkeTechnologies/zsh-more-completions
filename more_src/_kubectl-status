#compdef kubectl-status
# _kubectl-status — human-friendly status for Kubernetes resources (bergerx/kubectl-status)
# upstream: https://github.com/bergerx/kubectl-status
# Flags from cmd/main.go (cobra/pflag + cli-runtime).

_kubectl-status() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--help-all[show all flags]' \
        '(-w --watch)'{-w,--watch}'[watch resources for changes]' \
        '--local[only show local manifests, no cluster contact]' \
        '--include-owners[include owner resources]' \
        '--include-events[include events]' \
        '--include-matching-services[include matching services]' \
        '--include-matching-ingresses[include matching ingresses]' \
        '--include-application-details[include application details]' \
        '--include-rollout-diffs[include rollout diffs]' \
        '--include-volumes[include volumes]' \
        '--include-managed-fields[include managedFields]' \
        '--include-node-lease[include node Lease objects]' \
        '--include-node-kubelet-api-summary[include node kubelet API summary]' \
        '--include-node-detailed-usage[include node detailed usage]' \
        '--shallow[shallow output mode]' \
        '--deep[deep output mode]' \
        '--color=[when to colorize]:mode:(auto always never)' \
        '--absolute-time[use absolute timestamps instead of "ago"]' \
        '*'{-f+,--filename=}'[file/dir/URL with manifests]:file:_files' \
        '(-A --all-namespaces)'{-A,--all-namespaces}'[query all namespaces]' \
        '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
        '(-l --selector)'{-l+,--selector=}'[label selector]:sel:' \
        '*:resource:'
}

_kubectl-status "$@"
