#compdef pg_autoctl

# Zsh completion for pg_autoctl (pg_auto_failover cluster management)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--pgdata=[path to the Postgres data directory]:directory:_directories' \
  '--monitor=[URI to connect to the monitor]:uri' \
  '--json[output data in JSON format]' \
  '--verbose[increase output detail]' \
  '--version[print version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands
    commands=(
      'run:start the pg_autoctl service'
      'stop:stop the pg_autoctl service'
      'reload:reload configuration'
      'status:display service status'
      'create:initialize a new node or formation'
      'drop:remove a node or formation'
      'show:display information about the cluster'
      'config:manage local configuration'
      'get:retrieve a configuration value or setting'
      'set:update a configuration value or setting'
      'perform:manage manual transitions (failover/switchover)'
      'enable:enable a feature (maintenance/secondary/ssl)'
      'disable:disable a feature'
    )
    _describe -t commands 'command' commands
    ;;
  args)
    case $line[1] in
      create|drop)
        local -a subcommands
        subcommands=(
          'monitor:initialize/drop a monitor node'
          'postgres:initialize/drop a standalone Postgres node'
          'coordinator:initialize/drop a Citus coordinator node'
          'worker:initialize/drop a Citus worker node'
          'formation:create/drop a new formation on the monitor'
        )
        [[ $line[1] == "drop" ]] && subcommands+=('node:drop a specific node from the monitor')
        _describe -t subcommands 'subcommand' subcommands
        ;;
      show)
        local -a subcommands
        subcommands=(
          'state:print the monitor view of node states'
          'events:print the history of events from the monitor'
          'uri:show the connection strings for the nodes'
          'settings:print replication settings for a formation'
          'systemd:generate a systemd service unit file for the node'
          'file:list internal files (config, state, pid)'
        )
        _describe -t subcommands 'subcommand' subcommands
        ;;
      config)
        local -a subcommands
        subcommands=(
          'check:validate the current configuration'
          'get:retrieve a specific configuration value'
          'set:update a configuration value'
        )
        _describe -t subcommands 'subcommand' subcommands
        ;;
      perform)
        local -a subcommands
        subcommands=(
          'failover:trigger an automated failover to the best candidate'
          'switchover:perform a controlled switchover'
          'promotion:promote a specific target node to primary'
        )
        _describe -t subcommands 'subcommand' subcommands
        ;;
      enable|disable)
        local -a subcommands
        subcommands=(
          'maintenance:toggle maintenance mode'
          'secondary:toggle ability to have secondary nodes'
          'ssl:manage SSL configuration'
        )
        _describe -t subcommands 'subcommand' subcommands
        ;;
    esac
    ;;
esac

return ret
