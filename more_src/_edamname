#compdef edamname
# Documentation: https://man.archlinux.org/search?q=edamname
# Reference accessed: 2026-05-16

# EMBOSS edamname: search EDAM ontology
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help message and exit]' \
  '-auto[turn off all prompts and use defaults]' \
  '-stdout[write standard output instead of file]' \
  '-filter[read from stdin, write to stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug output to program.dbg]' \
  '-verbose[report verbose informational messages]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying program messages]' \
  '-version[report current EMBOSS version number]' \
  '-outfile=[output filename]:file:_files' \
  '-sensitive[search definitions and comments, not just preferred name]' \
  '-subclasses[include subclasses of matched terms]' \
  '-obsoletes[include obsolete terms]' \
  '-outformat=[output format]:format:(edam excel html nametable obo text xml tagseq listfile)' \
  '*:query:' && ret=0

return ret
