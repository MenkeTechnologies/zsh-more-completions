#compdef edamname
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/edamname.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS edamname: search EDAM ontology by name
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help message and exit]' \
  '-auto[turn off all prompts and use defaults]' \
  '-stdout[write standard output instead of file]' \
  '-filter[read from stdin, write to stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug output to program.dbg]' \
  '-verbose[report verbose informational messages]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying program messages]' \
  '-version[report current EMBOSS version number]' \
  '-query=[name(s) to search for in ontology]:query:' \
  '-namespace=[restrict search to EDAM namespaces]:namespace:(data entity format identifier operation resource topic)' \
  '-outfile=[output filename]:file:_files' \
  '-sensitive[extend matching to include term definitions]' \
  '-subclasses[include all EDAM sub-classes of matched terms]' \
  '-obsolete[include obsolete terms]' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '-oformat2=[ontology term output format]:format:(obo brief list html xml json excel)' \
  '*:query:' && ret=0

return ret
