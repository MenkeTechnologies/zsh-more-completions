#compdef zonecfg

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-z+[specify zone name]:zone name:' \
  '-f+[read commands from file]:command file:_files' \
  '-r[read-only mode]' \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  && ret=0

local -a subcommands=(
  'add:add a resource to the zone configuration'
  'cancel:cancel the current resource modification'
  'clear:clear a property value'
  'commit:commit the current configuration'
  'create:create a new zone configuration'
  'delete:delete the zone configuration'
  'end:end the current resource specification'
  'exit:exit zonecfg'
  'export:export the zone configuration'
  'help:display help information'
  'info:display zone configuration information'
  'remove:remove a resource from the zone configuration'
  'revert:revert the zone configuration to the last committed state'
  'select:select a resource for modification'
  'set:set a property value'
  'verify:verify the zone configuration'
)

case $state in
  (subcmd)
    _describe -t subcommands 'zonecfg subcommand' subcommands && ret=0
    ;;
  (args)
    local -a resource_types=(
      'fs:filesystem resource'
      'net:network resource'
      'device:device resource'
      'rctl:resource control'
      'attr:attribute resource'
      'dataset:ZFS dataset resource'
      'dedicated-cpu:dedicated CPU resource'
      'capped-cpu:capped CPU resource'
      'capped-memory:capped memory resource'
      'admin:admin resource'
      'anet:automatic network resource'
    )
    case $line[1] in
      (add|remove|select|info)
        _describe -t resource-types 'resource type' resource_types && ret=0
        ;;
      (set)
        local -a properties=(
          'zonename:zone name'
          'zonepath:zone root path'
          'brand:zone brand'
          'autoboot:automatic boot'
          'bootargs:boot arguments'
          'ip-type:IP type'
          'hostid:host ID'
          'pool:resource pool'
          'limitpriv:privilege limit'
          'scheduling-class:scheduling class'
          'max-lwps:maximum LWPs'
          'max-processes:maximum processes'
          'max-shm-memory:maximum shared memory'
          'max-shm-ids:maximum shared memory IDs'
          'max-msg-ids:maximum message IDs'
          'max-sem-ids:maximum semaphore IDs'
          'cpu-shares:CPU shares'
          'max-lofi:maximum lofi devices'
          'fs-allowed:allowed filesystem types'
        )
        _describe -t properties 'property' properties && ret=0
        ;;
      (create)
        _arguments \
          '-b[create blank configuration]' \
          '-a+[create from archive]:archive path:_files' \
          '-t+[create from template zone]:template zone:' \
          && ret=0
        ;;
      (export)
        _arguments '-f+[export to file]:output file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
