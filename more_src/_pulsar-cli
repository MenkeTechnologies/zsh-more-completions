#compdef pulsar-cli pulsar
# _pulsar-cli — Apache Pulsar pulsar-cli CLI command-line frontend wrapping the Apache Pulsar standalone broker discovery websocket functions-worker bookie zookeeper proxy CLI subcommands for running Pulsar services with cluster-name configuration runtime BookKeeper integration topic schema function tenant namespace (Apache Pulsar team, Java); custom argparse
# upstream: https://pulsar.apache.org/

_pulsar-cli() {
    local -a sub=(
        'broker:broker operations'
        'standalone:standalone mode'
        'discovery:discovery service'
        'websocket:websocket proxy'
        'functions-worker:functions worker'
        'bookie:bookie operations'
        'zookeeper:ZooKeeper operations'
        'zookeeper-shell:ZooKeeper shell'
        'proxy:proxy operations'
        'bookkeeper:bookkeeper subcommands'
        'tokens:token operations'
        'compact-topic:compact a topic'
        'transaction-coordinator:transaction coordinator'
        'pulsar-admin:admin operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "broker.conf standalone.conf *.conf"' \
        '--config=+[file]:file:_files -g "*.conf"' \
        '--bookkeeper-config=+[file]:file:_files' \
        '--zookeeper-port=+[port]:n:' \
        '--no-broker[do not start broker]' \
        '--no-functions-worker[no functions worker]' \
        '--no-stream-storage[no stream storage]' \
        '--no-zookeeper[no zookeeper]' \
        '--cluster-name=+[name]:str:' \
        '--zookeeper-servers=+[host:port]:str:' \
        '--configuration-store=+[host:port]:str:' \
        '--global-zookeeper=+[host:port]:str:' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pulsar-cli subcommand' sub ;;
    esac
}

_pulsar-cli "$@"
