#compdef fitsheader
# Documentation: https://docs.astropy.org/en/stable/io/fits/usage/scripts.html#fitsheader
# Source: astropy/astropy astropy/io/fits/scripts/fitsheader.py — print FITS headers (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)--version[show version]' \
    '*'{-e+,--extension=}'[HDU extension(s) to read]:hdu:_default' \
    '*'{-k+,--keyword=}'[keyword(s) to extract]:keyword:_default' \
    '(-f --fitsort)'{-t+,--table=}'[print as a table]:format:_default' \
    '(-t --table)'{-f,--fitsort}'[print using fitsort format]' \
    '(-s --sort)'{-s+,--sort=}'[sort by this keyword]:keyword:_default' \
    '(-c --compressed)'{-c,--compressed}'[include compressed images]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:FITS file:_files -g "*.{fits,fit,fts,fits.gz,fit.gz,fts.gz}"' \
    && ret=0

return ret
