#compdef virt-edit
# _virt-edit — libguestfs virt-edit (edit a file inside a libvirt VM image with $EDITOR; -a disk image, -d domain name, -c libvirt URI, -m mount spec, -e per-line Perl expression for non-interactive edits, -b backup suffix; positional argument is the in-guest path)
# upstream: https://github.com/libguestfs/libguestfs (edit)
# Flags from libguestfs edit/edit.ml on tip.

_virt-edit() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '*-m+[mount spec]:mountspec:' \
        '-e+[Perl expression]:perl:' \
        '-b+[backup suffix]:suffix:' \
        '--format=*[disk format]:fmt:(raw qcow2 vmdk vdi)' \
        '*:file path in guest:'
}

_virt-edit "$@"
