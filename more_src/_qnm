#compdef qnm
# Documentation: https://github.com/ranyitz/qnm
# Reference accessed: 2026-05-20
# Verified: upstream src/cli.ts (commander-based) — commands list, doctor,
# match, homepage and global flags -v/--version, -d, -o, --disable-colors,
# --homepage, --repo, --remote, --no-remote, --sort.

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d)-d[full error messages (debug)]' \
  '(-o --open)'{-o,--open}'[open editor at package.json of chosen module]' \
  '--disable-colors[minimize styling]' \
  '--homepage[open module homepage in default browser]' \
  '--repo[open repository in default browser]' \
  '(--no-remote)--remote[fetch remote registry metadata]' \
  '(--remote)--no-remote[skip remote fetches]' \
  '--sort=[sort order]:order:(size duplicates)' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'qnm command' compadd -- list doctor match homepage
  ;;
rest)
  case $line[1] in
    list)
      _arguments '--deps[list direct deps from package.json]' '--remote[fetch remote data]' '*:: :_default' && ret=0
      ;;
    doctor)
      _arguments '--sort=[sort order]:order:(duplicates size)' '*:: :_default' && ret=0
      ;;
    match)
      _arguments '--remote[fetch remote data]' '1:string pattern:' '*:: :_default' && ret=0
      ;;
    homepage)
      _arguments '1:module:_default' '*:: :_default' && ret=0
      ;;
    *)
      _arguments '*::module name:_default' && ret=0
      ;;
  esac
  ;;
esac

return ret
