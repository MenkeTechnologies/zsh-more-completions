#compdef finterp
# Interpolate a column from one FITS table extension into another

local ret=1

_arguments -s \
  "infile1=[first input FITS file]:file:_files" \
  "infile2=[second input FITS file]:file:_files" \
  "outfile=[output FITS file]:file:_files" \
  "incol=[column to interpolate]:" \
  "sortkey1=[sort key in first file]:" \
  "sortkey2=[sort key in second file]:" \
  "order=[interpolation order]:" \
  "tcheck=[check tolerance]:bool:(yes no)" \
  "extrap=[allow extrapolation]:bool:(yes no)" \
  "copyall=[copy all other extensions]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
