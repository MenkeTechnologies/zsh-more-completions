#compdef outlines
# _outlines — dottxt-ai outlines structured-generation library for LLMs supports JSON regex grammar context-free grammars (dottxt-ai team, Python); argparse
# upstream: https://github.com/dottxt-ai/outlines

_outlines() {
    local -a sub=(
        'generate:generate text from a model'
        'json:JSON-schema constrained generation'
        'regex:regex constrained generation'
        'choice:multiple-choice generation'
        'cfg:context-free grammar generation'
        'tokenize:tokenize input'
        'cache:cache subcommands'
        'config:configuration subcommands'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--model=+[model name]:str:' \
        '-m+[model name]:str:' \
        '--backend=+[backend]:b:(transformers vllm llamacpp openai mlxlm exllamav2)' \
        '--device=+[device]:d:(cpu cuda mps auto)' \
        '--dtype=+[dtype]:t:(float16 float32 bfloat16 auto)' \
        '--api-key=+[API key]:str:' \
        '--api-base=+[API base]:url:_urls' \
        '--temperature=+[F]:f:' \
        '--max-tokens=+[N]:n:' \
        '--top-p=+[F]:f:' \
        '--top-k=+[N]:n:' \
        '--seed=+[N]:n:' \
        '--samples=+[N]:n:' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--no-cache[disable cache]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'outlines subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments \
                    '--prompt=+[prompt]:str:' \
                    '*:prompt:' ;;
                json) _arguments \
                    '--schema=+[schema file]:file:_files -g "*.json"' \
                    '--prompt=+[prompt]:str:' ;;
                regex) _arguments \
                    '--pattern=+[regex pattern]:str:' \
                    '--prompt=+[prompt]:str:' ;;
                choice) _arguments \
                    '--choices=+[choices csv]:str:' \
                    '--prompt=+[prompt]:str:' ;;
                cfg) _arguments \
                    '--grammar=+[grammar file]:file:_files -g "*.gbnf *.lark *.bnf"' \
                    '--prompt=+[prompt]:str:' ;;
                cache) _arguments '1:cache cmd:(clear list path)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
            esac
            ;;
    esac
}

_outlines "$@"
