#compdef asciidoctor-pdf

local -a arguments

arguments=(
    '-a[Document attribute]:attribute=value'
    '--attribute[Document attribute]:attribute=value'
    '-b[Backend]:backend'
    '--backend[Backend]:backend'
    '-d[Document type]:doctype:(article book manpage inline)'
    '--doctype[Document type]:doctype:(article book manpage inline)'
    '-D[Output directory]:dir:_directories'
    '--destination-dir[Output directory]:dir:_directories'
    '-o[Output file]:file:_files'
    '--out-file[Output file]:file:_files'
    '-n[Auto-number sections]'
    '--section-numbers[Auto-number sections]'
    '-r[Require library]:library'
    '--require[Require library]:library'
    '-s[Suppress enclosing document structure]'
    '--no-header-footer[Suppress enclosing document structure]'
    '-S[Safe mode]:mode:(unsafe safe server secure)'
    '--safe-mode[Safe mode]:mode:(unsafe safe server secure)'
    '-T[Template directory]:dir:_directories'
    '--template-dir[Template directory]:dir:_directories'
    '-v[Print version]'
    '--version[Print version]'
    '-h[Show help]'
    '--help[Show help]'
    '-q[Suppress warnings]'
    '--quiet[Suppress warnings]'
    '-t[Enable timing information]'
    '--timings[Enable timing information]'
    '--trace[Include backtrace on errors]'
    '--verbose[Verbose mode]'
    '--failure-level[Minimum failure level]:level:(WARN ERROR INFO)'
    '--theme[PDF theme file or name]:theme:_files -g "*.yml"'
    '--pdf-theme[PDF theme file or name]:theme:_files -g "*.yml"'
    '--pdf-fontsdir[PDF fonts directory]:dir:_directories'
    '*:asciidoc file:_files -g "*.{adoc,asc,asciidoc}"'
)

_arguments -s -S $arguments
