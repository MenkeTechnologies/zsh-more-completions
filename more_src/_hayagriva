#compdef hayagriva
# _hayagriva — citation/bibliography CLI for YAML & BibLaTeX (typst/hayagriva)
# upstream: https://github.com/typst/hayagriva
# Subcommands & flags from src/main.rs (clap).

_hayagriva() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--format=[input file format]:format:(bibtex biblatex yaml)' \
        '--select=[selector to filter entries]:selector:' \
        '(-k --key)'{-k+,--key=}'[CSV of keys to filter by]:keys:' \
        '--show-keys[show keys of filtered entries]' \
        '--show-bound[show bound entries per selector key]' \
        '--no-fmt[do not format output]' \
        '1:bibliography file:_files -g "*.(yml|yaml|bib)"' \
        '2: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'cite:format citations for filtered entries'
                'reference:format a bibliography of filtered entries'
                'styles:list available citation styles'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                cite|reference)
                    _arguments \
                        '--style=[citation style name]:style:' \
                        '--csl=[CSL style file]:file:_files -g "*.csl"' \
                        '--locale=[locale code]:locale:' \
                        '--locales=[CSL locale dir]:dir:_files -/' \
                        '--locators=[CSV of locators]:list:' \
                        '--combined[combine all citations]'
                    ;;
            esac
            ;;
    esac
}

_hayagriva "$@"
