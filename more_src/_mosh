#compdef mosh
# Documentation: https://github.com/mobile-shell/mosh/blob/master/man/mosh.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mosh (mobile shell). Flags from man/mosh.1 OPTIONS section.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--client=[path to client helper (default mosh-client)]:client binary:_files' \
  '--server=[command to run server helper (default mosh-server)]:server command' \
  '--ssh=[OpenSSH command to use (default ssh)]:ssh command' \
  '--ssh-pty[allocate a pty on the SSH connection (default)]' \
  '--no-ssh-pty[do not allocate a pty on the SSH connection]' \
  '--predict=[controls speculative local echo]:mode:(adaptive always never)' \
  '-a[synonym for --predict=always]' \
  '-n[synonym for --predict=never]' \
  '--predict-overwrite[overwrite existing text instead of inserting]' \
  '-o[synonym for --predict-overwrite]' \
  '--family=[address family selection]:family:(inet inet6 auto all prefer-inet prefer-inet6)' \
  '-4[synonym for --family=inet]' \
  '-6[synonym for --family=inet6]' \
  '(-p --port)'{-p+,--port=}'[server-side UDP port or PORT:PORT2 range]:port' \
  '--bind-server=[server bind address selection]:bind:(ssh any)' \
  '--no-init[disable terminal initialization strings]' \
  '--local[run mosh-server locally without SSH]' \
  '--experimental-remote-ip=[method for discovering remote IP]:method:(proxy local remote)' \
  '(- *)--help[display help message]' \
  '(- *)--version[display version information]' \
  '1:remote host:_hosts' \
  '*::remote command:_command_names -e' && ret=0

return ret
