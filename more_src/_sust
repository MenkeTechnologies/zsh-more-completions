#compdef sust
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/sust.c
# output a time-frequency representation of seismic data via the S transform

local ret=1

_arguments -s -S \
  'dt=[dt]:dt:' \
  'fmin=[fmin]:fmin:' \
  'fmax=[fmax]:fmax:' \
  'verbose=[verbose]:verbose:' \
  'n1=[n1]:n1:' \
  'n2=[n2]:n2:' \
  'n3=[n3]:n3:' \
  '*:file:_files' && ret=0

return ret
