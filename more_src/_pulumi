#compdef pulumi

# Zsh completion for Pulumi (infrastructure as code)

local curcontext="$curcontext" state line ret=1

local -a pulumi_commands
pulumi_commands=(
  'about:print information about the Pulumi environment'
  'cancel:cancel a stacks currently running update'
  'config:manage configuration and secrets'
  'console:open the current stack in the Pulumi Console'
  'convert:convert Pulumi programs from one language to another'
  'destroy:destroy all existing resources in the stack'
  'env:manage environments'
  'import:import resources into an existing stack'
  'install:install packages and plugins'
  'login:log in to the Pulumi Cloud'
  'logout:log out of the Pulumi Cloud'
  'logs:show aggregated resource logs for a stack'
  'new:create a new Pulumi project'
  'org:manage Pulumi organizations'
  'package:work with Pulumi packages'
  'plugin:manage language and resource provider plugins'
  'policy:manage resource policies'
  'preview:show a preview of updates to a stacks resources'
  'refresh:refresh the resources in a stack'
  'schema:analyze package schemas'
  'stack:manage stacks'
  'state:edit the current stacks state'
  'up:create or update the resources in a stack'
  'version:print Pulumi version number'
  'watch:continuously update the resources in a stack'
  'whoami:display the current logged-in user'
)

local -a pulumi_global_flags
pulumi_global_flags=(
  '--color=[colorize output]:color mode:(always auto never raw)'
  '--cwd=[run pulumi as if it had been started in the given directory]:directory:_directories'
  '--disable-integrity-checking[disable integrity checking of checkpoint files]'
  '--emoji[enable emojis in the output]'
  '--logflow[flow log settings to child processes]'
  '--logtostderr[log to stderr instead of to files]'
  '--memprofilerate=[rate for memory profiling]:rate:'
  '--non-interactive[disable interactive mode]'
  '--profiling=[output a CPU profile to this path]:file:_files'
  '--tracing=[emit tracing to the specified endpoint]:endpoint:_urls'
  '-v[verbosity level for V logs]:level:'
  '--verbose=[verbosity level for V logs]:level:'
  '-h[help for command]'
  '--help[help for command]'
)

_arguments -s -S \
  $pulumi_global_flags \
  '-e[use with --logtostderr to control log severity]' \
  '--logto=[write logs to this file]:log file:_files' \
  '1:command:_describe -t commands command pulumi_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      up)
        _arguments -s -S \
          $pulumi_global_flags \
          '--config=[config file to use]:config file:_files' \
          '--config-file=[use the given configuration file]:config file:_files' \
          '-c=[config key=value pairs]:key=value:' \
          '--config-path[config keys contain a path element]' \
          '-d[debug mode for this update]' \
          '--debug[debug mode for this update]' \
          '--diff[display operation as a rich diff]' \
          '--exec-agent=[arbitrary string to identify the execution agent]:agent:' \
          '--exec-kind=[set exec kind]:kind:(auto cli)' \
          '-f[skip previews and confirmations]' \
          '--skip-preview[skip previews and confirmations]' \
          '-j[serialize output as JSON]' \
          '--json[serialize output as JSON]' \
          '-m=[optional message to associate with the update]:message:' \
          '--message=[optional message to associate with the update]:message:' \
          '-p=[the maximum number of resources to update in parallel]:parallelism:' \
          '--parallel=[the maximum number of resources to update in parallel]:parallelism:' \
          '--policy-pack=[apply a policy pack]:pack:_files' \
          '--policy-pack-config=[config file for a policy pack]:config:_files' \
          '-r[refresh the state before performing the update]' \
          '--refresh[refresh the state before performing the update]' \
          '--replace=[specify resources to replace]:urn:' \
          '--secrets-provider=[the type of secrets provider]:provider:(default passphrase awskms azurekeyvault gcpkms hashivault)' \
          '--show-config[show configuration keys and variables]' \
          '--show-reads[show resources that are being read]' \
          '--show-replacement-steps[show detailed replacement steps]' \
          '--show-sames[show resources that are not updated]' \
          '-s=[the name of the stack to operate on]:stack:' \
          '--stack=[the name of the stack to operate on]:stack:' \
          '--suppress-outputs[suppress output values]' \
          '--suppress-permalink[suppress the state permalink]' \
          '-t=[specify a single resource URN to update]:urn:' \
          '--target=[specify a single resource URN to update]:urn:' \
          '--target-dependents[allow updating of dependents]' \
          '--target-replace=[specify a resource to replace]:urn:' \
          '-y[automatically approve and perform the update]' \
          '--yes[automatically approve and perform the update]' \
          '*:path:_files' && ret=0
        ;;
      preview)
        _arguments -s -S \
          $pulumi_global_flags \
          '--config=[config key=value pairs]:key=value:' \
          '--config-file=[use the given configuration file]:config file:_files' \
          '--config-path[config keys contain a path element]' \
          '-d[debug mode]' \
          '--debug[debug mode]' \
          '--diff[display operation as a rich diff]' \
          '--exec-agent=[identify the execution agent]:agent:' \
          '--exec-kind=[set exec kind]:kind:(auto cli)' \
          '-j[serialize output as JSON]' \
          '--json[serialize output as JSON]' \
          '-m=[optional message]:message:' \
          '--message=[optional message]:message:' \
          '-p=[parallel resource operations]:parallelism:' \
          '--parallel=[parallel resource operations]:parallelism:' \
          '--policy-pack=[apply a policy pack]:pack:_files' \
          '--policy-pack-config=[config file for a policy pack]:config:_files' \
          '-r[refresh the state before preview]' \
          '--refresh[refresh the state before preview]' \
          '--replace=[specify resources to replace]:urn:' \
          '--show-config[show configuration keys]' \
          '--show-reads[show resources being read]' \
          '--show-replacement-steps[show detailed replacement steps]' \
          '--show-sames[show unchanged resources]' \
          '-s=[stack name]:stack:' \
          '--stack=[stack name]:stack:' \
          '--suppress-outputs[suppress output values]' \
          '--suppress-permalink[suppress the state permalink]' \
          '-t=[target a specific resource]:urn:' \
          '--target=[target a specific resource]:urn:' \
          '--target-dependents[allow updating dependents]' \
          '--target-replace=[target a specific resource for replacement]:urn:' \
          '*:path:_files' && ret=0
        ;;
      destroy)
        _arguments -s -S \
          $pulumi_global_flags \
          '--config-file=[use the given configuration file]:config file:_files' \
          '-d[debug mode]' \
          '--debug[debug mode]' \
          '--diff[display as a rich diff]' \
          '--exec-agent=[identify the execution agent]:agent:' \
          '--exec-kind=[set exec kind]:kind:(auto cli)' \
          '-j[serialize output as JSON]' \
          '--json[serialize output as JSON]' \
          '-m=[optional message]:message:' \
          '--message=[optional message]:message:' \
          '-p=[parallel resource operations]:parallelism:' \
          '--parallel=[parallel resource operations]:parallelism:' \
          '-r[refresh the state before destroying]' \
          '--refresh[refresh the state before destroying]' \
          '--show-config[show configuration keys]' \
          '-s=[stack name]:stack:' \
          '--stack=[stack name]:stack:' \
          '--suppress-outputs[suppress output values]' \
          '--suppress-permalink[suppress the state permalink]' \
          '-t=[target a specific resource]:urn:' \
          '--target=[target a specific resource]:urn:' \
          '--target-dependents[allow destroying dependents]' \
          '-y[automatically approve]' \
          '--yes[automatically approve]' \
          '-f[skip previews and confirmations]' \
          '--skip-preview[skip previews and confirmations]' && ret=0
        ;;
      refresh)
        _arguments -s -S \
          $pulumi_global_flags \
          '--config-file=[use the given configuration file]:config file:_files' \
          '-d[debug mode]' \
          '--debug[debug mode]' \
          '--diff[display as a rich diff]' \
          '--exec-agent=[identify the execution agent]:agent:' \
          '--exec-kind=[set exec kind]:kind:(auto cli)' \
          '-j[serialize output as JSON]' \
          '--json[serialize output as JSON]' \
          '-m=[optional message]:message:' \
          '--message=[optional message]:message:' \
          '-p=[parallel resource operations]:parallelism:' \
          '--parallel=[parallel resource operations]:parallelism:' \
          '--show-replacement-steps[show detailed replacement steps]' \
          '--show-sames[show unchanged resources]' \
          '-s=[stack name]:stack:' \
          '--stack=[stack name]:stack:' \
          '--suppress-outputs[suppress output values]' \
          '--suppress-permalink[suppress the state permalink]' \
          '-t=[target a specific resource]:urn:' \
          '--target=[target a specific resource]:urn:' \
          '-y[automatically approve]' \
          '--yes[automatically approve]' \
          '-f[skip previews]' \
          '--skip-preview[skip previews]' && ret=0
        ;;
      new)
        _arguments -s -S \
          $pulumi_global_flags \
          '--config=[config key=value pairs]:key=value:' \
          '--config-path[config keys contain a path element]' \
          '-d=[project description]:description:' \
          '--description=[project description]:description:' \
          '--dir=[the location to place the generated project]:directory:_directories' \
          '-f[skip prompts and use defaults]' \
          '--force[skip prompts and use defaults]' \
          '-g[install dependencies after project creation]' \
          '--generate-only[generate project files but skip creating stack]' \
          '-n=[project name]:name:' \
          '--name=[project name]:name:' \
          '-o[use offline mode for templates]' \
          '--offline[use offline mode for templates]' \
          '--secrets-provider=[secrets provider]:provider:(default passphrase awskms azurekeyvault gcpkms hashivault)' \
          '-s=[stack name]:stack:' \
          '--stack=[stack name]:stack:' \
          '-y[skip prompts and accept defaults]' \
          '--yes[skip prompts and accept defaults]' \
          '1:template:' && ret=0
        ;;
      stack)
        local -a stack_commands
        stack_commands=(
          'change-secrets-provider:change the secrets provider for a stack'
          'export:export a stacks state to standard output'
          'graph:export a stacks dependency graph'
          'history:display history for a stack'
          'import:import a deployment from standard input'
          'init:create an empty stack'
          'ls:list stacks'
          'output:show a stacks output properties'
          'rename:rename an existing stack'
          'rm:remove a stack and its configuration'
          'select:switch the current workspace to the given stack'
          'tag:manage stack tags'
          'unprotect:unprotect resources in a stacks state'
        )
        _arguments -s -S \
          $pulumi_global_flags \
          '1:stack command:_describe -t commands command stack_commands' \
          '*::stack args:->stack_args' && ret=0
        case "$state" in
          stack_args)
            case "${line[1]}" in
              init)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '--copy-config-from=[copy config from another stack]:stack:' \
                  '--no-select[do not select the stack after creation]' \
                  '--secrets-provider=[secrets provider]:provider:(default passphrase awskms azurekeyvault gcpkms hashivault)' \
                  '1:stack name:' && ret=0
                ;;
              ls)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '-a[list stacks across all projects]' \
                  '--all[list stacks across all projects]' \
                  '-j[serialize output as JSON]' \
                  '--json[serialize output as JSON]' \
                  '-o=[organization to list stacks for]:organization:' \
                  '--organization=[organization to list stacks for]:organization:' \
                  '-p=[project to list stacks for]:project:' \
                  '--project=[project to list stacks for]:project:' \
                  '-t=[tag filter]:tag=value:' \
                  '--tag=[tag filter]:tag=value:' && ret=0
                ;;
              rm)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '-f[force the removal]' \
                  '--force[force the removal]' \
                  '--preserve-config[do not delete config file]' \
                  '-y[skip confirmation]' \
                  '--yes[skip confirmation]' \
                  '-s=[stack name]:stack:' \
                  '--stack=[stack name]:stack:' && ret=0
                ;;
              select)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '--create[create the stack if it does not exist]' \
                  '--secrets-provider=[secrets provider]:provider:(default passphrase awskms azurekeyvault gcpkms hashivault)' \
                  '1:stack name:' && ret=0
                ;;
              output)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '-j[serialize output as JSON]' \
                  '--json[serialize output as JSON]' \
                  '-s=[stack name]:stack:' \
                  '--stack=[stack name]:stack:' \
                  '--show-secrets[display secret output values]' \
                  '1:property name:' && ret=0
                ;;
              export)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '--file=[export to a file]:file:_files' \
                  '--show-secrets[export secret values in plaintext]' \
                  '-s=[stack name]:stack:' \
                  '--stack=[stack name]:stack:' \
                  '--version=[export a specific version]:version:' && ret=0
                ;;
              import)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '--file=[import from a file]:file:_files' \
                  '-f[force the import]' \
                  '--force[force the import]' \
                  '-s=[stack name]:stack:' \
                  '--stack=[stack name]:stack:' && ret=0
                ;;
              history)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '-j[serialize output as JSON]' \
                  '--json[serialize output as JSON]' \
                  '--full-dates[show full dates]' \
                  '--page=[page number]:page:' \
                  '--page-size=[page size]:size:' \
                  '--show-secrets[show secret values in output]' \
                  '-s=[stack name]:stack:' \
                  '--stack=[stack name]:stack:' && ret=0
                ;;
              *)
                _arguments -s -S $pulumi_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      config)
        local -a config_commands
        config_commands=(
          'cp:copy config to another stack'
          'env:manage stack environments'
          'get:get a single configuration value'
          'refresh:update the local configuration based on the most recent deployment'
          'rm:remove a configuration value'
          'rm-all:remove multiple configuration values'
          'set:set a single configuration value'
          'set-all:set multiple configuration values'
        )
        _arguments -s -S \
          $pulumi_global_flags \
          '--config-file=[use the given configuration file]:config file:_files' \
          '-j[serialize output as JSON]' \
          '--json[serialize output as JSON]' \
          '--show-secrets[show secret values in output]' \
          '-s=[stack name]:stack:' \
          '--stack=[stack name]:stack:' \
          '1:config command:_describe -t commands command config_commands' \
          '*::config args:->config_args' && ret=0
        case "$state" in
          config_args)
            case "${line[1]}" in
              set)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '--path[config key is a path]' \
                  '--plaintext[store as plaintext]' \
                  '--secret[store as encrypted secret]' \
                  '-s=[stack name]:stack:' \
                  '--stack=[stack name]:stack:' \
                  '1:key:' \
                  '2:value:' && ret=0
                ;;
              get)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '-j[serialize output as JSON]' \
                  '--json[serialize output as JSON]' \
                  '--path[config key is a path]' \
                  '-s=[stack name]:stack:' \
                  '--stack=[stack name]:stack:' \
                  '1:key:' && ret=0
                ;;
              rm)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '--path[config key is a path]' \
                  '-s=[stack name]:stack:' \
                  '--stack=[stack name]:stack:' \
                  '1:key:' && ret=0
                ;;
              *)
                _arguments -s -S $pulumi_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      plugin)
        local -a plugin_commands
        plugin_commands=(
          'install:install one or more plugins'
          'ls:list plugins'
          'rm:remove one or more plugins'
        )
        _arguments -s -S \
          $pulumi_global_flags \
          '1:plugin command:_describe -t commands command plugin_commands' \
          '*::plugin args:->plugin_args' && ret=0
        case "$state" in
          plugin_args)
            case "${line[1]}" in
              install)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '--exact[force installation of exact version]' \
                  '-f[install from a tarball]:file:_files' \
                  '--file=[install from a tarball]:file:_files' \
                  '--reinstall[reinstall even if already installed]' \
                  '--server=[server to download from]:server url:_urls' \
                  '1:kind:(resource analyzer language)' \
                  '2:name:' \
                  '3:version:' && ret=0
                ;;
              ls)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '-j[serialize output as JSON]' \
                  '--json[serialize output as JSON]' \
                  '-p[list only project plugins]' \
                  '--project[list only project plugins]' && ret=0
                ;;
              rm)
                _arguments -s -S \
                  $pulumi_global_flags \
                  '-a[remove all plugins]' \
                  '--all[remove all plugins]' \
                  '-y[skip confirmation]' \
                  '--yes[skip confirmation]' \
                  '1:kind:(resource analyzer language)' \
                  '2:name:' \
                  '3:version:' && ret=0
                ;;
              *)
                _default && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      import)
        _arguments -s -S \
          $pulumi_global_flags \
          '--config-file=[use the given configuration file]:config file:_files' \
          '-d[debug mode]' \
          '--debug[debug mode]' \
          '-f=[import from a file]:file:_files' \
          '--file=[import from a file]:file:_files' \
          '--from=[import from a specific source]:source:' \
          '--generate-code[generate resource declaration code]:bool:(true false)' \
          '-o=[output path for generated code]:output:_files' \
          '--out=[output path for generated code]:output:_files' \
          '-p=[parallel operations]:parallelism:' \
          '--parallel=[parallel operations]:parallelism:' \
          '--parent=[parent resource URN]:urn:' \
          '--protect[mark imported resources as protected]:bool:(true false)' \
          '--properties=[list of properties to include]:properties:' \
          '--provider=[provider for the imported resource]:provider:' \
          '-s=[stack name]:stack:' \
          '--stack=[stack name]:stack:' \
          '--suppress-outputs[suppress output values]' \
          '-y[automatically approve]' \
          '--yes[automatically approve]' \
          '-f[skip previews]' \
          '--skip-preview[skip previews]' \
          '1:type:' \
          '2:name:' \
          '3:id:' && ret=0
        ;;
      login)
        _arguments -s -S \
          $pulumi_global_flags \
          '-c=[cloud URL]:url:_urls' \
          '--cloud-url=[cloud URL]:url:_urls' \
          '--default-org=[default organization]:organization:' \
          '-l[use local mode]' \
          '--local[use local mode]' \
          '1:backend URL:_urls' && ret=0
        ;;
      logout)
        _arguments -s -S \
          $pulumi_global_flags \
          '-a[logout from all backends]' \
          '--all[logout from all backends]' \
          '-c=[cloud URL]:url:_urls' \
          '--cloud-url=[cloud URL]:url:_urls' \
          '-l[use local mode]' \
          '--local[use local mode]' \
          '1:backend URL:_urls' && ret=0
        ;;
      logs)
        _arguments -s -S \
          $pulumi_global_flags \
          '-f[follow the log stream]' \
          '--follow[follow the log stream]' \
          '-j[serialize output as JSON]' \
          '--json[serialize output as JSON]' \
          '-r=[resource name filter]:resource:' \
          '--resource=[resource name filter]:resource:' \
          '--since=[only return logs newer than]:duration:' \
          '-s=[stack name]:stack:' \
          '--stack=[stack name]:stack:' && ret=0
        ;;
      watch)
        _arguments -s -S \
          $pulumi_global_flags \
          '--config=[config key=value pairs]:key=value:' \
          '--config-file=[use the given configuration file]:config file:_files' \
          '--config-path[config keys contain a path element]' \
          '-d[debug mode]' \
          '--debug[debug mode]' \
          '--diff[display as a rich diff]' \
          '-m=[optional message]:message:' \
          '--message=[optional message]:message:' \
          '-p=[parallel operations]:parallelism:' \
          '--parallel=[parallel operations]:parallelism:' \
          '--path=[specify one or more paths to watch]:path:_files' \
          '--policy-pack=[apply a policy pack]:pack:_files' \
          '--policy-pack-config=[config file for a policy pack]:config:_files' \
          '-r[refresh the state before updating]' \
          '--refresh[refresh the state before updating]' \
          '--secrets-provider=[secrets provider]:provider:(default passphrase awskms azurekeyvault gcpkms hashivault)' \
          '--show-config[show configuration keys]' \
          '--show-reads[show resources being read]' \
          '--show-replacement-steps[show detailed replacement steps]' \
          '--show-sames[show unchanged resources]' \
          '-s=[stack name]:stack:' \
          '--stack=[stack name]:stack:' && ret=0
        ;;
      cancel)
        _arguments -s -S \
          $pulumi_global_flags \
          '-s=[stack name]:stack:' \
          '--stack=[stack name]:stack:' \
          '-y[skip confirmation]' \
          '--yes[skip confirmation]' && ret=0
        ;;
      state)
        local -a state_commands
        state_commands=(
          'delete:deletes a resource from the stacks state'
          'move:move resources from one stack to another'
          'rename:renames a resource in the stacks state'
          'unprotect:unprotect resources in the stacks state'
          'upgrade:migrates the current backend to the latest version'
        )
        _arguments -s -S \
          $pulumi_global_flags \
          '1:state command:_describe -t commands command state_commands' \
          '*:args:' && ret=0
        ;;
      whoami)
        _arguments -s -S \
          $pulumi_global_flags \
          '-v[display detailed user information]' \
          '--verbose[display detailed user information]' \
          '-j[serialize output as JSON]' \
          '--json[serialize output as JSON]' && ret=0
        ;;
      about)
        _arguments -s -S \
          $pulumi_global_flags \
          '-j[serialize output as JSON]' \
          '--json[serialize output as JSON]' \
          '-t[print only the transitive dependencies]:bool:(true false)' \
          '--transitive[print only the transitive dependencies]:bool:(true false)' \
          '-s=[stack name]:stack:' \
          '--stack=[stack name]:stack:' && ret=0
        ;;
      *)
        _arguments -s -S \
          $pulumi_global_flags \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
