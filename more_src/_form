#compdef form
# Documentation: https://github.com/djmcgill/form
# form: split a single Rust file of nested modules into a directory tree (svd2rust)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-i --input)'{-i,--input}'=[input file (defaults to stdin)]:file:_files' \
  '(-o --outdir)'{-o,--outdir}'=[output directory]:dir:_files -/' \
  '-f[format output with prettyplease]' && ret=0

return ret
