#compdef vorta

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--create[create a backup]' \
  '--list[list archives]' \
  '--foreground[run in foreground]' \
  '--daemonize[run as daemon]' && ret=0

return ret
