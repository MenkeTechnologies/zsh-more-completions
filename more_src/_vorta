#compdef vorta
# Documentation: https://man.archlinux.org/search?q=vorta
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--create[create a backup]' \
  '--list[list archives]' \
  '--foreground[run in foreground]' \
  '--daemonize[run as daemon]' && ret=0

return ret
