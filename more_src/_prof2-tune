#compdef prof2-tune
# Documentation: https://professor.hepforge.org/docs.sphinx213/prof2-tune.html
# prof2-tune - Professor2 chi2 minimisation tuning against reference data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--wfile=[weight file with per-bin chi2 weights]:file:_files' \
  '--output=[prefix for output files]:prefix:' \
  '--limits=[text file with parameter limits and fixed parameters]:file:_files' \
  '--scan=[brute-force scan N points to find minimiser start point]:N:' \
  '--minos[run Minos algorithm after minimisation]' \
  '--limit-errs[re-read runsdir to regularize error interpolations]' \
  '(-g --gradient)'{-g,--gradient}'[run minimisation with analytic gradient]' \
  '(-v --debug)'{-v,--debug}'[enable debug messages]' \
  '(-q --quiet)'{-q,--quiet}'[suppress messages]' \
  '(-s --strategy)'{-s,--strategy}'=[Minuit strategy 0/1/2]:strategy:(0 1 2)' \
  '--filter[filter out data bins with zero error]' \
  '1:refdir:_files -/' \
  '2:ipolfile:_files' \
  '3:runsdir:_files -/' && ret=0

return ret
