#compdef duplicacy-cli duplicacy
# _duplicacy-cli — Gilbert Chen Duplicacy lock-free deduplication backup CLI alias (gilbertchen team, Go); urfave/cli
# upstream: https://github.com/gilbertchen/duplicacy

_duplicacy-cli() {
    local -a sub=(
        'init:initialize new repository'
        'list:list snapshots'
        'check:check repository integrity'
        'cat:print snapshot file'
        'diff:diff two snapshots'
        'restore:restore from snapshot'
        'backup:create a new snapshot'
        'prune:prune old snapshots'
        'copy:copy snapshots between storages'
        'history:show file history'
        'info:show storage info'
        'preference:set preferences'
        'add:add named storage'
        'set:set repository options'
        'password:change password'
        'benchmark:run benchmark'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-verbose[verbose]' \
        '-debug[debug]' \
        '-log[log mode]' \
        '-stack[print stack on error]' \
        '-d[debug]' \
        '-suppress=+[suppress messages]:str:' \
        '-profile=+[profile addr]:str:' \
        '-comment=+[comment]:str:' \
        '-background[run in background]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'duplicacy subcommand' sub ;;
        args)
            case $words[1] in
                backup) _arguments \
                    '-stats[show backup statistics]' \
                    '-threads=+[threads]:n:' \
                    '-limit-rate=+[kb/s]:n:' \
                    '-dry-run[dry run]' \
                    '-vss[use vss snapshot]' \
                    '-vss-timeout=+[seconds]:n:' \
                    '-tag=+[tag]:str:' \
                    '-storage=+[storage]:str:' \
                    '-hash[force hashing]' \
                    '-quote[quote arguments]' \
                    '-enum-only[enum only]' \
                    '-upload-rate=+[kb/s]:n:' \
                    '-no-include-cache[no cache exclude]' ;;
                restore) _arguments \
                    '-r+[revision]:n:' \
                    '-stats[show stats]' \
                    '-threads=+[threads]:n:' \
                    '-overwrite[overwrite existing]' \
                    '-delete[delete files not in snapshot]' \
                    '-quote[quote arguments]' \
                    '-storage=+[storage]:str:' \
                    '-ignore-owner[ignore owner]' \
                    '-key=+[encryption key]:str:' ;;
                prune) _arguments \
                    '-r+[revision]:n:' \
                    '-id=+[snapshot id]:str:' \
                    '-tag=+[tag]:str:' \
                    '-keep=+[retention spec]:str:' \
                    '-storage=+[storage]:str:' \
                    '-exhaustive[exhaustive search]' \
                    '-exclusive[exclusive lock]' \
                    '-dry-run[dry run]' \
                    '-delete-only[delete only]' \
                    '-collect-only[collect only]' \
                    '-ignore=+[snapshot id]:str:' \
                    '-threads=+[threads]:n:' ;;
                init) _arguments \
                    '1:repository id:' \
                    '2:storage url:' \
                    '-encrypt[encrypt repository]' \
                    '-e[encrypt repository]' \
                    '-chunk-size=+[size]:n:' \
                    '-c+[chunk size]:n:' \
                    '-min-chunk-size=+[size]:n:' \
                    '-max-chunk-size=+[size]:n:' \
                    '-iterations=+[iterations]:n:' \
                    '-pref-dir=+[preference dir]:dir:_files -/' \
                    '-storage-name=+[name]:str:' \
                    '-no-bit-identical-chunks[no bit-identical chunks]' \
                    '-repository=+[repository path]:dir:_files -/' ;;
                copy) _arguments \
                    '-r+[revision]:n:' \
                    '-id=+[snapshot id]:str:' \
                    '-from=+[from storage]:str:' \
                    '-to=+[to storage]:str:' \
                    '-threads=+[threads]:n:' \
                    '-download-threads=+[threads]:n:' \
                    '-upload-threads=+[threads]:n:' \
                    '-key=+[key]:str:' \
                    '-bit-identical[bit identical]' ;;
                check) _arguments \
                    '-all[check all snapshots]' \
                    '-a[check all snapshots]' \
                    '-id=+[snapshot id]:str:' \
                    '-r+[revision]:n:' \
                    '-tag=+[tag]:str:' \
                    '-files[check files]' \
                    '-chunks[check chunks]' \
                    '-fossils[show fossils]' \
                    '-resurrect[resurrect fossils]' \
                    '-storage=+[storage]:str:' \
                    '-threads=+[threads]:n:' ;;
            esac
            ;;
    esac
}

_duplicacy-cli "$@"
