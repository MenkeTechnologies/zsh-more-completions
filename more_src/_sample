#compdef sample

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-wait[wait until process exists, then start sampling]' \
  '-mayDie[read symbol info right away]' \
  '-fullPaths[show full paths to source files]' \
  '-e[open the output in TextEdit]' \
  {-f+,-file+}'[output filename]:file:_files' \
  '1:pid or process name:_pids' \
  '2::duration in seconds:' \
  '3::sampling interval in ms:' && ret=0

return ret
