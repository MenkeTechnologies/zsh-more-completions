#compdef kafka-storage
# Documentation: https://kafka.apache.org/documentation/ (kafka-storage.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '(- *)'{-h,--help}'[Show this help message and exit]'
    '1:command:(info format version-mapping feature-dependencies random-uuid)'
    {--config,-c}'[The Kafka configuration file to use]:file:_files'
    {--cluster-id,-t}'[The cluster ID to use]:id:'
    {--add-scram,-S}'[A SCRAM_CREDENTIAL to add to the __cluster_metadata log]:scram:'
    {--ignore-formatted,-g}'[Skip over already formatted directories rather than failing]'
    {--release-version,-r}'[The release version to use for the initial feature settings]:version:'
    {--feature,-f}'[Set a specific feature in feature=level format]:feature:'
    {--standalone,-s}'[Initialize a controller as a single-node dynamic quorum]'
    {--no-initial-controllers,-N}'[Initialize a server without specifying a dynamic quorum]'
    {--initial-controllers,-I}'[Initialize a server with the specified dynamic quorum]:voters:'
)

_arguments -s -S $arguments
