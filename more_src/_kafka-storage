#compdef kafka-storage
# Documentation: https://man.archlinux.org/search?q=kafka-storage
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '1:command:(info format random-uuid)'
    '--config[Server config file]:file:_files'
    '--cluster-id[Cluster ID]:id:'
    '--release-version[Release version]:version:'
    '--add-scram[Add SCRAM credential in format MECHANISM=\[key=value,...\]]:scram:'
    '--ignore-formatted[Ignore already formatted directories]'
    '--standalone[Use standalone mode for single-node clusters]'
    '--initial-controllers[Initial controller quorum voters]:voters:'
)

_arguments -s -S $arguments
