#compdef zpool-labelclear
# _zpool-labelclear — OpenZFS zpool labelclear (remove the ZFS uberblock + label written on the named raw device; -f forces destruction even if pool is active; positional argument is the block device whose labels should be wiped)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_labelclear) on tip.

_zpool-labelclear() {
    _arguments \
        '-f[force]' \
        '1:device:_files -g "/dev/*"'
}

_zpool-labelclear "$@"
