#compdef helix hx

# Zsh completion for Helix editor

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '(-v)'-v'[increase logging verbosity]' \
  '(-g --grammar)'{-g,--grammar}'[fetch or build tree-sitter grammars]:action:(fetch build)' \
  '--health[check health of language config]:language:' \
  '--tutor[open the tutorial]' \
  '-w[specify initial window width]:width:' \
  '--vsplit[open in vertical split]' \
  '--hsplit[open in horizontal split]' \
  '-c[specify config file]:config:_files' \
  '--log[specify log file]:file:_files' \
  '--config[specify config file]:config:_files' \
  '--working-dir[specify working directory]:directory:_files -/' \
  '*:file:_files' && return 0
