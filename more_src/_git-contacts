#compdef git-contacts
# Documentation: https://github.com/git/git/blob/master/contrib/contacts/git-contacts
# Source: git/git contrib/contacts/git-contacts — list people who might be interested in a patch (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*:file or rev-list arg:_files' \
    && ret=0

return ret
