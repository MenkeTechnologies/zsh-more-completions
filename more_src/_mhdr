#compdef mhdr

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[print specific header]:header name:(From To Cc Bcc Subject Date Message-Id In-Reply-To References Content-Type)' \
  '-p[decode MIME encoded-words]' \
  '-d[decode RFC 2047 headers]' \
  '-A[print all headers]' \
  '-M[print MIME structure]' \
  '*:message:_files' && ret=0

return ret
