#compdef mhdr
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/mhdr.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h+[colon-separated header list to print]:headers:' \
  '-p+[extract RFC 2045 parameter]:parameter:' \
  '-d[decode RFC 2047 headers]' \
  '-H[prefix output lines with filename]' \
  '-M[search all occurrences (default: first only)]' \
  '(-D)-A[scan headers for RFC 5322 addresses, one per line]' \
  '(-A)-D[treat header as RFC 5322 date, print as Unix timestamp]' \
  '*:message:_files' && ret=0

return ret
