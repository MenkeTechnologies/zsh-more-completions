#compdef jenkinsfile-runner

# Jenkinsfile Runner: run a Jenkinsfile without a full Jenkins server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-w[Jenkins WAR file]:file:_files -g "*.war"' \
  '--jenkins-war=[Jenkins WAR file]:file:_files -g "*.war"' \
  '-p[plugins dir]:dir:_files -/' \
  '--plugins=[plugins dir]:dir:_files -/' \
  '-f[Jenkinsfile path]:file:_files' \
  '--file=[Jenkinsfile path]:file:_files' \
  '-jv[Jenkins HTTP port]:port:' \
  '--jenkins-http-port=[Jenkins HTTP port]:port:' \
  '--no-sandbox[run sandboxed groovy off]' \
  '-cli[run Jenkins CLI]:cmd:' \
  '-a[run with args]:args:' \
  '*::jenkinsfile-runner args:_files' && ret=0
return ret
