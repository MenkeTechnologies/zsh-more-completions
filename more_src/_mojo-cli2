# _mojo-cli2 — Modular Chris Lattner Mojo Lang mojo-cli2 CLI command-line frontend wrapping the Mojo new programming language that bridges the gap between research and production by combining the best of Python syntax with systems programming and metaprogramming written in Mojo originally Chris Lattner Tim Davis now Modular Inc Mojo is a programming language that fundamentally reinvents Python for an era of AI hardware new programming language designed to combine the usability of Python with the performance of C MLIR multi-level intermediate representation kernel-fusion automatic-differentiation static-typing struct fn def trait param compile-time variants run build doc format package test install repl debug Modular-AI-engine MAX (Modular Chris Lattner Tim Davis Mojo Lang team, Mojo); custom argparse
# upstream: https://www.modular.com/mojo

_mojo-cli2() {
    local -a sub=(
        'build:Compile Mojo program'
        'doc:Generate documentation'
        'format:Format Mojo source code'
        'package:Package Mojo modules'
        'repl:Open Mojo REPL'
        'run:Compile and run Mojo program'
        'test:Run tests in modules/files'
        'help:show help'
        'version:show version'
        'completion:generate shell completion'
        'debug:Debug Mojo program'
        'install:Install Mojo'
        'demangle:Demangle a mangled name'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c[compile only]' \
        '-D+[define]:str:' \
        '*-D+[define]:str:' \
        '-emit=+[t]:t:(asm llvm-ir mlir mlir-co object shared-lib)' \
        '*-emit=+[t]:t:(asm llvm-ir mlir mlir-co object shared-lib)' \
        '-g[debug info]' \
        '-g0[no debug info]' \
        '-O+[level]:n:(0 1 2 3)' \
        '-O0[no optimize]' \
        '-O1[O1]' \
        '-O2[O2]' \
        '-O3[O3]' \
        '-Os[Os]' \
        '-Oz[Oz]' \
        '-march=+[arch]:str:' \
        '-mtriple=+[triple]:str:' \
        '-mcpu=+[cpu]:str:' \
        '-mattr=+[attr]:str:' \
        '*-mattr=+[attr]:str:' \
        '-o+[output]:file:_files' \
        '--no-debug-info[no debug info]' \
        '--no-color[no color]' \
        '--color[force color]' \
        '--no-warnings[no warnings]' \
        '-Werror[warn as error]' \
        '--werror[warn as error]' \
        '--no-emit-source-loc[no source loc]' \
        '-I+[dir]:dir:_files -/' \
        '*-I+[dir]:dir:_files -/' \
        '-include-dir=+[dir]:dir:_files -/' \
        '*-include-dir=+[dir]:dir:_files -/' \
        '-import-path=+[dir]:dir:_files -/' \
        '*-import-path=+[dir]:dir:_files -/' \
        '--diagnostic-format=+[fmt]:f:(default json yaml)' \
        '--error-limit=+[N]:n:' \
        '--max-include-stack=+[N]:n:' \
        '--max-import-depth=+[N]:n:' \
        '--max-recursion-depth=+[N]:n:' \
        '--max-template-depth=+[N]:n:' \
        '--debug-level=+[N]:n:' \
        '--target-system=+[s]:str:' \
        '--check-prefix=+[name]:str:' \
        '--check-prefixes=+[names]:str:' \
        '--parse-only[parse only]' \
        '--print-ast[print AST]' \
        '--print-effects[print effects]' \
        '--no-import-collisions[no import collisions]' \
        '--no-mojo-import[no mojo import]' \
        '--enable-cffi[enable CFFI]' \
        '--enable-traceback[enable traceback]' \
        '--enable-coverage[enable coverage]' \
        '--enable-asserts[enable asserts]' \
        '--enable-bounds-checks[bounds checks]' \
        '--enable-debug-checks[debug checks]' \
        '--print-stats[print stats]' \
        '--print-elapsed-time[print elapsed time]' \
        '--print-passes[print passes]' \
        '--no-stdlib[no stdlib]' \
        '--allow-recursion[allow recursion]' \
        '--allow-undefined[allow undefined]' \
        '--detect-divergence[detect divergence]' \
        '--check-tags[check tags]' \
        '--source-map=+[file]:file:_files' \
        '--debug-only=+[t]:str:' \
        '--lib=+[name]:str:' \
        '*--lib=+[name]:str:' \
        '-l+[library]:str:' \
        '*-l+[library]:str:' \
        '-L+[library path]:dir:_files -/' \
        '*-L+[library path]:dir:_files -/' \
        '--linker=+[name]:str:' \
        '--ldflags=+[flags]:str:' \
        '*--ldflags=+[flags]:str:' \
        '--lto[link-time optimization]' \
        '--fast-math[fast math]' \
        '--no-fast-math[no fast math]' \
        '--use-experimental-kgen-target[experimental kgen]' \
        '--diagnose-spurious-shape-conflicts[diagnose shape conflicts]' \
        '--enable-async[enable async]' \
        '--enable-implicit-tile[enable implicit tile]' \
        '--enable-roi-coloring[enable ROI coloring]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mojo subcommand' sub ;;
        args)
            case $words[1] in
                build|run|test|format|doc|debug) _arguments '*:source:_files -g "*.mojo *.🔥 *.🔥mojo"' ;;
                package) _arguments '*:dir:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_mojo-cli2 "$@"
