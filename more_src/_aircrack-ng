#compdef aircrack-ng
# _aircrack-ng — Aircrack-ng (WPA/WEP key cracker; -a attack type (1=WEP|2=WPA), -e ESSID filter, -b BSSID filter, -m MAC filter, -w wordlist (WPA), -P probability (WPA), -d/-l mask, -n key length (WEP), -i index, -f fudge factor, -k korek attack, -x[1234] brute-force step, -y PTW attack, -K Korek-only, -p threads, -q quiet, -E continue from session, -l save key to file)
# upstream: https://github.com/aircrack-ng/aircrack-ng
# Flags from aircrack-ng src/aircrack-ng.c on tip.

_aircrack-ng() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-a+[attack]:type:(1 2)' \
        '-e+[ESSID]:essid:' \
        '-b+[BSSID]:bssid:' \
        '-m+[mac filter]:mac:' \
        '-w+[wordlist]:file:_files' \
        '-P+[probability]:n:' \
        '-d+[bytes]:bytes:' \
        '-l+[mask]:mask:' \
        '-n+[key length]:bits:(64 128 152 256 512)' \
        '-i+[index]:n:' \
        '-f+[fudge factor]:n:' \
        '-k+[korek attack]:n:' \
        '-x[brute force]' \
        '-X[brute force monothreaded]' \
        '-y[PTW attack]' \
        '-K[Korek-only]' \
        '-p+[threads]:n:' \
        '-q[quiet]' \
        '-E+[session]:file:_files' \
        '-r+[realm]:realm:' \
        '*:capture file:_files -g "*.(cap|pcap|ivs|hccapx)"'
}

_aircrack-ng "$@"
