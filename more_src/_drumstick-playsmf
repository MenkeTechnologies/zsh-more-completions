#compdef drumstick-playsmf
# _drumstick-playsmf — play SMF MIDI files via ALSA sequencer (pedrolcl/drumstick)
# upstream: https://github.com/pedrolcl/drumstick
# Flags from utils/playsmf/playsmf.cpp (QCommandLineParser).

_drumstick-playsmf() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-p --port)'{-p+,--port=}'[destination MIDI port (client:port)]:port:' \
        '*:SMF file:_files -g "*.{mid,midi}"'
}

_drumstick-playsmf "$@"
