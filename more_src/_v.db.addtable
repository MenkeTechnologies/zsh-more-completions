#compdef v.db.addtable
# GRASS GIS: create and connect a new attribute table to a vector map

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--verbose[verbose output]' \
  '--quiet[quiet output]' \
  '--map=[vector map name]:name:' \
  '--table=[name for the new attribute table]:table:' \
  '--layer=[layer to receive the new table]:layer:' \
  '--key=[name of key column]:key:' \
  '--columns=[name and type of the new column(s)]:columns:' && ret=0

return ret
