#compdef phpbrew

# Zsh completion for phpbrew (PHP version manager)

_phpbrew() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:initialize phpbrew config file'
    'known:list known PHP versions'
    'update:update PHP release info'
    'install:install a PHP version'
    'list:list installed PHP versions'
    'use:use a PHP version for the current shell session'
    'switch:switch default PHP version'
    'each:run a command for all PHP versions'
    'clean:clean up built files of a PHP version'
    'remove:remove an installed PHP version'
    'purge:remove an installed PHP and its source'
    'env:export environment variables'
    'ext:manage PHP extensions'
    'variants:list available variants'
    'info:show current PHP information'
    'config:edit PHP configuration'
    'self-update:self-update phpbrew'
    'cd:change to directories'
    'download:download PHP source'
    'off:temporarily disable phpbrew'
    'fpm:manage PHP-FPM'
    'ctags:generate ctags'
    'app:manage phpbrew apps'
    'lookup-prefix:lookup prefix'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'phpbrew command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        install)
          _arguments -s -S \
            '-j+[number of concurrent build jobs]:jobs:' \
            '--jobs=[number of concurrent build jobs]:jobs:' \
            '--name=[provide a name for the build]:name:' \
            '--mirror=[use a mirror for downloading]:mirror URL:' \
            '--post-clean[clean up after install]' \
            '--build-dir=[specify a build directory]:directory:_files -/' \
            '--no-clean[do not clean object files after install]' \
            '--no-configure[do not run configure]' \
            '--no-patch[do not apply patches]' \
            '--no-test[do not run tests]' \
            '--like=[derive configure options from another version]:version:' \
            '-d[build with debug support]' \
            '--debug[build with debug support]' \
            '--old[install old version]' \
            '--stdout[send build output to stdout]' \
            '1:version:' \
            '*:variants:' \
            && ret=0
          ;;
        ext)
          _arguments -s -S \
            '1:subcommand:(install enable disable known list config-options clean purge)' \
            && ret=0
          ;;
        list)
          _arguments -s -S \
            '-d[show detail]' \
            '--dir[show directory]' \
            && ret=0
          ;;
        use|switch)
          _arguments -s -S \
            '1:PHP version:' \
            && ret=0
          ;;
        known)
          _arguments -s -S \
            '--more[show more versions]' \
            '--old[show old versions]' \
            '-u[update available versions]' \
            '--update[update available versions]' \
            && ret=0
          ;;
        cd)
          _arguments -s -S \
            '1:target:(var etc build dist src)' \
            && ret=0
          ;;
        fpm)
          _arguments -s -S \
            '1:subcommand:(setup start stop restart status)' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--verbose[verbose output]' \
            '--debug[debug mode]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_phpbrew "$@"
