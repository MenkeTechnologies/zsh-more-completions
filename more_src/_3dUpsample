#compdef 3dUpsample
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dUpsample.html
# AFNI upsample a 3D+time dataset in the time direction

local ret=1

_arguments -s -S \
  '(-1 -one -linear)-1[linear interpolation instead of 7th order]' \
  '(-1 -one -linear)-one[linear interpolation instead of 7th order]' \
  '(-1 -one -linear)-linear[linear interpolation instead of 7th order]' \
  '-prefix[output dataset name prefix]:prefix:' \
  '-verb[verbose output]' \
  '-n[upsampling factor]:n:' \
  '-input[input dataset]:dataset:_files' \
  '-datum[output data type]:datum:(float short byte)' \
  '*:dataset:_files' && ret=0

return ret
