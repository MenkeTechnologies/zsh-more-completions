#compdef spectral-cli
# _spectral-cli — Stoplight Spectral OpenAPI/AsyncAPI linter CLI alias (Stoplight / SmartBear, TypeScript); yargs
# upstream: https://github.com/stoplightio/spectral

_spectral-cli() {
    local -a sub=(
        'lint:lint OpenAPI/AsyncAPI/JSON Schema documents'
        'rule:rule introspection'
        'help:show help'
        'version:show version'
        'completion:generate shell completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spectral subcommand' sub ;;
        args)
            case $words[1] in
                lint) _arguments \
                    '--ruleset=+[ruleset file]:file:_files -g ".spectral.yaml .spectral.yml .spectral.json .spectral.js"' \
                    '-r+[ruleset file]:file:_files -g ".spectral.yaml .spectral.yml .spectral.json .spectral.js"' \
                    '--format=+[format]:fmt:(stylish json junit html text teamcity pretty markdown github-actions sarif)' \
                    '-f+[format]:fmt:(stylish json junit html text teamcity pretty markdown github-actions sarif)' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--encoding=+[encoding]:enc:(utf8 utf-8 utf16le latin1)' \
                    '-e+[encoding]:enc:(utf8 utf-8 utf16le latin1)' \
                    '--skip-rule=+[skip rule]:list:' \
                    '-D+[skip rule]:list:' \
                    '--display-only-failures[display only failures]' \
                    '--show-unmatched-globs[show unmatched globs]' \
                    '--ignore-unknown-format[ignore unknown format]' \
                    '--fail-severity=+[fail severity]:s:(error warn info hint)' \
                    '-F+[fail severity]:s:(error warn info hint)' \
                    '--resolver=+[custom resolver]:file:_files' \
                    '--stdin-filepath=+[stdin filename]:str:' \
                    '*:document:_files' ;;
                rule) _arguments \
                    '1:cmd:(list show)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_spectral-cli "$@"
