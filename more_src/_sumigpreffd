#compdef sumigpreffd
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/migration_inversion/sumigpreffd.c
# The 2-D prestack common-shot Fourier finite-difference

local ret=1

_arguments -s -S \
  'nxo=[nxo]:nxo:' \
  'nxshot=[nxshot]:nxshot:' \
  'nz=[nz]:nz:' \
  'dx=[dx]:dx:' \
  'dz=[dz]:dz:' \
  'vfile=[vfile]:vfile:' \
  'fmax=[fmax]:fmax:' \
  'f1=[f1]:f1:' \
  'lpad=[lpad]:lpad:' \
  'verbose=[verbose]:verbose:' \
  '*:file:_files' && ret=0

return ret
