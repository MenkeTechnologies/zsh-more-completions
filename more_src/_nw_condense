#compdef nw_condense
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: condense (collapse) tree clades.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-m+[group map file (label group per line)]:file:_files' \
  '-u[unicify: remove duplicate leaf labels]' \
  '*:newick file:_files' && ret=0

return ret
