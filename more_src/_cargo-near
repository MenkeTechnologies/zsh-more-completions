#compdef cargo-near
# Documentation: https://github.com/near/cargo-near
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'new:create new NEAR project'
  'build:build NEAR contract'
  'abi:generate ABI'
  'create-dev-account:create dev account on testnet'
  'deploy:deploy contract'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--teach-me[teach me mode]' \
  '*--quiet[quiet]' \
  '*-q[quiet]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cargo-near command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '--no-locked[do not require Cargo.lock]' \
          '--no-release[non-release build]' \
          '--no-abi[do not generate ABI]' \
          '--no-embed-abi[do not embed ABI in wasm]' \
          '--no-doc[skip doc generation]' \
          '--no-wasmopt[skip wasm-opt]' \
          '--features=[features csv]:list:' \
          '--no-default-features[no default features]' \
          '--out-dir=[output directory]:dir:_files -/' \
          '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
          '--color=[color mode]:c:(auto always never)' \
          '--variant=[reproducible-wasm variant name]:variant:' \
          '--env=[environment variable assignments]:env:' \
          '*: :' && ret=0 ;;
      (abi)
        _arguments \
          '--no-locked[do not require Cargo.lock]' \
          '--no-doc[skip doc generation]' \
          '--features=[features csv]:list:' \
          '--no-default-features[no default features]' \
          '--out-dir=[output directory]:dir:_files -/' \
          '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
          '--color=[color mode]:c:(auto always never)' \
          '*: :' && ret=0 ;;
      (deploy)
        _arguments \
          '--account-id=[NEAR account id]:a:' \
          '--no-locked[do not require Cargo.lock]' \
          '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
          '*: :' && ret=0 ;;
      (new)
        _arguments \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
