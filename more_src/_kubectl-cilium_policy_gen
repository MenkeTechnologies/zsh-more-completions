#compdef kubectl-cilium_policy_gen
# Documentation: https://man.archlinux.org/search?q=kubectl-cilium_policy_gen
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--all-namespaces[all namespaces]' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '*:args:_default'
