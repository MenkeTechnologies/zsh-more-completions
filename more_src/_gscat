#compdef gscat
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/gscat.1.html
# Scotch: scatter a centralized source graph into a distributed one

local ret=1

_arguments -s \
  '-h[display help]' \
  '-r-[set root process for centralized files (default 0)]:pnum' \
  '-V[display version and copyright]' \
  '*:file:_files' && ret=0

return ret
