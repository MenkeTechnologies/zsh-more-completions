#compdef psa_constant_names
# Documentation: https://man.archlinux.org/search?q=psa_constant_names
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:type:(alg algorithm curve ecc_curve group dh_group type key_type usage key_usage error status)' \
  '*:numeric value:' && ret=0

return ret
