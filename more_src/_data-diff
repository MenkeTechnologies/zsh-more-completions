#compdef data-diff
# Documentation: https://github.com/datafold/data-diff
# data-diff - compare tables within or across databases (Datafold)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-k --key-columns)'{-k,--key-columns=}'[names of primary key columns]:columns' \
  '(-t --update-column)'{-t,--update-column=}'[name of updated_at/last_updated column]:column' \
  '(-c --columns)'{-c,--columns=}'[extra columns to compare]:columns' \
  '(-l --limit)'{-l,--limit=}'[maximum number of differences to find]:n' \
  '--bisection-factor=[segments per iteration]:n' \
  '--bisection-threshold=[minimum rows per segment]:n' \
  '(-j --threads)'{-j,--threads=}'[worker threads per database]:n' \
  '(-w --where)'{-w,--where=}'[additional where expression]:expr' \
  '(-s --stats)'{-s,--stats}'[print stats instead of a detailed diff]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '--json[output as JSON]' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
  '--table-write-limit=[max rows to write to a materialized table]:n' \
  '--case-sensitive[column names are case sensitive]' \
  '--assume-unique-key[skip uniqueness validation of key column]' \
  '--sample-exclusive-rows[sample rows only in one table]' \
  '--materialize-all-rows[materialize all rows, not just diff]' \
  '--materialize-to-table=[materialize diff results to a table]:table' \
  '--min-age=[oldest row age to compare]:age' \
  '--max-age=[newest row age to compare]:age' \
  '--dbt[diff models from a dbt project]' \
  '--cloud[run diff on Datafold cloud]' \
  '--select=[select dbt models to diff]:models' \
  '*::arg:_default' && ret=0

return ret
