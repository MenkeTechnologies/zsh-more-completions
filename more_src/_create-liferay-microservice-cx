#compdef create-liferay-microservice-cx
# Documentation: https://www.npmjs.com/package/create-liferay-microservice-cx
# Reference accessed: 2026-05-24
# Verified: npm view create-liferay-microservice-cx bin; npm readme Options table.

# Zsh completion for create-liferay-microservice-cx - Liferay microservice client extension scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-n --name)'{-n,--name=}'[project name in kebab-case]:name:' \
  '(-o --org)'{-o,--org=}'[Java package organization]:org:' \
  '--oauth-app=[OAuth application name]:name:' \
  '--app-title=[application display title]:title:' \
  '--port=[server port]:port:' \
  '--author=[author name]:author:' \
  '--email=[author email]:email:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  ':project name:' && ret=0

return ret
