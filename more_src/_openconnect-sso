#compdef openconnect-sso

_arguments -s \
  '(-s --server)'{-s,--server=}'[VPN server]:server:' \
  '(-u --user)'{-u,--user=}'[username]:user:' \
  '(-p --profile)'{-p,--profile=}'[profile]:path:_files' \
  '(-P --profile-selector)'{-P,--profile-selector}'[show profile selector]' \
  '--proxy=[proxy server]:url:' \
  '--authgroup=[auth login selection]:group:' \
  '(-g --usergroup)'{-g,--usergroup=}'[user group]:group:' \
  '--authenticate=[auth-only output]:fmt:(shell json)' \
  '--browser-display-mode=[browser visibility]:mode:(shown hidden)' \
  '--on-disconnect=[disconnect command]:cmd:' \
  '--ac-version=[AnyConnect version string]:ver:' \
  '(-l --log-level)'{-l,--log-level=}'[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:openconnect args:'
