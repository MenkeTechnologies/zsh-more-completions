#compdef docker-container-volumes
# Source: https://github.com/rsherstnev/zshcompletions/blob/104351539ca29288a402ade731889a8824bb72aa/_docker-container-volumes
# Repository: rsherstnev/zshcompletions (_docker-container-volumes)

_docker_container_volumes_completion() {
    local state

    _arguments \
        '1: :->container_name' \
        '*: :->args'

    case "$state" in
        container_name)
            local -a running_containers
            running_containers=($(docker ps --format '{{.Names}}'))
            _describe 'containers' running_containers
            ;;
    esac
}

