#compdef cassowary
# Documentation: https://github.com/rogerwelin/cassowary
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for cassowary HTTP load testing tool (rogerwelin/cassowary).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:run a load test against a URL'
    )
    _describe -t commands 'cassowary command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-u+[target URL (required)]:url' \
          '-c+[number of concurrent users]:users' \
          '-n+[total number of requests]:requests' \
          '-d+[test duration in seconds]:duration' \
          '-t+[request timeout]:seconds' \
          '-f+[file containing URL paths]:file:_files' \
          '*-H+[HTTP header]:header' \
          '--postfile=[POST body file]:file:_files' \
          '--patchfile=[PATCH body file]:file:_files' \
          '--disable-keep-alive[disable HTTP keep-alive]' \
          '--ca=[CA certificate]:file:_files' \
          '--cert=[client cert for mTLS]:file:_files' \
          '--key=[client key for mTLS]:file:_files' \
          '--renegotiation=[TLS renegotiation]:mode:(never once freely)' \
          '--json-metrics[export metrics as JSON]' \
          '--json-metrics-file=[JSON metrics output file]:file:_files' \
          '--raw-output=[export raw request data as CSV]:file:_files' \
          '-p+[Prometheus PushGateway URL]:url' \
          '--cloudwatch[export metrics to AWS CloudWatch]' \
          '--histogram[output histogram visualization]' \
          '--boxplot[output boxplot visualization]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
