#compdef armadactl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      cancel:'cancel jobs'
      cordon:'cordon executor'
      create:'create queue or other resource'
      delete:'delete resources'
      docs:'documentation helpers'
      get:'get Armada resources'
      preempt:'preempt jobs'
      reprioritize:'reprioritize jobs'
      submit:'submit jobs'
      uncordon:'uncordon executor'
      update:'update resources'
      version:'show version'
      watch:'watch events'
      config:'configure armadactl contexts'
    )
    _describe -t commands command commands && ret=0
    ;;
  (args)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--armada-url=[Armada API URL]:url:' \
      '--user-token=[user token]:' \
      '*: : _default' && ret=0
    ;;
esac

return ret
