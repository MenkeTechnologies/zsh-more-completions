#compdef ext4magic

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-d+[dest dir]:dir:_files -/' \
  '-f+[input file]:file:_files' \
  '-i+[input filesystem image]:file:_files' \
  '-j+[journal file]:file:_files' \
  '-l[list deleted files]' \
  '-L[long listing]' \
  '-m[try magic scan]' \
  '-M[full magic scan]' \
  '-r[recover]' \
  '-R[recovery options]' \
  '-S[skip overwrites]' \
  '-T[scan tree]' \
  '-x[hex inode]' \
  '-Z[zero out journal]' \
  '-a+[after time]:time:' \
  '-b+[before time]:time:' \
  '-J[scan journal]' \
  '*:device:_files' && ret=0

return ret
