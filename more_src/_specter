#compdef specter
# Documentation: https://github.com/zllovesuki/specter
# specter - QUIC-based DHT overlay network and tunnel

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(client server)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      client)
        _arguments -s \
          '1:subcommand:(tunnel connect config-example)' \
          '--server=[start the local management API and UI]:hostport:' \
          '--keyless=[enable keyless TLS for custom domains]:hostport:' \
          '--tcp[fall back to TLS/TCP instead of QUIC]' \
          '*:arg:' && ret=0
        ;;
      server)
        _arguments -s '*:arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
