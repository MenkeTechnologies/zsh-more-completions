#compdef chainMergeSort
# combine sorted chain files into a larger sorted file

local ret=1

_arguments -s -S \
  '-saveId[keep the existing chain identifiers]' \
  '-inputList=[file containing a list of input chain files]:file:_files' \
  '-tempDir=[space for temporary sorting data (default ./)]:dir:_files -/' \
  '*:chain file:_files -g "*.chain"' && ret=0

return ret
