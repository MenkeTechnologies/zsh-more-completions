#compdef audiveris
# Documentation: https://audiveris.github.io/audiveris/_pages/guides/advanced/cli/
# Audiveris OMR engine: transcribe scanned scores to MusicXML

local ret=1

_arguments -s -S \
  '(-help)-help[display general help then stop]' \
  '(-version)-version[display version then stop]' \
  '-batch[run with no graphic user interface]' \
  '-export[export book as MusicXML]' \
  '-print[print out book]' \
  '-transcribe[transcribe whole book]' \
  '-force[reprocess even if target step already completed]' \
  '-save[save OMR data after each successful step]' \
  '-swap[write sheets to disk after processing]' \
  '-upgrade[update legacy project files]' \
  '-sample[populate book sample repository]' \
  '-annotate[create zip archive with symbol annotations]' \
  '-output[output folder path]:dir:_files -/' \
  '-step[target processing step]:step:(LOAD BINARY SCALE GRID HEADERS STEM_SEEDS BEAMS LEDGERS HEADS STEMS REDUCTION CUE_BEAMS TEXTS MEASURES CHORDS CURVES SYMBOLS RHYTHMS PAGE)' \
  '-sheets[select specific sheet numbers or ranges]:sheets:' \
  '-constant[assign an application constant value]:key=value:' \
  '-option[assign an application constant value]:key=value:' \
  '-playlist[load XML playlist file]:file:_files -g "*.xml"' \
  '-run[execute Java class on sheets]:class:' \
  '*:input file:_files -g "*.(omr|png|jpg|jpeg|tif|tiff|bmp|gif|pdf)"' && ret=0

return ret
