#compdef bup-cli
# _bup-cli — Avery Pennarun bup very-efficient backup system based on git packfile format CLI alias (bup team, Python); custom argparse
# upstream: https://github.com/bup/bup

_bup-cli() {
    local -a sub=(
        'bloom:generate or repair bloom filter'
        'cat-file:print object contents'
        'daemon:run a bup daemon'
        'damage:randomly damage a repo for testing'
        'drecurse:recurse a directory printing entries'
        'fsck:check repo integrity'
        'ftp:browse repo via FTP'
        'fuse:mount repo via FUSE'
        'gc:garbage collect repo'
        'genkey:generate authentication key'
        'get:retrieve commits/branches'
        'help:show help'
        'import-duplicity:import duplicity backup'
        'import-rdiff-backup:import rdiff-backup'
        'import-rsnapshot:import rsnapshot'
        'index:scan filesystem and create index'
        'init:initialize repo'
        'join:join chunks back into stream'
        'list-idx:list pack indexes'
        'ls:list files in repo'
        'margin:print pack data margin'
        'memtest:run memory test'
        'meta:save/extract file metadata'
        'midx:create multi-index file'
        'mux:multiplex stdin/stdout'
        'newliner:wrap output with newlines'
        'on:run cmd in repo on remote'
        'on--server:run cmd in repo (server)'
        'prune-older:remove old saves'
        'random:write random data'
        'restore:restore files from saves'
        'rm:remove saves'
        'save:save filesystem to repo'
        'server:run as a server'
        'split:split stream into chunks'
        'tag:create/remove tags'
        'tick:wait for clock to tick'
        'version:show version'
        'web:run web server'
        'xstat:show extended file stats'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--bup-dir=+[bup dir]:dir:_files -/' \
        '-d+[bup dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bup subcommand' sub ;;
        args)
            case $words[1] in
                save) _arguments \
                    '-n+[snapshot name]:str:' \
                    '--name=+[snapshot name]:str:' \
                    '-d+[date]:str:' \
                    '--date=+[date]:str:' \
                    '-v[verbose]' \
                    '--verbose[verbose]' \
                    '-q[quiet]' \
                    '--quiet[quiet]' \
                    '--smaller=+[smaller than size]:str:' \
                    '--bwlimit=+[bw limit kb/s]:n:' \
                    '-r+[remote]:str:' \
                    '--remote=+[remote]:str:' \
                    '*:files:_files' ;;
                restore) _arguments \
                    '-C+[output dir]:dir:_files -/' \
                    '--outdir=+[output dir]:dir:_files -/' \
                    '-v[verbose]' \
                    '-q[quiet]' \
                    '--meta[restore metadata]' \
                    '--no-meta[no metadata]' \
                    '--map-user=+[from=to]:str:' \
                    '--map-group=+[from=to]:str:' \
                    '*:paths:_files' ;;
                ls) _arguments \
                    '-s[show hash]' \
                    '-a[show hidden]' \
                    '-A[show hidden including . and ..]' \
                    '-d[show dirs as dirs]' \
                    '-l[long format]' \
                    '--human-readable[human readable]' \
                    '*:paths:_files' ;;
                index) _arguments \
                    '*:paths:_files' \
                    '-p[print files only]' \
                    '-s[show stats]' \
                    '-m[show modified]' \
                    '-u[update index]' \
                    '--update[update index]' \
                    '--clear[clear index]' \
                    '-x[stay on one fs]' \
                    '--one-file-system[stay on one fs]' \
                    '--fake-valid[mark as valid]' \
                    '--check[run integrity check]' \
                    '--exclude=+[path]:str:' \
                    '--exclude-from=+[file]:file:_files' \
                    '--exclude-rx=+[regex]:str:' \
                    '--exclude-rx-from=+[file]:file:_files' ;;
                init) _arguments '-r+[remote]:str:' '--remote=+[remote]:str:' ;;
                prune-older) _arguments \
                    '*:branch:' \
                    '-n[dry run]' \
                    '--dry-run[dry run]' \
                    '--pretend[dry run]' \
                    '--keep-all-for=+[duration]:str:' \
                    '--keep-dailies-for=+[duration]:str:' \
                    '--keep-monthlies-for=+[duration]:str:' \
                    '--keep-yearlies-for=+[duration]:str:' \
                    '--wrt=+[time]:str:' ;;
                fsck) _arguments \
                    '*:pack:_files -g "*.pack"' \
                    '-r[generate recovery blocks]' \
                    '--repair[repair errors]' \
                    '-g[generate recovery blocks]' \
                    '-v[verbose]' \
                    '-j+[parallel jobs]:n:' \
                    '--jobs=+[parallel jobs]:n:' \
                    '--par2-ok[par2 ok]' \
                    '--disable-par2[disable par2]' ;;
            esac
            ;;
    esac
}

_bup-cli "$@"
