#compdef mountsnoop mountsnoop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/mountsnoop.py argparse)
# Reference accessed: 2026-05-29
# mountsnoop — trace mount() and umount() syscalls system-wide (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-P --parent_process)'{-P,--parent_process}'[also snoop the parent process]' \
  '--cgroupmap=[trace cgroups in this BPF map only]:map:' \
  '--mntnsmap=[trace mount namespaces in this BPF map only]:map:' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
