#compdef sfacctd
# Documentation: https://raw.githubusercontent.com/pmacct/pmacct/master/src/sfacctd.c
# Reference accessed: 2026-05-30
# sfacctd — pmacct sFlow accounting daemon. Collects sFlow v2/v4/v5 samples + accounts via plugins.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version and compile-time options]' \
  '-L+[bind to this IP address]:ip:' \
  '-l+[listen on this UDP port]:port:' \
  '-f+[config file]:file:_files' \
  '-a[list supported aggregation primitives]' \
  '-c+[aggregation method (default src_host)]:primitive:' \
  '-D[run as daemon]' \
  '-n+[networks/ASNs definitions file]:file:_files' \
  '-t+[ports definitions file]:file:_files' \
  '*-P+[activate plugin]:plugin:(memory print mysql pgsql sqlite3 amqp kafka tee)' \
  '-d[enable debug mode]' \
  '-S+[syslog facility]:facility:(auth mail daemon kern user local0 local1 local2 local3 local4 local5 local6 local7)' \
  '-F+[PID file]:file:_files' \
  '-R[renormalize sampled data]' \
  '-u[keep IP protocols in numeric format]' \
  '-I+[read packets from savefile]:file:_files -g "*.(pcap|cap)"' \
  '-Z+[sleep between savefile replays (seconds)]:sec:' \
  '-W[do not exit when savefile finishes; sleep instead]' \
  '-Y+[number of times to replay savefile]:N:' \
  '-T+[dry run]:target:(config setup)' \
  '-p+[memory plugin socket]:socket:_files' \
  '-b+[memory plugin buckets]:N:' \
  '-m+[memory pool count]:N:' \
  '-s+[memory pool size]:bytes:' \
  '-r+[print plugin refresh time (seconds)]:sec:' \
  '-O+[output format]:fmt:(formatted csv json avro)' \
  '-o+[output file]:file:_files' \
  '-M[print event markers]' \
  '-A[append to output file]' \
  '-E+[CSV separator character]:char:' \
  && ret=0

return ret
