#compdef puppet-facts
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/facts.md
# puppet facts - retrieve, show and upload node facts

local ret=1

_arguments -s -S \
  '--render-as=[output render format]:format:(json s yaml console dot)' \
  '--verbose[whether to log verbosely]' \
  '--debug[whether to log debug information]' \
  '--terminus=[indirected subsystem backend]:terminus:' \
  '--config-file=[Facter configuration file location]:file:_files' \
  '--custom-dir=[directory containing custom facts]:dir:_files -/' \
  '--external-dir=[directory containing external facts]:dir:_files -/' \
  '--no-block[disable the fact blocking mechanism]' \
  '--no-cache[disable the fact caching mechanism]' \
  '--show-legacy[include legacy facts when querying all facts]' \
  '--timing[display resolution time for each fact]' \
  '--value-only[show only the value for single fact queries]' \
  '1:action:(find info save show upload)' \
  '*::fact:' && ret=0

return ret
