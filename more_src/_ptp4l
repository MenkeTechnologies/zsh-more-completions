#compdef ptp4l
# _ptp4l — linuxptp ptp4l CLI Precision Time Protocol IEEE 1588 PTP daemon synchronizing system clocks across Ethernet links between hardware time stamping NIC PHCs grandmaster boundary transparent ordinary clock roles E2E P2P delay-mechanism slave-only master-only servo (linuxptp team, C); getopt
# upstream: https://linuxptp.sourceforge.net/

_ptp4l() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-A[auto select transport]' \
        '-2[use IEEE 802.3 transport]' \
        '-4[use UDP IPv4 transport]' \
        '-6[use UDP IPv6 transport]' \
        '-E[E2E delay mechanism]' \
        '-P[P2P delay mechanism]' \
        '-H[hardware time stamping]' \
        '-S[software time stamping]' \
        '-L[legacy hw time stamping]' \
        '-f+[config file]:file:_files -g "*.conf *.cfg"' \
        '-i+[interface]:_net_interfaces' \
        '-p+[phc device]:file:_files -g "/dev/ptp*"' \
        '-s[slave only mode]' \
        '-l+[print level]:l:(0 1 2 3 4 5 6 7)' \
        '-m[print to stdout]' \
        '-q[do not print to syslog]' \
        '-v[show version]' \
        '*:additional cfg:'
}

_ptp4l "$@"
