#compdef cbworkloadgen
# Documentation: https://docs.couchbase.com/server/6.0/cli/cbworkloadgen-tool.html
# Couchbase workload generator for testing servers and clusters

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --node)'{-n,--node}'+[node to connect to as HOST:PORT]:node:_hosts' \
  '(-u --user)'{-u,--user}'+[REST username of the cluster]:username:' \
  '(-p --password)'{-p,--password}'+[REST password of the cluster]:password:' \
  '(-b --bucket)'{-b,--bucket}'+[bucket to insert data into]:bucket:' \
  '(-i --item)'{-i,--item}'+[number of items to insert]:items:' \
  '(-r --ratio)'{-r,--ratio}'+[set/get operation ratio (0-1)]:ratio:' \
  '(-s --size)'{-s,--size}'+[minimum value size in bytes]:size:' \
  '--prefix=[prefix for memcached keys / json doc ids]:prefix:' \
  '(-t --threads)'{-t,--threads}'+[number of concurrent workers]:threads:' \
  '(-j --json)'{-j,--json}'[insert data in JSON format]' \
  '(-l --loop)'{-l,--loop}'[loop forever until interrupted]' && ret=0

return ret
