#compdef v.to.db
# Documentation: https://grass.osgeo.org/grass-stable/manuals/v.to.db.html
# GRASS GIS: populate database values from vector features

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '-p[print only]' \
  '-h[print header]' \
  '-s[only print SQL statements]' \
  '-c[print also totals for length, area or count]' \
  '--overwrite[allow output to overwrite existing files]' \
  '--verbose[verbose output]' \
  '--quiet[quiet output]' \
  '--map=[vector map name]:name:' \
  '--layer=[layer number or name]:layer:' \
  '--type=[input feature type]:type:(point line boundary centroid area)' \
  '--option=[geometric value to upload]:option:(cat area compact fd perimeter length count coor start end sides query slope sinuous azimuth bbox)' \
  '--columns=[attribute column(s) to populate]:columns:' \
  '--units=[measurement units]:units:(miles feet meters kilometers acres hectares radians degrees)' \
  '--qcolumn=[query column]:column:' \
  '--separator=[field separator]:separator:(pipe comma space tab newline)' && ret=0

return ret
