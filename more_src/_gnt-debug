#compdef gnt-debug
# _gnt-debug — Google Ganeti gnt-debug CLI for the Ganeti virtualisation cluster manager debug subcommand running cluster-wide diagnostic operations IAllocator wconfd test-jobset locks delay submit-job test-jobqueue (ganeti team, Python); custom argparse
# upstream: https://github.com/ganeti/ganeti

_gnt-debug() {
    local -a sub=(
        'allocator:test allocator'
        'delay:add delay'
        'submit-job:submit a test job'
        'test-jobqueue:test job queue'
        'iallocator:test IAllocator'
        'wconfd:debug wconfd'
        'locks:show held locks'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--cluster=+[name]:str:' \
        '--no-headers[no headers]' \
        '--separator=+[char]:str:' \
        '-o+[output fields]:str:' \
        '--output=+[output fields]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gnt-debug subcommand' sub ;;
        args)
            case $words[1] in
                delay) _arguments \
                    '--print[print]' \
                    '-n+[node csv]:str:' \
                    '--repeat=+[N]:n:' \
                    '*:seconds:' ;;
                allocator|iallocator) _arguments \
                    '--algorithm=+[a]:a:(hail balanced metad-fairlock chained random)' \
                    '--mode=+[m]:m:(allocate relocate multi-relocate change-group node-evacuate)' ;;
                submit-job) _arguments \
                    '--count=+[N]:n:' \
                    '*:op-spec:' ;;
            esac
            ;;
    esac
}

_gnt-debug "$@"
