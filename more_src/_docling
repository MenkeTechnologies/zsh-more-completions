#compdef docling
# Documentation: https://docling-project.github.io/docling/reference/cli/
# Reference accessed: 2026-05-21
# Verified: upstream CLI reference at the URL above.

# Zsh completion for docling - document conversion CLI (IBM Research)

_arguments \
  '*--from[input format]:fmt:(docx pptx html image pdf asciidoc md csv xlsx xml_uspto xml_jats xml_xbrl mets_gbs json_docling audio vtt latex)' \
  '*--to[output format]:fmt:(md json yaml html html_split_page text doctags vtt)' \
  '--output[output directory]:dir:_directories' \
  '--pipeline[processing pipeline]:pipeline:(legacy standard vlm asr)' \
  '--vlm-model[VLM preset]:model:(granite_docling deepseek_ocr qwen phi4)' \
  '--asr-model[ASR/Whisper model]:model:(tiny tiny_mlx base base_mlx small small_mlx medium medium_mlx large large_mlx large-v2 large-v3 large-v3-turbo turbo)' \
  '--no-ocr[disable bitmap content OCR]' \
  '--ocr[enable bitmap content OCR]' \
  '--force-ocr[replace existing text with OCR output]' \
  '--ocr-engine[OCR engine]:engine:(auto easyocr rapidocr tesseract tesserocr ocrmac kserve_v2_ocr)' \
  '--ocr-lang[comma-separated OCR language codes]:langs:' \
  '--table-mode[table extraction mode]:mode:(fast accurate)' \
  '--enrich-code[enable code enrichment]' \
  '--enrich-formula[enable formula enrichment]' \
  '--enrich-picture-classes[classify pictures]' \
  '--enrich-picture-description[describe pictures]' \
  '--enrich-chart-extraction[extract chart data]' \
  '--num-threads[processing threads]:n:' \
  '--device[compute device]:device:(auto cpu cuda mps xpu)' \
  '--document-timeout[per-document timeout in seconds]:secs:' \
  '--page-batch-size[pages per batch]:n:' \
  '--abort-on-error[stop on first error]' \
  '--pdf-backend[PDF backend]:backend:(pypdfium2 docling_parse dlparse_v2 dlparse_v4)' \
  '--image-export-mode[image export mode]:mode:(placeholder embedded referenced)' \
  '--profiling[enable profiling]' \
  '--save-profiling[save profiling data]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:file:_files'
