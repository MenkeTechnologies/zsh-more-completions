#compdef totp-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'add-token:add a new token'
      'change-password:change storage password'
      'delete:delete a token'
      'dump:dump all tokens'
      'generate:generate a TOTP code'
      'instant:generate code without storage'
      'list:list all tokens'
      'set-length:set token length'
      'set-prefix:set token namespace'
      'update:update a token'
    )
    _describe -t commands 'totp-cli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      add-token|delete|generate|update|set-length)
        _arguments -s -S \
          '1:namespace:' \
          '2:account:' && ret=0
        ;;
      list)
        _arguments -s -S \
          '1:namespace:' && ret=0
        ;;
      instant)
        _arguments -s -S \
          '1:token:' && ret=0
        ;;
    esac
    ;;
esac

return ret
