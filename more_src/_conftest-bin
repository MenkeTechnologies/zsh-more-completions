#compdef conftest
# _conftest-bin — Conftest OPA Rego config tester (Open Policy Agent, Go); writes Rego policies and tests configs against them
# upstream: https://github.com/open-policy-agent/conftest

_conftest-bin() {
    local -a sub=(
        'test:test files against policies'
        'verify:verify Rego policies'
        'parse:parse files and print AST'
        'push:push policies to OCI registry'
        'pull:pull policies from OCI registry'
        'plugin:plugin commands'
        'update:update Conftest'
        'completion:print shell completion'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'conftest subcommand' sub ;;
        args)
            case $words[1] in
                test) _arguments \
                    '-p+[policy dir]:dir:_files -/' \
                    '--policy+[policy dir]:dir:_files -/' \
                    '-d+[data file or dir]:path:_files' \
                    '--data+[data file or dir]:path:_files' \
                    '-i+[input format]:fmt:(yaml json toml hcl1 hcl2 cue dockerfile edn xml ini vcl)' \
                    '--input+[input format]:fmt:' \
                    '-c+[combine input]' \
                    '--combine[combine input]' \
                    '--all-namespaces[query all namespaces]' \
                    '-n+[namespace]:namespace:' \
                    '--namespace+[namespace]:namespace:' \
                    '-o+[output format]:fmt:(stdout json tap table junit github sarif)' \
                    '--output+[output format]:fmt:' \
                    '--fail-on-warn[fail on warnings]' \
                    '--ignore+[ignore regex]:regex:' \
                    '--no-fail[do not exit non-zero]' \
                    '--parser+[parser]:parser:' \
                    '--quiet[only failures]' \
                    '--strict[strict]' \
                    '--show-builtin-errors[show builtin errors]' \
                    '--suppress-exceptions[suppress exceptions]' \
                    '--trace[print trace]' \
                    '--update+[update from URL]:url:_urls' \
                    '*:file:_files' ;;
                verify) _arguments \
                    '-p+[policy dir]:dir:_files -/' \
                    '-d+[data file/dir]:path:_files' \
                    '-o+[output format]:fmt:(stdout json tap table junit github)' \
                    '--report+[trace report]:str:(notes fails full)' \
                    '--strict[strict]' \
                    '--trace[print trace]' ;;
                push|pull) _arguments \
                    '-p+[policy dir]:dir:_files -/' \
                    '--tls[force TLS]' \
                    '*:registry URL:_urls' ;;
                parse) _arguments \
                    '-i+[input format]:fmt:' \
                    '--combine[combine input]' \
                    '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_conftest-bin "$@"
