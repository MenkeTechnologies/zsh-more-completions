#compdef comet
# Documentation: https://github.com/comet-ml/comet-ml
# Reference accessed: 2026-05-23
# Verified: comet --help (comet_ml PyPI console script).

# Zsh completion for comet - Comet ML experiment tracking CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'comet command' \
      'check[check Comet configuration]' \
      'models[manage models]' \
      'offline[upload offline experiment archive]' \
      'optimize[run Comet optimize]' \
      'python[run script with Comet logging]' \
      'upload[upload experiment assets]' \
      'init[initialize Comet project]' \
      'login[login to Comet]' \
      'bootstrap_dir[bootstrap directory for Comet]' && ret=0
    ;;
esac

return ret
