#compdef cargo-set-rust-version
# _cargo-set-rust-version — set Cargo.toml rust-version to latest channel release (stellar/cargo-set-rust-version)
# upstream: https://github.com/stellar/cargo-set-rust-version
# Flags from src/main.rs (clap).

_cargo-set-rust-version() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--manifest=[Cargo.toml file path]:file:_files -g "*.toml"' \
        '--channel=[channel for latest version lookup]:channel:(stable beta nightly)'
}

_cargo-set-rust-version "$@"
