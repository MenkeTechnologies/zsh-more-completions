#compdef horst

_arguments -s \
  '(- *)-v[show version]' \
  '(- *)-h[show help]' \
  '-q[quiet, no UI]' \
  '-D[debug]' \
  '-a[always add virtual monitor interface]' \
  '-c[config file]:file:_files' \
  '-C[initial channel]:n:' \
  '-i[interface]:iface:_net_interfaces' \
  '-t[node timeout secs]:secs:' \
  '-V[initial view]:view:(history essid statistics spectrum)' \
  '-d[display update interval ms]:ms:' \
  '-b[RX buffer size bytes]:bytes:' \
  '-M[MAC to hostname map file]:file:_files' \
  '-s[spectrum analyzer mode]' \
  '-u[upper channel limit]:n:' \
  '-N[server mode]' \
  '-n[connect to server]:ip:' \
  '-p[port]:port:' \
  '-o[output capture file]:file:_files' \
  '-X[control named pipe]:name:' \
  '-x[send command to control pipe]:cmd:' \
  '*-e[filter by source MAC]:mac:' \
  '*-f[filter by packet type]:type:' \
  '*-m[filter by mode]:mode:(AP STA ADH PRB WDS UNKNOWN)' \
  '-B[filter by BSSID]:bssid:'
