#compdef acme-dns
# Documentation: https://github.com/joohoi/acme-dns (main.go flag.String)
# Reference accessed: 2026-05-30
# acme-dns — limited DNS server for ACME DNS-01 challenges. Minimal CLI: configuration is via cfg file.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-c+[config file location (default /etc/acme-dns/config.cfg)]:file:_files -g "*.(cfg|conf|yaml|yml|toml)"' \
  && ret=0

return ret
