#compdef pcp-pidstat
# Documentation: https://man.archlinux.org/search?q=pcp-pidstat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a+[archive]:file:_files' \
  '-A+[align]:time:' \
  '-B+[boot]:time:' \
  '-C+[exec regex]:regex:' \
  '-D[show user]' \
  '-G+[grep names]:names:' \
  '-H+[host]:host:_hosts' \
  '-I+[interval]:sec:' \
  '-O+[origin]:time:' \
  '-p+[pid]:pid:_pids' \
  '-R+[realtime info]:opts:' \
  '-r+[memory info]:opts:' \
  '-S+[start time]:time:' \
  '-T+[end time]:time:' \
  '-t[show thread tasks]' \
  '-U[show non-root]' \
  '-u[show CPU stats]' \
  '-V[show version]' \
  '-v[show pcp version]' \
  '-Z+[timezone]:tz:' \
  '-z[archive timezone]' \
  '*:interval count:' && ret=0

return ret
