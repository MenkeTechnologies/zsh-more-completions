#compdef pcp-pidstat
# Documentation: https://man7.org/linux/man-pages/man1/pcp-pidstat.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-\?[show help]' \
  '(- *)--help[show help]' \
  '-a+[archive source]:archive:_files' \
  '--archive=[archive source]:archive:_files' \
  '-h+[target host]:host:_hosts' \
  '--host=[target host]:host:_hosts' \
  '-O+[time origin]:time:' \
  '--origin=[time origin]:time:' \
  '-s+[number of samples]:samples:' \
  '--samples=[number of samples]:samples:' \
  '-t+[interval between samples]:interval:' \
  '--interval=[interval between samples]:interval:' \
  '-Z+[timezone specification]:tz:' \
  '--timezone=[timezone specification]:tz:' \
  '-z[use host timezone]' \
  '--hostzone[use host timezone]' \
  '-I[divide CPU usage by total processors (SMP)]' \
  '-l[display process command name and all arguments]' \
  '-R[report real-time priority and scheduling policy]' \
  '-r[report page faults and memory utilization]' \
  '-k[report stack utilization]' \
  '-U+[display real user name (optional username filter)]:username:_users' \
  '--user-name=[display real user name (optional username filter)]:username:_users' \
  '-G+[display only processes matching the name pattern]:processname:' \
  '--process-name=[display only processes matching the name pattern]:processname:' \
  '-p+[display only specified PIDs]:pid list:_pids' \
  '--pid-list=[display only specified PIDs]:pid list:_pids' \
  '-B+[report process states]:state:' \
  '-f+[timestamp format string]:format:' \
  '-V[show version]' \
  '--version[show version]' \
  '*:interval count:' && ret=0

return ret
