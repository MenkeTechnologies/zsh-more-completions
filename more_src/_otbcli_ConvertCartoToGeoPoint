#compdef otbcli_ConvertCartoToGeoPoint
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ConvertCartoToGeoPoint.html
# Orfeo ToolBox: convert cartographic coordinates to geographic ones

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-carto.x[X cartographic coordinate]:value:' \
  '-carto.y[Y cartographic coordinate]:value:' \
  '-mapproj[map projection to use]:proj:(utm lambert2 lambert93 wgs epsg)' \
  '-mapproj.utm.zone[UTM zone number 1-60]:value:' \
  '-mapproj.utm.northhem[point is in northern hemisphere]:bool:(true false)' \
  '-mapproj.epsg.code[EPSG code of map projection]:value:' \
  '-long[output point longitude in decimal degrees]:value:' \
  '-lat[output point latitude in decimal degrees]:value:' \
  '*::arg:_files' && ret=0

return ret
