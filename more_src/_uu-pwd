#compdef uu-pwd
# Documentation: https://man.archlinux.org/search?q=uu-pwd
# Reference accessed: 2026-05-16
# Source: Homebrew bottle
# Formula: uutils-coreutils
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

autoload -U is-at-least

_uu-pwd() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-L[use PWD from environment, even if it contains symlinks]' \
'--logical[use PWD from environment, even if it contains symlinks]' \
'-P[avoid all symlinks]' \
'--physical[avoid all symlinks]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
}

(( $+functions[_uu-pwd_commands] )) ||
_uu-pwd_commands() {
    local commands; commands=()
    _describe -t commands 'uu-pwd commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-pwd" ]; then
    _uu-pwd "$@"
else
    compdef _uu-pwd uu-pwd
fi
