#compdef intxyz
# Documentation: https://dasher.wustl.edu/tinker/distribution/doc/sphinx/tinker/_build/html/text/analysis-programs.html
# Tinker: convert a Tinker .int internal coordinates file into a .xyz Cartesian file

local ret=1

_arguments -s -S \
  '(-k -key -keyfile)'{-k,-key,-keyfile}'[keyfile to use for the calculation]:keyfile:_files -g "*.key"' \
  '*:Tinker int file:_files -g "*.int"' && ret=0

return ret
