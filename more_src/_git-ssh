#compdef git-ssh
# Documentation: https://man.archlinux.org/search?q=git-ssh
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/git-ssh — SSH wrapper for git hosting

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
