#compdef diagrams
# _diagrams — MinJae Kwon mingrammer diagrams Python CLI for diagram-as-code generating cloud architecture diagrams AWS Azure GCP Kubernetes OnPrem with Graphviz backends (mingrammer team, Python); typer
# upstream: https://github.com/mingrammer/diagrams

_diagrams() {
    local -a sub=(
        'render:render a diagram script'
        'list:list providers'
        'list-nodes:list nodes for a provider'
        'list-edges:list edge types'
        'preview:preview diagram'
        'export:export to format'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'diagrams subcommand' sub ;;
        args)
            case $words[1] in
                render|export) _arguments \
                    '-f+[format]:f:(png jpg svg pdf dot)' \
                    '--format=+[format]:f:(png jpg svg pdf dot)' \
                    '-o+[output file]:file:_files -g "*.png *.jpg *.svg *.pdf *.dot"' \
                    '--output=+[output file]:file:_files -g "*.png *.jpg *.svg *.pdf *.dot"' \
                    '--direction=+[d]:d:(TB BT LR RL)' \
                    '--node-attr=+[attr=value]:str:' \
                    '--graph-attr=+[attr=value]:str:' \
                    '--edge-attr=+[attr=value]:str:' \
                    '--show[show after render]' \
                    '--filename=+[name]:str:' \
                    '*:python script:_files -g "*.py"' ;;
                list-nodes) _arguments \
                    '*:provider:(aws azure gcp k8s onprem oci openstack saas elastic generic alibabacloud digitalocean firebase ibm outscale)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_diagrams "$@"
