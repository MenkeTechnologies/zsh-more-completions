#compdef mblaze

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'maddr:extract addresses from messages'
  'mcom:compose messages'
  'mdirs:list maildirs'
  'mdeliver:deliver messages to maildirs'
  'mexport:export messages as mbox'
  'mflag:manipulate message flags'
  'mflow:reformat format=flowed messages'
  'mfwd:forward messages'
  'mgenmid:generate Message-IDs'
  'mhdr:show message headers'
  'minc:incorporate new messages'
  'mlist:list messages'
  'mmime:create MIME messages'
  'mpick:filter messages by expressions'
  'mrep:reply to messages'
  'mscan:generate one-line message summaries'
  'msed:edit message headers'
  'mseq:manage message sequences'
  'mshow:render messages'
  'msort:sort messages'
  'mthread:arrange messages by thread'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' && ret=0

case $state in
  (command)
    _describe -t commands 'mblaze command' commands && ret=0
    ;;
esac

return ret
