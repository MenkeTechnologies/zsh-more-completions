#compdef waifu2x-converter-cpp
# Documentation: https://github.com/DeadSix27/waifu2x-converter-cpp
# waifu2x image super-resolution converter (OpenCL/CUDA)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-i --input)'{-i,--input}'+[path to input image file or directory]:input:_files' \
  '(-o --output)'{-o,--output}'+[path to output image file or directory]:output:_files' \
  '(-r --recursive-directory)'{-r,--recursive-directory}'+[search directories recursively]:0/1:(0 1)' \
  '(-a --auto-naming)'{-a,--auto-naming}'[add postfix to output name]' \
  '(-g --generate-subdir)'{-g,--generate-subdir}'+[generate sub folder in recursive mode]:0/1:(0 1)' \
  '(-t --tta)'{-t,--tta}'+[enable test-time augmentation]:0/1:(0 1)' \
  '(-s --silent)'{-s,--silent}'[enable silent mode]' \
  '(-v --log-level)'{-v,--log-level}'+[set log level]:level' \
  '(-m --mode)'{-m,--mode}'+[image processing mode]:mode:(noise scale noise-scale)' \
  '--noise-level+[noise reduction level]:level:(0 1 2 3)' \
  '--scale-ratio+[custom scale ratio]:ratio' \
  '--model-dir+[path to custom model directory]:dir:_files -/' \
  '(-j --jobs)'{-j,--jobs}'+[number of threads]:jobs' \
  '(-p --processor)'{-p,--processor}'+[set target processor]:processor' \
  '--force-OpenCL[force OpenCL on Intel platform]' \
  '(-z --resume)'{-z,--resume}'[ignore already-converted files]' \
  '--disable-gpu[disable GPU]' \
  '--block-size+[block size]:size' \
  '(-q --image-quality)'{-q,--image-quality}'+[JPEG/WebP quality (0-101)]:quality' \
  '(-c --png-compression)'{-c,--png-compression}'+[PNG compression level (0-9)]:level' \
  '(-f --output-format)'{-f,--output-format}'+[output format in recursive mode]:format:(png jpg webp)' \
  '(-l --list-processor)'{-l,--list-processor}'[dump processor list]' \
  '--list-supported-formats[dump supported format list]' && ret=0

return ret
