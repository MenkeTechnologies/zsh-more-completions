#compdef packager
# Documentation: https://shaka-project.github.io/shaka-packager/html/documentation.html
# Shaka Packager - media packaging SDK/tool for DASH and HLS

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--quiet[suppress output messages]' \
  '--dump_stream_info[dump stream info and exit]' \
  '--mpd_output=[MPD output file name]:file:_files' \
  '--hls_master_playlist_output=[output path for HLS master playlist]:file:_files' \
  '--hls_playlist_type=[HLS playlist type]:type:(VOD EVENT LIVE)' \
  '--segment_duration=[segment duration in seconds]:seconds:' \
  '--fragment_duration=[fragment duration in seconds]:seconds:' \
  '--generate_static_live_mpd[generate static manifest instead of dynamic]' \
  '--base_urls=[comma separated BaseURLs for the MPD]:urls:' \
  '--min_buffer_time=[common duration for MPD data rate definition]:seconds:' \
  '--enable_widevine_encryption[enable Widevine key server encryption]' \
  '--enable_raw_key_encryption[enable encryption using command-line keys]' \
  '--keys=[encryption keys (label=:key_id=:key=)]:keys:' \
  '--protection_scheme=[protection scheme]:scheme:(cenc cbc1 cens cbcs)' \
  '--clear_lead=[clear lead in seconds when encryption is enabled]:seconds:' \
  '*:stream descriptor:_files' && ret=0

return ret
