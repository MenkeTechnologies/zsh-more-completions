#compdef kustomize-cli
# Documentation: https://github.com/kubernetes-sigs/kustomize
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: there is no upstream `kustomize-cli` binary; the real binary is
# `kustomize` (see the sibling _kustomize file). This file exists so that
# anyone who has aliased/symlinked the kustomize binary to `kustomize-cli`
# still gets sensible completion. Definitions kept narrow on purpose to
# avoid drifting from upstream subcommand changes.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build a kustomization target from a directory or URL'
  'cfg:commands for reading and writing configuration'
  'completion:generate shell completion script'
  'create:create a new kustomization in the current directory'
  'edit:edit a kustomization file'
  'fn:commands for running functions against configuration'
  'localize:localize a remote kustomization to a local copy'
  'version:print the kustomize version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--stack-trace[print stack trace on error]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kustomize command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build)
        _arguments -s -S \
          '--enable-alpha-plugins[enable alpha plugins]' \
          '--enable-helm[enable use of the Helm chart inflator generator]' \
          '--helm-command=[helm command path]:file:_files' \
          '--enable-exec[enable exec functions]' \
          '--enable-managedby-label[enable adding app.kubernetes.io/managed-by label]' \
          '--enable-star[enable starlark functions]' \
          '--load-restrictor=[set the load restrictor]:r:(LoadRestrictionsRootOnly LoadRestrictionsNone)' \
          '*--mount=[mount a local directory]:m:' \
          '--network[enable network access for functions]' \
          '--network-name=[docker network for the container]:n:' \
          '--reorder=[reorder the resources]:r:(legacy none)' \
          '--as-current-user[use the uid and gid of the command executor]' \
          '(-o --output)'{-o+,--output=}'[write output to file or directory]:file:_files' \
          '*:kustomization directory:_directories' && ret=0 ;;
      (create)
        _arguments -s -S \
          '--annotations=[comma-separated annotations]:list:' \
          '--autodetect[detect resources in the current directory]' \
          '--labels=[comma-separated labels]:list:' \
          '--namespace=[set the namespace]:ns:' \
          '--nameprefix=[set the name prefix]:p:' \
          '--namesuffix=[set the name suffix]:s:' \
          '--recursive[detect resources recursively]' \
          '*--resource=[add a resource]:resource:_files' \
          && ret=0 ;;
      (edit)
        _arguments \
          '1:subcommand:(add fix remove set)' \
          '*: :' && ret=0 ;;
      (cfg)
        _arguments \
          '1:subcommand:(cat count grep tree)' \
          '*: :_files -/' && ret=0 ;;
      (fn)
        _arguments -s -S \
          '1:subcommand:(eval export run sink source)' \
          '--enable-exec[enable exec functions]' \
          '--enable-star[enable starlark functions]' \
          '(-i --image)'{-i+,--image=}'[run this container image]:img:' \
          '*--mount=[mount a local directory]:m:' \
          '--network[enable network access]' \
          '*: :_files' && ret=0 ;;
      (localize)
        _arguments -s -S \
          '*: :_files' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files && ret=0 ;;
    esac ;;
esac

return ret
