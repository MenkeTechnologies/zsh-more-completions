#compdef foamExec
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamExec — run a command inside the OpenFOAM environment of a given installation/version.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-prefix[alternative installation prefix (passed to foamEtcFile, sets FOAM_INST_DIR)]:dir:_directories' \
    '-version[alternative OpenFOAM version (passed to foamEtcFile)]:ver:' \
    '-help[print usage]' \
    '*:command and args:_command_names -e' \
    && ret=0

return ret
