#compdef llamafactory-cli lmf
# Documentation: https://github.com/hiyouga/LLaMA-Factory
# Reference accessed: 2026-05-23
# Verified: llamafactory-cli usage banner and subcommand -h (llamafactory PyPI).

# Zsh completion for llamafactory-cli - LLaMA Factory training and serving CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'llamafactory-cli command' \
      'api[launch OpenAI-style API server]' \
      'chat[launch CLI chat interface]' \
      'export[merge LoRA adapters and export model]' \
      'train[train models]' \
      'webchat[launch Web UI chat]' \
      'webui[launch LlamaBoard]' \
      'env[show environment info]' \
      'version[show version info]' && ret=0
    ;;
esac

return ret
