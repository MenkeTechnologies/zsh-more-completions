#compdef mp4box MP4Box

# Zsh completion for MP4Box - GPAC MPEG-4 file utility

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-add[add a media track]:input:_files' \
  '-cat[concatenate a file]:input:_files' \
  '-rem[remove a track]:track ID' \
  '-rap[insert random access points]' \
  '-enable[enable a track]:track ID' \
  '-disable[disable a track]:track ID' \
  '-new[force creation of a new file]' \
  '-flat[store file with all media data first]' \
  '-frag[fragment file]:duration_ms' \
  '-dash[DASH segment a file]:duration_ms' \
  '-dash-live[live DASH session]:duration_ms' \
  '-profile=[DASH profile]:profile:(live onDemand main full dashavc264\:live dashavc264\:onDemand)' \
  '-segment-name=[DASH segment name template]:template' \
  '-segment-ext=[segment file extension]:extension' \
  '-segment-timeline[use SegmentTimeline in DASH]' \
  '-single-segment[produce single segment DASH]' \
  '-url-template[use URL template in DASH]' \
  '-mpd-title=[MPD title]:title' \
  '-mpd-source=[MPD source]:source' \
  '-mpd-info-url=[MPD more info URL]:url' \
  '-base-url=[base URL for DASH]:url' \
  '-out=[output file]:file:_files' \
  '-tmp=[temporary directory]:directory:_files -/' \
  '-inter=[interleave duration in ms]:ms' \
  '-split=[split file]:duration_or_size' \
  '-split-size=[split by size]:bytes' \
  '-split-chunk=[extract a chunk]:start\:end' \
  '-splitx=[split file by extraction]:start\:end' \
  '-splitz=[split file at given time]:time' \
  '-info=[print media info]:track ID' \
  '-dts[print DTS info]' \
  '-cts[print CTS info]' \
  '-sdp[print SDP info]' \
  '-stat[print file statistics]' \
  '-diso[dump ISO file structure]' \
  '-dxml[dump ISO file structure as XML]' \
  '-bt[dump scene to BT format]' \
  '-xmt[dump scene to XMT-A format]' \
  '-drtp[dump RTP hint samples]' \
  '-raw=[extract raw track data]:track ID' \
  '-raws=[extract raw track data with SPS/PPS]:track ID' \
  '-nhnt=[extract track to NHNT format]:track ID' \
  '-nhml=[extract track to NHML format]:track ID' \
  '-single=[extract track to single sample format]:track ID' \
  '-avi=[extract track to AVI format]:track ID' \
  '-qcp=[extract track to QCP format]:track ID' \
  '-srt[extract subtitle track to SRT]:track ID' \
  '-ttxt[extract subtitle track to TTXT]:track ID' \
  '-nchunk=[extract track to chunks]:track ID\:nb_chunks' \
  '-lang=[set track language]:track ID=lang' \
  '-delay=[set track delay]:track ID=delay_ms' \
  '-name=[set track handler name]:track ID=name' \
  '-itags=[set iTunes tags]:tag=value' \
  '-brand=[set major brand]:brand' \
  '-ab=[add alternate brand]:brand' \
  '-rb=[remove alternate brand]:brand' \
  '-isma[create ISMA compliant file]' \
  '-ismax[create ISMA compliant file with extended features]' \
  '-3gp[create 3GP compliant file]' \
  '-ipod[create iPod compliant file]' \
  '-psp[create PSP compliant file]' \
  '-no-sys[remove all MPEG-4 systems info]' \
  '-no-iod[remove IOD from file]' \
  '-crypt=[encrypt file]:drm_file:_files -g "*.xml"' \
  '-decrypt=[decrypt file]:drm_file:_files -g "*.xml"' \
  '-set-kms=[set KMS URI for track]:track ID=URI' \
  '-hint[hint the file for RTP/RTSP]' \
  '-unhint[remove all hint tracks]' \
  '-mtu=[network path MTU]:bytes' \
  '-copy[insert moov before mdat]' \
  '-tight[tight interleaving]' \
  '*:MP4 file:_files -g "*.mp4 *.m4a *.m4v *.3gp *.3g2 *.mov *.ts *.m2ts"'
