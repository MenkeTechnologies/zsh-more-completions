#compdef pt-find
# Documentation: https://man.archlinux.org/search?q=pt-find
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--charset=[charset]:charset:' \
  '--case-insensitive[case insensitive]' \
  '--day-start[count days from beginning of day]' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--engine=[storage engine filter]:engine:' \
  '--exec=[exec SQL on each match]:sql:' \
  '--exec-plus=[batched SQL on matches]:sql:' \
  '--host=[MySQL host]:host:_hosts' \
  '--password=[MySQL password]:pw:' \
  '--port=[MySQL port]:port:' \
  '--print[print full path (default)]' \
  '--printf=[printf-style format]:fmt:' \
  '--socket=[MySQL socket]:file:_files' \
  '--user=[MySQL user]:user:' \
  '*:DSN_or_predicate:' && ret=0

return ret
