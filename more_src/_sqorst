#compdef sqorst
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss193.html
# KAPPA: squash or stretch an NDF in one or more dimensions

local ret=1

_arguments -s \
  'AXIS=[single axis to squash or stretch]:axis' \
  'CENTRE=[reference point for WCS transformation]:centre' \
  'CONSERVE=[preserve total data value]:conserve:(TRUE FALSE)' \
  'FACTORS=[distortion factors per dimension]:factors' \
  'IN=[input NDF]:NDF:_files' \
  'LBOUND=[lower pixel-index bounds of output]:lbound' \
  'METHOD=[interpolation method]:method' \
  'MODE=[how output shape is defined]:mode:(Factors Bounds PixelScale)' \
  'OUT=[output NDF]:NDF:_files' \
  'PARAMS=[resampling-scheme parameters]:params' \
  'PIXSCALE=[new pixel scales for WCS axes]:pixscale' \
  'TITLE=[title for the output NDF]:title' \
  'UBOUND=[upper pixel-index bounds of output]:ubound' \
  '*:NDF:_files' && ret=0

return ret
