#compdef cich
# ============================================================================
# cich - CipherChat-mini: minimal Matrix chat CLI (Node, MIT)
#
# Author : Neon-X Hub
# Upstream: https://github.com/neon-x-hub/cipher-chat-mini
# npm    : cipher-chat-mini
#
# cich is a commander-driven Node CLI that wraps a Matrix client
# in a terminal-first experience: log in (interactive prompt), join
# rooms, list rooms, send messages, fetch message history within
# a time range, and run a TUI chat session. Per-room E2E encryption
# via the underlying Matrix bot SDK's libolm bindings.
#
# Subcommands:
#   auth login / auth signup / auth logout
#   room join / leave / create / list / messages
#   bot start / stop / disable / enable / state / config
#
# Plus a top-level TUI session that drops into a per-room chat
# view after auth.
#
# The Matrix lane is built on `matrix-bot-sdk ^0.7.1` (declared
# verbatim at upstream package.json HEAD), the bot-focused fork
# of `matrix-js-sdk` maintained by Travis Ralston (turt2live,
# github.com/turt2live/matrix-bot-sdk, 270+ stars). matrix-bot-sdk
# is the lower-level / bot-oriented Matrix client - smaller surface
# than matrix-js-sdk (the Element Web engine), opinionated toward
# server-side workloads (no React deps, no UI helpers), and the
# de-facto pick for Node Matrix bots, bridges, and CLI utilities.
# It speaks the Matrix Client-Server API + Application Service
# API + the same Olm/Megolm encryption stack as the upstream
# matrix-js-sdk; the two libraries interoperate at the network
# level because they implement the same spec.
#
# Note: cich pulls in `matrix-bot-sdk` rather than the upstream
# `matrix-js-sdk` for the same reason most Node Matrix CLIs do -
# tighter bundle, fewer dependencies, server-side ergonomics. This
# is structurally similar to how Rust Matrix tools split between
# the larger matrix-rust-sdk (full client) and the lower-level
# ruma crate (protocol primitives only).
#
# ----------------------------------------------------------------------------
# AXIS 217 :: MATRIX CLIENT-SERVER API (matrix.org spec, end-to-end encrypted chat)  [CLOSES]
# Round 1351 :: TS-Node slot 3 of 4 :: CLOSES Axis 217 (210th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : matrix-org/matrix-rust-sdk            [R1349 _errornowatcher]
#   Go      : mautrix/go                            [R1350 _meowlnir]
#   TS/Node : turt2live/matrix-bot-sdk              [R1351 THIS FILE]
#
# All three lanes' canonical libraries interoperate end-to-end
# because Matrix is a published open spec (matrix.org) with
# multiple reference + production implementations. End-to-end
# encryption is delegated to libolm-derived implementations
# (Olm C library, vodozemac Rust port, libolm WASM in JS) so
# rooms encrypted by an Element Web user are decryptable by a
# matrix-rust-sdk client and vice versa.
# ============================================================================

_cich() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_cich_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                auth) _arguments '1:subcommand:(login signup logout)' '*::arg:->_default' ;;
                room) _cich_room ;;
                bot)  _arguments '1:subcommand:(start stop disable enable state config)' '*::arg:->_default' ;;
            esac
            ;;
    esac

    return ret
}

_cich_cmds() {
    local -a cmds
    cmds=(
        'auth:Authentication (login, signup, logout)'
        'room:Room management (join, leave, create, list, messages)'
        'bot:Manage the chat bot lifecycle (start, stop, enable, disable, state, config)'
    )
    _describe -t commands 'cich command' cmds
}

_cich_room() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[help]' \
        '1: :((join leave create list messages))' \
        '*::arg:->roomargs' \
    && ret=0

    case $state in
        roomargs)
            case $words[1] in
                join)     _arguments '1:room ID or alias:' ;;
                leave)    _arguments '1:room ID:' ;;
                create)   _arguments \
                              '(-n --name)'{-n,--name}'[room name]:name:' \
                              '(-p --public)'{-p,--public}'[make room public]' \
                              '(-e --encrypted)'{-e,--encrypted}'[enable E2E encryption]' \
                              '(-t --topic)'{-t,--topic}'[room topic]:topic:' ;;
                list)     _arguments '(-m --membership)'{-m,--membership}'[filter by membership]:type:(join invite leave all)' ;;
                messages) _arguments \
                              '1:room ID:' \
                              '(-s --start)'{-s,--start}'[start date (ISO or relative like 7d, 24h)]:date:' \
                              '(-e --end)'{-e,--end}'[end date (ISO or relative like now, 1h)]:date:' \
                              '(-l --limit)'{-l,--limit}'[max messages to fetch]:n:' \
                              '(-d --direction)'{-d,--direction}'[paginate direction]:dir:(forward backward)' ;;
            esac
            ;;
    esac

    return ret
}

_cich "$@"
