#compdef opendoor
# Documentation: https://man.archlinux.org/search?q=opendoor
# Reference accessed: 2026-05-16

# Zsh completion for opendoor — web recon CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'opendoor' scan crawl enumerate bruteforce report && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
