#compdef systemd-cryptsetup
# _crypttab — systemd-cryptsetup (per-volume helper invoked from systemd-cryptsetup@.service to read /etc/crypttab and attach/detach LUKS / TrueCrypt / plain dm-crypt volumes; subcommand attach <name> <device> [keyfile] [options], detach <name>)
# upstream: https://github.com/systemd/systemd (src/cryptsetup/cryptsetup.c)
# Argument shape from systemd src/cryptsetup/cryptsetup.c on tip.

_crypttab() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '1:command:(attach detach)' \
        '2:name:' \
        '3:device:_files' \
        '4:keyfile:_files' \
        '5:options:'
}

_crypttab "$@"
