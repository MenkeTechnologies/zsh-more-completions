#compdef copybara
# Documentation: https://github.com/google/copybara
# Reference accessed: 2026-05-17
# Verified: upstream README and reference docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'migrate:move and transform code between repositories'
  'validate:validate a Copybara config file'
  'info:show information about a workflow'
  'help:show help'
  'version:show version'
)

_arguments -s -S -C \
  '--help[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--config-root=[root directory for config resolution]:dir:_files -/' \
  '--git-destination-url=[override git destination URL]:url:' \
  '--git-origin-url=[override git origin URL]:url:' \
  '--dry-run[do not push or write outputs]' \
  '--force[force operation]' \
  '--init-history[initialize migration history]' \
  '--squash[squash all pending commits]' \
  '--last-rev=[explicit last migrated revision]:ref:' \
  '--output-root=[output root directory]:dir:_files -/' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'copybara command' commands && ret=0
    ;;
  args)
    _arguments \
      '1:config file:_files -g "*.bara.sky"' \
      '2:workflow name:' \
      '3:source ref:' && ret=0
    ;;
esac

return ret
