#compdef zoomeye

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize API key'
      'info:show account information'
      'search:search for hosts or web apps'
      'ip:query IP information'
      'history:query IP history'
      'domain:search domain information'
      'clear:clear local cache'
    )
    _describe -t commands 'zoomeye command' commands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--apikey=[API key]:api key' && ret=0
        ;;
      info)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-d,--dork}'=[search dork query]:dork' \
          '-num=[number of results]:number' \
          '-type=[search type]:type:(host web)' \
          '-page=[page number]:page' \
          '-force[force search without cache]' \
          '-count[only show count]' \
          '-facet=[facet fields]:facet' \
          '-stat=[statistics fields]:stat' \
          '-filter=[filter fields]:filter' \
          '-save=[save results to file]:output file:_files' \
          '-figure=[show chart figure]:figure:(pie)' && ret=0
        ;;
      ip)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-force[force query without cache]' \
          '-filter=[filter fields]:filter' \
          '1:IP address' && ret=0
        ;;
      history)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-force[force query without cache]' \
          '-filter=[filter fields]:filter' \
          '1:IP address' && ret=0
        ;;
      domain)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-d,--dork}'=[domain query]:dork' \
          '-page=[page number]:page' \
          '-type=[search type]:type:(0 1)' \
          '-count[only show count]' && ret=0
        ;;
      clear)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
