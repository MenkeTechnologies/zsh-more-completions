#compdef det
# Documentation: https://docs.determined.ai/latest/reference/cli-reference.html
# Determined AI deep-learning training platform command-line client

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print CLI version and exit]' \
  '(-u --user)'{-u,--user}'=[run as the specified user]:user:' \
  '(-m --master)'{-m,--master}'=[master address]:address:' \
  '1:command:((
    auth\:"authentication management"
    agent\:"manage agents"
    command\:"manage commands"
    checkpoint\:"manage checkpoints"
    deploy\:"deploy a cluster"
    experiment\:"manage experiments"
    job\:"manage jobs"
    master\:"manage the master"
    model\:"manage models"
    notebook\:"manage notebooks"
    oauth\:"manage OAuth"
    preview-search\:"preview a hyperparameter search"
    resources\:"resource allocation history"
    shell\:"manage shells"
    slot\:"manage slots"
    task\:"manage tasks"
    template\:"manage configuration templates"
    config-policies\:"manage configuration policies"
    tensorboard\:"manage TensorBoard instances"
    trial\:"manage trials"
    user\:"manage users"
    version\:"show version information"
  ))' \
  '*::arg:->args' && ret=0

return ret
