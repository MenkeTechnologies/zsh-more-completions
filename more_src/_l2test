#compdef l2test
# Documentation: https://man.archlinux.org/search?q=l2test
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-r[reverse-receive mode]' \
  '-s[connect mode]' \
  '-w[wait]' \
  '-d[dump mode]' \
  '-x[recv with delay]' \
  '-y[delay rate]' \
  '-c+[command]:cmd:' \
  '-b+[bytes]:n:' \
  '-i+[hci dev]:dev:' \
  '-p+[psm]:psm:' \
  '*:bdaddr:' && ret=0

return ret
