#compdef GtcToVcf
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/arrays/GtcToVcf.java
# Picard: converts an Illumina GTC file to a VCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[GTC file to be converted]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output VCF file to write]:file:_files' \
  '(-MANIFEST --EXTENDED_ILLUMINA_MANIFEST)'{-MANIFEST,--EXTENDED_ILLUMINA_MANIFEST}'=[extended Illumina manifest csv]:file:_files' \
  '(-CF --CLUSTER_FILE)'{-CF,--CLUSTER_FILE}'=[Illumina cluster file egt]:file:_files' \
  '(-BPM_FILE --ILLUMINA_BEAD_POOL_MANIFEST_FILE)'{-BPM_FILE,--ILLUMINA_BEAD_POOL_MANIFEST_FILE}'=[Illumina bead pool manifest bpm file]:file:_files' \
  '(-E_GENDER --EXPECTED_GENDER)'{-E_GENDER,--EXPECTED_GENDER}'=[expected gender for sample]:s:' \
  '--SAMPLE_ALIAS=[sample alias identifier]:s:' \
  '--PIPELINE_VERSION=[pipeline version used to generate VCF]:s:' \
  '--ANALYSIS_VERSION_NUMBER=[analysis version number]:n:' \
  '(-G_GTC --GENDER_GTC)'{-G_GTC,--GENDER_GTC}'=[GTC file optimized for gender calling]:file:_files' \
  '(-FP_VCF --FINGERPRINT_GENOTYPES_VCF_FILE)'{-FP_VCF,--FINGERPRINT_GENOTYPES_VCF_FILE}'=[fingerprint VCF for sample]:file:_files' \
  '--DO_NOT_ALLOW_CALLS_ON_ZEROED_OUT_ASSAYS=[fail if calls on zeroed-out assays]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
