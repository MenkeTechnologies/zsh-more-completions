#compdef sd-mux-ctrl

# sd-mux-ctrl: control SD-Mux device for shared SD card access
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '-l[list connected SD-Mux devices]' \
  '-e[set hostname]:host:' \
  '-d[device by name]:dev:' \
  '-i[index]:n:' \
  '--dut[connect SD card to DUT]' \
  '--ts[connect SD card to test station]' \
  '--device-power=[set DUT power]:state:(on off)' \
  '--usb=[set USB to DUT/TS]:dest:(dut ts)' \
  '*::sd-mux-ctrl args:_files' && ret=0
return ret
