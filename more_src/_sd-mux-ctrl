#compdef sd-mux-ctrl
# Documentation: https://man.archlinux.org/man/sd-mux-ctrl.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# sd-mux-ctrl: control SD-Wire SD card multiplexer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-l[list connected SD-Wire devices]' \
  '--list[list connected SD-Wire devices]' \
  '-d[serial number of device]:serial:' \
  '--device-serial=[serial number of device]:serial:' \
  '-v[show version]' \
  '--vendor=[USB vendor id]:vid:' \
  '--product=[USB product id]:pid:' \
  '--dut[switch SD card to DUT]' \
  '--ts[switch SD card to test station]' \
  '--set-serial=[program new serial number]:serial:' \
  '--status[print mux status]' \
  '--info[show device info]' \
  '*::sd-mux-ctrl args:_files' && ret=0
return ret
