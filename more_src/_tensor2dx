#compdef tensor2dx
# Documentation: https://apbs.readthedocs.io/en/latest/using/tools.html
# Convert tensor grid data to OpenDX format

local ret=1

_arguments -s \
  '1:x grid points:' \
  '2:y grid points:' \
  '3:z grid points:' \
  '4:origin file:_files' \
  '5:data file:_files' && ret=0

return ret
