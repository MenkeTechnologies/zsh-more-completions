#compdef mlxlink
# Documentation: https://man.archlinux.org/search?q=mlxlink
# Reference accessed: 2026-05-16

# mlxlink: Mellanox link / cable diagnostics
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-d[device]:dev:' \
  '--device=[device]:dev:' \
  '-p[port number]:n:' \
  '--port=[port number]:n:' \
  '--depth=[port depth]:n:' \
  '--pcie_index=[PCIe index]:n:' \
  '--node=[node]:n:' \
  '-c[show cable info]' \
  '--cable[show cable info]' \
  '--dme[show data me]' \
  '--ddm[show diagnostic monitoring]' \
  '--cable_dump[full cable dump]' \
  '--write[write cable register]:offset:value:' \
  '--read[read cable register]:offset:' \
  '--troubleshoot[run troubleshooting]' \
  '--show_advanced[show advanced fields]' \
  '--show_eye[print eye]' \
  '--show_serdes[serdes registers]' \
  '--show_fec[show FEC info]' \
  '--show_module[show module info]' \
  '--show_link_partner[show link partner]' \
  '*::mlxlink args:_files' && ret=0
return ret
