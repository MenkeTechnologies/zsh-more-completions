#compdef mlxlink
# Documentation: https://docs.nvidia.com/networking/display/mftv421/mlxlink+utility
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --device)'{-d+,--device=}'[mst device]:dev:' \
  '(-p --port)'{-p+,--port=}'[port number]:n:' \
  '--port_type=[port type]:type:(NETWORK PCIE OOB)' \
  '--depth=[DUT hierarchy depth]:n:' \
  '--pcie_index=[internal domain index]:n:' \
  '--node=[node index]:n:' \
  '--show_links[show valid PCIe links]' \
  '(-m --show_module)'{-m,--show_module}'[module information]' \
  '(-c --show_counters)'{-c,--show_counters}'[physical counters and BER]' \
  '(-e --show_eye)'{-e,--show_eye}'[eye opening data]' \
  '--show_fec[FEC capabilities]' \
  '--show_serdes_tx[transmitter parameters]' \
  '--show_device[general device info]' \
  '--show_ber_monitor[BER monitor data]' \
  '--show_external_phy[external PHY info]' \
  '(-a --port_state)'{-a+,--port_state=}'[port state]:state:(UP DN TG)' \
  '(-s --speeds)'{-s+,--speeds=}'[link speeds]:speeds:' \
  '--link_mode_force=[force link mode]:b:' \
  '(-l --loopback)'{-l+,--loopback=}'[loopback mode]:mode:(NO RM PH EX)' \
  '(-k --fec)'{-k+,--fec=}'[FEC mode]:fec:(AU NF FC RS LL DF-RS DF-LL)' \
  '--serdes_tx=[serdes TX parameters]:params:' \
  '--serdes_tx_lane=[serdes TX lane]:n:' \
  '--database[save permanently]' \
  '--tx_params_override[override TX params]' \
  '--cable[enable cable operations]' \
  '--prbs_select=[PRBS select]:s:(MEDIA HOST)' \
  '--prbs_mode=[PRBS mode]:m:(EN DS)' \
  '--generator_pattern=[generator pattern]:p:(PRBS31 PRBS23 PRBS7 PRBS11 PRBS9 PRBS13 SSPR SSPRQ)' \
  '--checker_pattern=[checker pattern]:p:(PRBS31 PRBS23 PRBS7 PRBS11 PRBS9 PRBS13 SSPR SSPRQ)' \
  '--lane_rate=[lane rate]:r:(HDR SDR FDR EDR NDR)' \
  '--swap_generator[PAM4 MSB/LSB swap generator]' \
  '--invert_generator[invert generator]' \
  '--swap_checker[swap checker]' \
  '--invert_checker[invert checker]' \
  '--generator_lanes=[generator lane indices]:lanes:' \
  '--checker_lanes=[checker lane indices]:lanes:' \
  '--test_mode=[PRBS test mode]:mode:(EN DS TU)' \
  '--rx_prbs=[RX PRBS pattern]:p:' \
  '--tx_prbs=[TX PRBS pattern]:p:' \
  '--rx_rate=[RX rate]:r:' \
  '--tx_rate=[TX rate]:r:' \
  '--invert_tx_polarity[invert TX polarity]' \
  '--invert_rx_polarity[invert RX polarity]' \
  '--lanes=[lane indices]:lanes:' \
  '--dump[dump cable EEPROM]' \
  '--ddm[digital optical monitoring]' \
  '--read[read cable EEPROM]' \
  '--write=[write cable EEPROM hex bytes]:bytes:' \
  '--page=[EEPROM page]:n:' \
  '--offset=[EEPROM offset]:n:' \
  '--length=[EEPROM length]:n:' \
  '--margin[enable eye margin scan]' \
  '--measure_time=[margin measure time sec]:s:(10 30 60 90 120 240 480 600 900)' \
  '--eye_select=[eye select]:e:(UP MID DOWN ALL)' \
  '--lane=[specific lane index]:n:' \
  '(-b --ber_collect)'{-b+,--ber_collect=}'[BER collect CSV file]:file:_files' \
  '--amber_collect=[amber collect CSV]:file:_files' \
  '--ber_limit=[BER limit]:l:(Nominal Corner Drift)' \
  '--iteration=[iteration count]:n:' \
  '--pc[clear counters]' \
  '--json[JSON output]' \
  '--yes[non-interactive]' && ret=0
return ret
