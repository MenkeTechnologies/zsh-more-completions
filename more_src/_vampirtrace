#compdef vampirtrace vtcc vtc++ vtcxx vtfort vtf90 vtf77 vtrun vtfilter vtunify vtdyn
# _vampirtrace — TU Dresden ZIH VampirTrace performance tracing library compiler wrappers and post-processing tools (Vampir team, C); custom argparse
# upstream: https://tu-dresden.de/zih/forschung/projekte/vampirtrace

_vampirtrace() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-vt:cc+[CC compiler]:str:' \
        '-vt:cxx+[CXX compiler]:str:' \
        '-vt:f77+[F77 compiler]:str:' \
        '-vt:fc+[F90 compiler]:str:' \
        '-vt:mpi+[MPI mode]:b:(0 1)' \
        '-vt:show[show command]' \
        '-vt:showme[show command]' \
        '-vt:verbose[verbose]' \
        '-vt:opari[opari mode]' \
        '-vt:nodyninst[no dyninst]' \
        '-vt:noompi[no OpenMPI]' \
        '-vt:nompi[no MPI]' \
        '-vt:hyb[hybrid mode]' \
        '-vt:omp[OpenMP mode]' \
        '-vt:seq[sequential]' \
        '-vt:noopari[no opari]' \
        '-vt:inst+[instrumentation type]:t:(manual compinst manualinst dyninst)' \
        '-vt:filter+[filter file]:file:_files' \
        '-vt:bin+[binary path]:file:_files' \
        '-vt:rep+[N]:n:' \
        '-vt:strip-headers[strip headers]' \
        '-c[compile only]' \
        '-o+[output file]:file:_files' \
        '-l+[library]:str:' \
        '-L+[lib dir]:dir:_files -/' \
        '-I+[include dir]:dir:_files -/' \
        '-D+[macro]:str:' \
        '*:source file:_files -g "*.c *.cpp *.cxx *.f *.f90 *.f95"'
}

_vampirtrace "$@"
