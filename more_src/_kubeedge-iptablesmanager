#compdef kubeedge-iptablesmanager iptablesmanager
# _kubeedge-iptablesmanager — KubeEdge iptables manager (programs NAT rules so cloudcore can forward kubectl exec/logs into edge nodes via the stream tunnel)
# upstream: https://github.com/kubeedge/kubeedge
# Flags from cloud/cmd/iptablesmanager/app/{server,options/options}.go on tip.

_kubeedge-iptablesmanager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[path to kubeconfig]:file:_files' \
        '--forwardport=[forward port (default = cloudcore stream port 10003)]:port:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)'
}

_kubeedge-iptablesmanager "$@"
