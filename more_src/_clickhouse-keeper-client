#compdef clickhouse-keeper-client
# Documentation: https://man.archlinux.org/search?q=clickhouse-keeper-client
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)--help[show help]' \
  '(-q --query)'{-q,--query=}'[query to run]:query:' \
  '(-h --host)'{-h,--host=}'[server host]:host:_hosts' \
  '(-p --port)'{-p,--port=}'[server port]:port:' \
  '(-c --config-file)'{-c,--config-file=}'[config file]:file:_files' \
  '--connection-timeout=[connection timeout]:duration:' \
  '--session-timeout=[session timeout]:duration:' \
  '--operation-timeout=[operation timeout]:duration:' \
  '--history-file=[history file]:file:_files' \
  '--log-level=[log level]:level:(trace debug information warning error fatal)' \
  '--password=[password]:password:' \
  '--identity=[identity]:identity:' \
  '--no-confirmation[skip confirmations]'
