#compdef cargo-mommy
# Documentation: https://github.com/Gankra/cargo-mommy
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cargo-mommy has no proper CLI flags of its own; it forwards all
# arguments to `cargo` and is configured via CARGO_MOMMYS_* env vars.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*: :_files' && ret=0

return ret
