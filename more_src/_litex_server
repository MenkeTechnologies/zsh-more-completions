#compdef litex_server
# Documentation: https://github.com/enjoy-digital/litex/blob/master/litex/tools/litex_server.py
# LiteX remote bus server (bridges host to SoC over UART/JTAG/UDP/PCIe/USB)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--bind-ip=[host bind address]:ip:' \
  '--bind-port=[host bind port]:port:' \
  '--addr-width=[bus address width]:width:' \
  '--debug[enable debug]' \
  '--uart[select UART interface]' \
  '--uart-port=[set UART port]:port:_files' \
  '--uart-baudrate=[set UART baudrate]:baud:' \
  '--jtag[select JTAG interface]' \
  '--jtag-config=[OpenOCD JTAG configuration file]:file:_files' \
  '--jtag-chain=[JTAG chain]:chain:' \
  '--udp[select UDP interface]' \
  '--udp-ip=[set UDP remote IP address]:ip:' \
  '--udp-port=[set UDP remote port]:port:' \
  '--udp-scan[scan network for available UDP devices]' \
  '--pcie[select PCIe interface]' \
  '--pcie-bar=[set PCIe BAR]:bar:' \
  '--usb[select USB interface]' \
  '--usb-vid=[set USB vendor ID]:vid:' \
  '--usb-pid=[set USB product ID]:pid:' \
  '--usb-max-retries=[number of USB reconnecting retries]:n:' && ret=0

return ret
