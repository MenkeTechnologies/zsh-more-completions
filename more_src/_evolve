#compdef evolve
# Documentation: https://evolve-db.netlify.app/getting-started/tool/
# Evolve database migration tool for .NET (inspired by Flyway)

local ret=1

_arguments -s -C \
  '(-? -h --help)'{-\?,-h,--help}'[show help]' \
  '(-c --connection-string)'{-c,--connection-string}'=[connection string to the target database engine]:connstring' \
  '(-l --location)'{-l,--location}'=[paths to scan recursively for migration scripts]:dir:_files -/' \
  '(-s --schema)'{-s,--schema}'=[list of schemas managed by Evolve]:schema' \
  '(-p --placeholder)'{-p,--placeholder}'=[strings to replace in scripts (key:value)]:placeholder' \
  '--metadata-table=[name of the metadata table]:table' \
  '1:command:(migrate erase repair info)' \
  '*::arg:_default' && ret=0

return ret
