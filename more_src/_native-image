#compdef native-image

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version information]' \
  '--expert-options[list image build options for experts]' \
  '--expert-options-all[list all image build options]' \
  '--expert-options-detail[show option details]' \
  '-cp+[class search path]:classpath:_files' \
  '-classpath+[class search path]:classpath:_files' \
  '--class-path=[class search path]:classpath:_files' \
  '-jar+[jar file to build from]:jar file:_files -g "*.jar"' \
  '-o+[name of the output file]:output file:_files' \
  '--no-fallback[build a standalone image without fallback mode]' \
  '--force-fallback[force building with fallback mode]' \
  '--allow-incomplete-classpath[allow incomplete classpath at build time]' \
  '--initialize-at-build-time=[initialize classes at build time]:class list' \
  '--initialize-at-run-time=[initialize classes at run time]:class list' \
  '--install-exit-handlers[install signal handlers for exit]' \
  '-H:+Name=[set the image name]:name' \
  '-H:+Path=[set the image output directory]:directory:_directories' \
  '-H:+Class=[set the main class]:class name' \
  '-H:+[image build option]:option' \
  '-J+[pass option to the JVM]:JVM option' \
  '-g[generate debug information]' \
  '--verbose[enable verbose output]' \
  '--diagnostics-mode[enable diagnostics]' \
  '--dry-run[show what would be done without building]' \
  '--static[build a statically linked image]' \
  '--libc=[C library to use]:libc:(glibc musl)' \
  '--shared[build a shared library instead of executable]' \
  '--pgo=[PGO profile data]:profile file:_files' \
  '--pgo-instrument[build with PGO instrumentation]' \
  '--gc=[set the garbage collector]:gc:(serial epsilon G1)' \
  '--enable-preview[enable preview features]' \
  '--enable-monitoring=[enable monitoring features]:features' \
  '--enable-sbom=[embed SBOM in the image]:format' \
  '--enable-http[enable HTTP support]' \
  '--enable-https[enable HTTPS support]' \
  '--enable-url-protocols=[enable URL protocols]:protocols' \
  '--features=[enable features]:feature classes' \
  '-march=[set machine type for AOT compilation]:arch:(compatibility native x86-64-v3)' \
  '--no-server[do not use native image build server]' \
  '--report-unsupported-elements-at-runtime[report unsupported elements at runtime]' \
  '--trace-class-initialization=[trace class initialization]:class name' \
  '--trace-object-instantiation=[trace object instantiation]:class name' \
  '*:class or file:_files' && ret=0

return ret
