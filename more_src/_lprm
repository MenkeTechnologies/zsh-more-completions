#compdef lprm
# Documentation: https://manpages.debian.org/lprm
# Source: OpenPrinting/cups berkeley/lprm.c — BSD-style print job remover (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[use encryption]' \
    '-P+[printer or class]:printer:_default' \
    '-U+[username for authentication]:user:_users' \
    '-h+[connect to CUPS server[:port]]:host:_hosts' \
    '*:job ID or "-" for all:_default' \
    && ret=0

return ret
