#compdef pegasus-statistics
# Documentation: https://pegasus.isi.edu/documentation/manpages/pegasus-statistics.html
# pegasus-statistics - generate statistics about the run of a Pegasus workflow

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print a usage summary with all available options]' \
  '(-o --output)'{-o,--output}'=[specify the output directory for results]:dir:_files -/' \
  '(-c --conf)'{-c,--conf}'=[the properties file to use, overrides all other property files]:file:_files' \
  '(-f --file)'{-f,--file}'=[specify the output format]:format:(text csv)' \
  '(-s --statistics-level)'{-s,--statistics-level}'=[statistics information to generate]:level:(all summary wf_stats jb_stats tf_stats ti_stats int_stats)' \
  '(-t --time-filter)'{-t,--time-filter}'=[time grouping for statistics]:filter:(month week day hour)' \
  '(-i --ignore-db-inconsistency)'{-i,--ignore-db-inconsistency}'[turn off the check for database consistency]' \
  '(-v --verbose)'{-v,--verbose}'[increase logging verbosity to INFO or DEBUG]' \
  '(-q --quiet)'{-q,--quiet}'[decrease logging level to ERROR]' \
  '(-m --multiple-wf)'{-m,--multiple-wf}'[enable statistics generation across multiple workflows]' \
  '(-p --ispmc)'{-p,--ispmc}'[generate statistics for workflows with PMC clustering enabled]' \
  '(-u --isuuid)'{-u,--isuuid}'[treat positional arguments as workflow UUIDs not directories]' \
  '*:submit dir:_files -/' && ret=0

return ret
