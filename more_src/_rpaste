#compdef rpaste
# Documentation: https://github.com/orhun/rustypaste-cli
# Reference accessed: 2026-05-21
# Verified: upstream rustypaste-cli docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --server-version)'{-V,--server-version}'[show server version]' \
  '(-l --list)'{-l,--list}'[list files on the server]' \
  '(-d --delete)'{-d,--delete}'[delete file(s) from the server]' \
  '(-o --oneshot)'{-o,--oneshot}'[create a one-shot link]' \
  '(-c --config)'{-c,--config}'[specify custom config file]:file:_files' \
  '(-s --server)'{-s,--server}'[rustypaste server URL]:url' \
  '(-a --auth)'{-a,--auth}'[auth or delete token]:token' \
  '(-u --url)'{-u,--url}'[shorten a URL]:url' \
  '(-r --remote)'{-r,--remote}'[upload from remote URL]:url' \
  '(-e --expire)'{-e,--expire}'[link expiration duration]:duration' \
  '(-n --filename)'{-n,--filename}'[override server-side filename]:name' \
  '(-p --pretty)'{-p,--pretty}'[pretty-print output]' \
  '*:file:_files'
