#compdef mapscii

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--latitude=[initial latitude in decimal degrees]:latitude' \
  '--longitude=[initial longitude in decimal degrees]:longitude' \
  '--zoom=[initial zoom level]:zoom level' \
  '--width=[terminal width in columns]:columns' \
  '--height=[terminal height in rows]:rows' \
  '--braille[use braille characters for rendering]' \
  '--projection=[map projection]:projection:(mercator equirectangular)'
