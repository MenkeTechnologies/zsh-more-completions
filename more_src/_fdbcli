#compdef fdbcli

# Zsh completion for fdbcli - FoundationDB CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-C --cluster-file)'{-C+,--cluster-file=}'[path to cluster file]:cluster file:_files' \
  '--exec=[execute command and exit]:command:' \
  '--log[enable trace file logging]' \
  '--log-dir=[directory for trace files]:log directory:_directories' \
  '--trace-format=[trace file format]:format:(xml json)' \
  '--tls-certificate-file=[path to TLS certificate file]:cert file:_files -g "*.{pem,crt}"' \
  '--tls-key-file=[path to TLS private key file]:key file:_files -g "*.{pem,key}"' \
  '--tls-ca-file=[path to TLS CA file]:ca file:_files -g "*.{pem,crt}"' \
  '--tls-password=[TLS key passphrase]:password:' \
  '--tls-verify-peers=[TLS peer verification rules]:rules:' \
  '--debug-tls[print TLS debug information]' \
  '--timeout=[timeout in seconds]:seconds:' \
  '--memory=[memory limit]:memory:' \
  '--build-flags[print build flags]' \
  '--api-version=[API version to use]:version:' \
  '--status-from-json=[read status from JSON file]:json file:_files -g "*.json"' \
  '*--knob-[set a runtime knob]:knob name=value:' && ret=0

return ret
