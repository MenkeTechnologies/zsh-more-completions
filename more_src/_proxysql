#compdef proxysql

_arguments -s \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-D --datadir)'{-D,--datadir=}'[data directory]:dir:_files -/' \
  '(-e --exit-on-error)'{-e,--exit-on-error}'[disable auto-restart on crash]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(- *)'{-h,--help,-help,--usage}'[show help]' \
  '(-M --no-monitor)'{-M,--no-monitor}'[disable Monitor Module]' \
  '(-n --no-start)'{-n,--no-start}'[start only Admin service]' \
  '(-r --reuseport)'{-r,--reuseport}'[enable SO_REUSEPORT]' \
  '(-S --admin-socket)'{-S,--admin-socket=}'[admin Unix socket path]:path:_files' \
  '(-U --uuid)'{-U,--uuid=}'[set UUID]:uuid:' \
  '(- *)'{-V,--version}'[print version]' \
  '--clickhouse-server[enable ClickHouse server]' \
  '--idle-threads[auxiliary threads for idle connections]' \
  '--initial[rename/empty database file]' \
  '--no-version-check[skip latest version check]' \
  '--reload[merge config file into database]' \
  '--sqlite3-server[enable SQLite3 server]'
