#compdef gfsh

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'alter:alter region or runtime configuration'
  'backup:back up persistent data'
  'change:change config (e.g. loglevel)'
  'clear:clear defined indexes or other state'
  'close:close a durable client/cq'
  'compact:compact disk-store or all disk-stores'
  'configure:configure pdx or other settings'
  'connect:connect to a Geode locator/JMX manager'
  'create:create region/index/disk-store/lucene/etc.'
  'debug:enable or disable debugging'
  'define:define an index or query'
  'deploy:deploy JAR/JARs to members'
  'describe:describe a region/member/connection/disk-store'
  'destroy:destroy a region/index/disk-store/etc.'
  'disconnect:disconnect from the connected locator'
  'echo:echo text/expression'
  'execute:execute a function'
  'exit:exit gfsh'
  'export:export configuration/data/logs/stack-traces'
  'gc:run garbage collection'
  'get:get an entry from a region'
  'help:show help'
  'hint:show hints'
  'history:show command history'
  'import:import data into the cluster'
  'list:list members/regions/disk-stores/indexes/etc.'
  'load-balance:rebalance gateway-senders or partitioned regions'
  'locate:locate an entry'
  'netstat:run a netstat-like report'
  'pause:pause a gateway-sender'
  'pdx:configure or rename PDX types'
  'put:put an entry into a region'
  'query:execute an OQL query'
  'rebalance:rebalance the cluster'
  'remove:remove an entry from a region'
  'restore:restore redundancy'
  'resume:resume a paused gateway-sender'
  'revoke:revoke a missing disk-store'
  'run:run gfsh commands from a script file'
  'set:set variable values'
  'sh:shell escape'
  'show:show metrics/log/dead-locks/missing-disk-stores/subscription-queue-size'
  'shutdown:shutdown the cluster'
  'sleep:sleep for given seconds'
  'start:start locator/server/jconsole/pulse/jvisualvm/gfmon'
  'status:show status of a locator or server'
  'stop:stop a locator or server'
  'undeploy:undeploy a JAR'
  'validate:validate a disk-store offline'
  'version:show version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'gfsh subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create|destroy|describe|list|alter|show)
        _values 'object' \
          'region' 'index' 'disk-store' 'lucene' 'lucene-index' \
          'gateway-receiver' 'gateway-sender' 'async-event-queue' \
          'jndi-binding' 'data-source' 'member' 'function' 'client' \
          'durable-cqs' 'durable-client-cqs' 'metrics' 'log' \
          'connections' 'subscription-queue-size' 'dead-locks' && ret=0
        ;;
      (start)
        _values 'start target' \
          'locator' 'server' 'jconsole' 'pulse' 'jvisualvm' 'gfmon' && ret=0
        ;;
      (stop|status)
        _values 'target' 'locator' 'server' 'gateway-sender' 'gateway-receiver' && ret=0
        ;;
      (export|import)
        _values 'export target' \
          'data' 'config' 'cluster-configuration' 'logs' 'stack-traces' 'offline-disk-store' && ret=0
        ;;
      (define)
        _values 'define target' 'index' && ret=0
        ;;
      (clear)
        _values 'clear target' 'defined' 'defined indexes' && ret=0
        ;;
      (pdx)
        _values 'pdx action' 'rename' && ret=0
        ;;
      (validate)
        _values 'validate target' 'offline-disk-store' && ret=0
        ;;
      (load-balance)
        _values 'load-balance target' 'gateway-sender' && ret=0
        ;;
      (pause|resume)
        _values 'target' 'gateway-sender' && ret=0
        ;;
      (revoke)
        _values 'revoke target' 'missing-disk-store' && ret=0
        ;;
      (backup|compact)
        _values 'target' 'disk-store' && ret=0
        ;;
      (change)
        _values 'change target' 'loglevel' && ret=0
        ;;
      (configure)
        _values 'configure target' 'pdx' && ret=0
        ;;
      (set)
        _values 'set target' 'variable' && ret=0
        ;;
      (run)
        _files
        ret=0
        ;;
    esac
    ;;
esac

return ret
