#compdef rew
# rew — file path rewriting tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--diff[print differences between input and output paths]' \
  '--dry-run[do not perform any filesystem operations]' \
  '-e[evaluate pattern as an expression]:expression:' \
  '-f[read pattern from a file]:file:_files' \
  '--no-clobber[do not overwrite existing files]' \
  '(-p --parents)'{-p,--parents}'[create parent directories as needed]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--yes[do not ask for confirmation]' \
  '--color=[when to use color]:when:(auto always never)' \
  '*:pattern or file:_files' \
  && ret=0

return ret
