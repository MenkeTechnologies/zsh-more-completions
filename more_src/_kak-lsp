#compdef kak-lsp
# Documentation: https://man.archlinux.org/search?q=kak-lsp
# Reference accessed: 2026-05-16

_arguments -s \
  '--kakoune[print Kakoune commands]' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '(-d --daemonize)'{-d,--daemonize}'[daemonize]' \
  '(-s --session)'{-s,--session}'=[session]:session:' \
  '(-t --timeout)'{-t,--timeout}'=[seconds]:n:' \
  '*-v[verbose]' \
  '--debug[debug logging]' \
  '--log=[log file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]'
