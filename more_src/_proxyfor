#compdef proxyfor
# Documentation: https://github.com/sigoden/proxyfor
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for proxyfor (github.com/sigoden/proxyfor, clap)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-l --listen)'{-l,--listen}'[listen address]:addr' \
  '(-f --filters)'{-f,--filters}'[regex filter on method+uri]:regex' \
  '(-m --mime-filters)'{-m,--mime-filters}'[content-type substring]:value' \
  '(-W --web)'{-W,--web}'[enable web UI]' \
  '(-T --tui)'{-T,--tui}'[TUI mode]' \
  '(-D --dump)'{-D,--dump}'[dump traffic to console]' \
  '1::reverse proxy URL:url' && ret=0

return ret
