#compdef systemd-logind
# _systemd-logind (systemd login + seat management daemon owning sessions, seats, user slices and inhibitor locks; controlled at runtime by loginctl(1); reads /etc/systemd/logind.conf; daemon binary accepts only standard systemd unit args)
# upstream: https://github.com/systemd/systemd (src/login)
# Argument shape from systemd src/login/logind.c on tip.

_systemd-logind() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-logind "$@"
