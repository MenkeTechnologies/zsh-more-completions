#compdef autodock_gpu adgpu
# Documentation: https://github.com/ccsb-scripps/AutoDock-GPU
# autodock_gpu - OpenCL/CUDA accelerated AutoDock (AD-GPU).

local ret=1

_arguments -s -S \
  '(-M --ffile)'{-M+,--ffile=}'[grid map field file (.maps.fld)]:file:_files' \
  '(-L --lfile)'{-L+,--lfile=}'[ligand PDBQT file]:file:_files' \
  '(-F --flexres)'{-F+,--flexres=}'[flexible residue PDBQT file]:file:_files' \
  '(-B --filelist)'{-B+,--filelist=}'[batch file list]:file:_files' \
  '(-I --import_dpf)'{-I+,--import_dpf=}'[import AutoDock4 DPF file]:file:_files' \
  '(-R --xraylfile)'{-R+,--xraylfile=}'[reference ligand for RMSD]:file:_files' \
  '(-N --resnam)'{-N+,--resnam=}'[output log file name]:name:' \
  '(-C --contact_analysis)'{-C+,--contact_analysis=}'[distance-based interaction analysis]:n:' \
  '(-x --xmloutput)'{-x+,--xmloutput=}'[generate XML output]:n:(0 1)' \
  '(-d --dlgoutput)'{-d+,--dlgoutput=}'[create DLG output]:n:(0 1)' \
  '(-2 --dlg2stdout)'{-2+,--dlg2stdout=}'[write DLG to stdout]:n:(0 1)' \
  '--clustering=[output clustering analysis]:n:(0 1)' \
  '--gbest=[output best pose as PDBQT]:n:(0 1)' \
  '--npdb=[number of pose PDBQT files]:n:' \
  '(-D --devnum)'{-D+,--devnum=}'[GPU device number]:n:' \
  '(-c --loadxml)'{-c+,--loadxml=}'[load initial population from XML]:file:_files' \
  '(-s --seed)'{-s+,--seed=}'[random seeds (comma-separated)]:seeds:' \
  '(-n --nrun)'{-n+,--nrun=}'[number of LGA runs]:n:' \
  '(-e --nev)'{-e+,--nev=}'[max score evaluations per run]:n:' \
  '(-g --ngen)'{-g+,--ngen=}'[max generations per run]:n:' \
  '(-l --lsmet)'{-l+,--lsmet=}'[local-search method]:method:(sw sd fire ad adam)' \
  '(-i --lsit)'{-i+,--lsit=}'[max local-search iterations]:n:' \
  '(-p --psize)'{-p+,--psize=}'[population size]:n:' \
  '(-H --heuristics)'{-H+,--heuristics=}'[enable automatic search method]:n:(0 1)' \
  '(-E --heurmax)'{-E+,--heurmax=}'[heuristic evaluations limit]:n:' \
  '(-A --autostop)'{-A+,--autostop=}'[convergence-based stopping]:n:(0 1)' \
  '(-a --asfreq)'{-a+,--asfreq=}'[AutoStop test frequency]:n:' \
  '--mrat=[mutation rate %]:n:' \
  '--crat=[crossover rate %]:n:' \
  '--lsrat=[local-search rate %]:n:' \
  '--trat=[tournament selection rate %]:n:' \
  '--dmov=[max LGA movement delta]:n:' \
  '--dang=[max LGA angle delta]:n:' \
  '--rholb=[Solis-Wets rho lower bound]:n:' \
  '--lsmov=[Solis-Wets movement delta]:n:' \
  '--lsang=[Solis-Wets angle delta]:n:' \
  '--cslim=[Solis-Wets success/failure limit]:n:' \
  '--initswgens=[initial Solis-Wets generations]:n:' \
  '(-T --derivtype)'{-T+,--derivtype=}'[derivative atom types]:types:' \
  '(-P --modpair)'{-P+,--modpair=}'[modify vdW pair parameters]:pairs:' \
  '(-u --ubmod)'{-u+,--ubmod=}'[unbound model 0/1/2]:n:(0 1 2)' \
  '--smooth=[vdW smoothing parameter]:n:' \
  '--elecmindist=[min electrostatic distance]:n:' \
  '--stopstd=[AutoStop energy std dev tolerance]:n:' \
  '(-X --xml2dlg)'{-X+,--xml2dlg=}'[convert XML output to DLG]:file:_files' \
  '*:file:_files' && ret=0

return ret
