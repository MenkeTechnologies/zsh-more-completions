#compdef L2A_Process
# Documentation: https://step.esa.int/thirdparties/sen2cor/
# Sen2Cor Sentinel-2 Level-2A processor (atmospheric correction)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--mode=[processing mode]:mode:(generate_datastrip process_tile)' \
  '--resolution=[target resolution in metres]:resolution:(10 20 60)' \
  '--datastrip=[datastrip folder]:dir:_files -/' \
  '--tile=[tile folder]:dir:_files -/' \
  '--output_dir=[output directory]:dir:_files -/' \
  '--work_dir=[work directory]:dir:_files -/' \
  '--img_database_dir=[image database directory]:dir:_files -/' \
  '--res_database_dir=[results database directory]:dir:_files -/' \
  '--processing_centre=[processing centre code (^[A-Z_]{4}$)]:centre:' \
  '--archiving_centre=[archiving centre code]:centre:' \
  '--processing_baseline=[processing baseline]:baseline:' \
  '--GIP_L2A=[select the user GIPP file]:file:_files' \
  '--GIP_L2A_SC=[select the scene classification GIPP]:file:_files' \
  '--GIP_L2A_AC=[select the atmospheric correction GIPP]:file:_files' \
  '--GIP_L2A_PB=[select the processing baseline GIPP]:file:_files' \
  '--raw[export raw image data]' \
  '--tif[export GeoTIFF image data]' \
  '--sc_only[perform only scene classification]' \
  '--cr_only[create only the L2A product tree without processing]' \
  '--debug[print debug log messages]' \
  '*:L1C input dir:_files -/' && ret=0

return ret
