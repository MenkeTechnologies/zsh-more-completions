#compdef slow5tools
# Documentation: https://hasindu2008.github.io/slow5tools/commands.html
# SLOW5/BLOW5 toolkit (f2s/s2f/merge/split/index/get/view/stats/cat/skim/degrade)

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_slow5tools_cmds() {
  local -a cmds
  cmds=(
    'f2s:Convert FAST5 to SLOW5/BLOW5'
    'fast5toslow5:Convert FAST5 to SLOW5/BLOW5'
    's2f:Convert SLOW5/BLOW5 to FAST5'
    'slow5tofast5:Convert SLOW5/BLOW5 to FAST5'
    'merge:Merge multiple SLOW5/BLOW5 files'
    'split:Split a SLOW5/BLOW5 file into many'
    'index:Index a SLOW5/BLOW5 file'
    'get:Get records by read ID'
    'view:View/convert SLOW5/BLOW5 contents'
    'stats:Print summary statistics'
    'cat:Concatenate files with identical specs'
    'skim:Skim and print components'
    'quickcheck:Check file integrity'
    'degrade:Apply lossy compression'
  )
  _describe -t commands 'slow5tools command' cmds
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'=[verbosity level 0-6]:level' \
  '--cite[print citation information]' \
  '1: :_slow5tools_cmds' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $line[1] in
      f2s|fast5toslow5)
        _arguments -s \
          '--to=[output format]:fmt:(slow5 blow5)' \
          '(-d --out-dir)'{-d,--out-dir}'=[output directory]:dir:_files -/' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-c --compress)'{-c,--compress}'=[record compression]:type:(none zlib zstd)' \
          '(-s --sig-compress)'{-s,--sig-compress}'=[signal compression]:type:(none svb-zd ex-zd)' \
          '(-p --iop)'{-p,--iop}'=[number of I/O processes]:n' \
          '--lossless=[retain auxiliary fields]:bool:(true false)' \
          '(-a --allow)'{-a,--allow}'[allow multiple run IDs per file]' \
          '--retain[retain directory structure]' \
          '*:fast5:_files' && ret=0
        ;;
      s2f|slow5tofast5)
        _arguments -s \
          '(-d --out-dir)'{-d,--out-dir}'=[output directory]:dir:_files -/' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-p --iop)'{-p,--iop}'=[number of I/O processes]:n' \
          '*:slow5:_files' && ret=0
        ;;
      merge)
        _arguments -s \
          '--to=[output format]:fmt:(slow5 blow5)' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-c --compress)'{-c,--compress}'=[record compression]:type:(none zlib zstd)' \
          '(-s --sig-compress)'{-s,--sig-compress}'=[signal compression]:type:(none svb-zd ex-zd)' \
          '(-t --threads)'{-t,--threads}'=[number of threads]:n' \
          '(-K --batchsize)'{-K,--batchsize}'=[records in memory at once]:n' \
          '--lossless=[retain auxiliary fields]:bool:(true false)' \
          '(-a --allow)'{-a,--allow}'[allow attribute differences]' \
          '*:slow5:_files' && ret=0
        ;;
      split)
        _arguments -s \
          '--to=[output format]:fmt:(slow5 blow5)' \
          '(-d --out-dir)'{-d,--out-dir}'=[output directory]:dir:_files -/' \
          '(-c --compress)'{-c,--compress}'=[record compression]:type:(none zlib zstd)' \
          '(-s --sig-compress)'{-s,--sig-compress}'=[signal compression]:type:(none svb-zd ex-zd)' \
          '(-g --groups)'{-g,--groups}'[split per read group]' \
          '(-r --reads)'{-r,--reads}'=[reads per file]:n' \
          '(-f --files)'{-f,--files}'=[number of output files]:n' \
          '(-x --demux)'{-x,--demux}'=[split by TSV demux file]:file:_files' \
          '--demux-code=[categories column header]:header' \
          '--demux-rid=[read IDs column header]:header' \
          '(-m --demux-missing)'{-m,--demux-missing}'=[category for unlisted reads]:name' \
          '(-u --demux-uniq)'{-u,--demux-uniq}'=[category for multi-category reads]:name' \
          '--lossless=[retain auxiliary fields]:bool:(true false)' \
          '(-t --threads)'{-t,--threads}'=[number of threads]:n' \
          '*:slow5:_files' && ret=0
        ;;
      index)
        _arguments -s '*:slow5:_files' && ret=0
        ;;
      get)
        _arguments -s \
          '--to=[output format]:fmt:(slow5 blow5)' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-c --compress)'{-c,--compress}'=[record compression]:type:(none zlib zstd)' \
          '(-s --sig-compress)'{-s,--sig-compress}'=[signal compression]:type:(none svb-zd ex-zd)' \
          '(-t --threads)'{-t,--threads}'=[number of threads]:n' \
          '(-K --batchsize)'{-K,--batchsize}'=[records in memory at once]:n' \
          '(-l --list)'{-l,--list}'=[single-column read ID list]:file:_files' \
          '--index=[custom slow5 index]:file:_files' \
          '*:slow5:_files' && ret=0
        ;;
      view)
        _arguments -s \
          '--to=[output format]:fmt:(slow5 blow5)' \
          '--from=[input format]:fmt:(slow5 blow5)' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-c --compress)'{-c,--compress}'=[record compression]:type:(none zlib zstd)' \
          '(-s --sig-compress)'{-s,--sig-compress}'=[signal compression]:type:(none svb-zd ex-zd)' \
          '(-t --threads)'{-t,--threads}'=[number of threads]:n' \
          '(-K --batchsize)'{-K,--batchsize}'=[records in memory at once]:n' \
          '*:slow5:_files' && ret=0
        ;;
      cat)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '*:slow5:_files' && ret=0
        ;;
      skim)
        _arguments -s \
          '(-t --threads)'{-t,--threads}'=[number of threads]:n' \
          '(-K --batchsize)'{-K,--batchsize}'=[records in memory at once]:n' \
          '--hdr[print header only]' \
          '--rid[print read ID list only]' \
          '*:slow5:_files' && ret=0
        ;;
      degrade)
        _arguments -s \
          '(-s --sig-compress)'{-s,--sig-compress}'=[signal compression]:type:(none svb-zd ex-zd)' \
          '(-b --bits)'{-b,--bits}'=[least significant bits to eliminate]:n' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '*:slow5:_files' && ret=0
        ;;
      stats|quickcheck)
        _arguments -s '*:slow5:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
