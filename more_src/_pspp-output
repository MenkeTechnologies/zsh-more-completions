#compdef pspp-output
# Documentation: https://manpages.debian.org/testing/pspp/pspp-output.1.en.html
# pspp-output - inspect and convert SPSS viewer (SPV) output files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage message]' \
  '(-v --version)'{-v,--version}'[print version information]' \
  '(-O)-O[set output format or format-specific option]:option:' \
  '(-F --force)'{-F,--force}'[write output despite source errors]' \
  '--table-look=[apply table styling from .stt or .tlo file]:file:_files' \
  '--use-page-setup[use page setup embedded in SPV]' \
  '--member-names[show Zip member names for each object]' \
  '--select=[filter by object class]:class:' \
  '--commands=[filter by command identifier]:command:' \
  '--subtypes=[filter by table subtype]:subtype:' \
  '--labels=[filter by table title or label]:label:' \
  '--nth-commands=[select command occurrence by number]:n:' \
  '--instances=[select object instance]:instance:' \
  '--show-hidden[include hidden output objects]' \
  '--or[separate alternative selection criteria]' \
  '--errors[select only objects causing read errors]' \
  '--members=[filter by Zip member name]:member:' \
  '1:command:(detect dir convert get-table-look convert-table-look)' \
  '*:file:_files' && ret=0

return ret
