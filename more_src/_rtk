#compdef rtk

local curcontext="$curcontext" state line ret=1

_rtk_commands() {
  local -a commands=(
    'ls:list directory contents with token-optimized output'
    'tree:show a condensed directory tree'
    'read:read files with filtering controls'
    'smart:generate a short technical file summary'
    'git:run git with compact output'
    'gh:run GitHub CLI with compact output'
    'glab:run GitLab CLI with compact output'
    'aws:run AWS CLI with compact output'
    'pnpm:run pnpm with compact output'
    'err:run a command and show only errors'
    'test:run tests and show only failures'
    'json:inspect JSON with compact output'
    'deps:summarize project dependencies'
    'env:show filtered environment variables'
    'find:run find with compact output'
    'diff:show a condensed diff'
    'log:filter and deduplicate log output'
    'grep:run grep with compact grouped output'
    'init:install RTK hooks and instructions'
    'curl:run curl with truncation and recovery hints'
    'wget:download with compact output'
    'proxy:run a command as a raw passthrough proxy'
    'summary:run a command and show a heuristic summary'
    'gain:show token savings analytics'
    'discover:find missed savings opportunities'
    'session:show RTK adoption across recent sessions'
    'telemetry:manage telemetry consent'
  )
  _describe -t commands 'rtk command' commands
}

_arguments -C -s -S \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--ultra-compact[enable ultra-compact mode]' \
  '--skip-env[set SKIP_ENV_VALIDATION=1 for child processes]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _rtk_commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (ls|tree|find|log)
        _arguments '*:arg' && ret=0
        ;;
      (read)
        _arguments -s -S \
          '1:file:_files' \
          '*:file:_files' \
          '(-l --level)'{-l,--level}'[filter level]:level:(none minimal aggressive)' \
          '(-m --max-lines)'{-m,--max-lines}'[maximum lines to show]:lines' \
          '--tail-lines[keep only the last N lines]:lines' \
          '(-n --line-numbers)'{-n,--line-numbers}'[show line numbers]' && ret=0
        ;;
      (smart)
        _arguments -s -S \
          '1:file:_files' \
          '(-m --model)'{-m,--model}'[summary model]:model:(heuristic)' \
          '--force-download[force model download]' && ret=0
        ;;
      (git)
        _arguments -s -S \
          '-C+[change directory before executing]:dir:_directories' \
          '-c+[git config override]:key=value' \
          '--git-dir[path to the .git directory]:dir:_directories' \
          '--work-tree[path to the working tree]:dir:_directories' \
          '--no-pager[disable the pager]' \
          '--no-optional-locks[skip optional locks]' \
          '--bare[treat repository as bare]' \
          '--literal-pathspecs[treat pathspecs literally]' \
          '1:git command:(status log diff add commit push pull show branch checkout fetch merge rebase)' \
          '*::git arg:' && ret=0
        ;;
      (gh)
        _arguments \
          '1:gh subcommand:(pr issue run repo auth workflow)' \
          '*::gh arg:' && ret=0
        ;;
      (glab)
        _arguments -s -S \
          '(-R --repo)'{-R,--repo}'[target repository]:repo' \
          '(-g --group)'{-g,--group}'[target group]:group' \
          '1:glab subcommand:(mr issue ci pipeline api repo auth)' \
          '*::glab arg:' && ret=0
        ;;
      (aws)
        _arguments \
          '1:aws service:(sts s3 ec2 ecs ecr lambda logs cloudformation dynamodb iam)' \
          '*::aws arg:' && ret=0
        ;;
      (pnpm)
        _arguments -s -S \
          '(-F --filter)'{-F,--filter}'[workspace filter]:filter' \
          '1:pnpm command:(list install add remove update test run exec why)' \
          '*::pnpm arg:' && ret=0
        ;;
      (err|test|proxy|summary)
        _arguments '*:command:_command_names -e' && ret=0
        ;;
      (json)
        _arguments -s -S \
          '1:file:_files' \
          '(-d --depth)'{-d,--depth}'[maximum depth]:depth' \
          '--keys-only[show keys only]' && ret=0
        ;;
      (deps)
        _arguments '1:path:_directories' && ret=0
        ;;
      (env)
        _arguments -s -S \
          '(-f --filter)'{-f,--filter}'[filter by name]:pattern' \
          '--show-all[include sensitive values]' && ret=0
        ;;
      (diff)
        _arguments \
          '1:first file:_files' \
          '2:second file:_files' && ret=0
        ;;
      (grep)
        _arguments -s -S \
          '1:pattern:' \
          '2:path:_directories' \
          '(-l --max-len)'{-l,--max-len}'[maximum line length]:columns' \
          '(-m --max)'{-m,--max}'[maximum results]:count' \
          '(-c --context-only)'{-c,--context-only}'[show only match context]' \
          '(-t --file-type)'{-t,--file-type}'[filter by file type]:type' \
          '(-n --line-numbers)'{-n,--line-numbers}'[show line numbers]' \
          '*::extra arg:' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '(-g --global)'{-g,--global}'[install in the global assistant config directory]' \
          '--opencode[install the OpenCode plugin]' \
          '--gemini[initialize for Gemini CLI]' \
          '--agent[target agent]:agent:(claude codex gemini cursor windsurf cline kilocode antigravity)' \
          '--show[show the current configuration]' \
          '--claude-md[inject full instructions into CLAUDE.md]' \
          '--hook-only[install only the hook without RTK.md]' \
          '--auto-patch[patch settings automatically]' \
          '--no-patch[skip settings patching]' \
          '--uninstall[remove RTK artifacts]' \
          '--codex[target Codex CLI]' \
          '--copilot[install GitHub Copilot integration]' && ret=0
        ;;
      (curl)
        _arguments \
          '1:url:_urls' \
          '*::curl arg:' && ret=0
        ;;
      (wget)
        _arguments -s -S \
          '1:url:_urls' \
          '(-O --output-document)'{-O,--output-document}'[output file]:file:_files' \
          '*::wget arg:' && ret=0
        ;;
      (gain)
        _arguments \
          '--graph[show an ASCII graph]' \
          '--history[show recent command history]' \
          '--daily[show daily breakdown]' \
          '--all[include all data]' \
          '--format[output format]:format:(table json)' && ret=0
        ;;
      (discover)
        _arguments \
          '--all[inspect all projects]' \
          '--since[look back N days]:days' \
          '--format[output format]:format:(table json)' && ret=0
        ;;
      (session)
        _arguments \
          '--format[output format]:format:(table json)' && ret=0
        ;;
      (telemetry)
        _arguments \
          '1:telemetry command:(status enable disable forget)' && ret=0
        ;;
    esac
    ;;
esac

return ret
