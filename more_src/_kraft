#compdef kraft
# Documentation: https://unikraft.org/docs/cli/options
# Reference accessed: 2026-05-19
# Verified: upstream docs at unikraft.org/docs/cli/options (global
# flags) and the kraftkit root command source for the subcommand
# list. Corrected: --no-update-check -> --no-check-updates; removed
# invented --no-color/--no-emojis/--paths-experimental/--config-dir
# and invented top-level commands (logout/update/pull/push/status/
# rm). Added real --no-parallel/--pager/--runtime-dir/--paths-*.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:configure and build unikernels'
  'clean:remove build objects'
  'fetch:fetch a Unikraft unikernel sources'
  'menu:open the Unikraft configuration TUI'
  'set:set a variable for a Unikraft project'
  'unset:unset a variable for a Unikraft project'
  'lib:manage and maintain Unikraft microlibraries'
  'pkg:package and distribute Unikraft unikernels and their dependencies'
  'events:follow the events of running unikernels'
  'logs:fetch logs of a unikernel'
  'ps:list running unikernels'
  'remove:remove one or more running unikernels'
  'run:run a unikernel'
  'start:start one or more unikernels'
  'stop:stop one or more running unikernels'
  'pause:pause one or more running unikernels'
  'net:manage local machine networks'
  'volume:manage machine volumes'
  'compose:build and run compose projects'
  'cloud:manage resources on Unikraft Cloud'
  'login:provide authorization details for a remote service'
  'version:show kraft version information'
  'system:manage internal subsystems'
  'completion:generate completion scripts'
  'help:help about any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--log-level=[log level verbosity]:lvl:(trace debug info warn error fatal panic)' \
  '--log-type=[logging format]:t:(fancy basic json)' \
  '--log-timestamps[enable log timestamps]' \
  '--no-check-updates[do not check for updates]' \
  '--no-prompt[do not prompt for user interaction]' \
  '--no-parallel[do not run internal tasks in parallel]' \
  '--pager=[system pager for output piping]:pager:' \
  '--runtime-dir=[directory for placing runtime files]:dir:_files -/' \
  '--containerd-addr=[address of containerd daemon socket]:addr:' \
  '--buildkit-host=[address of BuildKit daemon socket]:addr:' \
  '--paths-config=[path to KraftKit config directory]:dir:_files -/' \
  '--paths-manifests=[path to Unikraft manifest cache]:dir:_files -/' \
  '--paths-sources=[path to Unikraft component cache]:dir:_files -/' \
  '*--unikraft-mirrors=[paths to mirrors of Unikraft component artifacts]:path:' \
  '*--unikraft-manifests=[paths to package or component manifests]:path:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kraft command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '(-K --no-cache)'{-K,--no-cache}'[do not use cache]' \
          '(-f --force)'{-f,--force}'[force a rebuild]' \
          '(-j --jobs)'{-j+,--jobs=}'[allow N jobs at once]:n:' \
          '(-m --target)'{-m+,--target=}'[build a particular known target]:tgt:' \
          '(-w --workdir)'{-w+,--workdir=}'[work on a unikernel at a path]:dir:_files -/' \
          '*: :_files' && ret=0 ;;
      (run)
        _arguments \
          '(-d --detach)'{-d,--detach}'[run the unikernel in detached mode]' \
          '(-p --port)'{-p+,--port=}'[publish a machine port to the host]:p:' \
          '(-M --memory)'{-M+,--memory=}'[assign memory to the unikernel]:mb:' \
          '(-w --workdir)'{-w+,--workdir=}'[work on a unikernel at a path]:dir:_files -/' \
          '(-e --env)'{-e+,--env=}'[set environment variables]:var:' \
          '--rm[automatically remove the unikernel when it shuts down]' \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
