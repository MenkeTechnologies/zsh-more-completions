#compdef kraft
# Documentation: https://man.archlinux.org/search?q=kraft
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:configure and build unikernels'
  'clean:remove build objects'
  'cloud:manage resources on Unikraft Cloud'
  'compose:build/run compose projects'
  'completion:generate completion script'
  'fetch:fetch upstream sources'
  'lib:manage microlibraries'
  'login:authorize remote service'
  'logout:remove credentials'
  'logs:fetch logs of unikernel'
  'menu:open Unikraft configuration TUI'
  'net:manage machine networks'
  'pause:pause running unikernels'
  'pkg:package and distribute unikernels'
  'ps:list running unikernels'
  'pull:pull components'
  'push:push package to registry'
  'remove:remove running unikernels'
  'rm:alias for remove'
  'run:run a unikernel'
  'start:start unikernels'
  'status:show status'
  'stop:stop running unikernels'
  'unset:remove an entry'
  'update:update component listing'
  'version:show version'
  'volume:manage machine volumes'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config-dir=[config directory]:dir:_files -/' \
  '--log-level=[log level]:lvl:(panic fatal error warn info debug trace)' \
  '--log-type=[log type]:t:(basic fancy json quiet)' \
  '--log-timestamps[show timestamps]' \
  '--no-update-check[skip update check]' \
  '--no-prompt[disable interactive prompts]' \
  '--no-color[disable colored output]' \
  '--no-emojis[disable emojis]' \
  '--paths-experimental[enable experimental paths]' \
  '--paths-config=[config paths]:paths:' \
  '--paths-manifests=[manifests paths]:paths:' \
  '--paths-sources=[sources paths]:paths:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kraft command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '(-K --no-cache)'{-K,--no-cache}'[do not use cache]' \
          '(-f --force)'{-f,--force}'[force build]' \
          '(-j --jobs)'{-j+,--jobs=}'[parallel jobs]:n:' \
          '(-m --target)'{-m+,--target=}'[platform/architecture]:tgt:' \
          '(-w --workdir)'{-w+,--workdir=}'[working dir]:dir:_files -/' \
          '*: :_files' && ret=0 ;;
      (run)
        _arguments \
          '(-d --detach)'{-d,--detach}'[detached mode]' \
          '(-p --port)'{-p+,--port=}'[port mapping]:p:' \
          '(-M --memory)'{-M+,--memory=}'[memory MB]:mb:' \
          '(-W --workdir)'{-W+,--workdir=}'[workdir]:dir:_files -/' \
          '(-N --network)'{-N+,--network=}'[network]:net:' \
          '(-V --volume)'{-V+,--volume=}'[volume mount]:vol:' \
          '(-e --env)'{-e+,--env=}'[env var]:var:' \
          '(--rm)--rm[auto-remove on exit]' \
          '*: :_files' && ret=0 ;;
      (pkg|cloud|compose|net|volume|lib) _values 'subcommand' 'create' 'list' 'ls' 'logs' 'remove' 'rm' 'inspect' 'pull' 'push' 'info' 'login' 'init' 'pause' 'start' 'stop' 'update' && ret=0 ;;
    esac ;;
esac

return ret
