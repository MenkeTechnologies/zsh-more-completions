#compdef gpfdist
# Documentation: https://docs.vmware.com/en/VMware-Greenplum/
# Greenplum parallel file distribution server for external tables

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '--version[show version]' \
  '-d+[directory to serve files from]:dir:_files -/' \
  '-p+[HTTP port to serve files on]:port:' \
  '-P+[highest port in a bind range]:port:' \
  '-l+[log file path]:file:_files' \
  '-t+[connection timeout in seconds]:secs:' \
  '-k+[session cleanup timeout in seconds]:secs:' \
  '-m+[maximum data row length in bytes]:bytes:' \
  '-S[open files for synchronous I/O]' \
  '-w+[delay before closing target files in seconds]:secs:' \
  '--ssl=[enable SSL with certificate path]:path:_files -/' \
  '--ssl_verify_peer=[SSL certificate authentication]:bool:(on off)' \
  '--sslclean=[delay before closing SSL sessions]:secs:' \
  '--compress[enable Zstandard compression]' \
  '--multi_thread=[max threads for parallel transfer]:num:' \
  '-c+[YAML config file for transformation rules]:file:_files' \
  '-s[simplified logging, WARN and higher only]' \
  '-v[verbose mode]' \
  '-V[very verbose mode]' && ret=0

return ret
