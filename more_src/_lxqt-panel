#compdef lxqt-panel
# Documentation: https://man.archlinux.org/man/lxqt-panel.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --configfile)'{-c,--configfile}'+[config file]:file:_files' \
  '(-p --profile)'{-p,--profile}'+[profile name]:profile:' && ret=0

return ret
