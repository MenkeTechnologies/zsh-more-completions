#compdef lxqt-panel
# Documentation: https://github.com/lxqt/lxqt-panel/blob/master/panel/lxqtpanelapplication.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config --configfile)'{-c,--config,--configfile}'+[use alternate configuration file]:file:_files' && ret=0

return ret
