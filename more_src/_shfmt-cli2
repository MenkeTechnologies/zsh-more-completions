#compdef shfmt-cli2 shfmt2
# _shfmt-cli2 — Daniel Martí mvdan shfmt-cli2 CLI command-line frontend wrapping the shfmt shell parser and formatter for sh bash POSIX mksh bats open-source written in Go originally Daniel Martí mvdan supports POSIX Shell Bash Bats mksh formatter modeled after gofmt parse format minify diff list write find ad-hoc-options indentation spacing structure shfmt-tooltip language-modes bash POSIX mksh editorconfig support -i -bn -ci -sr -kp -fn -ln -filename -d -f -l -mn -s -w -tojson -fromjson -ot -tov -ke -idx -kp -tr -wr -e -p --version (Daniel Martí mvdan team, Go); custom argparse
# upstream: https://github.com/mvdan/sh

_shfmt-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-l[list files with formatting issues]' \
        '-d[show diff]' \
        '-w[write result to file]' \
        '-s[simplify code]' \
        '-mn[minify]' \
        '-ln=+[lang]:l:(bash posix mksh bats auto)' \
        '--language=+[l]:l:(bash posix mksh bats auto)' \
        '-i+[indent spaces]:n:' \
        '--indent=+[N]:n:' \
        '-bn[binary next line]' \
        '-ci[case indent]' \
        '-sr[space redirect]' \
        '-kp[keep padding]' \
        '-fn[function next line]' \
        '-filename=+[name]:str:' \
        '-f[find shell files]' \
        '-tojson[print json AST]' \
        '-fromjson[from json AST]' \
        '-ot+[output type]:str:' \
        '-tov[to v command]' \
        '-ke[keep header]' \
        '-idx[print index ranges]' \
        '-tr[show tree]' \
        '-wr[wrap long]' \
        '-e[exit code]' \
        '-p[POSIX mode]' \
        '*:script:_files -g "*.sh *.bash *.ksh *.zsh *.dash *.bats"'
}

_shfmt-cli2 "$@"
