#compdef gram
# Documentation: https://man.archlinux.org/search?q=gram
# Reference accessed: 2026-05-16
# Source: cargo binstall gram@0.1.0
# Probed via: shell-completion zsh
# Repository: https://github.com/gramlang/gram

autoload -U is-at-least

_gram() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-v[Print version]' \
'--version[Print version]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Set the path to the program entrypoint:_default' \
":: :_gram_commands" \
"*::: :->gram" \
&& ret=0
    case $state in
    (gram)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gram-command-$line[2]:"
        case $line[2] in
            (check)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':path -- Set the path to the program entrypoint:_default' \
&& ret=0
;;
(run)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':path -- Set the path to the program entrypoint:_default' \
&& ret=0
;;
(shell-completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Bash, Fish, Zsh, PowerShell, or Elvish:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_gram__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gram-help-command-$line[1]:"
        case $line[1] in
            (check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(run)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(shell-completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_gram_commands] )) ||
_gram_commands() {
    local commands; commands=(
'check:Check a program' \
'run:Run a program' \
'shell-completion:Print a shell completion script. Supports Bash, Fish, Zsh, PowerShell, and Elvish.' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'gram commands' commands "$@"
}
(( $+functions[_gram__check_commands] )) ||
_gram__check_commands() {
    local commands; commands=()
    _describe -t commands 'gram check commands' commands "$@"
}
(( $+functions[_gram__help_commands] )) ||
_gram__help_commands() {
    local commands; commands=(
'check:Check a program' \
'run:Run a program' \
'shell-completion:Print a shell completion script. Supports Bash, Fish, Zsh, PowerShell, and Elvish.' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'gram help commands' commands "$@"
}
(( $+functions[_gram__help__check_commands] )) ||
_gram__help__check_commands() {
    local commands; commands=()
    _describe -t commands 'gram help check commands' commands "$@"
}
(( $+functions[_gram__help__help_commands] )) ||
_gram__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'gram help help commands' commands "$@"
}
(( $+functions[_gram__help__run_commands] )) ||
_gram__help__run_commands() {
    local commands; commands=()
    _describe -t commands 'gram help run commands' commands "$@"
}
(( $+functions[_gram__help__shell-completion_commands] )) ||
_gram__help__shell-completion_commands() {
    local commands; commands=()
    _describe -t commands 'gram help shell-completion commands' commands "$@"
}
(( $+functions[_gram__run_commands] )) ||
_gram__run_commands() {
    local commands; commands=()
    _describe -t commands 'gram run commands' commands "$@"
}
(( $+functions[_gram__shell-completion_commands] )) ||
_gram__shell-completion_commands() {
    local commands; commands=()
    _describe -t commands 'gram shell-completion commands' commands "$@"
}

if [ "$funcstack[1]" = "_gram" ]; then
    _gram "$@"
else
    compdef _gram gram
fi
