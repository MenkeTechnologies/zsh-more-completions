#compdef hsc2hs-ghc-9.14.1

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-o+,--output=}'[main output file]:file:_files' \
  {-t+,--template=}'[template file]:file:_files' \
  {-c+,--cc=}'[C compiler]:cc:_command_names -e' \
  {-l+,--ld=}'[linker]:linker:_command_names -e' \
  '*'{-C+,--cflag=}'[flag for C compiler]:flag:' \
  '*-I+[include directory for C compiler]:dir:_files -/' \
  '*'{-L+,--lflag=}'[flag for linker]:flag:' \
  '*'{-i+,--include=}'[include file]:file:_files' \
  {-D+,--define=}'[define macro]:macro[=value]:' \
  '--no-compiler-flags[do not pass flags to compiler]' \
  '--cross-compile[behave as a cross-compiler]' \
  '--cross-safe[ensure all features are cross-compile safe]' \
  '*:hsc input file:_files -g "*.hsc"' && ret=0

return ret
