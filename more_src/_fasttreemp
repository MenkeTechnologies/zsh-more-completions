#compdef fasttreemp FastTreeMP

# FastTreeMP: OpenMP-parallel build of FastTree
local curcontext="$curcontext" ret=1
_arguments -C \
  '-nt[nucleotide alignment]' \
  '-gtr[GTR model]' \
  '-lg[LG model]' \
  '-wag[WAG model]' \
  '-gamma[fit gamma rates]' \
  '-cat[rate categories]:n:' \
  '-nocat[disable rate categories]' \
  '-spr[SPR rounds]:n:' \
  '-mlacc[ML accuracy levels]:n:' \
  '-slownni[thorough NNI]' \
  '-noml[skip ML]' \
  '-nome[skip ME]' \
  '-fastest[fastest mode]' \
  '-pseudo[pseudocount]:val:' \
  '-bionj[BIONJ]' \
  '-boot[bootstrap replicates]:n:' \
  '-seed[random seed]:n:' \
  '-quiet[suppress output]' \
  '-log[log file]:file:_files' \
  '-intree[user starting tree]:file:_files' \
  '-out[output tree]:file:_files' \
  '-threads[number of threads]:n:' \
  '*:alignment file:_files -g "*.(fa|fasta|aln|phy)"' && ret=0
return ret
