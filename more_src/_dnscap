#compdef dnscap

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-?[show help]' \
  '-a+[capture filter expr]:bpf:' \
  '-A+[ignore initiator]:ip:' \
  '-b+[BPF filter]:bpf:' \
  '-c[count mode]' \
  '-d[debug]' \
  '-E+[error mask]:mask:' \
  '-e[record cleartext only]' \
  '-f+[output filter]:filter:' \
  '-g[stop on bad packets]' \
  '-h+[hash function]:hash:(none mac sha1)' \
  '-i+[interface]:iface:' \
  '-k+[input pcap dir]:dir:_files -/' \
  '-l+[layer]:layer:' \
  '-L+[ip filter]:ip:' \
  '-m+[match]:match:' \
  '-n[no DNS resolve]' \
  '-o+[option]:opt:' \
  '-O[show output]' \
  '-p[show packets]' \
  '-P+[plugin]:plugin:' \
  '-q[quiet]' \
  '-r+[read pcap]:file:_files -g "*.{pcap,pcapng}"' \
  '-s+[snaplen]:n:' \
  '-S[show stats]' \
  '-t+[time limit]:sec:' \
  '-T+[t1 t2]:range:' \
  '-u+[port]:port:' \
  '-w+[write pcap]:file:_files' \
  '-W+[base name]:str:' \
  '-x+[xact]:opt:' \
  '-y[forced yaml output]' \
  '-Y+[yaml stats interval]:sec:' \
  '-z+[match name]:name:' \
  '*:dump:_files' && ret=0

return ret
