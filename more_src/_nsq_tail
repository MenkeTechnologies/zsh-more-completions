#compdef nsq_tail
# Documentation: https://nsq.io/components/utilities.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-version[show version]' \
  '*-topic=[NSQ topic (repeatable)]:topic:' \
  '-channel=[NSQ channel]:channel:' \
  '*-nsqd-tcp-address=[nsqd TCP address (repeatable)]:address:' \
  '*-lookupd-http-address=[lookupd HTTP address (repeatable)]:address:' \
  '-n=[total messages to show]:n:' \
  '-print-topic[print topic name with each message]' \
  '-max-in-flight=[max in-flight messages]:n:' \
  '-consumer-opt=[client config option key=val (repeatable)]:opt:' \
  '-log-level=[log verbosity]:level:(debug info warn error fatal)' \
  '-log-prefix=[log message prefix]:prefix:' && ret=0

return ret
