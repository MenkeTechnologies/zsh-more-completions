#compdef rust-strings
# Documentation: https://github.com/rust-embedded/cargo-binutils
# Reference accessed: 2026-05-16
# Verified: cargo-binutils wrapper invoking llvm-strings.
# Removed from prior file: bogus man.archlinux.org search URL.

# rust-strings: cargo-binutils wrapper for llvm-strings
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-n[minimum string length]:n:' \
  '-t[print offset in radix]:radix:(d o x)' \
  '*:object file:_files' && ret=0
return ret
