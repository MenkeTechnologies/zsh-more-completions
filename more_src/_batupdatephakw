#compdef batupdatephakw
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/batupdatephakw.html
# Update BAT PHA spectrum keywords from a batmaskwtevt ray-trace auxiliary file

local ret=1

_arguments -s -S \
  'infile=[input/output BAT spectral file, modified in place]:infile:_files' \
  'auxfile=[ray trace auxiliary file from batmaskwtevt]:auxfile:_files' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  '*:file:_files' && ret=0

return ret
