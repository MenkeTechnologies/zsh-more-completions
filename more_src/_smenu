#compdef smenu
# Documentation: https://github.com/p-gen/smenu/blob/master/smenu.1
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

# p-gen/smenu - interactive selector reading from stdin

local ret=1
_arguments -s -S \
  '(- *)-h[display help message]' \
  '(- *)-H[display long help message]' \
  '(- *)-V[display version information]' \
  '-n+[max lines in selection window]:lines:' \
  '-i+[include regex for selectable words]:regex:' \
  '-e+[exclude regex for non-selectable words]:regex:' \
  '-m+[message/title above the window]:message:' \
  '-a+[set display attributes]:attributes:' \
  '-T[enable tag mode for multiple selections]' \
  '-P[enable pin mode for ordered multiple selections]' \
  '-p[auto-tag current word when ENTER pressed]' \
  '-c[enable column mode]' \
  '-l[enable line mode]' \
  '-t+[enable tabulation mode with optional column count]:columns:' \
  '-w[widen columns to use full terminal width]' \
  '-M[center the display on screen]' \
  '-d[clean up display by removing window after exit]' \
  '-W+[word delimiter characters]:delims:' \
  '-L+[line delimiter characters]:delims:' \
  '-q[disable scroll bar display]' \
  '-g+[column separator characters]:chars:' \
  '-s+[position cursor on word matching pattern at startup]:pattern:' \
  '-x+[set timeout with action (current/quit/word)]:timeout spec:' \
  '-X+[set hidden timeout (no display of remaining time)]:timeout spec:' \
  '-r[enable ENTER validation in search mode]' \
  '-v[use visual bell instead of audible alert]' \
  '-Q[disable word grouping by quotes]' \
  '-f+[global inactivity timeout]:seconds:' \
  '*:: :_default' && ret=0
return ret
