#compdef htmldoc
# Documentation: https://www.msweet.org/htmldoc/htmldoc.html
# HTMLDOC - convert HTML and Markdown to PDF, PostScript, EPUB and HTML

local ret=1

_arguments -s -S \
  '-d+[output directory]:dir:_files -/' \
  '-f+[output file]:file:_files' \
  '-t+[output format]:format:(epub html html-index pdf pdf11 pdf12 pdf13 pdf14 ps ps1 ps2 ps3)' \
  '-v[verbose progress to stderr]' \
  '--batch=[generate book file without GUI]:file:_files' \
  '--book[input files comprise a structured book]' \
  '--webpage[input files are unstructured web pages]' \
  '--continuous[continuous web page no breaks]' \
  '--format=[output format]:format:(epub html html-index pdf pdf11 pdf12 pdf13 pdf14 ps ps1 ps2 ps3)' \
  '--outfile=[output file]:file:_files' \
  '--outdir=[output directory]:dir:_files -/' \
  '--size=[page size]:size:(Letter A4 Legal Universal)' \
  '--landscape[landscape orientation]' \
  '--portrait[portrait orientation]' \
  '--duplex[two-sided printing]' \
  '--no-duplex[one-sided printing]' \
  '--top=[top margin]:margin' \
  '--bottom=[bottom margin]:margin' \
  '--left=[left margin]:margin' \
  '--right=[right margin]:margin' \
  '--fontsize=[base font size in points]:size' \
  '--fontspacing=[line spacing multiplier]:spacing' \
  '--bodyfont=[default body text font]:font' \
  '--textfont=[document text typeface]:font' \
  '--headingfont=[heading typeface]:font' \
  '--headfootfont=[header/footer font]:font' \
  '--headfootsize=[header/footer text size]:size' \
  '--header=[page header contents]:lcr' \
  '--header1=[first page header]:lcr' \
  '--footer=[page footer contents]:lcr' \
  '--tocheader=[TOC header]:lcr' \
  '--tocfooter=[TOC footer]:lcr' \
  '--title[generate title page]' \
  '--no-title[skip title page]' \
  '--titlefile=[HTML/Markdown for title]:file:_files' \
  '--titleimage=[title page image]:file:_files' \
  '--no-toc[skip table of contents]' \
  '--toclevels=[heading levels in TOC]:levels' \
  '--toctitle=[TOC heading text]:string' \
  '--numbered[number headings]' \
  '--no-numbered[do not number headings]' \
  '--bodycolor=[background color]:color' \
  '--bodyimage=[background image]:file:_files' \
  '--textcolor=[text color]:color' \
  '--linkcolor=[link color]:color' \
  '--logoimage=[logo for headers/footers]:file:_files' \
  '--letterhead=[letterhead image]:file:_files' \
  '--links[include hyperlinks]' \
  '--no-links[exclude hyperlinks]' \
  '--linkstyle=[link decoration]:style:(plain underline)' \
  '--compression=[flate compression level]:level' \
  '--no-compression[disable compression]' \
  '--jpeg=[JPEG image quality]:quality' \
  '--no-jpeg[disable JPEG compression]' \
  '--embedfonts[embed fonts]' \
  '--no-embedfonts[do not embed fonts]' \
  '--encryption[enable PDF encryption]' \
  '--no-encryption[disable PDF encryption]' \
  '--owner-password=[owner password]:password' \
  '--user-password=[user password]:password' \
  '--permissions=[document permissions]:perms' \
  '--firstpage=[initial PDF page displayed]:page' \
  '--pagemode=[initial viewing mode]:mode:(document outline fullscreen)' \
  '--pagelayout=[initial page layout]:layout:(single one twoleft tworight)' \
  '--pageeffect=[page transition effect]:effect' \
  '--pageduration=[page display seconds]:seconds' \
  '--effectduration=[effect duration seconds]:seconds' \
  '--pdf-indent=[pre-formatted content indentation]:margin' \
  '--pscommands[include PostScript commands]' \
  '--no-pscommands[exclude PostScript commands]' \
  '--xrxcomments[include Xerox job comments]' \
  '--no-xrxcomments[exclude Xerox job comments]' \
  '--color[color output]' \
  '--gray[grayscale output]' \
  '--path=[file search paths]:paths' \
  '--cookies=[HTTP cookies]:cookies' \
  '--referer=[HTTP Referer header]:url' \
  '--no-localfiles[disable local file access]' \
  '--browserwidth=[browser width for scaling]:pixels' \
  '--nup=[pages per output page]:n:(1 2 4 6 9 16)' \
  '--charset=[character set encoding]:charset' \
  '--strict[strict HTML conformance checking]' \
  '--no-strict[loose HTML conformance checking]' \
  '--datadir=[data files location]:dir:_files -/' \
  '--helpdir=[help files location]:dir:_files -/' \
  '--quiet[suppress error messages]' \
  '--verbose[progress information]' \
  '--help[display all options]' \
  '--version[display version number]' \
  '*:input:_files' && ret=0

return ret
