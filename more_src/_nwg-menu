#compdef nwg-menu
# Documentation: https://github.com/nwg-piotr/nwg-menu
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-v[display version information]' \
  '-d[auto-hide: close window when left]' \
  '-debug[turn on debug messages]' \
  '-k[clicking outside closes the window]' \
  '-t[hovering categories opens submenus]' \
  '-cmd-lock[screen lock command]:command:' \
  '-cmd-logout[logout command]:command:' \
  '-cmd-restart[reboot command]:command:' \
  '-cmd-shutdown[shutdown command]:command:' \
  '-fm[file manager]:command:_command_names' \
  '-ha[horizontal alignment]:alignment:(left right)' \
  '-isl[icon size large]:size:' \
  '-iss[icon size small]:size:' \
  '-lang[force language]:language:' \
  '-ml[margin left]:pixels:' \
  '-mr[margin right]:pixels:' \
  '-mb[margin bottom]:pixels:' \
  '-mt[margin top]:pixels:' \
  '-o[output to display the menu on]:output:' \
  '-padding[vertical item padding]:pixels:' \
  '-s[styling css file name]:css file:_files' \
  '-slen[search result length limit]:n:' \
  '-term[terminal emulator]:terminal:_command_names' \
  '-va[vertical alignment]:alignment:(top bottom)' \
  '-wm[window manager: sway, hyprland, river]:wm:(sway hyprland river)' && ret=0

return ret
