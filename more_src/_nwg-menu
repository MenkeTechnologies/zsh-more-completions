#compdef nwg-menu

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-cmd-lock[lock command]:command:' \
  '-cmd-logout[logout command]:command:' \
  '-cmd-restart[restart command]:command:' \
  '-cmd-shutdown[shutdown command]:command:' \
  '-fm[file manager command]:command:_command_names' \
  '-ha[horizontal alignment]:alignment:(left right)' \
  '-isl[icon size large]:size:' \
  '-iss[icon size small]:size:' \
  '-lang[language]:language:' \
  '-ml[margin left]:pixels:' \
  '-mr[margin right]:pixels:' \
  '-mb[margin bottom]:pixels:' \
  '-mt[margin top]:pixels:' \
  '-o[output name]:output:' \
  '-padding[padding]:pixels:' \
  '-s[custom styling file]:css file:_files' \
  '-term[terminal emulator]:terminal:_command_names' \
  '-va[vertical alignment]:alignment:(top bottom)' \
  '-wm[window manager name]:wm:(sway hyprland)' && ret=0

return ret
