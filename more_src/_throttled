#compdef throttled lenovo_fix
# Documentation: https://man.archlinux.org/search?q=throttled
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '--config=[config file]:file:_files' \
  '--debug[enable debug logging]' \
  '--dry-run[do not write MSRs]' \
  '--no-sysfs[do not use sysfs]' \
  '--monitor=[monitor file]:file:_files' && ret=0

return ret
