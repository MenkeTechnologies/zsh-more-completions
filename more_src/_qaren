#compdef qaren
# Source: cargo binstall qaren@1.0.1
# Probed via: --generate-completions zsh
# Repository: https://github.com/qaren-cli/qaren.git

autoload -U is-at-least

_qaren() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--generate-completions=[Generate shell completion scripts \[possible values\: bash, elvish, fish, powershell, zsh\]]:SHELL:(bash elvish fish powershell zsh)' \
'--example[Print detailed usage examples]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_qaren_commands" \
"*::: :->qaren" \
&& ret=0
    case $state in
    (qaren)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:qaren-command-$line[1]:"
        case $line[1] in
            (diff)
_arguments "${_arguments_options[@]}" : \
'-u[Output unified diff  \[short\: -u\]]' \
'--unified[Output unified diff  \[short\: -u\]]' \
'-b[Ignore changes in the amount of white space]' \
'--ignore-space-change[Ignore changes in the amount of white space]' \
'-Z[Ignore white space at line end]' \
'--ignore-trailing-space[Ignore white space at line end]' \
'-B[Ignore changes where lines are all blank]' \
'--ignore-blank-lines[Ignore changes where lines are all blank]' \
'-r[Recursively compare directories  \[short\: -r\]]' \
'--recursive[Recursively compare directories  \[short\: -r\]]' \
'--files-only[Instead of comparing file contents, only compare file existence (requires -r)]' \
'(--quiet)-q[Report only when files differ (POSIX diff -q)]' \
'(--quiet)--brief[Report only when files differ (POSIX diff -q)]' \
'(-q --brief)--quiet[Quiet mode - no output. Return exit code only]' \
'(--quiet)-s[Report when two files are the same (POSIX diff -s)]' \
'(--quiet)--report-identical-files[Report when two files are the same (POSIX diff -s)]' \
'-i[Ignore case differences in file contents]' \
'--ignore-case[Ignore case differences in file contents]' \
'-w[Ignore all white space (for KV\: strips spaces inside values)]' \
'--ignore-all-space[Ignore all white space (for KV\: strips spaces inside values)]' \
'-A[Strip ANSI escape codes from input files]' \
'--strip-ansi[Strip ANSI escape codes from input files]' \
'-P[Suppress "Insecure file permissions" warnings]' \
'--no-perm-warn[Suppress "Insecure file permissions" warnings]' \
'-D[Suppress "duplicate key" warnings]' \
'--no-duplicate-warn[Suppress "duplicate key" warnings]' \
'--example[Print detailed usage examples]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::file1 -- First file to compare:_files' \
'::file2 -- Second file to compare:_files' \
&& ret=0
;;
(kv)
_arguments "${_arguments_options[@]}" : \
'(--d1 --d2)-d+[Delimiter for BOTH files when they share the same format. Auto-detected if omitted. Use --d1/--d2 for cross-format comparisons. Examples\: '\''='\'', '\''\:'\'', '\'' '\'']:DELIMITER:_default' \
'(--d1 --d2)--delimiter=[Delimiter for BOTH files when they share the same format. Auto-detected if omitted. Use --d1/--d2 for cross-format comparisons. Examples\: '\''='\'', '\''\:'\'', '\'' '\'']:DELIMITER:_default' \
'--d1=[Delimiter override for file1 only (overrides --delimiter for file1)]:DELIMITER:_default' \
'--d2=[Delimiter override for file2 only (overrides --delimiter for file2)]:DELIMITER:_default' \
'-o+[Output format (text or json)]:FORMAT:_default' \
'--output=[Output format (text or json)]:FORMAT:_default' \
'*-x+[Ignore a specific key (exact match). Can be passed multiple times.  \[short\: -x\]]:KEY:_default' \
'*--ignore-key=[Ignore a specific key (exact match). Can be passed multiple times.  \[short\: -x\]]:KEY:_default' \
'*--ignore-keyword=[Ignore keys containing this keyword (case-insensitive substring)]:KEYWORD:_default' \
'-g+[Generate a patch file containing missing keys \[short\: -g\]]:FILE:_files' \
'--generate-patch=[Generate a patch file containing missing keys \[short\: -g\]]:FILE:_files' \
'--direction=[Direction for patch generation. '\''source-to-target'\'' (default)\: keys in FILE1 missing from FILE2. '\''target-to-source'\''\: keys in FILE2 missing from FILE1. '\''bidirectional'\''\: creates two patch files, one for each direction]:DIR:_default' \
'-Q[Strip surrounding quotes from keys and values  \[short\: -Q\]]' \
'--strip-quotes[Strip surrounding quotes from keys and values  \[short\: -Q\]]' \
'-i[Ignore case differences in file contents]' \
'--ignore-case[Ignore case differences in file contents]' \
'-w[Ignore all white space (for KV\: strips spaces inside values)]' \
'--ignore-all-space[Ignore all white space (for KV\: strips spaces inside values)]' \
'-A[Strip ANSI escape codes from input files]' \
'--strip-ansi[Strip ANSI escape codes from input files]' \
'-P[Suppress "Insecure file permissions" warnings]' \
'--no-perm-warn[Suppress "Insecure file permissions" warnings]' \
'-D[Suppress "duplicate key" warnings]' \
'--no-duplicate-warn[Suppress "duplicate key" warnings]' \
'-r[Recursively compare directories containing Key-Value files  \[short\: -r\]]' \
'--recursive[Recursively compare directories containing Key-Value files  \[short\: -r\]]' \
'(-v --verbose -s --summary)-q[Quiet mode - no stdout/stderr output. Return exit code only.  \[short\: -q\]]' \
'(-v --verbose -s --summary)--quiet[Quiet mode - no stdout/stderr output. Return exit code only.  \[short\: -q\]]' \
'(-v --verbose -q --quiet)-s[Summary mode - minimize output, aggregate warnings  \[short\: -s\]]' \
'(-v --verbose -q --quiet)--summary[Summary mode - minimize output, aggregate warnings  \[short\: -s\]]' \
'-S[Show secret values in plain text (disables masking)  \[short\: -S\]]' \
'--show-secrets[Show secret values in plain text (disables masking)  \[short\: -S\]]' \
'(-q --quiet -s --summary)-v[Show identical keys in output as well (hidden by default)  \[short\: -v\]]' \
'(-q --quiet -s --summary)--verbose[Show identical keys in output as well (hidden by default)  \[short\: -v\]]' \
'--missing-only[Show only keys present in source but missing in target (ignores modifications/additions)]' \
'--mask-patches[Mask secrets in generated patch files. By default, patches contain real values to allow easy synchronization. Use this flag to redact sensitive values with ***MASKED*** before sharing patches securely]' \
'--example[Print detailed usage examples]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::file1 -- First file to compare (source / reference):_files' \
'::file2 -- Second file to compare (target):_files' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'--example[Print detailed usage examples]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::what -- Setting to configure\: '\''exit'\'', '\''color'\'', '\''advisor'\'', '\''masking'\'', '\''show'\'', or '\''path'\'':_default' \
'::action -- Action\: '\''show'\'' (default) or '\''toggle'\'':_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_qaren__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:qaren-help-command-$line[1]:"
        case $line[1] in
            (diff)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(kv)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_qaren_commands] )) ||
_qaren_commands() {
    local commands; commands=(
'diff:Perform literal line-by-line comparison (like POSIX diff)' \
'kv:Perform semantic key-value comparison \[alias\: kvp\]' \
'config:View and modify persistent Qaren settings' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'qaren commands' commands "$@"
}
(( $+functions[_qaren__subcmd__config_commands] )) ||
_qaren__subcmd__config_commands() {
    local commands; commands=()
    _describe -t commands 'qaren config commands' commands "$@"
}
(( $+functions[_qaren__subcmd__diff_commands] )) ||
_qaren__subcmd__diff_commands() {
    local commands; commands=()
    _describe -t commands 'qaren diff commands' commands "$@"
}
(( $+functions[_qaren__subcmd__help_commands] )) ||
_qaren__subcmd__help_commands() {
    local commands; commands=(
'diff:Perform literal line-by-line comparison (like POSIX diff)' \
'kv:Perform semantic key-value comparison \[alias\: kvp\]' \
'config:View and modify persistent Qaren settings' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'qaren help commands' commands "$@"
}
(( $+functions[_qaren__subcmd__help__subcmd__config_commands] )) ||
_qaren__subcmd__help__subcmd__config_commands() {
    local commands; commands=()
    _describe -t commands 'qaren help config commands' commands "$@"
}
(( $+functions[_qaren__subcmd__help__subcmd__diff_commands] )) ||
_qaren__subcmd__help__subcmd__diff_commands() {
    local commands; commands=()
    _describe -t commands 'qaren help diff commands' commands "$@"
}
(( $+functions[_qaren__subcmd__help__subcmd__help_commands] )) ||
_qaren__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'qaren help help commands' commands "$@"
}
(( $+functions[_qaren__subcmd__help__subcmd__kv_commands] )) ||
_qaren__subcmd__help__subcmd__kv_commands() {
    local commands; commands=()
    _describe -t commands 'qaren help kv commands' commands "$@"
}
(( $+functions[_qaren__subcmd__kv_commands] )) ||
_qaren__subcmd__kv_commands() {
    local commands; commands=()
    _describe -t commands 'qaren kv commands' commands "$@"
}

if [ "$funcstack[1]" = "_qaren" ]; then
    _qaren "$@"
else
    compdef _qaren qaren
fi
