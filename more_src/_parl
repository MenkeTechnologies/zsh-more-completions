#compdef parl parldyn
# Documentation: https://man.archlinux.org/search?q=parl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-h[show help]' \
  '-V[show version]' \
  '-O+[output to a single executable]:file:_files' \
  '-o+[output filename]:file:_files' \
  '-B[bundle in modules into binary]' \
  '-T+[manifest target]:type:' \
  '-q[quiet]' \
  '*:PAR archive or Perl script:_files -g "*.(par|pl|pm)"' && ret=0

return ret
