#compdef parl parldyn
# Documentation: https://metacpan.org/dist/PAR/view/script/parl.pod
# Reference accessed: 2026-05-20
# Verified: upstream PAR parl(1) manpage (verified locally via `man parl`).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '*-A+[pre-load PAR archive (-Afoo.par)]:par file:_files -g "*.par"' \
  '*-M+[load Perl module]:module:' \
  '*-I+[add include path]:path:_files -/' \
  '-p[make a PAR distribution]' \
  '-i+[install PAR distribution]:par file or URL:_files -g "*.par"' \
  '-u+[uninstall PAR distribution]:par file:_files -g "*.par"' \
  '-s+[sign PAR distribution]:par file:_files -g "*.par"' \
  '-v+[verify PAR distribution]:par file:_files -g "*.par"' \
  '-O+[output as a stand-alone binary or script]:output file:_files' \
  '-b[bundle non-core modules into binary]' \
  '-B[bundle core modules into binary]' \
  '--par-options[treat generated binary args as parl options]' \
  '*:PAR archive or Perl script:_files -g "*.(par|pl|pm)"' && ret=0

return ret
