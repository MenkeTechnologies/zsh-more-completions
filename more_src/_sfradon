#compdef sfradon
# Documentation: https://raw.githubusercontent.com/ahay/src/master/system/seismic/Mradon.c
# Madagascar: high-resolution Radon transform

local ret=1

_arguments -s \
  'adj=[if y perform adjoint operation]:adj:(y n)' \
  'inv=[if y perform inverse operation]:inv:(y n)' \
  'spk=[if y use spiking (hi-res) inversion]:spk:(y n)' \
  'verb=[verbosity flag]:verb:(y n)' \
  'np=[number of p values (if adj=y)]:np' \
  'dp=[p sampling (if adj=y)]:dp' \
  'p0=[p origin (if adj=y)]:p0' \
  'nx=[number of offsets (if adj=n)]:nx' \
  'offset=[file containing offset headers]:offset file:_files' \
  'eps=[damping and tolerance for inversion]:eps' \
  'ns=[number of sharpening cycles]:ns' \
  'tol=[inversion tolerance]:tol' \
  'perc=[percentage for sharpening]:perc' \
  'fact=[factor for sharpening]:fact' \
  'parab=[if y parabolic Radon transform]:parab:(y n)' \
  'x0=[reference offset]:x0' \
  'ox=[offset origin]:ox' \
  'dx=[offset increment]:dx' \
  'niter=[iterations for conjugate gradient solver]:niter' \
  '*:RSF file:_files' && ret=0

return ret
