#compdef nvassemble
# Documentation: https://www.systutorials.com/docs/linux/man/1-nvassemble/
# NVIDIA Texture Tools: assemble cube/volume/array textures

local ret=1

_arguments -s \
  '(-volume -array)-cube[assemble a cube texture]' \
  '(-cube -array)-volume[assemble a volume texture]' \
  '(-cube -volume)-array[assemble an array texture]' \
  '*:file:_files' && ret=0

return ret
