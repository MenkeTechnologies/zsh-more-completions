#compdef zabbix-java-gateway zabbix_java_gateway
# Documentation: https://www.zabbix.com/documentation/current/en/manual/appendix/config/zabbix_java
# Reference accessed: 2026-05-16
# Verified: Zabbix docs. No CLI flags - configured via settings.sh
# (PID_FILE, LISTEN_IP, LISTEN_PORT, START_POLLERS, TIMEOUT) or Java -D
# properties (-Dzabbix.pidFile, -Dzabbix.listenIP, etc.).

# zabbix-java-gateway: Zabbix Java JMX gateway (settings.sh-driven)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::extra args:_files' && ret=0
return ret
