#compdef op-batcher
# Documentation: https://man.archlinux.org/search?q=op-batcher
# Reference accessed: 2026-05-16

_arguments -s -S \
  '--l1-eth-rpc=[L1 JSON-RPC endpoint]:url:' \
  '--l2-eth-rpc=[L2 rollup JSON-RPC endpoint]:url:' \
  '--rollup-rpc=[Rollup node RPC for batch encoding]:url:' \
  '--private-key=[Hex private key for batch submission]' \
  '--mnemonic=[Hot wallet mnemonic]' \
  '--poll-interval=[Poll cadence]:duration:' \
  '--num-confirmations=[L1 confirmations to wait]:n:' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '*::arguments: _default'
