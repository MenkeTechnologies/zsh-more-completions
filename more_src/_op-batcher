#compdef op-batcher
# Documentation: https://github.com/ethereum-optimism/optimism/blob/develop/op-batcher/flags/flags.go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '--l1-eth-rpc=[L1 JSON-RPC endpoint]:url:' \
  '--l2-eth-rpc=[L2 rollup JSON-RPC endpoint]:url:' \
  '--rollup-rpc=[Rollup node RPC for batch encoding]:url:' \
  '--sub-safety-margin=[L1 sub-safety margin]:n:' \
  '--poll-interval=[Poll cadence]:duration:' \
  '--max-pending-tx=[max pending L1 transactions]:n:' \
  '--max-channel-duration=[max channel duration in L1 blocks]:n:' \
  '--max-l1-tx-size-bytes=[max L1 transaction size in bytes]:bytes:' \
  '--max-blocks-per-span-batch=[max blocks per span batch]:n:' \
  '--target-num-frames=[target number of frames per channel]:n:' \
  '--approx-compr-ratio=[approximate compression ratio]:ratio:' \
  '--compressor=[compressor type]:type:' \
  '--compression-algo=[compression algorithm]:algo:' \
  '--stopped[start the batcher in stopped state]' \
  '--batch-type=[batch type (0 singular, 1 span)]:type:(0 1)' \
  '--data-availability-type=[data availability type]:type:' \
  '--active-sequencer-check-duration=[active sequencer check interval]:duration:' \
  '--check-recent-txs-depth=[blocks to check for recent transactions]:n:' \
  '--wait-node-sync[wait for node sync before starting]' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '*::arguments: _default'
