#compdef srb
# Documentation: https://sorbet.org/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above plus
# https://github.com/sorbet/sorbet/blob/master/main/options/options.cc

# Zsh completion for srb (Sorbet Ruby type checker)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize Sorbet in current project'
      'tc:typecheck the project'
      'rbi:manage RBI files'
    )
    _describe -t commands 'srb command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      tc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(- *)--version[show version]' \
          '--dir=[directory to typecheck]:directory:_directories' \
          '--file=[specific file to typecheck]:file:_files' \
          '--typed=[minimum typing level]:level:(ignore false true strict strong auto)' \
          '--typed-override=[YAML file with per-file typing overrides]:file:_files -g "*.yaml"' \
          '--ignore=[ignore files matching pattern]:pattern' \
          {-a,--autocorrect}'[auto-correct errors where possible]' \
          '--suggest-unsafe[include unsafe autocorrects using T.unsafe]' \
          '--isolate-error-code=[only report specific error code]:code' \
          '--suppress-error-code=[suppress specific error code]:code' \
          '--no-config[do not load sorbet/config]' \
          '--remove-path-prefix=[strip prefix from displayed paths]:prefix' \
          '--color=[control color output]:when:(always never auto)' \
          '--lsp[start in language server protocol mode]' \
          '--disable-watchman[do not use watchman in LSP mode]' \
          '-e+[typecheck a string of Ruby code]:code' \
          '-p+[print intermediate representation]:ir' \
          '--stop-after=[stop after specific compiler pass]:pass' \
          '--cache-dir=[directory for cache files]:directory:_directories' \
          '--max-cache-size-bytes=[cache size limit in bytes]:bytes' \
          '--max-threads=[number of threads to use]:count' \
          '--metrics-file=[file for metrics output]:file:_files' \
          '--metrics-prefix=[prefix for metrics]:prefix' \
          '--metrics-branch=[branch name for metrics export]:branch' \
          '--metrics-sha=[SHA field in metrics output]:sha' \
          '--metrics-repo=[repository name for metrics]:repo' \
          '--metrics-extra-tags=[comma-separated key=value tags]:tags' \
          '--statsd-host=[StatsD host]:host' \
          '--statsd-port=[StatsD port]:port' \
          '--statsd-prefix=[StatsD metric prefix]:prefix' \
          '*:files:_files -g "*.rb"' && ret=0
        ;;
    esac
    ;;
esac

return ret
