#compdef casa
# Documentation: https://casadocs.readthedocs.io/en/v6.5.6/api/configuration.html
# CASA (Common Astronomy Software Applications) interactive shell startup.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --version)'{-v,--version}'[show CASA version]' \
  '--logfile[redirect logger output to file]:logfile:_files' \
  '--log2term[direct logging output to the terminal]' \
  '--nologger[do not start the CASA logger GUI]' \
  '--nologfile[do not create a log file]' \
  '--nogui[avoid starting GUI tools]' \
  '--rcdir[location for startup and internal working files]:dir:_files -/' \
  '--norc[do not load user config.py file]' \
  '--colors[IPython prompt color scheme]:scheme:(Neutral NoColor Linux LightBG)' \
  '--pipeline[load CASA pipeline modules on startup]' \
  '--agg[start without a graphical backend]' \
  '--iplog[create an IPython log in the current directory]' \
  '--notelemetry[disable telemetry collection]' \
  '--nocrashreport[disable anonymous crash reporting]' \
  '--datapath[colon-separated data search paths]:datapath:_files -/' \
  '--user-site[include user local site-packages in the Python path]' \
  '-c[execute a Python eval string or script]:script:_files' \
  '*:file:_files' && ret=0

return ret
