#compdef cdc-filter-helper filter-helper
# _cdc-filter-helper — TiCDC filter expression checker
# upstream: https://github.com/pingcap/tiflow
# Flags from cmd/filter-helper/main.go on tip.

_cdc-filter-helper() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config)'{-c,--config=}'[changefeed config file]:file:_files' \
        '(-t --table)'{-t,--table=}'[table name (schema.table)]:table:' \
        '(-d --ddl)'{-d,--ddl=}'[DDL query to test]:sql:'
}

_cdc-filter-helper "$@"
