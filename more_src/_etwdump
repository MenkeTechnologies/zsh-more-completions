#compdef etwdump
# Documentation: https://www.wireshark.org/docs/man-pages/etwdump.html
# Provide an extcap interface to read Event Tracing for Windows (ETW)

local ret=1

_arguments -s -S \
  '--help[display program arguments]' \
  '--version[display program version]' \
  '--extcap-interfaces[list available interfaces]' \
  '--extcap-interface=[specify which interface to use]:interface:' \
  '--extcap-dlts[list DLTs for the specified interface]' \
  '--extcap-config[list configuration options for the interface]' \
  '--capture[begin capturing from the designated interface]' \
  '--fifo=[specify destination for captured packets]:path:_files' \
  '--iue=[include undecidable events]:value:(true false)' \
  '--etlfile=[select an ETL file for display]:etl file:_files' \
  '--params=[provider, keyword, and level filters]:filter parameters:' && ret=0

return ret
