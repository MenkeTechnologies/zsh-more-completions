# Source: cargo binstall kopium@0.23.0
# Probed via: completions zsh
# Repository: https://github.com/kube-rs/kopium
#compdef kopium

autoload -U is-at-least

_kopium() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'()-f+[Point to the location of a CRD to use on disk]:FILE:_files' \
'()--filename=[Point to the location of a CRD to use on disk]:FILE:_files' \
'--api-version=[Use this CRD version if multiple versions are present]:API_VERSION:_default' \
'--schema=[Schema mode to use for kube-derive]:SCHEMA_MODE:(manual derived disabled)' \
'*-D+[Derive these additional traits on generated objects]:TRAIT:_default' \
'*--derive=[Derive these additional traits on generated objects]:TRAIT:_default' \
'*-e+[Elide the following containers from the output]:ELIDE:_default' \
'*--elide=[Elide the following containers from the output]:ELIDE:_default' \
'--map-type=[Type used to represent maps via \`additionalProperties\`]:MAP_TYPE:(BTreeMap HashMap)' \
'-A[Enable all automation features]' \
'--auto[Enable all automation features]' \
'--hide-prelude[Do not emit prelude(s)]' \
'--hide-kube[Do not derive CustomResource nor set kube-derive attributes]' \
'-d[Emit doc comments from CRD field descriptions]' \
'--docs[Emit doc comments from CRD field descriptions]' \
'-b[Emit builder derives via the \`typed-builder\` crate]' \
'--builders[Emit builder derives via the \`typed-builder\` crate]' \
'--relaxed[Relaxed interpretation]' \
'--no-condition[Disable standardized Condition API]' \
'--no-object-reference[Disable standardised ObjectReference API]' \
'--smart-derive-elision[Automatically removes \`#\[derive(Default)\]\` from structs that contain fields for which a default cannot be automatically derived]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::crd -- Give the name of the input CRD to use (e.g., `prometheusrules.monitoring.coreos.com`):_default' \
":: :_kopium_commands" \
"*::: :->kopium" \
&& ret=0
    case $state in
    (kopium)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kopium-command-$line[2]:"
        case $line[2] in
            (list-crds)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_kopium__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kopium-help-command-$line[1]:"
        case $line[1] in
            (list-crds)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_kopium_commands] )) ||
_kopium_commands() {
    local commands; commands=(
'list-crds:List available CRDs' \
'completions:Generate completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'kopium commands' commands "$@"
}
(( $+functions[_kopium__completions_commands] )) ||
_kopium__completions_commands() {
    local commands; commands=()
    _describe -t commands 'kopium completions commands' commands "$@"
}
(( $+functions[_kopium__help_commands] )) ||
_kopium__help_commands() {
    local commands; commands=(
'list-crds:List available CRDs' \
'completions:Generate completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'kopium help commands' commands "$@"
}
(( $+functions[_kopium__help__completions_commands] )) ||
_kopium__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'kopium help completions commands' commands "$@"
}
(( $+functions[_kopium__help__help_commands] )) ||
_kopium__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'kopium help help commands' commands "$@"
}
(( $+functions[_kopium__help__list-crds_commands] )) ||
_kopium__help__list-crds_commands() {
    local commands; commands=()
    _describe -t commands 'kopium help list-crds commands' commands "$@"
}
(( $+functions[_kopium__list-crds_commands] )) ||
_kopium__list-crds_commands() {
    local commands; commands=()
    _describe -t commands 'kopium list-crds commands' commands "$@"
}

if [ "$funcstack[1]" = "_kopium" ]; then
    _kopium "$@"
else
    compdef _kopium kopium
fi
