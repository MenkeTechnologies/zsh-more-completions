#compdef babeltrace2

# Zsh completion for babeltrace2 - trace converter and processor

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'convert:convert one or more traces (default)'
  'help:get help for a plugin or component class'
  'list-plugins:list available plugins'
  'query:query an object from a component class'
  'run:build a processing graph and run it'
)

_arguments -s -S \
  '1:command:->command' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '--log-level=[set log level]:level:(NONE FATAL ERROR WARN INFO DEBUG TRACE)' \
  '--omit-home-plugin-path[do not search for plugins in home directory]' \
  '--omit-system-plugin-path[do not search for plugins in system directories]' \
  '--plugin-path=[add directory to plugin search path]:directory:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose mode]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'babeltrace2 command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (convert)
        _arguments -s -S \
          '(-c --component)'{-c,--component}'[create a component]:name\:TYPE.PLUGIN.CLS' \
          '(-p --params)'{-p,--params}'[set component parameters]:params' \
          '--retry-duration=[set retry duration for live sources]:microseconds' \
          '(-o --output)'{-o,--output}'[set output format]:format:(text ctf dummy)' \
          '--output-format=[set output format]:format:(text ctf dummy)' \
          '(-i --input-format)'{-i,--input-format}'[set input format]:format:(ctf lttng-live)' \
          '--fields=[set output fields]:fields' \
          '--names=[set output name]:names' \
          '--no-delta[do not print time delta]' \
          '--clock-cycles[print clock cycles instead of time]' \
          '--clock-date[print full date]' \
          '--clock-gmt[print GMT/UTC time]' \
          '--clock-seconds[print time in seconds since epoch]' \
          '--color=[set color output]:when:(auto always never)' \
          '(-w --output-path)'{-w,--output-path}'[set CTF output path]:directory:_files -/' \
          '*:trace path:_files -/' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '(-c --component)'{-c,--component}'[create a component]:name\:TYPE.PLUGIN.CLS' \
          '(-p --params)'{-p,--params}'[set component parameters]:params' \
          '(-x --connection)'{-x,--connection}'[connect ports]:upstream\:downstream' \
          '--retry-duration=[set retry duration]:microseconds' && ret=0
        ;;
      (list-plugins)
        _arguments -s -S && ret=0
        ;;
      (help)
        _arguments '1:plugin or component class' && ret=0
        ;;
      (query)
        _arguments -s -S \
          '(-c --component)'{-c,--component}'[component class]:TYPE.PLUGIN.CLS' \
          '(-p --params)'{-p,--params}'[query parameters]:params' \
          '1:object' && ret=0
        ;;
    esac
    ;;
esac

return ret
