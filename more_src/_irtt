#compdef irtt
# _irtt — Isochronous Round-Trip Time tester
# upstream: https://github.com/heistp/irtt

_irtt() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'client:run as client'
                'server:run as server'
                'bench:run benchmarks'
                'clock:test wall clock'
                'sleep:test sleep accuracy'
                'version:show version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                client)
                    _arguments \
                        '(-d --duration)'{-d,--duration=}'[test duration]:duration:' \
                        '(-i --interval)'{-i,--interval=}'[send interval]:interval:' \
                        '(-l --length)'{-l,--length=}'[packet length]:bytes:' \
                        '(-o --output)'{-o,--output=}'[output file]:file:_files' \
                        '--dscp=[DSCP value]:dscp:' \
                        '--df=[do not fragment]:df:(true false)' \
                        '--fill=[payload fill]:fill:(none rand)' \
                        '--local=[local address]:address:' \
                        '--hmac=[HMAC key]:key:' \
                        '--timeouts=[timeouts spec]:timeouts:' \
                        '--timer=[timer type]:timer:(comp hybrid sleep busy)' \
                        '--waiter=[waiter type]:waiter:(3x4s)' \
                        '--thread-lock[lock goroutine to OS thread]' \
                        '--stats=[output stats]:format:(text json)' \
                        '--quiet[quiet output]' \
                        '--verbose[verbose output]' \
                        '1:server address:_hosts'
                    ;;
                server)
                    _arguments \
                        '(-b --bind)'{-b,--bind=}'[bind address]:address:' \
                        '--hmac=[HMAC key]:key:' \
                        '--pburst=[max packets per interval from client]:count:' \
                        '--fill=[payload fill]:fill:(none rand)' \
                        '--thread-lock[lock goroutine to OS thread]' \
                        '--verbose[verbose output]'
                    ;;
            esac
            ;;
    esac
}

_irtt "$@"
