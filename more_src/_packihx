#compdef packihx
# Documentation: https://manpages.debian.org/unstable/sdcc/packihx.1
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. STUB: packihx accepts no options
# beyond an optional input file; it reads stdin and writes stdout otherwise.

# packihx: SDCC tool to compact an Intel hex file
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:ihx file:_files -g "*.(ihx|hex)"' && ret=0
return ret
