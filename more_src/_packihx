#compdef packihx

# packihx: SDCC tool to compact an Intel hex file
# Documentation: https://sdcc.sourceforge.net/doc/sdccman.pdf
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:ihx file:_files -g "*.(ihx|hex)"' && ret=0
return ret
