#compdef standard-version

# Zsh completion for standard-version

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-r --release-as)'{-r,--release-as}'[specify release type or version]:release:(major minor patch)' \
  '(-p --prerelease)'{-p,--prerelease}'[make a pre-release with optional tag]:tag' \
  '(-f --first-release)'{-f,--first-release}'[first release, skip bumping version]' \
  '(-s --sign)'{-s,--sign}'[sign the git commit and tag]' \
  '(-n --no-verify)'{-n,--no-verify}'[bypass pre-commit and commit-msg hooks]' \
  '(-a --commit-all)'{-a,--commit-all}'[commit all staged changes]' \
  '(-t --tag-prefix)'{-t,--tag-prefix}'[set a custom tag prefix]:prefix' \
  '--dry-run[show what would happen without making changes]' \
  '--silent[suppress output]' \
  '--skip.changelog[skip changelog generation]' \
  '--skip.bump[skip version bump]' \
  '--skip.commit[skip git commit]' \
  '--skip.tag[skip git tag]' \
  '--header=[changelog header]:header' \
  '--infile=[read the CHANGELOG from this file]:changelog file:_files' \
  '--packageFiles=[files containing version]:file:_files' \
  '--bumpFiles=[additional files to bump version in]:file:_files' \
  '--preset=[conventional commits preset]:preset:(angular atom ember eslint express jquery jshint conventionalcommits)' \
  '--releaseCommitMessageFormat=[custom commit message format]:format' && ret=0

return ret
