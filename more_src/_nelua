#compdef nelua
# Documentation: https://github.com/edubart/nelua-lang
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (lualib/nelua/configer.lua).

# nelua - minimal, statically-typed, Lua-inspired systems language that
# compiles to C and native code.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)'{-v,--version}'[print compiler detailed version]' \
  '(- *)--semver[print compiler semantic version]' \
  '(- *)--config[print config variables only]' \
  '(-c --code)'{-c,--code}'[compile the backend code only]' \
  '(-a --analyze)'{-a,--analyze}'[analyze the code only]' \
  '(-b --binary)'{-b,--binary}'[compile the binary only]' \
  '(-B --object)'{-B,--object}'[compile as an object file]' \
  '(-Y --assembly)'{-Y,--assembly}'[compile as an assembly file]' \
  '(-A --static-lib)'{-A,--static-lib}'[compile as a static library]' \
  '(-H --shared-lib)'{-H,--shared-lib}'[compile as a shared library]' \
  '--script[run lua a script instead of compiling]' \
  '--lint[check for syntax errors only]' \
  '--print-ast[print the AST only]' \
  '--print-analyzed-ast[print the analyzed AST only]' \
  '--print-ppcode[print the generated Lua preprocessing code only]' \
  '--print-code[print the generated code only]' \
  '--print-assembly[print the assembly code only]' \
  '(-i --eval)'{-i+,--eval=}'[evaluate string code from input]:code:' \
  '(-d --debug)'{-d,--debug}'[run through GDB to get crash backtraces]' \
  '(-S --sanitize)'{-S,--sanitize}'[enable undefined/address sanitizers]' \
  '(-r --release)'{-r,--release}'[release build]' \
  '(-M --maximum-performance)'{-M,--maximum-performance}'[maximum performance build]' \
  '(-s --strip-bin)'{-s,--strip-bin}'[remove symbols from the compiled binary]' \
  '(-t --timing)'{-t,--timing}'[show compile timing information]' \
  '(-T --more-timing)'{-T,--more-timing}'[show detailed compile timing information]' \
  '(-V --verbose)'{-V,--verbose}'[show compile related information]' \
  '(-w --no-warning)'{-w,--no-warning}'[suppress all warning messages]' \
  '(-C --no-cache)'{-C,--no-cache}'[do not use any cached compilation]' \
  '--no-color[disable colorized output]' \
  '(-R --runner)'{-R+,--runner=}'[execute compiled output with a runner]:runner:' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '*'{-D+,--define=}'[define values in the preprocessor]:name[=value]:' \
  '*'{-P+,--pragma=}'[set initial compiler pragma]:name[=value]:' \
  '(-g --generator)'{-g+,--generator=}'[code generator backend]:generator:(c lua)' \
  '*'{-L+,--add-path=}'[add module search path]:path:_directories' \
  '--cc=[C compiler to use]:compiler:_command_names -e' \
  '--cflags=[additional C compiler flags]:flags:' \
  '--ldflags=[additional linker flags]:flags:' \
  '--stripflags=[additional flags for stripping]:flags:' \
  '--cache-dir=[compilation cache directory]:directory:_directories' \
  '--path=[set module search path]:path:' \
  '1:input file:_files -g "*.nelua"' \
  '*::runargs:_default' && ret=0

return ret
