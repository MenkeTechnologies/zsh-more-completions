#compdef nelua

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--analyze[only analyze]' \
  '--generate[analyze and generate code only]' \
  '--compile[analyze, generate, and compile only]' \
  '-o+[set output file]:file:_files' \
  '--output=[set output file]:file:_files' \
  '-D+[define a value]:name_value' \
  '--define=[define a value]:name_value' \
  '-P+[define a pragma]:name_value' \
  '--pragma=[define a pragma]:name_value' \
  '-g[compile with debug information]' \
  '-r[run after compiling]' \
  '-b[compile in release mode]' \
  '--release[compile in release mode]' \
  '-t+[override the generator]:generator:(c)' \
  '--generator=[override the generator]:generator:(c)' \
  '-p+[add to require search path]:path:_directories' \
  '--path=[add to require search path]:path:_directories' \
  '-L+[add to C library search path]:path:_directories' \
  '--lib-path=[add to C library search path]:path:_directories' \
  '--cc=[set the C compiler]:compiler:_command_names' \
  '--cflags=[set additional C compiler flags]:flags' \
  '--ldflags=[set additional linker flags]:flags' \
  '--cache-dir=[set the cache directory]:directory:_directories' \
  '--no-cache[do not use cache]' \
  '--print-code[print the generated code]' \
  '--print-ast[print the AST]' \
  '--timing[show timing information]' \
  '1:input file:_files -g "*.nelua"' && ret=0

return ret
