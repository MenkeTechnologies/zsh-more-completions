#compdef testkitchen test-kitchen-cli kitchen-ci kitchencli
# _testkitchen — Chef test-kitchen testkitchen alias CLI for running infrastructure-test suites against drivers Vagrant Docker AWS GCP Azure Hyper-V LXC ec2 converging cookbook-applied platforms validating with InSpec Serverspec (test-kitchen team, Ruby); Thor
# upstream: https://github.com/test-kitchen/test-kitchen

_testkitchen() {
    local -a sub=(
        'console:open Pry console'
        'converge:converge instance'
        'create:create instance'
        'destroy:destroy instance'
        'diagnose:show diagnostic info'
        'doctor:run diagnostics'
        'driver:driver operations'
        'exec:exec command on instance'
        'help:show help'
        'init:init Kitchen for project'
        'list:list instances'
        'login:SSH into instance'
        'package:package an instance'
        'setup:setup instance'
        'test:test instance'
        'verify:verify instance'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[concurrency]:n:' \
        '--concurrency=+[concurrency]:n:' \
        '-d+[destroy mode]:m:(always passing never)' \
        '--destroy=+[destroy mode]:m:(always passing never)' \
        '-l+[log level]:l:(debug info warn error fatal)' \
        '--log-level=+[log level]:l:(debug info warn error fatal)' \
        '--log-overwrite[overwrite log]' \
        '--no-color[no color]' \
        '--color[force color]' \
        '-t+[test suite]:str:' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'testkitchen subcommand' sub ;;
        args)
            case $words[1] in
                converge|create|destroy|setup|test|verify|login|diagnose|exec) _arguments \
                    '*:instance pattern:' ;;
                init) _arguments \
                    '--driver=+[driver]:d:(vagrant docker dokken ec2 gce azurerm hyperv lxc lxd openstack)' \
                    '--provisioner=+[p]:p:(chef_zero chef_solo chef_apply chef_client puppet_apply puppet_agent salt_solo shell ansible_playbook)' \
                    '--create-gemfile[create Gemfile]' ;;
                test) _arguments \
                    '-d+[destroy mode]:m:(always passing never)' \
                    '--destroy=+[destroy mode]:m:(always passing never)' \
                    '--auto-init[auto init]' ;;
            esac
            ;;
    esac
}

_testkitchen "$@"
