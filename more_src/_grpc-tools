#compdef grpc-tools grpc_tools_node_protoc grpc-tools-node-protoc
# _grpc-tools — grpc-tools for Node.js protoc wrapper CLI alias (gRPC team / Google, JavaScript); pass-through to protoc
# upstream: https://github.com/grpc/grpc-node

_grpc-tools() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--js_out=+[js output options]:str:' \
        '--grpc_out=+[grpc output options]:str:' \
        '--ts_out=+[ts output options]:str:' \
        '-I+[include path]:list:_files -/' \
        '--proto_path=+[proto path]:list:_files -/' \
        '--descriptor_set_in=+[descriptor set]:list:_files' \
        '--descriptor_set_out=+[descriptor set output]:file:_files' \
        '--include_imports[include imports]' \
        '--include_source_info[include source info]' \
        '--encode=+[encode message type]:str:' \
        '--decode=+[decode message type]:str:' \
        '--decode_raw[decode raw bytes]' \
        '--print_free_field_numbers[print free field numbers]' \
        '--error_format=+[error format]:fmt:(gcc msvs)' \
        '--plugin=+[plugin spec]:str:' \
        '*:proto:_files -g "*.proto"'
}

_grpc-tools "$@"
