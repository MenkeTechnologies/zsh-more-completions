#compdef vampire
# Documentation: https://man.archlinux.org/search?q=vampire
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '(-t --time_limit)'{-t+,--time_limit=}'[time limit seconds]:t:' \
  '--memory_limit+[memory limit MB]:mb:' \
  '(-m --mode)'{-m+,--mode=}'[run mode]:m:(vampire casc casc_sat casc_ltb portfolio bpa axiom_selection clausify model_check tclausify tpreprocess preprocess preprocess2 spider consequence_elimination)' \
  '--input_syntax+[input syntax]:s:(tptp smtlib smtlib2 auto)' \
  '--output_axiom_names[output axiom names]' \
  '--proof+[proof output]:p:(off on tptp proofcheck)' \
  '--statistics+[statistics level]:l:(none brief full)' \
  '(-p --print_clausifier_premises)'{-p,--print_clausifier_premises}'[print premises]' \
  '--include+[include path]:dir:_files -/' \
  '(-decode --decode)'{-decode+,--decode=}'[decode option string]:opts:' \
  '--show_options+[show options]:l:(off bad good all)' \
  '--show_experimental_options[show experimental]' \
  '--show_help+[show help on options]:on:(on off)' \
  '--saturation_algorithm+[saturation algo]:a:(discount otter lrs inst_gen fmb)' \
  '--age_weight_ratio+[age:weight]:r:' \
  '--literal_comparison_mode+[literal cmp]:m:(standard reverse predicate)' \
  '--symbol_precedence+[symbol precedence]:p:(arity occurrence reverse_arity scramble frequency reverse_frequency weighted_frequency)' \
  '--question_answering+[QA mode]:m:(off answer_literal from_proof)' \
  '--manual_cs[manual clause selection]' \
  '--cores+[cores]:n:' \
  '*: :_files -g "*.p *.tptp *.smt2 *.smt *.fof"' && ret=0

return ret
