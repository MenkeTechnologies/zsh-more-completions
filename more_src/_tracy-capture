#compdef tracy-capture
# Documentation: https://github.com/wolfpld/tracy

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-a,--address}'=[server address to connect to]:address:_hosts' \
  {-p,--port}'=[server port]:port:' \
  {-o,--output}'=[output file path]:file:_files' \
  {-f,--overwrite}'[overwrite existing output file]' \
  {-s,--seconds}'=[capture duration in seconds]:seconds:' \
  {-t,--timer}'[display elapsed time]' \
  && return 0
