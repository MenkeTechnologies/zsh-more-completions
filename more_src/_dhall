#compdef dhall
# Documentation: https://github.com/dhall-lang/dhall-haskell
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dhall (Dhall configuration language CLI, dhall-haskell)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--help[Print help]' \
  '--version[Print version]' \
  '--annotate[Add a type annotation to the output]' \
  '--alpha[Alpha-normalize the output expression]' \
  '--plain[Disable syntax highlighting]' \
  '--ascii[Use ASCII for rendering]' \
  '--censor[Hide source code in error messages]' \
  '--explain[Explain error messages in detail]' \
  '--file=[Read expression from file]:file:_files' \
  '--output=[Write result to file]:file:_files' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'version:Display version'
      'resolve:Resolve an expression imports'
      'type:Infer the type of an expression'
      'normalize:Normalize an expression'
      'repl:Interpret expressions in a REPL'
      'diff:Render the difference between normal forms of two expressions'
      'hash:Compute semantic hashes for Dhall expressions'
      'lint:Improve Dhall code (newer features, dead code removal)'
      'format:Standard code formatter for the Dhall language'
      'freeze:Add integrity checks to remote import statements'
      'encode:Encode a Dhall expression to binary'
      'decode:Decode a Dhall expression from binary'
      'text:Render a Dhall expression that evaluates to a Text literal'
      'to-directory-tree:Convert nested records into a directory tree'
      'tags:Generate etags file'
      'package:Create a package.dhall referencing provided paths'
      'rewrite-with-schemas:Simplify code using a schemas record'
      'haskell-syntax-tree:Output the parsed syntax tree (debug)'
    )
    _describe -t commands 'dhall command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      resolve)
        _arguments -s -S \
          '--help[Print help]' \
          '--file=[Read expression from file]:file:_files' \
          '--output=[Write result to file]:file:_files' \
          '--dot[Output import graph in dot format]' \
          '--list-imports[List all imports with their types]' \
          '--plain[Disable syntax highlighting]' \
          '--ascii[Use ASCII for rendering]' \
          '--censor[Hide source code in error messages]' && ret=0
        ;;
      type)
        _arguments -s -S \
          '--help[Print help]' \
          '--file=[Read expression from file]:file:_files' \
          '--output=[Write result to file]:file:_files' \
          '--plain[Disable syntax highlighting]' \
          '--ascii[Use ASCII for rendering]' \
          '--quiet[Only check but do not output the type]' && ret=0
        ;;
      normalize)
        _arguments -s -S \
          '--help[Print help]' \
          '--file=[Read expression from file]:file:_files' \
          '--output=[Write result to file]:file:_files' \
          '--alpha[Alpha-normalize the output]' \
          '--plain[Disable syntax highlighting]' \
          '--ascii[Use ASCII for rendering]' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '--help[Print help]' \
          '--plain[Disable syntax highlighting]' \
          '--ascii[Use ASCII for rendering]' \
          '1:expression 1' \
          '2:expression 2' && ret=0
        ;;
      hash)
        _arguments -s -S \
          '--help[Print help]' \
          '--file=[Read expression from file]:file:_files' \
          '--cache[Cache the hashed expression]' && ret=0
        ;;
      lint)
        _arguments -s -S \
          '--help[Print help]' \
          '--inplace[Modify files in place]' \
          '--check[Only check if files are linted]' \
          '--transitive[Also lint transitive imports]' \
          '*:files:_files' && ret=0
        ;;
      format)
        _arguments -s -S \
          '--help[Print help]' \
          '--inplace[Modify files in place]' \
          '--check[Only check if files are formatted]' \
          '--transitive[Also format transitive imports]' \
          '--ascii[Use ASCII for rendering]' \
          '--censor[Hide source code in error messages]' \
          '*:files:_files' && ret=0
        ;;
      freeze)
        _arguments -s -S \
          '--help[Print help]' \
          '--inplace[Modify files in place]' \
          '--all[Freeze all imports including local imports]' \
          '--cache[Cache imports as they are frozen]' \
          '--censor[Hide source code in error messages]' \
          '*:files:_files' && ret=0
        ;;
      encode)
        _arguments -s -S \
          '--help[Print help]' \
          '--file=[Read expression from file]:file:_files' \
          '--json[Use JSON encoding instead of CBOR]' && ret=0
        ;;
      decode)
        _arguments -s -S \
          '--help[Print help]' \
          '--file=[Read expression from file]:file:_files' \
          '--output=[Write result to file]:file:_files' \
          '--json[Decode from JSON instead of CBOR]' \
          '--plain[Disable syntax highlighting]' \
          '--ascii[Use ASCII for rendering]' && ret=0
        ;;
      text)
        _arguments -s -S \
          '--help[Print help]' \
          '--file=[Read expression from file]:file:_files' \
          '--output=[Write result to file]:file:_files' && ret=0
        ;;
      to-directory-tree)
        _arguments -s -S \
          '--help[Print help]' \
          '--file=[Read expression from file]:file:_files' \
          '--output=[Output directory]:dir:_directories' && ret=0
        ;;
      tags)
        _arguments -s -S \
          '--help[Print help]' \
          '--input=[Input source]:input:(stdin)' \
          '--output=[Output file]:file:_files' \
          '--etags[Generate etags format]' \
          '--suffixes=[File suffixes to process]:suffixes' \
          '--follow-symlinks[Follow symbolic links]' && ret=0
        ;;
    esac
    ;;
esac

return ret
