#compdef dra

# Zsh completion for dra - download release assets from GitHub

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --select)'{-s,--select}'[select asset matching pattern]:pattern' \
  '(-o --output)'{-o,--output}'[output file or directory]:path:_files' \
  '(-i --install)'{-i,--install}'[install to directory]:directory:_files -/' \
  '(-a --automatic)'{-a,--automatic}'[automatically select best asset]' \
  '(-t --tag)'{-t,--tag}'[download specific tag]:tag' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '--source[download source archive]' \
  '--untag[download untagged release]' \
  '1:repository (owner/repo)'
