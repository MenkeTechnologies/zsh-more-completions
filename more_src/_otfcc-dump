#compdef otfcc-dump
# Dump OpenType/TrueType font files to JSON (otfcc toolkit)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--pretty[pretty-print JSON output]' \
  '--ugly[compact JSON output]' \
  '--time[show time cost]' \
  '--glyph-name-prefix[set glyph name prefix]:prefix:' \
  '--ignore-glyph-order[ignore glyph order in font]' \
  '--ignore-hints[ignore hinting instructions]' \
  '--decimal-cmap[use decimal codepoints in cmap]' \
  '-o[output file]:file:_files' \
  '*:font file:_files -g "*.(otf|ttf|ttc|woff|woff2)"' \
  && return 0
