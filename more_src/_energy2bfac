#compdef energy2bfac
# Documentation: https://g-mmpbsa.readthedocs.io/en/stable/commands/energy2bfac.html
# Map MM/PBSA residue energies into PDB b-factor field (g_mmpbsa)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-s[structure file with mass data (default topol.tpr)]:struct:_files' \
  '-i[energy contribution data file (default decomp_energy.dat)]:dat:_files' \
  '-n[atomic index file for group selection]:ndx:_files -g "*.ndx"' \
  '-c[output complex structure PDB]:pdb:_files' \
  '-s1[output first subunit PDB]:pdb:_files' \
  '-s2[output second subunit PDB]:pdb:_files' \
  '-b[starting frame time (default 0)]:time' \
  '-e[ending frame time (default 0)]:time' \
  '-dt[frame sampling interval (default 0)]:time' \
  '-tu[time unit (default ps)]:unit:(fs ps ns us ms s)' \
  '-[no]w[view output files]' \
  '*:file:_files' && ret=0

return ret
