#compdef gog
# Documentation: https://man.archlinux.org/search?q=gog
# Reference accessed: 2026-05-16

# https://github.com/openclaw/gogcli — kong (RootFlags + command tree, v0.15.x)

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'send:send mail (gmail send shortcut)'
  'ls:list Drive files (drive ls shortcut)'
  'search:search Drive (drive search shortcut)'
  'open:print web URL for Google URL/ID'
  'download:download Drive file (drive download shortcut)'
  'upload:upload to Drive (drive upload shortcut)'
  'login:authorize / store refresh token'
  'logout:remove stored refresh token'
  'status:auth and config status'
  'me:people profile'
  'whoami:people profile'
  'auth:auth and credentials'
  'backup:encrypted account backups'
  'groups:Google Groups'
  'admin:Workspace admin (Directory API)'
  'drive:Google Drive'
  'docs:Google Docs'
  'slides:Google Slides'
  'calendar:Google Calendar'
  'classroom:Google Classroom'
  'time:local time utilities'
  'gmail:Gmail'
  'chat:Google Chat'
  'contacts:Google Contacts'
  'tasks:Google Tasks'
  'people:Google People'
  'keep:Google Keep (Workspace)'
  'sheets:Google Sheets'
  'forms:Google Forms'
  'appscript:Google Apps Script'
  'config:configuration'
  'exit-codes:print stable exit codes'
  'agent:agent helpers'
  'schema:machine-readable command schema'
  'version:print version'
  'completion:generate completion scripts'
)

_arguments -s -S \
  '--color=[color output]:mode:(auto always never)' \
  '(-a --account)'{-a+,--account=}'[account email for API commands]:email:' \
  '--client=[OAuth client / token bucket name]:name:' \
  '--access-token=[use this access token instead of stored refresh]:token:' \
  '--enable-commands=[restrict enabled commands]:list:' \
  '--disable-commands=[disable commands]:list:' \
  '--gmail-no-send[block Gmail send operations]' \
  '(-j --json)'{-j,--json}'[JSON output for scripting]' \
  '(-p --plain)'{-p,--plain}'[TSV/plain output]' \
  '--results-only[JSON: strip envelope fields]' \
  '--select=[JSON: select fields]:fields:' \
  '(-n --dry-run)'{-n,--dry-run}'[preview changes only]' \
  '(-y --force)'{-y,--force}'[skip confirmations]' \
  '--no-input[non-interactive / fail if prompt needed]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '--version[print version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'gog command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
