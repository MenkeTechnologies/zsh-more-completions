#compdef dwl
# Documentation: https://man.archlinux.org/search?q=dwl
# Reference accessed: 2026-05-16

# Zsh completion for dwl - dwm for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d)'-d'[enable debug logging]' \
  '(-s)'-s'[startup command]:command:_command_names'
