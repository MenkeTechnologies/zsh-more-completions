#compdef yamlfmt
# Documentation: https://man.archlinux.org/search?q=yamlfmt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-conf[config file path]:config file:_files' \
  '-in[read from stdin]' \
  '-dstar[dry run showing diff]' \
  '-dry[dry run]' \
  '-lint[lint mode]' \
  '-quiet[quiet output]' \
  '-continue-on-error[continue on error]' \
  '-extensions[comma-separated file extensions]:extensions' \
  '-exclude[exclude glob patterns]:pattern' \
  '-gitignore-excludes[use gitignore for excludes]' \
  '-gitignore-path[path to gitignore file]:gitignore file:_files' \
  '-formatter[formatter type]:formatter type' \
  '*:file:_files -g "*.{yaml,yml}"' && ret=0
return ret
