#compdef yamlfmt
# Documentation: https://github.com/google/yamlfmt/blob/main/docs/command-usage.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-help[print command usage information]' \
  '-version[print yamlfmt version]' \
  '-print_conf[print the merged configuration]' \
  '-dry[dry run mode]' \
  '-lint[lint mode (exit 1 on formatting diffs)]' \
  '-in[read input from stdin and write to stdout]' \
  '(-quiet -q)'{-quiet,-q}'[quiet mode (Dry Run / Lint only)]' \
  '(-verbose -v)'{-verbose,-v}'[verbose mode (Format only)]' \
  '-conf[path to a configuration file]:config file:_files' \
  '-global_conf[use the configuration file from the system config directory]' \
  '-no_global_conf[disable looking up the system config directory]' \
  '-dstar[enable doublestar path collection mode]' \
  '-match_type[control how include/exclude patterns are interpreted]:match type:' \
  '*-exclude[patterns to exclude]:pattern:' \
  '-gitignore_excludes[use gitignore to exclude paths]' \
  '-gitignore_path[path to gitignore file]:gitignore file:_files' \
  '*-extensions[extensions used in standard path collection]:extensions:' \
  '-kyaml[enable the alternate KYAML formatter]' \
  '-formatter[provide configuration values for the formatter]:formatter config:' \
  '*-debug[enable debug logging]:scope:(paths config diffs all)' \
  '-output_format[output format]:format:' \
  '*:file:_files -g "*.(yaml|yml)"' && ret=0
return ret
