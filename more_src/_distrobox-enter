#compdef distrobox-enter

# Zsh completion for distrobox-enter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-n+[container name]:name' \
  '--name=[container name]:name' \
  '-e+[command to run]:command' \
  '--cmd=[command to run]:command' \
  '--no-tty[do not allocate TTY]' \
  '--no-workdir[do not change working directory]' \
  '-a+[additional flags for podman/docker exec]:flags' \
  '--additional-flags=[additional flags for podman/docker exec]:flags' \
  '-d[dry run]' \
  '--dry-run[dry run]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '1:container name' \
  '*:command arguments' && ret=0

return ret
