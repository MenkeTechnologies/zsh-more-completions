#compdef qcshadergen
# Documentation: https://doc.qt.io/qt-6/qtquick-tooling-qcshadergen.html
# Reference accessed: 2026-05-20
# Verified: matches `qcshadergen --help` output on this system.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including generic Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  {-o+,--output=}'[output file]:file:_files' \
  '*:Vulkan GLSL source file:_files -g "*.(vert|frag)"' && ret=0

return ret
