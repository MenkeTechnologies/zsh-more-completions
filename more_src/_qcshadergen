#compdef qcshadergen
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including generic Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  {-o+,--output=}'[output file]:file:_files' \
  '*:Vulkan GLSL source file:_files -g "*.(vert|frag)"' && ret=0

return ret
