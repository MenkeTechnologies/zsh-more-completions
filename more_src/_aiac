#compdef aiac

# Zsh completion for aiac - Artificial Intelligence Infrastructure-as-Code Generator

local curcontext="$curcontext" state line ret=1

_aiac_commands() {
  local -a commands=(
    'get:generate code for the provided prompt'
    'list-models:list supported models'
    'help:help about any command'
    'version:print version'
  )
  _describe -t commands 'aiac command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '--no-config[ignore config file]' \
  '1: :_aiac_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      get)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-b --backend)'{-b,--backend}'[backend to use]:backend:(openai bedrock ollama)' \
          '(-f --full)'{-f,--full}'[print the full response (including explanations)]' \
          '(-q --quiet)'{-q,--quiet}'[do not print anything but the generated code]' \
          '(-s --save)'{-s,--save}'[save code to file]:file:_files' \
          '--readme[generate a README.md]' \
          '--model[specify model name]:model' \
          '--session[session ID]:session' \
          '*:prompt' && ret=0
        ;;
      list-models)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-b --backend)'{-b,--backend}'[backend to use]:backend:(openai bedrock ollama)' && ret=0
        ;;
    esac
    ;;
esac

return ret
