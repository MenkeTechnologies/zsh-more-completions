#compdef typst-watch
# _typst-watch — Typst typesetting system watch subcommand alias (Typst team, Rust); clap-rs
# upstream: https://github.com/typst/typst

_typst-watch() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--root=+[project root]:dir:_files -/' \
        '--font-path=+[font path]:list:_files -/' \
        '--input=+[input string key=value]:list:' \
        '--diagnostic-format=+[diagnostic format]:fmt:(human short json)' \
        '--features=+[features]:list:' \
        '--make-deps=+[deps file]:file:_files' \
        '--ppi=+[PPI for PNG export]:f:' \
        '--format=+[output format]:fmt:(pdf png svg html)' \
        '-f+[output format]:fmt:(pdf png svg html)' \
        '--open[open after compile]' \
        '--package-cache-path=+[package cache path]:dir:_files -/' \
        '--package-path=+[package path]:dir:_files -/' \
        '--no-package-resolve[no package resolve]' \
        '--pdf-standard=+[PDF standard]:list:(1.7 a-2b a-3b)' \
        '--creation-timestamp=+[creation timestamp]:str:' \
        '--ignore-system-fonts[ignore system fonts]' \
        '--timings=+[output timings file]:file:_files' \
        '--export-timings=+[export timings file]:file:_files' \
        '*:input-output:_files -g "*.typ"'
}

_typst-watch "$@"
