#compdef dgsh-readval
# Documentation: https://www.spinellis.gr/sw/dgsh/dgsh-readval.html
# dgsh-readval - directed graph shell value store reader (Unix-domain socket)

local ret=1

_arguments -s -S \
  '-s+[Unix-domain socket path for store communication]:path:_files' \
  '(-c -e -l)-c[read the current (rather than last) value, blocks if none]' \
  '(-c -e -l)-e[read current or empty value instead of blocking]' \
  '(-c -e -l)-l[read the last value from the store (default)]' \
  '-n[do not retry a failed connection to the store]' \
  '-q[ask the write store to terminate; no value retrieved]' \
  '-x[do not engage in dgsh negotiation protocol]' && ret=0

return ret
