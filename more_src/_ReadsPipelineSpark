#compdef ReadsPipelineSpark
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/spark/pipelines/ReadsPipelineSpark.java
# Runs BWA, MarkDuplicates, BQSR, and HaplotypeCaller on reads to generate a VCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-I,--input}'=[BAM/SAM/CRAM read file]:bam:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '(-O --output)'{-O,--output}'=[the output vcf]:output:_files' \
  '--output-bam=[the output bam]:bam:_files' \
  '--align[perform alignment using BWA-MEM]' \
  '*--known-sites=[the known variants]:vcf:_files' \
  '--strict[use the strict implementation matching the walker version]' \
  '*'{-L,--intervals}'=[genomic intervals to operate over]:intervals:' \
  '--spark-master=[URL of the Spark master to submit jobs to]:url:' \
  '--num-reducers=[number of reducers for Spark]:n:' \
  '*--conf=[Spark property name=value]:conf:' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam:_files' && ret=0

return ret
