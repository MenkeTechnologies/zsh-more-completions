#compdef mstconfig mlxconfig
# Documentation: https://github.com/Mellanox/mstflint/blob/master/man/mstconfig.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# mstconfig (a.k.a. mlxconfig): configure Mellanox device firmware options
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'query:query current and next-boot config'
  'set:set parameters'
  'reset:reset to defaults'
  'apply:apply config without reboot'
  'show:show parameters'
  'clear_semaphore:clear flash semaphore'
  'create_conf:create config file'
  'backup:backup current config'
  'restore:restore from backup'
  'gen_tlvs_dump:dump TLVs'
  'set_raw:set raw TLV'
  'get_raw:get raw TLV'
  'force_lazy[set with lazy]:'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-d[device specification (PCI/SF)]:dev:' \
  '--dev=[device specification (PCI/SF)]:dev:' \
  '-f[force, no prompt]' \
  '--force[force, no prompt]' \
  '-i[input file (config)]:file:_files' \
  '-x[hex output]' \
  '-y[answer yes]' \
  '--yes[answer yes]' \
  '--enable_verbosity[enable verbose printout]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mstconfig command' commands && ret=0 ;;
esac
return ret
