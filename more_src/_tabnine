#compdef tabnine
# _tabnine — TabNine tabnine AI code-completion CLI for the TabNine local and cloud-hosted code-completion engine across multiple editor integrations with team/private model support (codota tabnine team, Rust); clap
# upstream: https://www.tabnine.com/

_tabnine() {
    local -a sub=(
        'login:login to account'
        'logout:logout'
        'config:print config'
        'configure:configure settings'
        'status:show status'
        'whoami:show user'
        'restart:restart server'
        'upgrade:upgrade'
        'cache-clear:clear cache'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--no-cache[no cache]' \
        '--no-update[no auto update]' \
        '--log-file=+[file]:file:_files' \
        '--log-level=+[level]:l:(error warn info debug trace)' \
        '--cloud-host=+[host]:h:_hosts' \
        '--team=+[team]:str:' \
        '--proxy=+[url]:str:' \
        '--no-proxy[no proxy]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tabnine subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_tabnine "$@"
