#compdef pyquil pyquil-cli rigetti
# _pyquil — Rigetti Computing pyQuil Python library for writing executing and simulating quantum programs in Quil (rigetti team, Python); argparse
# upstream: https://github.com/rigetti/pyquil

_pyquil() {
    local -a sub=(
        'compile:compile a Quil program'
        'run:run a Quil program'
        'simulate:simulate on QVM'
        'rewrite:rewrite arithmetic'
        'qubits:get qubit info'
        'devices:list QPUs'
        'experiment:run an experiment'
        'tomography:run tomography'
        'rb:run randomized benchmarking'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--qvm-host=+[QVM host]:host:_hosts' \
        '--qvm-port=+[QVM port]:port:_ports' \
        '--quilc-host=+[quilc host]:host:_hosts' \
        '--quilc-port=+[quilc port]:port:_ports' \
        '--qpu-id=+[QPU id]:str:' \
        '--lattice-id=+[lattice id]:str:' \
        '--device=+[device]:str:' \
        '--shots=+[shots]:n:' \
        '-s+[shots]:n:' \
        '--seed=+[seed]:n:' \
        '--noise[enable noise]' \
        '--readout-noise=+[F]:f:' \
        '--gate-noise=+[F]:f:' \
        '--qcs-settings=+[settings file]:file:_files' \
        '--qcs-secrets=+[secrets file]:file:_files' \
        '--engagement-manager=+[manager url]:url:_urls' \
        '--gateway-url=+[gateway url]:url:_urls' \
        '--measurement-noise-probabilities=+[probs]:str:' \
        '--protoquil[protoquil mode]' \
        '--rewrite-arithmetic=+[bool]:b:(true false)' \
        '--no-progress-bar[no progress bar]' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pyquil subcommand' sub ;;
        args)
            case $words[1] in
                compile|run|simulate) _arguments \
                    '*:quil file:_files -g "*.quil *.py"' ;;
                experiment) _arguments \
                    '--method=+[method]:m:(symmetrization parametric)' \
                    '--symmetrization=+[mode]:m:(SYMMETRIZE_OUTPUTS OUTPUT_BIAS NONE)' \
                    '*:experiment file:_files' ;;
                rb) _arguments \
                    '--num-clifford=+[N]:n:' \
                    '--seqs-per-length=+[N]:n:' \
                    '--measurements-per-seq=+[N]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_pyquil "$@"
