#compdef testkube
# Documentation: https://docs.testkube.io/cli/testkube
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'create:Create resources'
      'delete:Delete resources'
      'get:Get resources'
      'run:Run test workflows or re-run executions'
      'watch:Watch test workflows'
      'cancel:Cancel executions'
      'status:Show status of feature or resource'
      'update:Update resource'
      'set:Set resources'
      'init:Initialize Testkube profiles'
      'install:Install components'
      'upgrade:Upgrade Helm chart and run migrations'
      'purge:Uninstall Testkube'
      'migrate:Migrate resources'
      'dashboard:Open Testkube dashboard'
      'login:Login to Testkube Pro'
      'config:Set feature configuration'
      'enable:Enable features'
      'disable:Disable features'
      'download:Manage artifacts'
      'generate:Generate resources'
      'debug:Print debugging info'
      'version:Show version info'
      'completion:Generate shell autocompletion'
      'pro:Testkube Pro operations'
      'agent:Agent-related commands'
      'marketplace:Browse and install workflows'
      'diagnostics:Diagnose issues'
      'docker:Docker operations'
      'mcp:AI assistant integration'
      'help:Help about any command'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (create)
        local -a subcmds=(
          'agent:Create an agent'
          'runner:Create a runner'
          'testworkflow:Create a test workflow'
          'testworkflowtemplate:Create a test workflow template'
          'ticket:Create a ticket'
          'webhook:Create a webhook'
          'webhooktemplate:Create a webhook template'
        )
        _arguments -C '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        [[ $state == subcmd ]] && _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
      (get)
        local -a subcmds=(
          'agent:Get agent details'
          'artifact:Get execution artifacts'
          'context:Get context'
          'testworkflow:Get test workflow'
          'testworkflowexecution:Get test workflow execution'
          'testworkflowtemplate:Get test workflow template'
          'webhook:Get webhook'
          'webhooktemplate:Get webhook template'
        )
        _arguments -C '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        [[ $state == subcmd ]] && _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
      (run)
        local -a subcmds=(
          'testworkflow:Run a test workflow'
          'testworkflowexecution:Re-run a test workflow execution'
        )
        _arguments -C '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        [[ $state == subcmd ]] && _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
      (delete)
        local -a subcmds=(
          'agent:Delete an agent'
          'crd:Delete CRD resources'
          'testworkflow:Delete a test workflow'
          'testworkflowtemplate:Delete a test workflow template'
          'webhook:Delete a webhook'
          'webhooktemplate:Delete a webhook template'
        )
        _arguments -C '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        [[ $state == subcmd ]] && _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
