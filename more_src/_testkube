#compdef testkube
# Documentation: https://man.archlinux.org/search?q=testkube
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'create:Create a resource'
      'delete:Delete a resource'
      'get:Get a resource'
      'run:Run tests or test suites'
      'abort:Abort test execution'
      'watch:Watch test execution'
      'status:Show testkube status'
      'dashboard:Open dashboard'
      'init:Install Testkube'
      'upgrade:Upgrade Testkube'
      'purge:Uninstall Testkube'
      'generate:Generate resources'
      'config:Set or get config values'
      'login:Login to Testkube Cloud'
      'set:Set resources'
      'disable:Disable features'
      'enable:Enable features'
      'download:Download artifacts'
      'debug:Debug Testkube'
      'pro:Testkube Pro commands'
      'version:Show version'
      'completion:Generate shell completion'
      'help:Help about any command'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (create)
        local -a subcmds=(
          'test:Create a test'
          'testsuite:Create a test suite'
          'executor:Create an executor'
          'webhook:Create a webhook'
          'testworkflow:Create a test workflow'
          'template:Create a template'
        )
        _arguments -C '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        [[ $state == subcmd ]] && _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
      (get)
        local -a subcmds=(
          'test:Get test details'
          'tests:Get all tests'
          'testsuite:Get test suite details'
          'testsuites:Get all test suites'
          'execution:Get execution details'
          'executions:Get all executions'
          'executor:Get executor details'
          'executors:Get all executors'
          'webhook:Get webhook details'
          'webhooks:Get all webhooks'
          'artifact:Get execution artifacts'
          'testworkflow:Get test workflow'
          'testworkflows:Get all test workflows'
        )
        _arguments -C '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        [[ $state == subcmd ]] && _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
      (run)
        local -a subcmds=(
          'test:Run a test'
          'testsuite:Run a test suite'
          'testworkflow:Run a test workflow'
        )
        _arguments -C '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        [[ $state == subcmd ]] && _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
      (delete)
        local -a subcmds=(
          'test:Delete a test'
          'testsuite:Delete a test suite'
          'executor:Delete an executor'
          'webhook:Delete a webhook'
          'testworkflow:Delete a test workflow'
        )
        _arguments -C '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        [[ $state == subcmd ]] && _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
