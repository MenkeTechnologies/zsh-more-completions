#compdef mod_wsgi-express

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start-server:start WSGI server'
  'install-module:install mod_wsgi module'
  'module-config:show module config'
  'module-location:show module location'
  'setup-server:write config files'
  'start-service:start daemon service'
  'tools:misc tools'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mod_wsgi-express command' commands && ret=0 ;;
  (args)
    _arguments \
      '--port=+[port]:port:' \
      '--host=+[host]:host:_hosts' \
      '--user=+[user]:user:_users' \
      '--group=+[group]:group:_groups' \
      '--working-directory=+[working dir]:dir:_files -/' \
      '--server-root=+[server root]:dir:_files -/' \
      '--document-root=+[document root]:dir:_files -/' \
      '--url-alias=+[url alias]:alias:' \
      '--application-type=+[app type]:type:(module script paste object dispatcher static)' \
      '--processes=+[processes]:n:' \
      '--threads=+[threads]:n:' \
      '--log-to-terminal[log to terminal]' \
      '--log-level=+[log level]:lvl:(debug info notice warn error crit alert emerg)' \
      '--error-log-name=+[error log name]:name:' \
      '--access-log-name=+[access log name]:name:' \
      '--ssl-certificate-file=+[ssl cert]:file:_files' \
      '--ssl-certificate-key-file=+[ssl key]:file:_files' \
      '*:script:_files' && ret=0
    ;;
esac

return ret
