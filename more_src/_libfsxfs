#compdef fsxfsinfo fsxfsmount
# _libfsxfs — libfsxfs tools (libyal SGI/Linux XFS parser; fsxfsinfo dumps XFS metadata + per-AG superblocks, fsxfsmount FUSE-mounts an XFS image read-only; -h help, -V version, -v verbose, -o image offset, -B bytes-per-sector, -E inode filter, -F path filter, -X exclusive; positional argument is the XFS image)
# upstream: https://github.com/libyal/libfsxfs
# Flags from libyal/libfsxfs fsxfstools/fsxfsinfo.c on tip.

_libfsxfs() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-B+[bytes per sector]:bytes:' \
        '-E+[inode filter]:inode:' \
        '-F+[path filter]:path:' \
        '-X[exclusive lock]' \
        '*:XFS image:_files'
}

_libfsxfs "$@"
