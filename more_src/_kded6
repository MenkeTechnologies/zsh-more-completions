#compdef kded6
# Documentation: https://manpages.debian.org/unstable/kded6/kded6.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian unstable kded6(8) manpage. Daemon otherwise driven by D-Bus.

# kded6: KDE Frameworks 6 daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '--check[check sycoca database, update if needed, then exit]' && ret=0
return ret
