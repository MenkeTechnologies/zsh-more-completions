#compdef kded6
# Documentation: https://github.com/KDE/kded/blob/master/src/kded.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (QCommandLineParser defs).

# kded6: KDE Frameworks 6 daemon (otherwise driven by D-Bus)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--check[check cache validity]' \
  '--replace[replace an existing instance]' && ret=0
return ret
