#compdef RepeatScout
# Documentation: https://github.com/Dfam-consortium/RepeatScout/blob/main/build_repeat_families.c
# RepeatScout: de-novo identification of repeat families from a genome

local ret=1

_arguments -s \
  '-sequence[input fasta sequence file]:file:_files' \
  '-output[output fasta file of repeat families]:file:_files' \
  '-freq[l-mer frequency table from build_lmer_table]:file:_files' \
  '-l[length of l-mer (default: auto)]:length:' \
  '-ranges[output ranges file]:file:_files' \
  '-L[size of region to extend left or right (default 10000)]:size:' \
  '-match[reward for a match (default 1)]:match:' \
  '-mismatch[penalty for a mismatch (default -1)]:mismatch:' \
  '-gap[penalty for a gap (default -5)]:gap:' \
  '-maxgap[maximum gap length (default 5)]:maxgap:' \
  '-maxoccurrences[cap on l-mer occurrences (default 10000)]:n:' \
  '-maxrepeats[maximum number of repeats (default 100000)]:n:' \
  '-cappenalty[penalty for lowercase letters (default -20)]:penalty:' \
  '-minimprovement[min score improvement to extend (default 3)]:n:' \
  '-stopafter[stop adding to family after no improvement (default 100)]:n:' \
  '-maxentropy[maximum entropy of a region (default -0.7)]:entropy:' \
  '-goodlength[min repeat length to output (default 50)]:length:' \
  '-tandemdist[tandem distance window (default 500)]:dist:' \
  '-minthresh[smallest number of required l-mers (default 3)]:n:' \
  '-v[verbose]' \
  '-vv[more verbose]' \
  '-vvv[even more verbose]' \
  '-vvvv[most verbose]' && ret=0

return ret
