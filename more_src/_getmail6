#compdef getmail getmail6 getmails getmail_fetch getmail-mbox-maildir-converter

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-g+,--getmaildir=}'[getmail dir]:dir:_files -/' \
  '*'{-r+,--rcfile=}'[rc file]:file:_files' \
  '(-l --list-mboxes)'{-l,--list-mboxes}'[list configured]' \
  '(-i --idle)'{-i+,--idle=}'[idle on folder]:folder:' \
  '(-q --quit)'{-q,--quit}'[quit on lock errors]' \
  '(-d --delete)'{-d,--delete}'[delete after retrieve]' \
  '(-D --no-delete)'{-D,--no-delete}'[do not delete]' \
  '(-a --all)'{-a,--all}'[retrieve all messages]' \
  '(-n --new)'{-n,--new}'[only retrieve new]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-s --quiet)'{-s,--quiet}'[quiet]' \
  '(-t --trace)'{-t,--trace}'[trace]' \
  '*'{-m+,--message-log=}'[message log file]:file:_files' \
  '*'{-L+,--logfile=}'[log file]:file:_files' \
  '(--message-log-syslog)--message-log-syslog[message log to syslog]' \
  '(--message-log-verbose)--message-log-verbose[verbose message log]' \
  '(--dump)--dump[dump configuration]' \
  '*: :_files' && ret=0

return ret
