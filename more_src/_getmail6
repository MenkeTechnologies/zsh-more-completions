# Flags taken from getmail6 ./getmail OptionParser (optparse) definitions.

local ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-g --getmaildir)'{-g+,--getmaildir=}'[look in DIR for config/data files]:dir:_files -/' \
  '*'{-r+,--rcfile=}'[load config from FILE]:file:_files' \
  '--dump[dump configuration and exit]' \
  '--trace[print extended trace info]' \
  '(-i --idle)'{-i+,--idle=}'[idle on FOLDER (single IMAP rc only)]:folder:' \
  '--store-password-in-gnome-keyring[store password in Gnome keyring]' \
  '--store-password-in-keyring[store password via Python keyring]' \
  '*'{-s+,--searchset=}'[rfc3501 searchstring (repeatable)]:search:' \
  '*'{-v,--verbose}'[verbose (repeatable)]' \
  '--fingerprint[show server fingerprint]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-d --delete)'{-d,--delete}'[delete after retrieval]' \
  '(-l --dont-delete)'{-l,--dont-delete}'[do not delete]' \
  '(-a --all)'{-a,--all}'[retrieve all messages]' \
  '(-n --new)'{-n,--new}'[retrieve only new]' \
  '--to-oldmail-on-each-mail[write oldmail per message]' \
  '--only-oldmail-file[only update oldmail file]' \
  '(-m --mark-read)'{-m,--mark-read}'[mark messages read on server]' \
  '*'{-o+,--only-account=}'[only process username]:username:' \
  '*: :_files' && ret=0

return ret
