#compdef gotestyourself
# _gotestyourself — gotest.tools meta package alias (Daniel Nephin); umbrella for gotestsum + assert/cmd/icmd packages
# upstream: https://github.com/gotestyourself/gotest.tools

_gotestyourself() {
    local -a sub=(
        'gotestsum:run gotestsum'
        'env:print env diagnostics'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gotestyourself subcommand' sub ;;
    esac
}

_gotestyourself "$@"
