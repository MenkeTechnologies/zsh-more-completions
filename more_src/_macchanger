#compdef macchanger
# _macchanger — Alvaro Lopez Ortega macchanger (view/change a NIC's MAC address; -s show current, -e keep vendor, -a random vendor, -A random fully, -r fully random, -p reset to permanent, -l list vendors, -m XX:XX:XX:XX:XX:XX set explicit MAC; -b BIA bit forced 0)
# upstream: https://github.com/alobbs/macchanger
# Flags from macchanger src/main.c on tip.

_macchanger() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-s[show current MAC]' \
        '--show[show current MAC]' \
        '-e[keep vendor bytes]' \
        '--ending[keep vendor bytes]' \
        '-a[random known vendor]' \
        '--another[random known vendor]' \
        '-A[random vendor (any)]' \
        '-p[reset to permanent (factory)]' \
        '--permanent[reset to permanent]' \
        '-r[fully random]' \
        '--random[fully random]' \
        '-l[list known vendors]' \
        '--list[list known vendors]' \
        '-b[treat MAC as burned-in (BIA bit 0)]' \
        '-m+[explicit MAC]:mac:' \
        '--mac+[explicit MAC]:mac:' \
        '1:interface:_net_interfaces'
}

_macchanger "$@"
