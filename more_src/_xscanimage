#compdef xscanimage
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/xscanimage.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org search URL.

# xscanimage: GTK frontend for scanimage / SANE
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show short summary of options]' \
  '(-V --version)'{-V,--version}'[show version number]' \
  '--display=[X11 display]:display:' \
  '--no-xshm[do not use shared memory images]' \
  '--sync[synchronous X11 connection]' \
  '*:device:' && ret=0
return ret
