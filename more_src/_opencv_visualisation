#compdef opencv_visualisation
# Documentation: https://github.com/opencv/opencv/blob/master/apps/visualisation/opencv_visualisation.cpp
# opencv_visualisation — visualise stages and features of a trained cascade

local ret=1

_arguments -s -S \
  '(-h --help -usage -?)'{-h,--help}'[show help message]' \
  '(-i --image)'{-i,--image}'=[path to reference image]:file:_files' \
  '(-m --model)'{-m,--model}'=[path to cascade XML file]:file:_files -g "*.xml"' \
  '(-d --data)'{-d,--data}'=[path to video output folder]:dir:_files -/' \
  '--ext=[output video file extension (avi, mp4)]:ext' \
  '--fourcc=[output video codec 4-char code (XVID, H264)]:fourcc' \
  '--fps=[output video frames-per-second]:fps' && ret=0

return ret
