#compdef git-hist
# Documentation: https://github.com/arkark/git-hist
# Source: arkark/git-hist — Rust TUI for browsing per-file Git history.
# Reference accessed: 2026-06-01
# Also invokable as `git hist <file>`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--date-format=[strftime date format]:format:_default' \
    '--date-of=[which timestamp to display]:role:(author committer)' \
    '--name-of=[which name to display]:role:(author committer)' \
    '--emphasize-diff[highlight changed portions of the diff]' \
    '--full-hash[show complete commit hashes]' \
    '--tab-size=[tab width in spaces (default 4)]:n:_default' \
    '--beyond-last-line[allow scrolling past the final content line]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:file:_files' \
    && ret=0

return ret
