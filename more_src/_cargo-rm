#compdef cargo-rm
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-remove.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for cargo-rm (now `cargo remove`, originally cargo-edit).
# cargo-edit's `cargo rm` was upstreamed into Cargo as `cargo remove` in
# Rust 1.66 (2022); flags below match the upstream cargo-remove docs.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '--dry-run[Do not actually write the manifest]' \
  '--manifest-path=[Path to Cargo.toml]:file:_files' \
  '-p+[Package to modify]:package' \
  '--package=[Package to modify]:package' \
  '-q[Do not print cargo log messages]' \
  '--quiet[Do not print cargo log messages]' \
  '*-v[Use verbose output (stackable)]' \
  '*--verbose[Use verbose output (stackable)]' \
  '--color=[Coloring]:when:(auto always never)' \
  '--frozen[Require Cargo.lock and cache are up to date]' \
  '--locked[Require Cargo.lock is up to date]' \
  '--offline[Run without accessing the network]' \
  '--dev[Remove as development dependency]' \
  '--build[Remove as build dependency]' \
  '--target=[Remove as dependency from the given target platform]:target' \
  '*:crate' && ret=0

return ret
