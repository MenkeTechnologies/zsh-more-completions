#compdef projen

# Zsh completion for Projen CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'new:Create a new projen project'
      'upgrade:Upgrade projen to the latest version'
    )
    _describe -t commands 'projen command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      new)
        _arguments -s -S \
          '--from=[create project from external module]:module' \
          '--no-post[skip post-synthesis steps]' \
          '--synth[synthesize after creation]' \
          '--no-synth[do not synthesize after creation]' \
          '--comments[include comments in .projenrc]' \
          '--no-comments[exclude comments from .projenrc]' \
          '-h[show help]' \
          '--help[show help]' \
          '1:project type' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
