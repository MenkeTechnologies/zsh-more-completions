#compdef anope services
# _anope — IRC services daemon (anope/anope)
# upstream: https://github.com/anope/anope
# Flags from src/init.cpp (custom argv handling).

_anope() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.conf"' \
        '--confdir=[config file directory]:dir:_files -/' \
        '--dbdir=[database directory]:dir:_files -/' \
        '(-d --debug)'{-d+,--debug=}'[debug level]:level:' \
        '--localedir=[locale directory]:dir:_files -/' \
        '--logdir=[log directory]:dir:_files -/' \
        '--modulesdir=[module directory]:dir:_files -/' \
        '(-e --noexpire)'{-e,--noexpire}'[disable expiry]' \
        '(-n --nofork)'{-n,--nofork}'[stay in foreground]' \
        '--nothird[disable third-party modules]' \
        '--protocoldebug[enable protocol-level debug]' \
        '(-r --readonly)'{-r,--readonly}'[read-only mode]' \
        '(-s --support)'{-s,--support}'[print support info]'
}

_anope "$@"
