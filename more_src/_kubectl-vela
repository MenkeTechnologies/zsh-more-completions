#compdef kubectl-vela
# Documentation: https://kubevela.io/docs/cli/vela/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context]:context:' \
  '1:subcommand:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'init:create application scaffolding'
      'up:deploy applications'
      'status:show application status'
      'ls:list applications'
      'delete:remove applications'
      'env:manage environments'
      'show:display reference documentation'
      'addon:manage extensions'
      'dry-run:dry-run application locally'
      'live-diff:compare application versions'
      'logs:view application logs'
      'port-forward:forward network connections'
      'exec:execute commands in containers'
      'revision:manage application revisions'
      'debug:debug running applications'
      'policy:manage policy definitions'
      'workflow:control deployment workflows'
      'adopt:import existing resources'
      'uischema:configure UI schemas'
      'component:manage component types'
      'trait:manage trait types'
      'def:manage custom definitions'
      'install:install KubeVela'
      'uninstall:uninstall KubeVela'
      'system:system operations'
      'version:show version'
    )
    _describe -t commands 'kubectl-vela command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
