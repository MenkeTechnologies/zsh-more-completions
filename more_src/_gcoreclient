#compdef gcoreclient
# Documentation: https://github.com/G-Core/gcorelabscloud-go
# G-Core Labs Cloud (GCloud) command line tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--api-url=[GCloud API URL]:url:' \
  '--auth-url=[authentication URL]:url:' \
  '--username=[account username]:username:' \
  '--password=[account password]:password:' \
  '--region=[region]:region:' \
  '--project=[project]:project:' \
  '--client-type=[client type]:type:' \
  '--api-version=[API version]:version:' \
  '--debug[activate debug mode]' \
  '*:command:(network instance volume loadbalancer keypair flavor subnet securitygroup floatingip snapshot image region project task heat cluster pool l7policy router fixed_ip port keystone quota limit)' && ret=0

return ret
