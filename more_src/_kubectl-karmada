#compdef kubectl-karmada
# Documentation: https://karmada.io/docs/reference/karmadactl/karmadactl-commands/karmadactl/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; subcommands cross-checked
# against karmada-io/karmada pkg/karmadactl/karmadactl.go.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'explain:get documentation for a resource'
      'get:display one or many resources from member clusters'
      'create:create a resource from a file or stdin'
      'delete:delete resources'
      'edit:edit a resource on the server'
      'init:install the Karmada control plane'
      'deinit:remove the Karmada control plane'
      'addons:enable or disable Karmada addons'
      'join:join a cluster to the Karmada control plane'
      'unjoin:remove a cluster from the Karmada control plane'
      'token:manage bootstrap tokens'
      'register:register a cluster to the Karmada control plane (pull mode)'
      'unregister:unregister a pull-mode cluster'
      'cordon:mark a cluster as unschedulable'
      'uncordon:mark a cluster as schedulable'
      'taint:update the taints on a cluster'
      'attach:attach to a running container'
      'logs:print container logs from a member cluster'
      'exec:execute a command in a container'
      'describe:show details of a resource'
      'interpret:validate/test resource interpreter customizations'
      'apply:apply a configuration and propagate it to member clusters'
      'promote:promote legacy resources into the Karmada control plane'
      'top:display resource (CPU/memory) usage of member clusters'
      'patch:update fields of a resource'
      'label:update the labels on a resource'
      'annotate:update the annotations on a resource'
      'completion:generate shell completion'
      'apiresources:print supported API resources'
      'api-versions:print supported API versions'
      'version:print version'
      'options:list global command-line options'
    )
    _describe -t commands 'kubectl-karmada command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
