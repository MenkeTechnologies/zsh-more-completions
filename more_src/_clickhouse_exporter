#compdef clickhouse_exporter
# _clickhouse_exporter — ClickHouse metrics for Prometheus (ClickHouse/clickhouse_exporter)
# upstream: https://github.com/ClickHouse/clickhouse_exporter
# Flags from clickhouse_exporter.go (flag).

_clickhouse_exporter() {
    _arguments \
        '(- *)-h[show help]' \
        '-telemetry.address=[bind address for metrics]:addr:' \
        '-telemetry.endpoint=[metrics URL path]:path:' \
        '-scrape_uri=[ClickHouse HTTP endpoint URI]:url:' \
        '-clickhouse_only[expose only ClickHouse metrics]' \
        '-insecure[ignore server certificate over HTTPS]:bool:(true false)'
}

_clickhouse_exporter "$@"
