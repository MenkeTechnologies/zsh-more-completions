#compdef homesick

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'clone:clone a git repository as a castle'
  'link:symlink castle files into home directory'
  'unlink:remove symlinks for a castle'
  'list:list cloned castles'
  'track:track a file in a castle'
  'commit:commit changes in a castle'
  'push:push castle changes to remote'
  'pull:pull castle changes from remote'
  'diff:show uncommitted changes in a castle'
  'show_path:show the path of a castle'
  'status:show status of a castle'
  'destroy:delete a castle'
  'cd:open a new shell in the castle directory'
  'open:open castle directory in file manager'
  'exec:execute a command in the castle directory'
  'exec_all:execute a command in all castle directories'
  'rc:run the RC file for a castle'
  'generate:create a new castle'
  'help:show help for a command'
  'version:show version'
)

_arguments -s -S \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-s --skip)'{-s,--skip}'[skip files that already exist]' \
  '(-f --force)'{-f,--force}'[overwrite files that already exist]' \
  '(-p --pretend)'{-p,--pretend}'[run but do not make any changes]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      clone)
        _arguments '1:repository URL or name' && ret=0
        ;;
      link|unlink|track|commit|push|pull|diff|show_path|status|destroy|cd|open|rc|exec)
        local -a castles
        castles=(${(f)"$(homesick list 2>/dev/null | sed 's/^[[:space:]]*//')"})
        _describe -t castles 'castle' castles && ret=0
        ;;
      generate)
        _arguments '1:castle name' && ret=0
        ;;
      help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
