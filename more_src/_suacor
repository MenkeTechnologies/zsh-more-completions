#compdef suacor
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/convolution_correlation/suacor.c
# SUACOR - auto-correlation

local ret=1

_arguments -s -S \
  'ntout=[odd number of time samples output]:n:' \
  'norm=[if non-zero normalize max abs output to 1]:n:(0 1)' \
  'sym=[if non-zero produce a symmetric output]:s:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
