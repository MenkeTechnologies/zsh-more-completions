#compdef xrdgsiproxy
# Documentation: https://man.archlinux.org/search?q=xrdgsiproxy
# Reference accessed: 2026-05-16

# xrdgsiproxy: manage GSI proxy certificate
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'init:create a new proxy'
  'info:show proxy info'
  'destroy:destroy proxy'
  'help:show help'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-cert[user cert]:file:_files' \
  '-key[user key]:file:_files' \
  '-out[proxy output]:file:_files' \
  '-valid[validity HH\:MM]:duration:' \
  '-path-length[max delegation depth]:n:' \
  '-bits[RSA key size]:bits:(512 1024 2048 4096)' \
  '-debug[debug]' \
  '-rfc[RFC 3820 compliant]' \
  '-f[file with proxy]:file:_files' \
  '-noregen[do not regenerate key]' \
  '-vo[VO name]:vo:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'xrdgsiproxy command' commands && ret=0 ;;
esac
return ret
