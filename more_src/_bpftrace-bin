#compdef bpftrace
# _bpftrace-bin — bpftrace high-level eBPF tracing language (iovisor); awk-like one-liner DSL for Linux eBPF
# upstream: https://github.com/bpftrace/bpftrace

_bpftrace-bin() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-l+[list probes matching glob]:glob:' \
        '-p+[PID to trace]:pid:_pids' \
        '-c+[command to execute]:cmd:_command_names -e' \
        '-d[debug parser]' \
        '-dd[debug AST]' \
        '-e+[program text]:script:' \
        '-o+[output file]:file:_files' \
        '-q[quiet]' \
        '-v[verbose]' \
        '-I+[include path]:dir:_files -/' \
        '--include+[header file]:file:_files' \
        '--unsafe[allow unsafe operations]' \
        '-B+[output buffer mode]:mode:(none line full)' \
        '-f+[output format]:fmt:(text json)' \
        '-k[kill child on exit]' \
        '-kk[force kill child]' \
        '--btf+[BTF file]:file:_files' \
        '--info[print runtime info]' \
        '--no-warnings[suppress warnings]' \
        '--usdt-file-activation[activate USDT by binary path]' \
        '*:script:_files -g "*.bt"'
}

_bpftrace-bin "$@"
