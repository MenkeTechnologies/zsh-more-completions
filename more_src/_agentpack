'--repo=[Path to the agentpack config repo (default\: \$AGENTPACK_HOME/repo)]:REPO:_files' \
'--profile=[Profile name (default\: "default")]:PROFILE:_default' \
'--target=[Target name\: codex|claude_code|cursor|vscode|jetbrains|zed|all (default\: "all")]:TARGET:_default' \
'--machine=[Machine id for machine overlays (default\: auto-detect)]:MACHINE:_default' \
'--json[Machine-readable JSON output]' \
'--yes[Skip confirmations (dangerous with --apply)]' \
'--dry-run[Force dry-run behavior (do not apply even if --apply is set)]' \
'-h[Print help]' \
'--help[Print help]' \
":: :_agentpack_commands" \
"*::: :->agentpack" \
&& ret=0
    case $state in
    (agentpack)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:agentpack-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'--repo=[Path to the agentpack config repo (default\: \$AGENTPACK_HOME/repo)]:REPO:_files' \
'--profile=[Profile name (default\: "default")]:PROFILE:_default' \
