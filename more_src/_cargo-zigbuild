#compdef cargo-zigbuild

local -a subcommands
subcommands=(
  'build:Compile a Cargo package with zig as linker'
  'check:Check a package for errors'
  'clippy:Run clippy with zig linker'
  'doc:Build documentation'
  'fix:Fix lint warnings'
  'run:Run a binary with zig-compiled output'
  'test:Run tests'
  'bench:Run benchmarks'
  'help:Show help'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      build|check|clippy|doc|fix|run|test|bench)
        _arguments \
          '(-p --package)'{-p,--package}'[Package to build]:package:' \
          '--workspace[Build all workspace members]' \
          '--all[Alias for --workspace]' \
          '--exclude=[Exclude packages]:package:' \
          '--release[Build in release mode]' \
          '--profile=[Build profile]:profile:' \
          '--features=[Features to enable]:features:' \
          '--all-features[Enable all features]' \
          '--no-default-features[Disable default features]' \
          '--target=[Target triple with optional glibc version]:target:' \
          '--manifest-path=[Path to Cargo.toml]:file:_files' \
          '--target-dir=[Target directory]:dir:_directories' \
          '(-j --jobs)'{-j,--jobs}'[Number of parallel jobs]:jobs:' \
          '--lib[Build only library]' \
          '--bin=[Build only specified binary]:binary:' \
          '--bins[Build all binaries]' \
          '--example=[Build only specified example]:example:' \
          '--examples[Build all examples]' \
          '--test=[Build only specified test]:test:' \
          '--tests[Build all tests]' \
          '--bench=[Build only specified benchmark]:bench:' \
          '--benches[Build all benchmarks]' \
          '--all-targets[Build all targets]' \
          '*:extra args:'
        ;;
    esac
    ;;
esac
