#compdef multica
# Documentation: https://multica.ai/docs/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  issue:issue
  project:project
  label:label
  agent:agent
  squad:squad
  autopilot:autopilot
  workspace:workspace
  repo:repository
  skill:skill
  daemon:daemon
  runtime:runtime
  auth:authentication
  login:login
  setup:setup
  attachment:attachment
  config:configuration
  update:update
  version:version
)

_arguments -C \
  '--server-url=[Multica server URL]:url:' \
  '--workspace-id=[workspace id]:id:' \
  '--profile=[configuration profile]:profile:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'multica command' commands && ret=0 ;;
  (args) _default && ret=0 ;;
esac

return ret
