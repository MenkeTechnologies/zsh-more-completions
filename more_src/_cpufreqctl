#compdef cpufreqctl cpufreqctl.auto-cpufreq
# _cpufreqctl — auto-cpufreq cpufreqctl Linux CPU frequency control CLI (AdnanHodzic, Python); argparse
# upstream: https://github.com/AdnanHodzic/auto-cpufreq

_cpufreqctl() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--governor[show governor]' \
        '--list-governors[list available governors]' \
        '--frequency[show current frequency]' \
        '--frequency-min[show min frequency]' \
        '--frequency-max[show max frequency]' \
        '--frequency-min-limit[show min frequency limit]' \
        '--frequency-max-limit[show max frequency limit]' \
        '--frequency-set=+[set frequency]:str:' \
        '--frequency-min-set=+[set min frequency]:str:' \
        '--frequency-max-set=+[set max frequency]:str:' \
        '--epp[show EPP]' \
        '--epb[show EPB]' \
        '--epp-set=+[set EPP]:str:(performance balance_performance balance_power power default)' \
        '--epb-set=+[set EPB]:str:' \
        '--policy=+[set policy]:str:(powersave performance ondemand conservative schedutil userspace)' \
        '--turbo[show turbo state]' \
        '--turbo-set=+[set turbo state]:n:(0 1)' \
        '--scaling-governor=+[set scaling governor]:g:(powersave performance ondemand conservative schedutil userspace)' \
        '--info[show info]' \
        '--info-x[show extra info]' \
        '--monitor[monitor]' \
        '--cpu=+[cpu id]:n:' \
        '*:arg:'
}

_cpufreqctl "$@"
