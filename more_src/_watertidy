#compdef watertidy
# Documentation: https://www.ccp4.ac.uk/html/watertidy.html
# CCP4 watertidy: tidy water molecules; logical-file keywords on command line

local ret=1

_arguments -s -S \
  '*:keyword or file:->kw' && ret=0

if [[ $state == kw ]]; then
  _alternative \
    'keywords:logical file:(XYZIN DISTOUT XYZOUT)' \
    'files:file:_files' && ret=0
fi

return ret
