#compdef LearnReadOrientationModel
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/readorientation/LearnReadOrientationModel.java
# GATK4: learn the prior probability of read orientation artifacts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-I,--input}'[.tar.gz containing outputs of CollectF1R2Counts]:file:_files -g "*.tar.gz"' \
  '(-O --output)'{-O,--output}'[tar.gz of artifact prior tables]:file:_files' \
  '--num-em-iterations[give up on EM after this many iterations]:n:' \
  '--convergence-threshold[stop EM when parameter distance falls below this]:val:' \
  '*:options:_files' && ret=0

return ret
