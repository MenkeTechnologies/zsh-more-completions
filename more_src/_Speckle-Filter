#compdef Speckle-Filter
# Documentation: https://github.com/senbox-org/s1tbx/blob/master/s1tbx-op-sar-processing/src/main/java/org/esa/s1tbx/sar/gpf/filtering/SpeckleFilterOp.java
# ESA SNAP gpt Speckle-Filter operator - spatial speckle reduction filters for SAR

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-PsourceBandNames=-[the list of source bands]:bands' \
  '-Pfilter=-[speckle reduction filter]:filter:(None Boxcar Median Frost Gamma\ Map Lee Refined\ Lee Lee\ Sigma IDAN)' \
  '-PfilterSizeX=-[the kernel x dimension]:size' \
  '-PfilterSizeY=-[the kernel y dimension]:size' \
  '-PdampingFactor=-[damping factor (Frost filter only)]:factor' \
  '-PestimateENL=-[estimate equivalent number of looks]:bool:(true false)' \
  '-Penl=-[the number of looks]:enl' \
  '-PnumLooksStr=-[number of looks]:looks:(1 2 3 4)' \
  '-PwindowSize=-[window size]:size:(5x5 7x7 9x9 11x11 13x13 15x15 17x17)' \
  '-PtargetWindowSizeStr=-[point target window size]:size:(3x3 5x5)' \
  '-PsigmaStr=-[sigma]:sigma:(0.5 0.6 0.7 0.8 0.9)' \
  '-PanSize=-[the adaptive neighbourhood size]:size' \
  '*:source product:_files' && ret=0

return ret
