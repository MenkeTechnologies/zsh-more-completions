#compdef xbindkeys
# Documentation: https://man.archlinux.org/man/xbindkeys.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help (with version and author info)]' \
  '(-d --defaults)'{-d,--defaults}'[print default rc file]' \
  '(-dg --defaults-guile)'{-dg,--defaults-guile}'[print default guile config file]' \
  '(-f --file)'{-f,--file}'+[alternative rc file]:file:_files' \
  '(-fg --file-guile)'{-fg,--file-guile}'+[alternative guile config file]:file:_files -g "*.scm"' \
  '(-X --display)'{-X,--display}'+[X display]:display:' \
  '(-g --geometry)'{-g,--geometry}'+[geometry for -k/-mk window]:geom:' \
  '(-k --key)'{-k,--key}'[identify single key pressed]' \
  '(-mk --multikey)'{-mk,--multikey}'[identify multi-key sequence]' \
  '(-n --nodaemon)'{-n,--nodaemon}'[do not run as background daemon]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' && ret=0

return ret
