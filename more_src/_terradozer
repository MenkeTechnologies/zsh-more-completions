#compdef terradozer
# Documentation: https://github.com/jckuester/terradozer
# terradozer: destroy AWS resources tracked in a Terraform state file

local ret=1

_arguments -s -S \
  '(-version)-version[show application version]' \
  '(-debug)-debug[enable debug logging]' \
  '(-dry-run)-dry-run[show what would be destroyed]' \
  '(-force)-force[destroy without asking for confirmation]' \
  '-timeout=[amount of time to wait for a destroy of a resource to finish]:duration:' \
  '-parallel=[limit the number of concurrent destroy operations]:count:' \
  '*:tfstate:_files -g "*.tfstate"' && ret=0

return ret
