#compdef present

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '-base[base path for slide assets]:path:_files -/' \
  '-content[base path for slide content]:path:_files -/' \
  '-http[HTTP listen address]:address:' \
  '-notes[enable presenter notes]' \
  '-orighost[host to use for .play playground]:host:' \
  '-play[enable playground]' \
  '-use_resolve[use resolution for mapping import paths]' \
  '*:slide file:_files -g "*.slide"' && ret=0

return ret
