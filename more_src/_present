#compdef present
# Documentation: https://pkg.go.dev/golang.org/x/tools/cmd/present
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '-base=[base path for slide template and static resources]:path:_files -/' \
  '-content=[base path for slide content]:path:_files -/' \
  '-http=[HTTP service address]:address:' \
  '-notes[enable presenter notes]' \
  '-orighost=[host component of web origin URL]:host:' \
  '-play[enable playground (permit execution of arbitrary user code)]' \
  '-use_pkgsite[use pkg.go.dev for documentation links]' \
  '*:slide file:_files -g "*.(slide|article)"' && ret=0

return ret
