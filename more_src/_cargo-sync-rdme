#compdef cargo-sync-rdme
# Documentation: https://github.com/gifnksm/cargo-sync-rdme
# Source: https://github.com/gifnksm/cargo-sync-rdme/blob/main/src/cli/args.rs
# Reference accessed: 2026-06-02
# Cargo subcommand; invoke as `cargo sync-rdme` or `cargo-sync-rdme`. Requires nightly rustdoc.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '*'{-v,--verbose}'[more output per occurrence]' \
    '(-q --quiet)'{-q,--quiet}'[less output per occurrence]' \
    '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
    '--workspace[sync READMEs for all packages in the workspace]' \
    '(-p --package)'{-p+,--package=}'[package to sync README]:spec:_default' \
    '(-F --features)'{-F+,--features=}'[features to activate]:features:_default' \
    '--all-features[activate all available features]' \
    '--no-default-features[do not activate the default feature]' \
    '--toolchain=[toolchain name for cargo rustdoc]:toolchain:(stable nightly)' \
    '--check[check if READMEs are synced]' \
    '--no-vcs[sync even if no VCS detected]' \
    '--allow-dirty[sync even if target is dirty]' \
    '--allow-staged[sync even if target has staged changes]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
