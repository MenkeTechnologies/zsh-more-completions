#compdef nad_eed_3d
# Documentation: https://bio3d.colorado.edu/imod/doc/man/nad_eed_3d.html
# nad_eed_3d - edge-enhancing nonlinear anisotropic diffusion of 3D volumes

local ret=1

_arguments -s -S \
  '-k[K value (lambda); ratio of local gradients]:value' \
  '-n[number of iterations]:value' \
  '-i[list of iterations at which to write output]:list' \
  '-e[extension to put after the iteration number]:ext' \
  '-o[single slice to output (numbered from 1)]:value' \
  '-m[mode for output file (0 byte, 1 integer, 2 real, 6 ushort)]:value' \
  '-s[sigma value for smoothing the structure tensor]:value' \
  '-t[time step]:value' \
  '-F[set output file format]:format:(MRC TIFF HDF)' \
  '-f[use faster but less accurate eigenvector routine]' \
  '-P[print process ID to standard error]' \
  '*:file:_files' && ret=0

return ret
