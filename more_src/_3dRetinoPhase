#compdef 3dRetinoPhase
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dRetinoPhase.html
# Compute retinotopy phase from FMRI time series

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-exp[expanding rings stimulus]:dataset:_files' \
  '-con[contracting rings stimulus]:dataset:_files' \
  '-clw[clockwise polar angle mapping stimulus]:dataset:_files' \
  '-ccw[counterclockwise polar angle mapping stimulus]:dataset:_files' \
  '-prefix[output dataset prefix]:prefix:' \
  '-spectra[output amplitude and phase spectra datasets]' \
  '-Tstim[stimulus period in seconds for full cycle]:T:' \
  '-Tpol[stimulus period for polar stimuli]:tpol:' \
  '-Tecc[stimulus period for eccentricity stimuli]:tecc:' \
  '-nrings[number of rings in stimulus]:Nr:' \
  '-nwedges[number of wedges in stimulus]:Nw:' \
  '-ort_adjust[account for DOF lost in detrending]:n:' \
  '-pre_stim[blank period (s) before stimulus began]:pre:' \
  '-sum_adjust[adjust sum of angles for wrapping]:yn:(y n)' \
  '-phase_estimate[phase estimation method]:meth:(FFT DELAY)' \
  '-ref_ts[reference time series for DELAY method]:file:_files' \
  '-multi_ref_ts[multiple reference time series]:file:_files' \
  '*:dataset:_files' && ret=0

return ret
