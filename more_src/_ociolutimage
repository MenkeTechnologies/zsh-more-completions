#compdef ociolutimage
# Documentation: https://opencolorio.readthedocs.io/
# generate or extract a LUT from an RGB lattice image

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--generate[generate an identity lattice image]' \
  '--extract[extract LUT data from a modified RGB lattice image]' \
  '*:file:_files' && ret=0

return ret
