#compdef auditbeat-cli auditbeat
# _auditbeat-cli — Elastic Beats auditbeat-cli CLI command-line frontend to the Auditbeat lightweight shipper collecting Linux audit framework auditd events file integrity monitoring FIM filesystem checks system module package process socket user shipping to Elasticsearch Logstash Kafka for security audit trail (Elastic team, Go); cobra
# upstream: https://www.elastic.co/beats/auditbeat

_auditbeat-cli() {
    local -a sub=(
        'run:run beat'
        'test:test config or output'
        'export:export config templates dashboards'
        'keystore:keystore management'
        'modules:module enable/disable/list'
        'setup:setup index templates dashboards'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[selectors]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml"' \
        '--c=+[config file]:file:_files -g "*.yml *.yaml"' \
        '-e[log to stderr]' \
        '--path.config=+[dir]:dir:_files -/' \
        '--path.data=+[dir]:dir:_files -/' \
        '--path.home=+[dir]:dir:_files -/' \
        '--path.logs=+[dir]:dir:_files -/' \
        '-E+[k=v]:str:' \
        '-M+[module setting]:str:' \
        '--strict.perms=+[bool]:s:(true false)' \
        '-N[do not publish events]' \
        '--once[publish once and exit]' \
        '--memprofile=+[file]:file:_files' \
        '--httpprof=+[host:port]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'auditbeat-cli subcommand' sub ;;
        args)
            case $words[1] in
                modules) _arguments '1:op:(enable disable list)' '*:module:' ;;
                setup) _arguments '1:op:(index-management dashboards pipelines)' ;;
            esac
            ;;
    esac
}

_auditbeat-cli "$@"
