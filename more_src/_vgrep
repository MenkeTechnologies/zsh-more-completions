#compdef vgrep

_vgrep() {
    _arguments \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '(-s --show)'{-s,--show}'=[show specific results]:command' \
        '(-n --no-header)'{-n,--no-header}'[do not print header]' \
        '(-N --no-less)'{-N,--no-less}'[do not use less as pager]' \
        '--no-git[do not use git grep]' \
        '--no-ripgrep[do not use ripgrep]' \
        '(-j --json)'{-j,--json}'[output as JSON]' \
        '*:pattern-or-file:_files'
}

_vgrep "$@"
