#compdef quota-warn warnquota

# warnquota: send mail to users over their disk quota
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-V[show version]' \
  '-F[storage format]:fmt:(vfsold vfsv0 vfsv1 rpc xfs)' \
  '-d[debug mode (no mail sent)]' \
  '-u[warn users]' \
  '-g[warn groups]' \
  '-i[skip insulating filesystems]' \
  '-c[warnquota config file]:file:_files' \
  '-s[mail subject line]:subject:' \
  '-q[charge user/group quota file]:file:_files' \
  '-a[admins file]:file:_files' \
  '*::warnquota args:_files' && ret=0
return ret
