#compdef genromfs
# Generate a romfs filesystem image

local ret=1

_arguments -s -S \
  '-f[output image file]:image file:_files' \
  '-d[source directory]:directory:_files -/' \
  '-v[verbose mode]' \
  '-V[set volume name]:name:' \
  '-a[align data to specified boundary]:alignment:' \
  '-A[set alignment and offset]:alignment,offset:' \
  '-x[exclude pattern]:pattern:' \
  '-h[show help]' && ret=0

return ret
