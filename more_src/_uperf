#compdef uperf
# Documentation: https://uperf.org/manual.html
# uperf - unified network performance tool

local ret=1

_arguments -s -S \
  '(-h)-h[print usage]' \
  '-m[run uperf with this profile]:profile:_files' \
  '-s[slave (passive) mode]' \
  '-S[protocol type for the control socket]:protocol:(tcp ssl)' \
  '-n[do not collect statistics]' \
  '-T[print thread statistics]' \
  '-t[print transaction averages]' \
  '-f[print flowop averages]' \
  '-g[print group statistics]' \
  '-k[collect kstat statistics]' \
  '-p[collect CPU utilization for flowops]' \
  '-e[collect default CPU counters for flowops]' \
  '-E[collect CPU counters for flowops]:counters' \
  '-a[collect all statistics]' \
  '-X[collect response times to file]:file:_files' \
  '-i[collect throughput every interval]:interval' \
  '-P[set the master port]:port' \
  '-R[emit raw time-stamped statistics]' \
  '-v[verbose output]' \
  '-V[display version information]' \
  '*::arg:_files' && ret=0

return ret
