#compdef mkinitcpio
# Documentation: https://man.archlinux.org/man/mkinitcpio.8
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mkinitcpio (Arch Linux initramfs generator)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-A --addhooks)'{-A,--addhooks}'[add hooks]:hooks' \
  '(-c --config)'{-c,--config}'[config file]:config:_files' \
  '(-d --generatedir)'{-d,--generatedir}'[set basedir for generation]:directory:_files -/' \
  '(-D --hookdir)'{-D,--hookdir}'[set hook directory]:directory:_files -/' \
  '(-I --include)'{-I,--include}'[include configuration]:config:_files' \
  '(-g --generate)'{-g,--generate}'[generate initramfs image]:output file:_files' \
  '(-H --hookhelp)'{-H,--hookhelp}'[show help for a hook]:hook' \
  '(-k --kernel)'{-k,--kernel}'[kernel version]:kernel version' \
  '(-L --listhooks)'{-L,--listhooks}'[list available hooks]' \
  '(-M --automods)'{-M,--automods}'[display modules found via autodetection]' \
  '(-n --nocolor)'{-n,--nocolor}'[disable color output]' \
  '(-P --allpresets)'{-P,--allpresets}'[process all presets in /etc/mkinitcpio.d]' \
  '(-p --preset)'{-p,--preset}'[build from preset]:preset' \
  '(-R --remove)'{-R,--remove}'[remove existing image]' \
  '(-r --moduleroot)'{-r,--moduleroot}'[module root directory]:directory:_files -/' \
  '(-S --skiphooks)'{-S,--skiphooks}'[skip hooks]:hooks' \
  '(-s --save)'{-s,--save}'[save build directory]' \
  '(-t --builddir)'{-t,--builddir}'[temporary build directory]:directory:_files -/' \
  '(-U --uki)'{-U,--uki}'[generate UKI image]:output file:_files' \
  '--cmdline=[kernel cmdline file]:file:_files' \
  '--no-cmdline[do not embed cmdline in UKI]' \
  '--splash=[splash bitmap for UKI]:file:_files' \
  '--uefistub=[UEFI stub for UKI]:file:_files' \
  '--ukiconfig=[ukify configuration]:file:_files' \
  '--no-ukify[do not call ukify]' \
  '--kernelimage=[kernel image for UKI]:file:_files' \
  '--osrelease=[os-release for UKI]:file:_files' \
  '--nopost[do not run post-build hooks]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-z --compress)'{-z,--compress}'[compression program]:program:(cat gzip bzip2 lz4 lzop xz zstd)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
