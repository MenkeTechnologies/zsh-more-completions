#compdef most

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-1[display only one window]' \
  '-b[startup in binary mode]' \
  '-C[disable color support]' \
  '-d[do not display the \~ lines]' \
  '-k[specify keybinding file]:keybinding file:_files' \
  '-s[squeeze consecutive blank lines]' \
  '-t[display tabs as highlighted characters]' \
  '-u[disable UTF-8 mode]' \
  '-v[display control characters as caret sequences]' \
  '-w[wrap long lines]' \
  '-z[disable gunzip-on-the-fly]' \
  '+*[start at specified line number]:line number' \
  '*:file:_files' && ret=0

return ret
