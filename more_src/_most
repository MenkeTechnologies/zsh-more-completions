#compdef most
# Documentation: https://github.com/jedsoft/most/blob/master/doc/most.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# most: paging program. Flags from upstream doc/most.1 OPTIONS section.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-1[VT100 mode (VMS only)]' \
  '-b[binary mode (16 bytes/line hex)]' \
  '-C[disable color support]' \
  '-c[make searches case-sensitive]' \
  '-d[omit backslash mark for wrapped lines]' \
  '-F[startup in follow-mode]' \
  '-M[disable use of mmap]' \
  '-r[default to regexp searches]' \
  '-s[squeeze-mode: collapse blank lines]' \
  '-t-[display tabs as ^I; -tN sets tab width]:tab width' \
  '-u[disable UTF-8 mode]' \
  '+u[force UTF-8 mode]' \
  '-v[display control characters (e.g. ^A)]' \
  '-w[wrap lines]' \
  '-z[disable gunzip-on-the-fly]' \
  '+/-[start at first line containing string]:string' \
  '+-[start at specified line number]:lineno' \
  '+d[allow file deletion via :D]' \
  '+s[secure mode: no edit/cd/shell/extra files]' \
  '*:file:_files' && ret=0

return ret
