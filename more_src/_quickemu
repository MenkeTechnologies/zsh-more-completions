#compdef quickemu

# Zsh completion for quickemu - quickly create and run virtual machines

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--vm=[specify VM configuration file]:config file:_files -g "*.conf"' \
  '--braille[enable braille support]' \
  '--delete-disk[delete the disk image]' \
  '--delete-vm[delete the VM and its disk image]' \
  '--display=[set display backend]:display:(sdl gtk spice spice-app none)' \
  '--fullscreen[start VM in fullscreen mode]' \
  '--ignore-msrs-always[configure KVM to always ignore unhandled MSRs]' \
  '--kill[kill the running VM process]' \
  '--screen=[use specified monitor for output]:monitor index' \
  '--screenpct=[percentage of screen to use]:percent' \
  '--shortcut[create a desktop shortcut]' \
  '--snapshot[create or manage VM snapshots]:action:(apply create delete info)' \
  '--snapshot-name=[specify snapshot name]:name' \
  '--status-quo[do not commit any changes to disk]' \
  '--viewer=[specify SPICE viewer]:viewer:(spicy remote-viewer)' \
  '--ssh-port=[set SSH port forwarding]:port' \
  '--extra_args=[pass extra arguments to QEMU]:arguments' \
  '--version[display version information]' \
  '(-h --help)'{-h,--help}'[display help]' && ret=0

return ret
