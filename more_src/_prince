#compdef prince

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-o,--output}'[output PDF file]:file:_files' \
  '--page-size[page size]:size' \
  '--page-margin[page margin]:margin' \
  {-s,--style}'[apply external style sheet]:file:_files' \
  '--media[media type]:media' \
  '--baseurl[base URL for relative URLs]:url' \
  '--fileroot[root directory for absolute filenames]:directory:_directories' \
  '--javascript[enable JavaScript]' \
  '--no-author-style[ignore author style sheets]' \
  '--no-default-style[ignore default style sheets]' \
  '--input[input type]:type:(auto html xml)' \
  '--encrypt[encrypt the PDF output]' \
  '--key-bits[encryption key size]:bits:(40 128)' \
  '--user-password[PDF user password]:password' \
  '--owner-password[PDF owner password]:password' \
  '--disallow-print[disallow printing]' \
  '--disallow-modify[disallow modification]' \
  '--disallow-copy[disallow copying]' \
  '--disallow-annotate[disallow annotations]' \
  '--no-compress[disable compression]' \
  '--no-object-streams[disable PDF object streams]' \
  '--no-embed-fonts[disable font embedding]' \
  '--pdf-profile[PDF profile]:profile:(PDF/A-1b PDF/A-3b PDF/X-1a PDF/X-3 PDF/X-4 PDF/UA-1)' \
  '--tagged-pdf[produce tagged PDF]' \
  '--no-artificial-fonts[disable artificial bold/italic]' \
  '--log[log file]:file:_files' \
  {-v,--verbose}'[verbose output]' \
  '--debug[enable debug mode]' \
  '*:input file:_files' && ret=0

return ret
