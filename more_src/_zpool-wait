#compdef zpool-wait
# _zpool-wait — OpenZFS zpool wait (block until specified background activities finish on a pool; -t selects activity (discard|free|initialize|replace|remove|resilver|scrub|trim|raidz_expand), -H scriptable, -p parsable, -T timestamp; positional pool to monitor)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_wait) on tip.

_zpool-wait() {
    _arguments \
        '-t+[activity]:activity:(discard free initialize replace remove resilver scrub trim raidz_expand)' \
        '-H[scriptable]' \
        '-p[parsable]' \
        '-T+[timestamp format]:format:(u d)' \
        '1:pool:'
}

_zpool-wait "$@"
