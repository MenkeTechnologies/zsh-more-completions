#compdef afpd
# _afpd — Netatalk afpd (Apple Filing Protocol server exposing AFP shares on Linux/BSD; -d debug, -F config file, -G group, -O proctitle, -P pidfile, -U user, -f volume file, -V version, -d log level, -t test config; daemon ordinarily started via launchd / systemd unit / netatalk init script)
# upstream: https://github.com/Netatalk/netatalk
# Flags from Netatalk/netatalk etc/afpd/main.c on tip.

_afpd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d+[debug level]:level:' \
        '-F+[config file]:file:_files' \
        '-G+[run as group]:group:_groups' \
        '-O+[proctitle]:title:' \
        '-P+[pidfile]:file:_files' \
        '-U+[run as user]:user:_users' \
        '-f+[volume file]:file:_files' \
        '-t[test config + exit]' \
        '-n+[netbios name]:name:'
}

_afpd "$@"
