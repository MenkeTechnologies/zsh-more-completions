#compdef typha
# Documentation: https://docs.tigera.io/calico/latest/reference/typha/configuration
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Typha: scaling agent for Calico (datastore fan-out)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config-file=[config file]:file:_files' \
  '*::typha args:_files' && ret=0
return ret
