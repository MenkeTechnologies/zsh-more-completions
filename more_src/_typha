#compdef typha
# Documentation: https://man.archlinux.org/search?q=typha
# Reference accessed: 2026-05-16

# Typha: scaling agent for Calico (datastore fan-out)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config-file=[config file]:file:_files' \
  '*::typha args:_files' && ret=0
return ret
