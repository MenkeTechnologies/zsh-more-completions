#compdef sievec
# _sievec — compile a Sieve script to a binary (or decompile with -d) (dovecot/pigeonhole)
# upstream: https://github.com/dovecot/pigeonhole
# Flags from src/sieve-tools/sievec.c (getopt).

_sievec() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-c+[Dovecot config file]:file:_files'
        '-d[decompile mode: dump existing binary instead of compiling]'
        '-D[enable Sieve debug output]'
        '*-P+[load this Sieve plugin]:plugin:'
        '-x+[extra Sieve extensions to enable]:extensions:'
        '1:script file:_files -g "*.sieve"'
        '2:output file:_files'
    )
    _arguments -s $args
}

_sievec "$@"
