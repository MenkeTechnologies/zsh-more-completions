#compdef dh_strip
# Documentation: https://manpages.debian.org/dh_strip
# Source: Debian/debhelper dh_strip — strip executables/shared libraries and create dbgsym packages (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '*-X+[exclude pattern]:pattern:_default' \
    '--name=-[debhelper file suffix]:name:_default' \
    '--no-act[do not act]' \
    '(-k --keep-debug --keep)'{-k,--keep-debug,--keep}'[keep debug symbols]' \
    '--dbgsym-migration=-[dbgsym migration package]:pkg:_default' \
    '(--no-automatic-dbgsym)--automatic-dbgsym[auto-generate dbgsym packages]' \
    '--no-automatic-dbgsym[disable automatic dbgsym]' \
    '--ddeb-migration=-[deprecated ddeb migration]:pkg:_default' \
    '*-O+[passthrough option]:opt:_default' \
    && ret=0

return ret
