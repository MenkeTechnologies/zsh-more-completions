#compdef multirender_test

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '--driver+[SDL renderer driver name]:driver:(software opengl opengles2 metal direct3d direct3d11 direct3d12 vulkan)' \
  '--info+[print SDL info]:type:(all version video render audio events power timer)' \
  '--video+[video driver]:driver:' \
  '--audio+[audio driver]:driver:' \
  '--logical-size+[logical resolution]:wxh:' \
  '--scale+[content scale]:scale:' \
  '--no-vsync[disable VSync]' \
  '--vsync[enable VSync]' \
  '--accel[hardware accelerated]' \
  '--noaccel[software rendering]' \
  '--fullscreen[fullscreen]' \
  '--windows+[number of windows]:n:' \
  '--title+[window title]:title:' \
  '--hidden[hidden window]' \
  '--center[center window]' \
  '*:image file:_files' && ret=0

return ret
