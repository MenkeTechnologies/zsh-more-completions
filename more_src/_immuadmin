#compdef immuadmin
# _immuadmin — immudb admin CLI (manage databases, users, permissions, backups, server config of an immudb instance)
# upstream: https://github.com/codenotary/immudb
# Persistent flags from cmd/immuadmin/command/init.go on tip; subcommands from cmd/immuadmin/command/{database,user,login,backup,hot_backup,serverconfig,stats}.go.

_immuadmin() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-p --immudb-port)'{-p+,--immudb-port=}'[immudb port]:port:' \
        '(-a --immudb-address)'{-a+,--immudb-address=}'[immudb host]:host:_hosts' \
        '--config=[config file (default immuadmin.toml)]:file:_files' \
        '--tokenfile=[admin session token file]:file:_files' \
        '(-m --mtls)'{-m,--mtls}'[enable mutual TLS]' \
        '--servername=[mTLS server name for cert verification]:name:' \
        '--certificate=[server cert file path]:file:_files' \
        '--pkey=[server private key file path]:file:_files' \
        '--clientcas=[client CA cert list path]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'login:authenticate as a sysadmin/admin user'
                'logout:invalidate the current admin token'
                'status:show server status'
                'stats:show server stats'
                'user:user/permission management (subcommands: list create changepassword activate deactivate permission)'
                'database:database management (subcommands: list create load unload delete update use flush compact truncate export import)'
                'dump:dump a database to a file'
                'backup:cold backup (subcommands accept --dbdir/--manual-stop-start/--uncompressed)'
                'restore:cold restore from a snapshot path'
                'hot-backup:hot-backup a database while online'
                'hot-restore:hot-restore a database while online'
                'set:set server config key (auth|mtls value)'
                'version:show version'
                'man:emit man pages'
                'help:show help'
            )
            _describe -t commands 'immuadmin command' subs
            ;;
        args)
            case $line[1] in
                user)
                    _arguments '1: :->ucmd'
                    case $state in
                        ucmd) _describe -t commands 'user subcommand' '(list create changepassword activate deactivate permission)' ;;
                    esac
                    ;;
                database)
                    _arguments '1: :->dcmd'
                    case $state in
                        dcmd) _describe -t commands 'database subcommand' '(list create load unload delete update use flush compact truncate export import)' ;;
                    esac
                    ;;
                backup)
                    _arguments \
                        '--dbdir=[database directory to back up]:dir:_files -/' \
                        '--manual-stop-start[require the user to stop/start immudb around the backup]' \
                        '--uncompressed[do not compress the snapshot tarball]'
                    ;;
                restore)
                    _arguments \
                        '--dbdir=[target database directory]:dir:_files -/' \
                        '--manual-stop-start[require the user to stop/start immudb around the restore]' \
                        '*:snapshot:_files'
                    ;;
            esac
            ;;
    esac
}

_immuadmin "$@"
