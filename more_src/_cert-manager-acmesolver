#compdef cert-manager-acmesolver
# _cert-manager-acmesolver — cert-manager ACME HTTP-01 challenge solver
# upstream: https://github.com/cert-manager/cert-manager
# Flags from cmd/acmesolver/app/app.go on tip.

_cert-manager-acmesolver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--listen-port=[port to listen on]:port:' \
        '--domain=[domain name to verify]:domain:' \
        '--token=[ACME challenge token to verify against]:token:' \
        '--key=[ACME challenge key to respond with]:key:' \
        '-v[klog verbosity level]:n:'
}

_cert-manager-acmesolver "$@"
