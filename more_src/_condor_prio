#compdef condor_prio
# Documentation: https://man.archlinux.org/search?q=condor_prio
# Reference accessed: 2026-05-16

# condor_prio: change priority of Condor jobs
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-name[schedd]:name:' \
  '-pool[pool]:pool:' \
  '-p[new priority]:n:' \
  '+[increase priority by]:n:' \
  '-[decrease priority by]:n:' \
  '*:jobid:' && ret=0
return ret
