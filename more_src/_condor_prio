#compdef condor_prio
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_prio.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_prio: change the priority of HTCondor jobs.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-p[set priority to integer value]:priority:' \
  '-a[change priority of all jobs in the queue]' \
  '-n[change priority of jobs at named schedd]:schedd-name:' \
  '-pool[pool containing the schedd]:pool-name:' \
  '*:jobid:' && ret=0
return ret
