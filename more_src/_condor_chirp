#compdef condor_chirp
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_chirp.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_chirp: send commands to a running HTCondor job.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'fetch:copy RemoteFileName from access point to execute machine'
  'put:copy LocalFileName from execute machine to access point'
  'remove:remove RemoteFileName from access point'
  'get_job_attr:print the named job ClassAd attribute'
  'get_job_attr_delayed:get cached job ClassAd attribute'
  'set_job_attr:set the named job ClassAd attribute'
  'set_job_attr_delayed:set the named job ClassAd attribute without immediate sync'
  'ulog:append Message to the job event log'
  'read:read bytes from a remote file'
  'write:write local file contents to a remote file'
  'rmdir:delete a directory'
  'getdir:list directory contents'
  'whoami:get current user identity'
  'whoareyou:get identity of a remote host'
  'link:create a hard link (or symbolic with -s)'
  'readlink:read symbolic link contents'
  'stat:get metadata for a path'
  'lstat:get metadata without following symlinks'
  'statfs:get file system metadata'
  'access:check access permissions'
  'chmod:change file permissions'
  'chown:change file ownership'
  'lchown:change link ownership'
  'truncate:truncate file to specified length'
  'utime:change access and modification times'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-mode[file opening mode characters (w/a/t/c/x)]:mode:' \
  '-perm[unix-format permissions]:perm:' \
  '-offset[starting position for read/write]:offset:' \
  '-stride[read/write with length and skip pattern]:stride:' \
  '-r[recursive directory deletion]' \
  '-l[detailed metadata listing]' \
  '-s[create a symbolic link instead of hard]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'condor_chirp command' commands && ret=0 ;;
esac
return ret
