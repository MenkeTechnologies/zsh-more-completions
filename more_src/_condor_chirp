#compdef condor_chirp
# Documentation: https://man.archlinux.org/search?q=condor_chirp
# Reference accessed: 2026-05-16

# condor_chirp: send commands to a running Condor job
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'fetch:fetch file'
  'put:put file'
  'remove:remove file'
  'get_job_attr:get job attribute'
  'set_job_attr:set job attribute'
  'get_job_attr_delayed:get job attr (delayed)'
  'set_job_attr_delayed:set job attr (delayed)'
  'ulog:append to user log'
  'getfile:fetch from spool'
  'putfile:put to spool'
  'getdir:list directory'
  'whoami:identity'
  'whoareyou:server identity'
  'link:hard link'
  'rmdir:remove dir'
  'mkdir:make dir'
  'rename:rename file'
  'access:access check'
  'stat:stat file'
  'lstat:lstat file'
  'statfs:statfs file'
  'utime:set time'
  'chmod:chmod'
  'chown:chown'
  'chgrp:chgrp'
  'truncate:truncate file'
  'read:read file range'
  'write:write file range'
  'pread:pread file'
  'pwrite:pwrite file'
  'sread:sparse read'
  'swrite:sparse write'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'condor_chirp command' commands && ret=0 ;;
esac
return ret
