#compdef hstr hh

# Zsh completion for hstr (hh) - shell history suggest box

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--show-configuration[show bash configuration for hstr]' \
  '--show-zsh-configuration[show zsh configuration for hstr]' \
  '--show-bash-configuration[show bash configuration for hstr]' \
  '(-f --favorites)'{-f,--favorites}'[show favorites view]' \
  '(-n --non-interactive)'{-n,--non-interactive}'[print filtered history and exit]' \
  '-k[kill last command from history]' \
  '-s[suggest from history]' \
  '-b[blacklist last command]'
