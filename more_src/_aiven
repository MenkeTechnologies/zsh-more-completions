#compdef aiven
# _aiven — Aiven CLI for managed cloud services
# upstream: https://github.com/aiven/aiven-client

_aiven() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--auth-token=[API authentication token]:token:' \
        '--auth-ca=[CA certificate for server verification]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'account:manage accounts'
                'cloud:manage cloud regions'
                'credits:manage credits'
                'events:view project events'
                'help:show help'
                'mirrormaker:manage MirrorMaker replication'
                'project:manage projects'
                'service:manage services'
                'ticket:manage support tickets'
                'user:manage user accounts'
                'vpc:manage VPCs'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                service)
                    _arguments -C \
                        '1:subcommand:(create delete get list logs restart update connection-info connection-pool-add connection-pool-delete connection-pool-list topic-create topic-delete topic-list types user-create user-delete user-list wait)' \
                        '*:: :->service_args'

                    case $state in
                        service_args)
                            _arguments \
                                '--project=[project name]:project:' \
                                '--format=[output format]:format:(json)' \
                                '*:service name:'
                            ;;
                    esac
                    ;;
                project)
                    _arguments \
                        '1:subcommand:(create delete details list switch update)' \
                        '*:project name:'
                    ;;
                user)
                    _arguments \
                        '1:subcommand:(access-token create info login logout)' \
                        '*:arguments:'
                    ;;
                cloud)
                    _arguments \
                        '1:subcommand:(list)' \
                        '--project=[project name]:project:'
                    ;;
                vpc)
                    _arguments \
                        '1:subcommand:(create delete list peering-connection-create peering-connection-delete peering-connection-list)' \
                        '--project=[project name]:project:'
                    ;;
            esac
            ;;
    esac
}

_aiven "$@"
