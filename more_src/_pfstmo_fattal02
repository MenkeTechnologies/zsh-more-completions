#compdef pfstmo_fattal02
# Documentation: http://pfstools.sourceforge.net/man1/pfstmo_fattal02.1.html
# pfstools: Fattal 2002 gradient domain tone mapping operator

local ret=1

_arguments -s -S \
  '(-a --alpha)'{-a,--alpha}'=[alpha parameter (deprecated)]:val' \
  '(-b --beta)'{-b,--beta}'=[strength of gradient modification (default 0.9)]:val' \
  '(-g --gamma)'{-g,--gamma}'=[luminance gamma adjustment]:val' \
  '(-s --saturation)'{-s,--saturation}'=[color saturation (default 0.8)]:val' \
  '(-n --noise)'{-n,--noise}'=[reduce gradient amplification near 0]:val' \
  '(-d --detail-level)'{-d,--detail-level}'=[detail level for local contrast enhancement]:val' \
  '(-w --white-point)'{-w,--white-point}'=[percent of overexposed pixels (default 0.5)]:val' \
  '(-k --black-point)'{-k,--black-point}'=[percent of underexposed pixels (default 0.1)]:val' \
  '(-m --multigrid)'{-m,--multigrid}'[use the multigrid solver]' \
  '--verbose[print additional information]' \
  '--help[print list of command line options]' && ret=0

return ret
