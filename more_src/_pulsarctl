#compdef pulsarctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'cluster:cluster operations'
  'tenant:tenant operations'
  'namespace:namespace operations'
  'topic:topic operations'
  'subscription:subscription operations'
  'sources:source connector operations'
  'sinks:sink connector operations'
  'functions:Pulsar functions operations'
  'functions-worker:functions worker operations'
  'schemas:schema operations'
  'brokers:broker operations'
  'broker-stats:broker statistics'
  'resource-quotas:resource quota operations'
  'ns-isolation-policy:namespace isolation policy operations'
  'packages:package operations'
  'plugin:plugin operations'
  'token:JWT token utilities'
  'oauth2:OAuth2 utilities'
  'context:manage pulsarctl contexts'
  'ctx:manage pulsarctl contexts'
  'completion:generate shell completion'
  'status:show status'
  'bkctl:BookKeeper control'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --fabulous)'{-C,--fabulous=}'[colorized output]:mode:(true false fabulous)' \
  '(-v --verbose)'{-v,--verbose=}'[log level]:level:(0 1 2 3 4)' \
  '(-s --admin-service-url)'{-s,--admin-service-url=}'[admin service URL]:url:' \
  '--auth-plugin=[authentication plugin]:plugin:' \
  '--auth-params=[auth parameters]:params:' \
  '--tls-allow-insecure[allow insecure TLS]' \
  '--tls-enable-hostname-verification[enable TLS hostname verification]' \
  '--tls-trust-cert-path=[TLS trust cert]:file:_files' \
  '--tls-cert-file=[TLS cert file]:file:_files' \
  '--tls-key-file=[TLS key file]:file:_files' \
  '--token=[bearer token]:token:' \
  '--token-file=[token file]:file:_files' \
  '--bookie-service-url=[bookie service URL]:url:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pulsarctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
      (cluster)
        _values 'cluster action' 'create' 'get' 'list' 'update' 'delete' \
          'list-failure-domains' 'create-failure-domain' 'get-failure-domain' 'delete-failure-domain' && ret=0
        ;;
      (tenant)
        _values 'tenant action' 'create' 'list' 'get' 'update' 'delete' && ret=0
        ;;
      (namespace)
        _values 'namespace action' \
          'list' 'create' 'delete' 'get-policies' 'set-clusters' 'get-clusters' \
          'set-backlog-quota' 'get-backlog-quota' 'set-message-ttl' 'get-message-ttl' \
          'set-retention' 'get-retention' 'unload' 'permissions' 'grant-permission' 'revoke-permission' && ret=0
        ;;
      (topic)
        _values 'topic action' \
          'create' 'list' 'delete' 'get' 'lookup' 'partitioned-stats' 'stats' \
          'create-partitioned-topic' 'delete-partitioned-topic' \
          'create-subscription' 'list-subscriptions' 'unsubscribe' \
          'last-message-id' 'compact' 'compact-status' 'offload' 'offload-status' && ret=0
        ;;
      (sources|sinks)
        _values 'connector action' \
          'create' 'list' 'get' 'update' 'delete' 'start' 'stop' 'restart' 'status' \
          'available-sources' 'available-sinks' 'reload' && ret=0
        ;;
      (functions)
        _values 'functions action' \
          'create' 'list' 'get' 'update' 'delete' 'restart' 'stop' 'start' 'status' \
          'stats' 'trigger' 'put-state' 'query-state' 'upload' 'download' && ret=0
        ;;
      (schemas)
        _values 'schemas action' \
          'get' 'delete' 'upload' 'extract' 'compatibility' 'metadata' 'versions' && ret=0
        ;;
      (token)
        _values 'token action' \
          'create-secret-key' 'create-key-pair' 'create' 'show' 'validate' && ret=0
        ;;
      (context|ctx)
        _values 'context action' \
          'list' 'use' 'current' 'rename' 'delete' 'set' && ret=0
        ;;
      (packages)
        _values 'packages action' \
          'upload' 'download' 'delete' 'list' 'list-versions' 'get-metadata' 'update-metadata' && ret=0
        ;;
    esac
    ;;
esac

return ret
