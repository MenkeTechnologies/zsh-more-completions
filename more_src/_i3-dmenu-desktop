#compdef i3-dmenu-desktop

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--dmenu=[specify the dmenu command to use]:dmenu command:' \
  '--entry-type=[specify the type of entries to display]:entry type:(name generic both command)' \
  '--show-duplicates[show duplicate entries]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version information]' \
  && ret=0

return ret
