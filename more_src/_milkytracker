#compdef milkytracker
# _milkytracker — FastTracker-II-style music tracker (milkytracker/milkytracker)
# upstream: https://github.com/milkytracker/MilkyTracker
# Flags from milkytracker(1) man page.

_milkytracker() {
    _arguments \
        '(- *)-help[show help]' \
        '-headless[run in headless mode (conversion only)]' \
        '-recvelocity[enable velocity recording for MIDI input]' \
        '-verbose[verbose output]' \
        '-bpp[bits per pixel]:bpp:(8 16 24 32)' \
        '-fullscreen[fullscreen mode]' \
        '-nosplash[no splash screen]' \
        '-orientation[display orientation]:orientation:(NORMAL ROTATE90CCW ROTATE90CW)' \
        '-swap[swap red/blue in 24 BPP]' \
        '-multi-track[export each track to a separate WAV file]' \
        '-output[output file (headless mode)]:file:_files' \
        '-resampler[resampler type]:type:' \
        '-sample-rate[sample rate Hz]:rate:(22050 44100 48000 96000)' \
        '-shift[mixer shift value]:shift:' \
        '-volume[mixer volume level]:level:' \
        '*:module file:_files -g "*.{xm,mod,mptm,it,s3m}"'
}

_milkytracker "$@"
