#compdef SPASS spass

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-help[show help]' \
  '-Stdin[read input from stdin]' \
  '-Auto+[auto mode]:n:(0 1)' \
  '-CNFOptSkolem+[CNF skolem]:n:(0 1)' \
  '-CNFRenaming+[CNF renaming]:n:(0 1 2 3 4)' \
  '-CNFStrSkolem+[strong skolem]:n:(0 1)' \
  '-CNFSubSumption+[subsumption]:n:(0 1)' \
  '-DocFile+[doc file]:file:_files' \
  '-DocProof+[print proof]:n:(0 1)' \
  '-Document+[document mode]:n:(0 1 2)' \
  '-FPDFGTrans+[fp transform]:n:(0 1)' \
  '-FullRed+[full reduction]:n:(0 1)' \
  '-IDef+[implicit def]:n:(0 1)' \
  '-IEq+[input eq]:n:(0 1)' \
  '-IEqR+[eq right]:n:(0 1)' \
  '-IEqF+[eq full]:n:(0 1)' \
  '-IFactor+[input factoring]:n:(0 1)' \
  '-IHyper+[hyper]:n:(0 1)' \
  '-IOFactor+[ord factoring]:n:(0 1)' \
  '-IORe+[ord res]:n:(0 1)' \
  '-IOHy+[ord hyper]:n:(0 1)' \
  '-IPara+[paramodulation]:n:(0 1)' \
  '-ISFactor+[s factoring]:n:(0 1)' \
  '-ISpR+[sup right]:n:(0 1)' \
  '-ISpL+[sup left]:n:(0 1)' \
  '-ISpT+[sup top]:n:(0 1)' \
  '-Loops+[loop limit]:n:' \
  '-Memory+[memory MB]:mb:' \
  '-PProblem+[print problem]:n:(0 1)' \
  '-PStatistic+[print stats]:n:(0 1)' \
  '-PGiven+[print given]:n:(0 1)' \
  '-PKept+[print kept]:n:(0 1)' \
  '-RAED+[arith ed]:n:(0 1)' \
  '-RBackContrCNF+[back contr]:n:(0 1)' \
  '-RBackTaut+[back taut]:n:(0 1)' \
  '-RCondRew+[cond rewrite]:n:(0 1)' \
  '-RDescend+[descend]:n:(0 1)' \
  '-Select+[selection func]:n:(0 1 2)' \
  '-Sorts+[sort res]:n:(0 1 2)' \
  '-Splits+[split limit]:n:' \
  '-Sub+[subsumption]:n:(0 1)' \
  '-Sub2+[two-sided subsumption]:n:(0 1)' \
  '-TimeLimit+[time limit s]:s:' \
  '-Verbose+[verbosity]:n:' \
  '*: :_files -g "*.dfg *.tptp *.p"' && ret=0

return ret
