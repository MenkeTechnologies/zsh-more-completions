#
# THE ruler CLI — yargs v18 + @iarna/toml + multi-agent file generation
#
# ruler's CLI is in src/cli/commands.ts.  Uses yargs v18 with
# .command() handlers + .strict() + .demandCommand(1).
#
# Source structure:
#     yargs(hideBin(process.argv))
#         .scriptName('ruler')
#         .usage('$0 <command> [options]')
#         .command<ApplyArgs>('apply', ..., (y) => y.options(...), applyHandler)
#         .command<InitArgs>('init', ..., (y) => y.options(...), initHandler)
#         .command<RevertArgs>('revert', ..., (y) => y.options(...), revertHandler)
#         .demandCommand(1)
#         .help()
#         .strict()
#         .parse();
#
# Subcommands (3):
#
#   apply [options]                    apply rules to all AI agents
#     --project-root DIR               project root directory
#     --agents AGENT_LIST              comma-separated agent IDs
#                                      (cursor / claude / copilot /
#                                      aider / continue / codex /
#                                      cline / roo / windsurf / etc.)
#     --config PATH                    path to ruler.toml config
#     --mcp / --no-mcp                 enable/disable MCP propagation
#                                      (alias: --with-mcp)
#     --mcp-overwrite                  replace native MCP config
#                                      (not merge)
#     --gitignore / --no-gitignore     auto-update .gitignore
#     --gitignore-local                write to .git/info/exclude
#     -v, --verbose                    verbose logging
#     --dry-run                        preview without writing
#     --local-only                     ignore global ~/.ruler
#     --nested                         load nested .ruler dirs
#     --backup / --no-backup           create .bak backups
#     --skills / --no-skills           skills support (experimental)
#     --subagents / --no-subagents     subagents support (experimental)
#
#   init [options]                     scaffold .ruler/ directory
#     --project-root DIR               project root
#     --global                         init in XDG_CONFIG_HOME/ruler
#
#   revert [options]                   undo ruler changes
#     --project-root DIR               project root
#     --agents AGENT_LIST              comma-separated agent IDs
#     --config PATH                    config path
#     --keep-backups                   keep .bak files
#     -v, --verbose                    verbose logging
#     --dry-run                        preview without writing
#     --local-only                     ignore global ~/.ruler
#
# Standard:
#   -h, --help                         show help
#
# @iarna/toml is used in src/config to parse the ruler.toml
# config file's [agents.xxx] sections + per-agent overrides.
#
# Five-axis distinctness from toml-rs (R689) + BurntSushi/
# toml (R690):
#
#   1. JSON-LIKE PARSE/STRINGIFY API — TOML.parse(text) +
#      TOML.stringify(obj); familiar to JS developers.
#
#   2. ASYNC STREAMING PARSE via @iarna/toml/async — uniquely
#      supports event-loop-friendly parsing of large TOML files.
#
#   3. NATIVE Date DATETIMES — TOML datetime types decode to
#      JavaScript Date.
#
#   4. ZERO RUNTIME DEPENDENCIES — pure-JS implementation
#      with no external npm deps in v2+.
#
#   5. REBECCA-TURNER / iarna / npm-INTERNALS ECOSYSTEM
#      PROVENANCE — distinct maintainer; long-time npm Inc.
#      engineer.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/intellectronica/ruler/blob/main/src/cli/commands.ts
# yargs v18 .command() + .option() definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _ruler_cmds _ruler_agents
_ruler_cmds=(
    'apply:apply ruler configurations to supported AI agents'
    'init:scaffold a .ruler directory with default files'
    'revert:revert ruler configurations from supported AI agents'
    'help:show help for a subcommand'
)
_ruler_agents=(
    'cursor:Cursor IDE'
    'claude:Claude Code'
    'copilot:GitHub Copilot'
    'aider:Aider'
    'continue:Continue.dev'
    'codex:Codex CLI'
    'cline:Cline'
    'roo:RooCode'
    'windsurf:Windsurf'
    'zed:Zed Agent Panel'
    'jetbrains:JetBrains AI Assistant'
    'goose:Goose'
    'gemini:Gemini CLI'
    'cody:Sourcegraph Cody'
    'amazonq:Amazon Q'
    'gitlab-duo:GitLab Duo'
    'aria:Aria (Opera)'
    'cursor-tab:Cursor Tab'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'ruler subcommand' _ruler_cmds && ret=0
        ;;
    args)
        case $words[1] in
            apply)
                _arguments \
                    '--project-root=[project root directory]:directory:_files -/' \
                    '--agents=[comma-separated agent IDs]:agents:->agents' \
                    '--config=[path to ruler.toml]:file:_files -g "*.toml"' \
                    '(--mcp --no-mcp --with-mcp)'{--mcp,--with-mcp}'[enable MCP propagation]' \
                    '--no-mcp[disable MCP propagation]' \
                    '--mcp-overwrite[replace native MCP config (not merge)]' \
                    '--gitignore[auto-update .gitignore]' \
                    '--no-gitignore[do not update .gitignore]' \
                    '--gitignore-local[write to .git/info/exclude instead of .gitignore]' \
                    '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
                    '--dry-run[preview without writing files]' \
                    '--local-only[ignore global ~/.ruler config]' \
                    '--nested[load nested .ruler directories]' \
                    '--backup[create .bak backup files]' \
                    '--no-backup[skip .bak backups]' \
                    '--skills[enable skills support (experimental)]' \
                    '--no-skills[disable skills support]' \
                    '--subagents[enable subagents support (experimental)]' \
                    '--no-subagents[disable subagents support]' \
                    && ret=0
                ;;
            init)
                _arguments \
                    '--project-root=[project root directory]:directory:_files -/' \
                    '--global[initialize in XDG_CONFIG_HOME/ruler]' \
                    && ret=0
                ;;
            revert)
                _arguments \
                    '--project-root=[project root directory]:directory:_files -/' \
                    '--agents=[comma-separated agent IDs]:agents:->agents' \
                    '--config=[path to ruler.toml]:file:_files -g "*.toml"' \
                    '--keep-backups[keep .bak backup files after revert]' \
                    '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
                    '--dry-run[preview without writing files]' \
                    '--local-only[ignore global ~/.ruler config]' \
                    && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _ruler_cmds && ret=0
                ;;
        esac
        case $state in
            agents)
                _values -s , 'agent ID' $_ruler_agents && ret=0
                ;;
        esac
        ;;
esac

return ret
