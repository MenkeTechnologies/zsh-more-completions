#compdef fpcalc

# Zsh completion for fpcalc - Chromaprint audio fingerprinting tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-length[max duration of audio to process in seconds]:duration (seconds)' \
  '-raw[output raw fingerprint data]' \
  '-signed[output signed integers in raw fingerprint]' \
  '-json[output in JSON format]' \
  '-text[output in text format]' \
  '-plain[output in plain format]' \
  '-algorithm[fingerprint algorithm to use]:algorithm:(1 2 3 4 5)' \
  '-overlap[overlap audio chunks]' \
  '-ts[output timestamps]' \
  '-chunk[set chunk duration]:chunk duration (seconds)' \
  '-rate[set sample rate]:sample rate (Hz)' \
  '-channels[set number of channels]:number of channels' \
  '*:audio file:_files' \
  && ret=0

return ret
