#compdef 3dAutobox
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dAutobox.html
# Crop an AFNI dataset to the smallest box containing all nonzero voxels

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-prefix[crop input and write output with this prefix]:prefix:' \
  '-input[input dataset]:dataset:_files' \
  '-noclust[skip clustering; preserve all nonzero voxels]' \
  '-extent[write spatial extent of box to stdout]' \
  '-extent_xyz_quiet[output extent values as numbers only]' \
  '-extent_ijk[show six autobox ijk slice boundaries]' \
  '-extent_ijk_to_file[write six ijk boundaries to file]:file:_files' \
  '-extent_ijk_midslice[write 3 ijk midslices to screen]' \
  '-extent_ijkord[output ijk indices in formatted table]' \
  '-extent_ijkord_to_file[write ijkord indices to file]:file:_files' \
  '-extent_xyz_to_file[write six xyz coords to file]:file:_files' \
  '-extent_xyz_midslice[display three xyz midpoint values]' \
  '-npad[number of extra voxels to pad each side]:n:' \
  '-npad_safety_on[constrain padded extents within dataset]' \
  '*:dataset:_files' && ret=0

return ret
