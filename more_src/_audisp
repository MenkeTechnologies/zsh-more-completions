#compdef audispd audisp-remote audisp-syslog audisp-prelude audisp-statsd
# _audisp — Linux audit audispd + dispatcher plugins (audispd reads from auditd over /var/run/audispd_events socket and fans events out to per-plugin processes; -h help, -V version, -f run in foreground, -c config file; plugin-specific binaries (audisp-remote, audisp-syslog, audisp-prelude, audisp-statsd) take similar -c/-v/-V/-h)
# upstream: https://github.com/linux-audit/audit-userspace
# Flags from linux-audit/audit-userspace audisp/audispd.c on tip.

_audisp() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-f[foreground]' \
        '-v[verbose]'
}

_audisp "$@"
