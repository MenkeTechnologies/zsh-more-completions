#compdef syz-check
# _syz-check — check syzkaller syscall descriptions against kernel binaries (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-check/check.go (flag).

_syz-check() {
    _arguments \
        '-os=[target OS]:os:(linux freebsd netbsd openbsd darwin windows fuchsia trusty test)' \
        '-dwarf=[check based on DWARF]:val:(true false)' \
        '-netlink=[check netlink policies]:val:(true false)' \
        '-obj-amd64=[amd64 kernel object file]:file:_files' \
        '-obj-386=[i386 kernel object file]:file:_files' \
        '-obj-arm64=[arm64 kernel object file]:file:_files' \
        '-obj-arm=[arm kernel object file]:file:_files' \
        '-obj-mips64le=[mips64le kernel object file]:file:_files' \
        '-obj-ppc64le=[ppc64le kernel object file]:file:_files' \
        '-obj-riscv64=[riscv64 kernel object file]:file:_files' \
        '-obj-s390x=[s390x kernel object file]:file:_files'
}

_syz-check "$@"
