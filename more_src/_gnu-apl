#compdef gnu-apl apl
# Documentation: https://www.gnu.org/software/apl/
# Documentation: https://ftp.gnu.org/gnu/apl/apl-2.0.tar.gz (src/UserPreferences.cc)
# Reference accessed: 2026-05-27
# Verified: upstream UserPreferences::usage() and parse_args_0/parse_args in apl-2.0/src/UserPreferences.cc

# Zsh completion for GNU APL interpreter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '-d[run in the background as a daemon]' \
  '-f+[read APL input from file]:file:_files' \
  '--id=[use processor ID]:proc:' \
  '-l+[turn logging facility on]:num:' \
  '--cc=[use count cores]:count:' \
  '-C+[chroot to new root before starting (root only)]:dir:_files -/' \
  '--cfg[show ./configure options used and exit]' \
  '--noCIN[do not echo input]' \
  '--CPU_limit_secs=[set CPU time limit in seconds]:sec:' \
  '--echoCIN[echo final input to COUT]' \
  '--rawCIN[do not emit escape sequences]' \
  '--to_COUT[redirect CERR to COUT]' \
  '--tcp_port=[redirect CIN/COUT/CERR to/from TCP port]:port:' \
  '--Color[start with ]XTERM ON]' \
  '--noColor[start with ]XTERM OFF]' \
  '--noCONT[do not )LOAD CONTINUE or SETUP workspace on startup]' \
  '--emacs[run in classical emacs mode]' \
  '--emacs_arg=[run in emacs mode with argument]:arg:' \
  '--eval=[evaluate APL line and exit]:expr:' \
  '--gpl[show license (GPL) and exit]' \
  '--huge[memory management]' \
  '-L+[)LOAD workspace name (not SETUP/CONTINUE) on startup]:wsname:' \
  '--LX=[execute APL expression first]:expr:' \
  '--OFF[automatically )OFF after last input file]' \
  '-p+[use profile N in preferences files]:N:' \
  '--par=[use processor parent ID]:proc:' \
  '--PW=[initial value of ]⎕PW]:value:' \
  '(-q --silent)'{-q,--silent}'[do not print the welcome banner]' \
  '(-s --script)'{-s,--script}'[shortcut for --silent --noCIN --noCONT --noColor]' \
  '--safe[safe mode (no shared vars, no native functions)]' \
  '--show_bin_dir[show binary directory and exit]' \
  '--show_doc_dir[show documentation directory and exit]' \
  '--show_etc_dir[show system configuration directory and exit]' \
  '--show_lib_dir[show library directory and exit]' \
  '--show_src_dir[show source directory and exit]' \
  '--show_all_dirs[show all directories and exit]' \
  '--SV[start APnnn (shared variable server)]' \
  '--noSV[do not start APnnn]' \
  '-T+[run testcase files]:*:file:_files' \
  '--TM=[test mode]:mode:((0\:"exit after last testcase" 1\:"exit after last testcase if no error" 2\:"continue after last testcase" 3\:"stop testcases after first error" 4\:"exit after first error"))' \
  '--TR[randomize order of testfiles]' \
  '--TS[append to (rather than override) summary.log]' \
  '-u+[run as user UID (root only)]:uid:' \
  '(-v --version)'{-v,--version}'[show version information and exit]' \
  '-w+[wait milliseconds at startup]:milli:' \
  '*:script:_files' && ret=0

return ret
