#compdef ypmatch
# _ypmatch — OpenBSD ypmatch (look up one or more keys in a YP map (or nickname); -k prefixes each key, -t skips nickname translation, -x lists nicknames)
# upstream: https://github.com/openbsd/src (usr.bin/ypmatch)
# Flags from usr.bin/ypmatch/ypmatch.1 on tip.

_ypmatch() {
    _arguments \
        '-k[print map key before value]' \
        '-t[skip nickname translation]' \
        '-d+[domain]:domain:' \
        '-x[list nickname translations]' \
        '*:key/mapname:(passwd group hosts services networks protocols rpc netgroup aliases)'
}

_ypmatch "$@"
