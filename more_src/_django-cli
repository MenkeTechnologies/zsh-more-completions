#compdef django-cli manage-py manage
# _django-cli — Django manage.py / django-admin command runner CLI alias (Django Software Foundation, Python); custom argparse
# upstream: https://github.com/django/django

_django-cli() {
    local -a sub=(
        'check:check the entire Django project'
        'createsuperuser:create superuser'
        'changepassword:change a user password'
        'collectstatic:collect static files'
        'compilemessages:compile gettext .po files'
        'createcachetable:create cache table'
        'dbshell:open DB shell'
        'diffsettings:show settings diff'
        'dumpdata:dump database contents to fixture'
        'flush:flush the database'
        'inspectdb:introspect database tables'
        'loaddata:load fixture'
        'makemessages:create/update .po files'
        'makemigrations:create new migration files'
        'migrate:apply migrations'
        'optimizemigration:optimize migrations'
        'remove_stale_contenttypes:remove stale content types'
        'runserver:run development server'
        'sendtestemail:send test email'
        'shell:open Python interactive shell'
        'showmigrations:show migrations'
        'sqlflush:show SQL for flush'
        'sqlmigrate:show SQL for a migration'
        'sqlsequencereset:reset DB sequences'
        'squashmigrations:squash migrations'
        'startapp:create new app'
        'startproject:create new project'
        'test:run tests'
        'testserver:run test server'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--settings=+[settings module]:str:' \
        '--pythonpath=+[python path]:dir:_files -/' \
        '--traceback[print traceback]' \
        '--no-color[no color]' \
        '--force-color[force color]' \
        '--skip-checks[skip system checks]' \
        '--verbosity=+[verbosity]:n:(0 1 2 3)' \
        '-v+[verbosity]:n:(0 1 2 3)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'django subcommand' sub ;;
        args)
            case $words[1] in
                runserver) _arguments \
                    '--ipv6[IPv6]' \
                    '-6[IPv6]' \
                    '--nothreading[no threading]' \
                    '--noreload[no auto reload]' \
                    '--insecure[insecure]' \
                    '--use-static-handler[use static handler]' \
                    '*:address-port:' ;;
                migrate) _arguments \
                    '--database=+[database]:str:' \
                    '--fake[fake apply migration]' \
                    '--fake-initial[fake initial migration]' \
                    '--plan[show migration plan]' \
                    '--run-syncdb[run syncdb]' \
                    '--check[check unapplied migrations]' \
                    '--prune[prune nonexistent migrations]' \
                    '*:app-and-migration:' ;;
                makemigrations) _arguments \
                    '--dry-run[dry run]' \
                    '--merge[merge]' \
                    '--empty[empty migration]' \
                    '--name=+[migration name]:str:' \
                    '-n+[migration name]:str:' \
                    '--no-header[no header]' \
                    '--check[check]' \
                    '--update[update]' \
                    '*:app:' ;;
                startapp|startproject) _arguments \
                    '1:name:' \
                    '*:dir:_files -/' ;;
                test) _arguments \
                    '--noinput[no input]' \
                    '--failfast[fail fast]' \
                    '--testrunner=+[test runner]:str:' \
                    '--debug-mode[debug mode]' \
                    '--debug-sql[debug SQL]' \
                    '--parallel=+[parallel]:n:' \
                    '--tag=+[tag]:list:' \
                    '--exclude-tag=+[exclude tag]:list:' \
                    '--pdb[pdb]' \
                    '--buffer[buffer]' \
                    '*:test-label:' ;;
                shell) _arguments \
                    '--no-startup[no startup]' \
                    '--interface=+[interface]:i:(ipython bpython python)' \
                    '-i+[interface]:i:(ipython bpython python)' \
                    '--command=+[command]:str:' \
                    '-c+[command]:str:' ;;
                dumpdata|loaddata) _arguments \
                    '--format=+[format]:f:(json yaml xml jsonl)' \
                    '--indent=+[indent]:n:' \
                    '--database=+[database]:str:' \
                    '--exclude=+[exclude]:list:' \
                    '-e+[exclude]:list:' \
                    '--natural-foreign[natural foreign]' \
                    '--natural-primary[natural primary]' \
                    '--all[all]' \
                    '-a[all]' \
                    '--pks=+[pks]:list:' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '*:app-or-fixture:' ;;
                collectstatic) _arguments \
                    '--noinput[no input]' \
                    '-n[dry run]' \
                    '--dry-run[dry run]' \
                    '--clear[clear before]' \
                    '-c[clear before]' \
                    '--link[link not copy]' \
                    '-l[link not copy]' \
                    '--no-default-ignore[no default ignore]' \
                    '--no-post-process[no post process]' \
                    '--ignore=+[ignore patterns]:list:' \
                    '-i+[ignore patterns]:list:' ;;
            esac
            ;;
    esac
}

_django-cli "$@"
