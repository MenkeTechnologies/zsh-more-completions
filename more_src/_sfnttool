#compdef sfnttool
# Documentation: https://github.com/googlefonts/sfntly
# Subset SFNT fonts and convert to WOFF or EOT (sfntly tools)

local ret=1

_arguments -s \
  '(-help -\?)'{-help,-\?}'[print this help information]' \
  '(-s -string)'{-s,-string}'[string to subset]:string' \
  '(-b -bench)'{-b,-bench}'[benchmark (run 10000 iterations)]' \
  '(-h -hints)'{-h,-hints}'[strip hints]' \
  '(-w -woff)'{-w,-woff}'[output WOFF format]' \
  '(-e -eot)'{-e,-eot}'[output EOT format]' \
  '(-x -mtx)'{-x,-mtx}'[enable MicroType Express compression for EOT format]' \
  '1:font file:_files -g "*.(ttf|otf|TTF|OTF)"' \
  '2:output file:_files' && ret=0

return ret
