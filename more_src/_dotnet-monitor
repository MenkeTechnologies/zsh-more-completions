#compdef dotnet-monitor

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'collect:run the monitoring service'
  'config:configuration commands'
  'generatekey:generate API key + hash for HTTP auth'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dotnet-monitor subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (collect)
        _arguments \
          '(-u --urls)'{-u,--urls=}'[listen URLs]:urls:' \
          '(-m --metrics)'{-m,--metrics=}'[enable metrics]:flag:(true false)' \
          '--metricUrls=[metrics URLs]:urls:' \
          '--diagnostic-port=[diagnostic port]:path:' \
          '--no-auth[disable auth]' \
          '--temp-apikey[use temporary API key]' \
          '--no-http-egress[disable HTTP egress]' && ret=0
        ;;
      (config)
        _values 'config action' 'show' && ret=0
        ;;
      (generatekey)
        _arguments \
          '(-o --output)'{-o,--output=}'[output format]:format:(Cmd Json MachineJson PowerShell Shell Text)' \
          '(-e --expiration)'{-e,--expiration=}'[key expiration]:timespan:' && ret=0
        ;;
    esac
    ;;
esac

return ret
