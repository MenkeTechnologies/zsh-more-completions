#compdef extlinux-update
# Documentation: https://man.archlinux.org/search?q=extlinux-update
# Reference accessed: 2026-05-16

# extlinux-update: regenerate extlinux.conf from kernel/initramfs in /boot
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '-n[no-op (dry run)]' \
  '--no-act[no-op (dry run)]' \
  '--update-mbr[also write MBR]' \
  '*::extlinux-update args:_files' && ret=0
return ret
