#compdef maildirlock
# Documentation: https://github.com/dovecot/tools/blob/main/README.maildirlock
# Reference accessed: 2026-05-19
# Verified: upstream tools/README.maildirlock in dovecot/tools on GitHub.

# maildirlock (dovecot): usage is `maildirlock <path> <timeout>`
local curcontext="$curcontext" ret=1

_arguments -C \
  '1:maildir path:_files -/' \
  '2:timeout (seconds):' && ret=0

return ret
