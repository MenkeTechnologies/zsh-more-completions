#compdef fontforge

# Zsh completion for fontforge - font editor

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c)'-c'[execute script argument]:script' \
  '(-cmap)'-cmap'[encoding]:encoding' \
  '(-display)'-display'[X display]:display' \
  '(-lang)'-lang'[scripting language]:language:(ff py)' \
  '(-last)'-last'[open last closed file]' \
  '(-library-status)'-library-status'[report libraries used]' \
  '(-new)'-new'[create a new font]' \
  '(-nosplash)'-nosplash'[do not display splash screen]' \
  '(-recover)'-recover'[recovery mode]:mode:(auto clean none)' \
  '(-script)'-script'[run script file]:script file:_files -g "*.{ff,py,pe}"' \
  '(-unique)'-unique'[do not start new fontforge if one is running]' \
  '*:font file:_files -g "*.(sfd|ttf|otf|pfb|pfa|bdf|woff|woff2|ufo|svg)"'
