#compdef migrate-mongo
# database migration tool for MongoDB in Node

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help for command]' \
  '(-V --version)'{-V,--version}'[output the version number]' \
  '(-f --file)'{-f,--file}'=[path to a custom config file]:file:_files' \
  '--migrations-dir=[override the migrations directory]:dir:_files -/' \
  '(-b --block)'{-b,--block}'[revert all scripts of the last migration (with down)]' \
  '1:command:(init create up down status help)' \
  '*::args:_default' && ret=0

return ret
