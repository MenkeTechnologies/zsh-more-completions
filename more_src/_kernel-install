#compdef kernel-install

# Zsh completion for kernel-install (add/remove kernels to/from the boot loader)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:Add a new kernel to the boot loader'
  'remove:Remove a kernel from the boot loader'
  'inspect:Print details about the kernel-install setup'
  'list:List installed kernels'
)

_arguments -s -S -C \
  '--esp-path=[Set the EFI System Partition path]:path:_files -/' \
  '--boot-path=[Set the boot path]:path:_files -/' \
  '--entry-token=[Specify the entry token]:token' \
  '--make-entry-directory=[Create the entry directory]:option:(auto yes no)' \
  '--verbose[Increase verbosity]' \
  '--root=[Set the root directory]:root:_files -/' \
  '--image=[Set the image file]:image:_files' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'kernel-install command' commands && ret=0
    ;;
  args)
    case $words[1] in
      add)
        _arguments \
          '1:kernel version' \
          '2:kernel image:_files' \
          '*:initrd:_files' && ret=0
        ;;
      remove)
        _arguments \
          '1:kernel version' && ret=0
        ;;
    esac
    ;;
esac

return ret
