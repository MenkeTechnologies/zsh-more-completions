#compdef dh_haskell_extra_depends dh_haskell_provides
# Documentation: https://manpages.debian.org/dh_haskell_extra_depends
# Source: haskell-devscripts dh_haskell_extra_depends, dh_haskell_provides — compute haskell dependency/provides substvars (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '--no-act[do not act]' \
    '*-O+[passthrough option]:opt:_default' \
    && ret=0

return ret
