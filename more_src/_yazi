#compdef yazi

# Zsh completion for yazi (terminal file manager)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--cwd-file=[Write the cwd on exit to this file]:file:_files' \
  '--chooser-file=[Write the selected files on exit to this file]:file:_files' \
  '--clear-cache[Clear the cache directory]' \
  '--client-id=[Use the specified client id]:id' \
  '--local-events=[Report specified local events]:events' \
  '--remote-events=[Report specified remote events]:events' \
  '--debug[Print debug information]' \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands_or_path' && ret=0

case $state in
  commands_or_path)
    local -a commands=(
      'sub:Subscribe to events from a running instance'
      'pub:Publish a message to a running instance'
      'pub-to:Publish a message to a specific instance'
      'pack:Manage packages'
    )
    _alternative \
      'commands:command:_describe -t commands command commands' \
      'files:file:_files' && ret=0
    ;;
esac

return ret
