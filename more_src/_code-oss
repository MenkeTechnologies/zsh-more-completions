#compdef code-oss

# Zsh completion for code-oss (Visual Studio Code - Open Source)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --diff)'{-d,--diff}'[Compare two files with each other]' \
  '(-m --merge)'{-m,--merge}'[Perform a three-way merge]' \
  '(-a --add)'{-a,--add}'=[Add folder(s) to the last active window]:folder:_files -/' \
  '(-g --goto)'{-g,--goto}'=[Open a file at path on the specified line and column]:file\:line\:column:_files' \
  '(-n --new-window)'{-n,--new-window}'[Force to open a new window]' \
  '(-r --reuse-window)'{-r,--reuse-window}'[Force to open a file or folder in an already opened window]' \
  '(-w --wait)'{-w,--wait}'[Wait for the files to be closed before returning]' \
  '--locale=[Set the display language]:locale:(de en es fr it ja ko ru zh-CN zh-TW)' \
  '--user-data-dir=[Set the user data directory]:dir:_files -/' \
  '--profile=[Open with the specified profile]:profile' \
  '--extensions-dir=[Set the extensions directory]:dir:_files -/' \
  '--install-extension=[Install a VS Code extension]:extension id or vsix:_files -g "*.vsix"' \
  '--uninstall-extension=[Uninstall a VS Code extension]:extension id' \
  '--list-extensions[List installed extensions]' \
  '--show-versions[Show versions of installed extensions]' \
  '--enable-proposed-api=[Enable proposed API features for an extension]:extension id' \
  '--disable-extensions[Disable all installed extensions]' \
  '--disable-extension=[Disable a specific extension]:extension id' \
  '--sync=[Turn sync on or off]:state:(on off)' \
  '--inspect-extensions=[Allow debugging and profiling of extensions]:port' \
  '--inspect-brk-extensions=[Allow debugging and profiling (break on start)]:port' \
  '--disable-gpu[Disable GPU hardware acceleration]' \
  '--telemetry[Show all telemetry events]' \
  '-s[Print process usage and diagnostics information]' \
  '--status[Print process usage and diagnostics information]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '-h[Print usage]' \
  '--help[Print usage]' \
  '*:file or folder:_files' && ret=0

return ret
