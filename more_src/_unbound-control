#compdef unbound-control
# _unbound-control — NLnet Labs unbound-control (remote-control client for the Unbound DNS resolver; uses TLS-authenticated control channel from unbound.conf)
# upstream: https://github.com/NLnetLabs/unbound
# Flags + commands from doc/unbound-control.8.in on tip.

_unbound-control() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)-h[show help + version]' \
        '-c+[unbound config file]:file:_files' \
        '-s+[server addr (ip[@port])]:server:_hosts' \
        '-q[quiet on success]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'start:exec unbound (start the daemon)'
                'stop:stop the daemon'
                'reload:reload config (flushes cache)'
                'reload_keep_cache:reload but keep caches'
                'fast_reload:online reload keeping queries running'
                'verbosity:set log verbosity (number)'
                'log_reopen:reopen the log file'
                'stats:print stats then reset'
                'stats_noreset:print stats without reset'
                'status:print daemon status'
                'local_zone:add local zone (name type)'
                'local_zone_remove:remove a local zone'
                'local_data:add local data RR'
                'local_data_remove:remove local data RR'
                'local_zones:bulk add zones from stdin'
                'local_zones_remove:bulk remove zones from stdin'
                'local_datas:bulk add data RRs from stdin'
                'local_datas_remove:bulk remove data RRs from stdin'
                'dump_cache:dump cache to stdout'
                'load_cache:load cache from stdin'
                'lookup:print where a name would be sent'
                'flush:flush messages for a name'
                'flush_type:flush messages for type'
                'flush_zone:flush a whole zone'
                'flush_bogus:flush all DNSSEC-bogus records'
                'flush_negative:flush negative responses'
                'flush_stats:reset counters without printing'
                'flush_requestlist:drop in-flight queries'
                'dump_requestlist:show in-flight queries'
                'flush_infra:flush infrastructure cache'
                'dump_infra:dump infrastructure cache'
                'set_option:set option value at runtime'
                'get_option:get option value'
                'list_stubs:list stub zones'
                'list_forwards:list forward zones'
                'list_insecure:list domain-insecure entries'
                'list_local_zones:list local zones'
                'list_local_data:list local RRs'
                'insecure_add:add a domain-insecure trust point'
                'insecure_remove:remove a domain-insecure entry'
                'forward_add:add a forward zone (with optional +i)'
                'forward_remove:remove a forward zone'
                'stub_add:add a stub zone (with optional +ip)'
                'stub_remove:remove a stub zone'
                'forward:show/set global forward servers'
                'ratelimit_list:list rate-limited domains'
                'ip_ratelimit_list:list IP rate-limited addresses'
                'list_auth_zones:list authority zones'
                'auth_zone_reload:reload an authority zone'
                'auth_zone_transfer:trigger AXFR/IXFR'
                'rpz_enable:enable an RPZ zone'
                'rpz_disable:disable an RPZ zone'
                'view_list_local_zones:list local zones inside a view'
                'view_local_zone:add a local zone inside a view'
                'view_local_zone_remove:remove a local zone from a view'
                'view_list_local_data:list local data RRs inside a view'
                'view_local_data:add a local data RR inside a view'
                'view_local_data_remove:remove a view-local RR'
                'view_local_datas:bulk add view-local RRs'
                'view_local_datas_remove:bulk remove view-local RRs'
                'add_cookie_secret:add a DNS cookie secret'
                'drop_cookie_secret:drop the staging cookie secret'
                'activate_cookie_secret:promote staging secret to active'
                'print_cookie_secrets:show cookie secrets'
            )
            _describe -t commands 'unbound-control command' subs
            ;;
    esac
}

_unbound-control "$@"
