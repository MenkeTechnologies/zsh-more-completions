#compdef findcent
# Documentation: http://www.starlink.ac.uk/docs/sun139.htx/sun139.html
# CCDPACK: Centroid image features from a position list

local ret=1

_arguments -s -S \
  'IN=[input images]:in:_files' \
  'OUTLIST=[output centroided position lists]:outlist:_files' \
  'INLIST=[input position lists]:inlist:_files' \
  'AUTOSCALE=[scale search parameters to data]:autoscale:(TRUE FALSE)' \
  'ISIZE=[size of centroid search box]:isize:' \
  'LOGFILE=[log file name]:logfile:_files' \
  'LOGTO=[where to write log information]:logto:(TERMINAL LOGFILE BOTH NEITHER)' \
  'MAXITER=[maximum centroid iterations]:maxiter:' \
  'MAXSHIFT=[maximum positional shift]:maxshift:' \
  'NAMELIST=[file to record output list names]:namelist:_files' \
  'NDFNAMES=[position list names refer to NDFs]:ndfnames:(TRUE FALSE)' \
  'POSITIVE=[features are positive (bright)]:positive:(TRUE FALSE)' \
  'TOLER=[centroid tolerance]:toler:' \
  '*:NDF data file:_files' && ret=0

return ret
