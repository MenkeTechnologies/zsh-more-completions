#compdef appwrite-cli2 appwrite2
# _appwrite-cli2 — Appwrite appwrite-cli2 CLI command-line frontend wrapping the Appwrite open-source secure self-hosted backend server for web mobile and Flutter developers full lifecycle alternative to Firebase Supabase written in Node TypeScript a complete backend with Database Auth Storage Functions Messaging Realtime Cloud-database self-hosted single-binary login logout init deploy pull migration migrate-from-firebase-supabase organizations projects functions databases users teams storage messaging realtime locale graphql avatars health database collections documents account websites projects (Appwrite team Eldad Fux Dolce Cox, Node/TypeScript); commander
# upstream: https://appwrite.io/

_appwrite-cli2() {
    local -a sub=(
        'account:account operations'
        'avatars:avatars operations'
        'client:HTTP client config'
        'completion:generate shell completion'
        'console:open console'
        'databases:database operations'
        'deploy:deploy resources'
        'functions:Functions operations'
        'graphql:run GraphQL'
        'health:health checks'
        'init:initialize project'
        'install:install Appwrite'
        'locale:locale operations'
        'login:authenticate'
        'logout:revoke session'
        'messaging:messaging operations'
        'migrations:migration operations'
        'organizations:organization operations'
        'projects:project operations'
        'pull:pull resources'
        'push:push resources'
        'register:register account'
        'reset:reset project'
        'storage:storage operations'
        'teams:team operations'
        'users:user operations'
        'whoami:show identity'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--endpoint=+[url]:str:' \
        '--project=+[id]:str:' \
        '--project-id=+[id]:str:' \
        '--key=+[key]:str:' \
        '--api-key=+[key]:str:' \
        '--token=+[token]:str:' \
        '-c+[config]:file:_files -g "appwrite.json *.json"' \
        '--config=+[file]:file:_files -g "appwrite.json *.json"' \
        '--cwd=+[dir]:dir:_files -/' \
        '--json[JSON output]' \
        '-j[JSON output]' \
        '--no-color[no color]' \
        '--force[force]' \
        '-f[force]' \
        '--all[all resources]' \
        '--yes[yes]' \
        '-y[yes]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--report[report]' \
        '--insecure[skip TLS verify]' \
        '--queries=+[query]:str:' \
        '*--queries=+[query]:str:' \
        '--id=+[id]:str:' \
        '--name=+[name]:str:' \
        '--key=+[key]:str:' \
        '--code=+[file]:file:_files' \
        '--variables=+[k=v]:str:' \
        '*--variables=+[k=v]:str:' \
        '--runtime=+[r]:r:(node-18.0 node-20 node-21 python-3.9 python-3.10 python-3.11 ruby-3.0 ruby-3.1 ruby-3.2 ruby-3.3 php-8.0 php-8.1 php-8.2 php-8.3 java-8.0 java-11.0 java-17.0 java-18.0 java-21.0 dotnet-3.1 dotnet-6.0 dart-2.15 dart-2.17 dart-2.18 dart-2.19 dart-3.0 dart-3.1 deno-1.21 deno-1.24 deno-1.28 deno-1.35 cpp-17 cpp-20 swift-5.5 swift-5.8 swift-5.9 kotlin-1.6 kotlin-1.7 kotlin-1.8 kotlin-1.9)' \
        '--timeout=+[sec]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'appwrite subcommand' sub ;;
        args)
            case $words[1] in
                databases|users|teams|projects|storage|functions|messaging|migrations) _arguments '1:op:(list get create update delete list-attributes get-attribute create-relationship-attribute create-collection delete-collection list-documents get-document update-document delete-document create-document)' '*:id:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_appwrite-cli2 "$@"
