_nof1-tracker() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_nof1_tracker_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                follow)
                    _arguments \
                        '(-r --risk-only)'{-r,--risk-only}'[only do risk assessment; skip trade execution]' \
                        '(-i --interval)'{-i,--interval}'=[polling interval in seconds (default 30)]:secs:' \
                        '(-t --price-tolerance)'{-t,--price-tolerance}'=[price tolerance threshold (default 1%)]:pct:' \
                        '(-m --total-margin)'{-m,--total-margin}'=[total margin (default 10 USDT)]:amount:' \
                        '--fixed-amount-per-coin=[fixed margin per coin]:amount:' \
                        '--profit=[auto-exit at profit target %]:pct:' \
                        '--auto-refollow[auto-refollow after profit target exit]' \
                        '--margin-type=[margin mode]:type:(ISOLATED CROSSED)' \
                        ':agent name:' && ret=0 ;;
                profit)
                    _arguments \
                        '(-s --since)'{-s,--since}'=[time filter (7d, 2024-01-01, timestamp)]:time:' \
                        '(-p --pair)'{-p,--pair}'=[trading pair (e.g. BTCUSDT)]:symbol:' \
                        '--group-by=[group by symbol or all]:type:(symbol all)' \
                        '--format=[output format]:format:(table json)' \
                        '--refresh[force refresh cache]' \
                        '--exclude-unrealized[exclude unrealized P&L]' \
                        '--unrealized-only[show only unrealized P&L]' && ret=0 ;;
                agents|telegram-test|status)
                    _arguments && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_nof1_tracker_commands] )) ||
_nof1_tracker_commands() {
    local -a commands
    commands=(
        'agents:list all available AI agents'
        'follow:follow an AI agent and copy their trades'
        'telegram-test:send a test Telegram message'
        'status:check system status and configuration'
        'profit:analyze profit/loss statistics for futures trades'
    )
    _describe -t commands 'nof1-tracker command' commands
}

_nof1-tracker "$@"
