#compdef imv-wayland imv-x11

# Zsh completion for imv - image viewer for X11/Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b)'-b'[set background color]:color' \
  '(-c)'-c'[execute command at startup]:command' \
  '(-d)'-d'[show overlay]' \
  '(-f)'-f'[start fullscreen]' \
  '(-l)'-l'[list open files at exit]' \
  '(-n)'-n'[start at specified file]:file:_files' \
  '(-r)'-r'[load directories recursively]' \
  '(-s)'-s'[set scaling mode]:mode:(none shrink full crop)' \
  '(-S)'-S'[slideshow duration in seconds]:seconds' \
  '(-t)'-t'[set initial pan type]:type:(center best-fit)' \
  '(-u)'-u'[set upscaling method]:method:(linear nearest)' \
  '(-w)'-w'[set window title]:title' \
  '(-x)'-x'[disable looping]' \
  '*:image file:_files -g "*.(png|jpg|jpeg|gif|bmp|tiff|tga|ppm|webp|svg|ico|heif|avif)"'
