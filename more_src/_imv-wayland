#compdef imv-wayland imv-x11
# Documentation: https://man.archlinux.org/man/imv.1
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# imv-wayland / imv-x11: backend-specific imv binaries; same flags as imv(1)
_arguments \
  '-h[show help and quit]' \
  '-v[show version and quit]' \
  '-b[set background color (hex or "checks")]:color:' \
  '-c[command to run at startup]:command:' \
  '-d[start with overlay visible]' \
  '-f[start fullscreen]' \
  '-i[X11 resource name / Wayland app ID]:name:' \
  '-l[list open files to stdout at exit]' \
  '-n[start at file path or index]:image path or index:' \
  '-r[load directories recursively]' \
  '-s[scaling mode]:mode:(none shrink full crop)' \
  '-t[slideshow mode with delay seconds]:seconds:' \
  '-u[upscaling method]:method:(linear nearest_neighbour)' \
  '-w[window title at startup]:title:' \
  '-x[disable looping of input paths]' \
  '-W[initial window width]:width:' \
  '-H[initial window height]:height:' \
  '*:image file:_files -g "*.(png|jpg|jpeg|gif|bmp|tiff|tga|ppm|webp|svg|ico|heif|avif)"'
