#compdef salmon-quantmerge
# Documentation: https://salmon.readthedocs.io/
# Salmon: merge multiple quantification results into a single matrix

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '--quants=[quantification directories to merge]:dirs:_files -/' \
  '--names=[names to give the samples]:names' \
  '(-c --column)'{-c,--column}'=[column merged into output (default TPM)]:column:(len elen tpm numreads)' \
  '--genes[use gene quantification instead of transcript]' \
  '--missing=[value for missing entries (default NA)]:value' \
  '(-o --output)'{-o,--output}'=[output file]:output:_files' && ret=0

return ret
