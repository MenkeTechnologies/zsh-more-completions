#compdef kubefed
# _kubefed — Kubernetes SIG Multi-Cluster kubefed CLI client for the Kubernetes Cluster Federation v2 multi-cluster control-plane managing federated resources across multiple member-clusters supporting join unjoin enable disable orphan namespaces clusters propagation-policy override admin-deploy operations for application multi-cluster orchestration (Kubernetes team, Go); cobra
# upstream: https://github.com/kubernetes-sigs/kubefed

_kubefed() {
    local -a sub=(
        'join:join a cluster'
        'unjoin:unjoin a cluster'
        'enable:enable a federated resource'
        'disable:disable a federated resource'
        'orphaning-deletion:control orphaning'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubefed-namespace=+[ns]:str:' \
        '--host-cluster-context=+[ctx]:str:' \
        '--cluster-context=+[ctx]:str:' \
        '--cluster-name=+[name]:str:' \
        '--add-to-registry[add to registry]' \
        '--limit-scope=+[s]:s:(Namespaced Cluster)' \
        '--scope=+[s]:s:(Cluster Namespaced)' \
        '--dry-run[dry run]' \
        '--kubeconfig=+[file]:file:_files' \
        '-o+[output]:f:(json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kubefed subcommand' sub ;;
        args)
            case $words[1] in
                join|unjoin) _arguments '*:cluster:' ;;
                enable|disable) _arguments '*:resource:' ;;
            esac
            ;;
    esac
}

_kubefed "$@"
