#compdef puppet-module
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/module.md
# puppet module - install, manage and inspect modules from the Puppet Forge

local ret=1

_arguments -s -S \
  '--render-as=[output render format]:format:(json s yaml console)' \
  '--verbose[whether to log verbosely]' \
  '--debug[whether to log debug information]' \
  '--environment=[environment to operate in]:environment:' \
  '--modulepath=[search path for modules]:path:_files -/' \
  '(-f --force)'{-f,--force}'[force the operation despite local changes]' \
  '(-i --target-dir)'{-i,--target-dir}'+[directory for module installation]:dir:_files -/' \
  '--ignore-dependencies[do not attempt to install dependencies]' \
  '(-c --ignore-changes)'{-c,--ignore-changes}'[proceed even with local changes]' \
  '(-v --version)'{-v,--version}'+[module version specification]:version:' \
  '--tree[show dependencies as a tree view]' \
  '1:action:(changes install list search uninstall upgrade build generate)' \
  '*::module:' && ret=0

return ret
