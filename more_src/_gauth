#compdef gauth

# https://github.com/pcarrier/gauth — manual flags (gauth.go)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage]' \
  '(-b -bare --bare)'{-b,-bare,--bare}'[print bare TOTP code]' \
  '(-a -add --add)'{-a,-add,--add}'[add account interactively]' \
  '(-r -remove --remove)'{-r,-remove,--remove}'[remove account]' \
  '(-s -secret --secret)'{-s,-secret,--secret}'[show OTP secret]' \
  '*:account prefix or operand:_default'
