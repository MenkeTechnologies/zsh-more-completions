#compdef sutaper
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/tapering/sutaper.c
# SUTAPER - taper the edge traces of a data panel to zero

local ret=1

_arguments -s -S \
  'ntr=[number of traces]:n:' \
  'tr1=[number of traces to taper at beginning]:n:' \
  'tr2=[number of traces to taper at end]:n:' \
  'min=[minimum amplitude factor of taper]:m:' \
  'tbeg=[length of taper (ms) at trace start]:t:' \
  'tend=[length of taper (ms) at trace end]:t:' \
  'taper=[taper type]:t:(1 2 3 4 5)' \
  '*:SU file:_files' && ret=0

return ret
