#compdef bsync

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-v,--verbose}'[verbose output]' \
  {-n,--dry-run}'[dry run, do not make changes]' \
  {-d,--delete}'[propagate deletions]' \
  {-i,--ignore}'=[ignore pattern]:pattern' \
  {-p,--policy}'=[conflict resolution policy]:policy:(newer older larger smaller)' \
  '--snap1=[path to snapshot file for dir1]:snapshot file:_files' \
  '--snap2=[path to snapshot file for dir2]:snapshot file:_files' \
  '--hash[use file hashing for comparison]' \
  '--trash=[trash directory for deleted files]:trash directory:_directories' \
  '1:directory 1:_directories' \
  '2:directory 2:_directories' && ret=0

return ret
