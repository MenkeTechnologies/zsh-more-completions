#compdef mupad
# Documentation: https://www.mathworks.com/discovery/mupad.html
# Reference accessed: 2026-05-19
# Verified: STUB. MuPAD is retired (acquired by MathWorks for Symbolic Math
# Toolbox); no canonical CLI manpage. Conservative file completion only.

# MuPAD: legacy symbolic computation system
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:MuPAD source:_files -g "*.mu"' && ret=0
return ret
