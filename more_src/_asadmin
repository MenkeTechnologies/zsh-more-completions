#compdef asadmin

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create-domain:create a domain'
  'delete-domain:delete a domain'
  'list-domains:list domains'
  'start-domain:start a domain'
  'stop-domain:stop a domain'
  'restart-domain:restart a domain'
  'backup-domain:back up a domain'
  'restore-domain:restore a domain'
  'create-instance:create an instance'
  'delete-instance:delete an instance'
  'list-instances:list instances'
  'start-instance:start an instance'
  'stop-instance:stop an instance'
  'create-cluster:create a cluster'
  'delete-cluster:delete a cluster'
  'list-clusters:list clusters'
  'start-cluster:start a cluster'
  'stop-cluster:stop a cluster'
  'restart-cluster:restart a cluster'
  'deploy:deploy an application'
  'undeploy:undeploy an application'
  'redeploy:redeploy an application'
  'list-applications:list applications'
  'list-components:list components'
  'enable:enable an application'
  'disable:disable an application'
  'create-jvm-options:add JVM options'
  'delete-jvm-options:remove JVM options'
  'list-jvm-options:list JVM options'
  'create-jdbc-resource:create a JDBC resource'
  'delete-jdbc-resource:delete a JDBC resource'
  'list-jdbc-resources:list JDBC resources'
  'create-jdbc-connection-pool:create a JDBC connection pool'
  'delete-jdbc-connection-pool:delete a JDBC connection pool'
  'list-jdbc-connection-pools:list JDBC connection pools'
  'create-jms-resource:create a JMS resource'
  'delete-jms-resource:delete a JMS resource'
  'list-jms-resources:list JMS resources'
  'list-jndi-resources:list JNDI resources'
  'create-jndi-resource:create a JNDI resource'
  'delete-jndi-resource:delete a JNDI resource'
  'list-resource-adapter-configs:list resource adapter configs'
  'create-resource-adapter-config:create resource adapter config'
  'delete-resource-adapter-config:delete resource adapter config'
  'enable-monitoring:enable monitoring'
  'disable-monitoring:disable monitoring'
  'set-log-levels:set log levels'
  'list-log-levels:list log levels'
  'list-jobs:list jobs'
  'attach:attach to a job'
  'configure-managed-jobs:configure managed jobs'
  'get:get a configuration value'
  'set:set a configuration value'
  'list:list configuration values'
  'login:store authentication credentials'
  'logout:remove stored credentials'
  'multimode:enter interactive multi-command mode'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(-H --host)'{-H,--host=}'[host]:host:_hosts' \
  '(-p --port)'{-p,--port=}'[port]:port:' \
  '(-u --user)'{-u,--user=}'[user]:user:_users' \
  '(-W --passwordfile)'{-W,--passwordfile=}'[password file]:file:_files' \
  '(-t --terse)'{-t,--terse}'[terse output]' \
  '(-T --extraterse)'{-T,--extraterse}'[extra-terse output]' \
  '(-s --secure)'{-s,--secure}'[use secure connection]' \
  '(-e --echo)'{-e,--echo}'[echo command]' \
  '(-I --interactive)'{-I,--interactive}'[interactive mode]' \
  '(-a --autoname)'{-a,--autoname}'[auto-generate names]' \
  '--detach[run command asynchronously]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'asadmin subcommand' subcommands && ret=0
    ;;
esac

return ret
