#compdef threemux
# Documentation: https://github.com/aaronjanse/3mux
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for threemux terminal multiplexer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '*::session or command: ' && ret=0

return ret
