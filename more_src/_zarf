#compdef zarf

_zarf_cmds() {
    local -a commands=(
        'init:prepare a cluster for Zarf'
        'destroy:remove Zarf from a cluster'
        'package:manage Zarf packages'
        'connect:access services deployed by Zarf'
        'dev:development utilities'
        'tools:collection of utility commands'
        'version:print version'
        'completion:generate shell completions'
        'help:print help information'
    )
    _describe -t commands 'zarf command' commands
}

_zarf() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '--log-level=[log level]:level:(warn info debug trace)' \
        '-l=[log level]:level:(warn info debug trace)' \
        '--architecture=[target architecture]:arch:(amd64 arm64)' \
        '-a=[target architecture]:arch:(amd64 arm64)' \
        '--no-log-file[disable log file]' \
        '--no-progress[disable progress bars]' \
        '--tmpdir=[temporary directory]:dir:_directories' \
        '--zarf-cache=[Zarf cache directory]:dir:_directories' \
        '--insecure[allow insecure connections]' \
        '1:command:_zarf_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                init)
                    _arguments \
                        '--components=[comma-separated components]:components' \
                        '--confirm[confirm deployment]' \
                        '--storage-class=[storage class]:class' \
                        '--nodeport=[nodeport for registry]:port' \
                        '--registry-push-password=[registry push password]:password' \
                        '--registry-push-username=[registry push username]:username' \
                        '--registry-secret=[registry pull secret]:secret' \
                        '--registry-url=[external registry URL]:url' \
                        '--git-push-password=[git push password]:password' \
                        '--git-push-username=[git push username]:username' \
                        '--git-url=[external git URL]:url' \
                        '--artifact-push-password=[artifact push password]:password' \
                        '--artifact-push-username=[artifact push username]:username' \
                        '--artifact-url=[external artifact URL]:url'
                    ;;
                destroy)
                    _arguments \
                        '--confirm[confirm destruction]' \
                        '--remove-components[remove installed components]'
                    ;;
                package)
                    _arguments \
                        '1:action:(create deploy inspect remove list pull publish mirror)' \
                        '*::pkg-args:->pkg-args'
                    ;;
                connect)
                    _arguments \
                        '--name=[connection name]:name' \
                        '--namespace=[namespace]:namespace' \
                        '--resource-type=[resource type]:type' \
                        '--resource-name=[resource name]:name' \
                        '--remote-port=[remote port]:port' \
                        '--local-port=[local port]:port' \
                        '--cli-only[print URL only]' \
                        '1:connection'
                    ;;
                dev)
                    _arguments \
                        '1:action:(deploy find-images generate-config lint sha256sum patch-git)' \
                        '*:args'
                    ;;
                tools)
                    _arguments \
                        '1:tool:(archiver clear-cache download-init gen-key gen-pki get-creds kubectl registry sbom wait-for update-creds)' \
                        '*:args'
                    ;;
            esac

            case $state in
                pkg-args)
                    case $line[1] in
                        create)
                            _arguments \
                                '--output=[output directory]:dir:_directories' \
                                '-o=[output directory]:dir:_directories' \
                                '--confirm[confirm package creation]' \
                                '--set=[package variable]:key=value' \
                                '--max-package-size=[max package size in MB]:size' \
                                '--signing-key=[signing key file]:file:_files' \
                                '--differential=[differential package tag]:tag' \
                                '--registry-override=[registry override]:override' \
                                '--flavor=[package flavor]:flavor' \
                                '1:directory:_directories'
                            ;;
                        deploy)
                            _arguments \
                                '--confirm[confirm deployment]' \
                                '--components=[comma-separated components]:components' \
                                '--set=[deployment variable]:key=value' \
                                '--shasum=[expected package checksum]:shasum' \
                                '--sget=[cosign verification key]:key' \
                                '--skip-webhooks[skip waiting for webhooks]' \
                                '1:package:_files'
                            ;;
                        inspect)
                            _arguments \
                                '--sbom[view SBOM]' \
                                '--sbom-out=[SBOM output directory]:dir:_directories' \
                                '1:package:_files'
                            ;;
                        remove)
                            _arguments \
                                '--confirm[confirm removal]' \
                                '--components=[comma-separated components]:components' \
                                '1:package'
                            ;;
                        pull)
                            _arguments \
                                '--output-directory=[output directory]:dir:_directories' \
                                '-o=[output directory]:dir:_directories' \
                                '1:oci-ref'
                            ;;
                        publish)
                            _arguments \
                                '1:package:_files' \
                                '2:oci-ref'
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

_zarf "$@"
