#compdef dlt-convert

_arguments -s \
  '(- *)-h[show help]' \
  '-a[payload as ASCII]' \
  '-x[payload as hex]' \
  '-m[payload as hex and ASCII]' \
  '-s[only headers]' \
  '-o+[output DLT file]:file:_files' \
  '-v[verbose]' \
  '-c[count messages]' \
  '-f+[filter file]:file:_files' \
  '-b+[first message]:n:' \
  '-e+[last message]:n:' \
  '-w[follow as file grows]' \
  '-t[handle .tar.gz input]' \
  '*:dlt file:_files -g "*.dlt"'
