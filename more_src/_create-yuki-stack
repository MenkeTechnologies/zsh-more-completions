#compdef create-yuki-stack
# Documentation: https://www.npmjs.com/package/create-yuki-stack
# Reference accessed: 2026-05-24
# Verified: npm view create-yuki-stack bin; npm readme CLI Options table.

# Zsh completion for create-yuki-stack - typed full-stack TypeScript scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-y --yes)'{-y,--yes}'[skip prompts; use defaults]' \
  '--no-yes[negate --yes]' \
  '--frontend=[frontend frameworks; repeatable]:frontend:(nextjs react-router tanstack-start)' \
  '--database=[database option]:database:(none drizzle prisma mongoose)' \
  '--adapter=[database adapter]:adapter:(none neon)' \
  '--backend=[backend framework]:backend:(none express elysia hono spring-boot)' \
  '--api=[API layer]:api:(none eden trpc orpc)' \
  '--auth=[authentication]:auth:(none basic-auth better-auth next-auth)' \
  '--extras=[extra tooling; repeatable]:extra:(gh-actions email)' \
  '--package-manager=[package manager]:manager:(npm yarn pnpm bun)' \
  '--install[install dependencies after setup]' \
  '--no-install[skip dependency installation]' \
  '--git[initialize git repository]' \
  '--no-git[skip git initialization]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  ':project name:' && ret=0

return ret
