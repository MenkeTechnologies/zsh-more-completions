#compdef lsblk
# _lsblk-bin — util-linux list block devices; print tree of devices with size/type/mountpoint
# upstream: https://github.com/util-linux/util-linux

_lsblk-bin() {
    _arguments \
        '(-a --all)'{-a,--all}'[show empty devices]' \
        '(-A --noempty)'{-A,--noempty}'[hide empty devices]' \
        '(-b --bytes)'{-b,--bytes}'[print sizes in bytes]' \
        '(-D --discard)'{-D,--discard}'[print discard caps]' \
        '(-d --nodeps)'{-d,--nodeps}'[do not print holders]' \
        '(-E --dedup)'{-E,--dedup}'+[de-duplicate by column]:col:' \
        '(-e --exclude)'{-e,--exclude}'+[exclude major numbers]:list:' \
        '(-f --fs)'{-f,--fs}'[show FS info]' \
        '(-I --include)'{-I,--include}'+[include major numbers]:list:' \
        '(-i --ascii)'{-i,--ascii}'[ASCII tree]' \
        '(-J --json)'{-J,--json}'[json output]' \
        '(-l --list)'{-l,--list}'[list format]' \
        '(-M --merge)'{-M,--merge}'[group raid devices]' \
        '(-m --perms)'{-m,--perms}'[print perms]' \
        '(-n --noheadings)'{-n,--noheadings}'[no header]' \
        '(-O --output-all)'{-O,--output-all}'[all columns]' \
        '(-o --output)'{-o,--output}'+[columns]:cols:' \
        '(-P --pairs)'{-P,--pairs}'[key=value output]' \
        '(-p --paths)'{-p,--paths}'[full device paths]' \
        '(-r --raw)'{-r,--raw}'[raw output]' \
        '(-S --scsi)'{-S,--scsi}'[print SCSI only]' \
        '(-s --inverse)'{-s,--inverse}'[reverse tree]' \
        '(-T --tree)'{-T,--tree}'+[tree format]:col:' \
        '(-t --topology)'{-t,--topology}'[show topology]' \
        '(-x --sort)'{-x,--sort}'+[sort by column]:col:' \
        '(-y --shell)'{-y,--shell}'[shell var output]' \
        '(-z --zoned)'{-z,--zoned}'[show zone model]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:device:_files'
}

_lsblk-bin "$@"
