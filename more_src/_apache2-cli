#compdef apache2-cli httpd-cli apachectl
# _apache2-cli — ASF Apache HTTP Server CLI alias (apache team, C); custom argparse
# upstream: https://github.com/apache/httpd

_apache2-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-V[show version + compile settings]' \
        '-l[list compiled-in modules]' \
        '-L[list available directives]' \
        '-t[run syntax test]' \
        '-S[show parsed virtual host settings]' \
        '-M[show all enabled modules]' \
        '-X[debug mode (single process)]' \
        '-DDUMP_INCLUDES[dump includes]' \
        '-DDUMP_MODULES[dump modules]' \
        '-DDUMP_VHOSTS[dump vhosts]' \
        '-DDUMP_RUN_CFG[dump run config]' \
        '-DDUMP_CONFIG[dump config]' \
        '-DDUMP_CERTS[dump certs]' \
        '-D+[define]:str:' \
        '-d+[server root]:dir:_files -/' \
        '-e+[loglevel]:l:(debug info notice warn error crit alert emerg)' \
        '-E+[startup error log]:file:_files' \
        '-f+[config file]:file:_files -g "httpd.conf"' \
        '-c+[config directive]:str:' \
        '-C+[config directive (before reading config)]:str:' \
        '-k+[command]:c:(start stop restart graceful graceful-stop)' \
        '-T[disable type-check]' \
        '-w+[wait]:n:' \
        '-X[debug single process]' \
        '*:arg:'
}

_apache2-cli "$@"
