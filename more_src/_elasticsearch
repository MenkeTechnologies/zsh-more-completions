#compdef elasticsearch elasticsearch-cli

# Zsh completion for Elasticsearch

_elasticsearch() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-E+[configure a setting]:setting=value:' \
    '-d[run as daemon]' \
    '--daemonize[run as daemon]' \
    '-p+[PID file]:PID file:_files' \
    '--pidfile=[PID file]:PID file:_files' \
    '-q[turn off standard output/error streams logging]' \
    '--quiet[turn off standard output/error streams logging]' \
    '-s[silence terminal output]' \
    '--silent[silence terminal output]' \
    '-v[print version]' \
    '--version[print version]' \
    '-V[print version]' \
    '(-h --help)'{-h,--help}'[display help]' \
    '--enrollment-token=[enrollment token for joining a cluster]:token:' \
    '--node.name=[node name]:name:' \
    '--cluster.name=[cluster name]:name:' \
    '--path.data=[data directory]:directory:_files -/' \
    '--path.logs=[logs directory]:directory:_files -/' \
    '--path.home=[home directory]:directory:_files -/' \
    '--path.conf=[config directory]:directory:_files -/' \
    '--network.host=[network host]:host:_hosts' \
    '--http.port=[HTTP port]:port:' \
    '--transport.port=[transport port]:port:' \
    '--discovery.seed_hosts=[seed hosts]:hosts:' \
    '--cluster.initial_master_nodes=[initial master nodes]:nodes:' \
    '--xpack.security.enabled=[enable security]:enabled:(true false)' \
    '--xpack.security.enrollment.enabled=[enable enrollment]:enabled:(true false)' \
    '--xpack.security.http.ssl.enabled=[enable HTTPS]:enabled:(true false)' \
    '--xpack.security.http.ssl.keystore.path=[keystore path]:path:_files' \
    '--xpack.security.transport.ssl.enabled=[enable transport SSL]:enabled:(true false)' \
    && ret=0

  return ret
}

_elasticsearch "$@"
