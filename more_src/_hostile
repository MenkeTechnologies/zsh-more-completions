#compdef hostile

# Zsh completion for hostile - a nifty command line utility for managing your /etc/hosts file

local curcontext="$curcontext" state line ret=1

_hostile_commands() {
  local -a commands=(
    'list:list entries in your hosts file'
    'set:add (or update) an entry to your hosts file'
    'remove:remove an entry from your hosts file'
    'load:load entries from a file'
    'fetch:fetch and load entries from a URL'
  )
  _describe -t commands 'hostile command' commands
}

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '1: :_hostile_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      set)
        _arguments \
          '1:IP address' \
          '2:hostname' && ret=0
        ;;
      remove)
        _arguments '*:hostname' && ret=0
        ;;
      load|fetch)
        _arguments '1:file or URL:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
