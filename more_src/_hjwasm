#compdef hjwasm

# HJWasm: 64-bit-capable fork of JWasm assembler
# Documentation: https://www.japheth.de/JWasm/JWasm.html
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-?[show help]' \
  '-bin[binary output]' \
  '-coff[COFF output]' \
  '-elf[ELF32 output]' \
  '-elf64[ELF64 output]' \
  '-omf[OMF output]' \
  '-pe[Windows PE output]' \
  '-mz[MS-DOS MZ output]' \
  '-win64[Win64 COFF output]' \
  '-c[no link, .obj only]' \
  '-Fo[output object file]:file:_files' \
  '-Fl[listing file]:file:_files' \
  '-Sa[max source assemble syntax]' \
  '-Cp[case-preserve]' \
  '-Cu[upper case syms]' \
  '-Cx[lower case syms]' \
  '-D[predefine symbol]:symbol:' \
  '-I[include path]:dir:_files -/' \
  '-q[quiet]' \
  '-eq[error file]:file:_files' \
  '-WX[treat warnings as errors]' \
  '-w[warning level]:n:(0 1 2 3)' \
  '-Zd[line-number info]' \
  '-Zi[full symbolic debug]' \
  '-Zp[align structures]:n:(1 2 4 8 16)' \
  '-Zm[MASM 5.10 compat]' \
  '*:source file:_files -g "*.(asm|s)"' && ret=0
return ret
