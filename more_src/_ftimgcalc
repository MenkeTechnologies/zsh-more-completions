#compdef ftimgcalc
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftimgcalc.html
# Create a FITS image by performing computations on input images

local ret=1

_arguments -s -S \
  'outfile=[output image file, or NONE]:outfile:_files' \
  'expr=[calculator expression]:expr:' \
  'nvectimages=[number of images handled at once]:nvectimages:' \
  'replicate=[duplicate input extensions to match nvectimages]:replicate:(yes no)' \
  'diagfile=[diagnostic output file]:diagfile:_files' \
  'resultname=[HDU name for results]:resultname:' \
  'bunit=[unit for output image data]:bunit:' \
  'otherext=[append extensions from a source image]:otherext:(yes no)' \
  'wcsimage=[input image whose WCS keywords to copy]:wcsimage:' \
  'bitpix=[output data type, BITPIX or TFORM code]:bitpix:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
