#compdef obsidian
# Documentation: https://man.archlinux.org/search?q=obsidian
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'open:open vault or note'
  'create:create a new note'
  'append:append content to a note'
  'prepend:prepend content to a note'
  'search:search vault for query'
  'list:list notes'
  'tag:tag operations'
  'task:task operations'
  'link:link operations'
  'rename:rename a note'
  'move:move a note'
  'delete:delete a note'
  'meta:metadata operations'
  'vault:vault operations'
  'config:configuration'
  'plugin:plugin management'
  'theme:theme management'
  'sync:sync operations'
  'export:export notes'
  'import:import files'
  'backup:backup vault'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--copy[copy command output to clipboard]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'obsidian command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          'name=[note name]:name:' \
          'content=[initial content]:content:' \
          'template=[template name]:template:' \
          'silent[do not open]' \
          'vault=[target vault]:vault:' && ret=0 ;;
      (append|prepend)
        _arguments \
          'file=[note file]:file:' \
          'content=[content to add]:text:' \
          'vault=[target vault]:vault:' && ret=0 ;;
      (search)
        _arguments \
          'query=[search query]:q:' \
          'limit=[max results]:n:' \
          'total[show total count]' \
          'vault=[target vault]:vault:' && ret=0 ;;
      (open|delete|rename|move) _arguments '*: :' && ret=0 ;;
    esac ;;
esac

return ret
