#compdef raptor
# Documentation: https://bio3d.colorado.edu/imod/doc/man/raptor.html
# raptor - robust alignment and reconstruction of tilt series (RAPTOR)

local ret=1

_arguments -s -S \
  '(-e --execPath)'{-e,-execPath}'[path where RAPTOR binaries are located]:dir:_files -/' \
  '(-p --path)'{-p,-path}'[path where the MRC stack to be aligned is located]:dir:_files -/' \
  '(-i --input)'{-i,-input}'[input filename without the path]:file:_files' \
  '(-ou --output)'{-ou,-output}'[path where output files will be saved]:dir:_files -/' \
  '(-d --diameter)'{-d,-diameter}'[diameter(s) of the markers in pixels]:diameter' \
  '(-w --white)'{-w,-white}'[search for markers brighter than the background]' \
  '(-mar --markers)'{-mar,-markers}'[number of markers to be tracked]:count' \
  '(-a --angles)'{-a,-angles}'[extract tilt angles from the header]' \
  '(-b --bin)'{-b,-bin}'[bin the stack before performing alignment]:binning' \
  '(-re --rec)'{-re,-rec}'[run IMOD to reconstruct the tomogram]:value' \
  '(-th --thickness)'{-th,-thickness}'[thickness of the tomogram]:thickness' \
  '(-or --orientation)'{-or,-orientation}'[control the handedness of the tomogram]:value' \
  '(-tr --tracking)'{-tr,-tracking}'[do only marker tracking, no alignment]' \
  '(-x --xray)'{-x,-xray}'[handle strong straight line features]' \
  '(-v --verb)'{-v,-verb}'[how much output RAPTOR should write and keep]:level' \
  '(-max --maxDist)'{-max,-maxDist}'[maximum distance between two markers]:distance' \
  '(-mi --minNeigh)'{-mi,-minNeigh}'[minimum neighbors per marker for the MRF]:count' \
  '(-ro --rollOff)'{-ro,-rollOff}'[exponential decay coefficient for the MRF]:value' \
  '(-s --seed)'{-s,-seed}'[seed for the pseudo-random generator]:seed' \
  '(-h --help)'{-h,-help}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
