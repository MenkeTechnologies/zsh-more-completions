#compdef rootreadspeed
# Documentation: https://github.com/root-project/root/blob/master/tree/readspeed/src/ReadSpeedCLI.cxx
# Reference accessed: 2026-05-27
# Verified: upstream tree/readspeed/src/ReadSpeedCLI.cxx argument parser.

# rootreadspeed — benchmark read throughput / identify bottlenecks when
# reading TTree branches from local files or XRootD.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '*--files[ROOT files to read]:file:_files -g "*.root"' \
  '*--trees[TTrees to read from the files]:tree name:' \
  '(--branches --branches-regex)--all-branches[read every branch from the specified files and trees]' \
  '(--all-branches --branches-regex)*--branches[branches with matching names (errors if any missing)]:branch name:' \
  '(--all-branches --branches)*--branches-regex[branches matching the given regex (errors if none match)]:regex:' \
  '--threads=[number of threads for file reading]:thread count:' \
  '--tasks-per-worker=[tasks generated per worker thread in MT mode]:tasks:' && ret=0

return ret
