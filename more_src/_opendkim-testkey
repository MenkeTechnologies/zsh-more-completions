#compdef opendkim-testkey

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --domain)'{-d,--domain}'+[domain]:domain:' \
  '(-k --key)'{-k,--key}'+[private key file]:file:_files' \
  '(-s --selector)'{-s,--selector}'+[selector]:selector:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-x --conf)'{-x,--conf}'+[config file]:file:_files' && ret=0

return ret
