#compdef opendkim-testkey
# Documentation: https://manpages.debian.org/bookworm/opendkim-tools/opendkim-testkey.8.en.html
# Reference accessed: 2026-05-20
# Verified: opendkim-testkey(8) - single-letter options only, no long forms.
# Removed: fabricated --help/--version/--domain/--key/--selector/--verbose/--conf
# long forms; opendkim-testkey accepts -d -s -k -v -x only.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-d+[signing domain]:domain:' \
  '-s+[selector within the domain]:selector:' \
  '-k+[private key file]:file:_files' \
  '-v[increase verbosity (repeatable)]' \
  '-x+[configuration file]:file:_files' && ret=0

return ret
