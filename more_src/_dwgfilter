#compdef dwgfilter
# Documentation: https://github.com/LibreDWG/libredwg/blob/master/programs/dwgfilter.1
# LibreDWG: apply JSON filters via JQ for structured search or mass value changes

local ret=1

_arguments -s -S \
  '--debug[keep the tmp json]' \
  '-i[write back in-place, with an updating JQ query]' \
  '--help[display help and exit]' \
  '--version[output version information and exit]' \
  '*:DWG file:_files -g "*.(dwg|DWG)"' && ret=0

return ret
