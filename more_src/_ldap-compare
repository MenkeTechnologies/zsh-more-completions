#compdef ldap-compare
# _ldap-compare — distro-shipped LDAP compare wrapper (alias of ldapcompare(1); performs an LDAP Compare operation; -H URI, -D bind DN, -w password, -y password file, -x simple bind, -Z TLS, -v verbose, -h help, -V version; positional: DN attr=value)
# upstream: https://git.openldap.org/openldap/openldap (clients/tools/ldapcompare)
# Flags from OpenLDAP clients/tools/ldapcompare.c on tip.

_ldap-compare() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-H+[URI]:uri:' \
        '-D+[bind DN]:dn:' \
        '-w+[password]:password:' \
        '-y+[password file]:file:_files' \
        '-x[simple bind]' \
        '-Z[start TLS]' \
        '-ZZ[require start TLS]' \
        '-v[verbose]' \
        '1:DN:' \
        '2:attr=value:'
}

_ldap-compare "$@"
