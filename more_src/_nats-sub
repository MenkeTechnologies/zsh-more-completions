#compdef nats-sub
# Documentation: https://man.archlinux.org/search?q=nats-sub
# Reference accessed: 2026-05-16

# nats-sub: simple NATS message subscriber
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[NATS servers]:servers:' \
  '-q[queue group]:group:' \
  '-t[show timestamps]' \
  '-tls[use TLS]' \
  '-creds[credentials file]:file:_files' \
  '-nkey[nkey file]:file:_files' \
  '-name[client name]:name:' \
  '-user[user]:user:_users' \
  '-pass[password]:password:' \
  '1:subject:' && ret=0
return ret
