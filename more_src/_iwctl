#compdef iwctl

# Zsh completion for iwctl - iwd (iNet wireless daemon) wireless control utility

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'adapter:manage wireless adapters'
  'ap:manage access point interfaces'
  'debug:manage debug features'
  'device:manage wireless devices'
  'diagnostics:manage diagnostic interfaces'
  'dpp:manage DPP interfaces'
  'known-networks:manage known networks'
  'station:manage station-mode interfaces'
  'wsc:manage WSC interfaces'
)

_iwctl_station_names() {
  local -a stations
  stations=(${(f)"$(iwctl station list 2>/dev/null | awk 'NR>4 && NF>0 {print $1}')"})
  _describe -t stations 'station' stations
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-p[specify passphrase]:passphrase:' \
  '--passphrase[specify passphrase]:passphrase:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'iwctl command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (station)
        if (( CURRENT == 2 )); then
          _iwctl_station_names && ret=0
        elif (( CURRENT == 3 )); then
          local -a station_cmds=(
            'list:list stations'
            'show:show station info'
            'scan:scan for networks'
            'get-networks:list available networks'
            'connect:connect to a network'
            'connect-hidden:connect to a hidden network'
            'disconnect:disconnect from current network'
            'get-hidden-access-points:list hidden access points'
          )
          _describe -t commands 'station command' station_cmds && ret=0
        else
          case $line[3] in
            (connect|connect-hidden)
              _message 'network name' && ret=0
              ;;
          esac
        fi
        ;;
      (device)
        if (( CURRENT == 2 )); then
          _iwctl_station_names && ret=0
        elif (( CURRENT == 3 )); then
          local -a device_cmds=(
            'list:list devices'
            'show:show device info'
            'set-property:set device property'
          )
          _describe -t commands 'device command' device_cmds && ret=0
        fi
        ;;
      (adapter)
        if (( CURRENT == 2 )); then
          local -a adapters
          adapters=(${(f)"$(iwctl adapter list 2>/dev/null | awk 'NR>4 && NF>0 {print $1}')"})
          _describe -t adapters 'adapter' adapters && ret=0
        elif (( CURRENT == 3 )); then
          local -a adapter_cmds=(
            'list:list adapters'
            'show:show adapter info'
            'set-property:set adapter property'
          )
          _describe -t commands 'adapter command' adapter_cmds && ret=0
        fi
        ;;
      (known-networks)
        if (( CURRENT == 2 )); then
          local -a known
          known=(${(f)"$(iwctl known-networks list 2>/dev/null | awk 'NR>4 && NF>0 {print $1}')"})
          _describe -t networks 'known network' known && ret=0
        elif (( CURRENT == 3 )); then
          local -a kn_cmds=(
            'list:list known networks'
            'forget:forget a known network'
            'show:show network info'
            'set-property:set network property'
          )
          _describe -t commands 'known-networks command' kn_cmds && ret=0
        fi
        ;;
      (*)
        _message 'arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
