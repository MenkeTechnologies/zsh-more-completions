#compdef cassandra
# Documentation: https://docs.datastax.com/en/cassandra-oss/3.0/cassandra/tools/toolsCUtility.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Apache Cassandra daemon startup script (bin/cassandra).

local -a arguments

arguments=(
    '-f[Start in foreground (default is background)]'
    '-h[Show help]'
    '-p[Log process ID to file]:pid file:_files'
    '-v[Print version and exit]'
    '-R[Allow root to run cassandra]'
    '-D-[Set JVM system property (e.g. cassandra.join_ring=false)]:property'
)

_arguments -s -S $arguments
