#compdef helixorient gmx-helixorient
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-helixorient.html
# gmx helixorient: calculate local pitch/bending/rotation/orientation inside helices

local ret=1

_arguments -s \
  '-s[portable xdr run input file]:file:_files' \
  '-f[trajectory file]:file:_files' \
  '-n[index file]:file:_files' \
  '-oaxis[generic data file for helix axis]:file:_files' \
  '-ocenter[generic data file for center]:file:_files' \
  '-orise[xvgr/xmgr file for rise data]:file:_files' \
  '-oradius[xvgr/xmgr file for radius]:file:_files' \
  '-otwist[xvgr/xmgr file for twist]:file:_files' \
  '-obending[xvgr/xmgr file for bending]:file:_files' \
  '-otilt[xvgr/xmgr file for tilt]:file:_files' \
  '-orot[xvgr/xmgr file for rotation]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[frame sampling interval]:time:' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-sidechain[calculate sidechain directions relative to helix axis]' \
  '-incremental[calculate incremental rather than total rotation/tilt]' && ret=0

return ret
