#compdef pcl_viewer
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/pcl_pcd_viewer.1.html
# Point Cloud Library viewer for displaying .pcd point cloud files

local ret=1

_arguments -s -S \
  '-bc[background color r,g,b]:r,g,b:' \
  '-fc[foreground color r,g,b]:r,g,b:' \
  '-ps[point size (1..64)]:size:' \
  '-opaque[rendered point cloud opacity (0..1)]:opacity:' \
  '-ax[enable on-screen XYZ axes scaled to n]:n:' \
  '-ax_pos[set axes X,Y,Z position in space]:x,y,z:' \
  '-cam[use given camera settings as initial view]' \
  '-multiview[enable/disable auto multi-viewport rendering]:flag:(0 1)' \
  '-normals[display every Xth point surface normal as lines]:x:' \
  '-normals_scale[resize the normal unit vector size]:scale:' \
  '-pc[display every Xth point principal curvatures as lines]:x:' \
  '-pc_scale[resize the principal curvatures vectors size]:scale:' \
  '*:point cloud:_files -g "*.pcd"' && ret=0

return ret
