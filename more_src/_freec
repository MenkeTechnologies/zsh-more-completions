#compdef freec control-freec
# Documentation: http://boevalab.inf.ethz.ch/FREEC/tutorial.html
# Control-FREEC copy-number and allelic-content caller

local ret=1

_arguments -s -S \
  '-conf[configuration file (required)]:config:_files' \
  '--conf[configuration file (required)]:config:_files' \
  '-sample[sample BAM file]:bam:_files' \
  '--sample[sample BAM file]:bam:_files' \
  '-control[control BAM file]:bam:_files' \
  '--control[control BAM file]:bam:_files' && ret=0

return ret
