#compdef zfs-receive
# _zfs-receive — OpenZFS zfs receive create snapshot from stream CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-receive() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-d[discard leading path]' \
        '-e[discard all but last path]' \
        '-F[force rollback]' \
        '-f[force]' \
        '-M+[mount mode]:m:(none always)' \
        '-n[no act]' \
        '-o+[property=value]:str:' \
        '-s[save partial state]' \
        '-u[do not mount]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-x+[exclude property]:str:' \
        '*:destination dataset:'
}

_zfs-receive "$@"
