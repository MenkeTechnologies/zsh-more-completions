#compdef cargo-prebuilt prebuilt
# _cargo-prebuilt — install prebuilt binaries of crates.io crates (cargo-prebuilt/cargo-prebuilt)
# upstream: https://github.com/cargo-prebuilt/cargo-prebuilt
# Flags from src/config.rs (bpaf).

_cargo-prebuilt() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(- *)--docs[print link to documentation]' \
        '--target=[target triple]:triple:' \
        '(-s --safe)'{-s,--safe}'[do not overwrite existing binaries]' \
        '(-u --update)'{-u,--update}'[update packages based on binary hash]' \
        '--index=[index URL or scheme]:index:' \
        '--pub-key=[CSV of base64-encoded public verifying keys]:keys:' \
        '--auth=[auth token for private indexes]:token:' \
        '--index-key=[index key from config file]:key:' \
        '--ci[disable reports/config/safe-mode]' \
        '--no-sig[do not verify info/hashes signatures]' \
        '--no-hash[do not verify archive hashes]' \
        '--hash-bins[also hash extracted binaries]' \
        '--path=[install directory for binaries]:dir:_files -/' \
        '--report-path=[report output directory]:dir:_files -/' \
        '--no-create-path[do not create bin/report folders]' \
        '--reports=[CSV of report types]:reports:' \
        '--config=[config file]:file:_files -g "*.toml"' \
        '(-r --require-config)'{-r,--require-config}'[fail if no config file]' \
        '--out[output events]' \
        '--get-latest[print latest versions and exit]' \
        '--color[force color on]' \
        '--no-color[force color off]' \
        '*:packages (csv with optional @VERSION):'
}

_cargo-prebuilt "$@"
