#compdef bcbio bcbio_nextgen.py bcbio-vm.py bcbio_setup_genome.py
# _bcbio — Brad Chapman bcbio-nextgen validated reproducible variant calling RNA-seq small RNA-seq pipelines (bcbio team, Python); argparse subcommands
# upstream: https://github.com/bcbio/bcbio-nextgen

_bcbio() {
    local -a sub=(
        'install:install bcbio components'
        'upgrade:upgrade bcbio'
        'server:run bcbio server'
        'graph:show pipeline graph'
        'logs:show logs'
        'status:show job status'
        'sequel:Pacific Biosciences Sequel'
        'aws:AWS subcommands'
        'azure:Azure subcommands'
        'check:check installation'
        'templates:list templates'
        'merge:merge samples'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-n+[N cores]:n:' \
        '--numcores=+[N cores]:n:' \
        '-t+[scheduler]:t:(local ipython sge slurm torque lsf htcondor pbspro)' \
        '--type=+[scheduler]:t:(local ipython sge slurm torque lsf htcondor pbspro)' \
        '-s+[scheduler]:str:' \
        '--scheduler=+[scheduler]:str:' \
        '-q+[queue]:str:' \
        '--queue=+[queue]:str:' \
        '-r+[resource arg]:str:' \
        '--resources=+[resource arg]:str:' \
        '--timeout=+[seconds]:n:' \
        '--retries=+[N]:n:' \
        '-w+[working dir]:dir:_files -/' \
        '--workdir=+[working dir]:dir:_files -/' \
        '--tag=+[tag]:str:' \
        '--queue-name=+[name]:str:' \
        '--debug[debug logging]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bcbio subcommand' sub ;;
        args)
            case $words[1] in
                install|upgrade) _arguments \
                    '--data[install data]' \
                    '--tools[install tools]' \
                    '--genomes=+[csv]:str:' \
                    '--aligners=+[csv]:str:' \
                    '--datatarget=+[csv]:str:' \
                    '--cwl[install CWL components]' ;;
                server) _arguments \
                    '--port=+[port]:port:_ports' \
                    '--biocontainer-info[show container info]' ;;
                aws) _arguments '1:aws cmd:(cluster iam ami)' ;;
                templates) _arguments '*:template name:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_bcbio "$@"
