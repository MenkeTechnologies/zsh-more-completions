#compdef polimp
# Documentation: https://starlink.eao.hawaii.edu/docs/sun223.htx/sun223ss9.html
# POLPACK: copies FITS keyword values into the POLPACK extension.

local ret=1

_arguments -s -S \
  'IN=[input data files]:ndf:_files' \
  'TABLE=[FITS to POLPACK translation table]:file:_files' \
  'NAMELIST=[output file listing processed files]:file:_files' \
  'QUIET=[suppress screen output]:flag:(TRUE FALSE)' \
  '*:ndf:_files' && ret=0

return ret
