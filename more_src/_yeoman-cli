#compdef yeoman-cli
# _yeoman-cli — Yeoman scaffolding tool yo CLI alias (yeoman team, JavaScript); custom argparse
# upstream: https://github.com/yeoman/yo

_yeoman-cli() {
    local -a sub=(
        '--generators:list installed generators'
        '--help:show help'
        '--version:show version'
        '--no-color:disable color'
        '--no-insight:disable insight'
        '--insight:enable insight'
        '--force-install:retry install on fail'
        '--local-only:do not check global'
        '--skip-cache:do not cache prompts'
        'help:show help'
        'doctor:run yo doctor'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--generators[list installed generators]' \
        '--no-color[disable color]' \
        '--no-insight[disable insight]' \
        '--insight[enable insight]' \
        '--force-install[retry install on fail]' \
        '--local-only[do not check global]' \
        '--skip-cache[do not cache prompts]' \
        '--skip-install[do not install dependencies]' \
        '--force[overwrite files that exist]' \
        '-f[overwrite files that exist]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yo subcommand' sub ;;
    esac
}

_yeoman-cli "$@"
