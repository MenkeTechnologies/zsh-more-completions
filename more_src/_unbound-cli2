#compdef unbound-control2
# Documentation: https://man.archlinux.org/search?q=unbound-control2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start daemon'
  'stop:stop daemon'
  'reload:reload config'
  'reload_keep_cache:reload but keep cache'
  'verbosity:set verbosity 0-5'
  'log_reopen:reopen log'
  'stats:print statistics'
  'stats_noreset:print but do not reset stats'
  'status:show daemon status'
  'local_zone:add local zone'
  'local_zone_remove:remove local zone'
  'local_data:add local data'
  'local_data_remove:remove local data'
  'local_zones:add zones from stdin'
  'local_zones_remove:remove zones from stdin'
  'local_datas:add datas from stdin'
  'local_datas_remove:remove datas from stdin'
  'view_local_zone:add per-view zone'
  'view_local_zone_remove:remove per-view zone'
  'view_local_data:add per-view data'
  'view_local_data_remove:remove per-view data'
  'view_local_zones:per-view zones from stdin'
  'view_local_zones_remove:per-view zones remove'
  'view_local_datas:per-view datas from stdin'
  'view_local_datas_remove:per-view datas remove'
  'view_list_local_zones:list per-view local zones'
  'view_list_local_data:list per-view local data'
  'lookup:print server that would resolve name'
  'dump_cache:print cache'
  'load_cache:read cache'
  'flush:flush record'
  'flush_type:flush record/type'
  'flush_zone:flush zone'
  'flush_bogus:flush bogus'
  'flush_negative:flush negative'
  'flush_stats:flush stats'
  'flush_requestlist:flush request list'
  'dump_requestlist:print request list'
  'dump_infra:print infra cache'
  'flush_infra:flush infra cache'
  'set_option:set runtime option'
  'get_option:get runtime option'
  'list_stubs:list stub zones'
  'list_forwards:list forward zones'
  'list_local_zones:list local zones'
  'list_local_data:list local data'
  'list_insecure:list insecure points'
  'forward_add:add forward zone'
  'forward_remove:remove forward zone'
  'stub_add:add stub zone'
  'stub_remove:remove stub zone'
  'forward:set forward up'
  'view_list_local_zones:list per-view zones'
  'view_list_local_data:list per-view data'
  'insecure_add:add neg trust anchor'
  'insecure_remove:remove neg trust anchor'
  'auth_zone_reload:reload auth zone'
  'auth_zone_transfer:transfer auth zone'
  'rpz_enable:enable RPZ'
  'rpz_disable:disable RPZ'
  'add_cookie_secret:add cookie secret'
  'drop_cookie_secret:drop cookie secret'
  'activate_cookie_secret:activate cookie secret'
  'print_cookie_secrets:print cookie secrets'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-c+[config file]:file:_files -g "*.conf"' \
  '*-s+[server addr]:s:' \
  '*-q[quiet]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'unbound-control command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
