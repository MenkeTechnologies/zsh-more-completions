#compdef dunst

# Zsh completion for dunst - notification daemon

_arguments -s -S \
  '(-conf --config)'{-conf,--config}'[path to config file]:config file:_files' \
  '-verbosity[set log level]:level:(crit warn mesg info debug)' \
  '-print[print notifications to stdout]' \
  '-startup_notification[display startup notification]' \
  '(-v -version --version)'{-v,-version,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
