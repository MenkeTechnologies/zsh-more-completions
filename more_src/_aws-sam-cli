#compdef sam
# _aws-sam-cli — AWS SAM CLI (Amazon Web Services, Python); build/test/deploy SAM serverless apps locally + to AWS
# upstream: https://github.com/aws/aws-sam-cli

_aws-sam-cli() {
    local -a sub=(
        'build:build SAM app'
        'completion:print shell completion'
        'delete:delete SAM app'
        'deploy:deploy SAM app'
        'docs:open SAM docs'
        'help:show help'
        'init:initialize new SAM app'
        'list:list resources'
        'local:run locally'
        'logs:fetch logs'
        'package:package SAM app'
        'pipeline:pipeline subcommands'
        'publish:publish SAM app'
        'remote:invoke remote resource'
        'sync:sync local + cloud'
        'traces:fetch X-Ray traces'
        'validate:validate template'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--debug[debug log]' \
        '--info[show env info]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sam subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--no-interactive[no interactive]' \
                    '-a+[architecture]:arch:(arm64 x86_64)' \
                    '--architecture+[architecture]:arch:(arm64 x86_64)' \
                    '-r+[runtime]:runtime:' \
                    '--runtime+[runtime]:runtime:' \
                    '-p+[package type]:type:(Zip Image)' \
                    '--package-type+[package type]:type:(Zip Image)' \
                    '-d+[dependency manager]:str:' \
                    '--dependency-manager+[dependency manager]:str:' \
                    '-n+[name]:str:' \
                    '--name+[name]:str:' \
                    '--app-template+[app template]:str:' \
                    '--no-input[no input]' \
                    '-l+[location]:str:' \
                    '--location+[location]:str:' \
                    '--save-params[save params]' ;;
                build) _arguments \
                    '-b+[build dir]:dir:_files -/' \
                    '--build-dir+[build dir]:dir:_files -/' \
                    '-c[cached build]' \
                    '--cached[cached build]' \
                    '-u[use container]' \
                    '--use-container[use container]' \
                    '-t+[template file]:file:_files' \
                    '--template+[template file]:file:_files' \
                    '-p[parallel]' \
                    '--parallel[parallel]' \
                    '-m+[manifest]:file:_files' \
                    '--manifest+[manifest]:file:_files' \
                    '--mount-with+[mount mode]:mode:(READ WRITE)' \
                    '*:function:' ;;
                deploy) _arguments \
                    '--guided[interactive]' \
                    '-g[interactive]' \
                    '--stack-name+[stack name]:str:' \
                    '--s3-bucket+[s3 bucket]:str:' \
                    '--region+[region]:region:' \
                    '--profile+[profile]:profile:' \
                    '--capabilities+[capabilities]:caps:' \
                    '--confirm-changeset[confirm changeset]' \
                    '--no-confirm-changeset[skip confirm]' \
                    '--role-arn+[role ARN]:arn:' \
                    '--parameter-overrides+[parameter overrides]:str:' \
                    '--tags+[tags]:str:' \
                    '--no-execute-changeset[no execute]' \
                    '--fail-on-empty-changeset[fail on empty changeset]' \
                    '--resolve-s3[resolve s3]' \
                    '--resolve-image-repos[resolve image repos]' ;;
                local) _arguments '1:local cmd:(generate-event invoke start-api start-lambda)' '*:args:' ;;
                pipeline) _arguments '1:pipeline cmd:(init bootstrap)' '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_aws-sam-cli "$@"
