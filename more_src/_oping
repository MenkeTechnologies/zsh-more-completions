#compdef oping noping
# Documentation: https://noping.cc/documentation/oping/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-4[force IPv4]' \
  '-6[force IPv6]' \
  '-c+[number of ICMP packets to send]:count:' \
  '-i+[interval between sends]:interval:' \
  '-w+[wait timeout for replies]:secs:' \
  '-t+[time to live]:ttl:' \
  '-Q+[Quality of Service of outgoing packets]:qos:' \
  '-I+[source address]:srcaddr:' \
  '-D+[outgoing interface]:device:_net_interfaces' \
  '-m+[mark on outgoing packets]:mark:' \
  '-f+[hosts file]:file:_files' \
  '-O+[write RTT measurements file]:file:_files' \
  '-A+[use audible bell on reply]:n:' \
  '-B+[bell threshold ms]:ms:' \
  '-C+[ANSI color]:color:(0 1)' \
  '-M+[max output rows]:n:' \
  '*:host:_hosts' && ret=0

return ret
