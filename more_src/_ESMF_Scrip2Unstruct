#compdef ESMF_Scrip2Unstruct
# Documentation: https://earthsystemmodeling.org/docs/release/latest/ESMF_refdoc/node3.html
# ESMF: convert a SCRIP format grid file to an ESMF or UGRID unstructured grid file

local ret=1

_arguments -s -S \
  '1:input SCRIP grid file:_files' \
  '2:output unstructured grid file:_files' \
  '3:dual flag:((0\:"straight conversion" 1\:"dual mesh"))' \
  '4:output file format:(ESMF UGRID)' && ret=0

return ret
