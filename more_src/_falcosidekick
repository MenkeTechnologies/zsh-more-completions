#compdef falcosidekick
# Documentation: https://github.com/falcosecurity/falcosidekick
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-c --config-file)'{-c,--config-file}'=[config file]:file:_files -g "*.(yaml|yml)"' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]'
