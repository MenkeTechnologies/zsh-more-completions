#compdef falcosidekick
# Documentation: https://man.archlinux.org/search?q=falcosidekick
# Reference accessed: 2026-05-16

_arguments -s \
  '(-c --config-file)'{-c,--config-file}'=[config file]:file:_files -g "*.(yaml|yml)"' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]'
