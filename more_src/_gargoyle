#compdef gargoyle

# Gargoyle: cross-platform interactive fiction player
# Documentation: https://github.com/garglk/garglk/wiki
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:story file:_files -g "*.(z3|z4|z5|z6|z7|z8|zblorb|blorb|blb|ulx|gblorb|hex|t3)"' && ret=0
return ret
