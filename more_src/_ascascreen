#compdef ascascreen
# Performs the basic cleaning for the unscreened ASCA science files

local ret=1

_arguments -s \
  '-a[use all the minor modes found]' \
  '-d[set all values at their defaults]' \
  '-e[set the file name extension to use]:extension:' \
  '-f[use the supplied boolean expression for file selection]:expression:' \
  '-h[display help information]' \
  '-m[use the minor mode with the most events automatically]' \
  '-q[only write the .xco file and quit, do not run Xselect]' \
  '-v[give the version history]' \
  '-w[location of the wish shell]:wish path:_files' \
  '*:file:_files' && ret=0

return ret
