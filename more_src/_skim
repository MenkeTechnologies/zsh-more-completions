#compdef sk

# Zsh completion for skim (sk - fuzzy finder in Rust)

_arguments -s -S \
  '(-e --exact)'{-e,--exact}'[enable exact-match]' \
  '(-i)-i[case-insensitive match]' \
  '(+i)+i[case-sensitive match]' \
  '--regex[enable regex mode]' \
  '--algo[fuzzy matching algorithm]:algo:(skim_v1 skim_v2 clangd)' \
  '(-n --nth)'{-n,--nth}'[comma-separated list of field index expressions]:fields:' \
  '--with-nth[transform items for display]:fields:' \
  '(-d --delimiter)'{-d,--delimiter}'[field delimiter regex]:delimiter:' \
  '--tac[reverse the order of input]' \
  '--no-sort[do not sort the result]' \
  '--tiebreak[comma-separated list of sort criteria]:criteria:' \
  '(-m --multi)'{-m,--multi}'[enable multi-select]' \
  '--no-multi[disable multi-select]' \
  '--bind[custom key bindings]:bindings:' \
  '--color[color configuration]:scheme:' \
  '--no-hscroll[disable horizontal scroll]' \
  '--height[display height]:height:' \
  '--min-height[minimum height]:height:' \
  '--layout[layout]:layout:(default reverse reverse-list)' \
  '--reverse[shorthand for --layout=reverse]' \
  '--margin[screen margin]:margin:' \
  '--inline-info[display info inline]' \
  '--prompt[input prompt]:prompt:' \
  '--cmd-prompt[command prompt]:prompt:' \
  '--header[sticky header]:header:' \
  '--header-lines[number of header lines]:lines:' \
  '--ansi[enable processing of ANSI color codes]' \
  '--tabstop[number of spaces for a tab]:spaces:' \
  '(-0 --exit-0)'{-0,--exit-0}'[exit if there is no match]' \
  '(-1 --select-1)'{-1,--select-1}'[auto-select the only match]' \
  '(-f --filter)'{-f,--filter}'[filter mode]:query:' \
  '--print-query[print query as the first line]' \
  '--expect[comma-separated list of keys]:keys:' \
  '--read0[read input delimited by NUL]' \
  '--print0[print output delimited by NUL]' \
  '--no-clear[do not clear screen on exit]' \
  '(-c --cmd)'{-c,--cmd}'[command to invoke dynamically]:command:' \
  '(-I --replstr)'{-I,--replstr}'[replace string for dynamic command]:str:' \
  '--interactive[start in interactive mode]' \
  '--pre-select-n[pre-select first N items]:n:' \
  '--pre-select-pat[pre-select items matching pattern]:pattern:' \
  '--pre-select-items[pre-select items from string]:items:' \
  '--pre-select-file[pre-select items from file]:file:_files' \
  '(-q --query)'{-q,--query}'[start the finder with this query]:query:' \
  '--cmd-query[specify query for interactive mode]:query:' \
  '--preview[preview command]:command:' \
  '--preview-window[preview window layout]:layout:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && return 0
