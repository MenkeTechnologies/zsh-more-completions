#compdef Concordance
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/validation/Concordance.java
# GATK: evaluate a callset against a truth callset, producing summary concordance metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--truth=[truth VCF of passing variants]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  {-eval,--evaluation=}'[eval VCF to assess]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  {-C,--confidence=}'[confidence region interval list]:interval:_files' \
  {-S,--summary=}'[table of summary statistics output]:file:_files' \
  '--filter-analysis=[table of each filter contribution to FN and FP]:file:_files' \
  '--true-positives-and-false-negatives=[VCF to write true positives and false negatives]:vcf:_files' \
  '--tpfn=[VCF to write true positives and false negatives]:vcf:_files' \
  '--true-positives-and-false-positives=[VCF to write true positives and false positives]:vcf:_files' \
  '--tpfp=[VCF to write true positives and false positives]:vcf:_files' \
  '--filtered-true-negatives-and-false-negatives=[VCF to write filtered true negatives and false negatives]:vcf:_files' \
  '--ftnfn=[VCF to write filtered true negatives and false negatives]:vcf:_files' \
  '*:argument:_files' && ret=0

return ret
