#compdef bv
# Documentation: https://github.com/Dicklesworthstone/beads_viewer
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Dicklesworthstone/beads_viewer — graph-aware TUI for the Beads issue tracker.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--bdb=[path to beads.jsonl database]:file:_files' \
  '--as-of=[historical git ref for point-in-time view]:ref:' \
  '--label=[scope output to a specific label]:label:' \
  '--format=[output format]:format:(toon)' \
  '--recipe=[apply predefined recipe]:recipe:' \
  '-o+[output file]:file:_files' \
  '--export-md[generate Markdown status report]' \
  '--export-graph=[interactive HTML visualization]:file:_files' \
  '--graph-format=[graph export format]:format:(json dot mermaid)' \
  '--graph-root=[subgraph from specific root id]:id:' \
  '--graph-depth=[limit traversal depth]:n:' \
  '--graph-include-closed[include closed issues in graph]' \
  '--graph-title=[custom visualization title]:title:' \
  '--robot-triage[robot mode: triage recommendations]' \
  '--robot-next[robot mode: top pick + claim command]' \
  '--robot-plan[robot mode: parallel execution tracks]' \
  '--robot-priority[robot mode: priority misalignment]' \
  '--robot-insights[robot mode: full graph metrics]' \
  '--robot-label-health[robot mode: per-label health]' \
  '--robot-label-flow[robot mode: cross-label dependency analysis]' \
  '--robot-label-attention[robot mode: attention-ranked labels]' \
  '--attention-limit=[limit attention list size]:n:' \
  '--robot-history[robot mode: bead-to-commit correlations]' \
  '--robot-diff[robot mode: changes since git ref]' \
  '--diff-since=[git ref for --robot-diff]:ref:' \
  '--robot-burndown=[robot mode: sprint burndown]:sprint:' \
  '--robot-forecast=[robot mode: ETA prediction]:id-or-all:' \
  '--robot-alerts[robot mode: stale issues and cascades]' \
  '--robot-suggest[robot mode: hygiene recommendations]' \
  '--robot-graph[robot mode: dependency graph export]' \
  '--robot-file-beads=[robot mode: find beads touching file]:path:_files' \
  '--robot-orphans[robot mode: detect unlinked commits]' \
  '--robot-help[full robot protocol documentation]' \
  '--agents-check[check if blurb present in agent file]' \
  '--agents-add[add blurb to AGENTS.md/CLAUDE.md]' \
  '--agents-remove[remove blurb from agent file]' \
  '--agents-update[update blurb to latest version]' \
  '--agents-dry-run[preview agent file changes]' && ret=0

return ret
