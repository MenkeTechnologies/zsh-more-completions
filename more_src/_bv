#compdef bv
# Documentation: https://man.archlinux.org/search?q=bv
# Reference accessed: 2026-05-16

# Zsh completion for beads_viewer TUI (bv)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*::args:{ _message "see bv --help" }' && ret=0

return ret
