#compdef slim-lint
# Documentation: https://github.com/sds/slim-lint
# slim-lint linter for Slim templates

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help documentation]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '(-V --verbose-version)'{-V,--verbose-version}'[display verbose version information]' \
  '(-c --config)'{-c,--config}'=[specify which configuration file to use]:file:_files' \
  '(-e --exclude)'{-e,--exclude}'=[list of file paths to exclude]:files:_files' \
  '(-i --include-linter)'{-i,--include-linter}'=[specify which linters to include]:linters' \
  '(-x --exclude-linter)'{-x,--exclude-linter}'=[specify which linters to exclude]:linters' \
  '(-r --reporter)'{-r,--reporter}'=[specify which reporter to use]:reporter' \
  '--show-linters[display available linters]' \
  '--show-reporters[display available reporters]' \
  '--stdin-file-path=[make slim-lint treat stdin as a file]:file:_files' \
  '*:file:_files' && ret=0

return ret
