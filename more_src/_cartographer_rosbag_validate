#compdef cartographer_rosbag_validate
# Documentation: https://github.com/cartographer-project/cartographer_ros/blob/master/cartographer_ros/cartographer_ros/rosbag_validate_main.cc
# Validate sensor data in a ROS bag for Cartographer

local ret=1

_arguments -s -S \
  '(-help --help)'{-help,--help}'[show help]' \
  '-bag_filename=[bag to process]:bag:_files -g "*.bag"' \
  '-dump_timing[dump per-sensor timing information to CSV files]' \
  '*:bag:_files -g "*.bag"' && ret=0

return ret
