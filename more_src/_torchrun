#compdef torchrun

# Zsh completion for PyTorch distributed training launcher

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--nnodes=[number of nodes]:num_nodes' \
  '--nproc-per-node=[number of processes per node]:nproc' \
  '--rdzv-backend=[rendezvous backend]:backend:(static c10d etcd etcd-v2)' \
  '--rdzv-endpoint=[rendezvous endpoint host:port]:endpoint' \
  '--rdzv-id=[rendezvous job ID]:id' \
  '--rdzv-conf=[rendezvous configuration]:config' \
  '--standalone[standalone single-node mode]' \
  '--max-restarts=[maximum number of worker group restarts]:num' \
  '--monitor-interval=[interval in seconds to check worker status]:seconds' \
  '--start-method=[multiprocessing start method]:method:(spawn fork forkserver)' \
  '--role=[user-defined role for workers]:role' \
  '--node-rank=[rank of this node]:rank' \
  '--master-addr=[master node address]:address' \
  '--master-port=[master node port]:port' \
  '--local-addr=[local address]:address' \
  '--log-dir=[directory for log files]:directory:_directories' \
  '--redirects=[redirect stdout/stderr]:mode:(0 1 2 3)' \
  '--tee=[tee stdout/stderr to console and log]:mode:(0 1 2 3)' \
  '-m[run library module as a script]' \
  '--module[run library module as a script]' \
  '--no-python[do not prepend python to script]' \
  '--run-path[run as a runpath]' \
  '*:training script:_files -g "*.py"' && ret=0

return ret
