#compdef localgpt
# _localgpt — PromptEngineer48 LocalGPT chat with documents on local hardware using GPU CUDA Apple Silicon (PromptEngineer48 team, Python); argparse
# upstream: https://github.com/PromtEngineer/localGPT

_localgpt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--device-type=+[device]:d:(cpu cuda mps ipu xpu mkldnn opengl opencl ideep hip ve fpga ort xla lazy vulkan mtia hpu meta privateuseone)' \
        '--show-sources[show sources]' \
        '--use-history[use history]' \
        '--model-type=+[type]:t:(llama mistral non_llama)' \
        '--save-qa[save qa to csv]' \
        '--persist-directory=+[index dir]:dir:_files -/' \
        '-pd+[index dir]:dir:_files -/' \
        '--source-directory=+[docs dir]:dir:_files -/' \
        '-sd+[docs dir]:dir:_files -/' \
        '--model-id=+[model id]:str:' \
        '--model-basename=+[model basename]:str:' \
        '--embedding-model-name=+[embedding model]:str:' \
        '--n-gpu-layers=+[N]:n:' \
        '--n-batch=+[N]:n:' \
        '--n-ctx=+[N]:n:' \
        '--max-new-tokens=+[N]:n:' \
        '--temperature=+[F]:f:' \
        '--top-p=+[F]:f:' \
        '--top-k=+[N]:n:' \
        '--repeat-penalty=+[F]:f:' \
        '--max-tokens=+[N]:n:' \
        '--api-port=+[port]:port:_ports' \
        '--api-host=+[host]:host:_hosts'
}

_localgpt "$@"
