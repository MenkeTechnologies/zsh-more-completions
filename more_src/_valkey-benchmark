#compdef valkey-benchmark

# valkey-benchmark: benchmark client for Valkey
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '-h[host]:host:_hosts' \
  '-p[port]:port:' \
  '-s[socket]:file:_files' \
  '-a[password]:pass:' \
  '--user[user]:user:_users' \
  '-c[clients (default 50)]:n:' \
  '-n[total requests]:n:' \
  '-d[data size]:n:' \
  '-k[keep alive]:bool:(0 1)' \
  '-P[pipeline]:n:' \
  '-q[quiet]' \
  '--csv[output csv]' \
  '-l[loop]' \
  '-t[tests]:tests:' \
  '-I[idle mode]' \
  '-r[random keys (keyspace size)]:n:' \
  '--threads[number of threads]:n:' \
  '--tls[use TLS]' \
  '--cert=[TLS cert]:file:_files' \
  '--key=[TLS key]:file:_files' \
  '--cacert=[TLS CA]:file:_files' \
  '*::valkey-benchmark args:_files' && ret=0
return ret
