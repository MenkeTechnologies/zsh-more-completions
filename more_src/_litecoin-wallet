#compdef litecoin-wallet
# Documentation: https://github.com/litecoin-project/litecoin (src/bitcoin-wallet.cpp + configure.ac BITCOIN_WALLET_TOOL_NAME=litecoin-wallet)
# Reference accessed: 2026-05-29
# Litecoin Core standalone wallet tool (Bitcoin Core fork). Subcommands: info, create, salvage.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-version[print version and exit]' \
  '(- *)-help[print help and exit]' \
  '(- *)-?[print help and exit]' \
  '(- *)-h[print help and exit]' \
  '-datadir=[data directory]:dir:_directories' \
  '-wallet=[wallet name]:name:' \
  '-debug=[output debugging information (category)]:category:' \
  '-printtoconsole[send trace/debug info to console]' \
  '(-testnet -signet -regtest)-testnet[use Litecoin testnet]' \
  '(-testnet -signet -regtest)-signet[use Litecoin signet]' \
  '(-testnet -signet -regtest)-regtest[use Litecoin regression test mode]' \
  '-chain=[chain to use]:chain:(main test signet regtest)' \
  '1:command:((info\:"get wallet info" create\:"create new wallet file" salvage\:"attempt to recover private keys from a corrupt wallet"))' \
  && ret=0

return ret
