#compdef saw

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'groups:list log groups'
  'streams:list log streams for a group'
  'get:get log events'
  'watch:watch log events in real-time'
  'version:print version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--profile=[AWS profile]:profile' \
  '--region=[AWS region]:region' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'saw command' commands && ret=0
    ;;
  args)
    case $words[1] in
      get|watch)
        _arguments \
          '--help[show help]' \
          '--prefix=[stream prefix filter]:prefix' \
          '--start=[start time]:start' \
          '--stop=[stop time]:stop' \
          '--filter=[filter pattern]:pattern' \
          '--pretty[pretty print JSON]' \
          '--raw[output raw log text]' \
          '--expand[expand JSON fields]' \
          '1:log group' && ret=0
        ;;
      streams)
        _arguments \
          '--help[show help]' \
          '--prefix=[stream prefix filter]:prefix' \
          '--start=[start time]:start' \
          '--stop=[stop time]:stop' \
          '--order-by=[order by]:field:(LogStreamName LastEventTime)' \
          '--descending[sort descending]' \
          '1:log group' && ret=0
        ;;
      groups)
        _arguments \
          '--help[show help]' \
          '--prefix=[group prefix filter]:prefix' && ret=0
        ;;
    esac
    ;;
esac

return ret
