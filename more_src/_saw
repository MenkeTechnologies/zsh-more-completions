#compdef saw
# Documentation: https://github.com/TylerBrock/saw
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'groups:list log groups'
  'streams:list log streams for a group'
  'get:get log events'
  'watch:watch log events in real-time'
  'version:print version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--profile=[AWS profile]:profile' \
  '--region=[AWS region]:region' \
  '--expand[explode JSON with indenting]' \
  '--rawString[print JSON strings without escaping]' \
  '--invert[invert colors for light schemes]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'saw command' commands && ret=0
    ;;
  args)
    case $words[1] in
      get)
        _arguments \
          '--help[show help]' \
          '--prefix=[stream prefix filter]:prefix' \
          '--start=[start time (e.g. -2h or 2018-06-26)]:start' \
          '--stop=[end time]:stop' \
          '--filter=[CloudWatch filter pattern]:pattern' \
          '--pretty[toggle timestamp/stream-name prefix]' \
          '1:log group' && ret=0
        ;;
      watch)
        _arguments \
          '--help[show help]' \
          '--prefix=[stream prefix filter]:prefix' \
          '--filter=[CloudWatch filter pattern]:pattern' \
          '--raw[toggle timestamp/stream-name prefix]' \
          '1:log group' && ret=0
        ;;
      streams)
        _arguments \
          '--help[show help]' \
          '1:log group' && ret=0
        ;;
      groups)
        _arguments \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
