#compdef radacct
# _radacct — FreeRADIUS radacct (legacy accounting-report tool: pretty-prints detail accounting records and summarises session statistics per user, NAS-Identifier and time window; -d data dir, -f detail file, -F format string, -n NAS-Identifier filter, -t start time, -T end time, -h help, -v version)
# upstream: https://github.com/FreeRADIUS/freeradius-server (radacct)
# Flags from FreeRADIUS/freeradius-server src/main/radacct.c on tip.

_radacct() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-d+[data dir]:dir:_files -/' \
        '-f+[detail file]:file:_files' \
        '-F+[format string]:format:' \
        '-n+[NAS-Identifier]:nas:' \
        '-t+[start time]:time:' \
        '-T+[end time]:time:'
}

_radacct "$@"
