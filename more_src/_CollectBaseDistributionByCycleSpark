#compdef CollectBaseDistributionByCycleSpark
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/spark/pipelines/metrics/CollectBaseDistributionByCycleSpark.java
# GATK Spark: collect base distribution per cycle in a SAM/BAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  {-O,--output=}'[output metrics file]:file:_files' \
  {-C,--chart=}'[output chart PDF file]:pdf:_files -g "*.pdf"' \
  {-A,--aligned-reads-only}'[only include aligned reads]' \
  {-F,--pf-reads-only}'[only include PF reads]' \
  '*:argument:_files' && ret=0

return ret
