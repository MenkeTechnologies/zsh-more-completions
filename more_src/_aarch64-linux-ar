#compdef aarch64-linux-ar aarch64-linux-gnu-ar
# _aarch64-linux-ar — GNU binutils aarch64-linux-ar CLI cross-arch archive utility creating modifying extracting from static library archives .a for ARMv8 AArch64 Linux build environments adding deleting member object files in archive listing thin-archive S indexing for fast symbol lookup (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_aarch64-linux-ar() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--target=+[bfd]:str:' \
        '--plugin=+[plugin]:file:_files -g "*.so *.dylib"' \
        '*:archive and members:_files -g "*.a *.o"'
}

_aarch64-linux-ar "$@"
