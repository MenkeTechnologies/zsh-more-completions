#compdef nvautoflash

# nvautoflash: NVIDIA Tegra automatic flashing wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-d[device]:dev:' \
  '-c[config]:file:_files' \
  '-i[image]:file:_files' \
  '*::nvautoflash args:_files' && ret=0
return ret
