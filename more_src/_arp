#compdef arp
# _arp — OpenBSD arp (display + modify the kernel ARP cache; -a dumps all, -d deletes, -s installs static entry (temp/permanent/pub), -F flushes, -W announces ether_addr via gratuitous ARP)
# upstream: https://github.com/openbsd/src (usr.sbin/arp)
# Flags from usr.sbin/arp/arp.8 on tip.

_arp() {
    _arguments \
        '-a[display all entries]' \
        '-d[delete entry]' \
        '-F[flush all entries]' \
        '-n[numeric (no DNS)]' \
        '-V+[routing domain]:rdomain:' \
        '-f+[bulk-load from file]:file:_files' \
        '-s+[install static entry: hostname ether_addr]:hostname:_hosts' \
        '-W+[announce ether_addr via gratuitous ARP]:ether_addr:' \
        '*:hostname:_hosts'
}

_arp "$@"
