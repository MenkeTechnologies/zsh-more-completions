#compdef imodsortsurf
# Documentation: https://bio3d.colorado.edu/imod/doc/man/imodsortsurf.html
# Sort contours into surfaces or surfaces into objects

local ret=1

_arguments -s \
  '-o[Restrict the sorting to objects in the given list of object...]:value' \
  '-s[Split surfaces into new objects.]' \
  '-e[Use existing surfaces when splitting them into new objects....]' \
  '-c[Make new objects the same color as the object from which...]' \
  '-k[Keep the surface numbers when moving contours into new...]' \
  '-r[less than the given value, specified as described above.]:value' \
  '-R[Retains only the contours or meshes that form surfaces with...]' \
  '*:file:_files' && ret=0

return ret
