#compdef streamnet StreamNet
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/StreamReachAndWatershed.html
# TauDEM: stream reach and watershed delineation

local ret=1

_arguments -s -S \
  '-fel[input pit-filled elevation grid]:felfile:_files' \
  '-p[input D8 flow directions grid]:pfile:_files' \
  '-ad8[input D8 contributing area grid]:ad8file:_files' \
  '-src[input stream raster grid]:srcfile:_files' \
  '-ord[output Strahler stream order grid]:ordfile:_files' \
  '-tree[output stream network topology text file]:treefile:_files' \
  '-coord[output network coordinates text file]:coordfile:_files' \
  '-net[output channel network vector (OGR writeable)]:netfile:_files' \
  '-w[output watershed grid]:wfile:_files' \
  '-o[input outlets file (OGR readable dataset)]:outletfile:_files' \
  '-netlyr[layer name for output network file]:net layer name:' \
  '-sw[delineate whole area draining network as single watershed]' \
  '(-lyrno)-lyrname[OGR layer name for outlets]:layer name:' \
  '(-lyrname)-lyrno[OGR layer number for outlets]:layer number:' \
  '*:file:_files' && ret=0

return ret
