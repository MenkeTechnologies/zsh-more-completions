#compdef xterm

# Zsh completion for xterm - terminal emulator for X

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-display[X display to use]:display' \
  '-geometry[window geometry]:geometry' \
  '-bg[background color]:color' \
  '-fg[foreground color]:color' \
  '-fn[text font]:font:_x_font' \
  '-fb[bold text font]:font:_x_font' \
  '-fa[freetype font face]:face' \
  '-fs[freetype font size]:size' \
  '-fw[wide font]:font:_x_font' \
  '-title[window title]:title' \
  '-name[application name]:name' \
  '-class[application class]:class' \
  '-e[command to execute]:command:_command_names -e' \
  '-hold[keep window open after command exits]' \
  '-into[window id to embed into]:windowid' \
  '-ls[start login shell]' \
  '+ls[do not start login shell]' \
  '-iconic[start iconified]' \
  '-j[enable jump scrolling]' \
  '+j[disable jump scrolling]' \
  '-rightbar[put scrollbar on right]' \
  '-leftbar[put scrollbar on left]' \
  '-sb[enable scrollbar]' \
  '+sb[disable scrollbar]' \
  '-sl[scrollback lines]:lines' \
  '-ti[terminal id]:terminal id' \
  '-tm[terminal modes]:modes' \
  '-tn[terminal name]:name:(xterm xterm-256color vt100 vt220)' \
  '-T[title]:title' \
  '-n[icon name]:name' \
  '-cr[cursor color]:color' \
  '-ms[pointer color]:color' \
  '-bd[border color]:color' \
  '-bw[border width]:pixels' \
  '-aw[enable auto-wrap]' \
  '+aw[disable auto-wrap]' \
  '-bc[enable blinking cursor]' \
  '+bc[disable blinking cursor]' \
  '-bdc[enable blinking cursor on focus]' \
  '+bdc[disable blinking cursor on focus]' \
  '-cu[enable curses fix]' \
  '+cu[disable curses fix]' \
  '-dc[enable dynamic color changes]' \
  '+dc[disable dynamic color changes]' \
  '-fullscreen[start in fullscreen mode]' \
  '+fullscreen[do not start in fullscreen mode]' \
  '-maximized[start maximized]' \
  '+maximized[do not start maximized]' \
  '-lc[enable locale mode]' \
  '+lc[disable locale mode]' \
  '-mc[multiclick timeout in ms]:milliseconds' \
  '-rv[reverse video]' \
  '+rv[no reverse video]' \
  '-samename[disable title changes]' \
  '+samename[allow title changes]' \
  '-sf[enable sun function keys]' \
  '+sf[disable sun function keys]' \
  '-si[disable repositioning on output]' \
  '+si[enable repositioning on output]' \
  '-sk[enable repositioning on keypress]' \
  '+sk[disable repositioning on keypress]' \
  '-u8[enable UTF-8 mode]' \
  '+u8[disable UTF-8 mode]' \
  '-ut[disable utmp entry]' \
  '+ut[enable utmp entry]' \
  '-vb[enable visual bell]' \
  '+vb[disable visual bell]' \
  '-wf[wait for window to be mapped]' \
  '+wf[do not wait for window to be mapped]' \
  '-ziconbeep[icon name prefix percentage]:percent' \
  '-xrm[X resource]:resource' \
  '-help[show help]' \
  '-version[show version]' && ret=0

return ret
