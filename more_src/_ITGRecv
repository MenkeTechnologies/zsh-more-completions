#compdef ITGRecv
# Documentation: https://traffic.comics.unina.it/software/ITG/manual/
# D-ITG receiver component: receives traffic flows generated by ITGSend

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '-P[enable thread high priority (Windows only)]' \
  '-a+[bind data channels to a specific address]:address' \
  '-i+[bind data channels to a specific network interface]:interface' \
  '-Si+[bind signaling channels to a specific network interface]:interface' \
  '-Sp+[signaling channel port number]:port' \
  '-l+[enable logging to file]:logfile:_files' \
  '-L+[enable remote logging to ITGLog]:log spec' \
  '-q+[number of packets to push to the log at once]:log buffer size' \
  '-H+[enable passive mode toward specified ITGSend instance]:address' \
  '-n+[number of outgoing UDP packets for NAT traversal]:num packets' && ret=0

return ret
