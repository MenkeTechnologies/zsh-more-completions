#compdef bunchee

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-w[watch mode]' \
  '--watch[watch mode]' \
  '-m[generate source maps]' \
  '--sourcemap[generate source maps]' \
  '--cwd=[working directory]:directory:_directories' \
  '--dts[generate declaration files]' \
  '--no-dts[skip declaration files]' \
  '--runtime=[target runtime]:runtime:(node browser)' \
  '--env=[environment variables]:variables' \
  '--external=[external dependencies]:packages' \
  '--no-external[bundle all dependencies]' \
  '--target=[ES target]:target:(es2015 es2016 es2017 es2018 es2019 es2020 es2021 es2022 esnext)' \
  '-o+[output file]:output:_files' \
  '--output=[output file]:output:_files' \
  '--format=[output format]:format:(esm cjs)' \
  '--minify[enable minification]' \
  '--no-clean[do not clean output directory]' \
  '*:entry file:_files -g "*.{ts,tsx,js,jsx,mjs,mts}"' && ret=0

return ret
