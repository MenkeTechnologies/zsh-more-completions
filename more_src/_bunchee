#compdef bunchee
# Documentation: https://github.com/huozhi/bunchee
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# huozhi/bunchee — zero-config bundler for JavaScript/TypeScript packages.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-w[watch mode]' \
  '--watch[watch mode]' \
  '-m[generate source maps]' \
  '--sourcemap[generate source maps]' \
  '--cwd=[working directory]:directory:_directories' \
  '--dts[generate declaration files]' \
  '--no-dts[skip declaration files]' \
  '--runtime=[target runtime]:runtime:(node browser)' \
  '--env=[comma-separated env vars]:variables' \
  '--external=[external dependencies (comma-separated)]:packages' \
  '--no-external[bundle all dependencies]' \
  '--target=[ES target]:target:(es2015 es2016 es2017 es2018 es2019 es2020 es2021 es2022 esnext)' \
  '-o+[output file]:output:_files' \
  '--output=[output file]:output:_files' \
  '-f+[output format]:format:(esm cjs)' \
  '--format=[output format]:format:(esm cjs)' \
  '--minify[enable minification]' \
  '--clean[clean output directory before build]' \
  '--no-clean[do not clean output directory]' \
  '--success=[command to run after successful build]:command' \
  '*:entry file:_files -g "*.{ts,tsx,js,jsx,mjs,mts}"' && ret=0

return ret
