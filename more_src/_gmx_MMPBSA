#compdef gmx_MMPBSA
# Documentation: https://valdes-tresanco-ms.github.io/gmx_MMPBSA/dev/gmx_MMPBSA_command-line/
# MM/PBSA and MM/GBSA end-state free energy for GROMACS/AMBER/CHARMM/NAMD

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--input-file-help[print all available input-file options]' \
  '--create_input[create new input file]:type:(gb pb rism ala decomp nmode all)' \
  '(-O --overwrite)'{-O,--overwrite}'[allow output files to be overwritten]' \
  '-prefix[prefix for intermediate files (default _GMXMMPBSA_)]:prefix' \
  '-nogui[do not open gmx_MMPBSA_ana after calculations]' \
  '(-s --stability)'{-s,--stability}'[perform stability calculation]' \
  '-rewrite-output[parse existing output without re-running]' \
  '--clean[clean temporary files and exit]' \
  '-i[MM/PBSA input file]:in:_files' \
  '-xvvfile[XVV file for 3D-RISM]:xvv:_files' \
  '-o[output file with statistics]:dat:_files' \
  '-do[decomposition statistics output]:dat:_files' \
  '-eo[per-frame energy terms CSV]:csv:_files' \
  '-deo[decomposition per-residue CSV]:csv:_files' \
  '-cs[complex structure file (tpr/pdb/gro)]:struct:_files' \
  '-ci[complex index file]:ndx:_files -g "*.ndx"' \
  '-cg[receptor and ligand groups in complex index]:groups' \
  '-ct[complex trajectories]:traj:_files' \
  '-cp[complex topology file]:top:_files' \
  '-cr[complex reference structure (PDB)]:pdb:_files -g "*.pdb"' \
  '-rs[unbound receptor structure file]:struct:_files' \
  '-ri[receptor index file]:ndx:_files -g "*.ndx"' \
  '-rg[receptor group in index file]:group' \
  '-rt[unbound receptor trajectories]:traj:_files' \
  '-rp[receptor topology file]:top:_files' \
  '-lm[ligand mol2 file for parametrization]:mol2:_files -g "*.mol2"' \
  '-ls[unbound ligand structure file]:struct:_files' \
  '-li[ligand index file]:ndx:_files -g "*.ndx"' \
  '-lg[ligand group in index file]:group' \
  '-lt[unbound ligand trajectories]:traj:_files' \
  '-lp[ligand topology file]:top:_files' \
  '*:file:_files' && ret=0

return ret
