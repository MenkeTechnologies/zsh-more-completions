#compdef othercell
# Documentation: https://www.ccp4.ac.uk/html/othercell.html
# CCP4: list alternative unit cells and lattice symmetries

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-tolerance+[angular tolerance in degrees (default 3)]:degrees:' \
  'xmlout[direct output to an XML file]:xml:_files -g "*.xml"' && ret=0

return ret
