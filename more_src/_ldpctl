#compdef ldpctl
# _ldpctl — OpenBSD ldpctl (control + introspect the running ldpd(8) MPLS Label Distribution Protocol daemon; show neighbors/bindings/discovery/lib/fib/l2vpn, clear neighbors, fib couple/decouple, reload)
# upstream: https://github.com/openbsd/src (usr.sbin/ldpctl)
# Commands from usr.sbin/ldpctl/ldpctl.8 on tip.

_ldpctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'ldpctl command' \
                '(show:show subsystem state clear:clear neighbor entries fib:fib couple/decouple reload:reload ldpd configuration log:log level (brief|verbose))'
            ;;
        args)
            case $line[1] in
                show) _describe -t commands 'show target' '(interfaces discovery neighbor lib bindings fib l2vpn)' ;;
                fib) _describe -t commands 'fib subcommand' '(couple decouple)' ;;
                log) _describe -t commands 'log level' '(brief verbose)' ;;
                clear) _describe -t commands 'clear subcommand' '(neighbors)' ;;
            esac
            ;;
    esac
}

_ldpctl "$@"
