#compdef otf2bdf
# otf2bdf — convert OpenType/TrueType fonts to BDF bitmap format

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '-p+[set point size]:point size:' \
  '-r+[set resolution in dpi]:resolution dpi:' \
  '-o+[set output file]:output file:_files' \
  '-l+[subset character range]:range (start-end):' \
  '-c+[character code]:character code:' \
  '-pid+[set platform ID]:platform ID:' \
  '-eid+[set encoding ID]:encoding ID:' \
  '-v[print progress]' \
  '*:font file:_files -g "*.(otf|ttf|OTF|TTF)(-.)"' && ret=0

return ret
