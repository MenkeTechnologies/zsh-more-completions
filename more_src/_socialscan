#compdef socialscan
# Documentation: https://github.com/iojw/socialscan
# OSINT: check username and email usage/availability on online platforms.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show program version and exit]' \
  '*'{-p,--platforms}'[platforms to query (default all)]:platform:' \
  '--view-by[sort results by platform or query]:mode:(platform query)' \
  '(-a --available-only)'{-a,--available-only}'[only print usernames/emails that are available]' \
  '(-c --cache-tokens)'{-c,--cache-tokens}'[cache tokens for platforms requiring multiple requests]' \
  '(-i --input)'{-i+,--input=}'[file containing list of queries to execute]:file:_files' \
  '--proxy-list=[file containing HTTP proxy servers]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[show query responses as they are received]' \
  '--show-urls[display profile URLs for usernames on supported platforms]' \
  '--json=[output results in JSON to file]:file:_files' \
  '*:query:' && ret=0

return ret
