#compdef bleve
# ============================================================================
# bleve - command-line tool for the bleve full-text
#          search library (Go, Apache-2.0)
#
# Author : Couchbase + the bleve maintainers
#           (blevesearch)
# Upstream: https://github.com/blevesearch/bleve
#
# `bleve` is the operator CLI for the bleve indexing
# library - the canonical Go full-text + numeric + geo-
# spatial + vector indexing engine. The library was
# created at Couchbase in 2014 and is the indexing
# back-end for Couchbase Server's Full-Text Search
# feature, the zincsearch search server, and ~700 other
# Go projects with search requirements. The CLI lets
# operators bulk-load documents, run queries, dump
# index contents, inspect mappings, and check index
# integrity from the terminal.
#
# Usage:
#   bleve <command> [args] [flags]
#
# Commands (cobra Command tree):
#   bulk        - bulk-load from newline-delimited
#                  JSON files
#   check       - verify the index contents
#   count       - count documents in the index
#   create      - create a new index
#   dictionary  - print the term dictionary for a field
#   dump        - dump the index contents
#   fields      - list the fields in the index
#   index       - add files to the index
#   mapping     - print the index mapping
#   query       - run a query against the index
#   registry    - list bleve components compiled in
#   scorch      - scorch-specific subcommands (ascii,
#                  deleted, info, internal, snapshot)
#
# Common args:
#   <index-path>        - path to the bleve index dir
#
# create flags:
#   -m, --mapping <file>     - path to JSON index
#                               mapping file
#   -s, --store <type>       - storage type
#                               (default: bleve.Config
#                               default)
#   -i, --index <type>       - index type
#                               (default: bleve.Config
#                               default)
#
# query flags:
#   -r, --repeat <n>         - repeat query N times
#                               (default 1)
#   -l, --limit <n>          - limit results (default 10)
#   -s, --skip <n>           - skip first N results
#                               (default 0)
#   -x, --explain            - explain result scoring
#       --highlight          - highlight matching text
#                               (default true)
#       --fields             - load stored fields
#   -t, --type <type>        - query type (default
#                               query_string)
#   -f, --field <field>      - restrict to a single field
#                               (not for query_string)
#   -b, --sort-by <field>    - sort by field
#
# scorch sub-subcommands:
#   ascii / deleted / info / internal / snapshot
#
# The roaring lane is built on `github.com/RoaringBitmap/
# roaring` (declared at upstream go.mod HEAD as a direct
# dep, used in `index/upsidedown` + `search/searcher`
# for the inverted index posting lists), Daniel Lemire's
# Go reference implementation of the Roaring Bitmap
# data structure - github.com/RoaringBitmap/roaring,
# 2700+ stars. Lemire is the algorithm's CO-INVENTOR
# (Chambi-Lemire-Kaser-Godin, "Better bitmap performance
# with Roaring bitmaps", Software Practice & Experience
# 2016) and the personal maintainer of the C + C++ +
# Go + Java reference implementations under the
# RoaringBitmap GitHub umbrella.
#
# bleve uses roaring bitmaps as the canonical posting-
# list data structure: every indexed field's inverted
# index maps `term -> roaring_bitmap(doc_id)`. Query
# evaluation becomes a sequence of roaring intersection /
# union / difference operations - the same operational
# model that Lucene + Elasticsearch + Druid + Spark use
# for their bitmap indexes. This makes bleve's query
# planner directly comparable to Lucene's, despite the
# pure-Go vs JVM implementation difference.
#
# Cross-language interop matters here because bleve
# indexes can be opened by tools that speak the
# RoaringFormatSpec wire format - the C/C++ CRoaring
# library can deserialize bleve's posting lists for
# debugging or migration, and vice versa. This is a
# subtle but practical consequence of the umbrella-
# canonical pattern.
#
# ----------------------------------------------------------------------------
# AXIS 250 :: Roaring Bitmap compressed bitmap index
#              data structure (LANDMARK AXIS)
# Round 1449 :: Go slot 2 of 4 :: continues Axis 250
#
# Cross-language canonical library family for this axis:
#   Rust    : RoaringBitmap/roaring-rs    [R1448 _stoolap]
#   Go      : RoaringBitmap/roaring       [R1449 THIS FILE]
#             (Lemire's reference impl)
#   TS/Node : SalvatorePreviti/roaring-node
#                                          [R1450 closing]
#             (napi-rs binding to CRoaring)
#
# Lemire's Go implementation is the structurally
# important canonical in this axis cluster because of
# the unique *algorithm-author = library-author* pattern.
# The cross-language Roaring umbrella spans ~12
# language implementations (Rust, Go, Java, C, C++,
# Python, JavaScript, Swift, Haskell, Erlang, OCaml,
# Ruby), all governed under the same GitHub organization
# (github.com/RoaringBitmap), but Lemire personally
# maintains the C + C++ + Go + Java reference
# implementations:
#   - CRoaring (C): the spec-canonical, also the source
#     for many language bindings (Python, JavaScript,
#     Swift, etc. wrap CRoaring via FFI)
#   - C++ wrapper: thin idiomatic C++ over CRoaring
#   - Go (RoaringBitmap/roaring): pure-Go implementation
#     - this file's canonical for Axis 250's Go slot
#   - Java (RoaringBitmap/RoaringBitmap): pure-Java
#     implementation used by Lucene + Druid + Spark
#
# Lemire is a professor at Université du Québec à
# Montréal + an expert on data structures + a
# Distinguished Engineer at Microsoft Research. His
# work on bitmap indexes traces from the 2014 paper
# through ~10 years of follow-up research + library
# maintenance + cross-language coordination. The
# RoaringBitmap umbrella's longevity + cross-impl
# byte-format compatibility is the direct result of
# this single-author governance shape.
#
# This unique pattern echoes:
#   - BurntSushi/toml + toml-test (Axis 243): spec-
#     conformance-suite-author = library-author
#   - BLAKE3-team/BLAKE3 (Axis 245): algorithm-authors
#     = library-authors
#   - Roaring umbrella (Axis 250 THIS AXIS): algorithm-
#     co-inventor = umbrella-maintainer for the
#     reference impls
#
# Each pattern produces unusually high cross-language
# interop quality because the canonical author can
# coordinate spec + tests + implementations together.
#
# Cross-language interop at the wire format level:
# RoaringFormatSpec (github.com/RoaringBitmap/
# RoaringFormatSpec) defines the byte layout
# byte-for-byte; every umbrella implementation
# round-trips byte-identically. bleve's on-disk
# posting lists can be re-read by CRoaring + the C++
# wrapper + the Java impl + the Rust impl + the
# JavaScript impl, modulo any per-implementation
# extensions to the Container types.
# ============================================================================

_bleve() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '1: :_bleve_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                bulk)
                    _arguments \
                        '1:index path:_files -/' \
                        '*:data path:_files' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                check|count|dump|fields|mapping)
                    _arguments \
                        '1:index path:_files -/' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                create)
                    _arguments \
                        '(-m --mapping)'{-m,--mapping}'[JSON index mapping file]:file:_files -g "*.json"' \
                        '(-s --store)'{-s,--store}'[storage type]:type:' \
                        '(-i --index)'{-i,--index}'[index type]:type:' \
                        '1:index path:_files -/' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                dictionary)
                    _arguments \
                        '1:index path:_files -/' \
                        '2:field name:' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                index)
                    _arguments \
                        '1:index path:_files -/' \
                        '*:data path:_files' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                query)
                    _arguments \
                        '(-r --repeat)'{-r,--repeat}'[repeat query N times]:n:' \
                        '(-l --limit)'{-l,--limit}'[limit number of results]:n:' \
                        '(-s --skip)'{-s,--skip}'[skip first N results]:n:' \
                        '(-x --explain)'{-x,--explain}'[explain result scoring]' \
                        '--highlight[highlight matching text]' \
                        '--fields[load stored fields]' \
                        '(-t --type)'{-t,--type}'[query type]:type:(query_string match match_phrase term prefix wildcard regexp fuzzy bool numeric_range date_range)' \
                        '(-f --field)'{-f,--field}'[restrict query to field]:field:' \
                        '(-b --sort-by)'{-b,--sort-by}'[sort by field]:field:' \
                        '1:index path:_files -/' \
                        '2:query:' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                registry)
                    _arguments '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                scorch)
                    _arguments \
                        '1:subcommand:(ascii deleted info internal snapshot)' \
                        '*::path:_files' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_bleve_cmds() {
    local -a cmds
    cmds=(
        'bulk:bulk-load from newline-delimited JSON files'
        'check:verify the index contents'
        'count:count documents in the index'
        'create:create a new index'
        'dictionary:print the term dictionary for a field'
        'dump:dump the index contents'
        'fields:list the fields in the index'
        'index:add files to the index'
        'mapping:print the index mapping'
        'query:run a query against the index'
        'registry:list compiled-in bleve components'
        'scorch:scorch-specific subcommands'
    )
    _describe -t commands 'bleve command' cmds
}

_bleve "$@"
