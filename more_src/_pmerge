#compdef pmerge
# pkgcore package merge tool

local ret=1

_arguments -s -S \
  '--config=[specify configuration file]:config:_files' \
  '--color=[enable/disable color]:color:(true false)' \
  '--debug[enable debug mode]' \
  '-1[stop after first phase]' \
  '-a[ask before merging]' \
  '-C[unmerge packages]' \
  '-D[deep dependency resolution]' \
  '-e[empty tree]' \
  '-f[fetchonly]' \
  '-n[noreplace]' \
  '-N[newuse]' \
  '-o[onlydeps]' \
  '-O[nodeps]' \
  '-p[pretend]' \
  '-u[update]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '-s[set]:set name:' \
  '--domain=[specify domain]:domain:' \
  '--preload-vdb-state[preload vdb state]' \
  '-h[show help]' \
  '--help[show help]' \
  '*:package atom:' && ret=0

return ret
