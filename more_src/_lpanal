#compdef lpanal
# Csound linear predictive coding analysis for LPC resynthesis opcodes

local ret=1

_arguments -s -S \
  '-a[store pole values instead of filter coefficients]' \
  '-s+[override input sampling rate]:srate' \
  '-c+[channel to analyze]:channel' \
  '-b+[begin time in seconds]:begin' \
  '-d+[duration in seconds]:duration' \
  '-p+[number of poles (max 50)]:npoles' \
  '-h+[hop size in samples (max 500)]:hopsize' \
  '-C+[text for the lpfile header comment field]:comment' \
  '-P+[lowest pitch-tracking frequency (0 disables)]:mincps' \
  '-Q+[highest pitch-tracking frequency]:maxcps' \
  '-v+[verbosity level]:level:(0 1 2)' \
  '-X[write machine-independent format]' \
  '*:soundfile:_files' && ret=0

return ret
