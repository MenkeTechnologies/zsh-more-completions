#compdef crio

# Zsh completion for crio - CRI-O container runtime

_arguments -s -S \
  '(-c --config)'{-c,--config}'[path to configuration file]:file:_files' \
  '--conmon[path to conmon binary]:path:_files' \
  '--conmon-cgroup[cgroup to be used for conmon process]:cgroup:' \
  '--conmon-env[environment variable list for conmon process]:env:' \
  '(-l --log)'{-l,--log}'[log file path]:file:_files' \
  '--log-level[log level]:level:(trace debug info warn error fatal panic)' \
  '--log-dir[log directory]:dir:_files -/' \
  '--log-format[log format]:format:(text json)' \
  '--log-filter[filter for log messages]:filter:' \
  '--log-size-max[maximum log size in bytes]:bytes:' \
  '--log-journald[log to systemd journal]' \
  '--listen[path to CRI-O socket]:socket path:_files' \
  '--stream-address[bind address for streaming]:address:' \
  '--stream-port[bind port for streaming]:port:' \
  '--pause-command[path to pause command in pause container]:command:' \
  '--pause-image[pause container image]:image:' \
  '--pause-image-auth-file[path to auth file for pause image]:file:_files' \
  '--global-auth-file[path to global auth file]:file:_files' \
  '(-r --root)'{-r,--root}'[root directory for storage]:dir:_files -/' \
  '--runroot[run root directory for storage]:dir:_files -/' \
  '(-s --storage-driver)'{-s,--storage-driver}'[storage driver]:driver:(overlay vfs devmapper)' \
  '--storage-opt[storage driver option]:option:' \
  '--default-runtime[default OCI runtime]:runtime:' \
  '--runtimes[OCI runtimes]:runtimes:' \
  '--seccomp-profile[seccomp profile path]:file:_files' \
  '--apparmor-profile[apparmor profile name]:profile:' \
  '--cgroup-manager[cgroup manager]:manager:(cgroupfs systemd)' \
  '--default-capabilities[default capabilities]:capabilities:' \
  '--default-sysctls[default sysctls]:sysctls:' \
  '--default-ulimits[default ulimits]:ulimits:' \
  '--pids-limit[maximum number of processes allowed in a container]:limit:' \
  '--cni-config-dir[CNI configuration directory]:dir:_files -/' \
  '--cni-default-network[default CNI network name]:network:' \
  '--cni-plugin-dir[CNI plugin directory]:dir:_files -/' \
  '--image-volumes[image volume handling]:policy:(mkdir bind ignore)' \
  '--hooks-dir[OCI hooks directory]:dir:_files -/' \
  '--insecure-registry[insecure registry]:registry:' \
  '--registry[registry to prepend for unqualified images]:registry:' \
  '--default-transport[default image transport]:transport:' \
  '--signature-policy[signature policy file]:file:_files' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]'
