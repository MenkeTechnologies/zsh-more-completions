#compdef ezmlm-make
# Documentation: https://man.archlinux.org/search?q=ezmlm-make
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-+[switch char]:char:' \
  '-a[allow non-subscriber posting]' \
  '-A[only subscribers can post]' \
  '-b[enable bounces]' \
  '-B[disable bounces]' \
  '-c[enable command processing]' \
  '-C[disable command processing]' \
  '-d[enable digest]' \
  '-D[disable digest]' \
  '-e[edit existing list]' \
  '-E[no edit]' \
  '-f[append footer]' \
  '-F[no footer]' \
  '-g[guard list]' \
  '-G[no guard]' \
  '-h[disable headers]' \
  '-i[enable indexing]' \
  '-I[disable indexing]' \
  '-j[allow unsubscriptions]' \
  '-J[disable unsubscriptions]' \
  '-l[enable list command]' \
  '-L[disable list command]' \
  '-m[enable moderation]' \
  '-M[disable moderation]' \
  '-n[enable archive numbering]' \
  '-N[disable archive numbering]' \
  '-o[only moderators can post]' \
  '-O[anyone can post]' \
  '-p[allow public archive]' \
  '-P[private archive]' \
  '-q[enable request]' \
  '-Q[disable request]' \
  '-r[enable remote admin]' \
  '-R[disable remote admin]' \
  '-s[enable subscription log]' \
  '-S[disable subscription log]' \
  '-t+[trailer text]:text:' \
  '-T+[trailer file]:file:_files' \
  '-u[allow only subscribers to issue commands]' \
  '-U[anyone can issue commands]' \
  '-w[enable warn]' \
  '-W[disable warn]' \
  '-x+[extra config dir]:dir:_files -/' \
  '-y[enable confirmation]' \
  '-Y[disable confirmation]' \
  '1:dir:_files -/' \
  '2:dot:' \
  '3:local:' \
  '4:host:_hosts' \
  '5:code:' && ret=0

return ret
