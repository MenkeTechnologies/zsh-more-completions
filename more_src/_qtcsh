#compdef qtcsh
# Documentation: https://docs.open-mpi.org/en/main/
# Grid Engine: tcsh extended for transparent remote execution of commands

local ret=1

_arguments -s \
  '-A[verbose mode with diagnostic output for remote execution]' \
  '-B[submit remote tasks in batch mode, queuing if they cannot start]' \
  '-L[execute all commands locally even if listed in qtask files]' \
  '-R[enforce remote execution even if JOB_ID is set]' \
  '*::arg:_files' && ret=0

return ret
