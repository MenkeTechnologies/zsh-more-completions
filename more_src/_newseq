#compdef newseq
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/newseq.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# EMBOSS newseq: create new sequence(s) from user-typed/scripted residues
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-name=[output sequence name/identifier]:name:' \
  '-description=[output sequence description]:desc:' \
  '-type=[sequence type]:type:(N P)' \
  '-sequence=[sequence string to create]:seq:' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat5=[output format]:format:(fasta embl genbank swiss gcg pir raw)' \
  '-osextension5=[output file extension]:ext:' \
  '-osname5=[output base name]:name:' \
  '-osdirectory5=[output directory]:dir:_files -/' \
  '-osdbname5=[output database name]:name:' \
  '-ossingle5[separate file per sequence]' \
  '*:output:_files' && ret=0
return ret
