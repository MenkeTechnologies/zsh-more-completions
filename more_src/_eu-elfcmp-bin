#compdef eu-elfcmp
# _eu-elfcmp-bin — elfutils ELF binary comparator (Ulrich Drepper, Red Hat); semantic ELF file diff
# upstream: https://sourceware.org/elfutils

_eu-elfcmp-bin() {
    _arguments \
        '(-l --verbose)'{-l,--verbose}'[verbose differences]' \
        '(-q --quiet)'{-q,--quiet}'[only exit status]' \
        '--gaps+[handle gaps]:mode:(ignore match)' \
        '--hash-inexact[allow hash table reordering]' \
        '--ignore-build-id[ignore build IDs]' \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '1:file1:_files' \
        '2:file2:_files'
}

_eu-elfcmp-bin "$@"
