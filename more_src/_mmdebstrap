#compdef mmdebstrap
# Documentation: https://manpages.debian.org/bookworm/mmdebstrap/mmdebstrap.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mmdebstrap (create Debian chroot environments)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--variant=[chroot variant]:variant:(extract custom essential apt required minbase buildd important debootstrap standard)' \
  '--mode=[execution mode]:mode:(auto sudo root unshare fakeroot fakechroot chrootless)' \
  '--format=[output format]:format:(auto directory tar squashfs ext2 null)' \
  '--architectures=[extra architectures to enable]:archs:' \
  '*--include=[additional packages to install]:packages:' \
  '--components=[archive components]:components:' \
  '*--aptopt=[apt configuration option]:option:' \
  '*--dpkgopt=[dpkg configuration option]:option:' \
  '*--keyring=[keyring file for package verification]:keyring:_files' \
  '*--setup-hook=[hook after initial setup]:command:' \
  '*--extract-hook=[hook after extraction]:command:' \
  '*--essential-hook=[hook after installing essential]:command:' \
  '*--customize-hook=[hook after customization]:command:' \
  '--hook-dir=[directory with hook scripts]:directory:_files -/' \
  '*--skip=[phases or safety checks to skip]:phase:' \
  '--logfile=[write log to file]:log file:_files' \
  '(--simulate --dry-run)'{--simulate,--dry-run}'[simulate]' \
  '(-q --quiet -s --silent)'{-q,--quiet,-s,--silent}'[suppress stderr]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '--man[show man page]' \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:suite:(stable testing unstable sid bookworm trixie forky bullseye buster)' \
  '2:target:_files' \
  '3:mirror URL:' && ret=0

return ret
