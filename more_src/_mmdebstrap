#compdef mmdebstrap

# Zsh completion for mmdebstrap (create Debian chroot environments)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--variant[chroot variant]:variant:(extract custom essential apt minbase buildd important debootstrap standard)' \
  '--mode[execution mode]:mode:(auto sudo root unshare fakeroot fakechroot chrootless proot)' \
  '--format[output format]:format:(auto directory tar squashfs ext2 null)' \
  '--arch[target architecture]:architecture:(amd64 i386 arm64 armhf armel mips64el mipsel ppc64el s390x riscv64)' \
  '*--include[additional packages to install]:packages' \
  '*--exclude[packages to exclude]:packages' \
  '--components[archive components]:components' \
  '--architectures[extra architectures to enable]:architectures' \
  '*--aptopt[apt configuration option]:option' \
  '*--dpkgopt[dpkg configuration option]:option' \
  '*--keyring[keyring file for package verification]:keyring:_files' \
  '*--setup-hook[hook to run after initial setup]:command' \
  '*--extract-hook[hook to run after extraction]:command' \
  '*--essential-hook[hook to run after installing essential]:command' \
  '*--customize-hook[hook to run after customization]:command' \
  '--hook-dir[directory containing hook scripts]:directory:_files -/' \
  '*--skip[phases to skip]:phase:(download extract essential apt)' \
  '--merged-usr[use merged /usr layout]' \
  '--no-merged-usr[do not use merged /usr layout]' \
  '--verbose[be verbose]' \
  '--debug[print debug information]' \
  '--quiet[produce less output]' \
  '--logfile[write log to file]:log file:_files' \
  '--dry-run[simulate, do not actually create chroot]' \
  '--man[show man page]' \
  '--force-check-gpg[force GPG verification]' \
  '--help[show help]' \
  '--version[show version]' \
  '1:suite:(stable testing unstable sid bookworm trixie forky bullseye buster)' \
  '2:target:_files' \
  '3:mirror URL' && ret=0

return ret
