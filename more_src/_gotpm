#compdef gotpm

# https://github.com/google/go-tpm-tools — cobra (cmd/*.go)
local -a _gotpm_cmds
_gotpm_cmds=(
  'attest:remote attestation helpers'
  'flush:flush TPM handles'
  'read:read PCRs or NV indices'
  'pubkey:dump public keys'
  'token:token commands'
  'register:EK registration protocol'
  'seal:seal data to TPM'
  'unseal:unseal sealed blob'
  'verify:verify quotes / certs'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[print version bundle]' \
  '--quiet[suppress success output]' \
  '--verbose[extra diagnostics]' \
  '1: :->cmd' \
  '*:: :->args'

case $state in
  cmd)     
    _describe -t commands 'gotpm command' _gotpm_cmds
    ;;
  args) _default ;;
esac
