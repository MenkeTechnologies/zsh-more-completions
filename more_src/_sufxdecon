#compdef sufxdecon
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/decon_shaping/sufxdecon.c
# random noise attenuation by FX-DECONvolution

local ret=1

_arguments -s -S \
  'taper=[taper]:taper:' \
  'fmin=[fmin]:fmin:' \
  'fmax=[fmax]:fmax:' \
  'twlen=[twlen]:twlen:' \
  'ntrw=[ntrw]:ntrw:' \
  'ntrf=[ntrf]:ntrf:' \
  'verbose=[verbose]:verbose:' \
  'tmpdir=[tmpdir]:tmpdir:' \
  '*:file:_files' && ret=0

return ret
