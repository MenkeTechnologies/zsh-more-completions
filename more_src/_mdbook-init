#compdef mdbook-init

# Zsh completion for mdbook init subcommand (standalone)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--theme[copy default theme into source directory]' \
  '--title=[set book title]:title' \
  '--ignore=[create .gitignore or .hgignore]:vcs:(git hg none)' \
  '--force[skip confirmation prompts]' \
  '1:directory:_directories' && ret=0

return ret
