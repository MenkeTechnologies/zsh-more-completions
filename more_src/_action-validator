#compdef action-validator

_arguments -s -S \
  '(- *)'{-h,--help}'[help]' \
  '(- *)'{-V,--version}'[version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose validation output]' \
  '--rootdir=[root directory for glob matching]:path:_directories' \
  '*:GitHub Action/Workflow YAML file:_files -g \*.\(yaml\|yml\)'
