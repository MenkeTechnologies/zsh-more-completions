#compdef juliaup

# Zsh completion for juliaup - Julia version manager

_juliaup() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands=(
        'add:add a specific Julia version or channel to juliaup'
        'default:set the default Julia version'
        'list:list all available channels'
        'remove:remove a Julia version from juliaup'
        'status:show all installed Julia versions'
        'update:update all or a specific channel to the latest Julia version'
        'self:manage juliaup itself'
        'help:print help for a command'
    )

    _arguments -C \
        '(- *)--help[print help]' \
        '(- *)--version[print version]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'juliaup command' commands
            ;;
        args)
            case $words[1] in
                add)
                    _arguments -s -S \
                        '(- *)--help[print help]' \
                        '1:channel:'
                    ;;
                default)
                    _arguments -s -S \
                        '(- *)--help[print help]' \
                        '1:channel:'
                    ;;
                remove)
                    _arguments -s -S \
                        '(- *)--help[print help]' \
                        '1:channel:'
                    ;;
                update)
                    _arguments -s -S \
                        '(- *)--help[print help]' \
                        '1::channel:'
                    ;;
                list|status)
                    _arguments -s -S \
                        '(- *)--help[print help]'
                    ;;
                self)
                    local -a self_commands=(
                        'update:update juliaup itself'
                        'uninstall:uninstall juliaup'
                    )
                    _arguments -C \
                        '(- *)--help[print help]' \
                        '1:self command:->selfcmd'
                    case $state in
                        selfcmd)
                            _describe -t self_commands 'self command' self_commands
                            ;;
                    esac
                    ;;
                help)
                    _arguments -s -S \
                        '1:command:(add default list remove status update self)'
                    ;;
            esac
            ;;
    esac
}

_juliaup "$@"
