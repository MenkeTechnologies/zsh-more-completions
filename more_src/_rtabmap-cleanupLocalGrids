#compdef rtabmap-cleanupLocalGrids
# Documentation: https://github.com/introlab/rtabmap/blob/master/tools/CleanupLocalGrids/main.cpp
# Clean up local occupancy grids in an RTAB-Map database

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--radius[radius in cells around empty cell to clear obstacles]:n' \
  '--scan[filter also scans, not only local grids]' \
  '*:database:_files -g "*.db"' && ret=0

return ret
