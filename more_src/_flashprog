#compdef flashprog
# Documentation: https://man.archlinux.org/search?q=flashprog
# Reference accessed: 2026-05-16

# flashprog: SPI flash chip programmer (flashrom fork)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-R[show version]' \
  '(- *)--version[show version]' \
  '-r[read flash to file]:file:_files' \
  '--read=[read flash to file]:file:_files' \
  '-w[write flash from file]:file:_files' \
  '--write=[write flash from file]:file:_files' \
  '-v[verify flash against file]:file:_files' \
  '--verify=[verify flash against file]:file:_files' \
  '-E[erase flash]' \
  '--erase[erase flash]' \
  '-n[do not verify after write]' \
  '--noverify[do not verify after write]' \
  '-N[do not verify upon recovery]' \
  '--noverify-all[do not verify upon recovery]' \
  '-x[extract individual regions]' \
  '--extract[extract individual regions]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '-c[chip]:chip:' \
  '--chip=[chip]:chip:' \
  '-p[programmer]:programmer:(internal dummy nic3com nicrealtek gfxnvidia drkaiser satasii satamv atavia atapromise it8212 ft2232_spi serprog buspirate_spi developerbox dediprog ene_lpc rayer_spi pony_spi nicintel nicintel_eeprom nicintel_spi ogp_spi linux_mtd linux_spi mstarddc_spi pickit2_spi parade_lspcon mediatek_i2c_spi realtek_mst_i2c_spi ch341a_spi ch347_spi)' \
  '--programmer=[programmer]:programmer:' \
  '-l[layout file]:file:_files' \
  '--layout=[layout file]:file:_files' \
  '-i[image region:file]:region:' \
  '--image=[image region:file]:region:' \
  '--ifd[use Intel Flash Descriptor]' \
  '--fmap[use FMAP layout]' \
  '--fmap-file=[FMAP file]:file:_files' \
  '-L[list supported programmers, chips, etc]' \
  '--list-supported[list supported programmers, chips, etc]' \
  '--progress[show progress]' \
  '-o[output log file]:file:_files' \
  '--output=[output log file]:file:_files' \
  '*::flashprog args:_files' && ret=0
return ret
