#compdef purescript-language-server
# Documentation: https://github.com/nwolverson/purescript-language-server
# purescript-language-server - PureScript language server

local ret=1

_arguments -s -S \
  '--stdio[communicate over standard input/output]' \
  '--node-ipc[communicate using node IPC]' \
  '--socket=[communicate over a TCP socket on the given port]:port' \
  '--pipe=[communicate over the given named pipe]:pipe' \
  '--config=[supply configuration as a JSON object on the command line]:json' && ret=0

return ret
