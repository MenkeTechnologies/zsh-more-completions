#compdef pomerium-cli

# Zsh completion for Pomerium CLI client

local curcontext="$curcontext" state line ret=1

local -a pomerium_cli_commands
pomerium_cli_commands=(
  'tcp:create a TCP tunnel through Pomerium'
  'k8s:connect to a Kubernetes cluster through Pomerium'
  'cache:manage the local cache'
  'version:display version information'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--pomerium-url=[URL of the Pomerium proxy]:url:' \
  '--disable-tls-verification[disable TLS verification]' \
  '1:command:_describe -t commands command pomerium_cli_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      tcp)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--pomerium-url=[URL of the Pomerium proxy]:url:' \
          '--disable-tls-verification[disable TLS verification]' \
          '(-l --listen)'{-l,--listen}'=[local address to listen on]:address:' \
          '1:destination:' \
          && ret=0
        ;;
      k8s)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--pomerium-url=[URL of the Pomerium proxy]:url:' \
          '--disable-tls-verification[disable TLS verification]' \
          'exec:execute a command in a container' \
          && ret=0
        ;;
      cache)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          'clear:clear the local cache' \
          && ret=0
        ;;
      *)
        _arguments -s -S '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
