#compdef nats-server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-a,--addr}'=[bind address]:address' \
  {-p,--port}'=[client listen port]:port' \
  {-P,--pid}'=[PID file]:pid file:_files' \
  {-m,--http_port}'=[HTTP monitoring port]:port' \
  '--https_port=[HTTPS monitoring port]:port' \
  {-c,--config}'=[configuration file]:config file:_files' \
  {-l,--log}'=[log file]:log file:_files' \
  {-T,--logtime}'[timestamp log entries]' \
  '--logfile_size_limit=[log file size limit]:size' \
  {-s,--syslog}'[log to syslog]' \
  {-r,--remote_syslog}'=[remote syslog address]:address' \
  {-D,--debug}'[enable debug output]' \
  {-V,--trace}'[enable trace output]' \
  '-DV[enable debug and trace output]' \
  '--signal=[send signal to running server]:signal:(stop quit reopen reload lame-duck)' \
  '--cluster=[cluster listen URL]:url' \
  '--cluster_name=[cluster name]:name' \
  '--routes=[route URLs]:urls' \
  '--no_advertise[do not advertise known cluster IPs]' \
  '--cluster_listen=[cluster listen URL]:url' \
  '--tls[enable TLS]' \
  '--tlscert=[TLS certificate file]:cert file:_files' \
  '--tlskey=[TLS key file]:key file:_files' \
  '--tlscacert=[TLS CA certificate file]:ca file:_files' \
  '--tlsverify[enable TLS client verification]' \
  {-js,--jetstream}'[enable JetStream]' \
  {-sd,--store_dir}'=[JetStream storage directory]:directory:_directories' \
  {-ms,--max_mem_store}'=[JetStream max memory store]:size' \
  {-fs,--max_file_store}'=[JetStream max file store]:size' \
  '--no_auth_user=[default user for unauthenticated connections]:user' \
  '--user=[required username]:username' \
  '--pass=[required password]:password' \
  '--auth=[required authorization token]:token' \
  '--client_advertise=[client advertise URL]:url' \
  '--max_connections=[max client connections]:count' \
  '--max_control_line=[max control line size]:bytes' \
  '--max_payload=[max message payload size]:bytes' \
  '--max_pending=[max pending bytes per connection]:bytes' \
  '--max_subscriptions=[max subscriptions per client]:count' \
  '--ping_interval=[client ping interval]:duration' \
  '--ping_max=[max outstanding pings]:count' \
  '--write_deadline=[write deadline]:duration' \
  {-n,--server_name}'=[server name]:name' \
  '--trusted=[trusted operator keys]:keys' \
  '--nkey=[NKey for server authentication]:nkey' && ret=0

return ret
