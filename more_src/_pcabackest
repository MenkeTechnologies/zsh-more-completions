#compdef pcabackest
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/pcabackest.txt
# Creates an estimated PCA background spectrum for a specific observation

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[Standard Mode 2 file for the background model]:input file:_files' \
  'outfile=[output file with the background estimate]:output file:_files' \
  'modelfile=[PCA background model file(s) or caldb]:model file:_files' \
  'filterfile=[filter file created by xtefilt]:filter file:_files' \
  'modeltype=[background type construction]:type:(INTERNAL EXTERNAL BOTH)' \
  'interval=[interval in seconds between estimates]:seconds:' \
  'propane=[generate estimates for the propane layer]:flag:(yes no)' \
  'layers=[separate estimates for each anode of each layer]:flag:(yes no)' \
  'gaincorr=[apply gain and offset correction]:flag:(yes no)' \
  'gcorrfile=[EDS gain/offset correction file]:file:_files' \
  'fullspec=[produce 256-channel spectrum]:flag:(yes no)' \
  'saahfile=[South Atlantic Anomaly history file]:file:_files' \
  'interp=[enable interpolation]:flag:(yes no)' \
  'syserr=[detailed systematic error computation]:flag:(yes no)' \
  'maxmodels=[maximum number of background models]:count:' \
  'timeslop=[allowable filter file shortfall in seconds]:seconds:' \
  'clobber=[overwrite existing output files]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
