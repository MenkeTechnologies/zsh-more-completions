#compdef great_expectations

# Zsh completion for great_expectations - Data validation CLI

_great_expectations_datasource() {
  local -a subcommands=(
    'new:add a new datasource'
    'list:list known datasources'
    'delete:delete a datasource'
  )
  _describe -t subcommands 'datasource subcommand' subcommands
}

_great_expectations_suite() {
  local -a subcommands=(
    'new:create a new expectation suite'
    'edit:edit an existing expectation suite'
    'list:list existing expectation suites'
    'delete:delete an expectation suite'
  )
  _describe -t subcommands 'suite subcommand' subcommands
}

_great_expectations_checkpoint() {
  local -a subcommands=(
    'new:create a new checkpoint'
    'run:run a checkpoint'
    'list:list configured checkpoints'
    'delete:delete a checkpoint'
    'script:create a script from a checkpoint'
  )
  _describe -t subcommands 'checkpoint subcommand' subcommands
}

_great_expectations_docs() {
  local -a subcommands=(
    'build:build data docs'
    'list:list data docs sites'
    'clean:remove data docs'
  )
  _describe -t subcommands 'docs subcommand' subcommands
}

_great_expectations_store() {
  local -a subcommands=(
    'list:list active stores'
  )
  _describe -t subcommands 'store subcommand' subcommands
}

_great_expectations_project() {
  local -a subcommands=(
    'check-config:check great_expectations configuration'
    'upgrade:upgrade project to current version'
  )
  _describe -t subcommands 'project subcommand' subcommands
}

_great_expectations() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help message]' \
    '(- *)--version[show version]' \
    '(-v --verbose)'{-v,--verbose}'[set verbose output]' \
    '(-c --config)'{-c,--config}'[path to great_expectations directory]:directory:_directories' \
    '(-y --assume-yes)'{-y,--assume-yes}'[assume yes for all prompts]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case $state in
    cmds)
      local -a commands=(
        'init:initialize a new great_expectations project'
        'datasource:manage datasources'
        'suite:manage expectation suites'
        'checkpoint:manage checkpoints'
        'docs:manage data documentation'
        'store:manage stores'
        'project:manage project configuration'
      )
      _describe -t commands 'great_expectations command' commands
      ;;
    args)
      case $line[1] in
        datasource) _great_expectations_datasource ;;
        suite) _great_expectations_suite ;;
        checkpoint) _great_expectations_checkpoint ;;
        docs) _great_expectations_docs ;;
        store) _great_expectations_store ;;
        project) _great_expectations_project ;;
      esac
      ;;
  esac
}

_great_expectations "$@"
