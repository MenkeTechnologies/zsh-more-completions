#compdef pamundice
# Documentation: man pamundice (Netpbm)
# Source: Netpbm pamundice — combine grid of images (tiles) into one.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-across=[number of tiles across (with -down)]:n:' \
    '-down=[number of tiles down (with -across)]:n:' \
    '-indexfile=[tile-index PAM image]:file:_files' \
    '-hoverlap=[horizontal overlap between tiles]:pixels:' \
    '-voverlap=[vertical overlap between tiles]:pixels:' \
    '-listfile=[file with list of input tile filenames]:file:_files' \
    '-verbose[print progress messages]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:input filename pattern:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
