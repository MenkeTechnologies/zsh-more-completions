#compdef toolbx toolbox

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create:create new toolbox container'
  'enter:enter toolbox'
  'help:show help'
  'init-container:initialize container (entry point)'
  'list:list containers/images'
  'rm:remove containers'
  'rmi:remove images'
  'run:run command in toolbox'
)

_arguments -C \
  '(-y --assumeyes)'{-y,--assumeyes}'[auto-yes]' \
  '(- *)'{-h,--help}'[show help]' \
  '--log-level=[level]:level:(debug info warn error fatal panic)' \
  '--log-podman[show podman logs]' \
  '*'{-v,--verbose}'[verbose]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'toolbox subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments -s \
          '--authfile=[auth file]:file:_files' \
          '(-d --distro)'{-d,--distro}'=[distro]:distro:(arch fedora rhel ubuntu)' \
          '(-i --image)'{-i,--image}'=[image]:image:' \
          '(-r --release)'{-r,--release}'=[release]:release:' \
          '*:container:' && ret=0 ;;
      (enter)
        _arguments -s \
          '(-d --distro)'{-d,--distro}'=[distro]:distro:(arch fedora rhel ubuntu)' \
          '(-r --release)'{-r,--release}'=[release]:release:' \
          '*:container:' && ret=0 ;;
      (init-container)
        _arguments -s \
          '--gid=[GID]:gid:' \
          '--home=[home]:dir:_files -/' \
          '--home-link[symlink home]' \
          '--media-link[symlink media]' \
          '--mnt-link[symlink mnt]' \
          '--monitor-host[deprecated]' \
          '--shell=[shell]:shell:' \
          '--uid=[UID]:uid:' \
          '--user=[user]:user:_users' && ret=0 ;;
      (list)
        _arguments -s \
          '(-c --containers)'{-c,--containers}'[only containers]' \
          '(-i --images)'{-i,--images}'[only images]' && ret=0 ;;
      (rm)
        _arguments -s \
          '(-a --all)'{-a,--all}'[remove all]' \
          '(-f --force)'{-f,--force}'[force]' \
          '*:container:' && ret=0 ;;
      (rmi)
        _arguments -s \
          '(-a --all)'{-a,--all}'[remove all]' \
          '(-f --force)'{-f,--force}'[force]' \
          '*:image:' && ret=0 ;;
      (run)
        _arguments -s \
          '(-c --container)'{-c,--container}'=[container]:container:' \
          '(-d --distro)'{-d,--distro}'=[distro]:distro:(arch fedora rhel ubuntu)' \
          '--preserve-fds=[N]:n:' \
          '(-r --release)'{-r,--release}'=[release]:release:' \
          '*:command:_command_names' && ret=0 ;;
      (help) _arguments '*:command:(create enter init-container list rm rmi run)' && ret=0 ;;
    esac
    ;;
esac

return ret
