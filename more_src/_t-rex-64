#compdef t-rex-64
# Documentation: https://trex-tgn.cisco.com/trex/doc/trex_manual.html
# Cisco TRex stateful/stateless traffic generator server

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-f[YAML traffic template file (stateful mode)]:file:_files' \
  '-c[number of hardware threads per interface pair]:cores' \
  '-m[rate multiplier for CPS of each template]:multiplier' \
  '-d[test duration in seconds]:seconds' \
  '-l[run latency check in parallel at given rate per interface]:rate' \
  '-k[run warm-up traffic for given seconds before test]:seconds' \
  '-i[interactive (stateless) mode]' \
  '-p[send all packets of same flow from same direction]' \
  '-e[change src/dst IP per port (flow per port)]' \
  '-v[verbosity / debug info level]:level' \
  '--cfg[TRex platform config file]:file:_files' \
  '--astf[advanced stateful mode]' \
  '--iom[I/O display mode (0 silent, 1 normal, 2 short)]:mode:(0 1 2)' \
  '--no-watchdog[disable watchdog]' \
  '--nc[terminate exactly at end of duration]' \
  '--software[process all RX packets via software (no hw rules)]' \
  '--checksum-offload[enable IP/TCP/UDP TX checksum offload]' \
  '--active-flows[scale number of active flows (experimental)]:flows' \
  '--client_cfg[YAML file describing clients configuration]:file:_files' \
  '--lo[send only latency packets]' \
  '--lm[hex bitmask of ports that will send traffic]:bitmask' \
  '--learn-mode[learn dynamic NAT translation (1, 2 or 3)]:mode:(1 2 3)' \
  '--rx-check[enable Rx check module at given sample rate]:rate' \
  '--hops[number of hops in setup (Rx check)]:hops' \
  '--allow-coredump[allow creation of core dump]' \
  '--prefix[config file-prefix for parallel TRex instances]:prefix' \
  '--arp-refresh-period[seconds between gratuitous ARP (0 = never)]:seconds' \
  '*:arg:_files' && ret=0

return ret
