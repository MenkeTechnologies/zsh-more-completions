#compdef opam
# _opam-cli — OCaml package manager (OCaml/Inria, OCaml); manage OCaml switches + packages
# upstream: https://github.com/ocaml/opam

_opam-cli() {
    local -a sub=(
        'admin:opam admin commands'
        'clean:clean caches'
        'completion:print shell completion'
        'config:opam config commands'
        'env:print env for switch'
        'exec:exec command in env'
        'help:show help'
        'init:initialize opam'
        'install:install package'
        'list:list packages'
        'option:opam option commands'
        'pin:pin a package'
        'remove:remove package'
        'reinstall:reinstall package'
        'repository:repository commands'
        'show:show package info'
        'source:download source'
        'switch:switch management'
        'tree:print dependency tree'
        'unpin:unpin a package'
        'update:update package index'
        'upgrade:upgrade packages'
        'var:set/get opam vars'
        'version:show version'
        'why:print why a package is required'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--color+[color]:when:(always never auto)' \
        '-y[assume yes]' \
        '--yes[assume yes]' \
        '--no[assume no]' \
        '--root+[opam root]:dir:_files -/' \
        '--switch+[switch]:switch:' \
        '--set-root[set OPAMROOT]' \
        '--set-switch[set OPAMSWITCH]' \
        '--debug-level+[debug level]:n:' \
        '-d[debug]' \
        '--debug[debug]' \
        '--cli+[cli compat]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opam subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|reinstall|show|why|tree) _arguments '*:package:' ;;
                switch) _arguments '1:switch cmd:(create export import install list list-available remove reinstall set show set-base set-description set-invariant)' '*:args:' ;;
                pin) _arguments '1:pin cmd:(add edit list remove scan)' '*:args:' ;;
                repository) _arguments '1:repo cmd:(add list priority remove set-url update)' '*:args:' ;;
                init) _arguments \
                    '--bare[no compiler]' \
                    '--reinit[reinit existing]' \
                    '--compiler+[compiler]:compiler:' \
                    '--enable-shell-hook[enable shell hook]' \
                    '--disable-shell-hook[disable shell hook]' \
                    '--enable-completion[enable completion]' \
                    '--disable-completion[disable completion]' \
                    '*:repo url:_urls' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_opam-cli "$@"
