#compdef panda panda-css
# Documentation: https://panda-css.com/docs/references/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for Panda CSS CLI
# https://panda-css.com

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:Initialize Panda in your project'
  'codegen:Generate the Styled System'
  'cssgen:Generate only the CSS files'
  'debug:Troubleshoot style extraction'
  'studio:Start local UI to preview tokens'
  'ship:Prepare project for distribution'
)

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--cwd=[set current working directory]:path:_directories' \
  '--logfile=[output logs to file]:file:_files' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'panda command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (init)
        _arguments -s -S \
          '(-p --postcss)'{-p,--postcss}'[generate postcss.config.cjs]' \
          '(-i --interactive)'{-i,--interactive}'[run in interactive mode]' \
          '(-f --force)'{-f,--force}'[overwrite existing files]' \
          '--outdir=[specify directory for generated files]:dir:_directories' \
          '--jsx-framework=[set JSX framework]:framework:(react vue solid)' \
          '--syntax=[set preferred CSS syntax]:syntax:(object-literal)' && ret=0
        ;;
      (codegen)
        _arguments -s -S \
          '--clean[remove existing output directory]' \
          '(-w --watch)'{-w,--watch}'[regenerate on config change]' \
          '--cpu-prof[generate CPU profile]' && ret=0
        ;;
      (cssgen)
        _arguments -s -S \
          '--splitting[enable CSS code splitting]' \
          '1:type:(preflight tokens static global keyframes)' && ret=0
        ;;
      (debug)
        _arguments -s -S \
          '--outdir=[directory to save debug info]:dir:_directories' \
          '1:glob:' && ret=0
        ;;
      (studio)
        _arguments -s -S \
          '--port=[studio server port]:port:' \
          '--build[build studio for production]' && ret=0
        ;;
      (ship)
        _arguments -s -S \
          '--outfile=[path to write final CSS]:file:_files' \
          '--minify[minify output CSS]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(-w --watch)'{-w,--watch}'[watch for file changes]' \
          '--poll[use polling instead of native events]' \
          '--clean[clean output directory before generating]' \
          '(-c --config)'{-c,--config}'[path to custom config]:file:_files' \
          '--silent[suppress console output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
