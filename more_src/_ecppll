#compdef ecppll
# Documentation: https://github.com/YosysHQ/prjtrellis/blob/master/libtrellis/tools/ecppll.cpp
# Project Trellis: ECP5 PLL configuration generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --module)'{-n,--module}'=[module name]:name' \
  '--clkin_name=[input signal name]:name' \
  '(-i --clkin)'{-i,--clkin}'=[input frequency in MHz]:mhz' \
  '--clkout0_name=[primary output signal name]:name' \
  '(-o --clkout0)'{-o,--clkout0}'=[primary output frequency in MHz]:mhz' \
  '--clkout1_name=[secondary output 1 signal name]:name' \
  '--clkout1=[secondary output 1 frequency in MHz]:mhz' \
  '--phase1=[secondary output 1 phase in degrees]:deg' \
  '--clkout2_name=[secondary output 2 signal name]:name' \
  '--clkout2=[secondary output 2 frequency in MHz]:mhz' \
  '--phase2=[secondary output 2 phase in degrees]:deg' \
  '--clkout3_name=[secondary output 3 signal name]:name' \
  '--clkout3=[secondary output 3 frequency in MHz]:mhz' \
  '--phase3=[secondary output 3 phase in degrees]:deg' \
  '(-f --file)'{-f,--file}'=[write output to file]:file:_files' \
  '--highres[use secondary PLL output for higher frequency resolution]' \
  '--dynamic[enable dynamic clock control]' \
  '--reset[enable reset input]' \
  '--standby[enable standby input]' \
  '--feedback_clkout=[select output for feedback signal]:out' \
  '--internal_feedback[use internal feedback path]' \
  '--internal_feedback_wake[wake internal feedback]' \
  '--xo2[generate MachXO2/3 PLL configuration]' && ret=0

return ret
