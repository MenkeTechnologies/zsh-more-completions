#compdef criminalip

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'scan:scan a target'
      'search:search for assets'
      'domain:search domain information'
      'ip:search IP information'
      'banner:search banner information'
    )
    _describe -t commands 'criminalip command' commands && ret=0
    ;;
  args)
    case $line[1] in
      scan)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-q,--query}'=[target to scan]:target' \
          {-o,--output}'=[output file]:output file:_files' \
          {-f,--format}'=[output format]:format:(json csv table)' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-q,--query}'=[search query]:query' \
          {-o,--output}'=[output file]:output file:_files' \
          {-f,--format}'=[output format]:format:(json csv table)' && ret=0
        ;;
      domain)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-q,--query}'=[domain to search]:domain' \
          {-o,--output}'=[output file]:output file:_files' \
          {-f,--format}'=[output format]:format:(json csv table)' && ret=0
        ;;
      ip)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-q,--query}'=[IP address to search]:ip' \
          {-o,--output}'=[output file]:output file:_files' \
          {-f,--format}'=[output format]:format:(json csv table)' && ret=0
        ;;
      banner)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-q,--query}'=[banner search query]:query' \
          {-o,--output}'=[output file]:output file:_files' \
          {-f,--format}'=[output format]:format:(json csv table)' && ret=0
        ;;
    esac
    ;;
esac

return ret
