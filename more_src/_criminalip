#compdef criminalip cip
# Documentation: https://github.com/ChoiSG/criminalip-python
# Reference accessed: 2026-05-16
# Verified: ChoiSG/criminalip-python (archived 2024) is the only
# public CriminalIP CLI. Its binary is `cip`, not `criminalip`. Both
# names are completed here for compatibility.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated scan/search/domain/ip/banner subcommands with -q/--query
# (the real cip surface is init/ip/request-scan/scan-result/search/vpn).

# criminalip / cip: CriminalIP.io API CLI (archived 2024)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'init:set API key'
  'ip:lookup IP intelligence'
  'request-scan:request a scan'
  'scan-result:fetch scan result'
  'search:search the CriminalIP dataset'
  'vpn:VPN-related lookup'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'criminalip command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (ip)
        _arguments \
          '-o[output file]:file:_files' \
          '-f[input file with IPs]:file:_files' && ret=0
        ;;
      (search)
        _arguments \
          '-l[limit]:n:' \
          '-o[output file]:file:_files' && ret=0
        ;;
      (scan-result)
        _arguments '--progress[show progress]' && ret=0
        ;;
      (vpn)
        _arguments '-f[input file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac
return ret
