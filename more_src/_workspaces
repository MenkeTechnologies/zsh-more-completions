#compdef workspaces
# Documentation: https://www.npmjs.com/package/@turbo/workspaces
# Reference accessed: 2026-05-23
# Verified: npx @turbo/workspaces --help.

# Zsh completion for workspaces - Turborepo workspace manager tools

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'convert:convert project between workspace managers'
  'summary:display workspace summary'
  'help:show command help'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show version]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'workspaces command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (convert)
        _arguments           ':path:_directories'           ':package manager:(npm yarn pnpm bun)' && ret=0 ;;
      (summary)
        _arguments ':path:_directories' && ret=0 ;;
      (*)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
