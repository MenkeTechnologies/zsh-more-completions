#compdef mergeBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/merge.html
# merge overlapping/book-ended genomic features (bedtools merge)

local ret=1

_arguments -s -S \
  '-i[input file (BED/GFF/VCF/BAM)]:file:_files' \
  '-s[only merge features that are the same strand]' \
  '-S[force merge for one specific strand only]:strand:(+ -)' \
  '-d[maximum distance between features to be merged]:distance' \
  '-c[columns from the input file to operate upon]:columns' \
  '-o[operation to apply to -c]:operation' \
  '-delim[custom delimiter for collapse/distinct]:delim' \
  '-header[print the header from the A file before results]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
