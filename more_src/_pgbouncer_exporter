#compdef pgbouncer_exporter
# _pgbouncer_exporter — pgBouncer metrics for Prometheus (prometheus-community/pgbouncer_exporter)
# upstream: https://github.com/prometheus-community/pgbouncer_exporter
# Flags from pgbouncer_exporter.go (kingpin).

_pgbouncer_exporter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--pgBouncer.connectionString=[pgBouncer connection string]:dsn:' \
        '--web.telemetry-path=[metrics URL path]:path:' \
        '--pgBouncer.pid-file=[pgBouncer PID file for process metrics]:file:_files' \
        '--web.listen-address=[bind address]:addr:' \
        '--web.config.file=[exporter-toolkit web config]:file:_files -g "*.(yml|yaml)"' \
        '--log.level=[log level]:level:(debug info warn error)' \
        '--log.format=[log format]:fmt:(logfmt json)'
}

_pgbouncer_exporter "$@"
