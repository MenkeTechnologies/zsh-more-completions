#compdef enlightenment_backlight
# Documentation: https://github.com/Enlightenment/enlightenment
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# enlightenment_backlight: E backlight helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-l[show backlight value]' \
  '-s[set backlight value 0-1.0]:value:' \
  '*::enlightenment_backlight args:_files' && ret=0
return ret
