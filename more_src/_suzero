#compdef suzero
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/amplitudes/suzero.c
# SUZERO - zero-out or set constant data within a time window

local ret=1

_arguments -s -S \
  'itmax=[last time sample to zero out]:i:' \
  'itmin=[first time sample to zero out]:i:' \
  'value=[value to set]:v:' \
  '*:SU file:_files' && ret=0

return ret
