#compdef otbcli_ClassificationMapRegularization
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ClassificationMapRegularization.html
# Orfeo ToolBox: regularize a classification map by majority voting in a neighborhood

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-io.in[input labeled image to regularize]:image:_files' \
  '-io.out[output regularized labeled image]:output:_files' \
  '-ip.radius[radius of ball shaped structuring element]:value:' \
  '-ip.suvbool[set multiple majority pixels to undecided]:bool:(true false)' \
  '-ip.nodatalabel[label for unclassified pixels]:value:' \
  '-ip.undecidedlabel[label for ambiguous pixels]:value:' \
  '-ip.onlyisolatedpixels[process only isolated pixels]:bool:(true false)' \
  '-ip.isolatedthreshold[max same-label neighbours]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
