#compdef solbuild

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build the given package'
  'bi:alias for build-image'
  'build-image:build base solbuild image'
  'chroot:interactive chroot in build root'
  'init:initialize solbuild profile'
  'update:update profile base image'
  'index:create new repo index'
  'help:show help'
  'version:show version'
  'delete-cache:delete on-disk roots'
  'dc:alias for delete-cache'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-n --no-color)'{-n,--no-color}'[disable colors]' \
  '(-p --profile)'{-p+,--profile=}'[solbuild profile]:profile:' \
  '(-t --tmpfs)'{-t,--tmpfs}'[use tmpfs for build]' \
  '--memory=[memory size for tmpfs]:size:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'solbuild command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init) _arguments \
        '(-u --update)'{-u,--update}'[also update base after init]' && ret=0 ;;
      (build) _arguments \
        '(-n --network)'{-n,--network}'[allow network in build]' \
        '*:package file:_files -g "*.yml *.xml"' && ret=0 ;;
      (chroot) _arguments \
        '*:package file:_files -g "*.yml *.xml"' && ret=0 ;;
      (delete-cache|dc) _arguments \
        '(-a --all)'{-a,--all}'[also delete ccache and pkg/src caches]' \
        '(-i --images)'{-i,--images}'[delete profile images]' \
        '(-s --sizes)'{-s,--sizes}'[show sizes only]' && ret=0 ;;
    esac ;;
esac

return ret
