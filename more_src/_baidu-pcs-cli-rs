'--parents[如果父目录不存在，则创建父目录]' \
'-h[Print help]' \
'--help[Print help]' \
'*::remote -- 远程路径（支持多个）:_default' \
&& ret=0
;;
(version)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(app-self)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
