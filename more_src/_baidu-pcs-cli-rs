autoload -U is-at-least

_baidu-pcs-cli-rs() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-c+[配置文件路径， 可选 默认配置路径 可使用 \`self config\` 命令获取]:CONFIG:_default' \
'--config=[配置文件路径， 可选 默认配置路径 可使用 \`self config\` 命令获取]:CONFIG:_default' \
'--dns=[指定用于解析域名的 DNS 服务器地址（支持逗号分隔多个，格式如 8.8.8.8 或 8.8.8.8\:53）]:DNS:_default' \
'-h[Print help]' \
'--help[Print help]' \
":: :_baidu-pcs-cli-rs_commands" \
"*::: :->baidu-pan-cli-rs" \
&& ret=0
    case $state in
    (baidu-pan-cli-rs)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:baidu-pcs-cli-rs-command-$line[1]:"
        case $line[1] in
            (auth)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ls)
_arguments "${_arguments_options[@]}" : \
'-r[递归列出子目录]' \
'--recursive[递归列出子目录]' \
'-h[Print help]' \
'--help[Print help]' \
':remote -- 远程路径:_default' \
&& ret=0
;;
(cp)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':src -- 远程源路径:_default' \
':dest -- 远程目标路径:_default' \
&& ret=0
;;
(mv)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':src -- 远程源路径:_default' \
':dest -- 远程目标路径:_default' \
&& ret=0
;;
(rm)
_arguments "${_arguments_options[@]}" : \
'-r[递归删除子目录]' \
'--recursive[递归删除子目录]' \
'-h[Print help]' \
'--help[Print help]' \
'*::remote -- 远程路径（支持多个）:_default' \
&& ret=0
;;
(tx)
_arguments "${_arguments_options[@]}" : \
'-r[递归上传目录]' \
'--recursive[递归上传目录]' \
'--remove-source[上传完成后删除本地源文件]' \
'-h[Print help]' \
'--help[Print help]' \
':local -- 本地源路径:_default' \
':remote -- 远程目标路径:_default' \
&& ret=0
;;
(rx)
_arguments "${_arguments_options[@]}" : \
'-r[递归下载目录]' \
'--recursive[递归下载目录]' \
'-h[Print help]' \
'--help[Print help]' \
':remote -- 远程源路径:_default' \
'::local -- 本地目标路径（默认当前目录）:_default' \
&& ret=0
;;
(backup)
_arguments "${_arguments_options[@]}" : \
'-d[守护模式：持续监控本地变更并自动备份]' \
'--daemon[守护模式：持续监控本地变更并自动备份]' \
'--rm[备份成功后删除本地源文件]' \
'-h[Print help]' \
'--help[Print help]' \
'::local -- 本地源目录/文件（可选，未提供时从配置文件读取）:_default' \
'::remote -- 远程目标目录（可选，未提供时从配置文件读取）:_default' \
&& ret=0
;;
(quota)
_arguments "${_arguments_options[@]}" : \
'-v[是否显示详细信息]' \
'--verbose[是否显示详细信息]' \
'(-k --kb -m --mb -g --gb)-H[]' \
'(-k --kb -m --mb -g --gb)--human[]' \
'(-H --human -m --mb -g --gb)-k[]' \
'(-H --human -m --mb -g --gb)--kb[]' \
'(-H --human -k --kb -g --gb)-m[]' \
'(-H --human -k --kb -g --gb)--mb[]' \
'(-H --human -k --kb -m --mb)-g[]' \
'(-H --human -k --kb -m --mb)--gb[]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(wget)
_arguments "${_arguments_options[@]}" : \
'-p+[分享提取码（如有）]:PASSWORD:_default' \
'--password=[分享提取码（如有）]:PASSWORD:_default' \
'-o+[本地保存目录（默认当前目录）]:OUTPUT:_default' \
'--output=[本地保存目录（默认当前目录）]:OUTPUT:_default' \
'-h[Print help]' \
'--help[Print help]' \
':share_url -- 百度网盘分享链接，如 https\://pan.baidu.com/s/xxxxx:_default' \
&& ret=0
;;
(mkdir)
_arguments "${_arguments_options[@]}" : \
