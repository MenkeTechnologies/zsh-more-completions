#compdef cilium

# Zsh completion for Cilium CLI (Kubernetes networking, security, and observability)

local curcontext="$curcontext" state line ret=1

local -a cilium_commands
cilium_commands=(
  'bgp:access to BGP control plane'
  'clustermesh:multi-cluster management'
  'completion:output shell completion code'
  'config:manage configuration'
  'connectivity:connectivity troubleshooting'
  'context:display the configuration context'
  'encrypt:manage transparent encryption'
  'hubble:access Hubble the observability tool'
  'install:install Cilium in a Kubernetes cluster'
  'multicast:manage multicast'
  'status:display the status of Cilium'
  'sysdump:collect debugging information'
  'uninstall:uninstall Cilium from a Kubernetes cluster'
  'upgrade:upgrade a Cilium installation'
  'version:display version information'
)

local -a cilium_global_flags
cilium_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--context=[Kubernetes configuration context]:context:'
  '-n=[Kubernetes namespace]:namespace:'
  '--namespace=[Kubernetes namespace]:namespace:'
  '--helm-release-name=[Helm release name]:name:'
  '--kubeconfig=[path to kubeconfig]:kubeconfig:_files'
)

_arguments -s -S \
  $cilium_global_flags \
  '1:command:_describe -t commands command cilium_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      install)
        _arguments -s -S \
          $cilium_global_flags \
          '--chart-directory=[Helm chart directory]:directory:_directories' \
          '--cluster-id=[cluster ID for ClusterMesh]:id:' \
          '--cluster-name=[cluster name for ClusterMesh]:name:' \
          '--config=[set config key-value pair]:key=value:' \
          '--datapath-mode=[datapath mode]:mode:(vxlan geneve tunnel native aws-eni azure gke)' \
          '--dry-run[do not actually install]' \
          '--dry-run-helm-values[output Helm values without installing]' \
          '--encryption=[enable encryption]:type:(disabled ipsec wireguard)' \
          '--helm-auto-gen-values=[write auto-generated Helm values]:file:_files' \
          '--helm-set=[set Helm values]:values:' \
          '--helm-set-file=[set Helm values from files]:values:' \
          '--helm-set-string=[set string Helm values]:values:' \
          '--helm-values=[Helm values file]:values file:_files' \
          '--image-suffix=[custom image suffix]:suffix:' \
          '--image-tag=[custom image tag]:tag:' \
          '--inherit-ca=[inherit CA from existing installation]:namespace:' \
          '--ipam=[IP address management mode]:mode:(kubernetes cluster-pool multi-pool azure eni)' \
          '--ipv4-native-routing-cidr=[IPv4 native routing CIDR]:cidr:' \
          '--ipv6-native-routing-cidr=[IPv6 native routing CIDR]:cidr:' \
          '--kube-proxy-replacement=[kube-proxy replacement]:mode:(true false)' \
          '--list-versions[list available versions]' \
          '--repository=[Helm chart repository]:repo:' \
          '--restart-unmanaged-pods[restart unmanaged pods]' \
          '--rollback-on-failure[rollback on installation failure]' \
          '--set=[set Helm values on the command line]:values:' \
          '--version=[Cilium version]:version:' \
          '--wait[wait for install to complete]' \
          '--wait-duration=[max time to wait]:duration:' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          $cilium_global_flags \
          '--chart-directory=[Helm chart directory]:directory:_directories' \
          '--helm-values=[Helm values file]:values file:_files' \
          '--wait[wait for uninstall to complete]' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          $cilium_global_flags \
          '--chart-directory=[Helm chart directory]:directory:_directories' \
          '--dry-run[do not actually upgrade]' \
          '--dry-run-helm-values[output Helm values without upgrading]' \
          '--helm-auto-gen-values=[write auto-generated values]:file:_files' \
          '--helm-reset-values[reset Helm values to chart defaults]' \
          '--helm-reuse-values[reuse existing Helm values]' \
          '--helm-set=[set Helm values]:values:' \
          '--helm-set-file=[set Helm values from files]:values:' \
          '--helm-set-string=[set string Helm values]:values:' \
          '--helm-values=[Helm values file]:values file:_files' \
          '--repository=[Helm chart repository]:repo:' \
          '--reset-then-set-values=[reset then set values]:values:' \
          '--reuse-values[reuse values from previous release]' \
          '--version=[Cilium version]:version:' \
          '--wait[wait for upgrade to complete]' \
          '--wait-duration=[max time to wait]:duration:' && ret=0
        ;;
      status)
        _arguments -s -S \
          $cilium_global_flags \
          '--wait[wait for Cilium to be ready]' \
          '--wait-duration=[max time to wait]:duration:' \
          '--output=[output format]:format:(json)' && ret=0
        ;;
      connectivity)
        local -a connectivity_commands
        connectivity_commands=(
          'test:run connectivity tests'
          'perf:run performance tests'
        )
        _arguments -s -S \
          $cilium_global_flags \
          '1:connectivity command:_describe -t commands command connectivity_commands' \
          '*::connectivity args:->connectivity_args' && ret=0
        case "$state" in
          connectivity_args)
            case "${line[1]}" in
              test)
                _arguments -s -S \
                  $cilium_global_flags \
                  '--all-flows[collect all flows during test]' \
                  '--connect-timeout=[connection timeout]:duration:' \
                  '--curl-image=[curl image]:image:' \
                  '--curl-insecure[skip TLS verification]' \
                  '--datapath=[skip policy tests]:bool:(true false)' \
                  '--external-cidr=[external CIDR for tests]:cidr:' \
                  '--external-deployment[use external workload for tests]' \
                  '--external-ip=[external IP for tests]:ip:' \
                  '--external-other-ip=[other external IP for tests]:ip:' \
                  '--external-target=[external target for tests]:target:' \
                  '--flow-validation=[flow validation mode]:mode:(disabled warning strict)' \
                  '--hubble[use Hubble for validation]' \
                  '--include-conn-disrupt-test[include connection disruption test]' \
                  '--json-mock-image=[JSON mock image]:image:' \
                  '--multi-cluster=[test multi-cluster]:context:' \
                  '--perf[run performance tests]' \
                  '--perf-duration=[performance test duration]:duration:' \
                  '--request-timeout=[request timeout]:duration:' \
                  '--test=[run specific test]:test name:' \
                  '--test-concurrency=[max test concurrency]:number:' \
                  '--test-namespace=[namespace for tests]:namespace:' \
                  '--timestamp[show timestamps in output]' && ret=0
                ;;
              *)
                _arguments -s -S $cilium_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      clustermesh)
        local -a clustermesh_commands
        clustermesh_commands=(
          'connect:connect to a remote cluster'
          'disconnect:disconnect from a remote cluster'
          'enable:enable ClusterMesh'
          'disable:disable ClusterMesh'
          'status:show ClusterMesh status'
          'external-workload:manage external workloads'
        )
        _arguments -s -S \
          $cilium_global_flags \
          '1:clustermesh command:_describe -t commands command clustermesh_commands' \
          '*::clustermesh args:' && ret=0
        ;;
      hubble)
        local -a hubble_commands
        hubble_commands=(
          'enable:enable Hubble'
          'disable:disable Hubble'
          'port-forward:forward Hubble Relay port'
          'ui:manage Hubble UI'
        )
        _arguments -s -S \
          $cilium_global_flags \
          '1:hubble command:_describe -t commands command hubble_commands' \
          '*::hubble args:' && ret=0
        ;;
      config)
        local -a config_commands
        config_commands=(
          'delete:delete a configuration key'
          'set:set a configuration key'
          'view:view current configuration'
        )
        _arguments -s -S \
          $cilium_global_flags \
          '1:config command:_describe -t commands command config_commands' \
          '*::config args:' && ret=0
        ;;
      encrypt)
        local -a encrypt_commands
        encrypt_commands=(
          'status:display encryption status'
        )
        _arguments -s -S \
          $cilium_global_flags \
          '1:encrypt command:_describe -t commands command encrypt_commands' \
          '*::encrypt args:' && ret=0
        ;;
      bgp)
        local -a bgp_commands
        bgp_commands=(
          'peers:list BGP peers'
          'routes:list BGP routes'
        )
        _arguments -s -S \
          $cilium_global_flags \
          '1:bgp command:_describe -t commands command bgp_commands' \
          '*::bgp args:' && ret=0
        ;;
      sysdump)
        _arguments -s -S \
          $cilium_global_flags \
          '--cilium-label-selector=[label selector for cilium pods]:selector:' \
          '--cilium-namespace=[namespace for Cilium]:namespace:' \
          '--extra-label-selectors=[extra label selectors]:selectors:' \
          '--hubble-flows-count=[number of Hubble flows to collect]:count:' \
          '--hubble-flows-timeout=[timeout for Hubble flow collection]:duration:' \
          '--log-since-time=[only collect logs after this time]:time:' \
          '--log-since-duration=[only collect logs newer than this]:duration:' \
          '--node-list=[only collect from these nodes]:nodes:' \
          '--output=[output format]:format:(json)' \
          '--output-filename=[output file name]:filename:' \
          '--profiling[enable pprof profiling]' \
          '--profiling-duration=[profiling duration]:duration:' \
          '--quick[quick mode, skip expensive tasks]' \
          '--writer=[output writer]:writer:(tar-gz dir)' && ret=0
        ;;
      completion)
        _arguments -s -S \
          $cilium_global_flags \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S $cilium_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
