#compdef vanhove gmx-vanhove
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-vanhove.html
# gmx vanhove: compute Van Hove displacement and correlation functions

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[structure+mass database]:file:_files' \
  '-n[index file]:file:_files' \
  '-om[X PixMap matrix file]:file:_files' \
  '-or[xvgr/xmgr file]:file:_files' \
  '-ot[xvgr/xmgr file]:file:_files' \
  '-b[first frame time to read]:time:' \
  '-e[last frame time to read]:time:' \
  '-dt[frame sampling interval]:time:' \
  '-w[view output files]' \
  '-xvg[plot formatting]:format:(xmgrace xmgr none)' \
  '-sqrt[apply sqrt(t) transformation with bin spacing]:real:' \
  '-fm[frames in matrix; 0 plots all]:int:' \
  '-rmax[maximum r value in matrix]:real:' \
  '-rbin[bin width in matrix]:real:' \
  '-mmax[maximum density; 0 auto-calculates]:real:' \
  '-nlevels[matrix contour levels]:int:' \
  '-nr[number of curves for -or output]:int:' \
  '-fr[frame spacing for -or output]:int:' \
  '-rt[integration limit for -ot output]:real:' \
  '-ft[frames in -ot output; 0 plots all]:int:' && ret=0

return ret
