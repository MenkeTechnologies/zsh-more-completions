#compdef grok_exporter
# Documentation: https://github.com/fstab/grok_exporter
# Export Prometheus metrics from unstructured log data

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[print the grok_exporter version]' \
  '-config=[path to the config file]:_files' \
  '-showconfig[print the current configuration to the console]' \
  '-disable-exporter-metrics[exclude go_*, process_*, promhttp_* metrics from /metrics]' && ret=0

return ret
