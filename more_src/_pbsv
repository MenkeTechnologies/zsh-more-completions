#compdef pbsv

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'discover:discover structural variant signatures'
  'call:call structural variants'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'pbsv command' commands && ret=0
    ;;
  args)
    case $line[1] in
      discover)
        _arguments -s -S \
          '--tandem-repeats[tandem repeats BED file]:file:_files -g "*.bed"' \
          '-s[sample name override]:name:' \
          '1:aligned BAM:_files -g "*.bam"' \
          '2:output svsig.gz:_files' \
          '--help[show help]' && ret=0
        ;;
      call)
        _arguments -s -S \
          '-j[threads]:threads:' \
          '-t[SV types]:types:(DEL INS INV DUP BND)' \
          '--min-sv-length[minimum SV length]:length:' \
          '--max-ins-length[maximum insertion length]:length:' \
          '--call-min-reads-per-strand-all-samples[min reads per strand]:count:' \
          '--call-min-read-perc-one-sample[min read percentage]:percent:' \
          '--ccs[input is CCS reads]' \
          '1:reference FASTA:_files -g "*.fa(|sta)(|.gz)"' \
          '2:svsig.gz:_files' \
          '3:output VCF:_files' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
