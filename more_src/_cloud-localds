#compdef cloud-localds
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/cloud-localds.1.html
# Reference accessed: 2026-05-17
# Verified: upstream manpage and getopt in canonical/cloud-utils bin/cloud-localds.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-d,--disk-format=}'[disk format for output]:format:(raw qcow qcow2 vmdk vdi)' \
  {-f,--filesystem=}'[filesystem type]:filesystem:(iso9660 vfat)' \
  {-H,--hostname=}'[set hostname in meta-data]:hostname' \
  {-i,--interfaces=}'[write network interfaces file into metadata]:file:_files' \
  {-N,--network-config=}'[network config file]:file:_files' \
  {-m,--dsmode=}'[datasource mode]:mode:(local net)' \
  {-V,--vendor-data=}'[vendor-data file]:file:_files' \
  {-v,--verbose}'[increase verbosity]' \
  '1:output file:_files' \
  '2:user-data file:_files' \
  '3::meta-data file:_files' && ret=0

return ret
