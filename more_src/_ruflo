#compdef ruflo
# Documentation: https://github.com/ruvnet/ruflo
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: ruflo has 26+ commands with 140+ subcommands; surface is volatile.
# Only verified global flags retained; subcommand structure omitted.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help message]' \
  '(- *)--version[check the current version]' \
  '--watch[continuous monitoring mode]' \
  '--json[structured output]' \
  '--verbose[extended logging]' \
  '--dry-run[preview changes without executing]' \
  '*:arg:_files' && ret=0

return ret
