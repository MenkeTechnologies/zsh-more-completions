#compdef ruflo
# Source: https://github.com/MenkeTechnologies/zsh-more-completions/blob/d278e5f1659fc62ca4671ab34a319c3ceb558a41/src/_ruflo
# Repository: MenkeTechnologies/zsh-more-completions (src/_ruflo)

# Zsh completion for ruflo (AI agent orchestration platform)

local -a commands
commands=(
  'init:Initialize the environment'
  'login:Authenticate the CLI'
  'spawn:Create a new agent'
  'list:Show all currently active agents'
  'info:Provide detailed status and logs for a specific agent'
  'terminate:Safely shut down an agent'
  'swarm:Manage collaborative swarms'
  'automation:Manage multi-agent collaboration and automated workflows'
  'run:Run a task'
  'metrics:Display performance data'
  'memory:Check health and activity of the memory system'
  'daemon:Manage the background service'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '(- *)--version[Check the current version]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  spawn)
    _arguments \
      '--type=[Specify agent type]:type:(coder researcher analyst architect tester reviewer optimizer)' \
      '--name=[Specify agent name]:name:'
    ;;
  swarm)
    local -a swarm_cmds
    swarm_cmds=('init:Initialize a collaborative swarm')
    _arguments \
      '1: :_describe -t swarm_cmds "swarm command" swarm_cmds' \
      '--topology=[Specify swarm topology]:topology:(hierarchical mesh)' \
      '--max-agents=[Specify maximum number of agents]:number:'
    ;;
  automation)
    local -a auto_cmds
    auto_cmds=(
      'auto-agent:Automatically select and spawn agents'
      'mle-star:Run the MLE-STAR workflow'
    )
    _arguments \
      '1: :_describe -t auto_cmds "automation command" auto_cmds' \
      '--task-complexity=[Specify task complexity]:level:(low medium high)'
    ;;
  run)
    _arguments \
      '--plan-only[Preview task execution plan without running]'
    ;;
  memory)
    local -a mem_cmds
    mem_cmds=('stats:Check health and activity of the memory system')
    _arguments \
      '1: :_describe -t mem_cmds "memory command" mem_cmds'
    ;;
  daemon)
    local -a daemon_cmds
    daemon_cmds=('start:Start the background service')
    _arguments \
      '1: :_describe -t daemon_cmds "daemon command" daemon_cmds'
    ;;
esac
