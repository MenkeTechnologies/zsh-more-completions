#compdef pl2pm
# Documentation: https://perldoc.perl.org/pl2pm
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# pl2pm has no documented options; synopsis is "pl2pm files".

local -a arguments

arguments=(
    '*:Perl 4 library:_files -g "*.pl"'
)

_arguments -s -S $arguments
