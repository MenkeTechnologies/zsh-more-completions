#compdef fenics
# Documentation: https://man.archlinux.org/search?q=fenics
# Reference accessed: 2026-05-16

# FEniCS Project: Python-based PDE solver (CLI is a Python script runner)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:Python FEniCS script:_files -g "*.py"' && ret=0
return ret
