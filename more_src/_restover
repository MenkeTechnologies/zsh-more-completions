#compdef restover

# EMBOSS restover: find restriction enzymes that produce a specific
# single-stranded overhang sequence after cleavage.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show command-line help]' \
  '-auto[turn off prompts]' \
  '-stdout[write report to stdout]' \
  '-filter[stdin/stdout]' \
  '-options[prompt for ACD qualifiers]' \
  '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' \
  '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s) to search]:sequence USA:_files' \
  '-seqcomp=[overhang sequence to require (IUPAC ambiguity codes allowed)]:overhang:' \
  '-min=[minimum number of cuts per sequence]:cuts:' \
  '-max=[maximum number of cuts per sequence]:cuts:' \
  '-single[force single-cut enzymes]' \
  '-threeprime[match 3-prime overhang instead of 5-prime]' \
  '-plasmid[treat sequence as circular]' \
  '-commercial[restrict to commercially available enzymes]' \
  '-ambiguity[treat overhang ambiguity codes as exact matches]' \
  '-fragments[report fragment lengths produced by cuts]' \
  '-outfile=[output file]:file:_files' \
  '*:DNA sequence:_files' && ret=0

return ret
