#compdef restover
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/restover.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS restover: find restriction enzymes producing a specific overhang.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show command-line help]' \
  '-auto[turn off prompts]' \
  '-stdout[write report to stdout]' \
  '-filter[stdin/stdout]' \
  '-options[prompt for advanced qualifiers]' \
  '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' \
  '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s) to search]:sequence USA:_files' \
  '-seqcomp=[overhang sequence to require]:overhang:' \
  '-datafile=[restriction enzyme data file]:file:_files' \
  '-mfile=[methylation data file]:file:_files' \
  '-min=[minimum cuts per sequence]:cuts:' \
  '-max=[maximum cuts per sequence]:cuts:' \
  '-single[force single-cut enzymes]' \
  '-threeprime[match 3-prime overhang instead of 5-prime]' \
  '-blunt[allow blunt-end enzymes]' \
  '-noblunt[exclude blunt-end enzymes]' \
  '-sticky[allow sticky-end enzymes]' \
  '-nosticky[exclude sticky-end enzymes]' \
  '-ambiguity[allow ambiguity codes]' \
  '-noambiguity[disallow ambiguity codes]' \
  '-plasmid[treat sequence as circular]' \
  '-methylation[respect methylation blocking]' \
  '-commercial[restrict to commercially available enzymes]' \
  '-nocommercial[do not restrict to commercial enzymes]' \
  '-html[HTML output]' \
  '-limit[report one prototype per isoschizomer group]' \
  '-nolimit[report all isoschizomers]' \
  '-alphabetic[sort output alphabetically]' \
  '-fragments[report fragment lengths produced by cuts]' \
  '-outfile=[output report file]:file:_files' \
  '*:DNA sequence:_files' && ret=0

return ret
