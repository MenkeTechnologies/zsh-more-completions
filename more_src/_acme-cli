#compdef acme
# Documentation: https://sourceforge.net/projects/acme-crossass/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-V[show version]' \
  '(- *)--version[show version]' \
  '-o+[output file]:file:_files' \
  '--outfile=[output file]:file:_files' \
  '-l+[label dump file]:file:_files' \
  '--labeldump=[label dump]:file:_files' \
  '--vicelabels=[VICE labels]:file:_files' \
  '-r+[report file]:file:_files' \
  '--report=[report file]:file:_files' \
  '*-I+[include dir]:dir:_files -/' \
  '*-D+[define]:macro:' \
  '--initmem=[init memory hex]:n:' \
  '--maxerrors=[max errors]:n:' \
  '--maxdepth=[max depth]:n:' \
  '--strict[strict mode]' \
  '--strict-segments[strict segments]' \
  '--ignore-zeroes[ignore zeroes]' \
  '--cpu=[target CPU]:cpu:(6502 6510 65c02 r65c02 w65c02 65816 65ce02 4502 m65 c64dtv2)' \
  '--format=[output format]:f:(plain cbm apple)' \
  '--setpc=[set program counter]:n:' \
  '--use-stdout[use stdout]' \
  '--msvc[MSVC errors format]' \
  '-vDEBUG[verbose debug]' \
  '-v[verbose]' \
  '-vv[very verbose]' \
  '-w[show warnings]' \
  '-Wall[all warnings]' \
  '-Wno-[disable warning]:w:' \
  '*: :_files -g "*.a *.asm *.s"' && ret=0

return ret
