#compdef gmtinfo
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtinfo.html
# Source: GenericMappingTools/gmt classic-mode gmtinfo — table min/max/range summary.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[range reporting (all/per-table/per-segment)]:scope:_default' \
    '-C[output min/max in separate columns]' \
    '-D+[align region center on data]:opts:_default' \
    '-E+[record with min/max in column]:opts:_default' \
    '-F[count tables/segments/records/headers]' \
    '-I+[round min/max to multiples of inc]:inc:_default' \
    '-L[common limits across multiple tables]' \
    '-T+[round + emit as -T string]:inc:_default' \
    '*-V[verbose (stackable)]' \
    '-a+[aspatial column associations]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-r[pixel registration (default gridline)]' \
    '-s+[NaN-record handling]:opts:_default' \
    '*:input table:_files' \
    && ret=0

return ret
