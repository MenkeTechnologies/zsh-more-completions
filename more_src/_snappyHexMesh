#compdef snappyHexMesh
# Documentation: https://man.archlinux.org/search?q=snappyHexMesh
# Reference accessed: 2026-05-16

# OpenFOAM snappyHexMesh: automatic split-hex mesher
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-case[case directory]:dir:_files -/' \
  '-region[mesh region]:region:' \
  '-overwrite[overwrite existing mesh]' \
  '-checkGeometry[check geometry only]' \
  '-dict[alternative snappyHexMeshDict]:file:_files' \
  '-parallel[run in parallel]' \
  '-noFunctionObjects[disable function objects]' \
  '-decomposeParDict[decomposition dictionary]:file:_files' \
  '-fileHandler[file handler]:handler:(uncollated collated masterUncollated)' \
  '*::snappyHexMesh options:_files' && ret=0
return ret
