#compdef arm-none-eabi-c++filt
# _arm-none-eabi-c++filt — Arm Limited arm-none-eabi-c++filt CLI for the bare-metal ARM cross-cxxfilt demangling C++ symbol names showing original function class namespace template-parameter mangled-to-readable conversion (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-c++filt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-_[strip leading underscore]' \
        '--strip-underscore[strip leading underscore]' \
        '-n[no strip leading underscore]' \
        '--no-strip-underscore[no strip leading underscore]' \
        '-p[no print params]' \
        '--no-params[no print params]' \
        '-i[no print verbose info]' \
        '--no-verbose[no print verbose info]' \
        '-r[no recurse]' \
        '--no-recurse-limit[no recurse]' \
        '-s+[style]:s:(auto gnu lucid arm hp edg gnu-v3 java gnat dlang rust)' \
        '--format=+[style]:s:(auto gnu lucid arm hp edg gnu-v3 java gnat dlang rust)' \
        '-t[type encoding]' \
        '--types[type encoding]' \
        '*:mangled names:'
}

_arm-none-eabi-c++filt "$@"
