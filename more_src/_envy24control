#compdef envy24control

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[ALSA card id]:card:' \
  '-D+[ALSA control device]:dev:' \
  '-f+[settings file]:file:_files' \
  '-i[ignore card check]' \
  '-o+[output channels]:n:' \
  '-v[verbose]' && ret=0

return ret
