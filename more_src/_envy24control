#compdef envy24control
# Documentation: https://man.archlinux.org/search?q=envy24control
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[ALSA card id]:card:' \
  '-D+[ALSA control device]:dev:' \
  '-f+[settings file]:file:_files' \
  '-i[ignore card check]' \
  '-o+[output channels]:n:' \
  '-v[verbose]' && ret=0

return ret
