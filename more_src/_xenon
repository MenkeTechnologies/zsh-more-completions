#compdef xenon
# Documentation: https://github.com/rubik/xenon
# Reference accessed: 2026-05-17
# Verified: rubik/xenon upstream — Python cyclomatic complexity
# monitor (uses radon). Real flags: -h/--help, -V/--version,
# -a/--max-average, -m/--max-modules, -b/--max-absolute,
# -e/--exclude, -i/--ignore, --no-assert, --config-file, -u/--url.
# Removed from prior file: bogus man.archlinux.org search URL.

# Zsh completion for xenon - Python code complexity monitor

local curcontext="$curcontext" state line ret=1

local -a grades=(A B C D E F)

_arguments -s -S \
  '(-a --max-average)'{-a,--max-average}'[maximum average complexity grade]:grade:(${grades[@]})' \
  '(-m --max-modules)'{-m,--max-modules}'[maximum modules complexity grade]:grade:(${grades[@]})' \
  '(-b --max-absolute)'{-b,--max-absolute}'[maximum absolute complexity grade]:grade:(${grades[@]})' \
  '--no-assert[do not count assert statements]' \
  '(-e --exclude)'{-e,--exclude}'[exclude files matching pattern]:pattern:' \
  '--ignore[ignore directories]:directories:' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '*:paths:_files' && ret=0

return ret
