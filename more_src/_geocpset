#compdef geocpset
# Documentation: https://man.archlinux.org/man/geocpset.1.en
# geocpset: add geometric control points to a Hugin .pto project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output pto file]:file:_files -g "*.pto"' \
  '(-e --each-overlap)'{-e,--each-overlap}'[add a geometric control point to each overlap]' \
  '--min-overlap=[minimum overlap percentage to consider]:percent:' \
  '*:pto file:_files -g "*.pto"' && ret=0

return ret
