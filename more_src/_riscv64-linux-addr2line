#compdef riscv64-linux-addr2line riscv64-linux-gnu-addr2line riscv64-unknown-linux-gnu-addr2line riscv64-unknown-elf-addr2line
# _riscv64-linux-addr2line — GNU binutils riscv64-linux-addr2line CLI cross-arch address-to-source-line resolver translating RV64GC RV64GCV program counter values into source filename function name line number records by reading DWARF debug info for crash backtrace symbolication kernel-oops decoding (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_riscv64-linux-addr2line() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a[show addresses]' \
        '--addresses[show addresses]' \
        '-b+[bfd target]:str:' \
        '--target=+[bfd target]:str:' \
        '-C[demangle]' \
        '--demangle[demangle]' \
        '-e+[executable]:file:_files' \
        '--exe=+[executable]:file:_files' \
        '-f[show function names]' \
        '--functions[show function names]' \
        '-i[show inline frames]' \
        '--inlines[show inline frames]' \
        '-p[show pretty output]' \
        '--pretty-print[pretty output]' \
        '-s[strip directory components]' \
        '--basenames[strip directory components]' \
        '-j+[section]:str:' \
        '--section=+[name]:str:' \
        '-r+[recurse limit]:n:' \
        '--recurse-limit=+[N]:n:' \
        '*:address:'
}

_riscv64-linux-addr2line "$@"
