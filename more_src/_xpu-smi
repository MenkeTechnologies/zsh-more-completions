#compdef xpu-smi
# Documentation: https://github.com/intel/xpumanager/blob/master/doc/smi_user_guide.md
# xpu-smi - Intel XPU System Management Interface for Data Center GPUs

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[display version information and exit]' \
  '(-h --help)'{-h,--help}'[print help message and exit]' \
  '1:command:((
    discovery\:"discover the GPU devices and provide device info"
    diag\:"run test suites to diagnose GPU"
    health\:"get GPU device component health status"
    updatefw\:"update GPU firmware"
    topology\:"get the system topology"
    config\:"get and change the GPU settings"
    ps\:"list status of processes"
    vgpu\:"create and remove virtual GPUs in SR-IOV configuration"
    stats\:"list the GPU statistics"
    dump\:"dump device statistics data"
    log\:"collect GPU debug logs"
  ))' \
  '*::args:_files' && ret=0

return ret
