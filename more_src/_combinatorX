#compdef combinatorX
# Documentation: https://hashcat.net/wiki/doku.php?id=hashcat_utils
# combine up to eight wordlists with custom separators and session support

local ret=1

_arguments -s -S \
  '-1+[first wordlist]:file:_files' \
  '-2+[second wordlist]:file:_files' \
  '-3+[third wordlist]:file:_files' \
  '-4+[fourth wordlist]:file:_files' \
  '-5+[fifth wordlist]:file:_files' \
  '-6+[sixth wordlist]:file:_files' \
  '-7+[seventh wordlist]:file:_files' \
  '-8+[eighth wordlist]:file:_files' && ret=0

return ret
