#compdef archiveutil

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'extractXcodeAEA:extract an Xcode AEA (Apple Encrypted Archive) file'
  'help:show subcommand help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'archiveutil subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (extractXcodeAEA)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
