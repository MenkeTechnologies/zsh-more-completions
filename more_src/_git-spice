#compdef git-spice gs

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '-v[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'auth:manage authentication'
      'repo:manage repository settings'
      'branch:manage branches'
      'stack:manage stacked branches'
      'commit:manage commits'
      'restack:restack branches'
      'log:show branch and stack logs'
      'upstack:navigate upstack'
      'downstack:navigate downstack'
      'top:go to top of stack'
      'bottom:go to bottom of stack'
      'trunk:go to trunk branch'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (auth)
        _arguments '1:action:(login logout status)' && ret=0
        ;;
      (repo)
        _arguments \
          '1:action:(init sync)' \
          '--trunk=[trunk branch name]:branch:' \
          '--remote=[remote name]:remote:' && ret=0
        ;;
      (branch)
        _arguments -C \
          '1:action:->branch_actions' \
          '*::arg:->branch_args' && ret=0
        case $state in
          (branch_actions)
            local -a actions=(
              'create:create a new branch'
              'checkout:checkout a branch'
              'delete:delete a branch'
              'rename:rename a branch'
              'submit:submit a branch as a PR'
              'track:track an existing branch'
              'untrack:untrack a branch'
            )
            _describe -t actions 'action' actions && ret=0
            ;;
          (branch_args)
            case ${words[1]} in
              (create)
                _arguments \
                  '--insert-above[insert above current branch]' \
                  '--insert-below[insert below current branch]' \
                  '1:branch name:' && ret=0
                ;;
              (checkout|delete|rename|submit|track|untrack)
                _arguments '1:branch:__git_branch_names' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (stack)
        _arguments '1:action:(submit restack)' && ret=0
        ;;
      (commit)
        _arguments \
          '1:action:(create amend)' \
          '(-m --message)'{-m,--message}'=[commit message]:message:' \
          '(-a --all)'{-a,--all}'[stage all changes]' && ret=0
        ;;
      (restack)
        _arguments && ret=0
        ;;
      (log)
        _arguments \
          '--short[short output]' \
          '--long[long output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
