#compdef garage

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'server:run the Garage server daemon'
  'status:show cluster status'
  'node:manage cluster nodes'
  'layout:manage cluster layout'
  'bucket:manage buckets'
  'key:manage API keys'
  'stats:show statistics'
  'repair:repair data'
  'offline-repair:offline repair of data'
  'convert-db:convert metadata database format'
  'help:show help for a command'
)

_arguments -s -S \
  '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
  '--rpc-host=[RPC host]:host' \
  '--rpc-secret=[RPC secret]:secret' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      node)
        local -a node_cmds=(
          'id:display node ID'
          'connect:connect to a known node'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'node subcommand' node_cmds && ret=0
        ;;
      layout)
        local -a layout_cmds=(
          'assign:assign capacity to a node'
          'remove:remove a node from the layout'
          'show:show current layout'
          'apply:apply staged layout changes'
          'revert:revert staged layout changes'
          'skip-dead-nodes:skip dead nodes for rebalance'
          'config:get or set layout parameters'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'layout subcommand' layout_cmds && ret=0
        ;;
      bucket)
        local -a bucket_cmds=(
          'list:list all buckets'
          'info:get bucket info'
          'create:create a new bucket'
          'delete:delete a bucket'
          'alias:manage bucket aliases'
          'allow:allow key to access bucket'
          'deny:deny key from accessing bucket'
          'website:manage bucket website config'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'bucket subcommand' bucket_cmds && ret=0
        ;;
      key)
        local -a key_cmds=(
          'list:list all API keys'
          'info:get key info'
          'create:create a new API key'
          'rename:rename an API key'
          'delete:delete an API key'
          'allow:allow key administrative access'
          'deny:deny key administrative access'
          'import:import an existing API key'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'key subcommand' key_cmds && ret=0
        ;;
      repair)
        local -a repair_cmds=(
          'versions:repair object versions'
          'blocks:repair data blocks'
          'scrub:verify integrity of stored blocks'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'repair subcommand' repair_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
