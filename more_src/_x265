#compdef x265
# Documentation: https://manpages.debian.org/x265.1
# Source: x265 — H.265/HEVC encoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--preset[encoding-settings preset]:preset:(ultrafast superfast veryfast faster fast medium slow slower veryslow placebo)' \
    '*--tune[tune for source type / situation]:tune:(psnr ssim grain zerolatency fastdecode animation)' \
    '--profile[encode profile]:profile:(main main10 mainstillpicture main422 main444 main10-intra main12)' \
    '--crf[quality-based VBR 0..51 (default 28)]:crf:' \
    '--bitrate[target bitrate (kbps) for ABR]:rate:' \
    '--qp[QP for P slices in CQP mode]:qp:' \
    '--pass[multipass rate-control]:pass:(1 2 3)' \
    '--stats[multipass stats file (default x265_2pass.log)]:file:_files' \
    '--output[bitstream output file]:file:_files' \
    '--input-res[source picture WxH (auto in Y4M)]:WxH:' \
    '--fps[source frame rate]:fps:' \
    '--keyint[max IDR period (-1 = infinite GOP, default 250)]:frames:' \
    '--bframes[max consecutive B-frames (default 4)]:n:' \
    '--frames[max frames to encode]:n:' \
    '--pools[number of cores per CPU socket]:n:' \
    '--threads[thread-pool size (0=auto)]:n:' \
    '--psnr[report PSNR metric scores]' \
    '--ssim[report SSIM metric scores]' \
    '--hrd[signal HRD parameters]' \
    '--aud[emit access unit delimiters]' \
    '--hash[Decoded Picture Hash SEI]:mode:(0 1 2 3)' \
    '--transfer[transfer characteristics]:tx:(undef bt709 unknown reserved bt470m bt470bg smpte170m smpte240m linear log100 log316 iec61966-2-4 bt1361e iec61966-2-1 bt2020-10 bt2020-12 smpte2084 smpte428 arib-std-b67)' \
    '--colorprim[color primaries]:cp:(undef bt709 unknown reserved bt470m bt470bg smpte170m smpte240m film bt2020 smpte428 smpte431 smpte432)' \
    '--colormatrix[color matrix]:cm:(undef gbr bt709 unknown reserved fcc bt470bg smpte170m smpte240m ycgco bt2020nc bt2020c smpte2085 chroma-derived-nc chroma-derived-c ictcp)' \
    '*:input YUV / Y4M:_files' \
    && ret=0

return ret
