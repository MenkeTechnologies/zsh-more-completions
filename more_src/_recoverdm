#compdef recoverdm
# Documentation: https://manpages.org/recoverdm
# Recover files and disks with damaged sectors

local ret=1

_arguments -s -S \
  '-t[device type]:type:(FILE FLOPPY CDROM_IDE DISK_SCSI)' \
  '-i[device or file to recover]:input:_files' \
  '-o[file to write to (must not exist)]:output:_files' \
  '-l[generate map file of checksums and bad sectors]:file:_files' \
  '-n[retries before going to next sector (default 6)]:retries' \
  '-s[rotation speed of CDROM/DVD (default 1)]:speed' \
  '-r[retries while reading in RAW mode]:retries' \
  '-b[point to start]:offset' \
  '-p[sectors skipped after non-read one]:count' \
  '*:file:_files' && ret=0

return ret
