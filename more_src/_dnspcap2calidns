#compdef dnspcap2calidns
# Documentation: https://doc.powerdns.com/authoritative/manpages/dnspcap2calidns.1.html
# Convert DNS queries from a PCAP file into a calidns-compatible format

local ret=1

_arguments -s -S \
  '--help[show a summary of options]' \
  '--version[display the version]' \
  '1:pcapfile:_files' \
  '2:outfile:_files' && ret=0

return ret
