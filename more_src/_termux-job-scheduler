#compdef termux-job-scheduler
# Documentation: https://github.com/termux/termux-api-package/blob/master/scripts/termux-job-scheduler.in
# Reference accessed: 2026-05-27
# Verified: upstream termux-api-package scripts/termux-job-scheduler.in show_usage()/getopts.


# Schedule a script to run at specified intervals

_arguments \
  '-h[show this help]' \
  '(-p --pending)'{-p,--pending}'[list pending jobs and exit]' \
  '--cancel-all[cancel all pending jobs and exit]' \
  '--cancel[cancel given job-id and exit]' \
  '(-s --script)'{-s+,--script=}'[path to the script to be called]:path:' \
  '--job-id=[job id (will overwrite any previous job with the same id)]:int:' \
  '--period-ms=[schedule job approximately every period-ms milliseconds (default 0 means once). Note that since Android N, the minimum period is 900,000ms (15 minutes).]:int:' \
  '--network=[run only when this type of network available (default any)\: any|unmetered|cellular|not_roaming|none]:text:' \
  '--battery-not-low=[run only when battery is not low, default true (at least Android O)]:boolean:' \
  '--storage-not-low=[run only when storage is not low, default false (at least Android O)]:boolean:' \
  '--charging=[run only when charging, default false]:boolean:' \
  '--persisted=[should the job survive reboots, default false --trigger-content-uri text (at least Android N) --trigger-content-flag int default 1, (at least Android N)]:boolean:'
