#compdef condor_who
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_who.html
# display information about owners of jobs and jobs running on a machine

local ret=1

_arguments -s -S \
  '-help[display usage information]' \
  '-diagnostic[display extra information helpful for debugging]' \
  '-verbose[display PIDs and addresses of daemons]' \
  '-daemons[display information about the daemons running on the machine]' \
  '-quickdaemons[query the condor_master for its readiness ClassAd]' \
  '-wait-for-ready[wait for the readiness expression to evaluate true]:expression' \
  '-address[identify the condor_startd host address to query]:hostaddress' \
  '-allpids[query all local condor_startd daemons]' \
  '-logdir[directory containing log and address files to scan]:directory:_files -/' \
  '-pid[use the given PID to identify the condor_startd]:PID' \
  '-long[display entire ClassAds]' \
  '-jobs[display the job ClassAds rather than the slot ClassAds]' \
  '-startd[display the condor_startd daemon ClassAd]' \
  '-constraint[restrict displayed ClassAds to those matching expression]:expression' \
  '-limit[limit the number of ClassAds returned]:number' \
  '-snapshot[request a snapshot of the startd internal state]' \
  '-statistics[which Statistics attributes to include]:WhichStatistics' \
  '-wide[display fields without truncating them]' \
  '-format[display attribute attr in format fmt]:fmt:_default:attr' \
  '-autoformat[display attributes formatted in a default way]:attrs' \
  '-af[display attributes formatted in a default way]:attrs' \
  '-aaf[append specified attributes as additional columns]:attrs' \
  '-print-format[read output formatting from a custom print format file]:file:_files' \
  '-banner-format[read startd banner formatting from a print format file]:file:_files' \
  '-ospool[show ospool glide-in information in output and banner]' && ret=0

return ret
