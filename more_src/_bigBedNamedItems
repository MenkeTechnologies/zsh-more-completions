#compdef bigBedNamedItems
# _bigBedNamedItems — UCSC Kent Lab bigBedNamedItems extract items from a bigBed by name using extra indexes (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/bigBed.html

_bigBedNamedItems() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-field=+[field name]:str:' \
        '-nameFile[name file]' \
        '-udcDir=+[UDC cache dir]:dir:_files -/' \
        '*:bigBed name out_bed:_files -g "*.bb *.bigbed *.bed *.txt"'
}

_bigBedNamedItems "$@"
