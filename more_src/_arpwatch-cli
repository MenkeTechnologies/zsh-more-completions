#compdef arpwatch arpalert
# Documentation: https://manpages.debian.org/testing/arpwatch/arpwatch.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (arpwatch)
    _arguments -C \
      '-h[show help]' \
      '-d[debug]' \
      '-f+[arp data file]:file:_files' \
      '-i+[interface]:if:_net_interfaces' \
      '-N[no reports]' \
      '-n+[network/mask]:net:' \
      '-r+[read pcap]:file:_files -g "*.pcap *.cap"' \
      '-p[no promisc]' \
      '-Q[no warning report]' \
      '-R+[fork interval]:s:' \
      '-s+[sender]:s:' \
      '-u+[user to drop to]:u:_users' \
      '-W[no warnings]' \
      '-w+[mail recipient]:r:' \
      '-x+[net to ignore]:net:' \
      '-z+[net to ignore]:net:' \
      '-m+[mail program]:p:' \
      '*: :' && ret=0 ;;
  (arpalert)
    _arguments -C \
      '-h[help]' \
      '-V[version]' \
      '-i+[interface]:if:_net_interfaces' \
      '-d[debug mode]' \
      '-D+[daemon level]:n:' \
      '-l+[log alerts]:b:' \
      '-L+[lock file]:file:_files' \
      '-c+[config file]:file:_files' \
      '-p+[pid file]:file:_files' \
      '-w+[white list]:file:_files' \
      '-b+[black list]:file:_files' \
      '-m+[macvend mac file]:file:_files' \
      '-e+[exec script]:file:_files' \
      '-f+[leases file]:file:_files' \
      '-r+[read pcap]:file:_files' \
      '-u+[user to drop]:u:_users' \
      '-g+[group to drop]:g:' \
      '-v[verbose]' \
      '-T+[timeout]:s:' \
      '*: :' && ret=0 ;;
esac

return ret
