#compdef shpool
# shpool: persistent terminal session pool
# https://github.com/shell-pool/shpool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --socket)'{-s,--socket}'[path to the shpool daemon socket]:path:_files' \
  '(-c --config-file)'{-c,--config-file}'[path to config file]:path:_files' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'attach:attach to a named session (creates if needed)'
      'detach:detach from the current session'
      'list:list active sessions'
      'kill:kill a named session'
      'daemon:run the shpool daemon'
      'plumbing:internal plumbing commands'
    )
    _describe -t commands 'shpool command' commands && ret=0
    ;;
  args)
    case $line[1] in
      attach)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--ttl=[time to live for the session]:duration' \
          '--cmd=[command to run in the session]:command' \
          '(-f --force)'{-f,--force}'[force reattach if already attached]' \
          '1:session name' && ret=0
        ;;
      detach)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--json[output as JSON]' && ret=0
        ;;
      kill)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:session name' && ret=0
        ;;
      daemon)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--no-daemonize[do not daemonize]' && ret=0
        ;;
    esac
    ;;
esac

return ret
