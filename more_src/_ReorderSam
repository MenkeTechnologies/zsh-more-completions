#compdef ReorderSam
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/ReorderSam.java
# Picard: reorder reads to match the contig order of a reference dictionary

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM file]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[reordered output file]:file:_files' \
  '(-D --SEQUENCE_DICTIONARY)'{-D,--SEQUENCE_DICTIONARY}'=[sequence dictionary for output]:file:_files' \
  '(-S --ALLOW_INCOMPLETE_DICT_CONCORDANCE)'{-S,--ALLOW_INCOMPLETE_DICT_CONCORDANCE}'=[allow partial contig overlap]:b:(true false)' \
  '(-U --ALLOW_CONTIG_LENGTH_DISCORDANCE)'{-U,--ALLOW_CONTIG_LENGTH_DISCORDANCE}'=[allow same-name different-length contigs]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
