#compdef ansible-galaxy-cli
# _ansible-galaxy-cli — Red Hat Ansible Galaxy role/collection manager CLI alias (ansible team, Python); argparse
# upstream: https://github.com/ansible/ansible

_ansible-galaxy-cli() {
    local -a sub=(
        'collection:collection management'
        'collection init:initialize a new collection'
        'collection build:build collection artifact'
        'collection publish:publish collection'
        'collection install:install collection'
        'collection list:list installed collections'
        'collection verify:verify collection'
        'collection download:download collection'
        'role:role management'
        'role init:initialize new role'
        'role list:list roles'
        'role search:search roles'
        'role install:install role'
        'role remove:remove role'
        'role import:import role'
        'role delete:delete role'
        'role info:show role info'
        'role login:login (deprecated)'
        'role setup:setup integrations'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-vvv[more verbose]' \
        '-vvvv[connection debug]' \
        '--ignore-certs[ignore certs]' \
        '-c[ignore certs]' \
        '--token=+[token]:str:' \
        '--api-key=+[api key]:str:' \
        '-s+[server URL]:url:_urls' \
        '--server=+[server URL]:url:_urls' \
        '--ignore-signature-status-code=+[code]:n:' \
        '--keyring=+[keyring]:file:_files' \
        '--required-valid-signature-count=+[count]:n:' \
        '--signature=+[url]:url:_urls' \
        '--offline[offline]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ansible-galaxy subcommand' sub ;;
        args)
            case $words[1] in
                collection:install) _arguments \
                    '*:collection:' \
                    '--collections-path=+[path]:dir:_files -/' \
                    '-p+[path]:dir:_files -/' \
                    '--requirements-file=+[file]:file:_files -g "requirements.{yml,yaml}"' \
                    '-r+[file]:file:_files -g "requirements.{yml,yaml}"' \
                    '--force[force]' \
                    '--force-with-deps[force with deps]' \
                    '--ignore-errors[ignore errors]' \
                    '-i[ignore errors]' \
                    '--no-deps[no deps]' \
                    '--pre[pre-release]' \
                    '--upgrade[upgrade]' \
                    '-U[upgrade]' \
                    '--keyring=+[file]:file:_files' \
                    '--disable-gpg-verify[disable gpg verify]' ;;
                collection:build) _arguments \
                    '*:dir:_files -/' \
                    '--output-path=+[dir]:dir:_files -/' \
                    '--force[force]' ;;
                collection:publish) _arguments \
                    '1:tarball:_files -g "*.tar.gz"' \
                    '--no-wait[no wait]' \
                    '--import-timeout=+[seconds]:n:' ;;
                collection:init) _arguments \
                    '1:namespace.name:' \
                    '--init-path=+[dir]:dir:_files -/' \
                    '--collection-skeleton=+[dir]:dir:_files -/' \
                    '--force[force]' ;;
                collection:list) _arguments \
                    '--collections-path=+[path]:dir:_files -/' \
                    '-p+[path]:dir:_files -/' \
                    '--format=+[format]:f:(human yaml json)' ;;
                role:install) _arguments \
                    '*:role:' \
                    '--roles-path=+[path]:dir:_files -/' \
                    '-p+[path]:dir:_files -/' \
                    '--requirements-file=+[file]:file:_files -g "requirements.{yml,yaml}"' \
                    '-r+[file]:file:_files -g "requirements.{yml,yaml}"' \
                    '--force[force]' \
                    '--force-with-deps[force with deps]' \
                    '--no-deps[no deps]' \
                    '--keep-scm-meta[keep scm meta]' \
                    '--ignore-errors[ignore errors]' \
                    '-i[ignore errors]' ;;
                role:init) _arguments \
                    '1:name:' \
                    '--init-path=+[dir]:dir:_files -/' \
                    '--role-skeleton=+[dir]:dir:_files -/' \
                    '--type=+[type]:t:(default container network)' \
                    '--force[force]' ;;
                role:search) _arguments \
                    '*:query:' \
                    '--author=+[author]:str:' \
                    '--platforms=+[platforms]:str:' \
                    '--galaxy-tags=+[tags]:str:' ;;
            esac
            ;;
    esac
}

_ansible-galaxy-cli "$@"
