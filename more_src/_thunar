#compdef thunar Thunar

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quit)'{-q,--quit}'[quit running instance]' \
  '--bulk-rename[start bulk rename]' \
  '--daemon[run as daemon]' \
  '--sm-client-id=+[session id]:id:' \
  '--display=+[X display]:display:' \
  '--print-events[print debug events]' \
  '*:uri:_files' && ret=0

return ret
