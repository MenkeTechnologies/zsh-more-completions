#compdef dnf-cli
# _dnf-cli — Red Hat DNF package manager CLI alias (Red Hat / Fedora team, Python/C); custom argparse
# upstream: https://github.com/rpm-software-management/dnf

_dnf-cli() {
    local -a sub=(
        'advisory:show advisories'
        'alias:manage aliases'
        'autoremove:remove unneeded dependencies'
        'check:check problems in package database'
        'check-update:check for updates'
        'clean:remove cached data'
        'config-manager:configuration helper'
        'copr:add/manage COPR repos'
        'debuginfo-install:install debug info'
        'deplist:list package dependencies'
        'distro-sync:sync to distribution'
        'downgrade:downgrade packages'
        'download:download packages'
        'environment:manage environments'
        'erase:remove packages (alias)'
        'group:work with groups'
        'help:show help'
        'history:show transaction history'
        'info:show info'
        'install:install packages'
        'list:list packages'
        'makecache:create cache'
        'mark:mark packages'
        'module:work with modules'
        'needs-restarting:show what needs restart'
        'offline-distrosync:offline distro sync'
        'offline-upgrade:offline upgrade'
        'provides:find which package provides file'
        'reinstall:reinstall'
        'remove:remove packages'
        'repo:repository management'
        'repolist:list configured repos'
        'repoquery:query packages from repos'
        'repository-packages:work with packages from specific repo'
        'repomanage:check rpm dir for newest'
        'repoclosure:check rpm dir for closure'
        'repograph:dot graph of repodata'
        'reposync:sync packages from remote repo'
        'search:search packages'
        'shell:interactive shell'
        'swap:swap two packages'
        'system-upgrade:full system upgrade'
        'updateinfo:show advisories info'
        'upgrade:upgrade installed packages'
        'upgrade-minimal:upgrade installed (minimal)'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--installroot=+[install root]:dir:_files -/' \
        '--releasever=+[release version]:str:' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debugsolver[debug solver]' \
        '--disablerepo=+[disable repo]:list:' \
        '--enablerepo=+[enable repo]:list:' \
        '--repo=+[only this repo]:list:' \
        '--repofrompath=+[repo from path]:str:' \
        '--exclude=+[exclude packages]:list:' \
        '-x+[exclude packages]:list:' \
        '--disableexcludes=+[disable excludes]:list:' \
        '--assumeyes[assume yes]' \
        '-y[assume yes]' \
        '--assumeno[assume no]' \
        '--nodocs[no docs]' \
        '--noplugins[no plugins]' \
        '--allowerasing[allow erasing]' \
        '--best[best version]' \
        '--no-best[no best]' \
        '--bugfix[bugfix only]' \
        '--cacheonly[cache only]' \
        '-C[cache only]' \
        '--color=+[color]:c:(always auto never)' \
        '--cve=+[CVE]:list:' \
        '--enhancement[enhancement]' \
        '--newpackage[new package]' \
        '--obsoletes[handle obsoletes]' \
        '--refresh[refresh metadata]' \
        '--repofrompath=+[repo from path]:str:' \
        '--rpmverbosity=+[rpm verbosity]:level:(critical emergency error warn info debug)' \
        '--security[security only]' \
        '--setopt=+[set option]:str:' \
        '--showduplicates[show duplicates]' \
        '--skip-broken[skip broken]' \
        '--tolerant[tolerant]' \
        '-t[tolerant]' \
        '--use-host-config[use host config]' \
        '--downloadonly[download only]' \
        '--downloaddir=+[download dir]:dir:_files -/' \
        '--destdir=+[destdir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dnf subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|erase|upgrade|reinstall|downgrade|info|list|search|download|provides|repoquery|deplist|swap|mark|autoremove) _arguments '*:package:' ;;
                history) _arguments \
                    '1:cmd:(list info undo redo rollback userinstalled new sync stats)' \
                    '*:arg:' ;;
                group) _arguments \
                    '1:cmd:(install remove list info summary mark upgrade)' \
                    '*:arg:' ;;
                module) _arguments \
                    '1:cmd:(install update remove enable disable reset list info provides repoquery)' \
                    '*:arg:' ;;
                repo|repolist) _arguments \
                    '1:cmd:(list enable disable info)' \
                    '*:arg:' ;;
                copr) _arguments \
                    '1:cmd:(enable disable remove list debug search)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_dnf-cli "$@"
