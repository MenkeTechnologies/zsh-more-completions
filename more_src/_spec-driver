#compdef spec-driver
# Documentation: https://github.com/davidlee/spec-driver
# Reference accessed: 2026-05-22
# Verified: supekku/cli/main.py Typer app command registrations.

# Zsh completion for spec-driver - specification-driving development toolkit

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'spec-driver command' \
      'install[initialize workspace]' \
      'validate[validate workspace metadata]' \
      'doctor[health diagnostics]' \
      'sync[synchronize specs and registries]' \
      'create[create artifacts]' \
      'list[list artifacts]' \
      'show[show artifact details]' \
      'view[view rendered markdown]' \
      'read[alias for view]' \
      'edit[edit artifact in editor]' \
      'find[find artifact by ID]' \
      'complete[complete artifacts]' \
      'admin[workspace maintenance]' \
      'phase[workflow phase operations]' \
      'workflow[workflow orchestration]' \
      'accept[accept workflow handoffs]' \
      'review[review lifecycle]' \
      'block[block workflow]' \
      'unblock[unblock workflow]' \
      'tui[interactive artifact browser]' && ret=0
    ;;
esac

return ret
