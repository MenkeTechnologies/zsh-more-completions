#compdef gotty

_arguments \
  '(-a --address)'{-a,--address}'[IP address to listen on]:address' \
  '(-p --port)'{-p,--port}'[port to listen on]:port' \
  '(-c --credential)'{-c,--credential}'[credential for basic auth]:user\:pass' \
  '(-r --randomurl)'{-r,--randomurl}'[add random URL prefix]' \
  '--random-url-length[length of random URL]:length' \
  '(-w --permit-write)'{-w,--permit-write}'[permit clients to write to the TTY]' \
  '--permit-arguments[permit clients to send arguments]' \
  '(-t --title-format)'{-t,--title-format}'[title format]:format' \
  '--reconnect[enable reconnection]' \
  '--reconnect-time[time to reconnect in seconds]:seconds' \
  '--max-connection[maximum number of connections]:number' \
  '--once[accept only one client then exit]' \
  '--timeout[timeout in seconds]:seconds' \
  '--config[config file path]:file:_files' \
  '--width[static width]:columns' \
  '--height[static height]:rows' \
  '--ws-origin[WebSocket origin to accept]:origin' \
  '--term[terminal type to report]:terminfo' \
  '--close-signal[signal to send on close]:signal' \
  '--close-timeout[time to force kill process]:seconds' \
  '--preferences-path[preferences file path]:file:_files' \
  '--enable-tls[enable TLS/SSL]' \
  '--tls-cert[TLS certificate file]:file:_files' \
  '--tls-key[TLS key file]:file:_files' \
  '--tls-ca-crt[TLS CA certificate file]:file:_files' \
  '--index[custom index.html]:file:_files' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:_command_names -e' \
  '*::arguments:_normal'
