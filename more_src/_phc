#compdef phc
# Documentation: http://homepages.math.uic.edu/~jan/phcpack_doc_html/options.html
# PHCpack: polynomial homotopy continuation solver

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[writes helpful information to screen]' \
  '--version[displays the current version string]' \
  '-0[random numbers with fixed seed for repeatable runs]' \
  '-a[solving polynomial systems equation-by-equation]' \
  '-b[batch or blackbox processing]' \
  '-B[numerical irreducible decomposition in blackbox mode]' \
  '-c[irreducible decomposition for solution components]' \
  '-d[linear and nonlinear reduction w.r.t. the total degree]' \
  '-e[SAGBI/Pieri/Littlewood-Richardson homotopies]' \
  '-f[factor a pure dimensional solution set into irreducibles]' \
  '-g[check the format of an input polynomial system]' \
  '-j[path tracking with algorithmic differentiation]' \
  '-k[realization of dynamic output feedback placing poles]' \
  '-l[witness set for hypersurface cutting with random line]' \
  '-m[mixed volumes, MixedVol, DEMiCs, polyhedral homotopies]' \
  '-o[writes the symbol table of an input system]' \
  '-p[polynomial continuation in one parameter]' \
  '-q[tracking solution paths with incremental read/write]' \
  '-r[root counting and construction of start systems]' \
  '-s[equation and variable scaling on system and solutions]' \
  '-t[tasking for tracking paths using multiple threads]' \
  '-u[Newtons method and continuation with power series]' \
  '-v[verification, refinement and purification of solutions]' \
  '-V[run in verbose mode]' \
  '-w[witness set intersection using diagonal homotopies]' \
  '-x[convert solutions from PHCpack into Python dictionary]' \
  '-y[sample points from an algebraic set, given witness set]' \
  '-z[strip phc output solution lists into Maple format]' \
  '*:file:_files' && ret=0

return ret
