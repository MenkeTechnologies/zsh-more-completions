#compdef xkibitz
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/xkibitz.1.html
# Share an xterm among multiple displays

local ret=1

_arguments -s \
  '-escape[set the escape character (default ^])]:char:' \
  '*-display[add a display to the xkibitz session]:display:' \
  '*::program:_command_names -e' && ret=0

return ret
