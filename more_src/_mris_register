#compdef mris_register
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_register
# FreeSurfer register a surface to an average surface template

local ret=1

_arguments -s -S \
  '-1[treat target as a single subject surface not template]' \
  '-addframe[add field to atlas]:which_field where_in_atlas:' \
  '-annot[zero medial wall using annotation]:annot_name:' \
  '-C[specify curvature file]:curvature_fname:_files' \
  '-canon[use surface for canonical properties]:canon_name:' \
  '-inflated[use inflated surface for initial alignment]' \
  '-infname[name for inflated surface]:name:' \
  '-L[manual label alignment]:labelfile atlas_gcsa label_name:' \
  '-O[use orig_name for original properties]:orig_name:' \
  '-overlay[add variable from overlay file]:overlay_file navgs:' \
  '-overlay-dir[change overlay path]:overlay_dir:_files -/' \
  '-sreg[start registration with coords in file]:starting_reg_fname:_files' \
  '-jacobian[write out jacobian of mapping to file]:jacobian_fname:_files' \
  '-curv[use curvature]' \
  '-nocurv[do not use curvature]' \
  '-dist[distance term]:dist:' \
  '-tol[tolerance]:tol:' \
  '-nbrs[neighborhood size]:nbrs:' \
  '-norot[no rotation]' \
  '-rotate[rotation]:rotate:' \
  '-search[search]' \
  '-V[vertex number for diagnostics]:Gdiag_no:' \
  '-vector[print multiframe mode help]' \
  '--help[print help]' \
  '--version[print version]' \
  '1:surface to register (hemi.sphere):_files' \
  '2:target template:_files' \
  '3:output surface (hemi.sphere.reg):_files' && ret=0

return ret
