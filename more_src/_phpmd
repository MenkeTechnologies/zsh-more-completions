#compdef phpmd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--minimumpriority[minimum rule priority]:priority:(1 2 3 4 5)' \
  '--reportfile[send report to file]:file:_files' \
  '--suffixes[comma-separated list of valid file suffixes]:suffixes' \
  '--exclude[comma-separated list of patterns to exclude]:patterns' \
  '--strict[also report for nodes with @SuppressWarnings]' \
  '--not-strict[do not report for nodes with @SuppressWarnings]' \
  '--ignore-violations-on-exit[exit with zero even with violations]' \
  '--ignore-errors-on-exit[exit with zero even with errors]' \
  '--generate-baseline[generate baseline file]' \
  '--update-baseline[update existing baseline file]' \
  '--baseline-file[baseline file path]:file:_files' \
  '--cache[enable result cache]' \
  '--cache-file[cache file path]:file:_files' \
  '--cache-strategy[cache strategy]:strategy:(content timestamp)' \
  '--color[enable color output]' \
  '--extra-line-in-excerpt[extra context lines]:count' \
  '1:source:_files' \
  '2:report format:(xml text html json ansi github sarif checkstyle)' \
  '3:ruleset:(cleancode codesize controversial design naming unusedcode)' && ret=0

return ret