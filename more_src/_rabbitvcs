#compdef rabbitvcs
# Documentation: https://man.archlinux.org/search?q=rabbitvcs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'about:show about dialog'
  'add:add files'
  'annotate:show file annotations (blame)'
  'browser:repository browser'
  'changes:show changes'
  'checkout:checkout from repo'
  'cleanup:cleanup working copy'
  'commit:commit changes'
  'create:create repository'
  'delete:delete files'
  'diff:show diff'
  'export:export from repo'
  'help:show help'
  'ignore:add to ignore list'
  'import:import to repository'
  'lock:lock files'
  'log:show log'
  'mark-resolved:mark conflicts resolved'
  'merge:merge changes'
  'properties:show file properties'
  'rename:rename files'
  'revert:revert changes'
  'settings:open settings'
  'switch:switch working copy'
  'unlock:unlock files'
  'update:update working copy'
  'updateto:update to revision'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--vcs=[VCS backend]:vcs:(svn git mercurial)' \
  '1: :->cmd' \
  '*::path:_files' && ret=0

case $state in
  (cmd) _describe -t cmds 'rabbitvcs command' commands && ret=0 ;;
esac

return ret
