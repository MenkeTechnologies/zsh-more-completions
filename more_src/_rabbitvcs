#compdef rabbitvcs
# Documentation: https://github.com/rabbitvcs/rabbitvcs/blob/master/clients/cli/main.py
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'about:show about dialog'
  'add:add files'
  'annotate:show file annotations (blame)'
  'applypatch:apply patch'
  'branch:create branch (svn) / branches (git)'
  'branches:list/manage branches (git)'
  'browser:repository browser'
  'changes:show changes'
  'checkmods:check modifications'
  'checkout:checkout from repo'
  'clean:clean (git)'
  'cleanup:cleanup working copy (svn)'
  'clone:clone repository (git)'
  'commit:commit changes'
  'create:create repository'
  'createpatch:create a patch'
  'delete:delete files'
  'diff:show diff'
  'editconflicts:edit conflicts'
  'export:export from repo'
  'help:show help'
  'ignore:add to ignore list'
  'import:import to repository'
  'lock:lock files (svn)'
  'log:show log'
  'markresolved:mark conflicts resolved (svn)'
  'merge:merge changes'
  'open:open file/path'
  'properties:show file properties (svn)'
  'push:push (git)'
  'relocate:relocate working copy (svn)'
  'remotes:manage remotes (git)'
  'rename:rename files'
  'reset:reset (git)'
  'revert:revert changes'
  'settings:open settings'
  'switch:switch working copy (svn)'
  'tags:manage tags (git)'
  'unlock:unlock files (svn)'
  'update:update working copy'
  'updateto:update to revision (svn)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::path:_files' && ret=0

case $state in
  (cmd) _describe -t cmds 'rabbitvcs command' commands && ret=0 ;;
esac

return ret
