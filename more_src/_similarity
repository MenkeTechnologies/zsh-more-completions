#compdef similarity
# Documentation: https://apbs.readthedocs.io/en/latest/using/tools.html
# Compute similarity metrics between two scalar grid datasets

local ret=1

_arguments -s \
  '(- *)--help[print help message]' \
  '--format=[input file format]:format:(dx dxbin)' \
  '--scalar1=[first scalar data file]:file:_files' \
  '--scalar2=[second scalar data file]:file:_files' \
  '--mask1=[mask file for data set 1]:file:_files' \
  '--mask2=[mask file for data set 2]:file:_files' \
  '--transform=[coordinate transformation file]:file:_files' && ret=0

return ret
