#compdef virt-clone
# _virt-clone — virt-manager virt-clone (clone a libvirt domain definition + its storage; -o original domain, -n new domain name, -f new disk image, --auto-clone auto pick name/path, --mac, --uuid, --check skip-cb compat, --replace overwrite existing, --preserve-data don't copy data)
# upstream: https://github.com/virt-manager/virt-manager (virt-clone)
# Flags from virt-manager virtinst/cli.py + virt-clone on tip.

_virt-clone() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-c+[libvirt URI]:uri:' \
        '--connect+[libvirt URI]:uri:' \
        '-o+[original domain]:domain:' \
        '--original+[original domain]:domain:' \
        '--original-xml+[xml file]:file:_files -g "*.xml"' \
        '-n+[new domain name]:name:' \
        '--name+[new domain name]:name:' \
        '*-f+[disk image]:file:_files' \
        '*--file+[disk image]:file:_files' \
        '--auto-clone[auto-generate name and paths]' \
        '--mac+[mac address]:mac:' \
        '--uuid+[uuid]:uuid:' \
        '--replace[overwrite existing]' \
        '--preserve-data[reuse storage, do not copy]' \
        '--reflink[btrfs/xfs reflink copy]' \
        '--sparse[sparse copy]' \
        '--nonsparse[force non-sparse copy]' \
        '--print-xml[print resulting xml only]' \
        '--check+[checks]:checks:(all none disk_size path_in_use)' \
        '*:other arg:'
}

_virt-clone "$@"
