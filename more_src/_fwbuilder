#compdef fwbuilder
# Documentation: https://manpages.debian.org/bookworm/fwbuilder/fwbuilder.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm fwbuilder(1) manpage OPTIONS.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# fwbuilder: graphical firewall policy builder
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '-f[file to open at startup]:file:_files' \
  '-r[open RCS head revision of file]' \
  '-d[debug mode]' \
  '-o[output file for print operation]:file:_files' \
  '-P[print rules/objects for firewall object then exit]:object name:' \
  '*:file:_files' && ret=0
return ret
