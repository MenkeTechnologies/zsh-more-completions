#compdef snmptt snmpttd
# Documentation: https://man.archlinux.org/search?q=snmptt
# Reference accessed: 2026-05-16

_arguments -s \
  '--daemon[run as daemon]' \
  '--debug=[debug level]:n:' \
  '--debugfile=[debug log file]:file:_files' \
  '--ini=[ini file]:file:_files -g "*.ini"' \
  '--dump[dump defined traps]' \
  '--time[measure load time]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]'
