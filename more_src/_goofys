#compdef goofys

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-o+[FUSE mount options]:options' \
  '--dir-mode=[directory permissions]:mode' \
  '--file-mode=[file permissions]:mode' \
  '--uid=[owner UID]:uid' \
  '--gid=[owner GID]:gid' \
  '--endpoint=[S3 endpoint]:endpoint URL' \
  '--region=[AWS region]:region' \
  '--storage-class=[storage class]:class:(STANDARD STANDARD_IA ONEZONE_IA REDUCED_REDUNDANCY INTELLIGENT_TIERING GLACIER DEEP_ARCHIVE)' \
  '--profile=[AWS credential profile]:profile' \
  '--use-content-type[detect content type]' \
  '--sse[enable server-side encryption]' \
  '--sse-kms=[use SSE-KMS with key ID]:key ID' \
  '--sse-c=[use SSE-C with key]:key' \
  '--acl=[canned ACL]:acl:(private public-read public-read-write authenticated-read aws-exec-read bucket-owner-read bucket-owner-full-control)' \
  '--subdomain[use subdomain-style S3 URLs]' \
  '--requester-pays[enable requester pays]' \
  '-f[foreground operation]' \
  '--cheap[reduce S3 API calls]' \
  '--no-implicit-dir[do not create implicit directories]' \
  '--stat-cache-ttl=[stat cache TTL]:duration' \
  '--type-cache-ttl=[type cache TTL]:duration' \
  '--http-timeout=[HTTP timeout]:duration' \
  '--debug_fuse[enable FUSE debug output]' \
  '--debug_s3[enable S3 debug output]' \
  '1:bucket\:prefix:' \
  '2:mountpoint:_directories' && ret=0

return ret
