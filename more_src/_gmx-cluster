#compdef gmx-cluster
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-cluster.html
# gmx cluster: cluster structures

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[structure with mass database]:file:_files' \
  '-n[index file]:file:_files' \
  '-dm[RMSD matrix file]:file:_files' \
  '-om[raw RMSD matrix output]:file:_files' \
  '-o[clustered RMSD matrix output]:file:_files' \
  '-g[log file with cluster details]:file:_files' \
  '-dist[RMSD distribution]:file:_files' \
  '-ev[eigenvectors from diagonalization]:file:_files' \
  '-conv[Monte Carlo convergence]:file:_files' \
  '-sz[cluster sizes]:file:_files' \
  '-tr[transition matrix]:file:_files' \
  '-ntr[transition counts]:file:_files' \
  '-clid[cluster ID vs time]:file:_files' \
  '-cl[cluster structures]:file:_files' \
  '-clndx[cluster index file]:file:_files' \
  '-b[first frame time]:time:' \
  '-e[last frame time]:time:' \
  '-dt[frame sampling interval]:time:' \
  '-tu[time unit]:unit:(fs ps ns us ms s)' \
  '-w[view output files]' \
  '-xvg[xvg plot format]:format:(xmgrace xmgr none)' \
  '-dista[use distance RMSD instead of coordinate RMSD]' \
  '-nlevels[matrix discretization levels]:int:' \
  '-cutoff[RMSD cutoff in nm]:real:' \
  '-fit[apply least squares fitting]' \
  '-max[maximum RMSD level]:real:' \
  '-skip[analyze every nth frame]:int:' \
  '-av[write average vs central structure]' \
  '-wcl[write structures for n clusters]:int:' \
  '-nst[minimum structures per cluster for output]:int:' \
  '-rmsmin[minimum RMS for cluster member output]:real:' \
  '-method[clustering algorithm]:method:(linkage jarvis-patrick monte-carlo diagonalization gromos)' \
  '-minstruct[minimum structures for coloring]:int:' \
  '-binary[treat matrix as binary]' \
  '-pbc[apply periodic boundary condition check]' \
  '-M[Jarvis-Patrick nearest neighbors]:int:' \
  '-P[Jarvis-Patrick common neighbors required]:int:' \
  '-seed[Monte Carlo random seed]:int:' \
  '-niter[Monte Carlo iterations]:int:' \
  '-nrandom[initial random MC iterations]:int:' \
  '-kT[Monte Carlo Boltzmann factor]:real:' && ret=0

return ret
