#compdef alp
# Documentation: https://man.archlinux.org/search?q=alp
# Reference accessed: 2026-05-16

# tkuchiki/alp — see cmd/alp/cmd/flags.go (profile options) and command.go (modes).

local curcontext="$curcontext" state line ret=1

local -a prof=(
  '--config=[YAML config]:file:_files'
  '--file=[access log path]:file:_files'
  '--dump=[dump profiled YAML path]:file:_files'
  '--load=[load profiled YAML path]:file:_files'
  '--format=[output format]:format:(table markdown tsv csv html json)'
  '--sort=[sort field]:field:'
  '(-r)'{-r,--reverse}'[reverse sort order]'
  '--noheaders[omit header row]'
  '--show-footers[show footer row]'
  '--limit=[max rows]:count:'
  '(-o)'{-o+,--output=}'[comma-separated result columns]:columns:'
  '-q --query-string[include URI query string]'
  '--qs-ignore-values[mask query values]'
  '--location=[timezone location name]:tz:'
  '--decode-uri[decode percent-encoded URI]'
  '(-m)'{-m+,--matching-groups=}'[URI grouping regex captures]:groups:'
  '(-f)'{-f+,--filters=}'[log filter expression]:filter:'
  '--pos=[position file]:file:_files'
  '--nosave-pos[do not write position file]'
  '--percentiles=[comma-separated percentiles]:list:'
  '--page=[pagination depth]:pages:'
)

local -a json_extra=(
  '--uri-key=[JSON uri field]:key:'
  '--method-key=[JSON method field]:key:'
  '--time-key=[JSON time field]:key:'
  '--restime-key=[JSON response time field]:key:'
  '--reqtime-key=[JSON request time field]:key:'
  '--body-bytes-key=[JSON body bytes field]:key:'
  '--status-key=[JSON status field]:key:'
)

local -a ltsv_extra=(
  '--uri-label=[LTSV uri label]:label:'
  '--method-label=[LTSV method label]:label:'
  '--time-label=[LTSV time label]:label:'
  '--apptime-label=[LTSV apptime label]:label:'
  '--reqtime-label=[LTSV reqtime label]:label:'
  '--size-label=[LTSV size label]:label:'
  '--status-label=[LTSV status label]:label:'
)

local -a rx_extra=(
  '--pattern=[line regexp]:pattern:'
  '--uri-subexp=[URI regexp subexp]:n:'
  '--method-subexp=[method subexp]:n:'
  '--time-subexp=[time subexp]:n:'
  '--restime-subexp=[response time subexp]:n:'
  '--reqtime-subexp=[request time subexp]:n:'
  '--body-bytes-subexp=[body bytes subexp]:n:'
  '--status-subexp=[status subexp]:n:'
)

local -a pcap_extra=(
  '--pcap-server-ip=[server IP]:ip:'
  '--pcap-server-port=[server port]:port:'
)

_arguments -s -S \
  '--version[show version]' \
  '1: :->mode' \
  '*:: :->rest' && ret=0

case $state in
  (mode)
    _describe -t commands 'alp mode' '(ltsv json regexp pcap diff)' && ret=0
    ;;
  (rest)
    case $line[1] in
      (diff)
        _arguments -s -S \
          $prof \
          ':from profile YAML:_files' \
          ':to profile YAML:_files' && ret=0
        ;;
      (ltsv)
        if (( $#line == 1 )); then
          _describe -t commands 'ltsv' '(diff topN count :profile log directly)' && ret=0
        else
          case $line[2] in
            (diff)
              _arguments -s -S $prof $ltsv_extra ':from log:_files' ':to log:_files' && ret=0
              ;;
            (topN)
              _arguments -s -S $prof $ltsv_extra '::[N]: ' && ret=0
              ;;
            (count)
              _arguments -s -S $prof $ltsv_extra '--keys=[count keys expression]:keys:' && ret=0
              ;;
            (*)
              _arguments -s -S $prof $ltsv_extra '*:log file:_files' && ret=0
              ;;
          esac
        fi
        ;;
      (json)
        if (( $#line == 1 )); then
          _describe -t commands 'json' '(diff topN count :profile log directly)' && ret=0
        else
          case $line[2] in
            (diff)
              _arguments -s -S $prof $json_extra ':from log:_files' ':to log:_files' && ret=0
              ;;
            (topN)
              _arguments -s -S $prof $json_extra '::[N]: ' && ret=0
              ;;
            (count)
              _arguments -s -S $prof $json_extra '--keys=[count keys expression]:keys:' && ret=0
              ;;
            (*)
              _arguments -s -S $prof $json_extra '*:log file:_files' && ret=0
              ;;
          esac
        fi
        ;;
      (regexp)
        if (( $#line == 1 )); then
          _describe -t commands 'regexp' '(diff topN count :profile log directly)' && ret=0
        else
          case $line[2] in
            (diff)
              _arguments -s -S $prof $rx_extra ':from log:_files' ':to log:_files' && ret=0
              ;;
            (topN)
              _arguments -s -S $prof $rx_extra '::[N]: ' && ret=0
              ;;
            (count)
              _arguments -s -S $prof $rx_extra '--keys=[count keys expression]:keys:' && ret=0
              ;;
            (*)
              _arguments -s -S $prof $rx_extra '*:log file:_files' && ret=0
              ;;
          esac
        fi
        ;;
      (pcap)
        if (( $#line == 1 )); then
          _describe -t commands 'pcap' '(diff topN :profile capture directly)' && ret=0
        else
          case $line[2] in
            (diff)
              _arguments -s -S $prof $pcap_extra ':from capture:_files' ':to capture:_files' && ret=0
              ;;
            (topN)
              _arguments -s -S $prof $pcap_extra '::[N]: ' && ret=0
              ;;
            (*)
              _arguments -s -S $prof $pcap_extra '*:pcap file:_files' && ret=0
              ;;
          esac
        fi
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
