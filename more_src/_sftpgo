#compdef sftpgo
# Documentation: https://github.com/drakkan/sftpgo
# Reference accessed: 2026-05-21
# Verified: upstream src tree under internal/cmd/ at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'serve:start the SFTPGo service'
  'portable:serve a single directory/account'
  'initprovider:initialize or update the configured data provider'
  'resetprovider:reset the data provider (data will be lost)'
  'revertprovider:revert data provider to a previous version'
  'resetpwd:reset administrator password'
  'acme:obtain TLS certificates from ACME-based CAs'
  'gen:built-in generators (config, completion, manpage, etc.)'
  'startsubsys:run as an OpenSSH-compatible SFTP subsystem'
  'ping:health check to a SFTPGo instance'
  'smtptest:test SMTP configuration'
  'service:manage SFTPGo as a system service (Windows)'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config-dir)'{-c+,--config-dir=}'[configuration directory]:dir:_files -/' \
  '(-f --config-file)'{-f+,--config-file=}'[config file path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sftpgo command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (serve)
        _arguments \
          '--grace-time=[graceful shutdown seconds]:n:' \
          '--loaddata-from=[load users/folders from backup]:file:_files' \
          '--loaddata-clean[remove file after load]' \
          '--loaddata-mode=[restore mode]:mode:(0 1)' \
          '--loaddata-scan=[quota scan mode]:mode:(0 1 2)' \
          '--log-compress[compress rotated logs]' \
          '--log-file-path=[log file]:file:_files' \
          '--log-max-age=[log retention days]:n:' \
          '--log-max-backups=[old log files to keep]:n:' \
          '--log-max-size=[log size before rotation (MB)]:n:' \
          '--log-level=[log verbosity]:level:(debug info warn error)' \
          '--log-utc-time[use UTC for log timestamps]' && ret=0 ;;
      (portable)
        _arguments \
          '(-d --directory)'{-d+,--directory=}'[directory to serve]:dir:_files -/' \
          '(-u --username)'{-u+,--username=}'[username]:user:' \
          '(-p --password)'{-p+,--password=}'[password]:pass:' \
          '(-s --sftpd-port)'{-s+,--sftpd-port=}'[SFTP port]:port:' \
          '--ftpd-port=[FTPS port]:port:' \
          '--webdav-port=[WebDAV port]:port:' \
          '--ftpd-cert=[FTPS cert]:file:_files' \
          '--ftpd-key=[FTPS key]:file:_files' \
          '*--allowed-patterns=[allowed file patterns]:patterns:' \
          '*--denied-patterns=[denied file patterns]:patterns:' \
          '--public-key=[public key]:file:_files' \
          '--fs-provider=[filesystem provider]:provider:(0 1 2 3 4 5)' && ret=0 ;;
      (initprovider|resetprovider|revertprovider)
        _arguments \
          '--force[skip confirmation prompts]' && ret=0 ;;
      (acme)
        _arguments \
          '*::sub:(register run)' && ret=0 ;;
      (gen)
        local -a gen_subs=(
          'completion:generate shell completion script'
          'man:generate man pages'
        )
        _describe -t gencmds 'gen subcommand' gen_subs && ret=0 ;;
      (service)
        _arguments '*::sub:(install start stop status reload uninstall rotatelogs)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
