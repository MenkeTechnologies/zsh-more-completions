#compdef sing-box

# Zsh completion for sing-box - universal proxy platform

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'run:run the service'
      'check:check configuration'
      'format:format configuration'
      'merge:merge configurations'
      'generate:generate things'
      'geosite:geosite tools'
      'geoip:geoip tools'
      'rule-set:rule-set tools'
      'tools:various tools'
      'version:print version'
      'completion:generate shell completion'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case "$words[1]" in
      run)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[configuration file path]:file:_files' \
          '(-C --config-directory)'{-C,--config-directory}'[configuration directory path]:dir:_files -/' \
          '(-D --directory)'{-D,--directory}'[working directory]:dir:_files -/' \
          '--disable-color[disable color output]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      check)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[configuration file path]:file:_files' \
          '(-C --config-directory)'{-C,--config-directory}'[configuration directory path]:dir:_files -/' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      format)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[configuration file path]:file:_files' \
          '(-C --config-directory)'{-C,--config-directory}'[configuration directory path]:dir:_files -/' \
          '(-w --write)'{-w,--write}'[write result to config file]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(tls-keypair reality-keypair rand)' && ret=0
        ;;
      rule-set)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(compile decompile match format)' && ret=0
        ;;
      tools)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(connect fetch)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
