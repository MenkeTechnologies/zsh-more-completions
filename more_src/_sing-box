#compdef sing-box

# Zsh completion for sing-box - universal proxy platform

local -a subcommands
subcommands=(
  'run:Run the service'
  'check:Check the configuration'
  'format:Format the configuration'
  'merge:Merge configurations'
  'generate:Generate things'
  'geosite:Manage geosite resources'
  'geoip:Manage geoip resources'
  'rule-set:Manage rule-set resources'
  'tools:Experimental tools'
  'version:Print version'
  'completion:Generate shell completion script'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:subcommand:->subcmd' \
  '*:: :->args'

case $state in
  subcmd)
    _describe -t subcommands 'sing-box subcommand' subcommands
    ;;
  args)
    case $words[1] in
      run)
        _arguments \
          '(-c --config)'{-c,--config}'[specify configuration file]:config file:_files' \
          '(-C --config-directory)'{-C,--config-directory}'[specify configuration directory]:config dir:_directories' \
          '(-D --directory)'{-D,--directory}'[specify working directory]:working dir:_directories' \
          '--disable-color[disable color output]'
        ;;
      check)
        _arguments \
          '(-c --config)'{-c,--config}'[specify configuration file]:config file:_files' \
          '(-C --config-directory)'{-C,--config-directory}'[specify configuration directory]:config dir:_directories'
        ;;
      format)
        _arguments \
          '(-c --config)'{-c,--config}'[specify configuration file]:config file:_files' \
          '(-C --config-directory)'{-C,--config-directory}'[specify configuration directory]:config dir:_directories' \
          '(-w --write)'{-w,--write}'[write result to config file]'
        ;;
      merge)
        _arguments \
          '(-c --config)'{-c,--config}'[specify configuration file]:config file:_files' \
          '(-C --config-directory)'{-C,--config-directory}'[specify configuration directory]:config dir:_directories' \
          '*:output file:_files'
        ;;
      generate)
        local -a gen_cmds
        gen_cmds=(
          'tls-keypair:Generate TLS key pair'
          'reality-keypair:Generate reality key pair'
          'rand:Generate random bytes'
        )
        _arguments -C \
          '1:generate subcommand:->gen_sub' \
          '*:: :->gen_args'
        case $state in
          gen_sub)
            _describe -t gen_cmds 'generate subcommand' gen_cmds
            ;;
        esac
        ;;
      rule-set)
        local -a rs_cmds
        rs_cmds=(
          'compile:Compile rule-set source to binary'
          'decompile:Decompile rule-set binary to source'
          'match:Match rule-set against input'
          'format:Format rule-set source file'
        )
        _arguments -C \
          '1:rule-set subcommand:->rs_sub' \
          '*:: :->rs_args'
        case $state in
          rs_sub)
            _describe -t rs_cmds 'rule-set subcommand' rs_cmds
            ;;
          rs_args)
            _arguments '*:file:_files'
            ;;
        esac
        ;;
      tools)
        local -a tools_cmds
        tools_cmds=(
          'connect:Connect to a remote address'
          'fetch:Fetch a URL'
        )
        _arguments -C \
          '1:tools subcommand:->tools_sub' \
          '*:: :->tools_args'
        case $state in
          tools_sub)
            _describe -t tools_cmds 'tools subcommand' tools_cmds
            ;;
        esac
        ;;
      *)
        _arguments '*:arguments'
        ;;
    esac
    ;;
esac
