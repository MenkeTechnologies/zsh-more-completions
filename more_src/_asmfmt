#compdef asmfmt
# Documentation: https://man.archlinux.org/search?q=asmfmt
# Reference accessed: 2026-05-16

_arguments -s -S \
  '-l[list files that would change]' \
  '-w[write formatted output back to sources]' \
  '-d[show diffs instead of rewriting]' \
  '-e[report all errors instead of stopping after ten]' \
  '-cpuprofile=[write CPU profile to file]:profile file:_files' \
  '*:Go assembler file or directory:_files'
