#compdef sfigrad
# Documentation: https://www.reproducibility.org/wiki/Guide_to_madagascar_programs
# Madagascar: gradient on the first axis

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'adj=[adjoint flag (y/n)]:adj:(y n)' \
  'square=[take the square (y/n)]:square:(y n)' \
  '*: :_files' && ret=0

return ret
