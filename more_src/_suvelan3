#compdef suvelan3
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/test/suvelan3.c
# compute stacking velocity semblance for cdp gathers

local ret=1

_arguments -s -S \
  'nv=[number of velocities]:n' \
  'dv=[velocity sampling interval]:dv' \
  'fv=[first velocity]:fv' \
  'slowness=[0 velocity, 1 slowness, 2 slowness-squared linearly incremented]:slowness:(0 1 2)' \
  'smute=[NMO stretch mute factor]:smute' \
  'dtratio=[ratio of output to input time sampling intervals]:dtratio' \
  'nsmooth=[length of semblance num and den smoothing window]:nsmooth' \
  'normpow=[=1 divide by live traces after nmo, =0 by total traces in cmp]:normpow:(0 1)' \
  'verbose=[=1 for diagnostic print on stderr]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
