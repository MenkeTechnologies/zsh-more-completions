#compdef terjira jira
# Documentation: https://github.com/keepcosmos/terjira
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for terjira - command-line Jira tool

local curcontext="$curcontext" state line ret=1

local -a topcmds=(
  'login:authenticate with Jira'
  'logout:disconnect from Jira'
  'project:project commands'
  'board:board commands'
  'sprint:sprint commands'
  'issue:issue commands'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'terjira command' topcmds && ret=0 ;;
  (args)
    case $line[1] in
      (project)
        _arguments '1:subcommand:(ls list)' && ret=0 ;;
      (board)
        _arguments '1:subcommand:(ls list backlog)' && ret=0 ;;
      (sprint)
        _arguments '1:subcommand:(ls list active)' && ret=0 ;;
      (issue)
        _arguments \
          '1:subcommand:(ls list jql search assign attach_file comment edit_comment delete edit new open url take trans)' && ret=0 ;;
    esac ;;
esac

return ret
