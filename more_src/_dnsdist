#compdef dnsdist

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-C+[configuration file]:config file:_files' \
  '--config=[configuration file]:config file:_files' \
  '--check-config[check configuration and exit]' \
  '-c+[connect to control console]:address:' \
  '--client=[connect to control console]:address:' \
  '-k+[control console key]:key:' \
  '--setkey=[control console key]:key:' \
  '-e+[execute command]:command:' \
  '--execute=[execute command]:command:' \
  '-l+[listen address]:address:' \
  '--local=[listen address]:address:' \
  '-d[run as daemon]' \
  '--daemon[run as daemon]' \
  '-p+[PID file]:pid file:_files' \
  '--pidfile=[PID file]:pid file:_files' \
  '-u+[set uid]:user:_users' \
  '--uid=[set uid]:user:_users' \
  '-g+[set gid]:group:_groups' \
  '--gid=[set gid]:group:_groups' \
  '-s[run in supervised mode]' \
  '--supervised[run in supervised mode]' \
  '-v+[verbose mode]:level:' \
  '--verbose=[verbose mode]:level:' \
  '--api-key=[API key]:key:' \
  '--webserver-address=[webserver listen address]:address:' \
  '--webserver-port=[webserver port]:port:' \
  '*:downstream addresses:' && ret=0

return ret
