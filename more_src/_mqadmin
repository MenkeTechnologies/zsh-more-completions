#compdef mqadmin

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'topicList:fetch all topics from nameserver'
  'topicRoute:fetch topic route info'
  'topicStatus:examine topic offset/min/max/lastUpdateTime info'
  'topicClusterList:fetch topic cluster list'
  'updateTopic:create/update topic'
  'deleteTopic:delete topic'
  'updateBrokerConfig:update broker config'
  'updateAclConfig:update broker ACL config'
  'deleteAclConfig:delete broker ACL config'
  'updateGlobalWhiteAddr:update global white IP addresses'
  'getAccessConfigSubCommand:get accounts subcommand'
  'aclConfigVersion:get ACL config version'
  'consumerProgress:query consumers progress and speed'
  'consumerStatus:query consumer connection and consume status'
  'consumerConnection:query consumer connection info'
  'producerConnection:query producer connection info'
  'getConsumerStatus:get consumer status'
  'updateSubGroup:update or create subscription group'
  'deleteSubGroup:delete subscription group'
  'cloneGroupOffset:clone offsets from group'
  'consumeMessageDirectly:consume message by message id'
  'sendMessage:send a message'
  'queryMsgById:query message by id'
  'queryMsgByKey:query message by key'
  'queryMsgByOffset:query message by offset'
  'queryMsgByUniqueKey:query message by unique key'
  'queryCq:query commit queue'
  'printMsg:print messages'
  'printMsgByQueue:print messages by queue'
  'sendMsgStatus:send messages status'
  'brokerStatus:fetch broker runtime status'
  'brokerConsumeStats:fetch broker consume stats'
  'getBrokerConfig:get broker config'
  'cleanExpiredCQ:clean expired commit queue'
  'cleanUnusedTopic:clean unused topic'
  'startMonitoring:start monitoring service'
  'statsAll:topic and consumer-tps stats'
  'syncDocs:sync RocketMQ docs'
  'allocateMQ:allocate MQ test'
  'checkMsgSendRT:check message send RT'
  'clusterList:list all clusters in nameserver'
  'clusterRT:cluster RT'
  'getNamesrvConfig:get nameserver config'
  'updateNamesrvConfig:update nameserver config'
  'addBroker:add broker to controller'
  'electMaster:elect a new master'
  'cleanControllerBroker:clean controller broker meta'
  'getControllerMetaData:get controller meta data'
  'reBalanceConsumer:rebalance consumers'
  'reElectionMaster:re-elect master'
  'pullMessageList:pull messages list'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-n+[nameserver address]:host:port:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mqadmin subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (topicList|clusterList|brokerStatus|getNamesrvConfig|aclConfigVersion)
        _arguments \
          '-n+[nameserver address]:host:port:' \
          '-c+[cluster name]:cluster:' && ret=0
        ;;
      (consumerProgress)
        _arguments \
          '-n+[nameserver address]:host:port:' \
          '-g+[consumer group name]:group:' \
          '-s+[show client info]:flag:(true false)' && ret=0
        ;;
      (consumerStatus|consumerConnection)
        _arguments \
          '-n+[nameserver address]:host:port:' \
          '-g+[consumer group]:group:' \
          '-i+[client id]:id:' && ret=0
        ;;
      (updateTopic)
        _arguments \
          '-n+[nameserver address]:host:port:' \
          '-c+[cluster name]:cluster:' \
          '-b+[broker address]:host:port:' \
          '-t+[topic name]:topic:' \
          '-r+[read queue numbers]:n:' \
          '-w+[write queue numbers]:n:' \
          '-p+[topic permissions]:perm:(2 4 6)' \
          '-o+[order]:flag:(true false)' \
          '-s+[has unit]:flag:(true false)' \
          '-u+[is unit topic]:flag:(true false)' && ret=0
        ;;
      (deleteTopic)
        _arguments \
          '-n+[nameserver address]:host:port:' \
          '-c+[cluster name]:cluster:' \
          '-t+[topic name]:topic:' && ret=0
        ;;
      (updateSubGroup)
        _arguments \
          '-n+[nameserver address]:host:port:' \
          '-b+[broker address]:host:port:' \
          '-c+[cluster name]:cluster:' \
          '-g+[consumer group]:group:' \
          '-s+[consume enable]:flag:(true false)' \
          '-m+[consume from min enable]:flag:(true false)' \
          '-d+[consume broadcast enable]:flag:(true false)' \
          '-q+[retry queue numbers]:n:' \
          '-r+[retry max times]:n:' \
          '-i+[broker id]:id:' \
          '-w+[which broker when consume slowly]:n:' && ret=0
        ;;
      (sendMessage)
        _arguments \
          '-n+[nameserver address]:host:port:' \
          '-t+[topic]:topic:' \
          '-p+[message body]:body:' \
          '-k+[keys]:keys:' \
          '-c+[tags]:tags:' && ret=0
        ;;
      (queryMsgById|queryMsgByOffset|queryMsgByUniqueKey)
        _arguments \
          '-n+[nameserver address]:host:port:' \
          '-i+[message ID]:id:' \
          '-t+[topic]:topic:' \
          '-d+[bornHost]:host:' \
          '-b+[broker name]:broker:' \
          '-q+[queue id]:id:' \
          '-o+[offset]:offset:' && ret=0
        ;;
      (printMsg)
        _arguments \
          '-n+[nameserver address]:host:port:' \
          '-t+[topic]:topic:' \
          '-c+[charset]:charset:' \
          '-s+[subscription expression]:expr:' \
          '-b+[begin timestamp]:ts:' \
          '-e+[end timestamp]:ts:' \
          '-d+[print body]:flag:(true false)' && ret=0
        ;;
    esac
    ;;
esac

return ret
