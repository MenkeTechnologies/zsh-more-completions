#compdef crm_attribute

# crm_attribute: get/set node-level cluster attributes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '-G[query attribute]' \
  '--query[query attribute]' \
  '-v[set attribute value]:value:' \
  '--update=[set attribute value]:value:' \
  '-D[delete attribute]' \
  '--delete[delete attribute]' \
  '-n[attribute name]:name:' \
  '--name=[attribute name]:name:' \
  '-N[node name]:node:' \
  '--node=[node name]:node:' \
  '-i[attribute ID]:id:' \
  '--id=[attribute ID]:id:' \
  '-l[lifetime]:lifetime:(reboot forever)' \
  '--lifetime=[lifetime]:lifetime:(reboot forever)' \
  '-t[attribute type]:type:(nodes status crm_config rsc_defaults op_defaults)' \
  '--type=[attribute type]:type:(nodes status crm_config rsc_defaults op_defaults)' \
  '-s[attribute set]:set:' \
  '--set-name=[attribute set]:set:' \
  '-p[promotion score attribute name]' \
  '--promotion[promotion score attribute name]' \
  '--default=[default value if attribute is unset]:value:' \
  '--inhibit-policy-engine[do not trigger policy engine after change]' \
  '--score-attribute=[score attribute alias]:score:' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '*::crm_attribute args:_files' && ret=0
return ret
