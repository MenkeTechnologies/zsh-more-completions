#compdef crm_attribute

# Pacemaker crm_attribute: read/write a permanent or transient attribute
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-n --name)'{-n,--name=}'[attribute name]:name:' \
  '(-N --node)'{-N,--node=}'[node name]:node:' \
  '(-l --lifetime)'{-l,--lifetime=}'[lifetime]:lifetime:(forever reboot)' \
  '(-t --type)'{-t,--type=}'[attribute container type]:type:(crm_config nodes status rsc_defaults op_defaults tickets)' \
  '(-D --delete)'{-D,--delete}'[delete attribute]' \
  '(-G --query)'{-G,--query}'[query attribute value]' \
  '(-v --value)'{-v,--value=}'[attribute value (with -G/-q)]:val:' \
  '(-u --update)'{-u,--update=}'[set attribute value]:val:' \
  '(-q --quiet)'{-q,--quiet}'[only print value]' \
  '(-s --set-name)'{-s,--set-name=}'[set name]:set:' \
  '(-i --id)'{-i,--id=}'[XML id of attribute]:id:' \
  '*::crm_attribute args:_files' && ret=0
return ret
