#compdef crm_attribute
# Documentation: https://www.mankier.com/8/crm_attribute
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crm_attribute: query/set/delete Pacemaker attributes (node, cluster, defaults)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-output[show output help]' \
  '(- *)--help-selections[show selecting options]' \
  '(- *)--help-command[show command options]' \
  '(- *)--help-additional[show additional options]' \
  '(- *)'{-\$,--version}'[display software version]' \
  '*'{-V,--verbose}'[increase debug output]' \
  '(-q --quiet)'{-q,--quiet}'[print only the value on stdout]' \
  '(-G --query)'{-G,--query}'[query the current value]' \
  '(-D --delete)'{-D,--delete}'[delete the attribute/option]' \
  '(-v --update)'{-v+,--update=}'[update the attribute value]:value:' \
  '(-L --list-options)'{-L+,--list-options=}'[list all available options of given type]:type:(cluster)' \
  '(-i --id)'{-i+,--id=}'[operate on instance with this XML ID]:id:' \
  '(-n --name)'{-n+,--name=}'[operate on attribute with this name]:name:' \
  '(-P --pattern)'{-P+,--pattern=}'[operate on all attributes matching pattern]:pattern:' \
  '(-p --promotion)'{-p+,--promotion=}'[operate on promotion score for resource]:resource:' \
  '(-s --set-name)'{-s+,--set-name=}'[operate on instance within named set]:set:' \
  '(-N --node)'{-N+,--node=}'[set node attribute for named node]:node:' \
  '(-t --type)'{-t+,--type=}'[which part of the configuration]:section:(nodes status crm_config rsc_defaults op_defaults tickets)' \
  '(-l --lifetime)'{-l+,--lifetime=}'[lifetime of the node attribute]:lifetime:(reboot forever)' \
  '(-d --default)'{-d+,--default=}'[default if attribute is not set]:value:' \
  '(-W --wait)'{-W+,--wait=}'[wait for event before returning]:until:' \
  '-a[include advanced and deprecated options]' \
  '--all[include advanced and deprecated options]' \
  '--score[treat values as atomic score updates]' \
  '(-z --utilization)'{-z,--utilization}'[set a utilization attribute for the node]' \
  '--output-as=[specify output format]:fmt:(text xml)' \
  '--output-to=[specify output file (- for stdout)]:file:_files' && ret=0
return ret
