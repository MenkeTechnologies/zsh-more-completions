#compdef impacket-mssqlclient

# Impacket mssqlclient.py: interactive MSSQL client (similar to sqlcmd)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-port[MSSQL port]:port:' \
  '-db[database to connect to]:db:' \
  '-windows-auth[use Windows authentication]' \
  '-show[show SQL queries before executing]' \
  '-file[SQL script file to run]:file:_files -g "*.sql"' \
  '-target-ip[target IP]:ip:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos auth]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '*:[domain/]user[:password]@host:' && ret=0
return ret
