#compdef impacket-mssqlclient
# Documentation: https://man.archlinux.org/search?q=impacket-mssqlclient
# Reference accessed: 2026-05-16

# impacket-mssqlclient: MSSQL client (Tabular Data Stream)
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "-debug[verbose debug output]" \
  "-ts[print timestamps in log]" \
  "-ts-utc[print timestamps in UTC]" \
  "-target-ip[target IP]:ip:" \
  "-dc-ip[domain controller IP]:ip:" \
  "-codec[codec for non-utf-8 strings]:codec:" \
  "-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:" \
  "-no-pass[do not ask for password]" \
  "-k[use Kerberos]" \
  "-aesKey[AES key in hex]:hex:" \
  "-cert-pem[pem certificate file]:file:_files" \
  "-cert-pfx[pkcs12 cert file]:file:_files" \
  "-pfx-pass[pkcs12 cert password]:pass:" \
  -port[mssql port]:port: -db[initial database]:db: -windows-auth[use Windows authentication] -file[run script from file]:file:_files -show[show response] -encrypt[force encryption] -encrypt-strict[strict encryption] \
  '*::impacket-mssqlclient args:_files' && ret=0
return ret
