#compdef mOverlaps
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mOverlaps.html
# Determine which images in a table overlap and list the difference pairs

local ret=1

_arguments -s -S \
  '-e[exact overlap detection by checking edge pixels]' \
  '-d+[debugging level (1-2)]:level' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '1:images table:_files -g "*.tbl"' \
  '2:diffs table:_files -g "*.tbl"' && ret=0

return ret
