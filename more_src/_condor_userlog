#compdef condor_userlog
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_userlog.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-total[only display job totals]' \
  '-raw[display raw data only]' \
  '-debug[debug mode]' \
  '-j[select cluster or cluster.proc]:jobid:' \
  '-evict[only allocations ended due to eviction]' \
  '-all[select all clusters and allocations]' \
  '-hostname[display host name instead of IP]' \
  '*:log file:_files -g "*.log"' && ret=0
return ret
