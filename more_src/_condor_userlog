#compdef condor_userlog
# Documentation: https://man.archlinux.org/search?q=condor_userlog
# Reference accessed: 2026-05-16

# condor_userlog: summarize a Condor user log file
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-total[totals only]' \
  '-raw[raw events]' \
  '-debug[debug]' \
  '-evict[show eviction events]' \
  '-j[show specific job id]:jobid:' \
  '-all[all jobs]' \
  '*:log file:_files -g "*.log"' && ret=0
return ret
