#compdef naccess
# Documentation: https://github.com/biopython/biopython/blob/master/Bio/PDB/NACCESS.py
# Calculate atomic solvent accessible surface area

local ret=1

_arguments -s \
  '-p[probe size in Angstroms]:probe' \
  '-z[integration z-slice width]:zslice' \
  '-h[include HETATM records]' \
  '-w[include water (HOH) records]' \
  '-y[include hydrogen records]' \
  '*:PDB file:_files -g "*.pdb"' && ret=0

return ret
