#compdef build-astrometry-index
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/build-astrometry-index.1 — create astrometry.net index files (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[input FITS catalog (RA,DEC,...)]:file:_files -g "*.{fits,fit,fts}"' \
    '-e+[FITS extension to read]:ext:_default' \
    '-1+[share another indexs stars]:index:_files' \
    '-o+[output index filename]:file:_files' \
    '-N+[healpix Nside for quad-building]:n:_default' \
    '-l+[minimum quad size (arcmin)]:n:_default' \
    '-u+[maximum quad size (arcmin)]:n:_default' \
    '-P+[preset for -N/-l/-u (0=6arcmin..19)]:n:_default' \
    '-S+[sort column]:col:_default' \
    '-f[sort descending (e.g. for FLUX)]' \
    '-A+[RA column name (default RA)]:col:_default' \
    '-D+[Dec column name (default Dec)]:col:_default' \
    '-B+[cut sort-column below val]:n:_default' \
    '-U+[healpix Nside for uniformization]:n:_default' \
    '-H+[big healpix (default all-sky)]:n:_default' \
    '-s+[big healpix Nside (default 1)]:n:_default' \
    '-m+[margin]:n:_default' \
    '-n+[uniformization sweeps]:n:_default' \
    '-r+[search radius]:n:_default' \
    '-j+[jitter]:n:_default' \
    '-d+[dim quads]:n:_default' \
    '-p+[passes]:n:_default' \
    '-R+[reuse]:n:_default' \
    '-L+[max reuses]:n:_default' \
    '-E[encode quads with Skdt]' \
    '-I+[index id]:id:_default' \
    '-M[in-memory mode]' \
    '-T[temp file mode]' \
    '-t+[temp directory]:dir:_files -/' \
    '-v[verbose]' \
    && ret=0

return ret
