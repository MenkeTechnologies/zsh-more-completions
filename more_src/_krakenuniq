#compdef krakenuniq krakenuniq-build krakenuniq-download krakenuniq-extract-reads krakenuniq-mpa-report krakenuniq-report krakenuniq-translate
# _krakenuniq — Florian Breitwieser krakenuniq CLI taxonomic-classification tool extending Kraken with unique k-mer counting using HyperLogLog cardinality estimation reducing false-positive species calls in metagenomic shotgun NCBI taxonomy database building classification reporting for viruses bacteria archaea (Florian Breitwieser team, C++); getopt
# upstream: https://github.com/fbreitwieser/krakenuniq

_krakenuniq() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--db=+[database dir]:dir:_files -/' \
        '--threads=+[N]:n:' \
        '--fasta-input[FASTA input]' \
        '--fastq-input[FASTQ input]' \
        '--gzip-compressed[input gzipped]' \
        '--bzip2-compressed[input bzip2]' \
        '--paired[paired reads]' \
        '--check-names[check sequence names]' \
        '--quick[quick mode]' \
        '--min-hits=+[N]:n:' \
        '--unclassified-out=+[file]:file:_files' \
        '--classified-out=+[file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--preload[preload db]' \
        '--only-classified-output[only output classified]' \
        '--report-file=+[file]:file:_files' \
        '--hll-precision=+[N]:n:' \
        '--exact[exact k-mer match]' \
        '*:fastq file:_files -g "*.fq *.fastq *.fa *.fasta *.gz *.bz2"'
}

_krakenuniq "$@"
