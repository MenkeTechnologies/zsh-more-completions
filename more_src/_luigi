#compdef luigi

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--module=[module containing the task]:module' \
  '--task=[task class name]:task' \
  '--local-scheduler[use local scheduler instead of central]' \
  '--scheduler-host=[hostname of scheduler]:host' \
  '--scheduler-port=[port of scheduler]:port' \
  '--scheduler-url=[URL of scheduler]:url' \
  '--lock[use lock to prevent duplicate runs]' \
  '--lock-size=[max number of concurrent locks]:count' \
  '--lock-pid-dir=[directory for lock PID files]:directory:_directories' \
  '--no-lock[do not use locking]' \
  '--workers=[number of workers]:count' \
  '--logging-conf-file=[logging configuration file]:file:_files' \
  '--log-level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL NOTSET)' \
  '--parallel-scheduling[enable parallel scheduling]' \
  '--parallel-scheduling-processes=[parallel scheduling processes]:count' \
  '*:task parameters' && ret=0

return ret
