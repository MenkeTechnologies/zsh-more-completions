#compdef bedToBam
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/bedtobam.html
# convert BED/GFF/VCF features to BAM (bedtools bedtobam)

local ret=1

_arguments -s -S \
  '-i[input file (BED/GFF/VCF)]:file:_files' \
  '-g[genome file]:file:_files' \
  '-mapq[mapping quality (MAPQ) for all entries (default 255)]:mapq' \
  '-bed12[input BED is in BED12 (blocked) format]' \
  '-ubam[write uncompressed BAM output]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
