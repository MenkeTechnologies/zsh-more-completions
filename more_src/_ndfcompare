#compdef ndfcompare
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss121.html
# KAPPA: compare a pair of NDFs for equivalence

local ret=1

_arguments -s \
  'ACCDAT=[maximum allowed data-value difference]:accdat' \
  'ACCPOS=[maximum allowed axis-value difference]:accpos' \
  'ACCVAR=[maximum allowed variance difference]:accvar' \
  'CASE=[case-sensitive string comparison]:case:(TRUE FALSE)' \
  'COMP=[NDF components to compare]:comp' \
  'DOTESTS=[test indices to perform]:dotests' \
  'IN1=[first NDF for comparison]:NDF:_files' \
  'IN2=[second NDF for comparison]:NDF:_files' \
  'NBAD=[maximum allowed bad-value count difference]:nbad' \
  'REPORT=[output text file for differences]:file:_files' \
  'SKIPTESTS=[test indices to exclude]:skiptests' \
  'WHITE=[ignore leading or trailing whitespace]:white:(TRUE FALSE)' \
  '*:NDF:_files' && ret=0

return ret
