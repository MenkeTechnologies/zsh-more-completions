#compdef xmacrorec2 xmacroplay
# X11 keyboard/mouse macro recorder/player

local ret=1

if [[ $service == xmacrorec2 ]]; then
  _arguments -s -S \
    '-d[specify display]:display:' \
    '-k[specify stop key]:keycode:' \
    '-h[show help]' && ret=0
else
  _arguments -s -S \
    '-d[specify display]:display:' \
    '-h[show help]' \
    '1:macro file:_files' && ret=0
fi

return ret
