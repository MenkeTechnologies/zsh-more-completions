#compdef pit
# Documentation: https://man.archlinux.org/search?q=pit
# Reference accessed: 2026-05-16

# michaeldv/pit

local curcontext="$curcontext" ret=1 expl
_arguments -C   '1: :->cmd'   '*:: :->rest' && ret=0
case $state in
cmd)
  _wanted commands expl 'pit command' compadd -- init status log branch merge publish pull push help
  ;;
rest)
  _normal && ret=0
  ;;
esac
return ret
