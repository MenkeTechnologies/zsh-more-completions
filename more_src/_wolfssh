#compdef wolfssh

# WolfSSH: lightweight SSH client (wolfSSL library)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-l[username for SSH]:user:' \
  '-p[port number]:port:' \
  '-N[no command, just open session]' \
  '-i[identity file]:file:_files' \
  '-K[Kerberos auth]' \
  '-v[verbose]' \
  '*:user@host [command]:' && ret=0
return ret
