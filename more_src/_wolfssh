#compdef wolfssh
# Documentation: https://github.com/wolfSSL/wolfssh/blob/master/examples/client/client.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# wolfssh: SSH client example from wolfSSL.
# Flags verified from ShowUsage() / mygetopt() in examples/client/client.c.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-\?[display help]' \
  '-h+[host to connect to]:host:_hosts' \
  '-p+[port to connect on]:port:' \
  '-u+[username (required)]:user:_users' \
  '-P+[password]:password:' \
  '-i+[private key file]:file:_files' \
  '-j+[public key file]:file:_files' \
  '-x[exit after connection without I/O]' \
  '-N[use non-blocking sockets]' \
  '-t[use pseudo terminal]' \
  '-c+[execute remote command]:command:' \
  '-R[raw untranslated output (Windows only)]' \
  '-a[attempt SSH-AGENT]' \
  '-J+[DER certificate file]:file:_files' \
  '-A+[DER CA certificate file]:file:_files' \
  '-X[ignore IP checks on certificates]' \
  '-E[list all possible algorithms]' \
  '-k+[set key algorithms list]:list:' \
  '-C+[set encryption algorithms list]:list:' \
  '-q[turn off debugging]' \
  '-K+[TPM key authentication password]:password:' \
  '-z[show sizes (if compiled with WOLFSSH_SHOW_SIZES)]' && ret=0
return ret
