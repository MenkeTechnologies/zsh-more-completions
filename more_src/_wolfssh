#compdef wolfssh
# Documentation: https://man.archlinux.org/search?q=wolfssh
# Reference accessed: 2026-05-16

# wolfssh: SSH client implementation from wolfSSL
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '-V[show version]' \
  '-p[port]:port:' \
  '-l[user]:user:_users' \
  '-i[identity file]:file:_files' \
  '-N[no command, just port-forward etc.]' \
  '-T[no TTY allocation]' \
  '-tt[force TTY allocation]' \
  '-v[verbose]' \
  '-x[disable X11 forwarding]' \
  '-X[enable X11 forwarding]' \
  '-L[local port forward (port:host:port)]:fwd:' \
  '-R[remote port forward]:fwd:' \
  '-D[dynamic SOCKS forward]:port:' \
  '-o[ssh_config option]:option:' \
  '-F[ssh_config file]:file:_files' \
  '1:user@host:_users' \
  '*:command:' && ret=0
return ret
