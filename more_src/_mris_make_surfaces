#compdef mris_make_surfaces
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_make_surfaces
# FreeSurfer generate gray/white and pial cortical surfaces

local ret=1

_arguments -s -S \
  '-q[omit self-intersection, only gray/white surface]' \
  '-c[create curvature and area files from white surface]' \
  '-a[average curvature values N times (default 10)]:avgs:' \
  '-whiteonly[only generate white matter surface]' \
  '-orig_white[white surface to start with]:surf:_files' \
  '-orig_pial[pial surface to start with]:surf:_files' \
  '-w[snapshot value]:value:' \
  '-max_gray_scale[set outside_hi in white deformation]:mgs:' \
  '-first_wm_peak[settle WM surface at first intensity peak]' \
  '-pa[average pial curvature max N times (default 16)]:avgs:' \
  '-wa[average white curvature max N times (default 4)]:avgs:' \
  '-T1[T1 volume (default brain)]:T1vol:_files' \
  '-wvol[white volume hires]:whitevol:_files' \
  '-long[longitudinal]' \
  '-dura_thresh[multi-echo MPRAGE dura avoidance threshold]:threshold:' \
  '-SDIR[SUBJECTS_DIR]:dir:_files -/' \
  '-pial[pial surface name]:pial:' \
  '-white[white surface name]:white:' \
  '-wm_weight[WM mean weighting in T2 threshold (default 3)]:w:' \
  '-nsigma_above[sigmas above mean for GM T2 intensities]:n:' \
  '-nsigma_below[sigmas below mean for GM T2 intensities]:n:' \
  '-T2_min[minimum T2 threshold for cortical ribbon]:threshold:' \
  '-T2_max[maximum T2 threshold for cortical ribbon]:threshold:' \
  '-min_peak_pct[histogram peak percent inside outside]:pct:' \
  '-help[display help]' \
  '-all-info[display full version information]' \
  '1:subject name:' \
  '2:hemisphere:(lh rh)' && ret=0

return ret
