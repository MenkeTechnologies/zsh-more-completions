#compdef rusthound-ce
# Documentation: https://github.com/g0h4n/RustHound-CE/blob/main/HELP.md
# BloodHound Community Edition data collector written in Rust

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-d --domain)'{-d,--domain}'+[domain name like DOMAIN.LOCAL]:domain:' \
  '(-u --ldapusername)'{-u,--ldapusername}'+[LDAP username like user@domain.local]:user:' \
  '(-p --ldappassword)'{-p,--ldappassword}'+[LDAP password]:password:' \
  '(-f --ldapfqdn)'{-f,--ldapfqdn}'+[domain controller FQDN]:fqdn:' \
  '(-i --ldapip)'{-i,--ldapip}'+[domain controller IP address]:ip:' \
  '(-P --ldapport)'{-P,--ldapport}'+[LDAP port]:port:' \
  '(-n --name-server)'{-n,--name-server}'+[alternative name server for DNS queries]:ip:' \
  '(-o --output)'{-o,--output}'+[output directory]:dir:_files -/' \
  '*-v[set verbosity level]' \
  '(-c --collectionmethod)'{-c,--collectionmethod}'+[collection method]:method:(All DCOnly)' \
  '--ldaps[force LDAPS for requests]' \
  '(-k --kerberos)'{-k,--kerberos}'[use Kerberos authentication]' \
  '--dns-tcp[use TCP instead of UDP for DNS queries]' \
  '(-z --zip)'{-z,--zip}'[compress the JSON files into a zip archive]' \
  '--fqdn-resolver[use fqdn-resolver module to get computers IP address]' && ret=0

return ret
