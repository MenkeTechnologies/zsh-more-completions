#compdef termrec
# Documentation: https://man.archlinux.org/search?q=termrec
# Reference accessed: 2026-05-16

# Zsh completion for termrec — terminal session recorder

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '-o[output file]:file:_files' && ret=0

return ret
