#compdef pyanalyze

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--config-file[configuration file]:config file:_files' \
  '--verbose[enable verbose output]' \
  '--enable-all[enable all checks]' \
  '--disable-all[disable all checks]' \
  '*--enable[enable a specific check]:check name:' \
  '*--disable[disable a specific check]:check name:' \
  '--json-output[output results as JSON]:output file:_files' \
  '--text-output[output results as text]:output file:_files' \
  '--sarif-output[output results as SARIF]:output file:_files' \
  '--color[enable colored output]' \
  '--no-color[disable colored output]' \
  '--diff[only analyze changed files]' \
  '--incremental[enable incremental analysis]' \
  '*--import-path[add to Python import path]:path:_files -/' \
  '*:module or file:_files' && ret=0

return ret
