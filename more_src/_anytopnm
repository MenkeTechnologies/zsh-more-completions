#compdef anytopnm
# Documentation: https://man.archlinux.org/search?q=anytopnm
# Reference accessed: 2026-05-16

# netpbm anytopnm(1) — optional input file; libnetpbm common option -version only.

_arguments -s -S \
  '-version[print Netpbm version]' \
  '1:input image file (or stdin with -):_files' && return 0
