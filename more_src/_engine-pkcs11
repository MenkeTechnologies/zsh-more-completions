#compdef engine-pkcs11 engine_pkcs11
# Documentation: https://github.com/OpenSC/libp11
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# OpenSSL ENGINE for PKCS#11 (libp11). Engine controls passed via openssl -pre/-post.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-SO_PATH[path to pkcs11-engine shared library]:file:_files' \
  '-MODULE_PATH[path to pkcs11 module shared library]:file:_files' \
  '-PIN[PIN value]:pin:' \
  '-DEBUG_LEVEL[debug level 0-7]:level:(0 1 2 3 4 5 6 7)' \
  '-QUIET[suppress additional output details]' \
  '-VERBOSE[verbose engine logging]' \
  '-LOAD_CERT_CTRL[load certificate via PKCS#11 URI]:uri:' \
  '-SET_USER_INTERFACE[configure global user interface]:ui:' \
  '-SET_CALLBACK_DATA[set global UI extra data]:data:' \
  '-FORCE_LOGIN[force login to PKCS#11 module]' \
  '-RE_ENUMERATE[re-enumerate slots/tokens]' \
  '-VLOG_A[set logging callback]:cb:' \
  '*::engine-pkcs11 args:_files' && ret=0
return ret
