#compdef engine-pkcs11

# engine-pkcs11: OpenSSL engine for PKCS#11 (libp11)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-MODULE_PATH[path to pkcs11 module]:file:_files' \
  '-PIN[PIN]:pin:' \
  '-VERBOSE[verbose engine logging]' \
  '-LOAD_CERT_CTRL[load cert via URI]:uri:' \
  '*::engine-pkcs11 args:_files' && ret=0
return ret
