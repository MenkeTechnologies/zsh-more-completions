#compdef imstack
# Documentation: http://tdc-www.harvard.edu/software/wcstools/
# imstack: stack FITS image files into a single multi-dimensional image (WCSTools)

local ret=1

_arguments -s -S \
  '-i[do not put FITS header in output file]' \
  '-m[write IRAF multispec file]' \
  '-n[use each file this many times]:num' \
  '-o[output file name]:name:_files' \
  '-v[verbose]' \
  '-x[make first file root, others extensions]:root' \
  '*:FITS file:_files -g "*.(fits|fit|fts|FITS|FIT|FTS|imh)"' && ret=0

return ret
