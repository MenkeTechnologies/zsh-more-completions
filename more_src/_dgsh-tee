#compdef dgsh-tee
# Documentation: https://www.spinellis.gr/sw/dgsh/dgsh-tee.html
# dgsh-tee - directed graph shell multi-way pipe/tee with buffering

local ret=1

_arguments -s -S \
  '-a[open -o files for appending]' \
  '-b+[buffer size (k/M/G suffix), default 1MB]:size:' \
  '-f[spill to a temporary file when memory threshold reached]' \
  '-I[input-side buffering, read continuously]' \
  '*-i+[read input from file instead of stdin]:file:_files' \
  '-M[provide memory use statistics on termination]' \
  '*-o+[write copies of input to file instead of stdout]:file:_files' \
  '-m+[max memory to allocate for buffers (k/M/G), default 256MB]:size:' \
  '-p+[redirect input channels to output channels]:channels:' \
  '-s[scatter input fairly across sinks rather than copying]' \
  '-T+[directory for the temporary file]:dir:_files -/' \
  '-t+[record separator char (default newline)]:char:' && ret=0

return ret
