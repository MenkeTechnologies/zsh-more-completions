#compdef pulsemixer

_arguments \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--id[specify sink/source ID]:id:' \
  '--list-sinks[list available sinks]' \
  '--list-sources[list available sources]' \
  '--list-profiles[list available profiles]' \
  '--list-cards[list available cards]' \
  '--get-volume[get current volume]' \
  '--set-volume[set volume (0-150)]:volume:' \
  '--get-mute[get mute state]' \
  '--mute[mute]' \
  '--unmute[unmute]' \
  '--toggle-mute[toggle mute state]' \
  '--server[specify PulseAudio server address]:address:' \
  '--color[set color mode]:mode:(0 1 2)' \
  '--no-usage-stats[disable usage statistics]' \
  '--create-monitor[create a monitor source]'
