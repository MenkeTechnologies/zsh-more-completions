#compdef pulsemixer
# Documentation: https://github.com/GeorgeFilipkin/pulsemixer
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l --list)'{-l,--list}'[list all devices and streams]' \
  '--list-sinks[list output devices]' \
  '--list-sources[list input devices]' \
  '--id=[device ID]:id:' \
  '--get-volume[print current volume]' \
  '--set-volume=[set volume]:percent:' \
  '--set-volume-all=[set per-channel volume]:n\:n:' \
  '--change-volume=[adjust volume by amount]:delta:' \
  '--max-volume=[upper volume bound]:percent:' \
  '--get-mute[print mute state]' \
  '--mute[mute]' \
  '--unmute[unmute]' \
  '--toggle-mute[toggle mute]' \
  '--server=[PulseAudio server address]:address:' \
  '--color=[color mode]:mode:(0 1 2)' \
  '--no-mouse[disable mouse]' \
  '--create-config[create config file]'
