#compdef wraptool
# Documentation: https://mesonbuild.com/Using-wraptool.html
# meson tool to manage WrapDB dependencies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    list\:"query the list of packages available in WrapDB"
    search\:"locate specific packages including dependencies"
    info\:"show which versions of a package are available"
    install\:"add a dependency to the subprojects directory"
    status\:"check if your projects are up to date"
    update\:"upgrade an existing wrap to a newer release"
    update-db\:"download the latest WrapDB database"
    promote\:"promote a subproject dependency"
  ))' \
  '*::arg:->args' && ret=0

return ret
