#compdef graphql-mesh mesh
# _graphql-mesh — GraphQL Mesh gateway and federation CLI
# upstream: https://github.com/Urigo/graphql-mesh

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dev:Start the development server with hot reload'
  'start:Start the production server'
  'build:Build mesh artifacts for production'
  'serve-source:Serve a single source subgraph'
  'supergraph:Compose a supergraph from subgraphs'
  'validate:Validate the mesh configuration'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'graphql-mesh command' commands && ret=0
    ;;
  args)
    case $words[1] in
      dev)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--port=[port to listen on]:port' \
          '--host=[host to bind to]:host' \
          '--fusiongraph=[path to fusiongraph]:file:_files' \
          '--supergraph=[path to supergraph]:file:_files' && ret=0
        ;;
      start)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--port=[port to listen on]:port' \
          '--host=[host to bind to]:host' \
          '--fusiongraph=[path to fusiongraph]:file:_files' \
          '--supergraph=[path to supergraph]:file:_files' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--output=[output directory]:directory:_directories' \
          '--fileType=[output file type]:type:(json ts js)' && ret=0
        ;;
      supergraph)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--output=[output file path]:file:_files' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '(- *)--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
