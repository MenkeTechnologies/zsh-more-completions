#compdef f3brew
# Documentation: https://github.com/AltraMayor/f3
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--usage[show usage]' \
  '(- *)'{-V,--version}'[show version]' \
  '--fix-cmd[print f3fix command for usable area]' \
  '--max-write-rate=+[max write rate]:rate:' \
  '--max-read-rate=+[max read rate]:rate:' \
  '*:device:_files' && ret=0

return ret
