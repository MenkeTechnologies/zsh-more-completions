#compdef f3brew
# Documentation: https://man.archlinux.org/search?q=f3brew
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[debug]' \
  '--prevention[prevention mode]' \
  '*:device:_files' && ret=0

return ret
