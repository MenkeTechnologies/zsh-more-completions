#compdef thirdweb

# Zsh completion for thirdweb - thirdweb Web3 development CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a new project with thirdweb'
  'build:compile contracts'
  'deploy:deploy contracts'
  'publish:publish contracts'
  'release:release contracts'
  'detect:detect contract extensions'
  'generate:generate types for deployed contracts'
  'install:install dependencies'
  'login:log in to your thirdweb account'
  'logout:log out of your thirdweb account'
  'upload:upload files to IPFS'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--debug[enable debug logging]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'thirdweb command' commands && ret=0
    ;;
  args)
    case $words[1] in
      create)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--template[template to use]:template:' \
          '--framework[framework to use]:framework:(next cra vite express node)' \
          '--typescript[initialize as TypeScript project]' \
          '--javascript[initialize as JavaScript project]' \
          '--contract[create a contract project]' \
          '--app[create an app project]' \
          '1::project name:' && ret=0
        ;;
      build)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--path[path to project]:path:_directories' \
          '--debug[enable debug logging]' \
          '--clean[clean the cache before building]' && ret=0
        ;;
      deploy)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--path[path to project]:path:_directories' \
          '--debug[enable debug logging]' \
          '--dry-run[dry run without deploying]' \
          '--ci[run in CI mode]' && ret=0
        ;;
      publish)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--path[path to project]:path:_directories' \
          '--debug[enable debug logging]' && ret=0
        ;;
      detect)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--path[path to project]:path:_directories' \
          '--debug[enable debug logging]' && ret=0
        ;;
      upload)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:file or directory:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
