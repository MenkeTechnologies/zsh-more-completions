#compdef kube-alfred
# Documentation: https://github.com/kemalcanbora/kube-alfred
# Reference accessed: 2026-05-19
# Verified: kemalcanbora/kube-alfred README. Invoked as a kubectl plugin
# (kubectl alfred ...) with three documented subcommands: ask, set-key,
# del-key. API key is stored in the system keyring; no CLI flags are
# documented. Removed from prior file: invented --api-key, --model,
# -n/--namespace, --kubeconfig, --context flags and bogus
# man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'ask:ask a Kubernetes question and get an AI-powered answer'
  'set-key:store the Anthropic API key in the system keyring'
  'del-key:delete the stored Anthropic API key'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'kube-alfred command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (ask) _message 'question (quoted string)' && ret=0 ;;
      (set-key) _message 'Anthropic API key' && ret=0 ;;
      (del-key) ret=0 ;;
    esac ;;
esac

return ret
