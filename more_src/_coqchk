#compdef coqchk
# Documentation: https://rocq-prover.org/doc/V8.20.0/refman/practical-tools/coq-commands.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (Coq/Rocq command reference).

_arguments -s \
  '*-I+[include path]:dir:_files -/' \
  '*--include+[include path]:dir:_files -/' \
  '*-Q+[map physical to logical (non-recursive)]:dir:_files -/' \
  '*-R+[map physical to logical (recursive)]:dir:_files -/' \
  '-silent[less verbose]' \
  '*-admit+[trust module and dependencies]:module:' \
  '*-norec+[verify module without deps check]:module:' \
  '(-m --memory)'{-m,--memory}'[print memory summary]' \
  '(-o --output-context)'{-o,--output-context}'[print logical content summary]' \
  '-impredicative-set[accept impredicative Set]' \
  '-coqlib+[stdlib location]:dir:_files -/' \
  '-where[print stdlib location]' \
  '(- *)-v[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:module:'
