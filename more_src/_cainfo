#compdef cainfo
# Documentation: https://docs.epics-controls.org/en/latest/
# Source: epics-base/epics-base modules/ca/src/tools/cainfo.c — EPICS Channel Access process variable info.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-V[show EPICS/CA versions]' \
    '-w+[CA timeout (seconds)]:sec:_default' \
    '-s+[ca_client_status interest level]:level:_default' \
    '-p+[CA priority (0=lowest)]:prio:_default' \
    '*:PV name:_default' \
    && ret=0

return ret
