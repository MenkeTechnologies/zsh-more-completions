#compdef patchelf

_arguments \
  '--help[show help message]' \
  '--version[show version]' \
  '--page-size[set page size]:size' \
  '--print-interpreter[print ELF interpreter]' \
  '--print-soname[print DT_SONAME]' \
  '--print-rpath[print DT_RPATH or DT_RUNPATH]' \
  '--print-needed[print DT_NEEDED entries]' \
  '--print-os-abi[print OS ABI]' \
  '--set-interpreter[set ELF interpreter]:interpreter' \
  '--set-soname[set DT_SONAME]:name' \
  '--set-rpath[set DT_RPATH/DT_RUNPATH]:rpath' \
  '--add-rpath[add rpath entry]:rpath' \
  '--remove-rpath[remove DT_RPATH/DT_RUNPATH]' \
  '--shrink-rpath[remove unused rpath entries]' \
  '--add-needed[add DT_NEEDED entry]:library' \
  '--remove-needed[remove DT_NEEDED entry]:library' \
  '--replace-needed[replace DT_NEEDED entry]:old library:new library' \
  '--set-os-abi[set OS ABI]:abi' \
  '--no-default-lib[mark as not using default library search paths]' \
  '--no-sort[do not sort program headers]' \
  '--force-rpath[use DT_RPATH instead of DT_RUNPATH]' \
  '--output[write output to file]:output file:_files' \
  '--debug[print debug information]' \
  '--clear-symbol-version[clear version of a symbol]:symbol' \
  '--add-debug-tag[add DT_DEBUG tag]' \
  '--rename-dynamic-symbols[rename dynamic symbols]:map file:_files' \
  '*:ELF file:_files'
