#compdef crates-tui
# Documentation: https://github.com/ratatui-org/crates-tui
# Reference accessed: 2026-05-17
# Verified: upstream src/cli.rs at the URL above.

_arguments -s -S \
  '--version[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '--print-default-config[print default TOML configuration]' \
  '(-c --config-file)'{-c,--config-file=}'[config file]:file:_files' \
  '--color-file=[base16 color file]:file:_files' \
  '(-f --frame-rate)'{-f,--frame-rate=}'[frames per second]:float:' \
  '--data-dir=[application data directory]:dir:_directories' \
  '(--log --log-level)'{--log-level,--log=}'[log level]:level:(error warn info debug trace off)' \
  '*::initial query:'
