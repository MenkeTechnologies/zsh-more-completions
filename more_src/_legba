#compdef legba

autoload -U is-at-least

_legba() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-R+[Load a recipe from this YAML file]:RECIPE:_default' \
'--recipe=[Load a recipe from this YAML file]:RECIPE:_default' \
'-T+[Single target host, url or IP address, IP range, CIDR, @filename or comma separated combination of them]:TARGET:_default' \
'--target=[Single target host, url or IP address, IP range, CIDR, @filename or comma separated combination of them]:TARGET:_default' \
'--api=[Enable the REST API and bind it to the specified address\:port]:API:_default' \
'--api-allowed-origin=[Use a more restrictive CORS policy by only allowing requests from the specified origin]:API_ALLOWED_ORIGIN:_default' \
'--mcp=[Enable the MCP server and bind it to the specified address\:port. Use stdio to use standard input/output instead of SSE]:MCP:_default' \
'-U+[Constant, filename, glob expression as @/some/path/*.txt, permutations as #min-max\:charset / #min-max or range as \[min-max\] / \[n, n, n\]]:USERNAME:_default' \
'--username=[Constant, filename, glob expression as @/some/path/*.txt, permutations as #min-max\:charset / #min-max or range as \[min-max\] / \[n, n, n\]]:USERNAME:_default' \
'--payloads=[Constant, filename, glob expression as @/some/path/*.txt, permutations as #min-max\:charset / #min-max or range as \[min-max\] / \[n, n, n\]]:USERNAME:_default' \
'-P+[Constant, filename, glob expression as @/some/path/*.txt or permutations as #min-max\:charset / #min-max or range as \[min-max\] / \[n, n, n\]]:PASSWORD:_default' \
'--password=[Constant, filename, glob expression as @/some/path/*.txt or permutations as #min-max\:charset / #min-max or range as \[min-max\] / \[n, n, n\]]:PASSWORD:_default' \
'--key=[Constant, filename, glob expression as @/some/path/*.txt or permutations as #min-max\:charset / #min-max or range as \[min-max\] / \[n, n, n\]]:PASSWORD:_default' \
'-C+[Load username\:password combinations from this file]:COMBINATIONS:_default' \
'--combinations=[Load username\:password combinations from this file]:COMBINATIONS:_default' \
'--separator=[Separator if using the --combinations/-C argument]:SEPARATOR:_default' \
'-I+[Whether to iterate by user or by password]:ITERATE_BY:(user password)' \
'--iterate-by=[Whether to iterate by user or by password]:ITERATE_BY:(user password)' \
'-S+[Save and restore session information to this file]:SESSION:_default' \
'--session=[Save and restore session information to this file]:SESSION:_default' \
'-O+[Save results to this file]:OUTPUT:_default' \
'--output=[Save results to this file]:OUTPUT:_default' \
'--output-format=[Output file format]:OUTPUT_FORMAT:(text csv jsonl)' \
'--timeout=[Connection timeout in milliseconds]:TIMEOUT:_default' \
'--retries=[Number of attempts if a request fails]:RETRIES:_default' \
'--retry-time=[Delay in milliseconds to wait before a retry]:RETRY_TIME:_default' \
'--report-time=[Report runtime statistics every N milliseconds]:REPORT_TIME:_default' \
'--ulimit=[Value for ulimit (max open file descriptors)]:ULIMIT:_default' \
'--concurrency=[Number of concurrent workers]:CONCURRENCY:_default' \
'--rate-limit=[Limit the number of requests per second]:RATE_LIMIT:_default' \
'-W+[Wait time in milliseconds per login attempt]:WAIT:_default' \
'--wait=[Wait time in milliseconds per login attempt]:WAIT:_default' \
'--jitter-min=[Minimum number of milliseconds for random request jittering]:JITTER_MIN:_default' \
'--jitter-max=[Maximum number of milliseconds for random request jittering]:JITTER_MAX:_default' \
'--generate-completions=[Generate shell completions]:GENERATE_COMPLETIONS:(bash elvish fish powershell zsh)' \
'--cmd-binary=[Command binary]:CMD_BINARY:_default' \
'--cmd-args=[Command arguments. {USERNAME}, {PASSWORD}, {TARGET} and {PORT} can be used as placeholders]:CMD_ARGS:_default' \
'--cmd-success-exit-code=[Process exit code to be considered as a positive match]:CMD_SUCCESS_EXIT_CODE:_default' \
'--cmd-success-match=[String to look for in the process standard output to be considered as a positive match]:CMD_SUCCESS_MATCH:_default' \
'--http-ua=[Set a User-Agent. If none is specified, it'\''ll be picked randomly for each request]:HTTP_UA:_default' \
'--http-success=[Boolean expression to use to determine if a request is successful]:HTTP_SUCCESS:_default' \
'--http-method=[Request method for HTTP based plugins]:HTTP_METHOD:_default' \
'*--http-headers=[Request headers for HTTP based plugins]:HTTP_HEADERS:_default' \
'--http-csrf-page=[For each request grab a CSRF token from this page]:HTTP_CSRF_PAGE:_default' \
'--http-csrf-regexp=[Regular expression to use to grab the CSRF token name and value]:HTTP_CSRF_REGEXP:_default' \
'--http-payload=[Request payload (query string, post body or form data) for HTTP based plugins]:HTTP_PAYLOAD:_default' \
'--http-enum-ext=[File extension for HTTP enumeration]:HTTP_ENUM_EXT:_default' \
'--http-enum-ext-placeholder=[File extension placeholder for HTTP enumeration wordlist]:HTTP_ENUM_EXT_PLACEHOLDER:_default' \
'--http-ntlm-domain=[Domain for NTLM authentication over HTTP]:HTTP_NTLM_DOMAIN:_default' \
'--http-ntlm-workstation=[Workstation name for NTLM authentication over HTTP]:HTTP_NTLM_WORKSTATION:_default' \
'--proxy=[Proxy URL]:PROXY:_default' \
'--proxy-auth=[Proxy authentication as username\:password]:PROXY_AUTH:_default' \
'--dns-resolvers=[Comma separatd list of DNS resolvers to use instead of the system one]:DNS_RESOLVERS:_default' \
'--dns-port=[Resolver(s) port]:DNS_PORT:_default' \
'--dns-attempts=[Number of retries after lookup failure before giving up]:DNS_ATTEMPTS:_default' \
'--dns-max-positives=[If more than this amount of sequential dns resolutions point to the same ip, add that ip to an ignore list]:DNS_MAX_POSITIVES:_default' \
'--telnet-user-prompt=[Telnet server username login prompt string]:TELNET_USER_PROMPT:_default' \
'--telnet-pass-prompt=[Telnet server password login prompt string]:TELNET_PASS_PROMPT:_default' \
'--telnet-prompt=[Telnet server shell prompt after successful login]:TELNET_PROMPT:_default' \
'--ssh-auth-mode=[Authentication strategy]:SSH_AUTH_MODE:(key password)' \
'--ssh-key-passphrase=[Optional private key passphrase for key based authentication]:SSH_KEY_PASSPHRASE:_default' \
'--smtp-mechanism=[SMTP authentication mechanism, can be PLAIN (RFC4616), LOGIN (obsolete but needed for some providers like office365) or XOAUTH2]:SMTP_MECHANISM:_default' \
'--snmp-oid=[Specify a single OID to read, if not specified the entire SNMP tree is walked]:SNMP_OID:_default' \
'--snmp-max=[Specify a maximum number of OIDs to walk. Set to 0 to walk the entire SNMP tree (it may take a long time)]:SNMP_MAX:_default' \
'--socks5-address=[Remote address to test the proxying for]:SOCKS5_ADDRESS:_default' \
'--socks5-port=[Remote port to test the proxying for]:SOCKS5_PORT:_default' \
'--ldap-domain=[LDAP domain]:LDAP_DOMAIN:_default' \
'--kerberos-realm=[Kerberos realm]:KERBEROS_REALM:_default' \
'--kerberos-protocol=[Kerberos transport protocol]:KERBEROS_PROTOCOL:(udp tcp)' \
'--rdp-domain=[Domain name]:RDP_DOMAIN:_default' \
'--port-scanner-ports=[Range or comma separated values of integer port numbers to scan]:PORT_SCANNER_PORTS:_default' \
'--port-scanner-banner-timeout=[Timeout in milliseconds for banner grabbing]:PORT_SCANNER_BANNER_TIMEOUT:_default' \
'--port-scanner-http=[Comma separated list of ports for HTTP grabbing]:PORT_SCANNER_HTTP:_default' \
'--port-scanner-https=[Comma separated list of ports for HTTPS grabbing]:PORT_SCANNER_HTTPS:_default' \
'--port-scanner-http-headers=[Comma separated list lowercase header names for HTTP/HTTPS grabbing]:PORT_SCANNER_HTTP_HEADERS:_default' \
'-L[List all available protocol plugins]' \
'--list-plugins[List all available protocol plugins]' \
'-J[Log runtime statistics and events as JSON]' \
'--json[Log runtime statistics and events as JSON]' \
'--single-match[Exit after the first positive match is found]' \
'-Q[Do not report statistics]' \
'--quiet[Do not report statistics]' \
'--amqp-ssl[Enable SSL for AMQP]' \
'--http-follow-redirects[Follow HTTP redirects]' \
'--dns-ip-lookup[Perform ip to hostname lookup]' \
'--dns-no-https[Do not fetch HTTPS certificates for new domains]' \
'--pop3-ssl[Enable SSL for POP3]' \
'--kerberos-linux[If targeting a Linux Kerberos5 implementation, pass this flag to preserve the realm string case]' \
'--rdp-ntlm[Use a NTLM hash instead of a password]' \
'--rdp-admin-mode[Restricted admin mode]' \
'--rdp-auto-logon[AutoLogon mode in case of SSL negotiation]' \
'--mqtt-v5[Use v5 of the MQTT protocol]' \
'--mqtt-ssl[Use SSL/TLS connection (mqtts\://) with certificate verification disabled]' \
'--redis-ssl[Enable SSL for Redis]' \
'--port-scanner-no-banners[Do not attempt banner grabbing]' \
'--port-scanner-no-udp[Do not perform UDP scan]' \
'--port-scanner-no-tcp[Do not perform TCP scan]' \
'--irc-tls[Use TLS for IRC]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::plugin -- Protocol plugin to use, run with --list-plugins for a list of all available plugins:_default' \
&& ret=0
}

(( $+functions[_legba_commands] )) ||
_legba_commands() {
    local commands; commands=()
    _describe -t commands 'legba commands' commands "$@"
}

if [ "$funcstack[1]" = "_legba" ]; then
    _legba "$@"
else
    compdef _legba legba
fi
