#compdef gh-clean
# Documentation: https://github.com/mihirgupta0900/gh-clean
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# mihirgupta0900/gh-clean - CLI to clean up your GitHub repos (Commander.js).
# Subcommands and flags taken from src/index.ts.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'login:login to GitHub'
      'repo:clean GitHub repos'
    )
    _describe -t commands 'gh-clean command' commands && ret=0
    ;;
  args)
    _arguments \
      '(-f --force)'{-f,--force}'[force login]' \
      '(- *)'{-h,--help}'[show help]' && ret=0
    ;;
esac

return ret
