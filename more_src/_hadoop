#compdef hadoop
# Documentation: https://man.archlinux.org/search?q=hadoop
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'archive:create a hadoop archive'
  'checknative:check native code availability'
  'classpath:print class path'
  'conftest:validate config XML files'
  'credential:manage credentials and secrets'
  'distch:change ownership and permissions'
  'distcp:copy files or directories recursively'
  'dtutil:manage delegation tokens'
  'fs:filesystem shell (alias of hdfs dfs)'
  'gridmix:cluster benchmark'
  'jar:run a jar file'
  'jnipath:print computed java.library.path'
  'kerbname:convert principal via auth_to_local'
  'kdiag:diagnose Kerberos problems'
  'key:manage keys via KeyProvider'
  'kms:run Key Management Server'
  'version:print version'
  'envvars:show Hadoop env vars'
  'daemonlog:get/set log level for a daemon'
)

_arguments -C \
  '--buildpaths[include hadoop-* jars in classpath]' \
  '--config=[config directory]:dir:_files -/' \
  '--daemon=[daemon mode]:mode:(start stop status)' \
  '--debug[enable debug]' \
  '(- *)--help[show help]' \
  '--hostnames=[hostnames]:list:' \
  '--hosts=[hosts file]:file:_files' \
  '--loglevel=[log level]:level:(FATAL ERROR WARN INFO DEBUG TRACE)' \
  '--workers[run on workers]' \
  '*-archives=[archives]:list:' \
  '-conf=[config file]:file:_files -g "*.xml"' \
  '*-D[property]:prop=value:' \
  '*-files=[files]:list:' \
  '-fs=[default FS URI]:uri:' \
  '-jt=[job tracker]:jt:' \
  '*-libjars=[library jars]:list:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'hadoop subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (jar)
        _arguments \
          ':jarfile:_files -g "*.jar"' \
          ':main class:' \
          '*:args:' && ret=0
        ;;
      (key)
        _values 'key action' 'create' 'roll' 'delete' 'list' 'check' && ret=0
        ;;
      (credential)
        _values 'credential action' 'create' 'delete' 'list' 'check' && ret=0
        ;;
      (daemonlog)
        _arguments \
          '-getlevel[get log level]:host\:port:' \
          '-setlevel[set log level]:host\:port:' \
          '-protocol=[protocol]:proto:(http https)' && ret=0
        ;;
    esac
    ;;
esac

return ret
