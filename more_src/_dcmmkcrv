#compdef dcmmkcrv
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmmkcrv.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmpstat/apps/dcmmkcrv.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmpstat/apps/dcmmkcrv.cc OFCommandLine setup + docs/man/dcmmkcrv.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(-r --poly)'{-r,--poly}'[create as POLY curve (default)]' \
  '(+r --roi)'{+r,--roi}'[create as ROI curve]' \
  '(+v --data-vr)'{+v+,--data-vr=}'[select curve data VR 0=US 1=SS 2=FL 3=FD 4=SL (default: 4)]:number:(0 1 2 3 4)' \
  '(-c --curve-vr)'{-c+,--curve-vr=}'[select VR for Curve Data element 0=data-vr 1=OB 2=OW (default: 0)]:number:(0 1 2)' \
  '(-g --group)'{-g+,--group=}'[select repeating group 0=0x5000 1=0x5002 etc. (default: 0)]:number:' \
  '(-l --label)'{-l+,--label=}'[set Curve Label]:string:' \
  '(+d --description)'{+d+,--description=}'[set Curve Description]:string:' \
  '(-a --axis)'{-a+,--axis=}'[set Axis Units x\\y]:x:' \
  '*:dcmfile-in:_files'
