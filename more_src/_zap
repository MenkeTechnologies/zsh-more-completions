#compdef zap

_zap_commands() {
  local -a commands=(
    'init:Initialize zap'
    'install:Install a plugin'
    'remove:Remove a plugin'
    'update:Update plugins'
    'clean:Remove unused plugins'
    'list:List installed plugins'
    'version:Print version'
  )
  _describe 'command' commands
}

_zap() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help[Show help]' \
    '--version[Print version]' \
    '1:command:_zap_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        install)
          _arguments \
            '1:plugin (user/repo):'
          ;;
        remove)
          _arguments \
            '1:plugin:'
          ;;
        update)
          _arguments \
            '--all[Update all plugins]' \
            '--self[Update zap itself]' \
            '*:plugin:'
          ;;
      esac
      ;;
  esac
}

_zap "$@"
