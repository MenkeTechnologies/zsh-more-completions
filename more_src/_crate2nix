    local commands; commands=(
        "generate:Generates a Cargo.nix file from a cargo rust project." \
"source:Support for managing out-of-tree sources." \
"completions:Generates auto-completions for the shell." \
"help:Prints this message or the help of the given subcommand(s)" \
