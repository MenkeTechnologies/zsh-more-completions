#compdef nimaketime
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/nimaketime.html
# Create NICER good time intervals (GTI) from a prefilter MKF file

local ret=1

_arguments -s -S \
  'infile=[input prefilter MKF file]:infile:_files' \
  'outfile=[output GTI file]:outfile:_files' \
  'nicersaafilt=[apply NICER_SAA filtering]:nicersaafilt:(yes no)' \
  'saafilt=[apply generic SAA filtering]:saafilt:(yes no)' \
  'trackfilt=[apply pointing tracking filtering]:trackfilt:(yes no)' \
  'st_valid=[require valid star tracker solution]:st_valid:(yes no)' \
  'ang_dist=[max angular distance to boresight deg]:ang_dist:' \
  'elv=[minimum elevation above Earth limb deg]:elv:' \
  'br_earth=[minimum distance from bright Earth deg]:br_earth:' \
  'cor_range=[magnetic cut-off rigidity range GeV/c]:cor_range:' \
  'min_fpm=[minimum enabled FPMs required]:min_fpm:' \
  'ingtis=[additional GTI files to merge]:ingtis:_files' \
  'thresh_range=[NICER threshold setting range]:thresh_range:' \
  'threshfilter=[threshold range shortcut]:threshfilter:(ALL DAY NIGHT)' \
  'mingti=[minimum GTI duration seconds]:mingti:' \
  'erodedilate=[erosion-dilation parameter]:erodedilate:' \
  'expr=[custom maketime filtering expression]:expr:' \
  'outexprfile=[write filtering expressions to file]:outexprfile:_files' \
  'cleanup=[remove temporary files]:cleanup:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
