#compdef IDFileConverter
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: convert between identification file formats

local ret=1

_arguments -s -S \
  '-in[input file/directory with identification data]:input file:_files' \
  '-out[output file]:output file:_files' \
  '-out_type[output format]:type:' \
  '-mz_file[raw data file for RT and spectrum ID lookup]:file:_files' \
  '-mz_name[experiment filename to match in pepXML]:name:' \
  '-peptideprophet_analyzed[format pepXML as PeptideProphet result]' \
  '-score_type[Percolator score to report]:type:(qvalue PEP score)' \
  '-ignore_proteins_per_peptide[workaround for some Sequest .out files]' \
  '-scan_regex[regex for extracting scan numbers or RTs]:regex:' \
  '-no_spectra_data_override[prevent overriding spectrum data]' \
  '-no_spectra_references_override[prevent overriding spectrum references]' \
  '-add_ionmatch_annotation[annotate identifications with ion matches]:tolerance:' \
  '-concatenate_peptides[merge top peptide hits into single sequence]' \
  '-number_of_hits[peptide hits to export (FASTA only)]:n:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
