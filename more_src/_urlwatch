#compdef urlwatch

# Zsh completion for urlwatch - monitor web pages for changes

_arguments -s -S \
  '--urls=[path to URLs file]:urls file:_files -g "*.yaml"' \
  '--config=[path to config file]:config file:_files -g "*.yaml"' \
  '--hooks=[path to hooks file]:hooks file:_files -g "*.py"' \
  '--cache=[path to cache database]:cache file:_files' \
  '--list[list all watched URLs]' \
  '--add=[add URL to watch list]:url:' \
  '--delete=[delete URL by index]:index:' \
  '--test-filter=[test filter for URL by index]:index:' \
  '--test-diff-filter=[test diff filter for URL by index]:index:' \
  '--dump-config[print current configuration]' \
  '--edit[edit URLs file]' \
  '--edit-config[edit config file]' \
  '--edit-hooks[edit hooks file]' \
  '--features[list supported filters and reporters]' \
  '--gc-cache=[remove old cache entries]:max age days:' \
  '--no-cache[do not use cache]' \
  '--test-reporter=[test a reporter]:reporter:(text html markdown telegram slack email stdout)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
