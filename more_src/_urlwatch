#compdef urlwatch
# Documentation: https://github.com/thp/urlwatch
# Reference accessed: 2026-05-21
# Verified: parser.add_argument calls in lib/urlwatch/config.py upstream.

# Zsh completion for urlwatch - monitor web pages for changes

_arguments -s -S \
  '--tags=[only run jobs with the given tag(s)]:tags:' \
  '--urls=[path to URLs file]:urls file:_files' \
  '--config=[path to config file]:config file:_files' \
  '--hooks=[path to hooks file]:hooks file:_files -g "*.py"' \
  '--cache=[path to cache database]:cache file:_files' \
  '--list[list all jobs]' \
  '--add=[add new job]:job spec:' \
  '--delete=[delete a job by index or location]:job:' \
  '--enable=[enable a job]:job:' \
  '--disable=[disable a job]:job:' \
  '--change-location=[change a jobs location]:job:' \
  '--prepare-jobs[initialize new jobs or jobs without history]' \
  '--test-filter=[test filter for job (index)]:job:' \
  '--test-diff-filter=[test diff filter for job (needs historic snapshots)]:job:' \
  '--dump-history=[dump historic snapshots for job]:job:' \
  '--edit[edit URLs/jobs file]' \
  '--edit-config[edit configuration file]' \
  '--edit-hooks[edit hooks file]' \
  '--features[list supported jobs, filters and reporters]' \
  '--gc-cache[remove old cache entries]' \
  '--smtp-login[configure SMTP authentication]' \
  '--xmpp-login[configure XMPP authentication]' \
  '--telegram-chats[list active Telegram chats]' \
  '--test-reporter=[test a reporter]:reporter:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show version]' \
  '*:joblist:'
