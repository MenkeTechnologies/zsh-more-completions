#compdef samtools-head
# Documentation: http://www.htslib.org/doc/samtools-head.html
# samtools head: View the headers of a SAM/BAM/CRAM file

local ret=1

_arguments -s -S \
  '(-h --headers)'{-h,--headers}'[Display only the first INT header lines. By default, all header lines]:INT: ' \
  '(-n --records)'{-n,--records}'[Also display the first INT alignment records. By default, no alignment]:INT: ' \
  '*:file:_files' && ret=0

return ret
