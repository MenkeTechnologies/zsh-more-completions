#compdef buck-cli
# _buck-cli — Meta Buck1 multi-language build system CLI alias (Meta, Java); custom argparse (deprecated in favor of buck2)
# upstream: https://github.com/facebookarchive/buck

_buck-cli() {
    local -a sub=(
        'audit:inspect Buck internals'
        'build:build targets'
        'cache:inspect/manage caches'
        'clean:clean build state'
        'doctor:diagnose issues'
        'fetch:fetch sources'
        'help:show help'
        'install:build + install'
        'kill:kill the daemon'
        'killall:kill all daemons'
        'machine-log:replay machine log'
        'parser-cache:parser cache commands'
        'project:project IDE generators'
        'publish:publish artifact'
        'query:query targets'
        'rage:create bug report'
        'root:print buck root'
        'run:run a binary'
        'server:run buck server'
        'targets:list targets'
        'test:run tests'
        'uninstall:uninstall apk'
        'verify-caches:verify cache integrity'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose=+[verbosity]:n:' \
        '-v+[verbosity]:n:' \
        '--no-cache[no cache]' \
        '--num-threads=+[threads]:n:' \
        '-j+[threads]:n:' \
        '--config=+[config key=value]:list:' \
        '-c+[config key=value]:list:' \
        '--config-file=+[config file]:file:_files -g "*.buckconfig"' \
        '--show-output[show output paths]' \
        '--show-full-output[show full output paths]' \
        '--show-json-output[show json output]' \
        '--show-rulekey[show rulekeys]' \
        '--profile-buck-config[profile buck config]' \
        '--just-build=+[just build targets]:list:' \
        '--no-update[no update]' \
        '--keep-going[keep going]' \
        '-k[keep going]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'buck subcommand' sub ;;
        args)
            case $words[1] in
                build|test|run|install|targets|query|fetch|publish|uninstall) _arguments '*:target:' ;;
                project) _arguments \
                    '--ide=+[ide]:i:(intellij eclipse xcode)' \
                    '*:target:' ;;
                audit) _arguments \
                    '1:cmd:(input dep query rules visibility config flavors classpath modulemap mismatches alias dependencies)' \
                    '*:arg:' ;;
                cache) _arguments \
                    '1:cmd:(remove)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_buck-cli "$@"
