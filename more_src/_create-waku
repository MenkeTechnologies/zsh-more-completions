#compdef create-waku
# Documentation: https://www.npmjs.com/package/create-waku
# Reference accessed: 2026-05-23
# Verified: npx create-waku --help.

# Zsh completion for create-waku - Waku React framework project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--choose[choose from the template list]' \
  '--template=[template name]:template:' \
  '--example=[example to use as template]:example:' \
  '--project-name=[project name]:name:' \
  '--skip-install[skip installing dependencies]' \
  '--help[display help]' && ret=0

return ret
