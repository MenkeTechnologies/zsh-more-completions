#compdef cobbler cobblerd
# Documentation: https://man.archlinux.org/search?q=cobbler
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'check:check server health'
  'sync:sync configuration files'
  'sync-systems:sync systems only'
  'mkloaders:make bootloaders'
  'distro:manage distros'
  'profile:manage profiles'
  'system:manage systems'
  'repo:manage repos'
  'image:manage images'
  'mgmtclass:manage mgmt classes'
  'package:manage packages'
  'file:manage files'
  'menu:manage menus'
  'reposync:sync repos'
  'aclsetup:setup ACLs'
  'buildiso:build ISO'
  'hardlink:hardlink duplicate files'
  'import:import distro'
  'list:list everything'
  'replicate:replicate remote cobbler'
  'report:show reports'
  'reposync:sync repos'
  'signature:signature commands'
  'validate-autoinstalls:validate autoinstall'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cobbler command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (distro|profile|system|repo|image|mgmtclass|package|file|menu)
        _values 'op' add edit copy remove rename list report find && ret=0 ;;
    esac ;;
esac

return ret
