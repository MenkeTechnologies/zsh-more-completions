#compdef cuffcompare
# Documentation: https://man.archlinux.org/search?q=cuffcompare
# Reference accessed: 2026-05-16

# Cuffcompare: compare assembled transcripts against a reference
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[verbose mode]' \
  '-V[show extended messages]' \
  '-o[output prefix]:prefix:' \
  '-r[reference GTF/GFF]:file:_files -g "*.(gtf|gff)"' \
  '-R[ignore reference transcripts not overlapping any input]' \
  '-Q[restrict to input transcripts overlapping the reference]' \
  '-G[generate a combined GTF instead of consensus]' \
  '-T[do not output .tmap and .refmap files]' \
  '-C[include contained transcripts in output]' \
  '-s[FASTA reference]:file:_files -g "*.(fa|fasta)"' \
  '-e[minimum overlap percent for cluster (1-100)]:n:' \
  '-d[minimum number of intron distinct positions]:n:' \
  '*:input GTF files:_files -g "*.gtf"' && ret=0
return ret
