#compdef virt-convert
# Documentation: https://manpages.org/virt-convert
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--connect=[hypervisor URI]:uri:' \
  '(-i --input-format)'{-i+,--input-format=}'[input format]:fmt:(ovf vmx)' \
  '(-D --disk-format)'{-D+,--disk-format=}'[output disk format]:fmt:(raw qcow2)' \
  '--destination=[destination directory]:dir:_files -/' \
  '--noautoconsole[skip automatic console connection]' \
  '--print-xml[display generated libvirt XML without conversion]' \
  '--dry-run[simulate conversion without writing files]' \
  '(-q --quiet)'{-q,--quiet}'[suppress verbose output]' \
  '(-d --debug)'{-d,--debug}'[enable debugging output]' \
  '*:VM file or archive:_files' && ret=0

return ret
