#compdef virt-convert

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--connect=+[libvirt URI]:uri:' \
  '(-i --input-format)'{-i,--input-format}'+[input format]:fmt:(ovf vmx)' \
  '(-D --disk-format)'{-D,--disk-format}'+[output disk format]:fmt:(qcow2 raw vmdk vdi)' \
  '(-o --destination)'{-o,--destination}'+[destination dir]:dir:_files -/' \
  '--noautoconsole[no autoconsole]' \
  '--print-xml[print xml]' \
  '--dry-run[dry run]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--debug[debug]' \
  '*:VM file:_files' && ret=0

return ret
