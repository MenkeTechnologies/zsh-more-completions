#compdef humio-cli humioctl humio
# _humio-cli — CrowdStrike Falcon LogScale Humio humio-cli CLI command-line frontend wrapping the LogScale formerly Humio log management observability platform CLI providing login logout profile alert action notifier parser repo view ingest-listener users token role group dashboard parser source filter widget yaml-template export import query streaming-search live-search subscriptions aggregate-alert (CrowdStrike LogScale Humio team, Go); cobra
# upstream: https://www.crowdstrike.com/falcon-platform/falcon-logscale/

_humio-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'profiles:profile operations'
        'status:show cluster status'
        'alerts:alert operations'
        'aggregate-alerts:aggregate alert operations'
        'actions:action operations'
        'notifiers:notifier operations'
        'parsers:parser operations'
        'repo:repository operations'
        'view:view operations'
        'ingest-tokens:ingest token operations'
        'users:user operations'
        'tokens:token operations'
        'roles:role operations'
        'groups:group operations'
        'dashboards:dashboard operations'
        'query:run a query'
        'search:search logs'
        'ingest:ingest data'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--token=+[token]:str:' \
        '--address=+[url]:str:' \
        '--profile=+[name]:str:' \
        '--ca-certificate=+[file]:file:_files -g "*.pem *.crt"' \
        '--insecure[skip TLS verify]' \
        '--proxy=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'humio subcommand' sub ;;
        args)
            case $words[1] in
                alerts|aggregate-alerts|actions|notifiers|parsers|repo|view|ingest-tokens|users|tokens|roles|groups|dashboards|profiles) _arguments '1:op:(list get show create update delete export import enable disable)' '*:id:' ;;
                query|search) _arguments '*:query:' ;;
                ingest) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_humio-cli "$@"
