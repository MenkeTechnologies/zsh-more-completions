#compdef windowmasker
# BLAST+ tool to mask repeats/low-complexity DNA via per-genome unit-count statistics
# Flags from NCBI C++ Toolkit src/app/winmasker/README

local ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '-mk_counts[stage 1: build unit counts]' \
  '-ustat=[stage 2: name of unit-counts file]:file:_files' \
  '-convert[convert between unit-counts formats]' \
  '-in=[input file name]:file:_files' \
  '-out=[output file name]:file:_files' \
  '-infmt=[input format]:format:(fasta blastdb)' \
  '-outfmt=[output format]:format:(interval fasta maskinfo_asn1_bin maskinfo_asn1_text seqloc_asn1_bin seqloc_asn1_text)' \
  '-sformat=[unit-counts output format]:format:(ascii binary oascii obinary)' \
  '-fa_list[input is a list of FASTA file names]' \
  '-checkdup=[check for duplicate sequences]:bool:(true false)' \
  '-mem=[available memory in MB]:int:' \
  '-smem=[memory limit for optimized formats in MB]:int:' \
  '-unit=[unit length (1-16)]:int:' \
  '-genome_size=[genome length in bases]:int:' \
  '-window=[sliding window size]:int:' \
  '-t_low=[minimum unit-count threshold]:int:' \
  '-t_high=[maximum unit-count threshold]:int:' \
  '-t_thres=[masking threshold score]:int:' \
  '-t_extend=[window extension threshold]:int:' \
  '-set_t_low=[score for units below T_low]:int:' \
  '-set_t_high=[score for units above T_high]:int:' \
  '-dust=[also apply DUST and merge results]:bool:(true false)' \
  '-exclude_ids=[file of sequence ids to skip]:file:_files' \
  '-ids=[file of sequence ids to process]:file:_files' \
  '-text_match=[string-based id matching]:bool:(true false)' \
  '-use_ba=[use bit arrays]:bool:(true false)' \
  '-parse_seqids[parse Seq-ids in FASTA input]' && ret=0

return ret
