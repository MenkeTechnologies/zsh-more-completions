#compdef contsub
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/contsub.html
# MIRIAD: subtract continuum from a datacube

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input datacube]:in:_files' \
  'region=[rectangular region of interest]:region:' \
  'out=[output continuum-subtracted cube]:out:_files' \
  'cont=[output continuum map]:cont:_files' \
  'contchan=[continuum-only spectral channels]:contchan:' \
  'mode=[algorithm]:mode:(poly mean avgs subtr)' \
  'options=[output selection]:options:' \
  'verbose=[informational output]:verbose:' \
  'velaxis=[spectral axis specification]:velaxis:' \
  '*:image:_files' && ret=0

return ret
