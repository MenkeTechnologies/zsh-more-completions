#compdef greenmail
# Documentation: https://man.archlinux.org/search?q=greenmail
# Reference accessed: 2026-05-16

# greenmail: in-memory test mail server (SMTP/IMAP/POP3) launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--smtpHost=[SMTP bind host]:host:_hosts' \
  '--smtpPort=[SMTP port]:port:' \
  '--imapHost=[IMAP bind host]:host:_hosts' \
  '--imapPort=[IMAP port]:port:' \
  '--imapsPort=[IMAPS port]:port:' \
  '--pop3Host=[POP3 bind host]:host:_hosts' \
  '--pop3Port=[POP3 port]:port:' \
  '--apiHost=[API host]:host:_hosts' \
  '--apiPort=[API port]:port:' \
  '--users=[users (comma-list of login:pass)]:list:' \
  '--portStart=[start of port range]:port:' \
  '--portOffset=[port offset]:n:' \
  '--verbose[verbose]' \
  '*::greenmail args:_files' && ret=0
return ret
