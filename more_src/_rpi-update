#compdef rpi-update
# _rpi-update — Hexxeh rpi-update CLI for the Raspberry Pi firmware updater fetching latest pre-release kernel and firmware from GitHub installing to /boot and /lib/modules with backup uninstall (Hexxeh team, Bash); getopt
# upstream: https://github.com/Hexxeh/rpi-update

_rpi-update() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '-D+[hash]:str:' \
        '--rev=+[hash]:str:' \
        '--branch=+[branch]:str:' \
        '--source=+[url]:str:' \
        '--firmware-revision=+[revision]:str:' \
        '--keep-current-config[keep current config]' \
        '--no-backup[no backup]' \
        '--skip-kernel[skip kernel]' \
        '--skip-modules[skip modules]' \
        '--skip-bootloader[skip bootloader]' \
        '--skip-update-self[skip self update]' \
        '--root-path=+[dir]:dir:_files -/' \
        '--boot-path=+[dir]:dir:_files -/' \
        '*:revision hash:'
}

_rpi-update "$@"
