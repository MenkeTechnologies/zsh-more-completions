#compdef avra
# Documentation: https://github.com/Ro5bert/avra/blob/master/USAGE.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# AVRA: assembler for Atmel AVR microcontrollers
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-l[listing file]:file:_files' \
  '--listfile=[listing file]:file:_files' \
  '-m[map file]:file:_files' \
  '--mapfile=[map file]:file:_files' \
  '-o[output hex file]:file:_files' \
  '--outfile=[output hex file]:file:_files' \
  '-d[debug file]:file:_files' \
  '--debugfile=[debug file]:file:_files' \
  '-I[include directory]:dir:_files -/' \
  '--includepath=[include directory]:dir:_files -/' \
  '-D[predefine symbol]:symbol=value:' \
  '--define=[predefine symbol]:symbol=value:' \
  '-W[no warnings]' \
  '--no-warnings[no warnings]' \
  '-O[output format]:fmt:(motorola intel generic)' \
  '--filetype=[output format]:fmt:(motorola intel generic)' \
  '-e[execute initial macro]:macro:' \
  '*:source file:_files -g "*.(asm|s)"' && ret=0
return ret
