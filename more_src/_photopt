#compdef photopt
# Documentation: https://starlink.eao.hawaii.edu/docs/sun45.htx/sun45se15.html
# PHOTOM: examine the performance of the various sky estimators used by PHOTOM.

local ret=1

_arguments -s -S \
  'SEMIM=[semi-minor axis of aperture]:val:' \
  'ECCEN=[eccentricity of aperture]:val:' \
  'ANGLE=[orientation angle of aperture]:val:' \
  'PADU=[photons per data unit]:val:' \
  'SATURE=[saturation level threshold]:val:' \
  'INNER=[inner radius of background annulus]:val:' \
  'OUTER=[outer radius of background annulus]:val:' \
  'SKYEST=[sky estimator method]:method:' \
  'NP=[number of sample points]:n:' \
  'RANGE=[bounds for data values in plot]:range:' \
  '*:file:_files' && ret=0

return ret
