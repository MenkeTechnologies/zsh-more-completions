#compdef darling
# _darling — macOS / Darwin emulation layer for Linux (darlinghq/darling)
# upstream: https://github.com/darlinghq/darling
# Usage from src/startup/darling.c (positional command).

_darling() {
    if (( CURRENT == 2 )); then
        local -a cmds
        cmds=(
            'shell:open an interactive Darwin shell in the prefix'
            'exec:run a program from PATH inside the Darwin prefix'
            'shutdown:shut down the Darling prefix'
        )
        _describe -t commands 'darling command' cmds
        _files
        return
    fi

    case $words[2] in
        shell|shutdown) ;;
        exec)
            _files
            ;;
        *)
            # Treat as <program-path>
            _files
            ;;
    esac
}

_darling "$@"
