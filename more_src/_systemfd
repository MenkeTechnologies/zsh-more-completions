#compdef systemfd
# Documentation: https://github.com/mitsuhiko/systemfd
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '*'{-s,--socket}'=[socket to listen on (e.g. http::3000)]:socket spec:'
  '--no-pid[do not pass LISTEN_PID env var]'
  '-q[suppress informational output]'
  '(-h --help)'{-h,--help}'[show help message]'
  '(-V --version)'{-V,--version}'[show version information]'
  '(-)--[command to run]:command:_command_names -e'
  '*:arguments:'
)

_arguments -s -S $arguments
