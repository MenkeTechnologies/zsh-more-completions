#compdef systemfd

local -a arguments

arguments=(
  '(-s --socket)'{-s,--socket}'=[socket to listen on (e.g. http::3000)]:socket spec:'
  '--no-pid[do not pass PID env var]'
  '(-h --help)'{-h,--help}'[show help message]'
  '(-V --version)'{-V,--version}'[show version information]'
  '(-)--[command to run]:command:_command_names -e'
  '*:arguments:'
)

_arguments -s -S $arguments
