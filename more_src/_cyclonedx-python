#compdef cyclonedx-python cyclonedx-py
# Documentation: https://github.com/CycloneDX/cyclonedx-python
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# CycloneDX SBOM generator for Python projects.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'environment:build SBOM from a (virtual) Python environment'
  'env:alias for environment'
  'venv:alias for environment'
  'requirements:build SBOM from Pip requirements files'
  'pipenv:build SBOM from Pipenv manifest and lockfile'
  'poetry:build SBOM from Poetry project files'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cyclonedx-py command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
