#compdef CountBases
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/CountBases.java
# Count bases in a SAM/BAM/CRAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-I,--input}'=[BAM/SAM/CRAM read file]:bam:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '(-O --output)'{-O,--output}'=[output file (defaults to STDOUT)]:output:_files' \
  '*'{-L,--intervals}'=[genomic intervals to operate over]:intervals:' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam:_files' && ret=0

return ret
