#compdef spectrum2
# _spectrum2 — XMPP transport / gateway daemon (SpectrumIM/spectrum2)
# upstream: https://github.com/SpectrumIM/spectrum2
# Flags from spectrum/src/main.cpp (boost::program_options).

_spectrum2() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-n --no-daemonize)'{-n,--no-daemonize}'[do not run as daemon]' \
        '(-d --no-debug)'{-d,--no-debug}'[create coredumps on crash]' \
        '(-j --jid)'{-j+,--jid=}'[transport JID]:jid:' \
        '--config=[config file]:file:_files -g "*.cfg"' \
        '*:config file:_files -g "*.cfg"'
}

_spectrum2 "$@"
