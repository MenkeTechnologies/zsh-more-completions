#compdef head-cli
# _head-cli — GNU coreutils head output first part of files CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_head-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[print first n bytes]:str:' \
        '--bytes=+[print first n bytes]:str:' \
        '-n+[print first n lines]:str:' \
        '--lines=+[print first n lines]:str:' \
        '-q[never print file headers]' \
        '--quiet[never print file headers]' \
        '--silent[never print file headers]' \
        '-v[always print file headers]' \
        '--verbose[always print file headers]' \
        '-z[NUL terminator]' \
        '--zero-terminated[NUL terminator]' \
        '*:files:_files'
}

_head-cli "$@"
