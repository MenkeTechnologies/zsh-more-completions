#compdef AverageTensorImages
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/AverageTensorImages.cxx — average DT tensor images (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3)' \
    '2:average.nii:_files -g "*.{nii,nii.gz}"' \
    '3:mathtype:(0 1)' \
    '*:tensor images:_files -g "*.{nii,nii.gz}"' \
    && ret=0

return ret
