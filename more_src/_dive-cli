#compdef dive-cli ctop2 lazydocker2 docker-buildx-cli buildah-cli skopeo-cli crane-cli oras-cli zot

local curcontext="$curcontext" state line ret=1

case $service in
  (dive-cli)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--ci[CI mode]' \
      '--ci-config=[CI config]:file:_files' \
      '--source=[source]:s:(docker docker-archive podman)' \
      '--lowestEfficiency=[min efficiency]:n:' \
      '--highestUserWastedPercent=[max user wasted]:n:' \
      '--highestWastedBytes=[max wasted bytes]:n:' \
      '--ignore-errors[ignore errors]' \
      '*: :' && ret=0 ;;
  (ctop2|lazydocker2)
    _arguments '*: :' && ret=0 ;;
  (docker-buildx-cli)
    _arguments -C \
      '*: :_values "command" build bake create du imagetools inspect ls prune rm stop use version' && ret=0 ;;
  (buildah-cli|skopeo-cli|crane-cli|oras-cli|zot)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*: :' && ret=0 ;;
esac

return ret
