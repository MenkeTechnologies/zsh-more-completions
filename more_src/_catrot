#compdef catrot
# _catrot — rotate / flip a tab-separated star catalog (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from catrot.c (single-letter getopt-style).

_catrot() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-l[flip around N-S axis]' \
        '-r+[rotation angle (deg)]:deg:' \
        '-v[verbose output]' \
        '*:catalog file:_files'
}

_catrot "$@"
