#compdef crond

# Zsh completion for crond (cronie) - cron daemon

_arguments -s -S \
  '-c+[crontab directory]:directory:_files -/' \
  '-f[run in foreground]' \
  '-l+[log level]:level:(0 1 2 3 4 5 6 7 8)' \
  '-m+[mail command]:command:_command_names -e' \
  '-M+[mailer program]:program:_files' \
  '-n[include PID in syslog messages]' \
  '-p[allow non-root to run crontab]' \
  '-P[do not set PATH]' \
  '-s[use syslog for all output]' \
  '-V[print version]' \
  '-x+[enable debugging flags]:flags:(ext sch proc pars load misc test bit)'
