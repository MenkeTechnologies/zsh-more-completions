#compdef osv-scanner

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'scan:scan for vulnerabilities'
      'fix:fix vulnerabilities'
    )
    _describe -t commands 'osv-scanner command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      scan)
        _arguments -s -S \
          '--lockfile[path to lockfile]:lockfile:_files' \
          '--sbom[path to SBOM file]:sbom file:_files' \
          '--docker[docker image to scan]:image' \
          '(-r --recursive)'{-r,--recursive}'[scan directories recursively]' \
          '--skip-git[skip scanning git repositories]' \
          '--json[output as JSON]' \
          '--format[output format]:format:(table json markdown sarif gh-annotations)' \
          '--config[config file path]:config file:_files' \
          '--experimental-call-analysis[enable call analysis]' \
          '--experimental-licenses-summary[show license summary]' \
          '--experimental-licenses-allowlist[allowed licenses]:licenses' \
          '--no-ignore[do not respect ignore entries]' \
          '(-L --lockfile-as)'{-L,--lockfile-as}'[treat lockfile as specific type]:type' \
          '(-S --sbom-as)'{-S,--sbom-as}'[treat SBOM as specific type]:type' \
          '*:path:_files' && ret=0
        ;;
      fix)
        _arguments -s -S \
          '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac
return ret
