#     structured logging, the FOUNDATIONAL Go logger from the
#     2014-2019 pre-zap era; STILL THE TOP-50 Go GitHub project
#     by stars due to massive installed-base provenance
#
# These three Go Axis 9 variants cover the design space:
#   logrus  = FOUNDATIONAL hook-based structured logger (2014)
#   zap     = TYPED-CTOR performance-focused (2017)
#   zerolog = CHAINED-API zero-alloc JSON (2017)
#
# Axis 9 cross-language coverage as of R587:
#   - TS-Node: consola + winston + pino (three variants)
#   - Go: zap + zerolog + logrus (three variants — MATCHES TS-Node)
#   - Rust: env_logger + slog (two variants)
#
# -----------------------------------------------------------------------------
#
# WHAT IS sirupsen/logrus AND WHY IS IT THE 54TH GO CLI LIBRARY?
#
# logrus (https://github.com/sirupsen/logrus, 25000+ stars) is
# **Simon Eskildsen's "structured, pluggable logging for Go"** —
# the FOUNDATIONAL GO STRUCTURED LOGGING LIBRARY that dominated
# Go logging from 2014-2019 before zap (Uber 2017) and zerolog
# (Netflix 2017) displaced it for performance-sensitive services.
# Simon Eskildsen ("Sirupsen") was a Shopify staff engineer who
# released logrus as the structured-logging answer to Go's
# stdlib `log` package's limitations.
#
# logrus's distinguishing characteristics:
#
#   1. HOOK ARCHITECTURE FOR MULTI-DESTINATION LOGGING — logrus's
#      central design feature: every log entry fires through
#      every registered HOOK.  A Hook is an interface with two
#      methods (Levels + Fire) that lets users plug in arbitrary
#      destinations:
#
#          import (
#              log "github.com/sirupsen/logrus"
#              "github.com/heralight/logrus_mate"
#              "gopkg.in/gemnasium/logrus-airbrake-hook.v2"
#          )
#
#          log.AddHook(airbrake.NewHook(123, "xyz", "production"))
#          log.AddHook(slackrus.NewHook(slackChannelURL))
#          log.AddHook(syslog.NewSyslogHook("udp", "localhost:514", ...))
#          log.AddHook(elasticsearch.NewElasticHook(...))
#
#          log.WithFields(log.Fields{
#              "user_id": userID,
#              "action": "purchase",
#          }).Info("transaction completed")
#          // Fires to: stdout/stderr (default) + Airbrake + Slack +
#          //           syslog + Elasticsearch (all registered hooks)
#
#      Compare:
#         * zap: separate transports via different cores
#         * zerolog: separate Logger instances per destination
#         * stdlib log: single io.Writer destination
#         * logrus: HOOK CHAIN — every entry fires through every
#                    hook in order, hooks handle their own filtering
#      FIRST documented Go logger with hook-chain pluggable-
#      destination architecture.
#
#   2. FORMATTER INTERFACE WITH PLUGGABLE OUTPUT FORMATS —
#      logrus's Formatter interface decouples HOW a log entry
#      is rendered from WHERE it goes:
#
#          log.SetFormatter(&log.JSONFormatter{
#              TimestampFormat: "2006-01-02T15:04:05Z07:00",
#              PrettyPrint: false,
#          })
#          // Or:
#          log.SetFormatter(&log.TextFormatter{
#              FullTimestamp: true,
#              ForceColors: true,
#              DisableColors: false,
#              QuoteEmptyFields: true,
#          })
#
#      Built-in Formatters: JSONFormatter (production), TextFormatter
#      (development with colors).  Plus 30+ community Formatters
#      for logfmt / nested-JSON / CloudWatch / ECS / Stackdriver /
#      Splunk HEC formats.  Compare:
#         * zap: encoder system (JSON/Console/custom)
#         * zerolog: io.Writer with ConsoleWriter for pretty
#         * logrus: FORMATTER INTERFACE — pluggable rendering
#                    separate from output destination
#      FIRST documented Go logger with Formatter-interface
#      architecture separating rendering from delivery.
#
#   3. WithFields(map[string]interface{}) STRUCTURED FIELDS —
#      logrus's primary structured-logging API uses Go maps:
#
#          log.WithFields(log.Fields{
#              "username": "alice",
#              "user_id": 42,
#              "ip": req.RemoteAddr,
#              "method": req.Method,
#              "path": req.URL.Path,
#          }).Info("request handled")
#
#      Returns an Entry value that carries the fields.  Chainable:
#
#          ctx := log.WithFields(log.Fields{"request_id": reqID})
#          ctx.Info("starting handler")
#          ctx.WithField("user", username).Info("authenticated")
#
#      Compare:
#         * zap: typed-ctor functions (zap.String/Int/...)
#         * zerolog: chained methods (.Str().Int().Msg())
#         * slog (Go stdlib): variadic key-value pairs
#         * logrus: map[string]interface{} via WithFields
#      Pre-dates the typed-API and chained-API alternatives;
#      logrus's reflection-based field handling is the SOURCE
#      of its performance penalty vs zap/zerolog (it does
#      runtime type assertions to format each field).  FIRST
#      documented Go logger with map-based structured-fields API.
#
#   4. LEVEL-AWARE BACKWARDS COMPATIBILITY WITH stdlib log —
#      logrus's top-level functions (log.Info, log.Error, etc)
#      are drop-in replacements for stdlib `log` package
#      functions — switching `import "log"` to `log "github.com/
#      sirupsen/logrus"` works without code changes.  Plus
#      Print/Println/Printf/Fatal/Panic match stdlib log
#      signatures.  Compare:
#         * zap: completely new API (zap.NewProduction/...)
#         * zerolog: completely new API (zerolog.New())
#         * logrus: drop-in replacement for stdlib log + adds
#                    level methods (Info/Warn/Error/Debug/Trace/Fatal/Panic)
#      FIRST documented Go logger designed as stdlib-`log`
#      drop-in replacement.
#
#   5. 2014-2019 GO-ECOSYSTEM FOUNDATIONAL PROVENANCE — logrus
#      was the DEFAULT Go logger for 5 years (2014-2019).
#      Major historical adopters:
#         * Docker engine (early versions)
#         * Kubernetes (early kubectl + controllers)
#         * Helm (Kubernetes package manager)
#         * Prometheus exporters
#         * GitLab Runner
#         * etcd v2 (early)
#         * containerd (early)
#         * Terraform-go providers
#         * Firecracker CLI (firectl R???)
#         * AfterBurn (R???)
#         * Many AWS CDK Go constructs
#         * Many Hashicorp Go tools
#         * kala (THIS — Modern Job Scheduler)
#      Newer projects choose zap/zerolog for performance, but
#      logrus's MASSIVE INSTALLED BASE means most production
#      Go codebases pre-2020 use it.  Top-50 Go GitHub project
#      by stars (25k+) despite being the "old" choice.
#      Compare every other documented Go logger — only stdlib
#      `log` has comparable historical reach, but logrus is
#      the structured-logging predecessor of zap+zerolog.
#      FIRST documented Go logger with 2014-2019 default-status
#      foundational provenance.
#
# logrus's relationship to other documented Go libraries:
#
#   * Like zap (R579) — both have structured field logging
#   * Unlike zap — logrus uses reflection (slower) + WithFields;
#                   zap uses typed ctors (faster) + Field functions
#   * Like zerolog (R583) — both are structured Go loggers
#   * Unlike zerolog — logrus uses map[string]interface{};
#                       zerolog uses chained typed methods
#   * Closest cross-language analogs:
#         * TS-Node: winston (R580) — same era (2010s),
#                     same hook/transport architecture, same
#                     "default logger" historical position
#         * Rust: slog (R586) — same era (2014), same structured-
#                  logging foundational role
#         * Python: structlog — similar map-based structured-fields API
#     logrus is the FIRST documented Go logger with 2014-2019
#     ecosystem-default historical provenance + hook-chain
#     architecture.
#
# -----------------------------------------------------------------------------
#
# THE kala CLI — cobra + viper + logrus
#
# kala's CLI is in cmd/{root,serve,run}.go.  cobra for
# subcommands + viper for config-file/env/flag merging +
# logrus for all observability output:
#
#     import (
#         "github.com/ajvb/kala/cmd"
#         log "github.com/sirupsen/logrus"
#     )
#
#     func init() {
#         log.SetLevel(log.InfoLevel)
#     }
#
#     func main() {
#         if err := cmd.RootCmd.Execute(); err != nil {
#             log.Fatal(err)
#         }
#     }
#
# Subcommands:
#   serve [options]    — Start the kala job scheduler server
#   run <command>      — Run a single command immediately as
#                          a job (test the runner without
#                          scheduling)
#
# `kala serve` flags (per cmd/serve.go):
#   --port,         -p <port>      Port (default :8000)
#   --no-persist,   -n             No persistence mode (test)
#   --interface,    -i <if>        Interface to listen on
#   --default-owner,-o <email>     Default owner email
#   --jobdb         <impl>         Database backend
#                                    (boltdb/redis/mongo/consul/
#                                     postgres/mysql/mariadb)
#   --bolt-path     <path>         Path to bolt database file
#   --jobdb-address <host:port>    Job DB network address
#   --jobdb-username <user>        Job DB username
#   --jobdb-password <pass>        Job DB password
#   --jobdb-tls-capath <path>      Job DB TLS CA file
#   --jobdb-tls-certpath <path>    Job DB TLS client cert
#   --jobdb-tls-keypath <path>     Job DB TLS client key
#   --jobdb-tls-servername <name>  TLS server name
#   --verbose,      -v             Verbose (debug) logging
#   --persist-every,-e <seconds>   Persist interval (default 3600)
#   --jobstat-ttl   <minutes>      JobStat retention (default -1 = forever)
#   --profile                      Activate pprof handlers
#   --no-tx-persist                Periodic-only persistence
#
# Five-axis distinctness from every other documented Go logger:
#
#   1. HOOK-CHAIN ARCHITECTURE — Every other documented Go
#      logger uses transports (zap) or io.Writer destinations
#      (zerolog).  logrus uses HOOK CHAIN where every entry
#      fires through every registered Hook.
#
#   2. FORMATTER-INTERFACE ARCHITECTURE — Every other documented
#      Go logger has integrated rendering.  logrus separates
#      Formatter (rendering) from Hooks (delivery) via a
#      pluggable Formatter interface.
#
#   3. MAP-BASED STRUCTURED-FIELDS API — Every other documented
#      Go logger uses typed ctors or chained methods for
#      structured fields.  logrus uses `WithFields(log.Fields
#      {...})` — Go map literal API.
#
#   4. STDLIB-LOG DROP-IN COMPATIBILITY — Every other documented
#      Go logger introduces a completely new API.  logrus's
#      top-level functions are drop-in replacements for stdlib
#      `log` package — switching imports works without code
#      changes.
#
#   5. 2014-2019 ECOSYSTEM-DEFAULT FOUNDATIONAL PROVENANCE —
#      Every other documented Go logger emerged 2017+ for
#      performance reasons.  logrus is the FOUNDATIONAL Go
#      structured logger from 2014, dominant for 5 years
#      across Docker + Kubernetes + Helm + Prometheus +
#      GitLab Runner + etcd-v2 + containerd-early + etc.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/ajvb/kala/blob/master/cmd/{root,serve,run}.go
# RootCmd + serveCmd + runCommandCmd cobra command definitions
# with their Flags() bindings.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _kala_cmds
_kala_cmds=(
    'serve:start the kala job scheduler server'
    'run:run a single command immediately as a job'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '--kala=[config file (default $HOME/kala.yaml)]:file:_files' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'kala subcommand' _kala_cmds && ret=0
        ;;
    args)
        case $words[1] in
            serve)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '(-p --port)'{-p+,--port=}'[port for Kala (default :8000)]:port:' \
                    '(-n --no-persist)'{-n,--no-persist}'[no-persistence mode (testing)]' \
                    '(-i --interface)'{-i+,--interface=}'[interface to listen on]:iface:' \
                    '(-o --default-owner)'{-o+,--default-owner=}'[default owner email]:email:' \
                    '--jobdb=[job database backend]:db:(boltdb redis mongo consul postgres mysql mariadb)' \
                    '--bolt-path=[bolt database file path]:file:_files' \
                    '--jobdb-address=[job DB host:port]:address:' \
                    '--jobdb-username=[job DB username]:user:' \
                    '--jobdb-password=[job DB password]:password:' \
                    '--jobdb-tls-capath=[job DB TLS CA file]:file:_files' \
                    '--jobdb-tls-certpath=[job DB TLS client cert]:file:_files' \
                    '--jobdb-tls-keypath=[job DB TLS client key]:file:_files' \
                    '--jobdb-tls-servername=[TLS server name for cert verification]:name:' \
                    '(-v --verbose)'{-v,--verbose}'[verbose (debug-level) logging]' \
                    '(-e --persist-every)'{-e+,--persist-every=}'[interval between persists (seconds, default 3600)]:N:' \
                    '--jobstat-ttl=[JobStat retention in minutes (-1 = forever)]:N:' \
                    '--profile[activate pprof handlers]' \
                    '--no-tx-persist[periodic-only (not transactional) persistence]' \
                    && ret=0
                ;;
            run)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '*:command to run:' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
