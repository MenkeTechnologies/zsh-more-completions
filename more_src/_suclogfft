#compdef suclogfft
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/suclogfft.c
# fft real time traces to complex log frequency domain traces

local ret=1

_arguments -s -S \
  'sign=[sign]:sign:' \
  'dt=[dt]:dt:' \
  'verbose=[verbose]:verbose:' \
  'mode=[mode]:mode:' \
  'unwrap=[unwrap]:unwrap:' \
  'trend=[trend]:trend:' \
  'zeromean=[zeromean]:zeromean:' \
  'key=[key]:key:' \
  'op=[op]:op:' \
  '*:file:_files' && ret=0

return ret
