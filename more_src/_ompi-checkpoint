#compdef ompi-checkpoint
# Documentation: https://man.archlinux.org/search?q=ompi-checkpoint
# Reference accessed: 2026-05-16

# ompi-checkpoint: checkpoint a running MPI job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-mca[MCA parameter]:param value:' \
  '--mca=[MCA parameter]:param value:' \
  '*::ompi-checkpoint args:_files' && ret=0
return ret
