#compdef puppet-parser
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/parser.md
# puppet parser - validate and dump the Puppet language parse tree

local ret=1

_arguments -s -S \
  '--render-as=[output render format]:format:(json s yaml console)' \
  '--verbose[whether to log verbosely]' \
  '--debug[whether to log debug information]' \
  '-e+[dump one source expression from the command line]:source:' \
  '--format=[result format]:format:(old pn json)' \
  '--pretty[pretty print output (pn or json only)]' \
  '--validate[validate the parsed result]' \
  '--no-validate[do not validate the parsed result]' \
  '1:action:(validate dump)' \
  '*::manifest:_files -g "*.pp"' && ret=0

return ret
