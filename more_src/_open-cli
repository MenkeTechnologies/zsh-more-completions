#compdef open-cli
# Documentation: https://github.com/sindresorhus/open-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--wait[wait for the launched app to exit]' \
  '--background[do not bring the app to the foreground (macOS)]' \
  '--extension=[file extension when reading from stdin]:extension:' \
  '1:file or URL:_files' \
  '*::app and args: _default' && ret=0

return ret
