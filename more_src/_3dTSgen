#compdef 3dTSgen
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTSgen.html
# AFNI: generate simulated voxel time series from signal+noise models

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-input[input 3D+time dataset]:fname:_files' \
  '-inTR[use TR from input dataset]' \
  '-signal[signal model label]:slabel:' \
  '-noise[noise model label]:nlabel:' \
  '*-sconstr[constraints on signal parameter k]:k c d:' \
  '*-nconstr[constraints on noise parameter k]:k c d:' \
  '-sigma[noise standard deviation]:s:' \
  '-voxel[print results for given voxel]:num:' \
  '-output[output filename]:fname:_files' \
  '*-scoef[signal coefficient k output]:k fname:_files' \
  '*-ncoef[noise coefficient k output]:k fname:_files' \
  '-bucket[output bucket dataset]:n prefixname:_files' \
  '*-brick[define sub-brick of bucket]:m type k label:' \
  '*:dataset:_files' && ret=0

return ret
