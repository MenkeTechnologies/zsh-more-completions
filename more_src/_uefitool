#compdef uefitool
# Documentation: https://github.com/LongSoft/UEFITool
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# UEFITool: UEFI firmware image editor (Qt GUI + CLI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '*:UEFI firmware image:_files -g "*.(rom|bin|cap|fd|img)"' && ret=0
return ret
