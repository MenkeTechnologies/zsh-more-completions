#compdef uefitool
# Documentation: https://man.archlinux.org/search?q=uefitool
# Reference accessed: 2026-05-16

# UEFITool: UEFI firmware image editor (Qt GUI + CLI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '*:UEFI firmware image:_files -g "*.(rom|bin|cap|fd|img)"' && ret=0
return ret
