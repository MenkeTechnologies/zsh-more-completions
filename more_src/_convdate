#compdef convdate
# Documentation: man convdate(1)
# Source: InterNetNews/inn expire/convdate.c — convert dates to/from various forms (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-d[output Date header format]' \
    '-l[show local time]' \
    '(-c -n -s)-c[parse as ctime format]' \
    '(-c -n -s)-n[output as Unix epoch seconds]' \
    '(-c -n -s)-s[output as RFC 5322 Date format (default)]' \
    '*:date:_default' \
    && ret=0

return ret
