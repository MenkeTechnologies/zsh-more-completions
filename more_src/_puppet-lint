#compdef puppet-lint

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:file:_files' \
  '--load-from-puppetfile[load lint plugins from Puppetfile]' \
  '--no-puppetfile[do not load from Puppetfile]' \
  '--no-puppetfile-loader[disable Puppetfile loader]' \
  '--no-2sp_soft_tabs-check[disable 2-space soft tabs check]' \
  '--no-80chars-check[disable 80-char line length check]' \
  '--no-arrow_alignment-check[disable arrow alignment check]' \
  '--no-autoloader_layout-check[disable autoloader layout check]' \
  '--no-class_inherits_from_params_class-check[disable params class inherits check]' \
  '--no-class_parameter_defaults-check[disable class parameter defaults check]' \
  '--no-documentation-check[disable documentation check]' \
  '--no-double_quoted_strings-check[disable double quoted strings check]' \
  '--no-ensure_first_param-check[disable ensure first param check]' \
  '--no-ensure_not_symbol_or_string-check[disable ensure_not_symbol_or_string check]' \
  '--no-hard_tabs-check[disable hard tabs check]' \
  '--no-only_variable_string-check[disable only variable string check]' \
  '--no-puppet_url_without_modules-check[disable puppet:// without modules check]' \
  '--no-quoted_booleans-check[disable quoted booleans check]' \
  '--no-right_to_left_relationships-check[disable right-to-left relationships check]' \
  '--no-selector_inside_resource-check[disable selector inside resource check]' \
  '--no-trailing_whitespace-check[disable trailing whitespace check]' \
  '--no-unquoted_file_mode-check[disable unquoted file mode check]' \
  '--no-unquoted_resource_title-check[disable unquoted resource title check]' \
  '--no-variable_contains_dash-check[disable variable contains dash check]' \
  '--no-variable_scope-check[disable variable scope check]' \
  '--with-context[show context for warnings]' \
  '--with-filename[show filename for each match]' \
  '--list-checks[list available checks]' \
  '--no-fail-on-warnings[do not fail on warnings]' \
  '--fail-on-warnings[fail on warnings]' \
  '--fix[fix issues automatically when possible]' \
  '--log-format=[log format]:format:' \
  '--json[output as JSON]' \
  '--sarif[output as SARIF]' \
  '--show-ignored[show ignored issues]' \
  '--ignore-paths=[paths to ignore]:paths:' \
  '--relative[show relative paths]' \
  '*:Puppet manifest:_files -g "*.pp"' && ret=0

return ret
