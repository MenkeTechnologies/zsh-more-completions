#compdef puppet-lint
# Documentation: https://manpages.debian.org/trixie/puppet-lint/puppet-lint.1
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-config[do not load default configuration files]' \
  '(-c --config)'{-c+,--config=}'[load options from file]:file:_files' \
  '--with-context[show problem location in manifest]' \
  '--with-filename[display filename before warnings]' \
  '--fail-on-warnings[return non-zero exit for warnings]' \
  '--error-level=[set error reporting level]:level:(warning error all)' \
  '--show-ignored[display ignored problems]' \
  '--relative[compare layout relative to module root]' \
  '(-l --load)'{-l+,--load=}'[load custom checks from file]:file:_files' \
  '--load-from-puppet=[load plugins from module path]:modulepath:' \
  '(-f --fix)'{-f,--fix}'[automatically fix errors]' \
  '--log-format=[customize log output format]:format:' \
  '--json[output as JSON]' \
  '--sarif[output as SARIF]' \
  '--codeclimate-report-file=[save CodeClimate report]:file:_files' \
  '--list-checks[list available checks]' \
  '--only-checks=[run specific checks (comma-separated)]:checks:' \
  '--ignore-paths=[ignore patterns (comma-separated)]:paths:' \
  '--top-scope-variables=[allow top-scope variables (comma-separated)]:vars:' \
  '*--no-*-check[disable a specific check]' \
  '*--*-check[enable a specific check]' \
  '*:Puppet manifest:_files -g "*.pp"' && ret=0

return ret
