#compdef prefetch fastq-dump fasterq-dump vdb-dump sam-dump sra-stat vdb-validate vdb-config vdb-encrypt vdb-decrypt
# Documentation: upstream NCBI sra-tools docs + man pages
# Reference accessed: 2026-05-30 via WebFetch of
# github.com/ncbi/sra-tools/wiki/HowTo:-fasterq-dump and
# edwards.flinders.edu.au/fastq-dump/ + gh api inspection of
# tools/external/prefetch/{PrfMain.h,prefetch.c} for option-token
# constants.
# NCBI SRA Toolkit R105 — 10-stem multi-binary harvest covering
# the core NCBI Sequence Read Archive download/conversion/dump
# toolkit. All binaries share the common KApp-style help/version
# flags (-h/-V/--help/--version/-L log-level/-v verbose/-q quiet).

local curcontext="$curcontext" state line ret=1

# Shared KApp common flags across all SRA toolkit binaries.
local -a _common_kapp
_common_kapp=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '(-L --log-level)'{-L,--log-level}'=[log level]:level:(fatal sys int err warn info debug)'
  '(-v --verbose)*'{-v,--verbose}'[verbose mode (repeatable for more verbosity)]'
  '(-q --quiet)'{-q,--quiet}'[turn off all messages]'
  '--option-file=[read options from file]:file:_files'
  '--no-user-settings[do not load NCBI configuration]'
)

case $service in

  prefetch)
    # Retrieve SRA accessions, kart files, or URLs.
    _arguments -s -S \
      $_common_kapp \
      '--cart=[kart file with accessions to prefetch]:file:_files' \
      '--text-kart=[text kart file]:file:_files' \
      '--ngc=[NGC credentials file for protected data]:file:_files' \
      '(-o --output-file)'{-o,--output-file}'=[output file for single-accession mode]:file:_files' \
      '(-O --output-directory)'{-O,--output-directory}'=[output directory]:dir:_directories' \
      '--max-size=[max accession size (KB)]:KB:' \
      '--min-size=[skip accessions smaller than (KB)]:KB:' \
      '--force=[overwrite existing files]:mode:(no yes all ALL)' \
      '(-r --resume)'{-r,--resume}'=[resume incomplete downloads]:mode:(yes no)' \
      '(-C --verify)'{-C,--verify}'=[verify downloads]:mode:(yes no)' \
      '(-t --transport)'{-t,--transport}'=[transport mechanism]:transport:(http fasp both)' \
      '(-l --location)'{-l,--location}'=[cloud location]:location:' \
      '(-N --rows)'{-N,--rows}'=[rows to process (only for sra-stat)]:N:' \
      '--type=[type of files to prefetch]:type:(sra refseq all)' \
      '--eliminate-quals[remove quality scores]' \
      '--ascp-options=[options to pass to Aspera client]:options:' \
      '(-p --progress)'{-p,--progress}'[show progress]' \
      '(-c --check-all)'{-c,--check-all}'[check all dependencies]' \
      '--check-rs[check refseq dependencies]' \
      '*:accession or kart file:_files' \
      && ret=0
    ;;

  fastq-dump)
    # Convert SRA → FASTQ (legacy single-threaded; fasterq-dump
    # supersedes for most workflows).
    _arguments -s -S \
      $_common_kapp \
      '(-A --accession)'{-A,--accession}'=[SRA accession (default = SRA file name)]:accession:' \
      '--split-spot[split spots into individual reads]' \
      '--split-files[split into separate files per read]' \
      '--split-3[3-file split: paired + singletons (legacy default)]' \
      '--fasta=[FASTA output (optional line width, default 70)]:width:' \
      '(-B --dumpbase)'{-B,--dumpbase}'[dump bases (default)]' \
      '(-C --dumpcs)'{-C,--dumpcs}'=[dump color-space (SOLiD, optional cs-key)]:cskey:' \
      '(-I --readids)'{-I,--readids}'[append read IDs (.1/.2)]' \
      '(-F --origfmt)'{-F,--origfmt}'[keep original sequence names]' \
      '(-Q --offset)'{-Q,--offset}'=[ASCII quality score offset (default 33)]:N:' \
      '--skip-technical[output biological reads only]' \
      '--read-filter=[filter on read type]:filter:(pass reject criteria redacted)' \
      '(-W --clip)'{-W,--clip}'[apply left/right clips from CLIP_QUALITY_LEFT/RIGHT]' \
      '(-M --minReadLen)'{-M,--minReadLen}'=[minimum read length]:N:' \
      '(-N --minSpotId)'{-N,--minSpotId}'=[minimum spot ID]:row id:' \
      '(-X --maxSpotId)'{-X,--maxSpotId}'=[maximum spot ID]:row id:' \
      '--aligned[output only aligned spots]' \
      '--unaligned[output only unaligned spots]' \
      '(-O --outdir)'{-O,--outdir}'=[output directory]:dir:_directories' \
      '(-Z --stdout)'{-Z,--stdout}'[write to stdout]' \
      '--gzip[compress with gzip]' \
      '--bzip2[compress with bzip2]' \
      '*:SRA accession or file:_files' \
      && ret=0
    ;;

  fasterq-dump)
    # Multi-threaded SRA → FASTQ converter.
    _arguments -s -S \
      $_common_kapp \
      '(-O --outdir)'{-O,--outdir}'=[output directory]:dir:_directories' \
      '(-o --outfile)'{-o,--outfile}'=[output file name (overrides --outdir)]:file:_files' \
      '(-t --temp)'{-t,--temp}'=[temporary directory]:dir:_directories' \
      '(-f --force)'{-f,--force}'[force overwrite existing files]' \
      '(-e --threads)'{-e,--threads}'=[number of threads (default 6)]:N:' \
      '(-b --bufsize)'{-b,--bufsize}'=[input buffer size (default 1MB)]:size:' \
      '(-c --curcache)'{-c,--curcache}'=[cursor cache size (default 10MB)]:size:' \
      '(-m --mem)'{-m,--mem}'=[memory limit (default 100MB)]:size:' \
      '--split-3[3-file split (default)]' \
      '--split-spot[split into single output file by spot]' \
      '--split-files[split into multiple files]' \
      '--concatenate-reads[do not split spots]' \
      '--fasta[FASTA output (sorted, default 80 chars/line)]' \
      '--fasta-unsorted[FASTA output unsorted]' \
      '--fasta-ref-tbl=[extract reference sequences from table]:table:' \
      '--seq-defline=[custom sequence defline format]:format:' \
      '--qual-defline=[custom quality defline format]:format:' \
      '(-Z --stdout)'{-Z,--stdout}'[write to stdout (limited split modes)]' \
      '(-p --progress)'{-p,--progress}'[show progress bar]' \
      '--ngc=[NGC credentials file]:file:_files' \
      '--size-check=[disk-space check]:mode:(on off only)' \
      '--disk-limit=[manually specify available disk space]:size:' \
      '--disk-limit-tmp=[temp directory disk space]:size:' \
      '--table=[use specific sequence table (PacBio)]:table:(SEQUENCE)' \
      '*:SRA accession or file:_files' \
      && ret=0
    ;;

  vdb-dump)
    # Dump VDB / SRA database contents in textual form.
    _arguments -s -S \
      $_common_kapp \
      '(-T --table)'{-T,--table}'=[table name to dump]:table:' \
      '(-C --columns)'{-C,--columns}'=[columns to dump (comma-separated)]:cols:' \
      '(-R --rows)'{-R,--rows}'=[row range (e.g. 1-10,20)]:rows:' \
      '(-N --numelem)'{-N,--numelem}'[print number of elements per column]' \
      '(-S --numelemsum)'{-S,--numelemsum}'[print sum of elements per column]' \
      '(-f --format)'{-f,--format}'=[output format]:format:(csv xml json piped tab fastq fastq1 fasta fasta1 fasta2 qual qual1 hidden tab1)' \
      '(-d --boolean)'{-d,--boolean}'=[boolean printing format]:format:(1 T)' \
      '(-o --outdir)'{-o,--outdir}'=[output directory (one file per column)]:dir:_directories' \
      '(-A --schema_dump)'{-A,--schema_dump}'[dump schema]' \
      '(-E --table_enum)'{-E,--table_enum}'[enumerate tables]' \
      '(-O --column_enum)'{-O,--column_enum}'[enumerate columns]' \
      '(-o --idx_enum)'{-o,--idx_enum}'[enumerate indices]' \
      '*:VDB accession or file:_files' \
      && ret=0
    ;;

  sam-dump)
    # Dump aligned SRA → SAM/BAM.
    _arguments -s -S \
      $_common_kapp \
      '(-u --unaligned)'{-u,--unaligned}'[output unaligned reads]' \
      '(-1 --primary)'{-1,--primary}'[output only primary alignments]' \
      '(-c --cigar-long)'{-c,--cigar-long}'[output long version CIGAR]' \
      '(-r --header)'{-r,--header}'=[add or remove header]:mode:(add no)' \
      '--header-file=[read header from file]:file:_files' \
      '--header-comment=[insert comment header lines]:text:' \
      '(-n --no-header)'{-n,--no-header}'[do not output header]' \
      '(-s --seqid)'{-s,--seqid}'[print SEQ_ID instead of REF_NAME]' \
      '(-=  --hide-identical)'{-=,--hide-identical}'[hide identical reads]' \
      '(-g --spot-group)'{-g,--spot-group}'[print spot group]' \
      '(-p --prefix)'{-p,--prefix}'=[prefix for spot names]:prefix:' \
      '--aligned-region=[chromosome region (chr:from-to)]:region:' \
      '(-q --mate-distance)'{-q,--mate-distance}'=[output mate distance only]:N:' \
      '(-R --rows)'{-R,--rows}'=[row range]:range:' \
      '(-N --start)'{-N,--start}'=[start row]:N:' \
      '(-X --end)'{-X,--end}'=[end row]:N:' \
      '--unaligned-spots-only[only output spots with no alignments]' \
      '*:SRA accession or file:_files' \
      && ret=0
    ;;

  sra-stat)
    # SRA dataset statistics.
    _arguments -s -S \
      $_common_kapp \
      '(-x --xml)'{-x,--xml}'[output XML]' \
      '(-r --start)'{-r,--start}'=[start row]:N:' \
      '(-N --rows)'{-N,--rows}'=[number of rows]:N:' \
      '(-s --statistics)'{-s,--statistics}'[print statistics summary]' \
      '(-d --member-stats)'{-d,--member-stats}'=[per-member stats]:N:' \
      '(-b --bases)'{-b,--bases}'[base content/quality stats]' \
      '(-m --meta)'{-m,--meta}'[dump metadata]' \
      '(-p --progress)'{-p,--progress}'[show progress]' \
      '*:SRA accession or file:_files' \
      && ret=0
    ;;

  vdb-validate)
    # Validate the structure of a VDB / SRA accession.
    _arguments -s -S \
      $_common_kapp \
      '(-Q --table)'{-Q,--table}'=[specific table to validate]:table:' \
      '(-x --exhaustive)'{-x,--exhaustive}'[exhaustive validation]' \
      '(-r --referential-integrity)'{-r,--referential-integrity}'[check referential integrity]' \
      '(-B --consist-check)'{-B,--consist-check}'[consistency check]' \
      '(-I --index)'{-I,--index}'[check indices]' \
      '(-C --md5-check)'{-C,--md5-check}'[verify MD5 checksum files]' \
      '*:VDB / SRA accession or file:_files' \
      && ret=0
    ;;

  vdb-config)
    # Configure the SRA toolkit (NCBI repository, cache, etc.).
    _arguments -s -S \
      $_common_kapp \
      '--cfg[dump current configuration]' \
      '(-a --all)'{-a,--all}'[print all configuration]' \
      '(-p --proxy)'{-p,--proxy}'=[set proxy URL]:url:' \
      '--proxy-disable=[disable proxy]:bool:(yes no)' \
      '--set=[set configuration key=value]:kv:' \
      '(-w --wd)'{-w,--wd}'[print working directory]' \
      '--restore-defaults[restore default configuration]' \
      '--root[run as root mode (server install)]' \
      '--cfg-dir[print configuration directory]' \
      '--fix-default[fix the user default configuration]' \
      '--cloud-provider=[set cloud provider]:provider:(aws gcp azure)' \
      '(-i --import-ngc)'{-i,--import-ngc}'=[import NGC file]:file:_files' \
      && ret=0
    ;;

  vdb-encrypt)
    # Encrypt VDB / SRA files (deprecated NGC-style).
    _arguments -s -S \
      $_common_kapp \
      '(-d --decrypt-bin)'{-d,--decrypt-bin}'[decrypt instead of encrypt]' \
      '(-f --force)'{-f,--force}'[overwrite output if it exists]' \
      '(-p --password)'{-p,--password}'=[password file]:file:_files' \
      '(-q --quiet)'{-q,--quiet}'[no output]' \
      '*:input file:_files' \
      && ret=0
    ;;

  vdb-decrypt)
    # Decrypt VDB / SRA files (deprecated NGC-style).
    _arguments -s -S \
      $_common_kapp \
      '(-f --force)'{-f,--force}'[overwrite output if it exists]' \
      '(-p --password)'{-p,--password}'=[password file]:file:_files' \
      '*:input file:_files' \
      && ret=0
    ;;

esac

return ret
