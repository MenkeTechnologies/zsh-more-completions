#compdef sstable2json
# Documentation: https://man.archlinux.org/search?q=sstable2json
# Reference accessed: 2026-05-16

# sstable2json: dump Cassandra SSTable as JSON (legacy)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-e[enumerate only - keys only]' \
  '-k[only specific key]:key:' \
  '-x[exclude specific key]:key:' \
  '-l[print one row per line]' \
  '-t[show tombstones]' \
  '*:sstable file:_files -g "*-Data.db"' && ret=0
return ret
