(( $+functions[_jetti_commands] )) ||
_jetti_commands() {
    local commands; commands=(
'clone:Clone a repository into the organized directory structure' \
'list:List cloned repositories' \
'ls:List cloned repositories' \
'root:Print the root directory path' \
'rm:Remove a cloned repository' \
'remove:Remove a cloned repository' \
'completions:Generate shell completions' \
'fetch:Fetch updates for all repositories' \
'update:Fetch and fast-forward all repositories' \
'status:Show status of all repositories (branch, dirty files, ahead/behind)' \
'st:Show status of all repositories (branch, dirty files, ahead/behind)' \
'config:View or manage configuration' \
'cfg:View or manage configuration' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'jetti commands' commands "$@"
}
