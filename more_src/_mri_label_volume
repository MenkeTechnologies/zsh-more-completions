#compdef mri_label_volume
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_label_volume
# Compute the volume of labels in a segmentation volume

local ret=1

_arguments -s -S \
  '-pv[compute partial volume effects using intensity volume]:fname:_files' \
  '-icv[normalize by the intracranial volume]:fname:_files' \
  '-s[output in spreadsheet mode with subject name]:subject:' \
  '-a[compute volume of all non-zero voxels]' \
  '-t[replace one label with another]:in:out:' \
  '-b[compute brain volume and normalize by it]:brainvol:' \
  '-p[compute volume as percentage of all non-zero labels]' \
  '-l[log results to file]:fname:_files' \
  '-atlas_icv[LTA/XFM atlas transform and scale factor]:fname:_files:scalefactor:' \
  '-eTIV[same as atlas_icv]:fname:_files:scalefactor:' \
  '-eTIV_matdat[eTIV plus generate MATLAB data]:fname:_files:scalefactor:subject:' \
  '*:volume:_files' && ret=0

return ret
