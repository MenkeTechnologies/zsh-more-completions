#compdef bedGraphToBigWig
# _bedGraphToBigWig — UCSC Kent Lab bedGraphToBigWig convert sorted bedGraph signal track to indexed bigWig binary format (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/bigWig.html

_bedGraphToBigWig() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-blockSize=+[block size]:n:' \
        '-itemsPerSlot=+[items per slot]:n:' \
        '-unc[do not compress]' \
        '*:in_bedgraph chrom_sizes out_bigwig:_files -g "*.bedgraph *.bdg *.bgr *.chrom.sizes *.txt *.bw *.bigwig"'
}

_bedGraphToBigWig "$@"
