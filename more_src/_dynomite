#compdef dynomite
# Documentation: https://man.archlinux.org/search?q=dynomite
# Reference accessed: 2026-05-16

# Zsh completion for dynomite
# Upstream: Generic dynamo implementation for different k-v storage engines
# Conservative fallback — run `dynomite --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
