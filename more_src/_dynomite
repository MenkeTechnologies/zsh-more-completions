#compdef dynomite
# Documentation: https://github.com/Netflix/dynomite
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Netflix/dynomite: generic dynamo implementation for different k-v storage engines
# Flags verified from project README usage section.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-t --test-conf)'{-t,--test-conf}'[test configuration syntax and exit]' \
  '(-g --gossip)'{-g,--gossip}'[enable gossip (disabled by default)]' \
  '(-d --daemonize)'{-d,--daemonize}'[run as a daemon]' \
  '(-D --describe-stats)'{-D,--describe-stats}'[print stats description and exit]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[logging level (0-11, default 5)]:level:' \
  '(-o --output)'{-o+,--output=}'[log file (default stderr)]:file:_files' \
  '(-c --conf-file)'{-c+,--conf-file=}'[configuration file (default conf/dynomite.yml)]:file:_files' \
  '(-p --pid-file)'{-p+,--pid-file=}'[pid file]:file:_files' \
  '(-x --admin-operation)'{-x+,--admin-operation=}'[admin operation size (default 0)]:n:'
