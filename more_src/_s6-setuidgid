#compdef s6-setuidgid
# Documentation: https://skarnet.org/software/s6/s6-setuidgid.html
# Reference accessed: 2026-05-30
# s6-setuidgid — switch to account's UID/GID/GIDLIST then exec a program. NO FLAGS upstream.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:account name:_users' \
  '*:program + args:_command_names -e' \
  && ret=0

return ret
