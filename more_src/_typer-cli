#compdef typer-cli
# _typer-cli — Sebastián Ramírez Typer Python CLI framework helper CLI alias (tiangolo, Python); typer
# upstream: https://github.com/tiangolo/typer

_typer-cli() {
    local -a sub=(
        'run:run a Typer-compatible script'
        'utils:utility commands'
        'docs:generate Markdown docs'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--app=+[app variable]:str:' \
        '--func=+[function name]:str:' \
        '--pretty-exceptions[pretty exceptions]' \
        '--no-pretty-exceptions[no pretty exceptions]' \
        '--rich-help[rich help]' \
        '--no-rich-help[no rich help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'typer subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments '*:script:_files -g "*.py"' ;;
                docs) _arguments \
                    '--name=+[name]:str:' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '*:script:_files -g "*.py"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                utils) _arguments \
                    '1:cmd:(docs run)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_typer-cli "$@"
