#compdef woodpecker-cli
# Documentation: https://woodpecker-ci.org/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# woodpecker-cli: alias name for the woodpecker CLI binary on some distros.
# Subcommand list verified against upstream cli docs (v3.x).
local curcontext="$curcontext" state line ret=1

local -a commands=(
  'admin:server administration'
  'context:context management'
  'ctx:alias for context'
  'exec:execute a local pipeline'
  'info:show current user info'
  'lint:lint a pipeline config file'
  'org:organization-level registries and secrets'
  'pipeline:manage pipelines'
  'repo:manage repositories'
  'setup:initial CLI configuration wizard'
  'update:update the CLI to the latest version'
  'help:show help for a command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  '--server=[server address]:URL:' \
  '--token=[server auth token]:token:' \
  '--config=[config file]:file:_files' \
  '--log-level=[log level]:level:(trace debug info warn error fatal panic disabled)' \
  '--log-file=[log file]:file:_files' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      pipeline)
        local -a pipeline_cmds=(
          'approve:approve a blocked pipeline'
          'decline:decline a blocked pipeline'
          'create:create a new pipeline'
          'start:start a pipeline'
          'stop:stop a pipeline'
          'deploy:trigger a deployment'
          'last:show last pipeline details'
          'ls:list pipelines'
          'log:manage pipeline logs'
          'ps:show pipeline steps'
          'queue:show pipeline queue'
          'show:show pipeline details'
        )
        _describe -t commands 'pipeline subcommand' pipeline_cmds && ret=0
        ;;
      repo)
        local -a repo_cmds=(
          'add:add a repository'
          'rm:remove a repository'
          'show:show repository info'
          'update:update a repository'
          'ls:list repositories'
          'sync:sync repositories'
          'repair:repair repository webhooks'
          'cron:manage repository cron jobs'
          'registry:manage repository registries'
          'secret:manage repository secrets'
        )
        _describe -t commands 'repo subcommand' repo_cmds && ret=0
        ;;
      org)
        local -a org_cmds=(
          'registry:manage org-level registries'
          'secret:manage org-level secrets'
        )
        _describe -t commands 'org subcommand' org_cmds && ret=0
        ;;
      admin)
        local -a admin_cmds=(
          'org:org administration'
          'registry:global registries'
          'secret:global secrets'
          'user:user administration'
        )
        _describe -t commands 'admin subcommand' admin_cmds && ret=0
        ;;
      exec)
        _arguments \
          '--local[run pipeline locally]' \
          '--backend=[execution backend]:backend:(auto-detect docker local kubernetes)' \
          '--timeout=[pipeline timeout]:duration:' \
          '--volumes=[volumes to mount]:volumes:' \
          '--network=[network to attach]:network:' \
          '--privileged[enable privileged mode]' \
          '*:pipeline config:_files -g "*.(yml|yaml)"' && ret=0
        ;;
      lint)
        _arguments '*:pipeline config:_files -g "*.(yml|yaml)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
