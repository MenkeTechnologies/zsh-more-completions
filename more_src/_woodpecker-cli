#compdef woodpecker-cli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:manage builds'
  'repo:manage repositories'
  'pipeline:manage pipelines'
  'log:manage build logs'
  'deploy:trigger a deployment'
  'exec:execute a local pipeline'
  'info:show information about the current user'
  'registry:manage registries'
  'secret:manage secrets'
  'user:manage users'
  'org:manage organizations'
  'cron:manage cron jobs'
  'log-level:get or set the logging level'
  'lint:lint a pipeline configuration file'
  'setup:setup a Woodpecker CI environment'
  'update:update the CLI to the latest version'
  'help:show help for a command'
)

_arguments -s -S \
  '--server=[server address]:URL' \
  '--token=[server auth token]:token' \
  '--grpc-addr=[gRPC address]:address' \
  '--grpc-secure[use TLS for gRPC connection]' \
  '--grpc-skip-insecure[skip TLS certificate verification]' \
  '--log-level=[set log level]:level:(trace debug info warn error fatal panic disabled)' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      build)
        local -a build_cmds=(
          'ls:show build list'
          'last:show last build details'
          'info:show build info'
          'stop:stop a build'
          'start:start a build'
          'approve:approve a build'
          'decline:decline a build'
          'queue:show build queue'
          'ps:show build steps'
          'create:create a new build'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'build subcommand' build_cmds && ret=0
        ;;
      repo)
        local -a repo_cmds=(
          'ls:list repositories'
          'info:show repository info'
          'add:add a repository'
          'update:update a repository'
          'rm:remove a repository'
          'sync:sync repositories'
          'chown:change repository ownership'
          'repair:repair a repository'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'repo subcommand' repo_cmds && ret=0
        ;;
      secret)
        local -a secret_cmds=(
          'ls:list secrets'
          'info:show secret info'
          'add:add a secret'
          'rm:remove a secret'
          'update:update a secret'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'secret subcommand' secret_cmds && ret=0
        ;;
      cron)
        local -a cron_cmds=(
          'ls:list cron jobs'
          'info:show cron job info'
          'add:add a cron job'
          'rm:remove a cron job'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'cron subcommand' cron_cmds && ret=0
        ;;
      exec)
        _arguments \
          '--local[run pipeline locally]' \
          '--backend=[execution backend]:backend:(auto-detect docker local)' \
          '--timeout=[pipeline timeout]:duration' \
          '--volumes=[volumes to mount]:volumes' \
          '--network=[network to attach]:network' \
          '--privileged=[enable privileged mode]' \
          '*:pipeline config:_files -g "*.yml"' && ret=0
        ;;
      lint)
        _arguments '*:pipeline config:_files -g "*.yml"' && ret=0
        ;;
      deploy)
        _arguments \
          '--branch=[branch to deploy]:branch' \
          '--event=[trigger event]:event:(push tag)' \
          '1:repo' \
          '2:build number' \
          '3:environment' && ret=0
        ;;
    esac
    ;;
esac

return ret
