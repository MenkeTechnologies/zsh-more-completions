#compdef ElmerGrid
# Documentation: https://www.elmerfem.org/blog/documentation/
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:input type:((
    1\:"Elmer mesh"
    2\:"ElmerSolver mesh"
    3\:"ElmerPost mesh"
    4\:"Ansys mesh"
    14\:"Gmsh mesh"
    15\:"Fidap mesh"
    17\:"Comsol mesh"
  ))' \
  '2:output type:((
    1\:"Elmer mesh"
    2\:"ElmerSolver mesh"
    3\:"ElmerPost mesh"
  ))' \
  '3:input file:_files' \
  '-in+[input file]:input file:_files' \
  '-out+[output file]:output file:_files' \
  '-merge+[merge factor]:factor:' \
  '-order+[element order]:order:(1 2)' \
  '-scale+[scale factors x y z]:factors:' \
  '-relh+[relative mesh density]:density:' \
  '-partition+[number of partitions in x y z]:partitions:' \
  '-partorder+[partition ordering]:ordering:' \
  '-metis+[METIS partitioning with n partitions]:partitions:' \
  '-halo[include halo elements in partitions]' \
  '-decimals+[number of output decimals]:decimals:' \
  '-triangles[split quads into triangles]' \
  '-unite[unite meshes]' && ret=0

return ret
