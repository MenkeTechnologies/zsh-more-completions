#compdef create-medical-document
# Documentation: https://www.npmjs.com/package/create-medical-document
# Reference accessed: 2026-05-23
# Verified: npm view create-medical-document bin; npm readme create and upgrade sections.

# Zsh completion for create-medical-document - medical document framework scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--name=[project name]:name:'   '--yes[skip interactive prompts]'   '--electron[generate Electron project]'   '--no-electron[generate pure Web project]'   '--target=[upgrade target directory]:directory:_directories'   '--output=[upgrade snapshot output directory]:directory:_directories'   '--force[overwrite upgrade output directory]'   '--include=[upgrade include paths; comma-separated]:paths:'   '--exclude=[upgrade exclude paths; comma-separated]:paths:'   '--filter-config=[custom upgrade filter JSON]:file:_files'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' upgrade && ret=0
    ;;
  args)
    case $line[1] in
      upgrade)
        _arguments -C           '--target=[target project directory]:directory:_directories'           '--output=[snapshot output directory]:directory:_directories'           '--force[overwrite output directory]'           '--include=[include paths]:paths:'           '--exclude=[exclude paths]:paths:'           '--filter-config=[filter config JSON]:file:_files' && ret=0
        ;;
      *)
        _arguments -C           '--name=[project name]:name:'           '--yes[skip prompts]'           '--electron[generate Electron project]'           '--no-electron[generate Web project]' && ret=0
        ;;
    esac
    ;;
esac

return ret
