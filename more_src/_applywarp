#compdef applywarp
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/fnirt/applywarp.html
# FSL: apply warps estimated by fnirt (or other) to images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --in)'{-i,--in=}'[filename of input image to be warped]:input:_files' \
  '(-r --ref)'{-r,--ref=}'[filename of reference image]:ref:_files' \
  '(-o --out)'{-o,--out=}'[filename of output image]:output:_files' \
  '(-w --warp)'{-w,--warp=}'[filename of warp/coefficient field]:warp:_files' \
  '(-m --mask)'{-m,--mask=}'[filename of mask image in reference space]:mask:_files' \
  '--premat=[filename of pre-warp affine transform]:premat:_files' \
  '--postmat=[filename of post-warp affine transform]:postmat:_files' \
  '--interp=[interpolation method]:interp:(nn trilinear sinc spline)' \
  '(-d --datatype)'{-d,--datatype=}'[force output data type]:type:(char short int float double)' \
  '--rel[treat warp field as relative displacements]' \
  '--abs[treat warp field as absolute coordinates]' \
  '-s[intermediary supersampling of output]' \
  '--super[intermediary supersampling of output]' \
  '--superlevel=[level of intermediary supersampling]:level:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:image:_files' && ret=0

return ret
