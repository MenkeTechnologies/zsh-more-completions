#compdef crowbook

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)--list-options[list all options]' \
  '(- *)'{-l,--list-options-md}'[list all options in Markdown]' \
  '-s+[set an option]:key_value' \
  '--set=[set an option]:key_value' \
  '-o+[set output file]:file:_files' \
  '--output=[set output file]:file:_files' \
  '--to=[output format]:format:(html epub latex odt pdf)' \
  '-c+[set a single chapter file]:file:_files' \
  '--create=[create a new book project]:file:_files -g "*.book"' \
  '-n[only parse and check syntax]' \
  '--no-fancy[disable fancy formatting]' \
  '-v[print verbose output]' \
  '--verbose[print verbose output]' \
  '-q[print only errors]' \
  '--quiet[print only errors]' \
  '--lang=[set language]:language' \
  '--autograph[open autograph page]' \
  '1:book file:_files -g "*.book"' && ret=0

return ret
