#compdef crowbook
# Documentation: https://github.com/crowdagger/crowbook
# Reference accessed: 2026-05-17
# Verified: upstream src/bin/helpers.rs (clap definitions).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --single)'{-s,--single}'[run on a single Markdown file with embedded options]' \
  '(-n --no-fancy)'{-n,--no-fancy}'[disable fancy output]' \
  '(-v --verbose -q --quiet)'{-v,--verbose}'[print verbose output]' \
  '(-q --quiet -v --verbose)'{-q,--quiet}'[print only errors]' \
  '(-a --autograph)'{-a,--autograph}'[ask for an autograph at start]' \
  '(-f --force-emoji)'{-f,--force-emoji}'[force emoji in output]' \
  '*'{-c+,--create=}'[create new book project from Markdown files]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output file (requires --to)]:file:_files' \
  '(-t --to)'{-t+,--to=}'[output format]:format:(epub pdf html tex odt html.dir)' \
  '*--set[set book options as key value pairs]:key value' \
  '(-l --list-options)'{-l,--list-options}'[list all available options]' \
  '--list-options-md[list all options in Markdown (hidden)]' \
  '(-L --lang)'{-L+,--lang=}'[set language]:lang:' \
  '--print-template=[print a built-in template]:template:' \
  '(-S --stats)'{-S,--stats}'[print book statistics]' \
  '1:book file:_files -g "*.book"' && ret=0

return ret
