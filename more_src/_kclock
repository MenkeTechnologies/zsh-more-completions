#compdef kclock kclockd
# Documentation: https://github.com/KDE/kclock/blob/master/README.md
# Reference accessed: 2026-05-16
# Verified: upstream KDE kclock README. kclock is the QML/Kirigami
# front-end (GUI-only); kclockd is the backend daemon with the only
# verified flag (--no-powerdevil).
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# kclock: KDE Plasma Mobile clock app (front-end + daemon)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--no-powerdevil[disable PowerDevil scheduleWakeup (kclockd only)]' && ret=0
return ret
