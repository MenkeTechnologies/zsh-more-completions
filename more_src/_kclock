#compdef kclock kclockd
# Documentation: https://github.com/KDE/kclock/blob/master/src/kclock/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (kclock/main.cpp and
# kclockd/main.cpp QCommandLineParser defs). kclock is the
# QML/Kirigami front-end; kclockd is the backend daemon.

# kclock: KDE Plasma Mobile clock app (front-end + daemon)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--desktopfile=[the base file name of the desktop entry]:file:_files' \
  '--page=[select opened page]:page:' \
  '--new-window[explicitly open a new Clock window]' \
  '--alarm-lockscreen-popup=[open alarm popup on lockscreen for alarm id]:alarm-id:' \
  '--timer-lockscreen-popup=[open timer popup on lockscreen for timer id]:timer-id:' \
  '--no-powerdevil[do not use PowerDevil for alarms (kclockd only)]' && ret=0
return ret
