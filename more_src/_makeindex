#compdef makeindex
# _makeindex — TeX Live makeindex (sort .idx into a .ind index file; -c compresses blank runs, -g uses German sort, -l letter ordering, -q quiet, -p starts page number at N, -r ignores implicit ranges, -s style file, -t/-o/-g rename log/out/sort style outputs)
# upstream: https://tug.org/svn/texlive (Build/source/texk/web2c/makeindexk)
# Flags from web2c makeindexk/mkind.c on tip.

_makeindex() {
    _arguments \
        '-c[compress consecutive blanks]' \
        '-g[German sort]' \
        '-i[read stdin]' \
        '-l[letter ordering]' \
        '-q[quiet]' \
        '-r[disable implicit range formation]' \
        '-L[locale-aware sorting]' \
        '-T[Thai sorting]' \
        '-p+[page start]:start:(any odd even N+1)' \
        '-s+[style file]:file:_files -g "*.ist"' \
        '-o+[output index file]:file:_files -g "*.ind"' \
        '-t+[log file]:file:_files -g "*.ilg"' \
        '*:idx file:_files -g "*.idx"'
}

_makeindex "$@"
