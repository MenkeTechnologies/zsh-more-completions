#compdef cognito-cli cognitoctl
# _cognito-cli — AWS cognito-cli CLI alternative ergonomic command-line frontend wrapping the Amazon Cognito User Pools and Identity Pools APIs managing users groups identity-providers app-clients SignIn-SignUp SAML OIDC custom-domains user-pool-mfa-totp-sms admin-set-user-password sign-up confirm respond-to-auth-challenge token-revoke (AWS team, Go); cobra
# upstream: https://aws.amazon.com/cognito/

_cognito-cli() {
    local -a sub=(
        'user-pool:user-pool management'
        'identity-pool:identity-pool management'
        'user:user management'
        'group:group management'
        'app-client:app client management'
        'idp:identity provider management'
        'domain:domain management'
        'sign-up:sign up new user'
        'confirm:confirm user'
        'sign-in:sign in user'
        'admin-set-password:admin set password'
        'admin-create-user:admin create user'
        'mfa:MFA configuration'
        'token:token operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--region=+[r]:_aws_regions' \
        '--profile=+[name]:str:' \
        '--user-pool-id=+[id]:str:' \
        '--identity-pool-id=+[id]:str:' \
        '--client-id=+[id]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--email=+[address]:str:' \
        '--access-token=+[token]:str:' \
        '--id-token=+[token]:str:' \
        '--refresh-token=+[token]:str:' \
        '-f+[format]:f:(json yaml table text)' \
        '--format=+[format]:f:(json yaml table text)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cognito-cli subcommand' sub ;;
        args)
            case $words[1] in
                user-pool|identity-pool|user|group|app-client|idp|domain) _arguments '1:op:(list get create update delete enable disable)' '*:id:' ;;
            esac
            ;;
    esac
}

_cognito-cli "$@"
