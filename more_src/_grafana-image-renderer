#compdef grafana-image-renderer
# Documentation: https://man.archlinux.org/search?q=grafana-image-renderer
# Reference accessed: 2026-05-16

# grafana-image-renderer: render plugin for Grafana panels
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'render:render a single image'
  'server:run as render server'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--url=[Grafana URL]:url:' \
  '--width=[image width]:n:' \
  '--height=[image height]:n:' \
  '--timezone=[render timezone]:tz:' \
  '--encoding=[image encoding]:enc:(png jpeg)' \
  '--filename=[output filename]:file:_files' \
  '--port=[server port]:port:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'grafana-image-renderer command' commands && ret=0 ;;
esac
return ret
