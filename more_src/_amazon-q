#compdef amazon-q
# _amazon-q — Amazon Web Services amazon-q AWS Q Developer generative-AI CLI fork of Fig (aws team, Rust); clap-derive
# upstream: https://github.com/aws/amazon-q-developer-cli

_amazon-q() {
    local -a sub=(
        'init:install Q shell integrations'
        'login:authenticate with AWS Builder ID or IAM'
        'logout:logout and clear credentials'
        'whoami:show current user'
        'doctor:run diagnostic checks'
        'settings:show or set settings'
        'theme:set theme'
        'translate:translate natural language to shell command'
        'chat:start chat session'
        'inline:open inline suggestion'
        'completions:auto-completion subcommands'
        'integrations:integration subcommands'
        'install:install Q'
        'uninstall:uninstall Q'
        'update:update Q'
        'restart:restart background services'
        'app:app subcommands'
        'devtools:devtools subcommands'
        'diagnostic:run full diagnostic'
        'feed:show what'\''s new'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amazon-q subcommand' sub ;;
        args)
            case $words[1] in
                chat) _arguments \
                    '--no-interactive[non-interactive mode]' \
                    '--accept-all[auto-accept]' \
                    '--profile=+[AWS profile]:str:' \
                    '--region=+[AWS region]:r:(us-east-1 us-west-2 eu-west-1 eu-central-1 ap-northeast-1)' \
                    '--trust-all-tools[trust all tools]' \
                    '--trust-tools=+[tools csv]:str:' \
                    '*:prompt:' ;;
                translate) _arguments '*:natural language:' ;;
                settings) _arguments '1:key:' '2:value:' ;;
                doctor|diagnostic) _arguments \
                    '--force[force]' \
                    '--strict[strict]' ;;
                completions) _arguments '1:shell:(bash zsh fish)' ;;
                integrations) _arguments '1:integration cmd:(install uninstall reinstall status)' ;;
            esac
            ;;
    esac
}

_amazon-q "$@"
