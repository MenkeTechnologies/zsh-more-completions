#compdef cgdisp
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/cgdisp.html
# MIRIAD: display and overlay images on a PGPLOT device

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[up to seven input images]:in:_files' \
  'type=[image type]:type:(contour pixel amplitude angle box mask)' \
  'region=[region of interest]:region:' \
  'xybin=[spatial increment and binning]:xybin:' \
  'chan=[channel increment and averaging]:chan:' \
  'slev=[contour level scale factor]:slev:' \
  'levs1=[contour levels image 1]:levs1:' \
  'levs2=[contour levels image 2]:levs2:' \
  'levs3=[contour levels image 3]:levs3:' \
  'cols1=[colours contour image 1]:cols1:' \
  'cols2=[colours contour image 2]:cols2:' \
  'cols3=[colours contour image 3]:cols3:' \
  'range=[intensity range and lookup table]:range:' \
  'vecfac=[vector scale factor and increments]:vecfac:' \
  'boxfac=[box scale factor and increments]:boxfac:' \
  'device=[PGPLOT device]:device:' \
  'nxy=[subplots in x and y]:nxy:' \
  'labtyp=[spatial label types]:labtyp:(hms dms arcsec arcmin absdeg reldeg abspix relpix abskms relkms absghz relghz absnat relnat)' \
  'beamtyp=[beam FWHM polygon display]:beamtyp:' \
  'options=[display customization options]:options:' \
  '3format=[third-axis label format]:3format:' \
  'lines=[line widths]:lines:' \
  'break=[solid/dashed contour transitions]:break:' \
  'csize=[character sizes]:csize:' \
  'scale=[plot scales per mm]:scale:' \
  'comment1=[comment line 1]:comment1:' \
  'comment2=[comment line 2]:comment2:' \
  'comment3=[comment line 3]:comment3:' \
  'comment4=[comment line 4]:comment4:' \
  'comment5=[comment line 5]:comment5:' \
  'olay=[overlay description file]:olay:_files' \
  '*:image:_files' && ret=0

return ret
