#compdef rmsdist gmx-rmsdist
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-rmsdist.html
# Calculate RMS deviation of atom distances without structural fitting

local ret=1

_arguments -s -S \
  '-f+[trajectory input]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-s+[structure file with mass data]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-n+[index file]:index file:_files -g "*.ndx"' \
  '-equiv+[generic data file for equivalent atoms]:dat file:_files -g "*.dat"' \
  '-o+[xvg output for distance RMSD]:xvg file:_files -g "*.xvg"' \
  '-rms+[matrix output of RMS distances]:xpm file:_files -g "*.xpm"' \
  '-scl+[matrix output of scaled RMS distances]:xpm file:_files -g "*.xpm"' \
  '-mean+[matrix output of mean distances]:xpm file:_files -g "*.xpm"' \
  '-nmr3+[matrix with 1/r^3 NMR averaging]:xpm file:_files -g "*.xpm"' \
  '-nmr6+[matrix with 1/r^6 NMR averaging]:xpm file:_files -g "*.xpm"' \
  '-noe+[NOE distance list output]:dat file:_files -g "*.dat"' \
  '-b+[first frame ps]:time:' \
  '-e+[last frame ps]:time:' \
  '-dt+[frame sampling interval ps]:time:' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-nlevels+[matrix discretization levels]:n:' \
  '-max+[maximum matrix level]:value:' \
  '-w[view output files]' \
  '-sumh[average over equivalent hydrogens]' \
  '-pbc[apply periodic boundary conditions]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
