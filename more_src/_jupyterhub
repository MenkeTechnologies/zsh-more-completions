#compdef jupyterhub
# Multi-user Jupyter notebook server

local ret=1

_arguments -s -S \
  '-f[specify config file]:config file:_files -g "*.py"' \
  '--generate-config[generate default config file]' \
  '--no-db[disable database]' \
  '--upgrade-db[upgrade the database schema]' \
  '--no-ssl[disable SSL]' \
  '--ssl-key=[SSL key file]:key file:_files' \
  '--ssl-cert=[SSL cert file]:cert file:_files' \
  '--url=[specify public URL]:url:' \
  '--bind_url=[specify bind URL]:url:' \
  '--port=[specify port]:port:' \
  '--ip=[specify IP address]:address:_hosts' \
  '--pid-file=[PID file location]:file:_files' \
  '--log-level=[set log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--debug[set log level to DEBUG]' \
  '-h[show help]' \
  '--help[show help]' \
  '--help-all[show all help]' \
  '--version[show version]' && ret=0

return ret
