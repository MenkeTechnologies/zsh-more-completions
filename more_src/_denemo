#compdef denemo
# Documentation: https://man.archlinux.org/search?q=denemo
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-A --audio-options)'{-A,--audio-options}'+[audio backend options]:opts:' \
  '(-M --midi-options)'{-M,--midi-options}'+[MIDI backend options]:opts:' \
  '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive (Scheme script)]' \
  '(-i --script)'{-i,--script}'+[run a Scheme script]:file:_files -g "*.scm"' \
  '(-e --eval)'{-e,--eval}'+[evaluate Scheme expression]:expr:' \
  '(-N --new)'{-N,--new}'[start with empty document]' \
  '(-a --autosave)'{-a,--autosave}'[run autosave]' \
  '(-d --display)'{-d,--display}'+[X display]:display:' \
  '*:file:_files -g "*.{denemo,mxml,xml,abc,mid,midi,ly,mma}"' && ret=0

return ret
