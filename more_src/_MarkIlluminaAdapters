#compdef MarkIlluminaAdapters
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#MarkIlluminaAdapters
# Picard: mark Illumina adapter sequences in a SAM/BAM, writing XT tags

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output file (omit to generate metrics only)]:bam:_files -g "*.(bam|sam)"' \
  {-M=,--METRICS=}'[histogram of bases clipped per read count]:file:_files' \
  '--MIN_MATCH_BASES_SE=[minimum bases to match when clipping single-end reads]:int:' \
  '--MIN_MATCH_BASES_PE=[minimum bases to match per-read when clipping paired-end reads]:int:' \
  '--MAX_ERROR_RATE_SE=[max mismatch error rate for single-end clipping]:float:' \
  '--MAX_ERROR_RATE_PE=[max mismatch error rate for paired-end clipping]:float:' \
  '--FIVE_PRIME_ADAPTER=[non-standard 5-prime adapter sequence]:seq:' \
  '--THREE_PRIME_ADAPTER=[non-standard 3-prime adapter sequence]:seq:' \
  '*--ADAPTERS=[which adapter sequences to identify and clip]:adapter:(PAIRED_END INDEXED SINGLE_END NEXTERA_V1 NEXTERA_V2 DUAL_INDEXED FLUIDIGM TRUSEQ_SMALLRNA ALTERNATIVE_SINGLE_END)' \
  '--ADAPTER_TRUNCATION_LENGTH=[truncate adapters to this length to speed matching]:int:' \
  {-APT=,--PRUNE_ADAPTER_LIST_AFTER_THIS_MANY_ADAPTERS_SEEN=}'[prune adapter list threshold (-1 for heterogeneous mixes)]:int:' \
  '--NUM_ADAPTERS_TO_KEEP=[number of adapter sequences to keep when pruning]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
