#compdef hubble-relay
# Documentation: https://man.archlinux.org/search?q=hubble-relay
# Reference accessed: 2026-05-16

# hubble-relay: aggregates Hubble flows from multiple Cilium nodes
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'serve:run the Hubble Relay server'
  'completion:emit shell completion'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file]:file:_files' \
  '--debug[debug logging]' \
  '--listen-address=[gRPC listen addr]:addr:' \
  '--metrics-listen-address=[metrics addr]:addr:' \
  '--peer-service=[Hubble peer gRPC service]:host:port:' \
  '--dial-timeout=[peer dial timeout]:duration:' \
  '--retry-timeout=[peer retry timeout]:duration:' \
  '--sort-buffer-len-max=[sort buffer max len]:n:' \
  '--sort-buffer-drain-timeout=[sort buffer drain timeout]:duration:' \
  '--tls-disabled[disable TLS]' \
  '--tls-server-cert=[TLS server cert]:file:_files' \
  '--tls-server-key=[TLS server key]:file:_files' \
  '--tls-client-ca-files=[TLS client CA]:files:_files' \
  '--tls-client-cert=[TLS client cert]:file:_files' \
  '--tls-client-key=[TLS client key]:file:_files' \
  '--tls-client-disabled[disable upstream TLS]' \
  '--gops[enable gops]' \
  '--gops-port=[gops port]:port:' \
  '--pprof[enable pprof]' \
  '--pprof-address=[pprof addr]:addr:' \
  '--pprof-port=[pprof port]:port:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'hubble-relay command' commands && ret=0 ;;
esac
return ret
