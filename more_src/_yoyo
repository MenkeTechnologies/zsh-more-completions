#compdef yoyo
# Documentation: https://ollycope.com/software/yoyo/latest/
# yoyo-migrations database migration command-line tool

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --database)'{-d,--database}'=[database connection URL]:url' \
  '--config=[specify configuration file]:file:_files' \
  '--no-config-file[skip loading configuration file]' \
  '(-p --prompt-password)'{-p,--prompt-password}'[prompt for database password]' \
  '--verbosity=[verbosity level 0-3]:level:(0 1 2 3)' \
  '1:command:(new list apply rollback reapply develop mark unmark init break-lock)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      new)
        _arguments -s \
          '-m[migration description]:desc' \
          '--sql[create SQL format migration]' && ret=0
        ;;
      apply)
        _arguments -s \
          '--batch[skip prompts and apply all unapplied migrations]' \
          '(-r --revision)'{-r,--revision}'[apply specific migration and dependencies]:revision' && ret=0
        ;;
      rollback)
        _arguments -s \
          '--batch[skip prompts]' \
          '--all[rollback all applied migrations]' \
          '(-r --revision)'{-r,--revision}'[rollback specific migration]:revision' && ret=0
        ;;
      reapply|develop)
        _arguments -s \
          '-n[operate on n most recently applied migrations]:n' \
          '(-r --revision)'{-r,--revision}'[target specific migration]:revision' && ret=0
        ;;
    esac
    ;;
esac

return ret
