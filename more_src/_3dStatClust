#compdef 3dStatClust
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dStatClust.html
# AFNI agglomerative hierarchical clustering of thresholded voxels

local ret=1

_arguments -s -S \
  '(-prefix -output)'{-prefix,-output}'[output dataset prefix name]:prefix:' \
  '-session[directory for output dataset]:dir:_files -/' \
  '-verb[verbose output during execution]' \
  '(-dist_euc -dist_ind -dist_cor)-dist_euc[Euclidean distance between parameters]' \
  '(-dist_euc -dist_ind -dist_cor)-dist_ind[statistical distance for independent parameters]' \
  '(-dist_euc -dist_ind -dist_cor)-dist_cor[statistical distance for correlated parameters]' \
  '-thresh[threshold statistic file; voxels above t]:t:' \
  '-nclust[maximum number of output clusters]:n:' \
  '*:dataset:_files' && ret=0

return ret
