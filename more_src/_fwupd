#compdef fwupdmgr

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--version[show version]' \
  {-v,--verbose}'[show extra debugging information]' \
  '--offline[schedule installation for next reboot]' \
  '--allow-reinstall[allow reinstalling existing firmware]' \
  '--allow-older[allow downgrading firmware versions]' \
  '--force[force operation]' \
  '--show-all[show all results including non-updatable devices]' \
  '--no-reboot-check[do not check for reboot after update]' \
  '--no-safety-check[do not perform safety checks]' \
  '--disable-ssl-strict[disable strict SSL certificate checking]' \
  '--json[output in JSON format]' \
  {-y,--assume-yes}'[answer yes to all questions]' \
  '1:command:->commands' \
  '*::arguments:->args' \
  && ret=0

case $state in
  commands)
    local -a commands=(
      'activate:activate firmware update on device'
      'clear-history:clear firmware update history'
      'clear-offline:clear any scheduled offline updates'
      'disable-remote:disable a remote'
      'downgrade:downgrade firmware on device'
      'enable-remote:enable a remote'
      'get-approved-firmware:get list of approved firmware'
      'get-blocked-firmware:get list of blocked firmware'
      'get-details:get details about a firmware file'
      'get-devices:get all devices that support firmware updates'
      'get-history:show firmware update history'
      'get-plugins:get all enabled plugins'
      'get-releases:get releases for a device'
      'get-remotes:get configured remote sources'
      'get-results:get results of last update'
      'get-topology:get device topology'
      'get-updates:get available updates'
      'get-upgrades:get available upgrades'
      'install:install a firmware file'
      'modify-config:modify daemon configuration'
      'modify-remote:modify a remote'
      'refresh:refresh metadata from remote'
      'reinstall:reinstall current firmware'
      'report-history:report firmware history to server'
      'security:show host security attributes'
      'set-approved-firmware:set list of approved firmware'
      'switch-branch:switch firmware branch on device'
      'unlock:unlock a device'
      'update:update all devices with available updates'
      'upgrade:upgrade firmware on device'
      'verify:verify firmware on device'
      'verify-update:update device verification metadata'
    )
    _describe -t commands 'fwupdmgr command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      install|get-details)
        _arguments '1:firmware file:_files' && ret=0
        ;;
      enable-remote|disable-remote|modify-remote)
        _arguments '1:remote id' && ret=0
        ;;
    esac
    ;;
esac

return ret
