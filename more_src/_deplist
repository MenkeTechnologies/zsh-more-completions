#compdef deplist
# Documentation: https://github.com/cespare/deplist
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: https://github.com/zchee/zsh-completions (src/go/_deplist), BSD-3-Clause

# github.com/cespare/deplist — list external dependencies of a Go package
#
# Usage:
#     deplist [flags] [pkg]
# where pkg is the name of a Go package (e.g., github.com/cespare/deplist). If no
# package name is given, the current directory is used.
#
# Flags:
#   -std  Include standard library dependencies
#   -t    Include test dependencies

function _deplist() {
  local context curcontext=$curcontext state line ret=1
  declare -A opt_args

  _go_packages() {
    local -a gopaths
    gopaths=("${(s/:/)$(go env GOPATH)}")
    for p in $gopaths; do
      _alternative ':packages:_path_files -W "$p/src" -/'
    done
  }

  _arguments -C \
    '-std[include standard library dependencies]' \
    '-t[include test dependencies]' \
    '-h[show usage]' \
    '1: :_go_packages' \
    && ret=0

  return ret
}

_deplist "$*"
