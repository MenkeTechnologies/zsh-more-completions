#compdef gtestEventLoop
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/contrib/test/gtestEventLoop.cxx
# gtestEventLoop - GENIE example/test event loop application

local ret=1

_arguments -s -S \
  '-f[input filename containing the GENIE event sample]:file:_files' \
  '-n[number of events to analyze (default all)]:nevents:' \
  '*: :_files' && ret=0

return ret
