#compdef wazuh-logtest
# Documentation: https://man.archlinux.org/search?q=wazuh-logtest
# Reference accessed: 2026-05-16

# Wazuh logtest: interactive rules/decoders test tool (logtest_clients API)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-q[quiet]' \
  '-v[verbose]' \
  '-a[manager API host]:host:_hosts' \
  '-d[debug]' \
  '-u[user]:user:_users' \
  '-p[password]:pass:' \
  '-l[log file with sample]:file:_files' \
  '*::wazuh-logtest args:_files' && ret=0
return ret
