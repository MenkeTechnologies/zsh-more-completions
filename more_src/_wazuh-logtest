#compdef wazuh-logtest
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/tools/wazuh-logtest.html
# Reference accessed: 2026-05-17
# Verified: Wazuh wazuh-logtest reference docs.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -a/-u/-p flags (no manager API/auth flags on this tool —
# it talks to a local UNIX socket, not the API); -l takes location
# string, not a file.

# wazuh-logtest: test decoders/rules sandboxed via wazuh-analysisd
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version/license]' \
  '-q[quiet]' \
  '-v[verbose]' \
  '-d[debug output]' \
  '-U[assertion mode rule-id:alert-level:decoder-name]:spec:' \
  '-l[custom log-location string]:location:' && ret=0
return ret
