#compdef trurl

# Zsh completion for trurl (URL manipulation tool from curl project)

_arguments -s -S \
  '-h[Show help]' \
  '--help[Show help]' \
  '-v[Show version]' \
  '--version[Show version]' \
  '*--url=[Set URL to work with]:url:_urls' \
  '--set=[Set a URL component]:component (scheme\:// host port path query fragment user password zoneid):' \
  '*--append=[Append to a query string]:query=value:' \
  '--redirect=[Redirect to this URL]:url:_urls' \
  '--get=[Output URL component(s)]:format string ({url} {scheme} {host} {port} {path} {query} {fragment} {user} {password}):' \
  '--json[Output URL as JSON]' \
  '--urlencode[Output URL-encoded]' \
  '--default-port[Use default port for scheme]' \
  '--punycode[Use punycode for internationalized hostnames]' \
  '--as-idn[Display internationalized hostnames as IDN]' \
  '--no-guess-scheme[Do not guess URL scheme]' \
  '--sort-query[Sort query string parameters]' \
  '--trim=[Trim URL query parameters matching pattern]:glob pattern:' \
  '--qtrim=[Trim a specific query parameter]:query parameter:' \
  '--query-separator=[Set query separator character]:separator:' \
  '--accept-space[Accept spaces in URLs]' \
  '--force-replace[Replace URL even if parsing fails]' \
  '--iterate=[Iterate over given URL list file]:file:_files' \
  '--replace=[Replace a query key=value pair]:key=value:' \
  '--remove=[Remove a query key]:key:' \
  '*:url:_urls' && return 0
