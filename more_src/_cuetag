#compdef cuetag cuetag.sh
# Documentation: https://man.archlinux.org/search?q=cuetag
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '1:cue_file:_files -g "*.cue"' \
  '*:audio_file:_files -g "*.{flac,ogg,mp3,wav,m4a}"' && ret=0

return ret
