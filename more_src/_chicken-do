#compdef chicken-do
# Documentation: https://manpages.debian.org/testing/chicken-bin/chicken-do.1.en.html
# CHICKEN run a command only if targets are out of date relative to dependencies

local ret=1

_arguments -s -S \
  '(-h)-h[show usage and exit]' \
  '(-q)-q[quiet operation - do not print shell commands when executed]' \
  '--[treat all following tokens as target filenames]' \
  '*:target/dependency/command:_files' && ret=0

return ret
