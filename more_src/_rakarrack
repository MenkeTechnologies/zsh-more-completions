#compdef rakarrack
# Documentation: https://man.archlinux.org/search?q=rakarrack
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-p --preset)'{-p,--preset}'+[load preset]:file:_files' \
  '(-s --slim)'{-s,--slim}'[slim mode]' \
  '(-S --noseq)'{-S,--noseq}'[no sequencer]' \
  '(-n --noxml)'{-n,--noxml}'[no xml]' \
  '(-c --client)'{-c,--client}'+[JACK client name]:name:' && ret=0

return ret
