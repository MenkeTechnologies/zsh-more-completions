#compdef llama-bench
# Documentation: https://github.com/ggerganov/llama.cpp/blob/master/tools/llama-bench/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-m --model)'{-m,--model=}'[model path]:model file:_files -g "*.gguf"' \
  '(-p --n-prompt)'{-p,--n-prompt=}'[number of prompt tokens]:count:' \
  '(-n --n-gen)'{-n,--n-gen=}'[number of generation tokens]:count:' \
  '-pg+[prompt processing + text generation pp,tg]:pp,tg:' \
  '(-d --n-depth)'{-d,--n-depth=}'[context depth]:n:' \
  '(-b --batch-size)'{-b,--batch-size=}'[batch size]:size:' \
  '(-ub --ubatch-size)'{-ub,--ubatch-size=}'[micro batch size]:size:' \
  '(-ctk --cache-type-k)'{-ctk,--cache-type-k=}'[KV cache type for keys]:type:(f16 f32 q4_0 q4_1 q5_0 q5_1 q8_0)' \
  '(-ctv --cache-type-v)'{-ctv,--cache-type-v=}'[KV cache type for values]:type:(f16 f32 q4_0 q4_1 q5_0 q5_1 q8_0)' \
  '(-t --threads)'{-t,--threads=}'[number of threads]:threads:' \
  '(-ngl --n-gpu-layers)'{-ngl,--n-gpu-layers=}'[number of GPU layers]:layers:' \
  '(-ncmoe --n-cpu-moe)'{-ncmoe,--n-cpu-moe=}'[CPU MoE layers]:n:' \
  '(-sm --split-mode)'{-sm,--split-mode=}'[tensor split mode]:mode:(none layer row)' \
  '(-mg --main-gpu)'{-mg,--main-gpu=}'[main GPU index]:index:' \
  '(-nkvo --no-kv-offload)'{-nkvo,--no-kv-offload=}'[disable KV offload]:flag:(0 1)' \
  '(-fa --flash-attn)'{-fa,--flash-attn=}'[flash attention]:flag:(0 1)' \
  '(-dev --device)'{-dev,--device=}'[device selection]:dev:' \
  '(-mmp --mmap)'{-mmp,--mmap=}'[memory mapping]:flag:(0 1)' \
  '(-embd --embeddings)'{-embd,--embeddings=}'[embeddings mode]:flag:(0 1)' \
  '(-ts --tensor-split)'{-ts,--tensor-split=}'[tensor split ratios]:split:' \
  '(-ot --override-tensors)'{-ot,--override-tensors=}'[override tensors pattern=type]:pattern:' \
  '(-nopo --no-op-offload)'{-nopo,--no-op-offload=}'[disable op offload]:flag:(0 1)' \
  '(-fitt --fit-target)'{-fitt,--fit-target=}'[fit model to device memory MiB]:mib:' \
  '(-fitc --fit-ctx)'{-fitc,--fit-ctx=}'[minimum context for fit-target]:n:' \
  '--numa=[NUMA optimization]:mode:(distribute isolate numactl)' \
  '--prio=[process/thread priority]:level:(0 1 2 3)' \
  '--delay=[delay between tests in seconds]:seconds:' \
  '(-r --repetitions)'{-r,--repetitions=}'[number of repetitions]:count:' \
  '(-o --output)'{-o,--output=}'[output format]:format:(csv json jsonl md sql)' \
  '(-oe --output-err)'{-oe,--output-err=}'[error output format]:format:(csv json jsonl md sql none)' \
  '--list-devices[list available devices and exit]' \
  '(-rpc --rpc)'{-rpc,--rpc=}'[register RPC devices (comma-separated)]:servers:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--progress[show progress]' && ret=0

return ret
