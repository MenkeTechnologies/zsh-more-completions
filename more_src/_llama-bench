#compdef llama-bench

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-m+[model path]:model file:_files -g "*.gguf"' \
  '--model=[model path]:model file:_files -g "*.gguf"' \
  '-p+[number of prompt tokens]:count' \
  '--n-prompt=[number of prompt tokens]:count' \
  '-n+[number of generation tokens]:count' \
  '--n-gen=[number of generation tokens]:count' \
  '-b+[batch size]:size' \
  '--batch-size=[batch size]:size' \
  '-ub+[micro batch size]:size' \
  '--ubatch-size=[micro batch size]:size' \
  '-ctk=[KV cache type for keys]:type:(f16 f32 q4_0 q4_1 q5_0 q5_1 q8_0)' \
  '-ctv=[KV cache type for values]:type:(f16 f32 q4_0 q4_1 q5_0 q5_1 q8_0)' \
  '-t+[number of threads]:threads' \
  '--threads=[number of threads]:threads' \
  '-ngl+[number of GPU layers]:layers' \
  '--gpu-layers=[number of GPU layers]:layers' \
  '--split-mode=[tensor split mode]:mode:(none layer row)' \
  '--main-gpu=[main GPU]:GPU index' \
  '--no-mmap[do not memory-map model]' \
  '--mlock[force system to keep model in RAM]' \
  '--numa=[NUMA optimization]:mode:(disabled distribute isolate numactl)' \
  '-fa[enable flash attention]' \
  '--flash-attn[enable flash attention]' \
  '-r+[number of repetitions]:count' \
  '--repetitions=[number of repetitions]:count' \
  '-o+[output format]:format:(csv json md sql)' \
  '--output=[output format]:format:(csv json md sql)' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '--progress[show progress]' && ret=0

return ret
