#compdef riscv64-linux-ar riscv64-linux-gnu-ar riscv64-unknown-linux-gnu-ar riscv64-unknown-elf-ar
# _riscv64-linux-ar — GNU binutils riscv64-linux-ar CLI cross-arch archive utility creating modifying extracting from static library archives .a for RV64GC RV64GCV Linux build environments adding deleting member object files in archive listing thin-archive S indexing for fast symbol lookup (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_riscv64-linux-ar() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--target=+[bfd]:str:' \
        '--plugin=+[plugin]:file:_files -g "*.so *.dylib"' \
        '*:archive and members:_files -g "*.a *.o"'
}

_riscv64-linux-ar "$@"
