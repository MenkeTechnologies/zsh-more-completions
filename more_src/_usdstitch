#compdef usdstitch
# Documentation: https://openusd.org/release/toolset.html
# Aggregates multiple USD files into a single file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --out)'{-o,--out}'[specify output file path]:output:_files' \
  '*:USD file:_files' && ret=0

return ret
