#compdef boundary-worker
# Documentation: https://man.archlinux.org/search?q=boundary-worker
# Reference accessed: 2026-05-16

_arguments -s \
  '*-config=[HCL config file]:file:_files' \
  '*-config-kms=[HCL config with kms block]:file:_files' \
  '-debug[enable runtime tracing]' \
  '-log-format=[log format]:format:(standard json)' \
  '-log-level=[log level]:level:(trace debug info warn err)' \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '(- *)-version[show version]'
