#compdef keymgr

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file (knot.conf)]:file:_files -g "*.conf"' \
  '(-C --confdb)'{-C+,--confdb=}'[binary config DB directory]:dir:_files -/' \
  '(-D --dir)'{-D+,--dir=}'[KASP DB directory (no server config)]:dir:_files -/' \
  '(-t --tsig)'{-t+,--tsig=}'[generate TSIG key (name [alg [bits]])]:tsig:' \
  '(-l --list)'{-l,--list}'[list keys]' \
  '(-x --mono)'{-x,--mono}'[monochrome output]' \
  '(-X --color)'{-X,--color}'[force color output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

local -a top_cmds=(
  'init:initialize a new KASP database (idempotent)'
  'list-zones:list zones in the database'
  'list-keys:list keys in a zone'
  'list-policies:list policies'
  'list-keystores:list keystores'
  'generate:generate a new DNSSEC key'
  'import-bind:import a BIND-style key'
  'import-pem:import a key from a PEM file'
  'import-pkcs11:import a key from a PKCS#11 store'
  'import-pub:import only a public DNSKEY'
  'pregenerate:pre-generate signing keys for a period'
  'set:change timing or ksk/zsk on an existing key'
  'ds:print DS record for a key'
  'dnskey:print DNSKEY record for a key'
  'delete:delete a key'
  'share:share a key between zones'
  'cds:print CDS/CDNSKEY records'
  'generate-ksr:generate a Key Signing Request (KSR)'
  'sign-ksr:sign a KSR producing an SKR'
  'import-skr:import a Signed Key Response'
  'help:show help for a subcommand'
)

case $state in
  (cmd) _describe -t cmds 'keymgr command' top_cmds && ret=0 ;;
  (args)
    case $line[1] in
      (generate|set|import-pem|import-pkcs11)
        _arguments \
          '*::param:(algorithm size ksk zsk created publish ready active retire remove)' && ret=0 ;;
      (import-bind|import-pem|import-pub)
        _arguments '*::file:_files' && ret=0 ;;
    esac ;;
esac

return ret
