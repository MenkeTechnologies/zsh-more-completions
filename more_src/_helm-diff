#compdef helm-diff

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'upgrade:show diff for a helm upgrade'
  'rollback:show diff for a helm rollback'
  'revision:show diff between revisions'
  'release:show diff between releases'
  'version:show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'helm-diff command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      upgrade)
        _arguments -s -S \
          '--allow-unreleased[enables diffing of releases that are not yet deployed]' \
          '-C+[number of context lines]:lines' \
          '--context=[number of context lines]:lines' \
          '--color[force color output]' \
          '--no-color[disable color output]' \
          '--detailed-exitcode[return non-zero exit code on diff]' \
          '--devel[use development versions]' \
          '--disable-openapi-validation[disable OpenAPI validation]' \
          '--disable-validation[disable validation]' \
          '--dry-run[show diff without applying]' \
          '-f+[values file]:values file:_files -g "*.yaml"' \
          '--values=[values file]:values file:_files -g "*.yaml"' \
          '--install[install release if not present]' \
          '--normalize-manifests[normalize manifests before diff]' \
          '--output=[output format]:format:(diff simple template)' \
          '--post-renderer=[path to post renderer]:renderer:_files' \
          '--repo=[chart repository URL]:URL' \
          '--reset-values[reset values to defaults]' \
          '--reuse-values[reuse previous values]' \
          '--set=[set values on command line]:key=value' \
          '--set-file=[set values from file]:key=file' \
          '--set-string=[set string values]:key=value' \
          '--strip-trailing-cr[strip trailing CR]' \
          '--suppress=[suppress kinds]:kind' \
          '--three-way-merge[show three-way merge diff]' \
          '--version=[chart version]:version' \
          '1:release name:' \
          '2:chart:' && ret=0
        ;;
      revision)
        _arguments -s -S \
          '-C+[number of context lines]:lines' \
          '--context=[number of context lines]:lines' \
          '--color[force color output]' \
          '--no-color[disable color output]' \
          '--suppress=[suppress kinds]:kind' \
          '1:release name:' \
          '2:revision1:' \
          '3:revision2:' && ret=0
        ;;
      rollback)
        _arguments -s -S \
          '-C+[number of context lines]:lines' \
          '--context=[number of context lines]:lines' \
          '--color[force color output]' \
          '--no-color[disable color output]' \
          '1:release name:' \
          '2:revision:' && ret=0
        ;;
    esac
    ;;
esac

return ret
