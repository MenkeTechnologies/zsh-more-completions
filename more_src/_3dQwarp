#compdef 3dQwarp
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dQwarp.html
# AFNI nonlinear (warp) registration of one dataset to a base

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-base[base dataset]:dataset:_files' \
  '-source[source dataset]:dataset:_files' \
  '-prefix[output dataset prefix]:prefix' \
  '-nowarp[skip saving the _WARP file]' \
  '-iwarp[compute and save the inverse warp]' \
  '-nodset[do not save the warped source dataset]' \
  '-awarp[output nonlinear warp from affine alignment]' \
  '-inwarp[write index warp dataset (debugging)]' \
  '(-allineate -allin)'{-allineate,-allin}'[run 3dAllineate first for affine alignment]' \
  '-allinfast[use faster one-pass 3dAllineate]' \
  '(-allineate_opts -allopt)'{-allineate_opts,-allopt}'[extra 3dAllineate options]:opts' \
  '-resample[resample source to match base grid]' \
  '-aniso[anisotropic smoothing before alignment]' \
  '-pcl[clipped Pearson correlation (default)]' \
  '-pear[strict Pearson correlation]' \
  '-hel[Hellinger metric]' \
  '-mi[mutual information]' \
  '-nmi[normalized mutual information]' \
  '-lpc[local Pearson correlation (signed)]' \
  '-lpa[local Pearson correlation (absolute)]' \
  '-noneg[replace negative values with zero]' \
  '-nopenalty[disable penalty on cost functional]' \
  '-penfac[weight the penalty term]:fac' \
  '-warpscale[adjust warp displacement scale by patch]:scale' \
  '-useweight[weight voxels by base image intensity]' \
  '-wtgaus[Gaussian smoothing for weight volume]:val' \
  '-noweight[use binary equal weighting]' \
  '-weight[input custom weight volume]:dataset:_files' \
  '-wball[enhance weight in brain region]:spec' \
  '-wmask[dataset to specify weight enhancement]:dataset:_files' \
  '-wtprefix[save auto-computed weight volume]:prefix' \
  '-emask[exclude voxels from alignment]:dataset:_files' \
  '-blur[Gaussian blur input images FWHM in voxels]:fwhm' \
  '-pblur[progressive blurring by patch size]' \
  '-nopblur[disable progressive blurring]' \
  '-noXdis[no displacement in X direction]' \
  '-noYdis[no displacement in Y direction]' \
  '-noZdis[no displacement in Z direction]' \
  '-iniwarp[initial nonlinear warp dataset]:dataset:_files' \
  '-inilev[initial refinement level]:lev' \
  '(-minpatch -patchmin)'{-minpatch,-patchmin}'[minimum patch size]:size' \
  '-maxlev[maximum refinement level]:lev' \
  '-gridlist[custom patch grid sizes]:file:_files' \
  '(-allsave -saveall)'{-allsave,-saveall}'[save warps from each level]' \
  '-workhard[iterate more for better alignment]' \
  '-superhard[iterate even more (very slow)]' \
  '-Qfinal[quintic polynomials at finest patch level]' \
  '-lite[12-param cubics and 30-param quintics (default)]' \
  '-nolite[use full tensor product polynomials]' \
  '-nopad[disable zero-padding]' \
  '-plusminus[match base and source halfway]' \
  '-pmNAMES[change PLUS/MINUS prefix labels]:names' \
  '-pmBASE[output source-to-base warp from plusminus]' \
  '-verb[print verbose progress messages]' \
  '-quiet[minimize progress messages]' \
  '*:dataset:_files' && ret=0

return ret
