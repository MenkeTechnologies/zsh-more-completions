#compdef eu-objdump
# _eu-objdump-bin — elfutils objdump (Ulrich Drepper, Red Hat); display binary file information
# upstream: https://sourceware.org/elfutils

_eu-objdump-bin() {
    _arguments \
        '(-d --disassemble)'{-d,--disassemble}'[disassemble]' \
        '(-f --file-header)'{-f,--file-header}'[file header]' \
        '(-r --reloc)'{-r,--reloc}'[show relocations]' \
        '(-s --full-contents)'{-s,--full-contents}'[full section contents]' \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '*:file:_files'
}

_eu-objdump-bin "$@"
