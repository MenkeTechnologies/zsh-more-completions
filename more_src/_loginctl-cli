#compdef loginctl-cli
# _loginctl-cli — systemd loginctl control the systemd login manager CLI alias (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_loginctl-cli() {
    local -a sub=(
        'list-sessions:list sessions'
        'session-status:show session status'
        'show-session:show session properties'
        'activate:activate session'
        'lock-session:lock session'
        'unlock-session:unlock session'
        'lock-sessions:lock all sessions'
        'unlock-sessions:unlock all sessions'
        'terminate-session:terminate session'
        'kill-session:kill session'
        'list-users:list users'
        'user-status:show user status'
        'show-user:show user properties'
        'enable-linger:enable user linger'
        'disable-linger:disable user linger'
        'terminate-user:terminate user'
        'kill-user:kill user'
        'list-seats:list seats'
        'seat-status:show seat status'
        'show-seat:show seat properties'
        'attach:attach device to seat'
        'flush-devices:flush devices'
        'terminate-seat:terminate seat'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--no-ask-password[no ask password]' \
        '-p+[property]:str:' \
        '--property=+[property]:str:' \
        '-P+[property]:str:' \
        '-a[all]' \
        '--all[all]' \
        '--value[value only]' \
        '-l[full output]' \
        '--full[full output]' \
        '--kill-whom=+[whom]:w:(leader all)' \
        '-s+[signal]:str:' \
        '--signal=+[signal]:str:' \
        '-n+[lines]:n:' \
        '--lines=+[lines]:n:' \
        '-o+[output format]:f:(short short-precise short-iso short-iso-precise short-full short-monotonic short-unix verbose export json json-pretty json-sse json-seq cat with-unit)' \
        '--output=+[output format]:f:(short short-precise short-iso short-iso-precise short-full short-monotonic short-unix verbose export json json-pretty json-sse json-seq cat with-unit)' \
        '-H+[host]:host:_hosts' \
        '--host=+[host]:host:_hosts' \
        '-M+[machine]:str:' \
        '--machine=+[machine]:str:' \
        '--no-pager[no pager]' \
        '--no-legend[no legend]' \
        '--json=+[mode]:m:(short pretty off)' \
        '-j[json short]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'loginctl subcommand' sub ;;
    esac
}

_loginctl-cli "$@"
