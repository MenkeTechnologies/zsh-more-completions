#compdef fbcat
# Documentation: https://man.archlinux.org/search?q=fbcat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --device)'{-d,--device}'+[framebuffer device]:dev:_files -g "/dev/fb*"' \
  '(-s --black-is-zero)'{-s,--black-is-zero}'[interpret 0 as black]' \
  '*:output:_files' && ret=0

return ret
