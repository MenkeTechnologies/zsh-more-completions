#compdef srgn
# Documentation: https://github.com/alexpovel/srgn/blob/main/README.md
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.
# Removed fabricated boolean language flags (--python/--rust/--go/--c/--hcl
# etc.) — these are tree-sitter QUERY options, not booleans. Also removed
# fabricated --no-copy-file-on-demand, -c/--only-matching, --line-numbers,
# --files, -X/--fail-empty-glob, -.--dot-strict, --stdin-override-to.

# Zsh completion for srgn - a grep-like tool for source code surgery

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--completions=[generate shell completions]:shell:(bash zsh fish powershell elvish)' \
  '(-G --glob)'{-G,--glob}'+[glob of files to work on]:glob' \
  '(-H --hidden)'{-H,--hidden}'[process hidden files]' \
  '--gitignored[process files ignored by git]' \
  '--sorted[process files in alphabetical order]' \
  '--threads=[explicit thread count]:num' \
  '--stdin-detection=[force stdin detection]:mode:(auto force-readable force-unreadable)' \
  '--stdout-detection=[force stdout TTY detection]:mode:(auto force-tty force-pipe)' \
  '--dry-run[preview changes without writing]' \
  '--fail-no-files[fail if glob finds no files]' \
  '--fail-any[exit non-zero if anything matches]' \
  '--fail-none[exit non-zero if nothing matches]' \
  '(-d --delete)'{-d,--delete}'[delete matched scopes]' \
  '(-s --squeeze)'{-s,--squeeze}'[squeeze consecutive occurrences]' \
  '(-u --upper)'{-u,--upper}'[uppercase scopes]' \
  '(-l --lower)'{-l,--lower}'[lowercase scopes]' \
  '(-t --titlecase)'{-t,--titlecase}'[titlecase scopes]' \
  '(-n --normalize)'{-n,--normalize}'[normalize scopes via NFD]' \
  '(-g --german)'{-g,--german}'[perform German character replacements]' \
  '(-S --symbols)'{-S,--symbols}'[ASCII to Unicode symbol conversion]' \
  '--german-prefer-original[do not modify if original word is equally legal]' \
  '--german-naive[force replacements regardless of legality]' \
  '(-i --invert)'{-i,--invert}'[work on scopes outside the pattern]' \
  '(-L --literal-string)'{-L,--literal-string}'[treat scope as literal string]' \
  '(-j --join-language-scopes)'{-j,--join-language-scopes}'[OR language scopes instead of AND]' \
  '*-v[increase log verbosity]' \
  '*--verbose[increase log verbosity]' \
  '--python=[tree-sitter scope/query for Python]:query' \
  '--py=[tree-sitter scope/query for Python (alias)]:query' \
  '--rust=[tree-sitter scope/query for Rust]:query' \
  '--rs=[tree-sitter scope/query for Rust (alias)]:query' \
  '--go=[tree-sitter scope/query for Go]:query' \
  '--c=[tree-sitter scope/query for C]:query' \
  '--csharp=[tree-sitter scope/query for C#]:query' \
  '--cs=[tree-sitter scope/query for C# (alias)]:query' \
  '--typescript=[tree-sitter scope/query for TypeScript]:query' \
  '--ts=[tree-sitter scope/query for TypeScript (alias)]:query' \
  '--hcl=[tree-sitter scope/query for HCL]:query' \
  '--python-query=[ad-hoc tree-sitter query for Python]:query' \
  '--rust-query=[ad-hoc tree-sitter query for Rust]:query' \
  '--go-query=[ad-hoc tree-sitter query for Go]:query' \
  '--c-query=[ad-hoc tree-sitter query for C]:query' \
  '--csharp-query=[ad-hoc tree-sitter query for C#]:query' \
  '--typescript-query=[ad-hoc tree-sitter query for TypeScript]:query' \
  '--hcl-query=[ad-hoc tree-sitter query for HCL]:query' \
  '--python-query-file=[tree-sitter query file for Python]:file:_files' \
  '--rust-query-file=[tree-sitter query file for Rust]:file:_files' \
  '--go-query-file=[tree-sitter query file for Go]:file:_files' \
  '--c-query-file=[tree-sitter query file for C]:file:_files' \
  '--csharp-query-file=[tree-sitter query file for C#]:file:_files' \
  '--typescript-query-file=[tree-sitter query file for TypeScript]:file:_files' \
  '--hcl-query-file=[tree-sitter query file for HCL]:file:_files' \
  '*:scope or replacement:_files' && ret=0

return ret
