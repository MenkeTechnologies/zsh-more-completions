#compdef srgn

# Zsh completion for srgn - a grep-like tool for source code surgery

local curcontext="$curcontext" state line ret=1

local -a languages=(
  c csharp go hcl python rust typescript
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--completions[generate shell completions]:shell:(bash zsh fish powershell elvish)' \
  '(-g --glob)'{-g,--glob}'[glob of files to work on]:glob' \
  '(-H --hidden)'{-H,--hidden}'[process hidden files]' \
  '--gitignored[process files ignored by git]' \
  '(-T --sorted)'{-T,--sorted}'[process files in alphabetical order]' \
  '(-t --threads)'{-t,--threads}'[number of threads]:num' \
  '--files-from[list of files from stdin]' \
  '(-.  --dot-strict)'{-.,--dot-strict}'[enable dot-strict mode]' \
  '(-d --delete)'{-d,--delete}'[delete matched scopes]' \
  '(-u --upper)'{-u,--upper}'[uppercase scopes]' \
  '(-l --lower)'{-l,--lower}'[lowercase scopes]' \
  '--titlecase[titlecase scopes]' \
  '(-n --normalize)'{-n,--normalize}'[normalize scopes]' \
  '--german[perform German character replacements]' \
  '(-S --squeeze)'{-S,--squeeze}'[squeeze consecutive occurrences]' \
  '(-i --invert)'{-i,--invert}'[work on scopes outside the pattern]' \
  '(-p --fail-no-files)'{-p,--fail-no-files}'[fail if no files found]' \
  '--stdin-override-to[override stdin detection]:bool:(true false)' \
  '--fail-any[fail if any matches found]' \
  '--fail-none[fail if no matches found]' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '--no-copy-file-on-demand[disable copy-file-on-demand]' \
  '(-c --only-matching)'{-c,--only-matching}'[only print matching lines]' \
  '--line-numbers[print line numbers]' \
  '(-L --literal-string)'{-L,--literal-string}'[treat scope as literal string]' \
  '(-X --fail-empty-glob)'{-X,--fail-empty-glob}'[fail if glob matches nothing]' \
  '--files[print files only]' \
  '--python[use Python language]' \
  '--rust[use Rust language]' \
  '--go[use Go language]' \
  '--typescript[use TypeScript language]' \
  '--csharp[use C# language]' \
  '--c[use C language]' \
  '--hcl[use HCL language]' \
  '--python-query[tree-sitter query for Python]:query' \
  '--rust-query[tree-sitter query for Rust]:query' \
  '--go-query[tree-sitter query for Go]:query' \
  '*:scope or replacement:_files' && ret=0

return ret
