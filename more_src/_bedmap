#compdef bedmap
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/statistics/bedmap.html
# Documentation: https://github.com/bedops/bedops/blob/master/applications/bed/bedmap/src/Input.hpp
# Reference accessed: 2026-05-27
# Verified: upstream Input.hpp argument parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--help[show help message and exit]' \
  '--help-all[show all help, including hidden operations]' \
  '--version[show program version and citation info]' \
  '--ec[perform error checking on input compliance]' \
  '--header[accept BED/VCF/GFF/SAM/WIG headers in input files]' \
  '--chrom=[restrict operations to specified chromosome]:chromosome:' \
  '--delim=[set delimiter between output columns]:delim:' \
  '--multidelim=[set delimiter between elements of multi-valued output fields]:delim:' \
  '--prec=[floating-point output precision]:digits:' \
  '--sci[use scientific notation for numeric output]' \
  '--unmapped-val=[set value printed when no map element overlaps reference]:value:' \
  '--skip-unmapped[omit reference rows with zero overlapping map elements]' \
  '--sweep-all[read entire map file before processing reference]' \
  '--faster[assume no nested map elements (faster mode)]' \
  '--min-memory[minimize memory usage at the cost of speed]' \
  '--bp-ovr=[require N base-pair overlap between map and reference]:bp:' \
  '--range=[pad reference coordinates by N bp on each side]:bp:' \
  '--fraction-ref=[require fraction of reference element overlap]:fraction:' \
  '--fraction-map=[require fraction of map element overlap]:fraction:' \
  '--fraction-both=[require fraction overlap on both reference and map]:fraction:' \
  '--fraction-either=[require fraction overlap on either reference or map]:fraction:' \
  '--exact[require exact reference/map element match]' \
  '--echo[copy reference element to output]' \
  '--echo-map[list overlapping map elements joined with delimiter]' \
  '--echo-map-id[list IDs of overlapping map elements]' \
  '--echo-map-id-uniq[list unique IDs of overlapping map elements]' \
  '--echo-map-range[range covering all overlapping map elements]' \
  '--echo-map-score[list scores of overlapping map elements]' \
  '--echo-map-length[list lengths of overlapping map elements]' \
  '--echo-map-intersect-length[list intersect lengths between overlapping map and reference]' \
  '--echo-ref[copy reference element to output (alias)]' \
  '--echo-ref-length[length of the reference element]' \
  '--echo-ref-row-number[reference row number (1-based)]' \
  '--echo-ref-span[reference chromosome and start/end span]' \
  '--indicator[1 if any overlap, else 0]' \
  '--count[number of map elements overlapping reference]' \
  '--overlap-agg[total aggregate overlap base count]' \
  '--overlap-uniq[unique reference bases covered by any map element]' \
  '--overlap-uniq-fraction[fraction of reference bases covered by any map element]' \
  '--sum[sum of map element scores]' \
  '--average[mean of map element scores]' \
  '--wmean[length-weighted mean of map element scores]' \
  '--tmean[trimmed mean of map element scores]:low,high:' \
  '--median[median of map element scores]' \
  '--mad[median absolute deviation of map element scores]' \
  '--kth-average[kth-quantile of map element scores]:fraction:' \
  '--variance[variance of map element scores]' \
  '--stddev[standard deviation of map element scores]' \
  '--coefficient-variation[coefficient of variation of map element scores]' \
  '--min[minimum map element score]' \
  '--max[maximum map element score]' \
  '--min-element[map element with minimum score]' \
  '--min-element-rand[random map element with minimum score]' \
  '--min-element-stable[first-occurring map element with minimum score]' \
  '--max-element[map element with maximum score]' \
  '--max-element-rand[random map element with maximum score]' \
  '--max-element-stable[first-occurring map element with maximum score]' \
  '*:bed/starch file:_files -g "*.(bed|bed.gz|starch)(-.)"' && ret=0

return ret
