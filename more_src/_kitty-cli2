#compdef kitty-cli2
# Documentation: https://sw.kovidgoyal.net/kitty/invocation/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: there is no upstream tool named `kitty-cli2`; this file is a
# stray alternate kitty completion. The prior content contained
# fabricated flags (--reload-in-shell, --debug-license, --logo,
# --update-check-interval, --debug-config) and unreachable code after
# `return`. Reduced to the subset of kitty options that are verified
# against the kitty invocation docs; see _kitty for the full mapping.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(--app-id --class)'{--app-id=,--class=}'[set the WM_CLASS class]:class:' \
  '(--name --os-window-tag)'{--name=,--os-window-tag=}'[set the WM_CLASS name]:name:' \
  '(--title -T)'{--title=,-T+}'[set the OS window title]:title:' \
  '(--config -c)'{--config=,-c+}'[path to the configuration file]:file:_files -g "*.conf"' \
  '*'{--override=,-o+}'[override individual configuration options]:option=value:' \
  '(--directory --working-directory -d)'{--directory=,--working-directory=,-d+}'[set the working directory]:dir:_directories' \
  '--detach[detach from the controlling terminal]' \
  '--session=[path to a startup session file]:file:_files' \
  '--hold[remain open after child process exits]' \
  '(--single-instance -1)'{--single-instance,-1}'[run only a single instance of kitty]' \
  '--instance-group=[group for use with single-instance]:group:' \
  '--wait-for-single-instance-window-close[wait for the single instance window to close]' \
  '--listen-on=[listen on a socket for control messages]:socket:' \
  '--start-as=[set the initial window state]:state:(normal fullscreen maximized minimized)' \
  '--watcher=[path to a Python file for custom event handling]:file:_files -g "*.py"' \
  '(--version -v)'{--version,-v}'[show version]' \
  '--debug-rendering[print out rendering commands]' \
  '--debug-keyboard[print out key events as they are received]' \
  '--debug-input[print out key and mouse events as they are received]' \
  '--debug-font-fallback[print debug information for font fallback selection]' \
  '*::command:_command_names -e' && ret=0

return ret
