#compdef kitty-cli2
# Documentation: https://man.archlinux.org/search?q=kitty-cli2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --class)'{-c+,--class=}'[window class]:c:' \
  '(--name)--name=[window name]:n:' \
  '(--title -T)'{-T+,--title=}'[window title]:t:' \
  '(--config)*--config=[config file]:file:_files -g "*.conf"' \
  '(--override -o)*'{-o+,--override=}'[k=v override]:v:' \
  '(--directory -d --working-directory)*'{-d+,--directory=,--working-directory=}'[cwd]:dir:_files -/' \
  '(--detach)--detach[detach kitty]' \
  '(--session)--session=[session file]:file:_files' \
  '(--hold)--hold[hold after exit]' \
  '(--single-instance -1)'{-1,--single-instance}'[single instance]' \
  '(--instance-group)--instance-group=[instance group]:g:' \
  '(--listen-on)--listen-on=[socket]:s:' \
  '(--start-as)--start-as=[start as]:s:(normal fullscreen maximized minimized)' \
  '(--watcher)*--watcher=[watcher]:file:_files -g "*.py"' \
  '(--debug-rendering)--debug-rendering[debug rendering]' \
  '(--debug-keyboard)--debug-keyboard[debug keyboard]' \
  '(--debug-config)--debug-config[debug config]' \
  '(--debug-input)--debug-input[debug input]' \
  '(--debug-font-fallback)--debug-font-fallback[debug fonts]' \
  '(--debug-license)--debug-license[debug license]' \
  '(--update-check-interval)--update-check-interval=[s]:s:' \
  '(--wait-for-single-instance-window-close)--wait-for-single-instance-window-close[wait]' \
  '(--logo)--logo=[logo file]:file:_files' \
  '(-e --execute)'{-e,--execute}'[execute remaining as command]' \
  '(-o)*-o+[k=v override]:v:' \
  '(--reload-in-shell)--reload-in-shell[reload in shell]' \
  '*:command:_command_names -e' && ret=0

local -a commands
commands=(
  '+[positional command]'
  '@:remote control'
  '+kitten:run a kitten plugin'
  '+launch:launch a kitten plugin'
  '+complete:completions support'
  '+edit-in-kitty:edit file in kitty'
  '+open:open file/url'
  '+runpy:run python in kitty env'
  '+detach:detach process'
  '+shebang:run scripts'
  '+launch:run subcommand'
)
_describe -t cmds 'kitty positional' commands && ret=0

return ret
