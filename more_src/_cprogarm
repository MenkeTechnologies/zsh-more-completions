#compdef cprogarm
# Documentation: https://www.pemicro.com/faqs/faq_view.cfm?id=30
# PEmicro CPROG ARM command-line flash programmer — scripted flash programming

local ret=1

_arguments -s -S \
  '\?[wait and display programming result window]' \
  '\![wait and display result window only on error]' \
  '*:script/param:->args' && ret=0

case $state in
  args)
    if compset -P 'INTERFACE='; then
      _values 'interface' USBMULTILINK CYCLONE TRACELINK OPENSDA PARALLEL && ret=0
    elif compset -P 'PORT='; then
      _message 'port (e.g. USB1 or hardware serial)' && ret=0
    else
      _alternative \
        'params:assignment:compadd -S "" INTERFACE= PORT= FREQ=' \
        'files:config or program file:_files' && ret=0
    fi
    ;;
esac

return ret
