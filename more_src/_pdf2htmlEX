#compdef pdf2htmlEX
# Documentation: https://man.archlinux.org/search?q=pdf2htmlEX
# Reference accessed: 2026-05-16

_arguments -s \
  '(-f --first-page)'{-f,--first-page}'=[first page]:n:' \
  '(-l --last-page)'{-l,--last-page}'=[last page]:n:' \
  '--zoom=[zoom factor]:f:' \
  '--fit-width=[fit width]:n:' \
  '--fit-height=[fit height]:n:' \
  '--use-cropbox=[use crop box]:bool:(0 1)' \
  '--dpi=[DPI]:n:' \
  '--embed=[embed flags]:flags:' \
  '--embed-css=[embed CSS]:bool:(0 1)' \
  '--embed-font=[embed font]:bool:(0 1)' \
  '--embed-image=[embed image]:bool:(0 1)' \
  '--embed-javascript=[embed JS]:bool:(0 1)' \
  '--embed-outline=[embed outline]:bool:(0 1)' \
  '--embed-external-font=[embed external font]:bool:(0 1)' \
  '--split-pages=[split pages]:bool:(0 1)' \
  '--dest-dir=[destination dir]:dir:_files -/' \
  '--css-filename=[CSS filename]:name:' \
  '--page-filename=[page filename pattern]:pattern:' \
  '--outline-filename=[outline filename]:name:' \
  '--process-nontext=[process non-text]:bool:(0 1)' \
  '--process-outline=[process outline]:bool:(0 1)' \
  '--process-annotation=[process annotations]:bool:(0 1)' \
  '--process-form=[process form]:bool:(0 1)' \
  '--printing=[allow printing]:bool:(0 1)' \
  '--fallback=[fallback mode]:bool:(0 1)' \
  '--tmp-file-size-limit=[tmp file size limit MB]:n:' \
  '--font-format=[font format]:fmt:(ttf otf woff svg)' \
  '--decompose-ligature=[decompose ligature]:bool:(0 1)' \
  '--turn-off-ligatures=[turn off ligatures]:bool:(0 1)' \
  '--auto-hint=[auto hint]:bool:(0 1)' \
  '--external-hint-tool=[hint tool]:tool:_command_names' \
  '--stretch-narrow-glyph=[stretch narrow glyphs]:bool:(0 1)' \
  '--squeeze-wide-glyph=[squeeze wide glyphs]:bool:(0 1)' \
  '--override-fstype=[override fstype]:bool:(0 1)' \
  '--process-type3=[process Type 3]:bool:(0 1)' \
  '--heps=[horizontal threshold]:f:' \
  '--veps=[vertical threshold]:f:' \
  '--space-threshold=[space threshold]:f:' \
  '--font-size-multiplier=[font size multiplier]:f:' \
  '--space-as-offset=[space as offset]:bool:(0 1)' \
  '--tounicode=[ToUnicode]:n:(-1 0 1)' \
  '--optimize-text=[optimize text]:bool:(0 1)' \
  '--correct-text-visibility=[text visibility]:n:(0 1 2)' \
  '--covered-text-dpi=[covered text DPI]:n:' \
  '--bg-format=[background image format]:fmt:(png jpg svg)' \
  '--svg-node-count-limit=[SVG node count limit]:n:' \
  '--svg-embed-bitmap=[embed bitmap in SVG]:bool:(0 1)' \
  '(-o --owner-password)'{-o,--owner-password}'=[owner password]:password:' \
  '(-u --user-password)'{-u,--user-password}'=[user password]:password:' \
  '--no-drm[ignore DRM]' \
  '--clean-tmp=[clean tmp]:bool:(0 1)' \
  '--tmp-dir=[tmp dir]:dir:_files -/' \
  '--data-dir=[data dir]:dir:_files -/' \
  '--poppler-data-dir=[poppler data dir]:dir:_files -/' \
  '--debug[debug]' \
  '--proof[proof mode]' \
  '--quiet[quiet]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:pdf file:_files -g "*.pdf"'
