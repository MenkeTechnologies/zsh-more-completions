#compdef kagent
# Documentation: https://man.archlinux.org/search?q=kagent
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/kagent
local curcontext="$curcontext" state line ret=1

local -a _kagent_cmds
_kagent_cmds=(
  'install:install kagent in-cluster components'
  'uninstall:remove kagent from the cluster'
  'invoke:invoke a deployed agent with a task'
  'bug-report:collect diagnostics'
  'version:print CLI and server versions'
  'dashboard:open the kagent dashboard'
  'get:list kagent resources'
  'init:bootstrap a local agent project'
  'build:build agent container images'
  'deploy:apply agent manifests to Kubernetes'
  'add-mcp:add an MCP server entry to kagent.yaml'
  'run:run agent locally with docker compose'
  'mcp:scaffold and package MCP services'
  'env:environment documentation helpers'
)

_arguments -C -s -S \
  '--kagent-url[kAgent API base URL]:url' \
  '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]:namespace' \
  '(-o --output-format)'{-o,--output-format}'[command output format]:format' \
  '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
  '--timeout[client timeout]:duration' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'kagent command' _kagent_cmds && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments -s -S '--profile[installation profile]:profile:(minimal demo)' && ret=0
        ;;
      invoke)
        _arguments -s -S \
          '(-t --task)'{-t,--task}'[natural language task text]:task' \
          '(-s --session)'{-s,--session}'[reuse an existing session id]:session' \
          '(-a --agent)'{-a,--agent}'[agent name]:agent' \
          '(-S --stream)'{-S,--stream}'[stream assistant output]' \
          '(-f --file)'{-f,--file}'[read task contents from file]:file:_files' \
          '--token[bearer token for A2A requests]:token' \
          && ret=0
        ;;
      get)
        _default && ret=0
        ;;
      init)
        _arguments -s -S \
          '--instruction-file[path to custom system instructions]:file:_files' \
          '--model-provider[model vendor]:provider:(OpenAI Anthropic Gemini)' \
          '--model-name[model identifier]:model' \
          '--description[human-readable project description]:text' \
          '1:framework:(adk)' \
          '2:language:(python)' \
          '3:agent name:' \
          && ret=0
        ;;
      build)
        _arguments -s -S \
          '1:project directory:_files -/' \
          '--image[full OCI image reference]:image' \
          '--push[push image after build]' \
          '--platform[comma-separated target platforms]:platform' \
          && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '1:project directory:_files -/' \
          '(-i --image)'{-i,--image}'[container image to deploy]:image' \
          '--env-file[dotenv file with secrets]:file:_files' \
          '--namespace[destination namespace]:namespace' \
          '--dry-run[print manifests only]' \
          '--platform[comma-separated image platforms]:platform' \
          && ret=0
        ;;
      add-mcp)
        _arguments -s -S \
          '*::MCP name or args:_default' \
          '--project-dir[agent project root]:directory:_files -/' \
          '--remote[remote MCP http(s) URL]:url' \
          '*--header[HTTP header KEY=VALUE]:header' \
          '--command[stdio MCP executable]:command: _command_names -e' \
          '*--arg[argument repeated for MCP command]:argument' \
          '*--env[process environment KEY=VALUE]:env' \
          '--image[sidecar OCI reference]:reference' \
          '--build[local image build context]:path:_files -/' \
          && ret=0
        ;;
      run)
        _arguments -s -S \
          '::project directory:_files -/' \
          '--project-dir[agent project root]:directory:_files -/' \
          '--build[rebuild container images before starting compose]' \
          && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
