#compdef avidemux avidemux2 avidemux3_qt5 avidemux3_qt6 avidemux3_cli

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--quit[exit avidemux at end of script]' \
  '--nogui[suppress all dialogs (must be first)]' \
  '--autoindex[index file before loading]' \
  '--load=[load video file]:file:_files' \
  '--append=[append video file]:file:_files' \
  '--run=[load and run script]:script:_files -g "*.js *.py"' \
  '--save=[save video to file]:file:_files' \
  '--rebuild-index[force rebuild of index]' \
  '--info=[show file info]:file:_files' \
  '--save-jpg=[save current frame as JPEG]:file:_files' \
  '--video-codec=[set video codec]:codec:' \
  '--audio-codec=[set audio codec]:codec:' \
  '--output-format=[output format]:format:(MKV MP4 AVI MPEG_PS MPEG_TS WEBM RAW FLV)' \
  '--force-alt-h264[force alt h264 reader]' \
  '--force-smart[force smart copy]' \
  '--force-unpack-vop[force unpacking VOPs]' \
  '--audio-process[apply audio processing]' \
  '--audio-delay=[audio delay ms]:ms:' \
  '*:video file:_files' && ret=0

return ret
