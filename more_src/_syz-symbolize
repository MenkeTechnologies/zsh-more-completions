#compdef syz-symbolize
# _syz-symbolize — symbolize syzkaller kernel crash reports (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-symbolize/symbolize.go (flag).

_syz-symbolize() {
    _arguments \
        '-os=[target OS]:os:(linux freebsd netbsd openbsd darwin windows fuchsia trusty test)' \
        '-arch=[target architecture]:arch:(amd64 386 arm64 arm mips64le ppc64le riscv64 s390x)' \
        '-kernel_obj=[path to kernel build/obj dir]:dir:_files -/' \
        '-kernel_src=[path to kernel sources (defaults to kernel_obj)]:dir:_files -/' \
        '-outdir=[output directory]:dir:_files -/' \
        '-config=[optional configuration file]:file:_files' \
        '1:crash report file:_files'
}

_syz-symbolize "$@"
