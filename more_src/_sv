#compdef sv
# Documentation: https://smarden.org/runit/sv.8.html
# Reference accessed: 2026-05-21
# Verified: upstream runit sv(8) man page at the URL above.
# Removed from prior file: fabricated -h/--help flags (the man page documents
# only -v and -w sec); added 'try-restart' which the man page lists.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'up:bring the service up'
  'down:bring the service down'
  'once:run once, do not restart'
  'pause:send SIGSTOP to the run script'
  'cont:send SIGCONT to the run script'
  'hup:send SIGHUP'
  'alarm:send SIGALRM'
  'interrupt:send SIGINT'
  'quit:send SIGQUIT'
  '1:send SIGUSR1'
  '2:send SIGUSR2'
  'term:send SIGTERM'
  'kill:send SIGKILL'
  'exit:exit the service and supervisor'
  'status:report status (default)'
  'start:up + wait until running'
  'stop:down + wait until down'
  'reload:send HUP and report status'
  'restart:restart service and wait'
  'shutdown:exit supervisor and wait'
  'force-stop:stop, kill if not down within timeout'
  'force-reload:reload, kill if not done within timeout'
  'force-restart:restart, kill if not done within timeout'
  'force-shutdown:shutdown, kill if not done within timeout'
  'try-restart:restart only if running'
  'check:check service reached requested state'
)

_arguments -C \
  '-v[wait/report status after sending command]' \
  '-w+[override 7s wait timeout]:seconds:' \
  '1: :->cmd' \
  '*::svc:->svc' && ret=0

case $state in
  (cmd) _describe -t cmds 'sv command' commands && ret=0 ;;
  (svc)
    _alternative \
      'dir:/etc/sv:_files -W /etc/sv -/' \
      'dir:/service:_files -W /service -/' \
      'dir:/var/service:_files -W /var/service -/' \
      'dir:dir:_files -/' && ret=0 ;;
esac

return ret
