#compdef sv
# Documentation: https://man.archlinux.org/search?q=sv
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'up:bring the service up'
  'down:bring the service down'
  'once:run once, do not restart'
  'pause:send SIGSTOP to the run script'
  'cont:send SIGCONT to the run script'
  'hup:send SIGHUP'
  'alarm:send SIGALRM'
  'interrupt:send SIGINT'
  '1:send SIGUSR1'
  '2:send SIGUSR2'
  'term:send SIGTERM'
  'kill:send SIGKILL'
  'quit:send SIGQUIT'
  'exit:exit the service'
  'start:up + wait until running'
  'stop:down + wait until down'
  'restart:restart the service'
  'shutdown:stop service and supervisor'
  'force-stop:stop, kill if not down within sec'
  'force-reload:hup, kill if not up'
  'force-restart:term then up, kill if not up'
  'force-shutdown:exit + kill if not down'
  'check:check the service status'
  'status:print the status (default)'
  'reload:like force-reload but without timeout'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose output]' \
  '-w+[wait timeout in seconds]:n:' \
  '1: :->cmd' \
  '*::svc:->svc' && ret=0

case $state in
  (cmd) _describe -t cmds 'sv command' commands && ret=0 ;;
  (svc)
    _alternative \
      'dir:/etc/sv:_files -W /etc/sv -/' \
      'dir:/service:_files -W /service -/' \
      'dir:/var/service:_files -W /var/service -/' \
      'dir:dir:_files -/' && ret=0 ;;
esac

return ret
