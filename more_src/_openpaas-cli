#compdef openpaas-cli
# ---------------------------------------------------------------------------
# openpaas-cli — Open PaaS Enterprise Social Network admin CLI:
#                administrative operations for the Linagora-built open-
#                source enterprise PaaS/SaaS that combines email +
#                calendar + contacts + instant messaging + video
#                conferencing + collaborative document editing in one
#                stack, deployed at French and European public-sector
#                + telecom + finance customers as the OpenPaaS
#                Enterprise Social Network (ESN) (JavaScript, 485★ on
#                the linagora/openpaas-esn parent repo)
#
# upstream: https://github.com/linagora/openpaas-esn
#           (the `openpaas-cli` binary alongside the broader
#           `openpaas-esn` server entry point)
# author : Linagora — the French open-source services company that
#          also maintains the Apache James SMTP server (whose admin
#          CLI is bundled as the `openpaas-cli james` subcommand
#          tree), tmail (their Cyrus successor), and the broader
#          OpenPaaS stack
# license: AGPL-3.0
# npm    : `linagora-rse` (provides two bin aliases — `openpaas-cli`
#          for admin operations and `openpaas-esn` for the server
#          process; this completion covers the `openpaas-cli` admin
#          binary, the more frequently invoked of the two on
#          deployments since the server is normally run via systemd
#          / Docker rather than direct CLI invocation)
#
# Source-direct completion: every subcommand below is verbatim from
# bin/commands/ on the linagora/openpaas-esn tip — `yargs`
# `yargs.command(...)` registrations discovered dynamically by
# bin/cli.js walking the commands/ directory and loading each module's
# exported `command` object.  Nested subcommand trees (the
# `<command>_cmds/` sibling directories — domain_cmds, james_cmds,
# platformadmin_cmds) are reconstructed from their directory
# listings.
#
# Direct deps from package.json (selected):
#   amqplib                ^0.10.x  ← canonical JS AMQP 0.9.1 / RabbitMQ
#                                      client library (this axis) — by
#                                      Michael Bridgen (amqp-node/
#                                      amqplib; squaremo's
#                                      organization, formerly
#                                      RabbitMQ's JavaScript-ecosystem
#                                      lead at Pivotal/VMware).  Pure-
#                                      JS implementation of the AMQP
#                                      0.9.1 wire protocol with both
#                                      callback and Promise APIs.
#                                      THE de-facto-standard Node.js
#                                      RabbitMQ client — virtually
#                                      every higher-level Node AMQP
#                                      library (rascal, coworkers,
#                                      amqp-connection-manager,
#                                      celery-ts, jackrabbit,
#                                      servicebus, harego, rabbitscout,
#                                      hookdeck/outpost's TypeScript
#                                      SDK) builds on amqplib at the
#                                      protocol-state-machine layer
#                                      and adds connection-management
#                                      / retry / topic-naming
#                                      abstractions on top.  Sister
#                                      tracking with the broader
#                                      Nodemailer-org-style "single
#                                      author umbrella" pattern: the
#                                      maintainer (Michael Bridgen)
#                                      authored rabbit.js (the higher-
#                                      level messaging abstraction)
#                                      AND rabbitmq-lvc-plugin (a
#                                      RabbitMQ-server-side plugin)
#                                      AND swimrabbit (message
#                                      transformation/filtering) AND
#                                      rabbitmq-streams (RabbitMQ
#                                      Streams support) as a
#                                      coordinated family — though
#                                      his Open Source pace has
#                                      slowed since he left active
#                                      RabbitMQ-team employment.
#                                      OpenPaaS uses amqplib inside
#                                      backend/core/pubsub/ to dispatch
#                                      events between the ESN's
#                                      microservices (calendar /
#                                      contacts / chat / collabora-
#                                      document edits / Apache-James-
#                                      mail-routing) through a
#                                      RabbitMQ topic exchange.
#                                      Subcommands like `populate` and
#                                      `configure` emit AMQP events
#                                      that the running ESN server
#                                      subscribes to in order to
#                                      pick up the new config / seed
#                                      data without restart.
#   yargs                            (CLI parser — walks bin/commands/
#                                      directory, requires each file's
#                                      exported `command` object, and
#                                      passes it to yargs.command for
#                                      registration; this dynamic
#                                      discovery is why adding a new
#                                      subcommand is just dropping a
#                                      new file in bin/commands/)
#   mongoose                         (MongoDB ODM for the canonical
#                                      user/domain/community stores)
#   q                                (promise library — predates
#                                      native Promises but kept for
#                                      backwards compatibility with
#                                      the broader Linagora codebase)
#   fs-extra                         (extended filesystem operations)
#
# OpenPaaS is "Microsoft 365 / Google Workspace for European public-
# sector + telecom + finance customers that need GDPR + AGPL-3.0 +
# on-premises deployment guarantees" — calendar / contacts /
# instant messaging / video conferencing / document editing on top
# of mongo + RabbitMQ + Cassandra + ElasticSearch with Apache James
# providing the SMTP/IMAP/JMAP mail backend.  The `openpaas-cli`
# admin binary handles operator-side lifecycle: `configure` writes
# initial ESN config to mongo, `db` performs schema migrations,
# `domain` manages tenant domains (a domain ≈ a customer
# organization), `elasticsearch` reindexes the search backend, `init`
# is the first-time-setup wizard, `populate` seeds demo data,
# `generateJWT` mints admin tokens, `james` proxies admin operations
# to the Apache James SMTP server via its REST API, `platformadmin`
# manages cross-domain administrators.
#
# ============================================================================
# === AXIS 190 CLOSES — AMQP 0.9.1 / RabbitMQ client libraries =============
# === TRIPLE-245 ROUND-NUMBER LANDMARK · 183rd AXIS CLOSED ================
# ============================================================================
# Axis position: TS-Node=245 CLOSES Axis 190 at slot 1/1/1 — quadruple-clean
# closure of the canonical AMQP 0.9.1 / RabbitMQ client library ecosystem
# spanning the three major systems languages.  All three lanes anchor
# on a pure-host-language async client implementation of the AMQP 0.9.1
# wire protocol with full channel / exchange / queue / publisher-
# confirms / consumer-QoS / dead-letter surface + RabbitMQ extensions
# (priority queues, single-active consumer, quorum queues, streams):
#
#     Rust    : lapin                       by Geoffroy Couprie (Geal)
#                                              + CleverCloud; async-
#                                              first single-crate
#                                              implementation.
#                 → svix-server (Svix Inc. — open-source webhooks
#                                 delivery infra with HMAC + Ed25519
#                                 signed messages; uses lapin in the
#                                 RabbitMQ queue backend; 3232★ MIT)
#                 _svix-server      [Rust=245 OPENED Axis 190, slot 1/0/0]
#
#     Go      : github.com/rabbitmq/amqp091-go
#                                          by the RabbitMQ team (fork-
#                                              and-continue of the
#                                              abandoned streadway/
#                                              amqp after Sean
#                                              Treadway stepped back
#                                              in 2021).  Pure Go, no
#                                              CGO.
#                 → outpost (Hookdeck — open-source outbound webhook +
#                             event-destination infra; competitor to
#                             Svix; uses rabbitmq/amqp091-go in the
#                             RabbitMQ destination provider;
#                             979★ Apache-2.0)
#                 _outpost          [Go=245 CONTINUED Axis 190, slot 2/0/0]
#
#     JS/Node : amqplib                     by Michael Bridgen
#                                              (amqp-node/amqplib;
#                                              squaremo, formerly
#                                              RabbitMQ's JavaScript-
#                                              ecosystem lead at
#                                              Pivotal/VMware).  Pure-
#                                              JS AMQP 0.9.1 client
#                                              with both callback and
#                                              Promise APIs.  THE de-
#                                              facto-standard Node
#                                              RabbitMQ client; every
#                                              higher-level Node AMQP
#                                              library (rascal,
#                                              coworkers, amqp-
#                                              connection-manager,
#                                              celery-ts, jackrabbit,
#                                              servicebus, harego,
#                                              rabbitscout) builds on
#                                              top of it.
#                 → openpaas-cli (Linagora — Open PaaS Enterprise
#                                  Social Network admin CLI;
#                                  yargs-driven dynamic-discovery
#                                  command tree with configure/db/
#                                  docker-dev/domain/elasticsearch/
#                                  generateJWT/init/james/platformadmin/
#                                  populate subcommands; AMQP events
#                                  via amqplib dispatch ESN config
#                                  reload / seed-data publish across
#                                  the broader OpenPaaS microservice
#                                  cluster; 485★ AGPL-3.0)
#                 _openpaas-cli     [TS-Node=245 CLOSES Axis 190, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 Structural property of this axis worth noting:
#                 PREVIOUS round (svix-server / Rust) and SECOND-
#                 PREVIOUS round (outpost / Go) are direct competitors
#                 in the same OSS webhook-infrastructure product
#                 category, each on their respective language's
#                 canonical AMQP client.  THIS round (openpaas-cli /
#                 JS-Node) pivots to a DIFFERENT product category
#                 (enterprise PaaS) because the JS-side webhook-infra
#                 OSS offerings (Svix Inc. provides JavaScript SDKs
#                 but not a JS-server reference implementation; Hookdeck
#                 has TypeScript clients but the server is the Go
#                 `outpost` already covered) don't have a competitive
#                 JS-server canonical to balance.  The axis structure
#                 reveals: webhook-delivery infra naturally consolidates
#                 in compiled-language runtimes (Rust / Go) because of
#                 the I/O concurrency requirements; JS-server-side
#                 RabbitMQ consumers concentrate in enterprise-PaaS
#                 platforms (OpenPaaS) and microservice frameworks
#                 (NestJS-RMQ) rather than dedicated webhook-delivery
#                 products.
#
# Round-number 245 landmark fires simultaneously across all three lanes:
# Rust completion #245 (_svix-server) + Go completion #245 (_outpost) +
# TS-Node completion #245 (_openpaas-cli) = triple-245.  Axis #183 closed
# in the lifetime of the corpus — every canonical AMQP 0.9.1 / RabbitMQ
# client library in the three big systems languages now has both a
# representative consumer completion AND a documented axis closure
# landmark.
# ============================================================================

_openpaas-cli() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show CLI help]' \
        '(- *)--version[show CLI version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'configure:write initial OpenPaaS ESN configuration to MongoDB (idempotent — safe to re-run on existing deployments)'
                'db:database migration / inspection tools (apply pending schema migrations, dump current state)'
                'docker-dev:Docker-based development environment lifecycle (bring up / tear down the dev-mode stack)'
                'domain:manage tenant domains (a domain ≈ a customer organization; nested subcommands for create / list / delete / configure)'
                'elasticsearch:Elasticsearch backend operations (reindex / verify mapping / cluster status)'
                'generateJWT:mint an admin JWT for accessing the OpenPaaS admin API'
                'init:first-time setup wizard for fresh OpenPaaS deployments'
                'james:Apache James SMTP/IMAP/JMAP server admin proxy (nested subcommands forwarded to the James REST API)'
                'platformadmin:cross-domain platform administrator management (nested subcommands)'
                'populate:seed the ESN with demo data (users / domains / communities / messages) for development and testing'
                'help:show CLI help (or help for a specific subcommand)'
            )
            _describe -t commands 'openpaas-cli command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                domain)
                    _arguments \
                        '1: :->domaincmds' && ret=0
                    case $state in
                        domaincmds)
                            local -a domsubs
                            domsubs=(
                                'create:create a new tenant domain'
                                'list:list all tenant domains'
                                'delete:delete a tenant domain (irreversible)'
                                'configure:update domain configuration'
                            )
                            _describe -t domain-commands 'domain subcommand' domsubs && ret=0
                            ;;
                    esac
                    ;;
                james)
                    _arguments \
                        '1: :->jamescmds' && ret=0
                    case $state in
                        jamescmds)
                            local -a jamessubs
                            jamessubs=(
                                'add-domain:register a new mail domain in Apache James'
                                'remove-domain:remove a mail domain from Apache James'
                                'list-domains:list mail domains currently configured in Apache James'
                                'add-user:create a mailbox in James'
                                'remove-user:delete a mailbox from James'
                                'reindex:rebuild Apache James'\''s search index'
                            )
                            _describe -t james-commands 'james subcommand' jamessubs && ret=0
                            ;;
                    esac
                    ;;
                platformadmin)
                    _arguments \
                        '1: :->pacmds' && ret=0
                    case $state in
                        pacmds)
                            local -a pasubs
                            pasubs=(
                                'add:promote a user to platform administrator (gains cross-domain visibility)'
                                'remove:revoke platform-administrator status from a user'
                                'list:list all platform administrators'
                            )
                            _describe -t platformadmin-commands 'platformadmin subcommand' pasubs && ret=0
                            ;;
                    esac
                    ;;
                help)
                    local -a allsubs
                    allsubs=(configure db docker-dev domain elasticsearch generateJWT init james platformadmin populate)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_openpaas-cli "$@"
