#compdef cargo-wasi

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:compile the current package for WASI'
      'check:check the current package for errors'
      'run:run a binary compiled for WASI'
      'test:run tests for WASI'
      'bench:run benchmarks for WASI'
      'self:manage the cargo-wasi installation'
    )
    _describe -t commands 'cargo wasi command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build|check|run|test|bench)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-p+[package to build]:package:' \
          '--package=[package to build]:package:' \
          '--all[build all packages]' \
          '--workspace[build all packages in workspace]' \
          '--release[build in release mode]' \
          '--profile=[build profile]:profile:' \
          '--features=[features to activate]:features:' \
          '--all-features[activate all features]' \
          '--no-default-features[do not activate default features]' \
          '-j+[number of parallel jobs]:jobs:' \
          '--jobs=[number of parallel jobs]:jobs:' \
          '--lib[build only the library]' \
          '--bin=[build specific binary]:binary:' \
          '--bins[build all binaries]' \
          '--example=[build specific example]:example:' \
          '--examples[build all examples]' \
          '--test=[build specific test]:test:' \
          '--tests[build all tests]' \
          '-v[verbose output]' \
          '--verbose[verbose output]' \
          '*:args:' && ret=0
        ;;
      self)
        local -a self_commands=(
          'update:update cargo-wasi'
          'clean:clean cache'
        )
        _describe -t commands 'self command' self_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
