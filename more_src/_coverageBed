#compdef coverageBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/coverage.html
# compute depth and breadth of coverage of B on A (bedtools coverage)

local ret=1

_arguments -s -S \
  '-a[query file (BAM/BED/GFF/VCF)]:file:_files' \
  '*-b[database file(s)]:file:_files' \
  '-abam[BAM file as input A (deprecated)]:file:_files' \
  '-hist[report a histogram of coverage]' \
  '-d[report the depth at each position in each A feature]' \
  '-counts[only report the count of overlaps]' \
  '-f[minimum overlap as fraction of A]:fraction' \
  '-F[minimum overlap as fraction of B]:fraction' \
  '-r[require reciprocal overlap]' \
  '-e[satisfy minimum fraction for A OR B]' \
  '-s[force strandedness]' \
  '-S[require opposite strandedness]' \
  '-split[treat split BAM/BED12 entries as distinct intervals]' \
  '-sorted[memory-efficient algorithm for sorted input]' \
  '-g[genome file defining chromosome order]:file:_files' \
  '-header[print the header from the A file before results]' \
  '-sortout[sort database hits per record]' \
  '-nobuf[disable buffered output]' \
  '-iobuf[set read buffer size (K/M/G suffix)]:size' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
