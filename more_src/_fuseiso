#compdef fuseiso
# Mount ISO filesystem images via FUSE

local ret=1

_arguments -s -S \
  '-p[specify file permissions]:permissions:' \
  '-n[do not maintain .toc file]' \
  '-c[specify character set]:charset:' \
  '-h[show help]' \
  '--help[show help]' \
  '-o[FUSE mount options]:options:' \
  '1:ISO image:_files -g "*.iso"' \
  '2:mount point:_files -/' && ret=0

return ret
