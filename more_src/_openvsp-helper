#compdef openvsp-helper
# Documentation: https://man.archlinux.org/search?q=openvsp-helper
# Reference accessed: 2026-05-16

# openvsp-helper: out-of-process worker invoked by OpenVSP
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::helper args (typically invoked by OpenVSP, not user):_files' && ret=0
return ret
