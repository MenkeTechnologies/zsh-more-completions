#compdef qorder
# _qorder-pbs — PBS qorder (swap the order of two queued PBS jobs in their PBS queue so scheduler ranking changes; positional arguments are jobID1 jobID2 — both must be in the same queue and in a state where they can be reordered)
# upstream: https://github.com/openpbs/openpbs
# Argument shape from openpbs src/cmds/qorder.c on tip.

_qorder-pbs() {
    _arguments \
        '1:first jobID:' \
        '2:second jobID:'
}

_qorder-pbs "$@"
