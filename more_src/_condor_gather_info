#compdef condor_gather_info
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_gather_info.html
# gather and tar information about an HTCondor job and installation for support

local ret=1

_arguments -s -S \
  '-jobid[data mine information about this job]:ClusterId.ProcId' \
  '-scratch[path to temporary space for building the output tar file]:directory:_files -/' && ret=0

return ret
