#compdef btfdiff
# Documentation: dwarves btfdiff
# Source: acmel/dwarves btfdiff (master) — diff DWARF vs BTF output via pahole (bash).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:DWARF (or BTF+DWARF) filename:_files' \
    '2::BTF filename:_files' \
    && ret=0

return ret
