#compdef sftahsort
# Documentation: http://www.ahay.org/RSF/sftahsort.html
# Madagascar: sort trace-and-header (tah) data by header keys

local ret=1

_arguments -s \
  'headers=[trace header file name (default input _hdr.rsf)]:file:_files' \
  'input=[input file for trace amplitudes]:file:_files' \
  'sort=[list of sort keys (+ascending, -descending)]:keys' \
  'verbose=[print level: 0 terse 1 info 2 chatty 3 debug]:level:(0 1 2 3)' \
  '*:rsf file:_files' && ret=0

return ret
