#compdef ansifilter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-H --html)'{-H,--html}'[output HTML]' \
  '(-L --latex)'{-L,--latex}'[output LaTeX]' \
  '(-P --pango)'{-P,--pango}'[output Pango markup]' \
  '(-R --rtf)'{-R,--rtf}'[output RTF]' \
  '(-T --text)'{-T,--text}'[output plain text]' \
  '(-B --bbcode)'{-B,--bbcode}'[output BBCode]' \
  '(-M --svg)'{-M,--svg}'[output SVG]' \
  '(-i --input)'{-i,--input}'[input file]:file:_files' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-e --encoding)'{-e,--encoding}'[set encoding]:encoding' \
  '--font=[font name]:font' \
  '--font-size=[font size]:size' \
  '--line-numbers[add line numbers]' \
  '--wrap-no-numbers[wrap lines without numbers]' \
  '--no-trailing-nl[omit trailing newline]' \
  '--art-cp437[use code page 437 art]' \
  '--art-bin[use binary art]' \
  '--art-tundra[use Tundra art]' \
  '--map=[color map file]:file:_files' \
  '--anchors[add HTML anchors]' \
  '--title=[set document title]:title' \
  '--stylesheet=[use CSS stylesheet]:file:_files -g "*.css"' \
  '*:file:_files' && ret=0

return ret
