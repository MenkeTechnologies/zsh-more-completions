#compdef conventional-recommended-bump
# _conventional-recommended-bump — recommend semver bump from conventional commits
# upstream: https://github.com/conventional-changelog/conventional-changelog
# Flags from packages/conventional-recommended-bump/src/cli/index.ts (meow).

_conventional-recommended-bump() {
    _arguments \
        '(-p --preset)'{-p+,--preset=}'[preset name]:preset:(angular atom codemirror conventionalcommits ember eslint express jquery jshint)' \
        '(-g --config)'{-g+,--config=}'[config script path]:file:_files' \
        '(-h --header-pattern)'{-h+,--header-pattern=}'[regex for header pattern]:regex:' \
        '(-c --header-correspondence)'{-c+,--header-correspondence=}'[capturing group meaning]:list:' \
        '(-r --reference-actions)'{-r+,--reference-actions=}'[keywords referencing issues]:list:' \
        '(-i --issue-prefixes)'{-i+,--issue-prefixes=}'[issue prefixes]:list:' \
        '(-n --note-keywords)'{-n+,--note-keywords=}'[keywords for important notes]:list:' \
        '(-f --field-pattern)'{-f+,--field-pattern=}'[regex for other fields]:regex:' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-l --lerna-package)'{-l+,--lerna-package=}'[recommend bump for lerna package]:pkg:' \
        '(-t --tag-prefix)'{-t+,--tag-prefix=}'[tag prefix]:prefix:' \
        '--commit-path=[scope bump to a directory]:dir:_files -/' \
        '--skip-unstable[skip unstable tags (alpha/rc)]'
}

_conventional-recommended-bump "$@"
