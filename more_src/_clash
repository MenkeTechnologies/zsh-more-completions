#compdef clash

# Zsh completion for clash (rule-based network tunnel proxy)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d+[Set configuration directory]:directory:_files -/' \
  '-f+[Specify configuration file]:config file:_files -g "*.{yaml,yml}"' \
  '-ext-ctl+[Override external controller address]:address' \
  '-ext-ui+[Set path to external UI]:path:_files -/' \
  '-secret+[Override secret for external controller]:secret' \
  '-t[Test configuration and exit]' \
  '-v[Print version]' && ret=0

return ret
