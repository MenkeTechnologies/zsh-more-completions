# brush — reubeno/brush brush-shell/src/args.rs CommandLineArgs (bash-compatible Rust shell).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--config=[TOML config path]:file:_files' \
  '--no-config[skip config file]' \
  {-C}'[enable noclobber]' \
  {-c+}'[run command string then exit]' \
  {-e}'[exit on non-zero command]' \
  {-f}'[disable pathname globbing]' \
  {-i}'[force interactive]' \
  '--inherit-fd+[inherited FD number]:fd' \
  '(-l --login)'{-l,--login}'[login shell]' \
  {-n}'[read commands but do not execute]' \
  '--noediting[disable readline]' \
  '--noprofile[skip profile files]' \
  '--norc[skip rc files in interactive]' \
  '--noinheritenv[do not inherit environment]' \
  '*::script and args:_normal' && ret=0

return ret
