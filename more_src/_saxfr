#compdef saxfr
# Documentation: https://doc.powerdns.com/authoritative/manpages/saxfr.1.html
# Perform an AXFR zone transfer and display the zone with NSEC3 information

local ret=1

_arguments -s -S \
  '1:ipaddress:_hosts' \
  '2:port:_ports' \
  '3:zone:' \
  '*:option:(showdetails showflags unhash)' && ret=0

return ret
