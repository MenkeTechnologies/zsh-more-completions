#compdef neovim-qt nvim-qt
# Documentation: https://man.archlinux.org/search?q=neovim-qt
# Reference accessed: 2026-05-16

# neovim-qt: Qt5/Qt6 GUI for Neovim
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--server=[connect to nvim server]:server:' \
  '--embed[start neovim in embed mode]' \
  '--spawn[spawn neovim]' \
  '--nofork[do not fork from terminal]' \
  '--maximized[start maximized]' \
  '--fullscreen[start fullscreen]' \
  '--geometry=[WxH+X+Y]:geometry:' \
  '--stylesheet=[Qt stylesheet]:file:_files' \
  '--qwindowicon=[window icon]:icon:' \
  '--no-ext-tabline[disable ext_tabline]' \
  '--no-ext-popupmenu[disable ext_popupmenu]' \
  '--detach[detach from terminal]' \
  '*:files:_files' && ret=0
return ret
