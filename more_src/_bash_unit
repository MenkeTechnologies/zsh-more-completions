#compdef bash_unit
# Documentation: https://man.archlinux.org/search?q=bash_unit
# Reference accessed: 2026-05-16

# Zsh completion for bash_unit (pgrange/bash_unit), getopts -vp:s:f:rq

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-v[print bash_unit version and exit]' \
  '-p+[run tests matching extended regex]' \
  '-s+[skip tests matching extended regex]' \
  '-f+[output format (tap in practice)]:format:(tap)' \
  '-r[shuffle test order]' \
  '-q[quiet expectations]' \
  '*:test script:_files' && ret=0

return ret
