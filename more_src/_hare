#compdef hare

# Zsh completion for hare programming language

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build:compile a Hare program'
      'cache:manage build cache'
      'deps:show dependency tree'
      'release:manage releases'
      'run:compile and run a Hare program'
      'test:compile and run tests'
      'version:show version info'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      build|run|test)
        _arguments -s -S \
          '-v[verbose output]' \
          '-D[define a constant]:name=value' \
          '-j[set number of jobs]:jobs' \
          '-l[link with a library]:library' \
          '-L[add library search path]:path:_directories' \
          '-T[set tags]:tags' \
          '-o[output file]:file:_files' \
          '-R[set release mode]' \
          '-t[set target]:target' \
          '(- *)'{-h,--help}'[show help]' \
          '*:source:_files -g "*.ha"' && ret=0
        ;;
      cache)
        _arguments -s -S \
          '1:action:(clean)' && ret=0
        ;;
      deps)
        _arguments -s -S \
          '-T[set tags]:tags' \
          '-d[show as dot graph]' \
          '-M[show module source paths]' \
          '*:module' && ret=0
        ;;
    esac
    ;;
esac

return ret
