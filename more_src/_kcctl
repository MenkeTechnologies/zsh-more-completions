#compdef kcctl
# Documentation: https://github.com/kcctl/kcctl/blob/main/kcctl_completion
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (shipped completion + picocli
# command classes). kcctl is the Kafka Connect CLI (NOT KubeClipper);
# prior file had fabricated deploy/join/reset subcommands.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'info:display information about the Kafka Connect cluster'
  'config:set or retrieve the configuration of this client'
  'get:display info about plugins, offsets, connectors, loggers'
  'describe:display detailed info about the specified resources'
  'apply:apply files or stdin to register/update connectors'
  'patch:modify connector offsets, configs, or logger levels'
  'restart:restart connectors or a task'
  'pause:pause connectors'
  'resume:resume connectors'
  'stop:stop (but do not delete) connectors'
  'delete:delete connectors or their offsets'
  'help:display help information about the specified command'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'kcctl command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (config)
        _values 'config subcommand' \
          'set-context' 'get-contexts' 'current-context' 'use-context' && ret=0
        ;;
      (get)
        _values 'get subcommand' \
          'plugins' 'connectors' 'offsets' 'loggers' 'logger' && ret=0
        ;;
      (describe)
        _values 'describe subcommand' 'connector' 'connectors' 'plugin' && ret=0
        ;;
      (patch)
        _values 'patch subcommand' \
          'logger' 'connector' 'connectors' 'offsets' && ret=0
        ;;
      (restart)
        _values 'restart subcommand' 'connector' 'connectors' 'task' && ret=0
        ;;
      (pause|resume|stop)
        _values 'subcommand' 'connector' 'connectors' && ret=0
        ;;
      (delete)
        _values 'delete subcommand' 'connector' 'connectors' 'offsets' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
