#compdef charmcraft

# Zsh completion for charmcraft (Juju charm builder)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-v[Use verbose output]' \
  '--verbose[Use verbose output]' \
  '-q[Suppress non-essential output]' \
  '--quiet[Suppress non-essential output]' \
  '--trace[Show trace output]' \
  '--project-dir=[Project directory]:dir:_directories' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Initialize a charm directory'
      'pack:Build the charm'
      'publish:Push and release a charm to the store'
      'upload:Upload a charm to the store'
      'release:Release a charm revision to a channel'
      'login:Login to Charmhub'
      'logout:Logout from Charmhub'
      'whoami:Show current login info'
      'register:Register a charm name on Charmhub'
      'list-registered:List registered charms'
      'revisions:List revisions for a charm'
      'status:Show channel status for a charm'
      'close:Close a channel for a charm'
      'resources:List resources for a charm'
      'upload-resource:Upload a resource for a charm'
      'fetch-lib:Fetch a published library'
      'list-lib:List published libraries'
      'publish-lib:Publish a library'
      'create-lib:Create a new library'
      'extensions:List available extensions'
      'expand-extensions:Show expanded config with extensions'
      'clean:Remove build artifacts'
    )
    _describe -t commands 'charmcraft command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--name=[Charm name]:name' \
          '--author=[Author name]:author' \
          '-p+[Project directory]:dir:_directories' \
          '--project-dir=[Project directory]:dir:_directories' \
          '--profile=[Profile to use]:profile:(simple kubernetes machine)' \
          '-f[Force overwrite existing files]' \
          '--force[Force overwrite existing files]' && ret=0
        ;;
      pack)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--destructive-mode[Build in current system instead of container]' \
          '--shell[Drop into shell on error]' \
          '--shell-after[Drop into shell after build]' \
          '--bases-index=[Index of base to build]:index' && ret=0
        ;;
      publish|release)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--channel=[Channel to release to]:channel' \
          '--resource=[Resource to attach]:resource' \
          '1:charm-name' && ret=0
        ;;
      upload)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--release=[Release to channel after upload]:channel' \
          '--resource=[Resource to attach]:resource' \
          '1:charm-file:_files -g "*.charm"' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
