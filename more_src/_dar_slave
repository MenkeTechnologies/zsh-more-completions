#compdef dar_slave
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/dar_slave.1.html
# dar_slave - disk archive slave for remote dar operations over a pipe

local ret=1

_arguments -s \
  '-h[display help usage]' \
  '-V[display version information]' \
  '-i[read orders from the named file instead of standard input]:input pipe:_files' \
  '-o[send data to the named file instead of standard output]:output pipe:_files' \
  '-E[command to be launched between slices]:command' \
  '-Q[suppress stderr messages when not run from a terminal]' \
  '-9[minimum number of digits to use for slice numbers]:digits' \
  '*:archive basename:_files' && ret=0

return ret
