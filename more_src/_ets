#compdef ets
# Documentation: https://man.archlinux.org/search?q=ets
# Reference accessed: 2026-05-16

# https://github.com/manishsingh10895/ets-cli — manual dispatch in main.rs

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->a' \
  '*::arg:->args' && ret=0

case $state in
  (a)
    local -a _ets_a
    _ets_a=(
      'n:create express project'
      'g:generate source file'
    )
    _describe -t verbs 'ets verb' _ets_a && ret=0
    ;;
  (args)
    case $line[1] in
      (n|new)
        _arguments ':project directory:' && ret=0 ;;
      (g|generate)
        if (( $#line == 1 )); then
          local -a _ets_g
          _ets_g=(
            r:route
            c:controller
            rs:request-schema
            sc:scaffold
            m:model
            mw:middleware
            s:service
          )
          _describe -t kinds 'generator' _ets_g && ret=0
        else
          _arguments ':resource name:' && ret=0
        fi ;;
    esac ;;
esac

return ret
