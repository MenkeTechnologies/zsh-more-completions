#compdef create-volo-app
# Documentation: https://www.npmjs.com/package/create-volo-app
# Reference accessed: 2026-05-24
# Verified: npm view create-volo-app bin; dist/index.js commander options and npm readme.

# Zsh completion for create-volo-app - React + Firebase + Postgres fullstack scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--full[scaffold with production services hooked up]' \
  '--fast[non-interactive fast scaffold path]' \
  '--auth[enable production Firebase authentication setup]' \
  '--database=[database provider]:provider:(neon supabase)' \
  '--deploy[enable deployment setup]:provider:(cloudflare)' \
  '--connect[connect services to an existing project]' \
  '--config=[path to volo-config.json]:file:_files' \
  '--init-config[write a starter volo-config.json and exit]' \
  '(-t --template)'{-t,--template=}'[template URL or local path]:template:' \
  '--verbose[verbose logging]' \
  ':project name:' && ret=0

return ret
