#compdef cosign
# Documentation: https://man.archlinux.org/search?q=cosign
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'attach:attach signature/sbom/attestation'
  'attest:attest a container image'
  'attest-blob:attest a blob'
  'clean:remove signatures from image'
  'completion:generate completion'
  'copy:copy artifacts to another repo'
  'debug:debug commands'
  'download:download signatures/sboms/attestations'
  'env:print environment'
  'generate:generate signing payload'
  'generate-key-pair:generate signing key pair'
  'help:show help'
  'import-key-pair:import existing key pair'
  'initialize:initialize TUF root'
  'load:load signed image from disk'
  'login:login to OCI registry'
  'logout:logout'
  'manifest:manifest commands'
  'piv-tool:PIV tool'
  'pkcs11-tool:PKCS11 tool'
  'public-key:show public key'
  'save:save image to disk'
  'sign:sign a container image'
  'sign-blob:sign a blob'
  'tree:print signature/sbom/attestation tree'
  'triangulate:image artifact url for OCI'
  'trusted-root:trusted root commands'
  'verify:verify image signature'
  'verify-attestation:verify attestation'
  'verify-blob:verify blob'
  'verify-blob-attestation:verify blob attestation'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--output-file=[output file]:file:_files' \
  '*--timeout=[timeout]:t:' \
  '*-t+[timeout]:t:' \
  '*-d[debug]' \
  '*--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cosign command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sign)
        _arguments \
          '*--key=[private key]:file:_files' \
          '*--cert=[cert]:file:_files' \
          '*--cert-chain=[cert chain]:file:_files' \
          '*--certificate-identity=[identity]:i:' \
          '*--certificate-identity-regexp=[identity re]:re:' \
          '*--certificate-oidc-issuer=[OIDC issuer]:i:' \
          '*--certificate-oidc-issuer-regexp=[issuer re]:re:' \
          '*-a+[annotation k=v]:a:' \
          '*--annotations=[annotations csv]:list:' \
          '*--allow-insecure-registry[allow insecure]' \
          '*--allow-http-registry[allow HTTP]' \
          '*--attachment=[attachment]:a:(sbom)' \
          '*-r[recursive]' \
          '*--recursive[recursive]' \
          '*-y[yes]' \
          '*--yes[yes]' \
          '*--registry-token=[registry token]:t:' \
          '*--rekor-url=[Rekor URL]:url:' \
          '*--fulcio-url=[Fulcio URL]:url:' \
          '*--insecure-skip-verify[insecure skip verify]' \
          '*--key-ref=[key ref]:k:' \
          '*--bundle=[bundle file]:file:_files' \
          '*--rfc3161-timestamp=[rfc3161 file]:file:_files' \
          '*--tlog-upload=[tlog upload]:b:(true false)' \
          '*--no-tlog-upload[no tlog upload]' \
          '*--upload=[upload]:b:(true false)' \
          '*--sign-container-identity=[sign container identity]:i:' \
          '*--sk[use SK auth]' \
          '*: :' && ret=0 ;;
      (verify|verify-attestation|verify-blob|verify-blob-attestation)
        _arguments \
          '*--key=[public key]:file:_files' \
          '*--certificate=[cert]:file:_files' \
          '*--certificate-identity=[identity]:i:' \
          '*--certificate-identity-regexp=[identity re]:re:' \
          '*--certificate-oidc-issuer=[issuer]:i:' \
          '*--certificate-oidc-issuer-regexp=[issuer re]:re:' \
          '*--certificate-chain=[chain]:file:_files' \
          '*--certificate-github-workflow-trigger=[trigger]:t:' \
          '*--certificate-github-workflow-sha=[sha]:s:' \
          '*--certificate-github-workflow-name=[name]:n:' \
          '*--certificate-github-workflow-repository=[repo]:r:' \
          '*--certificate-github-workflow-ref=[ref]:r:' \
          '*--rekor-url=[Rekor URL]:url:' \
          '*--insecure-ignore-tlog[ignore tlog]' \
          '*--insecure-ignore-sct[ignore SCT]' \
          '*--bundle=[bundle file]:file:_files' \
          '*--annotations=[annotations]:a:' \
          '*--type=[predicate type]:t:' \
          '*--policy=[policy file]:file:_files' \
          '*-o+[output]:f:(json text)' \
          '*--output=[output]:f:(json text)' \
          '*: :' && ret=0 ;;
      (generate-key-pair)
        _arguments \
          '*--output-key-prefix=[prefix]:p:' \
          '*--kms=[KMS URI]:k:' \
          '*: :' && ret=0 ;;
      (download)
        _arguments \
          '1:subcommand:(signature sbom attestation)' \
          '*: :' && ret=0 ;;
      (manifest)
        _arguments \
          '1:subcommand:(verify)' \
          '*: :' && ret=0 ;;
      (debug)
        _arguments \
          '1:subcommand:(token)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
