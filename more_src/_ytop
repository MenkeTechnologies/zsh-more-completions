#compdef ytop

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --average-cpu)'{-a,--average-cpu}'[show average CPU in CPU widget]' \
  '(-b --battery)'{-b,--battery}'[show battery widget]' \
  '(-c --celsius)'{-c,--celsius}'[show temperatures in Celsius]' \
  '(-f --fahrenheit)'{-f,--fahrenheit}'[show temperatures in Fahrenheit]' \
  '(-s --statusbar)'{-s,--statusbar}'[show statusbar]' \
  '(-I --interfaces)'{-I,--interfaces}'[comma-separated list of network interfaces]:interfaces' \
  '(-p --per-cpu)'{-p,--per-cpu}'[show per-CPU graph]' \
  '(-r --rate)'{-r,--rate}'[refresh rate in seconds]:seconds'
