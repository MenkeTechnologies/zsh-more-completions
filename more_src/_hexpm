#compdef hexpm
# _hexpm — hexpm CLI client to the Hex.pm package management hosting service for the Erlang Elixir BEAM ecosystem listing packages owners releases checksums search-by-name-by-description retire-undeprecate-organization-account-key-token management for Erlang OTP-mix-rebar3-friendly package publishing workflows (Hex.pm team, Elixir); custom argparse
# upstream: https://hex.pm/

_hexpm() {
    local -a sub=(
        'audit:audit dependencies for vulnerabilities'
        'build:build a release'
        'config:show or set configuration'
        'docs:show or upload docs'
        'fetch:fetch a release'
        'info:show package info'
        'install:install a package'
        'organization:organization management'
        'outdated:show outdated dependencies'
        'owner:manage package owners'
        'package:fetch package data'
        'private:manage private packages'
        'profile:profile management'
        'publish:publish a release'
        'retire:retire a release'
        'revive:revive a retired release'
        'search:search packages'
        'sponsor:sponsor management'
        'user:user management'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--organization=+[name]:str:' \
        '--repo=+[repo]:str:' \
        '--api-url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--api-key=+[key]:str:' \
        '-f+[format]:f:(json yaml table)' \
        '--format=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hexpm subcommand' sub ;;
        args)
            case $words[1] in
                info|owner|fetch|install|retire|revive|search|package) _arguments '*:package:' ;;
                publish|docs) _arguments '*:tarball:_files -g "*.tar"' ;;
            esac
            ;;
    esac
}

_hexpm "$@"
