#compdef nflog-tool nflog-watcher
# _nflog-tool — netfilter NFLOG userspace helper (small reader binary that subscribes to a kernel NFLOG group and prints / writes received packets to pcap; -g group, -p pcap output, -d daemonize, -q quiet, -v verbose, -V version; useful when configuring iptables --jump NFLOG --nflog-group N)
# upstream: https://git.netfilter.org/libnetfilter_log (utils)
# Flags from libnetfilter_log examples/nfulnl_test.c on tip.

_nflog-tool() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-g+[group]:group:' \
        '-p+[pcap output]:file:_files -g "*.(pcap|pcapng)"' \
        '-d[daemonize]' \
        '-q[quiet]' \
        '-v[verbose]'
}

_nflog-tool "$@"
