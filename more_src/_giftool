#compdef giftool

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-b+[background color]:color:' \
  '-d+[delay (1/100 sec)]:delay:' \
  '-i[interlace]' \
  '-I[non-interlace]' \
  '-t+[transparent color]:color:' \
  '-u[unloop animation]' \
  '-U[loop animation]' \
  '-x+[disposal method]:disposal:(0 1 2 3)' \
  '*:GIF file:_files -g "*.gif"' && ret=0

return ret
