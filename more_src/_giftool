#compdef giftool
# Documentation: https://giflib.sourceforge.net/gif_lib.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-a+[set aspect-ratio byte]:aspect:' \
  '-b+[background color index]:color:' \
  '-d+[delay in 1/100 sec]:delay:' \
  '-f+[printf-style format string]:format:' \
  '-i+[set/clear interlacing]:flag:(1 0 yes no on off t f)' \
  '-n+[image index list (1-origin)]:indices:' \
  '-p+[upper-left corner x,y]:coords:' \
  '-s+[expected display size x,y]:size:' \
  '-t+[transparency color index]:color:' \
  '-u+[set/clear user-input flag]:flag:(1 0 yes no on off t f)' \
  '-x+[GIF89 disposal mode]:disposal:(0 1 2 3)' \
  '-z+[set/clear color-table sort flag]:flag:(1 0 yes no on off t f)' \
  '*:GIF file:_files -g "*.gif"' && ret=0

return ret
