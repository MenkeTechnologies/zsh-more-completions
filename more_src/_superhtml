#compdef superhtml
# Documentation: https://man.archlinux.org/search?q=superhtml
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:check HTML and SuperHTML documents'
      'fmt:format HTML and SuperHTML files'
      'lsp:start the language server'
      'help:show usage and exit'
      'version:print version and exit'
    )
    _describe -t commands 'superhtml command' commands && ret=0
    ;;
  args)
    case $line[1] in
      check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[print check usage and exit]' \
          '--syntax-only[disable element and attribute validation]' \
          '--stdin[read HTML from stdin instead of paths]' \
          '--stdin-super[read SuperHTML from stdin instead of paths]' \
          '-[read HTML from stdin (same as --stdin)]' \
          '*:path:_files' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '(- *)'{-h,--help}'[print fmt usage and exit]' \
          '--syntax-only[disable element and attribute validation]' \
          '--check[list non-conforming files without writing]' \
          '--stdin[read HTML from stdin; write formatted HTML to stdout]' \
          '--stdin-super[read SuperHTML from stdin; write formatted source to stdout]' \
          '-[read HTML from stdin (same as --stdin)]' \
          '*:path:_files' && ret=0
        ;;
      lsp)
        _arguments -s -S \
          '--syntax-only[disable element and attribute validation]' && ret=0
        ;;
      help|version)
        _nothing && ret=0
        ;;
    esac
    ;;
esac

return ret
