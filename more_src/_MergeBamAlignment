#compdef MergeBamAlignment
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/MergeBamAlignment.java
# Picard: merge alignment data with the unmapped reads in an unaligned BAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-UNMAPPED --UNMAPPED_BAM)'{-UNMAPPED,--UNMAPPED_BAM}'=[unaligned BAM in queryname order]:file:_files' \
  '*'{-ALIGNED,--ALIGNED_BAM}'=[SAM/BAM file(s) with alignment data]:file:_files' \
  '*'{-R1_ALIGNED,--READ1_ALIGNED_BAM}'=[alignment data for first read of pair]:file:_files' \
  '*'{-R2_ALIGNED,--READ2_ALIGNED_BAM}'=[alignment data for second read of pair]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[merged output file]:file:_files' \
  '(-PG --PROGRAM_RECORD_ID)'{-PG,--PROGRAM_RECORD_ID}'=[aligner program group ID]:pg:' \
  '(-PG_VERSION --PROGRAM_GROUP_VERSION)'{-PG_VERSION,--PROGRAM_GROUP_VERSION}'=[program group version]:ver:' \
  '(-PG_COMMAND --PROGRAM_GROUP_COMMAND_LINE)'{-PG_COMMAND,--PROGRAM_GROUP_COMMAND_LINE}'=[program group command line]:cmd:' \
  '(-PG_NAME --PROGRAM_GROUP_NAME)'{-PG_NAME,--PROGRAM_GROUP_NAME}'=[program group name]:name:' \
  '--CLIP_ADAPTERS=[clip adapters where identified]:b:(true false)' \
  '--IS_BISULFITE_SEQUENCE=[lane is bisulfite sequence]:b:(true false)' \
  '--ALIGNED_READS_ONLY=[output only aligned reads]:b:(true false)' \
  '(-MAX_GAPS --MAX_INSERTIONS_OR_DELETIONS)'{-MAX_GAPS,--MAX_INSERTIONS_OR_DELETIONS}'=[max indels per alignment (-1 unlimited)]:n:' \
  '(-SO --SORT_ORDER)'{-SO,--SORT_ORDER}'=[output sort order]:order:(coordinate queryname unsorted)' \
  '(-MC --ADD_MATE_CIGAR)'{-MC,--ADD_MATE_CIGAR}'=[add mate CIGAR (MC) tag]:b:(true false)' \
  '(-UNMAP_CONTAM --UNMAP_CONTAMINANT_READS)'{-UNMAP_CONTAM,--UNMAP_CONTAMINANT_READS}'=[unmap foreign-organism reads]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
