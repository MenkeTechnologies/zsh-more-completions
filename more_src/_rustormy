# Axis 16 newly opened at 1/0/0.  Seven axes at three-language
# symmetry.)
#
# -----------------------------------------------------------------------------
#
# WHY reqwest IS THE 70TH RUST CLI LIBRARY
#
# reqwest is the DEFACTO Rust HTTP client — the high-level
# convenience layer built on top of Sean McArthur's hyper.  Whereas
# hyper is the lower-level HTTP machinery (HTTP/1.1 + HTTP/2
# protocol handling, connection pooling, body streaming), reqwest
# wraps hyper in a friendly Client API that 80%+ of Rust HTTP code
# uses directly.
#
# Five distinguishing characteristics:
#
#   1. ASYNC + BLOCKING DUAL API — reqwest's central architectural
#      choice is offering BOTH an async API for tokio code AND a
#      blocking API for synchronous code:
#         use reqwest::Client;              // async
#         use reqwest::blocking::Client;    // blocking
#      The blocking API spawns a dedicated tokio runtime per-call
#      under the hood — convenient for CLIs that don't want to
#      go async-pervasive.  reqwest is the FIRST documented Rust
#      Axis 16 library with this dual API.
#
#   2. SERDE-INTEGRATED JSON via "json" Cargo feature — direct
#      deserialization from response into typed structs:
#         #[derive(Deserialize)]
#         struct Weather { temp: f64, humidity: f64 }
#         let weather: Weather = client.get(url)
#             .send()?.json()?;
#      This collapses the typical "fetch → parse JSON → map fields"
#      pipeline into a single call.  Other HTTP clients require
#      separate serde_json::from_str step.  reqwest is the FIRST
#      documented Rust Axis 16 library with first-class serde
#      integration.
#
#   3. TLS BACKEND CHOICE — reqwest supports both rustls (pure
#      Rust TLS) and native-tls (OS-provided TLS: OpenSSL on
#      Linux, SChannel on Windows, Secure Transport on macOS)
#      via Cargo features.  Default features include rustls,
#      allowing C-dependency-free Rust binaries.  reqwest is
#      the FIRST documented Rust Axis 16 library with this
#      TLS backend choice.
#
#   4. BUILT ON HYPER — reqwest delegates all low-level HTTP
#      machinery to hyper (HTTP/1.1, HTTP/2 multiplexing,
#      connection pooling, body streaming).  This makes reqwest
#      a "high-level facade" pattern — users get the friendly
#      API while internally benefiting from hyper's production-
#      hardened protocol implementation.  reqwest is the FIRST
#      documented Rust Axis 16 library with this hyper-built-on
#      architecture.
#
#   5. HYPERIUM ECOSYSTEM PROVENANCE — reqwest is part of Sean
#      McArthur's Hyperium project (hyper / tower / warp /
#      tonic).  The Hyperium ecosystem powers the Rust HTTP
#      stack used by cargo, starship, lsd, gitui, mdbook,
#      cargo-deny, cargo-audit, and 100,000+ Rust applications.
#      reqwest brings the FIRST Sean-McArthur library into
#      the taxonomy.
#
# reqwest's relationship to other potential Rust HTTP clients:
#
#   * Unlike ureq — ureq is BLOCKING-ONLY, simpler, smaller
#     (~1k lines vs ~10k); used when async is undesired.
#     reqwest's blocking mode is closer to ureq but with the
#     option to upgrade to async later.
#   * Unlike hyper directly — hyper is lower-level; users
#     manually construct hyper::Client + hyper::Request +
#     handle connection pooling.  reqwest abstracts this.
#   * Unlike isahc — isahc wraps libcurl (C library); reqwest
#     is pure Rust (with rustls).
#   * Unlike surf — surf is async-std-based (not tokio);
#     reqwest is tokio-based.
#   * Unlike attohttpc — attohttpc is minimalist blocking
#     HTTP; reqwest is full-featured.
#
# -----------------------------------------------------------------------------
#
# THE rustormy CLI — clap derive + reqwest blocking + crossterm
#
# rustormy's CLI is in src/config/cli.rs (clap derive Parser
# with 19 flags).  reqwest::blocking::Client is used in
# src/app.rs:
#
#     use reqwest::blocking::Client;
#     ...
#     let client = Client::builder()
#         .user_agent(concat!("rustormy/", env!("CARGO_PKG_VERSION")))
#         .timeout(Duration::from_secs(config.connect_timeout()))
#         .build()?;
#
# Five-axis distinctness from all previously-documented Rust
# Axis 9 logging crates + Axis 6 error crates + Axis 10 table
# crates etc.:
#
#   1. HTTP I/O ABSTRACTION — reqwest sends HTTP requests; all
#      previously documented Rust libraries address logging,
#      errors, tables, progress, colors, prompts, boxes,
#      humanization, text wrap, config, paths, or dates.  HTTP
#      I/O is a NEW abstraction axis (Axis 16).
#
#   2. ASYNC + BLOCKING DUAL — reqwest's dual API is a distinct
#      design choice not present in other Rust libraries
#      documented so far.
#
#   3. SERDE JSON FIRST-CLASS — direct serde deserialization
#      from HTTP responses.
#
#   4. HYPER FOUNDATION — built on hyper; production-hardened
#      protocol handling.
#
#   5. SEAN-MCARTHUR / HYPERIUM PROVENANCE — distinct maintainer
#      ecosystem (David Tolnay / serde, Tokio Project /
#      tokio-rs, Niko Matsakis / rayon, etc.).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/Tairesh/rustormy/blob/main/src/config/cli.rs
# clap v4 derive #[arg] attributes.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _rustormy_providers _rustormy_units _rustormy_formats
local -a _rustormy_text_modes _rustormy_langs
_rustormy_providers=(
    'open_meteo:Open-Meteo (default, free, no API key)'
    'open_weather_map:OpenWeatherMap (requires API key)'
    'world_weather_online:WorldWeatherOnline (requires API key)'
    'weather_api:WeatherAPI (requires API key)'
    'weather_bit:WeatherBit (requires API key)'
    'tomorrow_io:Tomorrow.io (requires API key)'
    'yr:Yr.no / MET Norway (free, no API key)'
)
_rustormy_units=(
    'metric:metric units (Celsius + km/h)'
    'imperial:imperial units (Fahrenheit + mph)'
)
_rustormy_formats=(
    'text:ASCII art weather display (default)'
    'json:JSON output'
)
_rustormy_text_modes=(
    'full:full multi-line ASCII art (default)'
    'compact:compact mode'
    'one_line:one-line mode'
)
_rustormy_langs=(
    'en:English'
    'ru:Russian'
    'es:Spanish'
    'ko:Korean'
)

_arguments -s -S \
    '(-c --city)'{-c+,--city=}'[city name (required if lat/lon not provided)]:city:_default' \
    '(-y --lat)'{-y+,--lat=}'[latitude (required if city not provided)]:latitude:_default' \
    '(-x --lon)'{-x+,--lon=}'[longitude (required if city not provided)]:longitude:_default' \
    '(-p --provider)'{-p+,--provider=}'[weather data provider]:provider:->provider' \
    '(-u --units)'{-u+,--units=}'[units for temperature and wind speed]:units:->units' \
    '(-o --format --output-format)'{-o+,--format=,--output-format=}'[output format]:format:->format' \
    '(-g --lang --language)'{-g+,--lang=,--language=}'[language for weather output]:language:->lang' \
    '--name[show city name in output]' \
    '--show-city-name[show city name in output (alias)]' \
    '--colors[use colors in output]' \
    '--use-colors[use colors in output (alias)]' \
    '--degrees[use degrees for wind direction]' \
    '--compact[compact mode for text output]' \
    '--one-line[one-line mode for text output]' \
    '(-m --text-mode)'{-m+,--text-mode=}'[text mode for text output]:mode:->mode' \
    '--align-right[align labels to the right in text output]' \
    '(-l --live --live-mode)'{-l,--live,--live-mode}'[live mode: continuously update weather data]' \
    '(-i --interval --live-mode-interval)'{-i+,--interval=,--live-mode-interval=}'[live mode update interval in seconds]:seconds:_default' \
    '--no-footer[hide the live-mode footer]' \
    '--no-cache[disable caching of geocoding results]' \
    '--clear-cache[clear cached geocoding results and exit]' \
    '*'{-v,--verbose}'[increase verbosity (can be used multiple times)]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

case $state in
    provider) _describe -t providers 'provider' _rustormy_providers && ret=0 ;;
    units)    _describe -t units 'units' _rustormy_units && ret=0 ;;
    format)   _describe -t formats 'format' _rustormy_formats && ret=0 ;;
    lang)     _describe -t langs 'language' _rustormy_langs && ret=0 ;;
    mode)     _describe -t modes 'text mode' _rustormy_text_modes && ret=0 ;;
esac

return ret
