#compdef nats-server-config-reloader
# _nats-server-config-reloader — NATS NACK sidecar that watches nats-server.conf files and SIGHUPs the server pid on change
# upstream: https://github.com/nats-io/nack
# Flags from cmd/nats-server-config-reloader/main.go on tip.

_nats-server-config-reloader() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-P --pid)'{-P,--pid}'=[NATS server pid file]:file:_files' \
        '*'{-c,--config}'=[NATS server config file (may be repeated)]:file:_files' \
        '--max-retries=[max attempts to trigger reload]:n:' \
        '--retry-wait-secs=[backoff seconds between failed reloads]:s:' \
        '--signal=[signal sent to the NATS server process (default SIGHUP=1)]:n:' \
        '--force-poll[force polling mode instead of inotify]' \
        '--poll-interval=[polling interval when using polling mode]:duration:' \
        '--max-watcher-retries=[max retries when creating an inotify watcher]:n:'
}

_nats-server-config-reloader "$@"
