#compdef yubico-piv-tool
# Documentation: https://developers.yubico.com/yubico-piv-tool/Manuals/yubico-piv-tool.1.html
# Reference accessed: 2026-05-21
# Verified: upstream Yubico yubico-piv-tool(1) manual.

# yubico-piv-tool: YubiKey PIV manager

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-a,--action}'[action to perform]:action:(version generate set-mgm-key reset pin-retries import-key import-certificate set-chuid request-certificate verify-pin verify-bio change-pin change-puk unblock-pin selfsign-certificate delete-certificate read-certificate read-public-key status test-signature test-decipher list-readers set-ccc write-object read-object attest move-key delete-key)' \
  '(-s --slot)'{-s,--slot}'[key slot]:slot:(9a 9c 9d 9e 82 83 84 85 86 87 88 89 8a 8b 8c 8d 8e 8f 90 91 92 93 94 95 f9)' \
  '(-A --algorithm)'{-A,--algorithm}'[algorithm]:algorithm:(RSA1024 RSA2048 RSA3072 RSA4096 ECCP256 ECCP384 ED25519 X25519)' \
  '(-H --hash)'{-H,--hash}'[hash algorithm]:hash:(SHA1 SHA256 SHA384 SHA512)' \
  '(-k --key)'{-k,--key}'[management key]:key' \
  '(-n --new-key)'{-n,--new-key}'[new management key]:key' \
  '(-m --new-key-algo)'{-m,--new-key-algo}'[management key algorithm]:algo:(TDES AES128 AES192 AES256)' \
  '(-i --input)'{-i,--input}'[input file]:input file:_files' \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '(-K --key-format)'{-K,--key-format}'[key format]:format:(PEM PKCS12 GZIP DER SSH)' \
  '(-f --format)'{-f,--format}'[data format]:format:(hex base64 binary)' \
  '(-p --password)'{-p,--password}'[private key password]:password' \
  '(-S --subject)'{-S,--subject}'[certificate subject]:subject' \
  '(-P --pin)'{-P,--pin}'[PIN/PUK]:pin' \
  '(-N --new-pin)'{-N,--new-pin}'[new PIN/PUK]:pin' \
  '--pin-policy=[PIN policy]:policy:(never once always matchonce matchalways)' \
  '--touch-policy=[touch policy]:policy:(never always cached)' \
  '(-r --reader)'{-r,--reader}'[card reader name]:reader' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]:level:'
