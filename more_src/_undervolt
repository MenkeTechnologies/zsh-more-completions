#compdef undervolt
# _undervolt — Intel CPU undervolting / power-limit utility (georgewhewell/undervolt)
# upstream: https://github.com/georgewhewell/undervolt
# Flags from undervolt.py (argparse).

_undervolt() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '(-v --verbose)'{-v,--verbose}'[enable verbose output]'
        '(-f --force)'{-f,--force}'[allow potentially unsafe operations]'
        '(-r --read)'{-r,--read}'[read existing offsets / power-limits / temp]'
        '--turbo=[Intel Turbo state (0=enabled, 1=disabled)]:state:(0 1)'
        '(-t --temp)'{-t+,--temp=}'[temperature target on AC (°C)]:celsius:'
        '--temp-bat=[temperature target on battery (°C)]:celsius:'
        '--throttlestop=[ThrottleStop XML profile path]:file:_files -g "*.xml"'
        '--tsindex=[ThrottleStop profile index]:n:'
        '(-p1 --power-limit-long)'{-p1+,--power-limit-long=}'[P1 power limit + time window (W s)]:limit:'
        '(-p2 --power-limit-short)'{-p2+,--power-limit-short=}'[P2 power limit + time window (W s)]:limit:'
        '--lock-power-limit[lock the configured power limits]'
        '--core=[core voltage offset (mV)]:offset:'
        '--gpu=[GPU voltage offset (mV)]:offset:'
        '--cache=[cache voltage offset (mV)]:offset:'
        '--uncore=[uncore voltage offset (mV)]:offset:'
        '--analogio=[analogio voltage offset (mV)]:offset:'
    )
    _arguments -s $args
}

_undervolt "$@"
