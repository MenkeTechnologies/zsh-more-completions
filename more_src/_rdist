#compdef rdist rdistd
# _rdist — rdist remote file distribution (sync files from a master host to multiple targets per a distfile rules language; -f distfile, -c label, -d KEY=VAL define variable, -m hostname (target one host), -n no-op (show what would happen), -o options (verify chown chgrp chmod follow ignlnks numchkg quiet remove young older sparse whole), -p path, -P rcmd path, -t timeout, -v verbose, -y younger only)
# upstream: https://github.com/magnumripper/rdist
# Flags from rdist src/rdist.c on tip.

_rdist() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-D[debug]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-i[ignore unresolved hosts]' \
        '-l+[log file]:file:_files' \
        '-f+[distfile]:file:_files' \
        '*-c+[label]:label:' \
        '*-d+[KEY=VAL]:var:' \
        '*-m+[hostname]:host:_hosts' \
        '-n[no-op show plan]' \
        '*-o+[options]:options:(verify chown chgrp chmod follow ignlnks numchkg quiet remove young older sparse whole)' \
        '-p+[server path]:path:_files' \
        '-P+[rcmd path]:path:_files' \
        '-t+[timeout]:seconds:' \
        '-y[younger only]'
}

_rdist "$@"
