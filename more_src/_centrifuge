#compdef centrifuge centrifuge-build centrifuge-inspect
# Documentation: https://github.com/DaehwanKimLab/centrifuge
# Reference accessed: 2026-05-27
# Verified: upstream DaehwanKimLab/centrifuge MANUAL.markdown and the centrifuge Perl wrapper Getopt::Long block.

# Zsh completion for centrifuge, centrifuge-build, centrifuge-inspect.

local curcontext="$curcontext" ret=1

case $service in
  centrifuge)
    _arguments -s \
      '-h[show help]' \
      '--help[show help]' \
      '--version[print version]' \
      '-q[input is FASTQ (default)]' \
      '--qseq[input is QSEQ]' \
      '-f[input is FASTA]' \
      '-r[one sequence per line]' \
      '-c[sequences given on command line]' \
      '(-s --skip)'{-s+,--skip=}'[skip first N reads]:int:' \
      '(-u --qupto)'{-u+,--qupto=}'[process only first N reads]:int:' \
      '(-5 --trim5)'{-5+,--trim5=}'[trim bases from 5 prime end]:int:' \
      '(-3 --trim3)'{-3+,--trim3=}'[trim bases from 3 prime end]:int:' \
      '--phred33[Phred+33 quality encoding]' \
      '--phred64[Phred+64 quality encoding]' \
      '-x+[index basename]:index:' \
      '-1+[mate-1 reads]:file:_files' \
      '-2+[mate-2 reads]:file:_files' \
      '-U+[unpaired reads]:file:_files' \
      '-S+[output SAM file]:file:_files' \
      '--report-file=[per-taxon classification report]:file:_files' \
      '--min-hitlen=[minimum partial hit length]:int:' \
      '-k+[max distinct primary assignments]:int:' \
      '--host-taxids=[preferred taxonomic IDs]:taxids:' \
      '--exclude-taxids=[taxonomic IDs to exclude]:taxids:' \
      '(-t --time)'{-t,--time}'[print wall-clock timing]' \
      '--quiet[minimal output]' \
      '--met-file=[write metrics to file]:file:_files' \
      '--met-stderr[write metrics to stderr]' \
      '--met=[metrics recording interval (sec)]:int:' \
      '(-o --offrate)'{-o+,--offrate=}'[override index offrate]:int:' \
      '(-p --threads)'{-p+,--threads=}'[parallel threads]:int:' \
      '--reorder[preserve input order in output]' \
      '--mm[memory-mapped I/O]' \
      '--seed=[RNG seed]:int:' \
      '--non-deterministic[non-deterministic mode]' \
      '--bam[input is BAM (wrapper)]' \
      '--temp-directory=[wrapper temp directory]:dir:_files -/' \
      '--no-named-pipes[wrapper: disable named pipes]' \
      '--keep[wrapper: keep temporary files]' \
      '--verbose[wrapper: verbose]' \
      '*:files:_files' && ret=0
    ;;
  centrifuge-build)
    _arguments -s \
      '-h[show help]' \
      '--help[show help]' \
      '--version[print version]' \
      '-f[input is FASTA]' \
      '-c[sequences on command line]' \
      '(-a --noauto)'{-a,--noauto}'[disable automatic parameter selection]' \
      '(-p --threads)'{-p+,--threads=}'[indexing threads]:int:' \
      '--conversion-table=[UID to taxonomic ID mapping]:file:_files' \
      '--taxonomy-tree=[taxonomic tree file]:file:_files' \
      '--name-table=[taxonomy name mapping]:file:_files' \
      '--size-table=[sequence length table]:file:_files' \
      '--bmax=[max suffixes per block]:int:' \
      '--bmaxdivn=[block size as reference fraction]:int:' \
      '--dcv=[difference-cover sample period]:int:' \
      '--nodc[disable difference-cover sampling]' \
      '(-o --offrate)'{-o+,--offrate=}'[mark every Nth BWT row]:int:' \
      '(-t --ftabchars)'{-t+,--ftabchars=}'[lookup table characters]:int:' \
      '--seed=[RNG seed]:int:' \
      '--kmer-count=[k-mer counting size]:int:' \
      '(-q --quiet)'{-q,--quiet}'[suppress verbose output]' \
      '*:files:_files' && ret=0
    ;;
  centrifuge-inspect)
    _arguments -s \
      '-h[show help]' \
      '--help[show help]' \
      '--version[print version]' \
      '(-a --across)'{-a+,--across=}'[newline interval for FASTA output]:int:' \
      '(-n --names)'{-n,--names}'[print sequence names only]' \
      '(-s --summary)'{-s,--summary}'[print detailed index summary]' \
      '--conversion-table[print UID to tax ID table]' \
      '--taxonomy-tree[print taxonomic tree]' \
      '--name-table[print name table]' \
      '--size-table[print sequence length table]' \
      '(-v --verbose)'{-v,--verbose}'[verbose debug output]' \
      '*:index:_files' && ret=0
    ;;
esac

return ret
