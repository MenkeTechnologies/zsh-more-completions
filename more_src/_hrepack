#compdef hrepack
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hrepack.1.en.html
# Copy an HDF4 file applying compression and/or chunking

local ret=1

_arguments -s \
  '-i+[input HDF file]:input file:_files -g "*.(hdf|h4)"' \
  '-o+[output HDF file]:output file:_files -g "*.(hdf|h4)"' \
  '-V[print version of the HDF4 library and exit]' \
  '-h[print usage information]' \
  '-v[verbose mode]' \
  '-t+[compression type (RLE,HUFF,GZIP,JPEG,SZIP,NONE)]:comp info' \
  '-c+[apply chunking, object list and chunk information]:chunk info' \
  '-f+[file with compression information]:cfile:_files' \
  '-m+[do not compress objects smaller than size bytes]:size' && ret=0

return ret
