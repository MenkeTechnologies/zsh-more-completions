#compdef dotc
# Documentation: https://docs.scala-lang.org/scala3/guides/migration/options-new.html
# Scala 3 (Dotty) compiler

local ret=1

_arguments -s -S \
  '(-help -h)'{-help,-h}'[show help]' \
  '-version[show compiler version]' \
  '-verbose[output messages about compilation activity]' \
  '-d+[destination for generated classfiles]:directory:_files -/' \
  '-classpath+[specify where to find user class files]:classpath:_files' \
  '-bootclasspath+[override location of bootstrap class files]:classpath:_files' \
  '-encoding+[specify character encoding used by source files]:encoding:' \
  '-release+[compile for a specific version of the Java platform]:version:' \
  '-deprecation[emit warning and location for usages of deprecated APIs]' \
  '-feature[emit warning and location for usages of features that should be imported explicitly]' \
  '-unchecked[enable additional warnings where generated code depends on assumptions]' \
  '-explain[explain errors in more detail]' \
  '-color+[colored output]:mode:(always never)' \
  '-pagewidth+[set page width]:width:' \
  '-print-lines[show source code line numbers]' \
  '-print-tasty[prints the raw tasty]' \
  '-new-syntax[require then and do in control expressions]' \
  '-old-syntax[require (...) around conditions]' \
  '-indent[remove braces syntax when possible due to significant indentation]' \
  '-no-indent[require classical brace syntax, indentation is not significant]' \
  '-rewrite[rewrite sources to migrate to new version when used with source version flags]' \
  '-from-tasty[compile classes from tasty files]' \
  '-Werror[fail the compilation if there are any warnings]' \
  '-Wconf+[configure compiler warnings]:config:' \
  '-Wunused+[enable or disable specific unused warnings]:conf:' \
  '-Wvalue-discard[warn when non-Unit expression results are unused]' \
  '-Xmax-inlines+[maximal number of successive inlines]:n:' \
  '-Xmax-inlined-trees+[maximal number of inlined trees]:n:' \
  '-Xprint-inline[show where inlined code comes from]' \
  '-Xignore-scala2-macros[ignore errors when compiling Scala 2 macro calls]' \
  '-Vprofile[show metrics about sources and internal representations]' \
  '*:source file:_files -g "*.scala"' && ret=0

return ret
