#compdef corstest corstest.py
# Documentation: https://github.com/RUB-NDS/CORStest
# CORStest - simple CORS misconfiguration checker

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-c[send cookie with all requests]:name=value:' \
  '-p[number of processes for multiprocessing]:processes:' \
  '-s[always force SSL/TLS requests]' \
  '-q[quiet mode; only report Allow-Credentials results]' \
  '-v[produce verbose output]' \
  '*:infile:_files' && ret=0

return ret
