#compdef bemenu-run
# _bemenu-run — bemenu bemenu-run CLI executable launcher around the bemenu dmenu-style menu library scanning PATH-resolved executables presenting them in a top-bar bottom-bar grid frontend ncurses wayland-layer-shell x11 backend selecting and launching with execvp from stdin keyboard filter (Cloudef team, C); getopt
# upstream: https://github.com/Cloudef/bemenu

_bemenu-run() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i[case insensitive]' \
        '--ignorecase[case insensitive]' \
        '-w[wrap navigation]' \
        '--wrap[wrap navigation]' \
        '-l+[lines]:n:' \
        '--list=+[lines]:n:' \
        '-P+[prefix]:str:' \
        '--prefix=+[prefix]:str:' \
        '-I+[index]:n:' \
        '--index=+[index]:n:' \
        '--prompt=+[prompt]:str:' \
        '-p+[prompt]:str:' \
        '--password[hide input]' \
        '-x+[mode]:m:(none indicator yes)' \
        '-b[bottom of screen]' \
        '--bottom[bottom of screen]' \
        '-f[grab keyboard]' \
        '--grab[grab keyboard]' \
        '-m+[monitor]:str:' \
        '--monitor=+[monitor]:str:' \
        '-H+[line height]:n:' \
        '--line-height=+[height]:n:' \
        '-W+[width factor]:n:' \
        '--width-factor=+[factor]:n:' \
        '--fn=+[font]:str:' \
        '--tb=+[title bg]:str:' \
        '--tf=+[title fg]:str:' \
        '--fb=+[filter bg]:str:' \
        '--ff=+[filter fg]:str:' \
        '--nb=+[normal bg]:str:' \
        '--nf=+[normal fg]:str:' \
        '--hb=+[highlight bg]:str:' \
        '--hf=+[highlight fg]:str:' \
        '--sb=+[selected bg]:str:' \
        '--sf=+[selected fg]:str:' \
        '--ab=+[alt bg]:str:' \
        '--af=+[alt fg]:str:' \
        '--scrollindicator=+[s]:str:' \
        '*::'
}

_bemenu-run "$@"
