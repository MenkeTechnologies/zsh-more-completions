#compdef pbs_rstat
# Documentation: https://www.altair.com/pbs-works-documentation/
# PBS: show status of advance, standing, or job-specific reservations

local ret=1

_arguments -s \
  '(-B -f -F -S)-B[brief output: display each reservation identifier only]' \
  '(-B -f -F -S)-f[full output: display all non-default reservation attributes]' \
  '(-B -f -F -S)-F[full output: display all non-default reservation attributes]' \
  '(-B -f -F -S)-S[short output: tabular reservation summary]' \
  '--version[print PBS version information and exit]' \
  '*:reservation id:_message "reservation id"' && ret=0

return ret
