#compdef heimdall
# Documentation: https://man.archlinux.org/search?q=heimdall
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'flash:flash firmware to device'
  'close-pc-screen:close PC screen'
  'detect:check if connected device is in download mode'
  'download-pit:download PIT file from device'
  'dump:dump partition'
  'help:show help'
  'info:show device info'
  'print-pit:print PIT file'
  'version:show version'
)

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'heimdall command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (flash)
        _arguments \
          '--repartition[repartition device]' \
          '--no-reboot[do not reboot device]' \
          '--resume[resume after no-reboot session]' \
          '--verbose[verbose output]' \
          '--no-verbose[no verbose]' \
          '--stdout-errors[print errors to stdout]' \
          '--usb-log-level=[USB log level]:lvl:(none error warning debug)' \
          '--pit=[PIT file]:file:_files -g "*.pit"' \
          '*--FACTORYFS=[factoryfs file]:file:_files -g "*.rfs *.img *.bin"' \
          '*--CACHE=[cache file]:file:_files' \
          '*--DBDATA=[dbdata file]:file:_files' \
          '*--BOOT=[boot image]:file:_files -g "*.img *.bin"' \
          '*--IBL+PBL=[bootloader]:file:_files -g "*.bin"' \
          '*--SBL=[secondary bootloader]:file:_files -g "*.bin"' \
          '*--KERNEL=[kernel image]:file:_files' \
          '*--MODEM=[modem firmware]:file:_files' \
          '*--RECOVERY=[recovery image]:file:_files -g "*.img"' \
          '*--PARAM=[param file]:file:_files' \
          '*--SYSTEM=[system image]:file:_files' \
          '*--USERDATA=[userdata image]:file:_files' \
          '*--TZSW=[TrustZone software]:file:_files' \
          '*--EFS=[EFS image]:file:_files' && ret=0 ;;
      (download-pit)
        _arguments \
          '--output=[output PIT file]:file:_files' \
          '--no-reboot[do not reboot]' \
          '--verbose[verbose]' && ret=0 ;;
      (print-pit)
        _arguments \
          '--file=[input PIT file]:file:_files -g "*.pit"' \
          '--no-reboot[do not reboot]' \
          '--verbose[verbose]' && ret=0 ;;
      (dump)
        _arguments \
          '--chip-type=[chip type]:c:(NAND RFS)' \
          '--chip-id=[chip id]:n:' \
          '--output=[output file]:file:_files' \
          '--no-reboot[do not reboot]' \
          '--verbose[verbose]' && ret=0 ;;
      (info)
        _arguments \
          '--no-reboot[do not reboot]' \
          '--verbose[verbose]' && ret=0 ;;
    esac ;;
esac

return ret
