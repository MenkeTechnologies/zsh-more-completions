#compdef support-bundle
# Documentation: https://troubleshoot.sh/docs/support-bundle/collecting/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (replicatedhq/troubleshoot cmd/troubleshoot/cli/root.go).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable debug logging]' \
  '--dry-run[print spec without collecting]' \
  '(-o --output)'{-o+,--output=}'[output file path for bundle]:file:_files' \
  '(-l --selector)'{-l+,--selector=}'[filter specs by label selector]:selector:' \
  '--load-cluster-specs[load specs from in-cluster Secrets and ConfigMaps]' \
  '--interactive[enable interactive mode]' \
  '--no-uri[disable upstream spec retrieval]' \
  '--redact[enable default redactions]' \
  '*--redactors=[additional redactor URIs]:uri:' \
  '--collect-without-permissions[generate bundle even with permission gaps]' \
  '--tokenize[use tokenization instead of masking]' \
  '--redaction-map[generate redaction mapping file]' \
  '--encrypt-redaction-map[encrypt the mapping file]' \
  '--token-prefix=[custom token format]:prefix:' \
  '--verify-tokenization[validation mode]' \
  '--bundle-id=[custom bundle identifier]:id:' \
  '--tokenization-stats[include statistics]' \
  '--since-time=[log cutoff date (RFC3339)]:time:' \
  '--since=[relative duration for logs]:duration:' \
  '--auto[enable auto-discovery of collectors]' \
  '--include-images[include container image metadata]' \
  '--rbac-check[enable RBAC checking]' \
  '--discovery-profile=[profile type]:profile:(minimal standard comprehensive paranoid)' \
  '*--exclude-namespaces=[namespaces to skip]:ns:' \
  '*--include-namespaces=[namespaces to include]:ns:' \
  '--include-system-namespaces[include system namespaces]' \
  '--auto-upload[auto-upload to replicated.app]' \
  '--license-id=[authentication license ID]:id:' \
  '--app-slug=[application slug]:slug:' \
  '--upload-domain=[custom upload domain]:domain:' \
  '*--metadata=[user-provided key=value pair]:kv:' \
  '--remote-host-collect-timeout=[remote operation timeout]:timeout:' \
  '--allow-insecure-connections[skip TLS verification]' \
  '--auto-update[enable auto-update check]' \
  '*:collector URL or spec:_default'
