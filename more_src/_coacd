#compdef coacd
# Documentation: https://github.com/SarahWeiii/CoACD
# coacd - collision-aware approximate convex decomposition for 3D meshes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[input model file (.obj)]:file:_files -g "*.obj"' \
  '(-o --output)'{-o,--output}'[output file (.obj or .wrl)]:file:_files -g "*.{obj,wrl}"' \
  '(-ro --remesh-output)'{-ro,--remesh-output}'[preprocessed mesh output]:file:_files' \
  '(-t --threshold)'{-t,--threshold}'[concavity threshold 0.01~1 (default 0.05)]:value:' \
  '(-pm --preprocess-mode)'{-pm,--preprocess-mode}'[manifold preprocess mode]:mode:(auto on off)' \
  '(-pr --prep-resolution)'{-pr,--prep-resolution}'[manifold preprocess resolution 20~100 (default 50)]:value:' \
  '(-nm --no-merge)'{-nm,--no-merge}'[disable merge postprocessing]' \
  '(-c --max-convex-hull)'{-c,--max-convex-hull}'[max convex hulls, -1 for no limit]:value:' \
  '(-mi --mcts-iteration)'{-mi,--mcts-iteration}'[MCTS search iterations 60~2000 (default 100)]:value:' \
  '(-md --mcts-depth)'{-md,--mcts-depth}'[max MCTS search depth 2~7 (default 3)]:value:' \
  '(-mn --mcts-node)'{-mn,--mcts-node}'[max MCTS child nodes 10~40 (default 20)]:value:' \
  '(-r --resolution)'{-r,--resolution}'[Hausdorff sampling resolution 1e3~1e4 (default 2000)]:value:' \
  '-k[value for Rv calculation (default 0.3)]:value:' \
  '(-d --decimate)'{-d,--decimate}'[enable vertex constraint per hull]' \
  '(-dt --max-ch-vertex)'{-dt,--max-ch-vertex}'[max vertices per convex hull]:value:' \
  '(-ex --extrude)'{-ex,--extrude}'[enable extrusion]' \
  '(-em --extrude-margin)'{-em,--extrude-margin}'[extrusion margin]:value:' \
  '(-am --approximate-mode)'{-am,--approximate-mode}'[approximation mode]:mode:' \
  '(-rm --real-metric)'{-rm,--real-metric}'[enable real metric (threshold in meters)]' \
  '--pca[enable PCA pre-processing]' \
  '(-s --seed)'{-s,--seed}'[random seed for reproducibility]:value:' \
  '*:input model:_files -g "*.obj"' && ret=0

return ret
