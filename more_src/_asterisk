#compdef asterisk
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man8/asterisk.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-c[run foreground with console]' \
  '-d[enable extra debugging]' \
  '*-v[increase verbosity]' \
  '-r[connect to running Asterisk instance]' \
  '-R[reconnect to running instance and re-run on disconnect]' \
  '-x+[execute CLI command and exit]:command:' \
  '-X[allow #exec in configs]' \
  '-C+[asterisk.conf path]:file:_files -g "*.conf"' \
  '-U+[run as user]:user:_users' \
  '-G+[run as group]:group:_groups' \
  '-f[fork]' \
  '-F[do not fork]' \
  '-g[dump core on crash]' \
  '-i[ignore startup audio prompts]' \
  '-I[force internal timing]' \
  '-L+[max load]:n:' \
  '-M+[max connections]:n:' \
  '-m[mute log/verbose output on console]' \
  '-n[disable color console]' \
  '-p[run as pseudo-realtime]' \
  '-q[reduce console messages]' \
  '-s+[remote console UNIX socket]:file:_files' \
  '-t[record temp recordings at exit]' \
  '-T[print timestamps on log/verbose output]' \
  '-W[Whitelist warnings (do not crash)]' \
  '*::passthrough:' && ret=0

return ret
