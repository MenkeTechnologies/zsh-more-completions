#compdef nancy

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'sleuth:audit dependencies for vulnerabilities'
  'iq:submit SBOM to Sonatype IQ Server'
  'config:setup persistent Nancy config'
  'help:show help'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--loud[show all output including non-vulnerable]' \
  '--quiet[only show vulnerable dependencies]' \
  '--no-color[disable color output]' \
  '--clean-cache[clear local cache]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'nancy command' commands && ret=0
    ;;
  args)
    case $line[1] in
      sleuth)
        _arguments -s -S \
          '(-p --path)'{-p,--path}'[path to Gopkg.lock or go.sum]:file:_files' \
          '--username[Sonatype OSS Index username]:username:' \
          '--token[Sonatype OSS Index API token]:token:' \
          '--exclude-vulnerability[exclude vulnerability IDs]:id:' \
          '--exclude-vulnerability-file[file with vulnerability exclusions]:file:_files' \
          '--output[output format]:format:(text json csv)' \
          '--help[show help]' && ret=0
        ;;
      iq)
        _arguments -s -S \
          '--iq-server-url[IQ Server URL]:url:' \
          '--iq-application[IQ application ID]:id:' \
          '--iq-stage[IQ stage]:stage:(develop build stage-release release operate)' \
          '--iq-username[IQ username]:username:' \
          '--iq-token[IQ token]:token:' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
