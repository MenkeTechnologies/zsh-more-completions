#compdef h2o-3

# H2O-3: H2O Java in-memory ML platform launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-version[show version]' \
  '-name[cluster name]:name:' \
  '-port[base port]:port:' \
  '-baseport[base port]:port:' \
  '-ip[bind IP]:ip:' \
  '-network[network mask]:mask:' \
  '-flatfile[flatfile of cluster members]:file:_files' \
  '-nthreads[number of threads]:n:' \
  '-Xmx[max heap]:size:' \
  '-Xms[initial heap]:size:' \
  '-context_path[web context path]:path:' \
  '-rest_api_ping_timeout[rest API ping timeout]:ms:' \
  '-jks[Java keystore]:file:_files' \
  '-jks_pass[keystore pass]:pass:' \
  '-hash_login[enable hashed login]' \
  '-ldap_login[enable LDAP login]' \
  '-kerberos_login[enable Kerberos login]' \
  '-pam_login[enable PAM login]' \
  '-login_conf[login.conf file]:file:_files' \
  '-internal_security_conf[internal security conf]:file:_files' \
  '-internal_security_conf_rel_paths[allow relative paths in security conf]' \
  '-spnego_properties=[SPNEGO properties]:file:_files' \
  '-user_name[user name]:user:_users' \
  '-log_dir[log directory]:dir:_files -/' \
  '-log_level[log level]:level:(TRACE DEBUG INFO WARN ERROR FATAL)' \
  '-quiet[quiet mode]' \
  '-Xlog_request[log requests]' \
  '*::h2o-3 args:_files' && ret=0
return ret
