#compdef tfcmt
# Documentation: https://suzuki-shunsuke.github.io/tfcmt/usage/
# Post terraform plan/apply results to GitHub pull requests as comments and labels

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--config=[configuration file path]:file:_files' \
  '--owner=[GitHub repository owner name]:owner' \
  '--repo=[GitHub repository name]:repo' \
  '--sha=[commit SHA (revision)]:sha' \
  '--pr=[pull request number]:number' \
  '--build-url=[build URL]:url' \
  '--log-level=[logging level]:level:(debug info warn error)' \
  '*--var=[template variable in <name>:<value> format]:var' \
  '--output=[output result to file instead of posting a comment]:file:_files' \
  '1:command:((plan\:"post terraform plan result" apply\:"post terraform apply result" version\:"show version"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      plan)
        _arguments -s -S \
          '--patch[update an existing comment instead of creating a new one]' \
          '--skip-no-changes[update label but do not post comment when there is no change]' \
          '--ignore-warning[ignore warnings]' \
          '--disable-label[disable adding or updating a label]' && ret=0
        ;;
    esac
    ;;
esac

return ret
