#compdef tmate

# Zsh completion for tmate - Terminal sharing (tmux fork)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-S[specify socket path]:socket:_files' \
  '-f[specify config file]:file:_files' \
  '-k[set server api key]:key:' \
  '-r[set read-only server name]:name:' \
  '-v[verbose mode]' \
  '-F[set output format for display command]:format:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'new-session:create a new session'
      'kill-session:kill session'
      'kill-server:kill tmate server'
      'display:display a message'
      'show-messages:show messages'
      'wait:wait for event'
      'set-option:set a session option'
      'new-window:create a new window'
      'split-window:split a window'
      'send-keys:send keys to a window'
      'select-pane:select a pane'
      'select-window:select a window'
      'attach-session:attach to an existing session'
      'detach-client:detach a client'
      'list-sessions:list sessions'
      'list-windows:list windows'
      'list-panes:list panes'
      'has-session:check for session existence'
      'rename-session:rename session'
      'rename-window:rename window'
      'source-file:source a config file'
      'swap-pane:swap two panes'
      'swap-window:swap two windows'
      'resize-pane:resize a pane'
    )
    _describe -t commands 'tmate command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (new-session)
        _arguments \
          '-d[do not attach]' \
          '-s[session name]:name:' \
          '-n[window name]:name:' \
          '-x[width]:width:' \
          '-y[height]:height:' \
          && ret=0
        ;;
      (attach-session)
        _arguments \
          '-t[target session]:session:' \
          '-r[read-only mode]' \
          && ret=0
        ;;
      (display)
        _arguments \
          '-p[print to stdout]' \
          '-t[target pane]:pane:' \
          && ret=0
        ;;
      (wait)
        _arguments \
          '1:channel:(tmate-ready)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
