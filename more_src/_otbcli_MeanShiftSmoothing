#compdef otbcli_MeanShiftSmoothing
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_MeanShiftSmoothing.html
# Orfeo ToolBox: perform mean-shift filtering (first step of LSMS)

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input single or multiband image]:image:_files' \
  '-fout[output image of final averaged spectral signatures]:output:_files' \
  '-foutpos[output image of 2D pixel displacement]:output:_files' \
  '-spatialr[radius of spatial neighborhood for averaging]:value:' \
  '-ranger[threshold on spectral euclidean distance]:value:' \
  '-thres[convergence threshold for stopping]:value:' \
  '-maxiter[maximum number of iterations]:value:' \
  '-rangeramp[coefficient to vary range radius with intensity]:value:' \
  '-modesearch[stop at already converged pixel on path]:bool:(true false)' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
