#compdef rabbitmq-streams
# Documentation: https://man.archlinux.org/search?q=rabbitmq-streams
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add_super_stream:create a partitioned stream'
  'add_replica:add replica to stream'
  'delete_replica:remove replica from stream'
  'stream_status:query replication status'
  'restart_stream:restart a stream'
)

_arguments -C \
  '-n=[node name]:node:' \
  '-q[quiet output]' \
  '-l[long node names]' \
  '-t=[timeout secs]:secs:' \
  '--erlang-cookie=[Erlang cookie]:cookie:' \
  '--formatter=[output formatter]:fmt:' \
  '--no-table-headers[no table headers]' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rabbitmq-streams subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (add_super_stream)
        _arguments \
          '-p=[virtual host]:vhost:' \
          '--partitions=[partition count]:n:' \
          ':stream name:' && ret=0
        ;;
      (add_replica|delete_replica)
        _arguments \
          '-p=[virtual host]:vhost:' \
          ':stream name:' \
          ':node:' && ret=0
        ;;
      (stream_status|restart_stream)
        _arguments \
          '-p=[virtual host]:vhost:' \
          ':stream name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
