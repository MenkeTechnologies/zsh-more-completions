#compdef edge-tts edge-playback
# Documentation: source-direct extraction from upstream
# rany2/edge-tts src/edge_tts/util.py —
#   amain() at lines 88-141 (the argparse.ArgumentParser +
#     10 add_argument calls; mutex group at lines 93-107
#     enforces -t/--text vs -f/--file vs -l/--list-voices)
#   DEFAULT_VOICE constant at src/edge_tts/constants.py
#     (value: "en-US-EmmaMultilingualNeural")
# Reference accessed: 2026-05-30 via gh api.
#
# edge-tts is the **reverse-engineered Microsoft Edge TTS
# service CLI** — provides programmatic access to the same
# 400+ neural voice text-to-speech that the Edge browser uses
# for "Read Aloud", without requiring a Microsoft account or
# Azure subscription.  Widely used in screen-reader / accessi-
# bility / video-narration / audiobook-generation workflows.
# Sister CLIs: edge-playback (interactive playback variant) +
# edge_tts Python library for programmatic use.  The
# completion supports BOTH binaries (same flag set).
#
# Critical extraction note: edge-tts uses **Python's argparse**
# with a **MUTUALLY EXCLUSIVE GROUP** for input source.  The
# group at util.py:93 is `required=True` and contains 3
# alternatives:
#   -t / --text TEXT          (inline text)
#   -f / --file FILE          (text from file; "-" = stdin)
#   -l / --list-voices        (list available voices and exit)
# Completion expresses this via the mutex syntax
# `(-t --text -f --file -l --list-voices)`.  Documented as
# the FIRST round in the corpus to document Python argparse's
# `add_mutually_exclusive_group(required=True)` pattern.
#
# Critical extraction note: the **DEFAULT_VOICE** value is
# `en-US-EmmaMultilingualNeural` (constants.py).  Other
# common voices users may want:
#   en-US-AvaNeural       (American female; very natural)
#   en-US-AndrewNeural    (American male)
#   en-GB-SoniaNeural     (British female)
#   en-GB-RyanNeural      (British male)
#   ja-JP-NanamiNeural    (Japanese female)
#   zh-CN-XiaoyiNeural    (Mandarin Chinese female)
# Run `edge-tts --list-voices` for the full 400+ voice list.
# Completion provides the most common 10 as a hint; the
# format is `<lang-locale>-<NAME>Neural`.
#
# Critical extraction note: the **--rate / --volume / --pitch**
# format follows SSML prosody conventions:
#   --rate    accepts `+N%` or `-N%`           (default: +0%)
#   --volume  accepts `+N%` or `-N%`           (default: +0%)
#   --pitch   accepts `+NHz` or `-NHz`         (default: +0Hz)
# Documented in the flag descriptions.  Common values:
#   --rate +25% (faster), --rate -25% (slower)
#   --volume +50% (louder), --volume -25% (quieter)
#   --pitch +20Hz (higher), --pitch -10Hz (lower)
#
# Critical extraction note: **--write-media** sends the audio
# to a file (instead of stdout); **--write-subtitles** sends
# SRT-formatted subtitles to a file (instead of stderr).
# Together they form the canonical "save the audio + the
# subtitle file" workflow for video narration.

local -a common_voices=(
  'en-US-EmmaMultilingualNeural:default; American female; multilingual'
  'en-US-AvaNeural:American female; very natural'
  'en-US-AndrewNeural:American male'
  'en-US-AriaNeural:American female; expressive'
  'en-GB-SoniaNeural:British female'
  'en-GB-RyanNeural:British male'
  'en-AU-NatashaNeural:Australian female'
  'es-MX-DaliaNeural:Mexican Spanish female'
  'ja-JP-NanamiNeural:Japanese female'
  'zh-CN-XiaoyiNeural:Mandarin Chinese female'
  'fr-FR-DeniseNeural:French female'
  'de-DE-KatjaNeural:German female'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--version[show edge-tts version and exit]' \
  '(-t --text -f --file -l --list-voices)'{-t+,--text=}'[text to speak (mutex with --file / --list-voices)]:text:' \
  '(-t --text -f --file -l --list-voices)'{-f+,--file=}'[read text from FILE ("-" or "/dev/stdin" for stdin)]:file:_files' \
  '(-t --text -f --file -l --list-voices)'{-l,--list-voices}'[list available voices (400+) and exit]' \
  '(-v --voice)'{-v+,--voice=}'[voice for TTS (default: en-US-EmmaMultilingualNeural)]:voice:->voice' \
  '--rate=[set TTS rate (SSML format: +/-N%; default: +0%)]:rate:(+0% +10% +25% +50% +100% -10% -25% -50%)' \
  '--volume=[set TTS volume (SSML format: +/-N%; default: +0%)]:volume:(+0% +25% +50% +100% -25% -50%)' \
  '--pitch=[set TTS pitch (SSML format: +/-NHz; default: +0Hz)]:pitch:(+0Hz +10Hz +20Hz +50Hz -10Hz -20Hz)' \
  '--write-media=[send audio output to FILE (default: stdout)]:file:_files' \
  '--write-subtitles=[send SRT-format subtitles to FILE (default: stderr)]:file:_files -g "*.srt"' \
  '--proxy=[use a proxy for TTS and voice list (HTTP/SOCKS URL)]:proxy:'

case $state in
  voice)
    _describe -t voices 'common Edge TTS voices (run `edge-tts --list-voices` for full list)' common_voices
    ;;
esac
