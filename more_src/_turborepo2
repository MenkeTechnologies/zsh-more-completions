#compdef turborepo2 turbo2
# _turborepo2 — Vercel Turborepo turborepo2 CLI command-line frontend wrapping the Turbo build system for JavaScript and TypeScript codebases originally TurboRepo now Vercel high-performance Rust-based monorepo build tool open-source written in Rust replaces Lerna fast incremental builds remote-caching parallel execution task pipeline run build dev lint test help completion login logout link unlink prune watch query gen daemon scan boundaries ls (Vercel Turborepo team Jared Palmer Tobias Koppers Anthony Shew, Rust); clap
# upstream: https://turbo.build/

_turborepo2() {
    local -a sub=(
        'bin:show turbo binary path'
        'boundaries:check workspace boundaries'
        'completion:generate shell completion'
        'daemon:turbo daemon ops'
        'gen:scaffold code'
        'generate:scaffold code'
        'help:show help'
        'info:show env info'
        'link:link to remote cache'
        'login:authenticate'
        'logout:revoke session'
        'ls:list packages'
        'prune:prune monorepo'
        'query:run a GraphQL query'
        'run:run a task'
        'scan:scan workspace'
        'telemetry:telemetry operations'
        'unlink:unlink remote cache'
        'watch:run tasks in watch mode'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-vv[more verbose]' \
        '--debug[debug]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--ui=+[u]:u:(stream tui)' \
        '--api=+[url]:str:' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--cache-workers=+[N]:n:' \
        '--concurrency=+[N]:str:' \
        '--continue[continue on error]' \
        '--dry-run=+[fmt]:f:(json text)' \
        '--dry[dry run]' \
        '--single-package[single package]' \
        '-F+[filter]:str:' \
        '*-F+[filter]:str:' \
        '--filter=+[filter]:str:' \
        '*--filter=+[filter]:str:' \
        '--affected[affected only]' \
        '--force=+[v]:v:(true false)' \
        '--framework-inference=+[v]:v:(true false)' \
        '--global-deps=+[deps]:str:' \
        '*--global-deps=+[deps]:str:' \
        '--graph=+[file]:file:_files' \
        '--ignore=+[paths]:str:' \
        '*--ignore=+[paths]:str:' \
        '--include-dependencies[include deps]' \
        '--no-cache[no cache]' \
        '--no-daemon[no daemon]' \
        '--no-deps[no deps]' \
        '--no-update-notifier[no update notifier]' \
        '--output-logs=+[m]:m:(full none hash-only new-only errors-only)' \
        '--log-order=+[o]:o:(auto stream grouped)' \
        '--log-prefix=+[p]:p:(auto none task)' \
        '--parallel[parallel]' \
        '--profile=+[file]:file:_files' \
        '--remote-cache-timeout=+[sec]:n:' \
        '--root-turbo-json=+[file]:file:_files -g "turbo.json *.json"' \
        '--summarize=+[v]:v:(true false)' \
        '--token=+[token]:str:' \
        '--team=+[name]:str:' \
        '--login=+[url]:str:' \
        '--scope=+[names]:str:' \
        '*--scope=+[names]:str:' \
        '--since=+[ref]:str:' \
        '--include-deps[include deps]' \
        '--out-dir=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '--color[force color]' \
        '--heap=+[file]:file:_files' \
        '--no-gitignore[no gitignore]' \
        '--anon-profile-id=+[id]:str:' \
        '--experimental-rust-codepath[experimental rust]' \
        '--experimental-write-cache[experimental write cache]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'turbo subcommand' sub ;;
        args)
            case $words[1] in
                run|watch) _arguments '*:task:' ;;
                gen|generate) _arguments '1:op:(workspace run)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                ls) _arguments '*:filter:' ;;
                prune) _arguments '*:package:' ;;
            esac
            ;;
    esac
}

_turborepo2 "$@"
