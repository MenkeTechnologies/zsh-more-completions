#compdef nodetool

local -a subcommands
subcommands=(
    'status:Print cluster information'
    'info:Print node information'
    'ring:Print token ring information'
    'netstats:Print network statistics'
    'cfstats:Print column family statistics'
    'tablestats:Print table statistics'
    'tpstats:Print thread pool statistics'
    'compactionstats:Print compaction statistics'
    'describecluster:Print cluster name and snitch'
    'repair:Repair one or more tables'
    'cleanup:Triggers removal of data not owned by node'
    'compact:Force compaction on tables'
    'flush:Flush memtables to SSTables'
    'drain:Drain the node'
    'move:Move node to new token'
    'decommission:Decommission the node'
    'removenode:Remove a node from the cluster'
    'assassinate:Forcefully remove a dead node'
    'rebuild:Rebuild data by streaming from other nodes'
    'bootstrap:Bootstrap operations'
    'disablebackup:Disable incremental backup'
    'enablebackup:Enable incremental backup'
    'disablebinary:Disable native transport'
    'enablebinary:Enable native transport'
    'disablegossip:Disable gossip'
    'enablegossip:Enable gossip'
    'disablehandoff:Disable hinted handoff'
    'enablehandoff:Enable hinted handoff'
    'getcompactionthreshold:Print compaction threshold'
    'setcompactionthreshold:Set compaction threshold'
    'getcompactionthroughput:Print compaction throughput'
    'setcompactionthroughput:Set compaction throughput'
    'getstreamthroughput:Print stream throughput'
    'setstreamthroughput:Set stream throughput'
    'getendpoints:Print endpoints owning a key'
    'getsstables:Print sstables owning a key'
    'gossipinfo:Show gossip information'
    'invalidatekeycache:Invalidate key cache'
    'invalidaterowcache:Invalidate row cache'
    'join:Join the ring'
    'listsnapshots:Lists all snapshots'
    'snapshot:Take a snapshot'
    'clearsnapshot:Remove snapshots'
    'scrub:Scrub SSTables'
    'upgradesstables:Rewrite SSTables for current version'
    'verify:Verify SSTables'
    'version:Print cassandra version'
    'describering:Show token ring for keyspace'
    'rangekeysample:Show sampled keys'
    'rebuild_index:Rebuild secondary index'
    'resetlocalschema:Reset local node schema'
    'reloadtriggers:Reload trigger classes'
    'settraceprobability:Set trace probability'
    'gettraceprobability:Print trace probability'
    'proxyhistograms:Print proxy histograms'
    'tablehistograms:Print table histograms'
    'stop:Stop compaction'
    'stopdaemon:Stop cassandra daemon'
    'import:Import new SSTables'
    'truncatehints:Truncate all hints'
    'toppartitions:Sample and print top partitions'
    'sjk:Run SJK diagnostic commands'
)

_arguments -C \
    '-h[Show help]' \
    '-u[JMX username]:username' \
    '-pw[JMX password]:password' \
    '-pwf[JMX password file]:file:_files' \
    '-p[JMX port]:port' \
    '-pp[JMX over SSL]' \
    '-h[Host]:host:_hosts' \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'nodetool subcommand' subcommands
        ;;
    args)
        _arguments \
            '*:keyspace or table'
        ;;
esac
