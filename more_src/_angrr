autoload -U is-at-least

_angrr() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--log-level=[Log level (off, error, warn, info, debug, trace)]:LEVEL:_default' \
'-c+[Path to configuration file]:FILE:_files' \
'--config=[Path to configuration file]:FILE:_files' \
'*-v[Increase log level (will be overridden by --log-level)]' \
'*--verbose[Increase log level (will be overridden by --log-level)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_angrr_commands" \
"*::: :->angrr" \
&& ret=0
    case $state in
    (angrr)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:angrr-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
'-i+[Prompt according to WHEN\: never, once, or always]' \
'--interactive=[Prompt according to WHEN\: never, once, or always]' \
'--output=[Output removed paths to the file]:FILE:_files' \
'--output-delimiter=[Output delimiter]:DELIMITER:_default' \
'--log-level=[Log level (off, error, warn, info, debug, trace)]:LEVEL:_default' \
'-c+[Path to configuration file]:FILE:_files' \
'--config=[Path to configuration file]:FILE:_files' \
'-n[Never prompt flag, override by \`--interactive\`]' \
'--no-prompt[Never prompt flag, override by \`--interactive\`]' \
'--no-statistic[Do not output statistic data]' \
'--output-unbuffered[Disable extra output buffering]' \
'--null-output-delimiter[Use \`\\0\` character as the output delimiter]' \
'--dry-run[Do not remove file]' \
'*-v[Increase log level (will be overridden by --log-level)]' \
'*--verbose[Increase log level (will be overridden by --log-level)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(touch)
_arguments "${_arguments_options[@]}" : \
'--max-depth=[Max recurse depth]:DEPTH:_default' \
'--log-level=[Log level (off, error, warn, info, debug, trace)]:LEVEL:_default' \
'-c+[Path to configuration file]:FILE:_files' \
'--config=[Path to configuration file]:FILE:_files' \
'-p[Project mode]' \
'--project[Project mode]' \
'-n[Do not recurse into directories]' \
'--no-recurse[Do not recurse into directories]' \
'-s[Do not output touched paths to stdout]' \
'--silent[Do not output touched paths to stdout]' \
'--output-runtime[Output runtime(in seconds) taken to stdout]' \
'--dry-run[Do not actually touch files]' \
'*-v[Increase log level (will be overridden by --log-level)]' \
'*--verbose[Increase log level (will be overridden by --log-level)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':path -- Path to touch:_files' \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
'--log-level=[Log level (off, error, warn, info, debug, trace)]:LEVEL:_default' \
'-c+[Path to configuration file]:FILE:_files' \
'--config=[Path to configuration file]:FILE:_files' \
'*-v[Increase log level (will be overridden by --log-level)]' \
'*--verbose[Increase log level (will be overridden by --log-level)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(example-config)
_arguments "${_arguments_options[@]}" : \
'--log-level=[Log level (off, error, warn, info, debug, trace)]:LEVEL:_default' \
'-c+[Path to configuration file]:FILE:_files' \
'--config=[Path to configuration file]:FILE:_files' \
'*-v[Increase log level (will be overridden by --log-level)]' \
'*--verbose[Increase log level (will be overridden by --log-level)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_angrr__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:angrr-help-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(touch)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(example-config)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_angrr_commands] )) ||
_angrr_commands() {
    local commands; commands=(
'run:Do retention' \
'touch:Touch GC roots' \
'validate:Validate and print configuration' \
'example-config:Print example configuration' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'angrr commands' commands "$@"
}
(( $+functions[_angrr__example-config_commands] )) ||
_angrr__example-config_commands() {
    local commands; commands=()
    _describe -t commands 'angrr example-config commands' commands "$@"
}
(( $+functions[_angrr__help_commands] )) ||
_angrr__help_commands() {
    local commands; commands=(
'run:Do retention' \
'touch:Touch GC roots' \
'validate:Validate and print configuration' \
'example-config:Print example configuration' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'angrr help commands' commands "$@"
}
(( $+functions[_angrr__help__example-config_commands] )) ||
_angrr__help__example-config_commands() {
    local commands; commands=()
    _describe -t commands 'angrr help example-config commands' commands "$@"
}
(( $+functions[_angrr__help__help_commands] )) ||
_angrr__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'angrr help help commands' commands "$@"
}
(( $+functions[_angrr__help__run_commands] )) ||
_angrr__help__run_commands() {
    local commands; commands=()
    _describe -t commands 'angrr help run commands' commands "$@"
}
(( $+functions[_angrr__help__touch_commands] )) ||
_angrr__help__touch_commands() {
    local commands; commands=()
    _describe -t commands 'angrr help touch commands' commands "$@"
}
(( $+functions[_angrr__help__validate_commands] )) ||
_angrr__help__validate_commands() {
    local commands; commands=()
    _describe -t commands 'angrr help validate commands' commands "$@"
}
(( $+functions[_angrr__run_commands] )) ||
_angrr__run_commands() {
    local commands; commands=()
    _describe -t commands 'angrr run commands' commands "$@"
}
(( $+functions[_angrr__touch_commands] )) ||
_angrr__touch_commands() {
    local commands; commands=()
    _describe -t commands 'angrr touch commands' commands "$@"
}
(( $+functions[_angrr__validate_commands] )) ||
_angrr__validate_commands() {
    local commands; commands=()
    _describe -t commands 'angrr validate commands' commands "$@"
}

if [ "$funcstack[1]" = "_angrr" ]; then
    _angrr "$@"
else
    compdef _angrr angrr
fi
