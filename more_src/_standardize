#compdef standardize
# Documentation: https://docs.chemaxon.com/latest/standardizer_command-line-application.html
# ChemAxon Standardizer command-line application

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-ha --help-actions)'{-ha,--help-actions}'[list of available actions]' \
  '(-c --config)'{-c,--config}'=[configuration XML file or action string]:config:_files' \
  '(-f --format)'{-f,--format}'=[output file format (default smiles)]:format:' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-e --export-fields-to-smiles)'{-e,--export-fields-to-smiles}'[export property fields to SMILES]' \
  '(-g --ignore-error)'{-g,--ignore-error}'[continue with next molecule on error]' \
  '--empty-mol-on-error[write an empty molecule and continue on error]' \
  '--unstandardized-mol-on-error[write the original molecule and continue on error]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output with time results]' \
  '--log=[write log messages to file]:file:_files' \
  '--loglevel=[set the log level]:level:(severe warning info off)' \
  '(-rp --report-property)'{-rp,--report-property}'=[name of the property to write report]:prop:' \
  '*:molecule file:_files' && ret=0

return ret
