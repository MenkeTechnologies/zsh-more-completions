#compdef psad

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--Version}'[show version]' \
  '(-A --Analyze-msgs)'{-A,--Analyze-msgs}'[analyze logs and exit]' \
  '(-D --debug)'{-D,--debug}'[debug mode]' \
  '(-i --interface)'{-i+,--interface=}'[interface]:if:_net_interfaces' \
  '(-S --Status)'{-S,--Status}'[show status]' \
  '(-F --Flush-all)'{-F,--Flush-all}'[flush all rules]' \
  '(-R --restart-fwsnort)'{-R,--restart-fwsnort}'[restart fwsnort]' \
  '(-X --auto-block-action)'{-X+,--auto-block-action=}'[block action]:a:(NEW DROP REJECT LOG)' \
  '(-N --Next-cycle)'{-N,--Next-cycle}'[run next analysis cycle]' \
  '--auto-nets[auto detect nets]' \
  '--auto-block-permanent[permanent block]' \
  '--auto-block-time+[block time]:s:' \
  '--no-fwcheck[skip fw check]' \
  '--no-rdns[no reverse DNS]' \
  '--no-whois[no whois]' \
  '--debug-syslog[debug syslog]' \
  '--restart[restart]' \
  '--config+[config file]:file:_files' \
  '--snort-rdir+[snort rules dir]:dir:_files -/' \
  '--snort-rules+[snort rules file]:file:_files' \
  '--Search-domains+[search domains]:list:' \
  '--CSV-fields+[csv fields]:fields:' \
  '--CSV-file+[csv output]:file:_files' \
  '*: :_files' && ret=0

return ret
