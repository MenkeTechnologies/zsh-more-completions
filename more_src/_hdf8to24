#compdef hdf8to24
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hdf8to24.1.en.html
# Convert an 8-bit HDF image to a 24-bit HDF image

local ret=1

_arguments -s \
  '-s+[magnification scale for the 8-bit input (default 1)]:scale' \
  '-j+[apply JPEG compression to output (default quality 75)]:quality' \
  '1:input hdf file:_files -g "*.(hdf|h4)"' \
  '2:output hdf file:_files -g "*.(hdf|h4)"' && ret=0

return ret
