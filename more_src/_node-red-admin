#compdef node-red-admin

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(--help)--help[show help]' \
  '(--version)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' \
  && ret=0

case $state in
  commands)
    local -a commands=(
      'target:set target Node-RED URL'
      'login:authenticate with Node-RED'
      'list:list installed nodes'
      'install:install a node module'
      'remove:remove a node module'
      'enable:enable a node module'
      'disable:disable a node module'
      'search:search for node modules'
      'info:show info about a node module'
      'hash-pw:generate password hash'
    )
    _describe -t commands 'node-red-admin command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      target)
        _arguments '1:target URL' && ret=0
        ;;
      install|remove|enable|disable|info)
        _arguments '1:module name' && ret=0
        ;;
      search)
        _arguments '1:search term' && ret=0
        ;;
    esac
    ;;
esac

return ret
