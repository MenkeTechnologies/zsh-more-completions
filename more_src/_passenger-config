#compdef passenger-config
# Documentation: https://manpages.debian.org/bookworm/passenger/passenger-config.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm passenger-config(1) manpage.

# passenger-config: Phusion Passenger configuration tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'about:show information about Passenger'
  'restart-app:restart an application'
  'detach-process:detach an app process'
  'reopen-logs:reopen log files'
  'system-metrics:show system metrics'
  'system-properties:show system properties'
  'compile-nginx-engine:compile nginx engine'
  'install-agent:install Passenger agent'
  'install-standalone-runtime:install standalone runtime'
  'build-native-support:build native support'
  'list-instances:list running Passenger instances'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--root[show Passenger root directory]' \
  '--version[show Passenger version]' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'passenger-config command' commands && ret=0 ;;
esac
return ret
