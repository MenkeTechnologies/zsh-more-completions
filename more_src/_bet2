#compdef bet2
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/fslwiki/BET/UserGuide
# bet2 - FSL Brain Extraction Tool (skull stripping)

local ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '-o[generate brain surface outline overlaid onto original image]' \
  '-m[generate binary brain mask]' \
  '-s[generate approximate skull image]' \
  '-n[do not generate the default brain image output]' \
  '-f[fractional intensity threshold (0->1, default 0.5)]:threshold:' \
  '-g[vertical gradient in fractional intensity threshold (-1->1)]:gradient:' \
  '-r[head radius (mm, initial surface sphere is set to half of this)]:radius:' \
  '-c[centre-of-gravity (voxels) of initial mesh surface]:x y z:' \
  '-t[apply thresholding to segmented brain image and mask]' \
  '-e[generate brain surface as mesh in .vtk format]' \
  '(-R -S -B -Z -F -A)-R[robust brain centre estimation (iterates BET several times)]' \
  '(-R -S -B -Z -F -A)-S[eye & optic nerve cleanup (disables -o option)]' \
  '(-R -S -B -Z -F -A)-B[bias field & neck cleanup]' \
  '(-R -S -B -Z -F -A)-Z[improve BET if FOV is very small in Z]' \
  '(-R -S -B -Z -F -A)-F[apply to 4D FMRI data]' \
  '(-R -S -B -Z -F -A)-A[run bet2 then betsurf for additional skull and scalp surfaces]' \
  '1:input image:_files -g "*.{nii,nii.gz,hdr,img}"' \
  '2:output brain image:_files -g "*.{nii,nii.gz,hdr,img}"' && ret=0

return ret
