#compdef cargo-nono
# _cargo-nono — check whether a crate / its deps are #[no_std] compatible (hobofan/cargo-nono)
# upstream: https://github.com/hobofan/cargo-nono
# Subcommands + flags from src/main.rs (clap).

_cargo-nono() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_cargo-nono_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                check)
                    _arguments \
                        '--no-default-features[evaluate with no default crate features]' \
                        '*--features=[features to evaluate (space- or comma-separated)]:features:' \
                        '--package=[only check this package]:package:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_cargo-nono_commands] )) ||
_cargo-nono_commands() {
    local -a commands
    commands=(
        'check:check the current crate (and its deps) for no_std compatibility'
    )
    _describe -t commands 'cargo-nono command' commands
}

_cargo-nono "$@"
