#compdef gpcore
# Documentation: https://github.com/g-portal/gpcore-cli
# Command line tool to interact with your GPCORE environment

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--endpoint=[set the API base URL]:url' \
  '--auth-realm=[set the authentication realm]:realm' \
  '--admin[enable admin mode]' \
  '--csv[output results in CSV format]' \
  '--json[output results in JSON format]' \
  '--id=[specify project UUID]:uuid' \
  '*:command:((agent\:"manage the SSH server agent" project\:"work with projects" user\:"user operations" loglevel\:"adjust logging verbosity" selfupdate\:"update the CLI to the latest release" completion\:"generate shell completion scripts" help\:"display help information"))' && ret=0

return ret
