#compdef gappa
# Documentation: https://github.com/lczech/gappa
# gappa: Genesis Applications for Phylogenetic Placement Analysis

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->module' \
  '2: :->command' \
  '*:: :->args' && ret=0

case $state in
  module)
    _values 'module' \
      'analyze[per-sample placement analyses]' \
      'edit[edit and manipulate jplace files]' \
      'examine[inspect and summarize placement files]' \
      'prepare[prepare data for placement analyses]' \
      'simulate[create random alignments, trees and placements]' \
      'tools[citation, license and version info]' && ret=0
    ;;
  command)
    case $line[1] in
      analyze)
        _values 'command' \
          'correlation[edge correlation of samples and metadata]' \
          'dispersion[edge dispersion between samples]' \
          'edgepca[edge PCA for a set of samples]' \
          'imbalance-kmeans[imbalance k-means clustering]' \
          'krd[pairwise Kantorovich-Rubinstein distance matrix]' \
          'phylogenetic-kmeans[phylogenetic k-means clustering]' \
          'placement-factorization[placement-factorization]' \
          'squash[squash clustering]' && ret=0
        ;;
      edit)
        _values 'command' \
          'accumulate[accumulate query masses into basal branches]' \
          'extract[extract placements from clades]' \
          'filter[filter jplace files by criteria]' \
          'merge[merge jplace files into one]' \
          'multiplicity[edit query multiplicities]' \
          'split[split queries into multiple files]' && ret=0
        ;;
      examine)
        _values 'command' \
          'assign[taxonomically assign placed queries]' \
          'edpl[expected distance between placement locations]' \
          'graft[tree with query sequences as pendant edges]' \
          'heat-tree[tree with edges colored by placement mass]' \
          'info[basic info about placement files]' \
          'lwr-distribution[likelihood weight ratio distribution]' \
          'lwr-histogram[histograms of likelihood weight ratios]' \
          'lwr-list[list of pqueries with likelihood weight ratios]' && ret=0
        ;;
      prepare)
        _values 'command' \
          'chunkify[chunkify fasta files and create abundance maps]' \
          'clean-tree[clean a Newick tree of problematic parts]' \
          'phat[generate consensus sequences via PhAT]' \
          'taxonomy-tree[convert taxonomy into a constraint tree]' \
          'unchunkify[unchunkify jplace files per sample]' && ret=0
        ;;
      simulate)
        _values 'command' \
          'random-alignment[create a random alignment]' \
          'random-placements[create random placements on a tree]' \
          'random-tree[create a random tree]' && ret=0
        ;;
      tools)
        _values 'command' \
          'citation[print references to cite]' \
          'license[show the license]' \
          'version[extended version information]' && ret=0
        ;;
    esac
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
