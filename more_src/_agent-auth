#compdef agent-auth wazuh-agent-auth ossec-agent-auth
# _agent-auth — Wazuh Inc agent-auth client CLI for registering Wazuh OSSEC agents against a manager via the authd REST endpoint exchanging shared keys for client certificate-based enrollment (wazuh team, C); getopt
# upstream: https://github.com/wazuh/wazuh

_agent-auth() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-m+[manager IP or hostname]:h:_hosts' \
        '--manager-ip=+[manager IP or hostname]:h:_hosts' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '-A+[agent name]:str:' \
        '--name=+[agent name]:str:' \
        '-c+[ca cert file]:file:_files -g "*.pem *.crt"' \
        '--ca-cert=+[ca cert file]:file:_files -g "*.pem *.crt"' \
        '-x+[client cert file]:file:_files -g "*.pem *.crt"' \
        '--client-cert=+[client cert file]:file:_files -g "*.pem *.crt"' \
        '-k+[client key file]:file:_files -g "*.pem *.key"' \
        '--client-key=+[client key file]:file:_files -g "*.pem *.key"' \
        '-P+[password]:str:' \
        '--password=+[password]:str:' \
        '-G+[group]:str:' \
        '--groups=+[csv groups]:str:' \
        '-D+[home dir]:dir:_files -/' \
        '--home=+[home dir]:dir:_files -/' \
        '-I+[agent address]:str:' \
        '--agent-ip=+[agent address]:str:' \
        '-i[force reinstall]' \
        '--force[force reinstall]'
}

_agent-auth "$@"
