#compdef apollo

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'client\:check:check a client project against a service'
  'client\:codegen:generate code from GraphQL schema'
  'client\:download-schema:download GraphQL schema'
  'client\:extract:extract queries from a client project'
  'client\:push:push client queries to Apollo'
  'service\:check:check a service against known operations'
  'service\:download:download a service schema'
  'service\:push:push a service schema to Apollo'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'apollo command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (client:codegen)
        _arguments \
          '--target=[target language]:target:(typescript swift scala flow)' \
          '--includes=[file glob to include]:glob' \
          '--excludes=[file glob to exclude]:glob' \
          '--localSchemaFile=[path to local schema]:file:_files' \
          '--tagName=[template tag name]:tag' \
          '--namespace=[namespace for generated types]:namespace' \
          '--outputFlat[output all generated files in one directory]' \
          '--passthroughCustomScalars[use custom scalars as-is]' \
          '--mergeInFieldsFromFragmentSpreads[merge fragment fields]' \
          '--addTypename[add __typename to operations]' \
          '--key=[API key]:key' \
          '--endpoint=[endpoint to query]:url' \
          '--header=[HTTP header]:header' \
          '1:output path:_files' && ret=0
        ;;
      (client:download-schema|service:download)
        _arguments \
          '--key=[API key]:key' \
          '--endpoint=[endpoint to query]:url' \
          '--header=[HTTP header]:header' \
          '1:output file:_files' && ret=0
        ;;
      (client:check|service:check)
        _arguments \
          '--key=[API key]:key' \
          '--endpoint=[endpoint to query]:url' \
          '--header=[HTTP header]:header' \
          '--tag=[schema tag]:tag' \
          '--includes=[file glob to include]:glob' \
          '--excludes=[file glob to exclude]:glob' \
          '--localSchemaFile=[path to local schema]:file:_files' && ret=0
        ;;
      (service:push|client:push)
        _arguments \
          '--key=[API key]:key' \
          '--endpoint=[endpoint to query]:url' \
          '--header=[HTTP header]:header' \
          '--tag=[schema tag]:tag' \
          '--localSchemaFile=[path to local schema]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
