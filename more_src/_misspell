#compdef misspell
# Documentation: https://github.com/client9/misspell
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-debug[debug output]' \
  '-error[exit non-zero on misspellings]' \
  '-f+[output format]:fmt' \
  '-help[show help]' \
  '-i+[ignore corrections csv]:words' \
  '-j+[parallel jobs]:n' \
  '-legal[display legal information and exit]' \
  '-locale+[spelling preferences]:locale:(US UK)' \
  '-o+[output destination]:dest' \
  '-q[suppress misspelling output]' \
  '-source+[source mode]:mode:(auto go text)' \
  '-w[overwrite files with corrections]' \
  '*: :_files' && ret=0

return ret
