#compdef misspell

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-debug[debug output]' \
  '-error[exit non-zero on misspellings]' \
  '-f+[output format]:fmt:' \
  '-help[show help]' \
  '-i+[ignore words csv]:words:' \
  '-j+[parallel jobs]:n:' \
  '-locale+[locale]:l:(US UK GB)' \
  '-o+[output file]:file:_files' \
  '-q[quiet]' \
  '-source+[source type]:s:(text go)' \
  '-w[overwrite files in place]' \
  '*: :_files' && ret=0

return ret
