#compdef stegseek
# Documentation: https://github.com/RickdeJager/stegseek
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--crack[crack mode (default)]' \
  '--seed[seed mode]' \
  '(-sf --stegofile)'{-sf,--stegofile}'=[stego file]:file:_files -g "*.(jpg|jpeg|bmp|wav|au)"' \
  '(-wl --wordlist)'{-wl,--wordlist}'=[wordlist]:file:_files' \
  '(-xf --extractfile)'{-xf,--extractfile}'=[output file]:file:_files' \
  '(-f --force)'{-f,--force}'[overwrite output file]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-t --threads)'{-t,--threads}'=[number of threads]:threads:' \
  '(-n --nocolor)'{-n,--nocolor}'[no color output]' \
  '1:stego file:_files -g "*.(jpg|jpeg|bmp|wav|au)"' \
  '2::wordlist:_files' \
  '3::output file:_files' && ret=0

return ret
