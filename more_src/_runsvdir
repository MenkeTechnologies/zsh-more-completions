#compdef runsvdir
# Documentation: https://smarden.org/runit/runsvdir.8
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '-P[run each runsv in a new session]'
  '-s[script to run on SIGTERM/SIGHUP]:script:_files'
  '1:directory:_directories'
)

_arguments -s -S $arguments
