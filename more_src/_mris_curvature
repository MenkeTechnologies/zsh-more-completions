#compdef mris_curvature
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_curvature
# mris_curvature - compute principal curvatures and directions of a surface

local ret=1

_arguments -s -S \
  '-w[write curvature files (.H and .K) to disk]' \
  '-a[apply n iterations of smoothing to the surface]:n:' \
  '*:input surface:_files' && ret=0

return ret
