#compdef grafana-server
# Documentation: https://grafana.com/docs/grafana/latest/setup-grafana/configure-grafana/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s \
  '--config=[config file]:file:_files' \
  '--homepath=[home directory]:dir:_files -/' \
  '--pidfile=[PID file]:file:_files' \
  '--packaging=[packaging type]:type:(deb rpm brew docker hosted)' \
  '*--configOverrides=[config overrides]:overrides:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]'
