#compdef sustrip
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/sustrip.c
# SUSTRIP - remove the SEGY headers from the traces

local ret=1

_arguments -s -S \
  'head=[file to save headers in]:f:_files' \
  'outpar=[output parameter file]:f:_files' \
  'ftn=[Fortran flag (0 = C, 1 = Fortran)]:f:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
