#compdef beam-wallet
# _beam-wallet — BEAM Development beam-wallet CLI for the Mimblewimble-based privacy-focused BEAM main-net wallet daemon and CLI managing BEAM keys creating sending receiving offline payments lelantus shielded transactions assets confidential treasury (BeamMW team, C++); boost program_options
# upstream: https://github.com/BeamMW/beam

_beam-wallet() {
    local -a sub=(
        'init:initialize wallet'
        'restore:restore wallet from seed'
        'info:show info'
        'send:send funds'
        'receive:receive funds'
        'listen:listen for offline transactions'
        'cancel_tx:cancel transaction'
        'delete_tx:delete transaction'
        'export_owner_key:export owner key'
        'export_miner_key:export miner key'
        'rescan:rescan wallet'
        'address_list:list addresses'
        'tx_history:transaction history'
        'tx_details:transaction details'
        'create_address:create new address'
        'delete_address:delete address'
        'restore_from_db:restore from db'
        'lelantus_send:lelantus shielded send'
        'lelantus_extract:lelantus extract'
        'asset_issue:issue asset'
        'asset_consume:consume asset'
        'asset_register:register asset'
        'asset_unregister:unregister asset'
        'asset_info:asset info'
        'export_data:export wallet data'
        'import_data:import wallet data'
        'block_details:show block details'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--storage=+[file]:file:_files -g "*.db"' \
        '--pass=+[password]:str:' \
        '--seed_phrase=+[phrase]:str:' \
        '--testnet[use testnet]' \
        '--mainnet[use mainnet]' \
        '--node_addr=+[host:port]:str:' \
        '--log_level=+[level]:l:(error warning info debug verbose trace)' \
        '--config=+[file]:file:_files -g "*.cfg beam-wallet.cfg"' \
        '--api_use_http[enable HTTP API]' \
        '--api_use_tls[enable TLS API]' \
        '--api_listen=+[host:port]:str:' \
        '--key_owner=+[file]:file:_files' \
        '--key_view=+[file]:file:_files' \
        '--cwd=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'beam-wallet subcommand' sub ;;
        args)
            case $words[1] in
                send) _arguments \
                    '--amount=+[BEAM]:f:' \
                    '--fee=+[BEAM]:f:' \
                    '--receiver_addr=+[addr]:str:' \
                    '--asset_id=+[id]:n:' ;;
                create_address) _arguments \
                    '--comment=+[text]:str:' \
                    '--expiration_time=+[d]:str:' ;;
            esac
            ;;
    esac
}

_beam-wallet "$@"
