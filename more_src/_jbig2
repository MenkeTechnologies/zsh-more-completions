#compdef jbig2
# Documentation: https://github.com/agl/jbig2enc
# JBIG2 encoder (jbig2enc)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --basename)'{-b,--basename}'[output file root name for symbol coding]:basename' \
  '(-d --duplicate-line-removal)'{-d,--duplicate-line-removal}'[use TPGD in generic region coder]' \
  '(-p --pdf)'{-p,--pdf}'[produce PDF ready data]' \
  '(-s --symbol-mode)'{-s,--symbol-mode}'[use text region, not generic coder]' \
  '-t[set classification threshold (def 0.92)]:threshold' \
  '-w[set classification weight (def 0.50)]:weight' \
  '-T[set 1 bpp threshold (def 200)]:threshold' \
  '(-G --global)'{-G,--global}'[use global BW threshold on 8 bpp images]' \
  '(-r --refine)'{-r,--refine}'[use refinement (requires -s: lossless)]' \
  '-O[dump thresholded image as PNG]:file:_files' \
  '-2[upsample 2x before thresholding]' \
  '-4[upsample 4x before thresholding]' \
  '-S[remove images from mixed input and save separately]' \
  '(-j --jpeg-output)'{-j,--jpeg-output}'[write images from mixed input as JPEG]' \
  '(-a --auto-thresh)'{-a,--auto-thresh}'[use automatic thresholding in symbol encoder]' \
  '--no-hash[disable hash function for automatic thresholding]' \
  '(-D --dpi)'{-D,--dpi}'[force dpi]:dpi' \
  '(-V --version)'{-V,--version}'[version info]' \
  '-v[be verbose]' \
  '*:file:_files' && ret=0

return ret
