#compdef JLECmd
# Documentation: https://github.com/EricZimmerman/JLECmd
# Jump List Explorer Command line edition

local ret=1

_arguments -s -S \
  '-d[directory to recursively process]:directory:_files -/' \
  '-f[file to process]:file:_files' \
  '-q[show only filename being processed]' \
  '--all[process all files vs only destinations-ms]' \
  '--csv[directory for CSV results]:directory:_files -/' \
  '--csvf[filename for CSV results]:filename' \
  '--html[directory for XHTML results]:directory:_files -/' \
  '--json[directory for JSON output]:directory:_files -/' \
  '--pretty[human readable JSON formatting]' \
  '--ld[include additional lnk file information]' \
  '--fd[include full lnk file information]' \
  '--appIds[path to file with AppID descriptions]:file:_files' \
  '--dumpTo[directory to save exported lnk files]:directory:_files -/' \
  '--withDir[show directory contents not in DestList]' \
  '--dt[custom date/time format]:format' \
  '--mp[display higher precision for timestamps]' \
  '--Debug[enable debug mode]' && ret=0

return ret
