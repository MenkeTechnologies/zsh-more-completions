#compdef interimap
# Documentation: https://manpages.debian.org/unstable/interimap/interimap.1.en.html
# interimap - fast bidirectional synchronization for QRESYNC-capable IMAP servers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config=[use configuration FILE]:file:_files' \
  '*--target=[limit scope of delete/rename to target]:target:(local remote database)' \
  '--watch=-[keep synchronizing, sleeping seconds between runs]::seconds' \
  '--notify[use IMAP NOTIFY for idle synchronization]' \
  '--repair[repair the given mailboxes]' \
  '--delete[delete the given mailboxes]' \
  '--rename[rename SOURCE mailbox to DEST]' \
  '(-q --quiet)'{-q,--quiet}'[reduce verbosity]' \
  '--debug[enable debug output]' \
  '*:mailbox:' && ret=0

return ret
