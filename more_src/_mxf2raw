#compdef mxf2raw
# Documentation: source-direct extraction from upstream
# bbc/bmx apps/mxf2raw/mxf2raw.cpp 3450-line hand-rolled
# `for (cmdln_index = 1; cmdln_index < argc; cmdln_index++)`
# argv-walking loop with `strcmp(argv[cmdln_index], "--flag")`
# arms - same bmx/dvrescue convention documented in R206 +
# R207 HARVEST_LOG entries.  Flag set extracted from the
# `usage()` function's printf block (lines 1693-1810).
# Reference accessed: 2026-05-30 via gh api.
# BBC bmx mxf2raw R208 — follow-up to R207's hunt-skip on
# "mxf2raw (3450 lines, ~80+ flags) extracts raw essence from
# MXF; deferred".  This round picks off the middle-sized bmx
# tool.  mxf2raw is the BBC bmx MXF-to-raw essence extractor:
# inputs an MXF file (any operational pattern, with optional
# AS-10/AS-11/UK-DPP/APP metadata), extracts raw essence
# (video/audio/data) to per-track .raw or .klv files, plus
# optional text-based metadata extraction (APP CRC-32, APP
# event-log, ADM CHNA descriptors, RDD 6 audio metadata, Wave
# chunks).  Heavily used in BBC broadcast workflows + the
# Archive Preservation Project (APP) at the BBC Archive.

# Checksum types enum decoded source-direct from upstream's
# `parse_checksum_type(opt, &checkum_type)` parser which
# accepts crc32/md5/sha1.
local -a bmx_checksum_types=(crc32 md5 sha1)

# Info-format enum: text or xml.
local -a mxf2raw_info_formats=(text xml)

# Log-level enum (same as bmxparse R207).
local -a bmx_log_levels=('0:debug' '1:info' '2:warning' '3:error')

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-v --version)'{-v,--version}'[print version info to stderr]' \
  '-l+[log to file (default stderr)]:file:_files' \
  '--log-level=[log level (0=debug 1=info 2=warning 3=error)]:level:(0 1 2 3)' \
  '--file-chksum-only=[calculate input file checksum and exit]:type:(crc32 md5 sha1)' \
  '--group[use the group reader instead of the sequence reader]' \
  '--no-reorder[do not re-order inputs by timecode (use for broken-TC files)]' \
  '--check-end[check that the last edit unit can be read when opening]' \
  '--check-complete[check that the input file structure is complete]' \
  '--check-app-issues[check for known issues with the APP (Archive Preservation Project) file]' \
  '--check-app-crc32[check APP essence CRC-32 data]' \
  '(-i --info)'{-i,--info}'[extract input information (default to stdout)]' \
  '--info-format=[input-info output format (text|xml; default text)]:fmt:(text xml)' \
  '--info-file=[input-info output filename (default stdout)]:file:_files' \
  '--track-chksum=[calculate per-track essence-data checksum]:type:(crc32 md5 sha1)' \
  '--file-chksum=[calculate input file checksum]:type:(crc32 md5 sha1)' \
  '--as11[extract AS-11 + UK DPP metadata]' \
  '--as10[extract AS-10 metadata]' \
  '--app[extract APP metadata]' \
  '--app-events=[APP event-types to extract (mask of d/p/t/v for digibeta-dropout/PSE-failure/timecode-break/VTR-error)]:mask:' \
  '--no-app-events-tc[do not extract timecodes from essence container for APP-event association]' \
  '--app-crc32=[output APP CRC-32 frame-data file]:file:_files' \
  '--app-tc=[output APP timecodes file]:file:_files' \
  '--all-tc=[output header + content package metadata timecodes file]:file:_files' \
  '--index[extract index tables]' \
  '--avid[extract Avid metadata]' \
  '--st436-mf=[number of frames to examine for SMPTE ST 436 ANC/VBI manifest]:count:' \
  '--rdd6=[extract RDD 6 audio metadata]:frame-range (single frame or N-M):filename:_files -g "*.xml"' \
  '--mca-detail[show detailed MCA channel-label info]' \
  '(-p --ess-out)'{-p+,--ess-out=}'[output essence prefix (suffix .raw)]:prefix:' \
  '--wrap-klv=[wrap essence frames as KLV (suffix .klv; mask v=video a=audio d=data)]:mask:' \
  '--read-ess[read essence data even when no other option requires it]' \
  '--deint[de-interleave multi-channel / AES-3 sound]' \
  '--start=[start edit unit (default 0)]:count:' \
  '--dur=[duration in edit units (default = min available)]:count:' \
  '--nopc[do not include pre-charge frames]' \
  '--noro[do not include roll-out frames]' \
  '--rt=[read at realtime rate x FACTOR (1.0=realtime, <1=slower, >1=faster)]:factor:' \
  '--no-seq-scan[(Windows) do not set sequential-scan file-cache hint]' \
  '--mmap-file[(Windows, non-MinGW) use memory-mapped file I/O for MXF]' \
  '--gf[support growing files: retry reading a frame on failure]' \
  '--gf-retries=[max times to retry on read failure]:n:' \
  '--gf-delay=[delay (seconds) between failure and retry]:sec:' \
  '--gf-rate=[realtime-rate factor after a read failure (1.0=RT)]:factor:' \
  '--disable-indexing-file[do not pre-index partitions and essence positions]' \
  '--http-min-read=[min bytes to read when accessing file over HTTP]:bytes:' \
  '--http-disable-seek[disable seeking when reading file over HTTP]' \
  '--text-out=[extract text-based objects to files with this prefix (.xml or .txt)]:prefix:' \
  '--wave-chunks-out=[extract Wave chunks to files with this prefix]:prefix:' \
  '--filter-wave-chunks=[comma-separated list of Wave chunk IDs to extract]:ids:' \
  '--chna-text-out=[extract mapped ADM CHNA descriptors as text files with prefix]:prefix:' \
  '--disable-tracks=[(per-input) comma-separated track-index list/range (e.g. "0-3,7,9")]:tracks:' \
  '--disable-audio[(per-input) disable audio tracks when reading essence]' \
  '--disable-video[(per-input) disable video tracks when reading essence]' \
  '--disable-data[(per-input) disable data tracks when reading essence]' \
  '*:MXF file ("-" for stdin):_files -g "*.(mxf|MXF)"'
