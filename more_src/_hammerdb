#compdef hammerdb
# Database load testing and benchmarking tool

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--cli[run in CLI mode]' \
  '--auto[run in auto mode with script]:script:_files' \
  '--librarycheck[check required libraries]' \
  && return 0
