#compdef areaimol
# CCP4: calculate solvent-accessible surface area of a structure

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZIN2[second input coordinate file (DIFFMODE COMPARE)]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZOUT[output pseudo-PDB file with area data]:output:_files' \
  '*:keyword:(DIFFMODE MODE SMODE TRANS)' && ret=0

return ret
