#compdef compute-sanitizer
# Documentation: https://docs.nvidia.com/compute-sanitizer/ComputeSanitizer/index.html
# Reference accessed: 2026-05-16
# Verified: NVIDIA Compute Sanitizer manual.
# Removed from prior file: bogus man.archlinux.org search URL.

# compute-sanitizer: NVIDIA CUDA error sanitizer (memcheck/race/init/sync)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--tool=[sanitizer tool]:tool:(memcheck racecheck initcheck synccheck)' \
  '--log-file=[log output to file]:file:_files' \
  '--save=[save report to file]:file:_files' \
  '--xml[XML output]' \
  '--prefix=[output line prefix]:prefix:' \
  '--print-level=[print level]:level:' \
  '--print-limit=[max errors to print]:n:' \
  '(-s --launch-skip)'{-s+,--launch-skip=}'[skip first N kernel launches]:n:' \
  '(-c --launch-count)'{-c+,--launch-count=}'[check only N kernel launches]:n:' \
  '*--kernel-name=[only check matching kernels]:regex:' \
  '*--kernel-name-exclude=[exclude matching kernels]:regex:' \
  '--force-blocking-launches[force blocking launches]' \
  '--force-synchronization-limit=[sync limit]:n:' \
  '--check-device-heap[check device heap]' \
  '--require-cuda-init[require CUDA init]' \
  '--leak-check=[leak check mode]:mode:(full no)' \
  '--padding=[padding bytes]:n:' \
  '--report-api-errors=[report API errors]:bool:(all no explicit)' \
  '--track-stream-ordered-races[track stream-ordered races]' \
  '--racecheck-report=[racecheck report level]:level:' \
  '--racecheck-deadlock-timeout=[deadlock timeout]:s:' \
  '--racecheck-trace-sync[trace sync ops]' \
  '--show-backtrace=[backtrace mode]:mode:(no host device yes)' \
  '--backtrace-short[short backtraces]' \
  '--destroy-on-device-error=[behavior on device error]:mode:(context kernel)' \
  '--error-exitcode=[exit code on error]:n:' \
  '--suppressions=[suppression file]:file:_files' \
  '--check-optix-leaks[check OptiX leaks]' \
  '--generate-coredump=[generate coredump]:bool:(yes no)' \
  '--coredump-name=[coredump filename]:name:' \
  '--language=[host language]:lang:(c c++)' \
  '*:cuda executable:_files' && ret=0
return ret
