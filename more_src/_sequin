#compdef sequin
# Documentation: https://sequinstream.com/docs/reference/cli/overview
# Reference accessed: 2026-05-21
# Verified: upstream sequinstream.com CLI overview + cli/main.go in
# github.com/sequinstream/sequin.
# Removed from prior file: fabricated consumer, stream, database, login,
# logout, observe top-level commands. main.go only registers
# AddContextCommands, AddTunnelCommands, AddConfigCommands.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'context:manage CLI contexts (configurations and environments)'
      'config:manage Sequin resources via YAML configuration files'
      'tunnel:create a tunnel to a local service'
    )
    _describe -t commands 'sequin command' commands && ret=0
    ;;
  args)
    case $line[1] in
      context)
        _arguments '1:action:(add ls select)' && ret=0
        ;;
      config)
        _arguments '1:action:(export plan apply interpolate)' '*:file:_files' && ret=0
        ;;
      tunnel)
        _arguments \
          '--port=[local port]:port:' \
          '--consumer=[consumer ID]:id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
