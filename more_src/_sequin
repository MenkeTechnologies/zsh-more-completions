#compdef sequin

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:manage configuration'
      'context:manage CLI contexts'
      'consumer:manage consumers'
      'database:manage database connections'
      'login:authenticate with Sequin'
      'logout:log out from Sequin'
      'observe:observe messages in real time'
      'stream:manage streams'
      'tunnel:create a tunnel to local service'
    )
    _describe -t commands 'sequin command' commands && ret=0
    ;;
  args)
    case $line[1] in
      consumer)
        _arguments '1:action:(create delete info list receive ack nack)' && ret=0
        ;;
      stream)
        _arguments '1:action:(create delete info list send)' && ret=0
        ;;
      database)
        _arguments '1:action:(create delete list info setup)' && ret=0
        ;;
      tunnel)
        _arguments \
          '--port=[local port]:port' \
          '--consumer=[consumer ID]:id' && ret=0
        ;;
      context)
        _arguments '1:action:(create list select)' && ret=0
        ;;
    esac
    ;;
esac

return ret
