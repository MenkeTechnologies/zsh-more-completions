#compdef applyconfiguration-gen
# _applyconfiguration-gen — Kubernetes server-side-apply configuration generator (kubernetes/code-generator)
# upstream: https://github.com/kubernetes/code-generator
# Flags from cmd/applyconfiguration-gen/args/args.go on tip.

_applyconfiguration-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--output-dir=[output directory]:dir:_files -/' \
        '--output-pkg=[output Go package path]:pkg:' \
        '--go-header-file=[Go header file prepended to generated files]:file:_files' \
        '*--external-applyconfigurations=[external applyconfig mappings (pkg.Type=applyconfig-pkg,...)]:list:' \
        '--openapi-schema=[OpenAPI schema file used for field discovery]:file:_files' \
        '*--lint-rules=[gengo lint rules to enable (comma-sep)]:rules:' \
        '-v[klog verbosity level]:n:' \
        '*:input-package:'
}

_applyconfiguration-gen "$@"
