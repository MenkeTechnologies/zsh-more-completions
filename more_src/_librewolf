#compdef librewolf librewolf-bin

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--browser[open in browser window]' \
  '--private-window[open new private window]' \
  '--new-window=[open URL in new window]:url:' \
  '--new-tab=[open URL in new tab]:url:' \
  '--search=[search query]:query:' \
  '-P+[use named profile]:profile:' \
  '--profile=[explicit profile path]:dir:_files -/' \
  '--profile-manager[show profile manager]' \
  '--ProfileManager[show profile manager]' \
  '--no-remote[disable remote connections]' \
  '--new-instance[start a new instance]' \
  '--allow-downgrade[allow profile downgrade]' \
  '--first-startup[show first-run dialog]' \
  '--marionette[enable marionette automation]' \
  '--start-debugger-server=[remote debug port]:port:' \
  '--remote-debugging-port=[devtools remote port]:port:' \
  '--devtools[open developer tools]' \
  '--screenshot=[save screenshot]:file:_files' \
  '--window-size=[window size WxH]:WxH:' \
  '--headless[run headless]' \
  '*:url_or_file:_files' && ret=0

return ret
