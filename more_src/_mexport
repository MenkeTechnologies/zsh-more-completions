#compdef mexport
# Documentation: https://manpages.debian.org/testing/mblaze/mexport.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream Debian man page at the URL above.
# mexport (mblaze): export Maildir messages as an mbox file on stdout.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-S[add Status: and X-Status: headers from Maildir flags]' \
  '*:message:_files' && ret=0

return ret
