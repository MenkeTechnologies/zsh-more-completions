#compdef curl-cli
# _curl-cli — Daniel Stenberg curl client URL transfer tool CLI alias (curl team, C); custom argparse
# upstream: https://github.com/curl/curl

_curl-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--manual[show extensive manual]' \
        '-M[show extensive manual]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-O[remote-name]' \
        '--remote-name[remote-name]' \
        '-J[remote-header-name]' \
        '--remote-header-name[remote-header-name]' \
        '-L[follow redirects]' \
        '--location[follow redirects]' \
        '-X+[request method]:m:(GET POST PUT PATCH DELETE OPTIONS HEAD TRACE CONNECT PROPFIND PROPPATCH MKCOL COPY MOVE LOCK UNLOCK)' \
        '--request=+[request method]:m:(GET POST PUT PATCH DELETE OPTIONS HEAD TRACE CONNECT PROPFIND PROPPATCH MKCOL COPY MOVE LOCK UNLOCK)' \
        '-H+[header]:str:' \
        '--header=+[header]:str:' \
        '-d+[data]:str:' \
        '--data=+[data]:str:' \
        '--data-raw=+[data]:str:' \
        '--data-binary=+[data]:str:' \
        '--data-urlencode=+[data]:str:' \
        '-F+[form data]:str:' \
        '--form=+[form data]:str:' \
        '--form-string=+[form data]:str:' \
        '-u+[user:password]:str:' \
        '--user=+[user:password]:str:' \
        '-A+[user-agent]:str:' \
        '--user-agent=+[user-agent]:str:' \
        '-e+[referer]:url:_urls' \
        '--referer=+[referer]:url:_urls' \
        '-c+[cookie jar]:file:_files' \
        '--cookie-jar=+[cookie jar]:file:_files' \
        '-b+[cookie]:str:' \
        '--cookie=+[cookie]:str:' \
        '-i[include response headers]' \
        '--include[include response headers]' \
        '-I[show response headers only]' \
        '--head[show response headers only]' \
        '-D+[dump headers]:file:_files' \
        '--dump-header=+[dump headers]:file:_files' \
        '-w+[write-out format]:str:' \
        '--write-out=+[write-out format]:str:' \
        '-s[silent]' \
        '--silent[silent]' \
        '-S[show errors with silent]' \
        '--show-error[show errors with silent]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--trace=+[file]:file:_files' \
        '--trace-ascii=+[file]:file:_files' \
        '-k[insecure SSL]' \
        '--insecure[insecure SSL]' \
        '--cacert=+[ca cert]:file:_files' \
        '--capath=+[ca path]:dir:_files -/' \
        '-E+[client cert]:file:_files' \
        '--cert=+[client cert]:file:_files' \
        '--key=+[private key]:file:_files' \
        '-x+[proxy]:str:' \
        '--proxy=+[proxy]:str:' \
        '--socks5=+[host:port]:str:' \
        '--socks5-hostname=+[host:port]:str:' \
        '--noproxy=+[no proxy hosts]:str:' \
        '--proxy-user=+[user:password]:str:' \
        '-U+[proxy user:password]:str:' \
        '-r+[byte range]:str:' \
        '--range=+[byte range]:str:' \
        '-z+[time condition]:str:' \
        '--time-cond=+[time condition]:str:' \
        '--max-time=+[seconds]:n:' \
        '-m+[seconds]:n:' \
        '--connect-timeout=+[seconds]:n:' \
        '--retry=+[count]:n:' \
        '--retry-delay=+[seconds]:n:' \
        '--retry-max-time=+[seconds]:n:' \
        '-4[ipv4]' \
        '--ipv4[ipv4]' \
        '-6[ipv6]' \
        '--ipv6[ipv6]' \
        '--http1.0[http 1.0]' \
        '--http1.1[http 1.1]' \
        '--http2[http 2]' \
        '--http3[http 3]' \
        '-K+[config file]:file:_files' \
        '--config=+[config file]:file:_files' \
        '-T+[upload file]:file:_files' \
        '--upload-file=+[upload file]:file:_files' \
        '-Z[parallel transfers]' \
        '--parallel[parallel transfers]' \
        '--parallel-max=+[n]:n:' \
        '-G[get instead of post]' \
        '--get[get instead of post]' \
        '-n[netrc]' \
        '--netrc[netrc]' \
        '--netrc-file=+[file]:file:_files' \
        '--netrc-optional[netrc optional]' \
        '--compressed[request compressed]' \
        '-j[junk session cookies]' \
        '--junk-session-cookies[junk session cookies]' \
        '--resolve=+[host:port:address]:str:' \
        '--interface=+[interface]:_net_interfaces' \
        '--limit-rate=+[rate]:str:' \
        '--digest[HTTP digest auth]' \
        '--basic[HTTP basic auth]' \
        '--anyauth[HTTP any auth]' \
        '--negotiate[HTTP negotiate auth]' \
        '--ntlm[HTTP NTLM auth]' \
        '--oauth2-bearer=+[token]:str:' \
        '--aws-sigv4=+[provider]:str:' \
        '-q[disable .curlrc]' \
        '--disable[disable .curlrc]' \
        '*:url:_urls'
}

_curl-cli "$@"
