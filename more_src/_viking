#compdef viking

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '(--profile)--profile[run with profiling]' \
  '(--latitude)--latitude=+[latitude]:lat:' \
  '(--longitude)--longitude=+[longitude]:lon:' \
  '(--zoom)--zoom=+[zoom level]:zoom:' \
  '(--map)--map=+[map id]:map:' \
  '(--external)--external=+[external mod]:mod:' \
  '*:file:_files -g "*.{vik,gpx,kml,kmz,fit,igc,nmea,tcx,geojson,tomtom,oziexplorer}"' && ret=0

return ret
