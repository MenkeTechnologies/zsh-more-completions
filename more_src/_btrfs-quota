#compdef btrfs-quota
# _btrfs-quota — btrfs-progs btrfs quota (enable/disable/rescan the quota groups (qgroups) subsystem on a btrfs filesystem; enable/disable take the mountpoint, rescan triggers a deep recount, --simple-mode enables the simplified single-shared accounting, -w wait for rescan)
# upstream: https://github.com/kdave/btrfs-progs
# Subcommands from btrfs-progs cmds/quota.c on tip.

_btrfs-quota() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'quota command' '(enable disable rescan)' ;;
        args)
            case $line[1] in
                enable) _arguments '--simple-mode[simple-mode qgroups]' '*:mountpoint:_files -/' ;;
                rescan) _arguments '-s[status]' '-w[wait]' '*:mountpoint:_files -/' ;;
                disable) _arguments '*:mountpoint:_files -/' ;;
            esac
            ;;
    esac
}

_btrfs-quota "$@"
