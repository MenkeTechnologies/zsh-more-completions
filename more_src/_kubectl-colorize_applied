#compdef kubectl-colorize_applied
# Documentation: https://github.com/cappyzawa/kubectl-colorize-applied
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (internal/cmd source).

# kubectl-colorize_applied (cappyzawa/kubectl-colorize-applied): reads stdin
# from `kubectl apply --dry-run` and colorizes pruned/configured/created/
# unchanged lines. No own flags beyond genericclioptions ConfigFlags.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--context=[kubeconfig context]:context:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '--user=[kubeconfig user name]:user:'
