#compdef gff3ToGenePred
# UCSC kent: convert a GFF3 file to a genePred file

local ret=1

_arguments -s -S \
  '-warnAndContinue[on bad genePreds put out warning but continue]' \
  '-useName[use the name tag as the name if present]' \
  '-rnaNameAttr=[use this RNA attribute as the genePred name column]:attr' \
  '-geneNameAttr=[use this gene attribute as the genePred name2 column]:attr' \
  '-attrsOut=[output attributes of mRNA record to file]:file:_files' \
  '-processAllGeneChildren[output genePred for all children of a gene]' \
  '-unprocessedRootsOut=[output GFF3 root records that were not used]:file:_files' \
  '-bad=[output genepreds that fail checks to file]:file:_files' \
  '-maxParseErrors=[maximum parsing errors before aborting]:n' \
  '-maxConvertErrors=[maximum conversion errors before aborting]:n' \
  '-honorStartStopCodons[only set CDS start/stop status from codon records]' \
  '-defaultCdsStatusToUnknown[default CDS status to unknown rather than complete]' \
  '-allowMinimalGenes[allow genes with exons as direct children and standalone genes]' \
  '-refseqHacks[enable hacks to make RefSeq conversion work]' \
  '1:input gff3:_files' \
  '2:output genePred:_files' && ret=0

return ret
