#compdef qodem
# Documentation: https://linux.die.net/man/1/qodem
# Reference accessed: 2026-05-17
# Verified: qodem(1) manpage on linux.die.net / openSUSE Leap manpages.
# Removed from prior file: bogus man.archlinux.org search URL;
# missing all qodem-specific flags.

# qodem: terminal emulator (modem/SSH/telnet/serial)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--capfile[capture file]:file:_files' \
  '--logfile[log file]:file:_files' \
  '--dial[phonebook entry index]:n:' \
  '--connect[host]:host:_hosts' \
  '--connect-method[connection method]:method:(ssh rlogin rsh telnet socket shell)' \
  '--username[user]:user:_users' \
  '--xterm[xterm-style]' \
  '--keyfile[key bindings file]:file:_files' \
  '--xl8file[translate-8 file]:file:_files' \
  '--xlufile[translate-Unicode file]:file:_files' \
  '--scrfile[script file]:file:_files' \
  '--config[config file]:file:_files' \
  '--create-config[create config file]:file:_files' \
  '--dotqodem-dir[.qodem directory]:dir:_files -/' \
  '--emulation[emulation type]:emu:' \
  '--codepage[codepage]:cp:' \
  '--geometry[geometry COLSxROWS]:WxH:' \
  '--status-line[status line]:state:(on off)' \
  '--doorway[doorway mode]:mode:(doorway mixed off)' \
  '--play[play music]:music:' \
  '--play-exit[exit after music]' \
  '--read-only[read-only mode]' \
  '--exit-on-completion[exit after script]' \
  '--version[show version]' \
  '(-h --help -?)'{-h,--help,-\?}'[show help]' && ret=0
return ret
