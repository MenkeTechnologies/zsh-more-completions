#compdef minio-mc

local curcontext="$curcontext" state line ret=1

(( $+functions[_mc] )) || autoload -Uz _mc 2>/dev/null
if (( $+functions[_mc] )); then
  _mc "$@"
  return
fi

local -a subcommands

subcommands=(
  'alias:manage server credentials in config file'
  'admin:manage MinIO servers'
  'anonymous:manage anonymous access to buckets and objects'
  'batch:manage batch jobs'
  'cat:display object contents'
  'cp:copy objects'
  'diff:show differences between two folders'
  'du:summarize disk usage'
  'encrypt:manage bucket encryption config'
  'event:manage object notifications'
  'find:search for objects'
  'get:get S3 object to local'
  'head:display first n lines'
  'idp:manage MinIO IDP configurations'
  'ilm:manage bucket lifecycle'
  'license:manage MinIO licenses'
  'legalhold:manage legal hold for object'
  'ls:list buckets and objects'
  'mb:make a bucket'
  'mirror:synchronize folders to a remote'
  'mv:move objects'
  'od:object disposition (block size and parity)'
  'one:upload a single object'
  'pipe:stream STDIN to an object'
  'put:upload object'
  'quota:manage bucket quotas'
  'rb:remove a bucket'
  'replicate:configure server side bucket replication'
  'restore:restore a copy of an object'
  'retention:manage retention policies'
  'rm:remove objects'
  'sed:replace text in an object'
  'share:generate URL for temporary access'
  'sql:run S3 select query'
  'stat:show metadata for object'
  'support:support related commands'
  'tag:manage tags for bucket and objects'
  'tree:list buckets and objects in tree format'
  'undo:undo PUT/DELETE operations'
  'update:update mc to the latest version'
  'version:manage bucket versioning'
  'watch:listen for object notification events'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config-dir=[path to configuration folder]:dir:_files -/' \
  '--debug[enable debug output]' \
  '--insecure[disable SSL certificate verification]' \
  '--json[enable JSON formatted output]' \
  '--no-color[disable color theme]' \
  '--quiet[disable progress bar display]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mc subcommand' subcommands && ret=0
    ;;
esac

return ret
