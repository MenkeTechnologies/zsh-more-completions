#compdef termvisage
# Documentation: https://termvisage.readthedocs.io/en/latest/cli.html
# terminal image viewer/browser built on term-image

local ret=1

_arguments -s -S \
  '(- *)--help[show basic help message]' \
  '(- *)--long-help[show full help message]' \
  '(- *)--version[print program version]' \
  '--completions[show shell tab-completion instructions]' \
  '--query-timeout=[terminal query timeout in seconds]:seconds' \
  '(-S --style)'{-S,--style=}'[rendering style]:style:(auto block iterm2 kitty)' \
  '--force-style[use specified style despite compatibility warnings]' \
  '(-C --cell-ratio)'{-C,--cell-ratio=}'[character cell width-to-height ratio]:ratio' \
  '--auto-cell-ratio[auto-detect cell ratio from terminal]' \
  '--swap-win-size[enable dimension workaround]' \
  '--no-swap-win-size[disable dimension workaround]' \
  '--cli[skip TUI, render directly to terminal]' \
  '--tui[launch interactive interface]' \
  '(-f --frame-duration)'{-f,--frame-duration=}'[time between frames in seconds]:seconds' \
  '(-R --repeat)'{-R,--repeat=}'[frame repetition count]:count' \
  '--anim-cache=[maximum cached frame count]:count' \
  '--cache-all-anim[cache all animation frames]' \
  '--cache-no-anim[disable frame caching]' \
  '--no-anim[disable animations]' \
  '--no-alpha[remove transparency]' \
  '(-A --alpha)'{-A,--alpha=}'[opacity threshold 0-1]:threshold' \
  '(-b --alpha-bg)'{-b,--alpha-bg=}'[replacement color for transparent areas]:color' \
  '--h-allow=[minimum unused columns]:columns' \
  '--v-allow=[minimum unused lines]:lines' \
  '--scroll[allow vertical overflow]' \
  '(-O --oversize)'{-O,--oversize}'[permit oversized images]' \
  '(-w --width)'{-w,--width=}'[image width in columns]:columns' \
  '(-h --height)'{-h,--height=}'[image height in lines]:lines' \
  '--fit[optimal terminal fitting]' \
  '--fit-to-width[fit to available width]' \
  '--original-size[use native image dimensions]' \
  '(-s --scale)'{-s,--scale=}'[uniform scaling factor]:factor' \
  '(-x --scale-x)'{-x,--scale-x=}'[horizontal scaling]:factor' \
  '(-y --scale-y)'{-y,--scale-y=}'[vertical scaling]:factor' \
  '--no-align[disable alignment/padding]' \
  '(-H --h-align)'{-H,--h-align=}'[horizontal positioning]:align:(left center right)' \
  '--pad-width=[alignment column width]:width' \
  '(-V --v-align)'{-V,--v-align=}'[vertical positioning]:align:(top middle bottom)' \
  '--pad-height=[alignment line height]:height' \
  '(-a --all)'{-a,--all}'[include hidden files/directories]' \
  '(-r --recursive)'{-r,--recursive}'[recursive directory scanning]' \
  '(-d --max-depth)'{-d,--max-depth=}'[maximum recursion depth]:depth' \
  '--thumbnail[enable thumbnail generation]' \
  '--no-thumbnail[disable thumbnail generation]' \
  '--max-pixels=[maximum renderable pixel count]:pixels' \
  '--multi[enable multiprocessing]' \
  '--no-multi[disable multiprocessing]' \
  '--config=[specify configuration file]:file:_files' \
  '--no-config[use default configuration]' \
  '(-l --log-file)'{-l,--log-file=}'[log output destination]:file:_files' \
  '--log-level=[logging verbosity]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '(-q --quiet)'{-q,--quiet}'[suppress notifications]' \
  '(-v --verbose)'{-v,--verbose}'[enhanced event reporting]' \
  '--verbose-log[detailed file logging]' \
  '--debug[debug mode with verbose output]' \
  '(--kz --kitty-z-index)'{--kz,--kitty-z-index=}'[image stacking order]:index' \
  '(--kc --kitty-compress)'{--kc,--kitty-compress=}'[ZLIB compression level]:level' \
  '(--itn --iterm2-native)'{--itn,--iterm2-native}'[enable native animation support]' \
  '(--itnmb --iterm2-native-max-bytes)'{--itnmb,--iterm2-native-max-bytes=}'[maximum animation data size]:bytes' \
  '(--itc --iterm2-compress)'{--itc,--iterm2-compress=}'[PNG compression level]:level' \
  '(--itjq --iterm2-jpeg-quality)'{--itjq,--iterm2-jpeg-quality=}'[JPEG quality setting]:quality' \
  '(--itnrff --iterm2-no-read-from-file)'{--itnrff,--iterm2-no-read-from-file}'[force image re-encoding]' \
  '*:source:_files' && ret=0

return ret
