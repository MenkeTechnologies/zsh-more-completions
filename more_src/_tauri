#compdef tauri cargo-tauri

# Zsh completion for Tauri CLI

_tauri() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:initialize a Tauri project in an existing directory'
    'dev:start the application in development mode'
    'build:build the application for production'
    'icon:generate various icons for all major platforms'
    'info:show a list of libraries and system dependencies'
    'add:add a Tauri plugin to the project'
    'plugin:manage Tauri plugins'
    'signer:sign the application bundle'
    'completions:generate shell completions'
    'permission:manage permissions'
    'capability:manage capabilities'
    'inspect:inspect the Tauri configuration'
    'android:manage Android project'
    'ios:manage iOS project'
    'migrate:migrate from one Tauri version to the next'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'tauri command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        init)
          _arguments -s -S \
            '--app-name=[app name]:name:' \
            '--window-title=[window title]:title:' \
            '--dist-dir=[web assets directory]:directory:_files -/' \
            '--dev-path=[dev server URL or directory]:URL or path:' \
            '-d+[set directory]:directory:_files -/' \
            '--directory=[set directory]:directory:_files -/' \
            '-f[force initialization even if directory is not empty]' \
            '--force[force initialization even if directory is not empty]' \
            '-l[write logs to terminal]' \
            '--log[write logs to terminal]' \
            '--ci[skip prompts]' \
            && ret=0
          ;;
        dev)
          _arguments -s -S \
            '-r+[binary runner]:runner:' \
            '--runner=[binary runner]:runner:' \
            '-e+[binary exit code that will stop the watcher]:exit code:' \
            '--exit-on-panic[exit on panic]' \
            '-c+[config file]:config:_files -g "*.{json,json5,toml}"' \
            '--config=[config file]:config:_files -g "*.{json,json5,toml}"' \
            '-f+[features to activate]:features:' \
            '--features=[features to activate]:features:' \
            '--release[build in release mode]' \
            '--target=[target triple]:target:' \
            '--no-watch[disable file watcher]' \
            '--no-dev-server[do not start dev server]' \
            '--port=[port for dev server]:port:' \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            && ret=0
          ;;
        build)
          _arguments -s -S \
            '-r+[binary runner]:runner:' \
            '--runner=[binary runner]:runner:' \
            '-d[debug build]' \
            '--debug[debug build]' \
            '-b+[bundles to create]:bundles:(deb appimage msi nsis dmg app updater)' \
            '--bundles=[bundles to create]:bundles:(deb appimage msi nsis dmg app updater)' \
            '-c+[config file]:config:_files -g "*.{json,json5,toml}"' \
            '--config=[config file]:config:_files -g "*.{json,json5,toml}"' \
            '-f+[features to activate]:features:' \
            '--features=[features to activate]:features:' \
            '--target=[target triple]:target:' \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            '--ci[run in CI mode]' \
            && ret=0
          ;;
        icon)
          _arguments -s -S \
            '-o+[output directory]:directory:_files -/' \
            '--output=[output directory]:directory:_files -/' \
            '--ios-color=[iOS icon background color]:color:' \
            '--png=[create custom-size icon.png]:size:' \
            '1:icon file:_files -g "*.{png,svg}"' \
            && ret=0
          ;;
        add)
          _arguments -s -S \
            '--tag=[git tag]:tag:' \
            '--branch=[git branch]:branch:' \
            '--rev=[git revision]:rev:' \
            '1:plugin name:' \
            && ret=0
          ;;
        plugin)
          _arguments -s -S \
            '1:subcommand:(init new)' \
            && ret=0
          ;;
        signer)
          _arguments -s -S \
            '1:subcommand:(generate sign)' \
            && ret=0
          ;;
        android)
          _arguments -s -S \
            '1:subcommand:(init dev build open)' \
            && ret=0
          ;;
        ios)
          _arguments -s -S \
            '1:subcommand:(init dev build open)' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[display version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_tauri "$@"
