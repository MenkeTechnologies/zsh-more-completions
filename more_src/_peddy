#compdef peddy
# Documentation: https://github.com/brentp/peddy
# QC and pedigree-relationship checks from a VCF and PED file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--plot[generate QC plots]' \
  '(-p --procs)'{-p,--procs}'=[number of CPUs to use]:procs' \
  '--prefix=[output file prefix]:prefix' \
  '--sites=[genome build sites]:sites:(hg19 GRCh37 hg38)' \
  '--each=[sampling stride]:n' \
  '--loglevel=[logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '1:vcf file:_files -g "*.vcf(|.gz)"' \
  '2:ped file:_files -g "*.(ped|fam)"' && ret=0

return ret
