#compdef kmix
# Documentation: https://apps.kde.org/kmix/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# KMix: KDE volume mixer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options inc Qt/KF]' \
  '(- *)--help-qt[show Qt-specific options]' \
  '(- *)--help-kde[show KDE-specific options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--style=[GUI style]:style:' \
  '--stylesheet=[Qt stylesheet]:file:_files' \
  '--platform=[Qt platform plugin]:platform:' \
  '--display=[X display]:display:' \
  '--platformpluginpath=[Qt plugin path]:dir:_files -/' \
  '--graphicssystem=[graphics system]:system:(raster opengl openvg)' \
  '--reverse[reverse layout direction]' \
  '*:file:_files -g "*"' && ret=0
return ret
