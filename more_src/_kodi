#compdef kodi
# kodi — open source media center

_arguments -s -S \
  '(- *)--help[show help]' \
  '--debug[enable debug logging]' \
  '(-w --windowed)'{-w,--windowed}'[run in windowed mode]' \
  '(-fs --fullscreen)'{-fs,--fullscreen}'[run in fullscreen mode]' \
  '(-p --portable)'{-p,--portable}'[run in portable mode]' \
  '--standalone[run in standalone mode]' \
  '--test[run in test mode]' \
  '--settings[open settings dialog on startup]' \
  '--no-addons[start without loading addons]' \
  '--lircdev[LIRC device to use]:device:_files -g "*(-%)"' \
  '--audio-backend[audio backend to use]:backend' \
  '--log-file[log file path]:log file:_files' \
  '*:media file:_files' \
  && return 0
