#compdef bottles bottles-cli
# Documentation: https://docs.usebottles.com/advanced/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for bottles-cli - Wine prefix manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'info:show Bottles system information'
  'list:enumerate bottles and components'
  'programs:display programs within a bottle'
  'tools:launch Wine utilities (cmd, winecfg, regedit)'
  'reg:manage Windows registry entries'
  'edit:modify bottle configuration'
  'add:register new programs to a bottle'
  'new:create a new bottle'
  'run:execute programs or executables'
  'shell:run commands in a Wine shell'
  'standalone:generate standalone launch scripts'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'bottles command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (list)
        _arguments \
          '(-f --filter)'{-f,--filter=}'[filter by env/category]:filter:' && ret=0
        ;;
      (programs|tools|run|shell)
        _arguments \
          '(-b --bottle)'{-b,--bottle=}'[target bottle]:bottle:' \
          '*:args:' && ret=0
        ;;
      (reg)
        _arguments \
          '(-k --key)'{-k,--key=}'[registry key]:key:' \
          '(-v --value)'{-v,--value=}'[value name]:value:' \
          '(-d --data)'{-d,--data=}'[value data]:data:' \
          '(-t --key-type)'{-t,--key-type=}'[value type]:type:' && ret=0
        ;;
      (edit)
        _arguments \
          '--runner=[Wine runner]:runner:' \
          '--dxvk=[DXVK version]:version:' \
          '--vkd3d=[VKD3D version]:version:' \
          '--win=[Windows version]:winver:' && ret=0
        ;;
      (new)
        _arguments \
          '--bottle-name=[bottle name]:name:' \
          '--environment=[environment]:env:(gaming application custom)' \
          '--arch=[architecture]:arch:(win32 win64)' && ret=0
        ;;
    esac
    ;;
esac

return ret
