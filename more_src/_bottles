#compdef bottles

# Zsh completion for bottles - Wine prefix manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-b+[specify bottle]:bottle name' \
  '--bottle[specify bottle]:bottle name' \
  '-e+[execute program in bottle]:program:_files' \
  '--executable[execute program in bottle]:program:_files' \
  '-l[list bottles]' \
  '--list[list bottles]' \
  '--json[output as JSON]' \
  '*:arguments:' && ret=0

return ret
