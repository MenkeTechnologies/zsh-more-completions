#compdef splittilt
# Documentation: https://bio3d.colorado.edu/imod/doc/man/splittilt.html
# Produce multiple command files for running Tilt in parallel

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '-CommandFile[Tilt command file. It can be entered with or without...]:file:_files' \
  '(-outroot -ou -RootNameOfOutput)'{-outroot,-ou,-RootNameOfOutput}'[Root name for output command files (default is root of input]:value' \
  '(-naming -na -NamingStyle)'{-naming,-na,-NamingStyle}'[0 if image files have descriptive extensions like...]:value' \
  '(-n -ProcessorNumber)'{-n,-ProcessorNumber}'[The number of machines that you expect to run the command...]:value' \
  '(-s -SliceMinimum)'{-s,-SliceMinimum}'[Minimum number of slices per chunk (default 50)]:value' \
  '(-t -TargetChunks)'{-t,-TargetChunks}'[Target number of chunks (default 5 times expected # of...]:value' \
  '(-m -ChunkMinimum)'{-m,-ChunkMinimum}'[Minimum number of chunks, except when vertical slices are...]:value' \
  '(-p -OldStyleXtiltPenalty)'{-p,-OldStyleXtiltPenalty}'[Computational penalty for old-style X-axis tilting (default]:value' \
  '(-v -VerticalSlices)'{-v,-VerticalSlices}'[Do vertical slices instead of old-style X-axis tilting,...]' \
  '(-c -SeparateChunks)'{-c,-SeparateChunks}'[Write chunks to separate files named setname-nnn.rec and...]' \
  '(-b -BoundaryPixels)'{-b,-BoundaryPixels}'[Number of pixels at each boundary between chunks to save in...]:value' \
  '(-i -InitialComNumber)'{-i,-InitialComNumber}'[Start with given command file number instead of 1. When this]:value' \
  '(-o -OpenForMoreComs)'{-o,-OpenForMoreComs}'[Leave the command file set open by naming the command file...]' \
  '(-unique -un -UniqueInfoFile)'{-unique,-un,-UniqueInfoFile}'[Attach the first command file number to a boundary info file]' \
  '(-d -DimensionsOfStack)'{-d,-DimensionsOfStack}'[Use the given values as the dimensions of the aligned stack.]:value' \
  '-StandardInput[read parameters from standard input]' \
  '-usage[print usage]' \
  '*:file:_files' && ret=0

return ret
