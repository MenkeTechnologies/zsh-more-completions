#compdef grafana-agent-flow
# _grafana-agent-flow — Flow-mode-only Grafana Agent binary (no static-mode pivot)
# upstream: https://github.com/grafana/agent
# Subcommands + flags from internal/flowmode/{flowmode,cmd_run,cmd_convert,cmd_fmt,cmd_tools}.go on tip (cobra).

_grafana-agent-flow() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                run:'run a Flow configuration file'
                convert:'convert a static-mode config to a Flow river config'
                fmt:'format a Flow river config file'
                tools:'collected diagnostic / inspection tools'
            )
            _describe -t commands 'grafana-agent-flow subcommand' subs
            ;;
        args)
            case $line[1] in
                run)
                    _arguments \
                        '--server.http.listen-addr=[HTTP listen address]:addr:' \
                        '--server.http.memory-addr=[in-memory HTTP address]:addr:' \
                        '--server.http.ui-path-prefix=[prefix to serve the HTTP UI at]:path:' \
                        '--server.http.enable-pprof[enable /debug/pprof endpoints]' \
                        '--cluster.enabled[start in clustered mode]' \
                        '--cluster.node-name=[name to use for this node]:name:' \
                        '--cluster.advertise-address=[address to advertise to the cluster]:addr:' \
                        '--cluster.join-addresses=[csv of addresses to join]:csv:' \
                        '--cluster.discover-peers=[key=value list for peer discovery]:kv:' \
                        '--cluster.rejoin-interval=[how often to rejoin peers]:duration:' \
                        '--cluster.max-join-peers=[number of peers to join from discovered set]:n:' \
                        '--cluster.name=[name of the cluster to join]:name:' \
                        '--config.format=[source file format]:fmt:(flow static prometheus promtail otelcol)' \
                        '--config.bypass-conversion-errors[bypass errors when converting]' \
                        '--config.extra-args=[extra arguments for the converter]:args:' \
                        '--disable-reporting[disable reporting of enabled components to Grafana]' \
                        '--storage.path=[base directory where components store data]:dir:_files -/' \
                        '*:config:_files'
                    ;;
                convert)
                    _arguments \
                        '(-f --source-format)'{-f,--source-format}'=[source config format]:fmt:(static prometheus promtail otelcol)' \
                        '(-o --output)'{-o,--output}'=[output file (default stdout)]:file:_files' \
                        '(-r --report)'{-r,--report}'=[conversion report output file]:file:_files' \
                        '(-b --bypass-errors)'{-b,--bypass-errors}'[bypass errors during conversion]' \
                        '*:source:_files'
                    ;;
                fmt)
                    _arguments \
                        '(-w --write)'{-w,--write}'[write result back to the source file]' \
                        '*:file:_files'
                    ;;
            esac
            ;;
    esac
}

_grafana-agent-flow "$@"
