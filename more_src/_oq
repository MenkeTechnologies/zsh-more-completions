#compdef oq
# oq — portable, jq-compatible processor for JSON, XML, YAML, CSV

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-i --input)'{-i,--input}'[input format]:format:(json xml yaml csv tsv)' \
  '(-o --output)'{-o,--output}'[output format]:format:(json xml yaml csv tsv text)' \
  '--xml-root=[root element name for XML output]:name:' \
  '--xml-item=[item element name for XML arrays]:name:' \
  '--csv-delimiter=[CSV field delimiter]:char:' \
  '(-n --null-input)'{-n,--null-input}'[do not read any input]' \
  '(-N --null-output)'{-N,--null-output}'[do not produce output]' \
  '(-r --raw-output)'{-r,--raw-output}'[output raw strings]' \
  '(-R --raw-input)'{-R,--raw-input}'[read each line as a JSON string]' \
  '(-c --compact-output)'{-c,--compact-output}'[compact output]' \
  '(-e --exit-status)'{-e,--exit-status}'[set exit status based on output]' \
  '(-j --json-output)'{-j,--json-output}'[force JSON output]' \
  '(-S --sort-keys)'{-S,--sort-keys}'[sort keys in output]' \
  '--tab[use tab for indentation]' \
  '--indent=[number of spaces for indentation]:n:' \
  '--slurp[read entire input as single array]' \
  '--rawfile=[bind variable to raw file content]:var=file:' \
  '--jsonargs[treat remaining args as JSON]' \
  '--args[treat remaining args as strings]' \
  '--arg=[set variable to string value]:name=value:' \
  '--argjson=[set variable to JSON value]:name=value:' \
  '1:jq filter:' \
  '*:input file:_files' \
  && ret=0

return ret
