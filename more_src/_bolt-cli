#compdef bolt
# _bolt — Puppet Bolt (agentless orchestrator: command/script/file/task/plan/apply on targets via SSH/WinRM/PCP/local; project/inventory/module/secret/group subcommands manage on-disk state)
# upstream: https://github.com/puppetlabs/bolt
# Subcommands from bolt lib/bolt/cli.rb on tip.

_bolt-cli() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--version[show version]' \
        '-h[show help]' \
        '--help[show help]' \
        '--debug[debug output]' \
        '--trace[trace]' \
        '--log-level+[log level]:level:(trace debug info warn error fatal)' \
        '--no-color[disable colors]' \
        '--format+[output format]:format:(human json rainbow)' \
        '1: :->subsystem' \
        '*::arg:->args'
    case $state in
        subsystem)
            _describe -t commands 'bolt subsystem' \
                '(command script file task plan apply lookup secret module project group inventory guide policy debug help)'
            ;;
        args)
            case $line[1] in
                command|script) _describe -t commands 'action' '(run)' ;;
                file) _describe -t commands 'action' '(download upload)' ;;
                task|plan) _describe -t commands 'action' '(run show new convert)' ;;
                lookup) _arguments '*:key:' ;;
                secret) _describe -t commands 'action' '(encrypt decrypt createkeys)' ;;
                module) _describe -t commands 'action' '(add install show generate-types)' ;;
                project) _describe -t commands 'action' '(init migrate)' ;;
                inventory) _describe -t commands 'action' '(show)' ;;
                group) _describe -t commands 'action' '(show)' ;;
                policy) _describe -t commands 'action' '(apply show new)' ;;
                guide) _arguments '1:topic:' ;;
            esac
            ;;
    esac
}

_bolt-cli "$@"
