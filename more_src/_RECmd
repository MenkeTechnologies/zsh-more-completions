#compdef RECmd
# Documentation: https://github.com/EricZimmerman/RECmd
# RECmd - Registry Explorer command-line registry hive parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[hive file to search]:file:_files' \
  '-d[directory to recursively search for hives]:directory:_directories' \
  '--kn=[display details for key name]:keyname' \
  '--vn=[value name to dump]:valuename' \
  '--bn=[batch mode settings file]:file:_files' \
  '--csv=[directory for CSV results]:directory:_directories' \
  '--csvf=[custom filename for CSV output]:filename' \
  '--saveTo=[file path to save binary value data]:file:_files' \
  '--json=[directory for JSON results]:directory:_directories' \
  '--jsonf=[custom filename for JSON output]:filename' \
  '--details[show additional details]' \
  '--base64=[find Base64 values >= byte size]:bytes' \
  '--minSize=[find values with data size >= bytes]:bytes' \
  '--sa=[search keys, values, data, slack]:term' \
  '--sk=[search in key names]:term' \
  '--sv=[search in value names]:term' \
  '--sd=[search in value data]:term' \
  '--ss=[search in value slack]:term' \
  '--literal[treat search values as literal]' \
  '--nd[suppress data display]' \
  '--regex[treat search strings as regex]' \
  '--dt=[custom datetime format]:format' \
  '--nl=[allow dirty hives without transaction logs]:bool:(true false)' \
  '--recover=[recover deleted keys/values]:bool:(true false)' \
  '--vss=[process Volume Shadow Copies]:bool:(true false)' \
  '--dedupe=[deduplicate files by SHA-1]:bool:(true false)' \
  '--sync=[download latest batch files]:bool:(true false)' \
  '--debug=[show debug information]:bool:(true false)' \
  '--trace=[show trace information]:bool:(true false)' && ret=0

return ret
