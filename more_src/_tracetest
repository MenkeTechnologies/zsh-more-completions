#compdef tracetest

# Zsh completion for tracetest CLI (kubeshop/tracetest)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'[output format]:format' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose debug]' \
  '(-s --server-url)'{-s,--server-url}'[Tracetest server URL]:url' \
  '--skip-verify[skip TLS verification]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      apply configure dashboard docgen environment datastore test server start version wait
      delete export get list run
    )
    _describe -t commands 'tracetest command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
