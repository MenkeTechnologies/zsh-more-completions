#compdef tracetest
# Documentation: https://docs.tracetest.io/cli/reference/tracetest
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tracetest CLI (kubeshop/tracetest)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help information]' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(pretty json yaml)' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[display debug information]' \
  '(-s --server-url)'{-s+,--server-url=}'[Tracetest server URL]:url' \
  '--skip-verify[skip verification of server certificate]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'apply:apply resources'
      'completion:generate autocompletion scripts for specified shells'
      'configure:configure your tracetest CLI'
      'dashboard:opens the Tracetest Dashboard URL'
      'delete:delete resources'
      'export:export resource'
      'get:get resource'
      'list:list resources'
      'run:run tests and test suites'
      'server:manage your tracetest server'
      'start:start Tracetest'
      'version:display CLI tool version'
      'wait:wait for a run group to be finished'
    )
    _describe -t commands 'tracetest command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
