#compdef sov
# Documentation: https://github.com/milgra/sov
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --columns)'{-c+,--columns=}'[number of thumbnail columns]:columns:' \
  '(-a --anchor)'{-a+,--anchor=}'[anchor window to screen edges (e.g. rt for right-top)]:lrtb:' \
  '(-m --margin)'{-m+,--margin=}'[margin from screen edge]:size:' \
  '(-r --ratio)'{-r+,--ratio=}'[thumbnail-to-screen ratio (positive integer)]:ratio:' \
  '(-t --timeout)'{-t+,--timeout=}'[ms to wait before showing overlay (positive integer)]:milliseconds:' \
  '(-k --holdkey)'{-k+,--holdkey=}'[keycode of hold key; sov stays visible while pressed]:keycode:' \
  '-v[increase verbosity of messages]' \
  '-s[location of html folder for styling]:dir:_files -/' \
  '-n[use workspace name instead of workspace number]' && ret=0

return ret
