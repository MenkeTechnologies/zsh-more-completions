#compdef mysql-router

# mysql-router: MySQL Router (HA / sharding routing proxy)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-c[config file]:file:_files -g "*.conf"' \
  '--config=[config file]:file:_files -g "*.conf"' \
  '-a[extra config]:file:_files' \
  '--extra-config=[extra config]:file:_files' \
  '-u[run as user]:user:_users' \
  '--user=[run as user]:user:_users' \
  '--service[run as Windows service]' \
  '--remove-service[remove Windows service]' \
  '--install-service[install Windows service]' \
  '--install-service-manual[install service for manual start]' \
  '--update-credentials-section=[update keyring section]:section:' \
  '--remove-credentials-section=[remove keyring section]:section:' \
  '--master-key-reader=[master key reader]:cmd:' \
  '--master-key-writer=[master key writer]:cmd:' \
  '--clear-all-credentials[clear all stored credentials]' \
  '--core-file[dump core on crash]' \
  '*::mysql-router args:_files' && ret=0
return ret
