#compdef stap

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p[stop after pass]:pass:(1 2 3 4 5)' \
  '*-e[inline script]:script:' \
  '*-E[additional script]:script:' \
  '-l[list matching probes]:probe:' \
  '-L[list probes with context vars]:probe:' \
  '-g[guru mode]' \
  '-u[unoptimized]' \
  '-w[suppress warnings]' \
  '-W[warnings as errors]' \
  '-k[keep build dir]' \
  '-m[kernel module name]:module:' \
  '*-d[add symbol info for module]:module:' \
  '*-I[tapset search path]:dir:_files -/' \
  '*-D[preprocessor define]:name=value:' \
  '*-B[kernel build flag]:name=value:' \
  '-a[cross-compile target]:arch:' \
  '-R[runtime sources dir]:dir:_files -/' \
  '-r[kernel build tree or release]:dir-or-release:' \
  '-s[per-CPU buffer MB]:mb:' \
  '-b[bulk mode]' \
  '-o[output destination]:file:_files' \
  '-S[max output file size and count]:size,n:' \
  '-c[run command then exit]:command:' \
  '-x[target process]:pid:' \
  '-t[timing stats]' \
  '-T[exit after seconds]:seconds:' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
  '-F[daemon/detach]' \
  '--privilege=[privilege mode]:mode:(stapusr stapsys stapdev)' \
  '--unprivileged[unprivileged mode]' \
  '--use-server=[use compile server]:spec:' \
  '--use-server-on-error=[fall back to server on error]:value:(yes no)' \
  '--list-servers=[list servers]:spec:' \
  '--trust-servers=[trust servers]:spec:' \
  '--sign-module[sign module]' \
  '--build-as=[build as user]:user:_users' \
  '*-G[set global]:name=value:' \
  '*--modinfo=[module info]:name=value:' \
  '--ldd[follow dynamic library deps]' \
  '--all-modules[probe all modules]' \
  '--skip-badvars[skip undefined variable errors]' \
  '*-v[increase verbosity]' \
  '--vp=[per-pass verbosity]:abcde:' \
  '--disable-cache[disable cache]' \
  '--clean-cache[clean cache]' \
  '--poison-cache[poison cache]' \
  '--dump-probe-types[dump probe types]' \
  '--dump-probe-aliases[dump probe aliases]' \
  '--dump-functions[dump functions]' \
  '--example[example mode]' \
  '--monitor=[monitor interval]:interval:' \
  '--no-global-var-display[do not show global vars]' \
  '--language-server[language server mode]' \
  '--suppress-handler-errors[suppress handler errors]' \
  '--suppress-time-limits[suppress time limits]' \
  '--color=[color output]:when:(never always auto)' \
  '--colour=[color output]:when:(never always auto)' \
  '--compatible=[compatible version]:version:' \
  '--check-version[check version]' \
  '(-P --prologue-searching)'{-P,--prologue-searching=}'[prologue searching]:value:(never always auto)' \
  '--remote=[remote URL]:url:' \
  '--remote-prefix[prefix output with remote name]' \
  '--runtime=[runtime]:runtime:(kernel dyninst bpf)' \
  '--dyninst[use dyninst runtime]' \
  '--bpf[use bpf runtime]' \
  '--save-uprobes[save uprobes]' \
  '--sysroot=[sysroot]:dir:_files -/' \
  '*--sysenv=[sysenv var]:name=value:' \
  '--target-namespaces=[target namespace PID]:pid:' \
  '--download-debuginfo=[download debuginfo]:value:(yes no ask)' \
  '--rlimit-as=[rlimit AS]:n:' \
  '--rlimit-cpu=[rlimit CPU]:n:' \
  '--rlimit-nproc=[rlimit nproc]:n:' \
  '--rlimit-stack=[rlimit stack]:n:' \
  '--rlimit-fsize=[rlimit fsize]:n:' \
  '*:script:_files'
