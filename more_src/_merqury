#compdef merqury merqury.sh
# merqury — reference-free quality and completeness evaluation using k-mers

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# merqury.sh takes positional arguments:
#   merqury.sh <read-db.meryl> [mat.meryl pat.meryl] <asm1.fasta> [asm2.fasta] <output>
# No traditional --flags; purely positional arguments.

_arguments -s -S \
  '1:meryl database directory:_files -/' \
  '2:assembly FASTA or second meryl db:_files' \
  '3:assembly FASTA or output prefix:_files' \
  '4:second assembly or output prefix:_files' \
  '5:output prefix (if using two assemblies):' \
  && ret=0

return ret
