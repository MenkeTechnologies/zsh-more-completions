#compdef cdi-cloner
# _cdi-cloner — CDI clone-source binary (streams a source PVC over the network to the cloned target)
# upstream: https://github.com/kubevirt/containerized-data-importer
# Flags from cmd/cdi-cloner/clone-source.go on tip.

_cdi-cloner() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--content-type=[clone content type]:type:(filesystem-clone blockdevice-clone)' \
        '--mount=[pvc mount point]:dir:_files -/' \
        '--upload-bytes=[approx number of bytes in input]:n:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[log to stderr and files]' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files'
}

_cdi-cloner "$@"
