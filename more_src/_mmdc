#compdef mmdc
# Documentation: https://github.com/mermaid-js/mermaid-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for Mermaid CLI (mermaid-js/mermaid-cli)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --input)'{-i+,--input=}'[input file (- for stdin)]:input file:_files -g "*.{mmd,md,mermaid}"' \
  '(-o --output)'{-o+,--output=}'[output file]:output file:_files -g "*.{svg,png,pdf}"' \
  '(-a --artefacts)'{-a+,--artefacts=}'[output dir for markdown images]:dir:_files -/' \
  '(-e --outputFormat)'{-e+,--outputFormat=}'[output format]:format:(svg png pdf)' \
  '(-t --theme)'{-t+,--theme=}'[theme]:theme:(default forest dark neutral)' \
  '(-b --backgroundColor)'{-b+,--backgroundColor=}'[background color]:color:' \
  '(-c --configFile)'{-c+,--configFile=}'[mermaid config file]:config file:_files -g "*.json"' \
  '(-C --cssFile)'{-C+,--cssFile=}'[custom CSS file]:css file:_files -g "*.css"' \
  '(-I --svgId)'{-I+,--svgId=}'[SVG element id]:id:' \
  '(-w --width)'{-w+,--width=}'[width]:n:' \
  '(-H --height)'{-H+,--height=}'[height]:n:' \
  '(-s --scale)'{-s+,--scale=}'[puppeteer scale]:n:' \
  '(-f --pdfFit)'{-f,--pdfFit}'[scale PDF to fit chart]' \
  '(-p --puppeteerConfigFile)'{-p+,--puppeteerConfigFile=}'[puppeteer config file]:config file:_files -g "*.json"' \
  '(-q --quiet)'{-q,--quiet}'[suppress log output]' \
  '*--iconPacks=[Iconify NPM packages]:packages:' \
  '*--iconPacksNamesAndUrls=[custom icon packs (prefix:url)]:spec:' && ret=0

return ret
