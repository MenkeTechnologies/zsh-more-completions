#compdef asciidoctor-revealjs
# Documentation: https://man.archlinux.org/search?q=asciidoctor-revealjs
# Reference accessed: 2026-05-16

_arguments -s \
  '*'{-a,--attribute}'=[attribute]:attr:' \
  '(-b --backend)'{-b,--backend}'=[backend]:backend:(revealjs html5 docbook5 docbook45 manpage)' \
  '(-B --base-dir)'{-B,--base-dir}'=[base dir]:dir:_files -/' \
  '(-d --doctype)'{-d,--doctype}'=[doctype]:type:(article book inline manpage)' \
  '(-D --destination-dir)'{-D,--destination-dir}'=[destination dir]:dir:_files -/' \
  '(-E --template-engine)'{-E,--template-engine}'=[template engine]:engine:' \
  '(-e --embedded)'{-e,--embedded}'[embedded mode]' \
  '*'{-I,--load-path}'=[load path]:dir:_files -/' \
  '(-n --section-numbers)'{-n,--section-numbers}'[number sections]' \
  '(-o --out-file)'{-o,--out-file}'=[output file]:file:_files' \
  '(-R --source-dir)'{-R,--source-dir}'=[source dir]:dir:_files -/' \
  '*'{-r,--require}'=[require library]:lib:' \
  '(-s --no-header-footer)'{-s,--no-header-footer}'[no header/footer]' \
  '(-S --safe-mode)'{-S,--safe-mode}'=[safe mode]:mode:(unsafe safe server secure)' \
  '--safe[safe mode]' \
  '(-T --template-dir)'{-T,--template-dir}'=[template dir]:dir:_files -/' \
  '--failure-level=[failure level]:level:(WARN ERROR FATAL)' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--trace[show trace]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-w --warnings)'{-w,--warnings}'[show warnings]' \
  '(-t --timings)'{-t,--timings}'[show timings]' \
  '(- *)'{-h,--help}'[show help]:topic:' \
  '(- *)'{-V,--version}'[show version]' \
  '*:file:_files -g "*.(adoc|asciidoc|asc)"'
