#compdef cargo-publish
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-publish.html

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --package)'{-p+,--package=}'[package(s) to publish]:package' \
  '--workspace[publish all packages in workspace]' \
  '*--exclude=[exclude packages]:package' \
  '--index=[registry index URL]:url' \
  '--registry=[registry to publish to]:registry' \
  '--token=[API token to use]:token' \
  '--no-verify[do not verify contents by building them]' \
  '--allow-dirty[allow dirty working directories]' \
  '(-n --dry-run)'{-n,--dry-run}'[perform checks without uploading]' \
  '(-F --features)'{-F+,--features=}'[features to activate]:features' \
  '--all-features[activate all available features]' \
  '--no-default-features[do not activate default feature]' \
  '(-j --jobs)'{-j+,--jobs=}'[number of parallel jobs]:jobs' \
  '--keep-going[do not abort on first error]' \
  '*--target=[build for target triple]:target' \
  '--target-dir=[directory for generated artifacts]:directory:_directories' \
  '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '*'{-v,--verbose}'[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[--locked + --offline]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]' \
  '*--config=[override cargo configuration]:KEY=VALUE_or_path' \
  '*-Z+[unstable cargo flag]:flag'
