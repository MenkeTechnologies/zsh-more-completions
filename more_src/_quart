#compdef quart

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run a development server'
  'shell:run a shell in the app context'
  'routes:show the routes for the app'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-e --env-file)'{-e,--env-file=}'[env file]:file:_files' \
  '(-A --app)'{-A,--app=}'[Quart app import]:app:' \
  '--debug[enable debug]' \
  '--no-debug[disable debug]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'quart subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-h --host)'{-h,--host=}'[bind host]:host:_hosts' \
          '(-p --port)'{-p,--port=}'[bind port]:port:' \
          '--certfile=[SSL cert]:file:_files' \
          '--cert=[SSL cert]:file:_files' \
          '--keyfile=[SSL key]:file:_files' \
          '--key=[SSL key]:file:_files' \
          '--reload[auto-reload]' \
          '--no-reload[disable auto-reload]' && ret=0
        ;;
      (routes)
        _arguments \
          '(-s --sort)'{-s,--sort=}'[sort by]:field:(endpoint methods domain rule match)' \
          '--all-methods[show HEAD and OPTIONS]' && ret=0
        ;;
    esac
    ;;
esac

return ret
