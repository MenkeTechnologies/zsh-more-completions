#compdef fix_ms_dir
# Documentation: https://github.com/AlecThomson/FixMS
# ASKAP utility — update the pointing centre of a beam in a MeasurementSet.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-r --restore)'{-r,--restore}'[restore direction to the original ASKAPsoft pipeline direction]' \
  '*:measurement set:_files -/' && ret=0

return ret
