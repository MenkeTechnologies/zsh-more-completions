#compdef trunk
# Documentation: https://github.com/trunk-rs/trunk
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (see also https://trunk-rs.github.io/trunk/).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build the project'
  'serve:serve and live-reload'
  'clean:clean dist'
  'config:show config'
  'tools:install Trunk-managed tools'
  'watch:rebuild on change'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-v[verbose]' \
  '*--config=[Trunk.toml path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'trunk command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build|watch|serve)
        _arguments \
          '(--release)--release[release build]' \
          '(--filehash)--filehash=[file hashing]:b:(true false)' \
          '(--minify)--minify=[minify]:b:(true false)' \
          '(-d --dist)'{-d+,--dist=}'[dist dir]:dir:_files -/' \
          '(--public-url)--public-url=[public URL]:url:' \
          '(--target)--target=[index.html]:file:_files -g "*.html"' \
          '(--features)*--features=[cargo features csv]:list:' \
          '(--all-features)--all-features[all cargo features]' \
          '(--no-default-features)--no-default-features[no default features]' \
          '(--cargo-profile)--cargo-profile=[profile]:p:' \
          '(--frozen)--frozen[frozen]' \
          '(--locked)--locked[locked]' \
          '(--offline)--offline[offline]' \
          '(--no-sri)--no-sri[no SRI]' \
          '(--inject-autoreload)--inject-autoreload[inject autoreload]' \
          '(--ws-protocol)--ws-protocol=[ws protocol]:p:' \
          '(--ws-base)--ws-base=[ws base]:b:' \
          '(--proxy-backend)--proxy-backend=[proxy backend URL]:url:' \
          '(--proxy-rewrite)--proxy-rewrite=[proxy rewrite]:r:' \
          '(--proxy-ws)--proxy-ws[proxy ws]' \
          '(--no-autoreload)--no-autoreload[no autoreload]' \
          '(--ignore)*--ignore=[ignore patterns]:p:' \
          '(--watch)*--watch=[watch paths]:p:_files' \
          '(--port)--port=[serve port]:port:' \
          '(--address)--address=[serve address]:addr:' \
          '(--tls-key-path)--tls-key-path=[TLS key]:file:_files' \
          '(--tls-cert-path)--tls-cert-path=[TLS cert]:file:_files' \
          '(--open)--open[open browser]' \
          '*: :_files' && ret=0 ;;
      (clean)
        _arguments \
          '(-d --dist)'{-d+,--dist=}'[dist dir]:dir:_files -/' \
          '*: :' && ret=0 ;;
      (config)
        _arguments '*: :' && ret=0 ;;
      (tools)
        _arguments \
          '1:subcommand:(install show)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
