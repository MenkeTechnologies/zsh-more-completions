#compdef modhead
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/fitsio/cexamples.html
# modhead - write or modify the value of a FITS header keyword

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:fits file:_files' \
  '2:keyword' \
  '3:new value' && ret=0

return ret
