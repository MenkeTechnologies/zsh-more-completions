#compdef gops

# Zsh completion for gops - a tool to list and diagnose Go processes

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'agent:run the gops agent'
  'stack:print the stack trace of a Go process'
  'memstats:print memory stats of a Go process'
  'gc:trigger garbage collection on a Go process'
  'setgc:set the GC target percentage on a Go process'
  'version:print the Go version used to build the process'
  'stats:print runtime stats of a Go process'
  'trace:take an execution trace of a Go process'
  'pprof-cpu:take a CPU profile of a Go process'
  'pprof-heap:take a heap profile of a Go process'
  'tree:display a process tree'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show gops version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gops command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (stack|memstats|gc|setgc|version|stats|trace|pprof-cpu|pprof-heap)
        _arguments -s -S \
          ':PID or addr:_pids' && ret=0
        ;;
    esac
    ;;
esac

return ret
