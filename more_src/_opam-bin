#compdef opam-bin
# Documentation: https://github.com/OCamlPro/opam-bin/blob/master/src/opam_bin_lib/main.ml
# Reference accessed: 2026-05-27
# Verified: upstream src/opam_bin_lib/main.ml and src/opam_bin_lib/command*.ml on master.

local curcontext="$curcontext" state line ret=1

local -a _ob_subcommands
_ob_subcommands=(
  'config:configure options'
  'install:install opam-bin in the opam configuration'
  'uninstall:un-install opam-bin from the opam configuration'
  'push:push binary packages to the remote server'
  'pull:pull binary packages from the remote server'
  'clean:clear all packages and archives from the cache and store'
  'list:list binary packages created on this computer'
  'info:display information on binary packages'
  'search:search binary packages'
  'share:share files between switches'
  'pre-session:opam hook (start session)'
  'pre-build:opam hook (backup sources before building)'
  'wrap-build:opam hook (exec or skip build commands)'
  'pre-install:opam hook (exec or skip install commands)'
  'wrap-install:opam hook (exec or skip install commands)'
  'post-install:opam hook (create binary archive after install)'
  'post-session:opam hook (end session)'
  'pre-remove:opam hook (remove binary install artefacts)'
)

_arguments -C \
  '(- *)--version[print opam-bin version]' \
  '(- *)--about[print about message]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'opam-bin subcommand' _ob_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _arguments \
          '--base-url=[URL where the archives folder is available]:url:' \
          '--rsync-url=[rsync target for pushing binary packages]:url:' \
          '--patches-url=[location of relocation patches (git@, file:// or https://)]:url:' \
          '--title=[title in the generated index.html]:title:' \
          '--enable-create[create a binary package after building a source package]' \
          '--disable-create[opposite of --enable-create]' \
          '--enable-share[share binary and source files between switches]' \
          '--disable-share[opposite of --enable-share]' \
          '--enable[enable binary packages]' \
          '--disable[disable binary packages]' \
          '--all-switches[activate on all switches except protected ones]' \
          '--not-all-switches[activate only on switches given by --switches]' \
          '--switches=[switches (comma list) to act on]:switches:' \
          '--protected-switches=[switches (comma list) NOT to act on]:switches:' \
          '--save[save new version of config file]' && ret=0
        ;;
      install)
        _arguments \
          '--check[only verify installation]' && ret=0
        ;;
      uninstall)
        _arguments \
          '--restore[restore previous configuration]' && ret=0
        ;;
      push)
        _arguments \
          '--merge[merge before pushing]' \
          '--local-only[do not push to remote, only update locally]' \
          '--extract=[extract archives to the given directory]:dir:_files -/' \
          '--delete[delete obsolete archives]' && ret=0
        ;;
      pull)
        # commandPull.ml has no flags
        _arguments '*:arg:' && ret=0
        ;;
      clean)
        _arguments '*:arg:' && ret=0
        ;;
      list)
        _arguments '*:arg:' && ret=0
        ;;
      info)
        _arguments \
          '--tail[tail the log file]' \
          '*:package:' && ret=0
        ;;
      search)
        _arguments '*:query:' && ret=0
        ;;
      share)
        _arguments \
          '(-r --rec)'{-r,--rec}'[recurse into directories]' \
          '--share-dir=[directory to use for shared files]:dir:_files -/' \
          '*:file:_files' && ret=0
        ;;
      pre-build|post-install)
        _arguments \
          '--opamfile=[opam file to use]:file:_files' \
          '*:args:' && ret=0
        ;;
      pre-session|wrap-build|pre-install|wrap-install|post-session|pre-remove)
        _arguments '*:args:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
