#compdef gocritic

# Zsh completion for gocritic (Go code analysis tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:run checks on Go packages'
  'check-package:run checks on a specific package'
  'version:show version'
)

_arguments -s -S \
  '-enable[checks to enable]:checks:' \
  '-disable[checks to disable]:checks:' \
  '-enableAll[enable all checks]' \
  '-disableAll[disable all checks]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gocritic command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (check)
        _arguments \
          '-enable[checks to enable]:checks:' \
          '-disable[checks to disable]:checks:' \
          '-enableAll[enable all checks]' \
          '-disableAll[disable all checks]' \
          '*:package or file:_files -g "*.go"' && ret=0
        ;;
    esac
    ;;
esac

return ret
