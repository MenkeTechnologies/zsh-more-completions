#compdef age-plugin-yubikey

# Zsh completion for age-plugin-yubikey - YubiKey plugin for age

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--generate[generate a new identity]' \
  '--identity[print identity from YubiKey]' \
  '--list[list YubiKey identities]' \
  '--list-all[list all YubiKey identities]' \
  '--pin-policy[PIN policy for key generation]:policy:(always once never)' \
  '--touch-policy[touch policy for key generation]:policy:(always cached never)' \
  '--slot[use specific slot]:slot' \
  '--serial[use specific YubiKey serial]:serial' \
  '--name[set identity name]:name'
