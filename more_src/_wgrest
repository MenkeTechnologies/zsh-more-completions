#compdef wgrest
# Documentation: https://github.com/suquant/wgrest
# wgrest - WireGuard REST API server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version and exit]' \
  '--conf=[wgrest config file path]:file:_files' \
  '--listen=[listen address]:addr:' \
  '--config-dir=[WireGuard config directory]:dir:_files -/' \
  '--certs-dir=[ACME TLS certificates cache directory]:dir:_files -/' \
  '--dump-interval=[config dump interval]:duration:' \
  '--static-auth-token=[bearer token for authorization]:token:' \
  '*--tls-domain=[TLS domain for ACME (Let'\''s Encrypt)]:domain:' && ret=0

return ret
