#compdef mcrepo
# Documentation: https://github.com/GeektankLabs/mcrepo
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new meta-context repository'
  'add:add a repository to the workspace'
  'status:show the state of all repositories'
  'write:set repository to write mode'
  'read:set repository to read mode'
  'sleep:set repository to sleep mode'
  'branch:create or manage a coordinated branch across repos'
  'merge:squash or merge the feature branch into the parent'
  'continue:resume a mid-operation git process'
  'abort:cancel a mid-operation git process'
  'push:fetch, verify, and push changes'
  'pull:sync with upstream'
  'skill:manage skills (list/new/install/enable/disable/validate)'
  'open:open repository in VS Code'
  'update:self-update the script'
  'install-extension:install the VS Code extension'
  'export-patch:generate a patch for submission'
  'create-patch:alias for export-patch'
  'help:display help information'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--no-shell-install[skip shell config during init]' \
  '--strategy=[patch strategy]:strategy:(intent legacy)' \
  '--skip-scan[bypass ClawHub security scan]' \
  '--require-scan[fail if scan unavailable]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'mcrepo command' commands && ret=0
    ;;
  args)
    case $words[1] in
      branch)
        _arguments \
          '--off[disable coordinated branching]' \
          '--delete[discard feature branch and return to parents]' \
          '*::name:_default' && ret=0
        ;;
      merge)
        _arguments \
          '-m+[commit message]:message:' \
          '--no-squash[perform a traditional merge commit]' \
          '--rebase[rebase parent into current branch]' && ret=0
        ;;
      push)
        _arguments \
          '-m+[commit message]:message:' \
          '--no-fetch[push without fetching first]' && ret=0
        ;;
      pull)
        _arguments '--rebase[pull with rebase strategy]' && ret=0
        ;;
      skill)
        local -a skillcmds=(
          'list:show available skills'
          'new:create a new skill'
          'install:install a skill from GitHub or ClawHub'
          'enable:activate a skill'
          'disable:deactivate a skill'
          'validate:check skill validity'
        )
        _describe -t skillcmds 'skill subcommand' skillcmds && ret=0
        ;;
      *) _default && ret=0 ;;
    esac
    ;;
esac

return ret
