#compdef prof2-runcombs
# Documentation: https://professor.hepforge.org/docs.sphinx213/
# prof2-runcombs - Professor2 generate random run-combination specifications

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--pname --pfile)'{--pname,--pfile}'=[name of the params file in each run directory]:name:' \
  '(-o --output)'{-o,--output}'=[output file name for writing results]:file:_files' \
  '(-v --debug)'{-v,--debug}'[enable debug messages]' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
  '1:runsdir:_files -/' \
  '*:run-combination spec (M:N):' && ret=0

return ret
