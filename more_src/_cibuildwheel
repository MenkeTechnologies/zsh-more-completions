#compdef cibuildwheel

# Zsh completion for cibuildwheel - build Python wheels in CI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--platform=[platform to build for]:platform:(linux macos windows auto)' \
  '--archs=[architectures to build]:archs' \
  '--output-dir=[directory for built wheels]:directory:_directories' \
  '--config-file=[path to config file]:config:_files -g "*.toml"' \
  '--package-dir=[path to package directory]:directory:_directories' \
  '--print-build-identifiers[print build identifiers and exit]' \
  '--allow-empty[do not error if no builds are selected]' \
  '--prerelease-pythons[use prerelease Python versions]' \
  '--only=[build only this identifier]:identifier' \
  '*:package directory:_directories' && ret=0

return ret
