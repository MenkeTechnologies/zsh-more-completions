#compdef wmnet
# Documentation: https://manpages.debian.org/trixie/wmnet/wmnet.1x.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian trixie wmnet(1x) man page OPTIONS list.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[brief help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-T --txrule)'{-T,--txrule}'+[transmit accounting rule]:NUM/NAME' \
  '(-R --rxrule)'{-R,--rxrule}'+[receive accounting rule]:NUM/NAME' \
  '(-t --txcolor)'{-t,--txcolor}'+[tx color]:color' \
  '(-r --rxcolor)'{-r,--rxcolor}'+[rx color]:color' \
  '(-x --maxrate)'{-x,--maxrate}'+[maximum rate for graph scale (default 6000)]:bytes' \
  '(-l --logscale)'{-l,--logscale}'[logarithmic scale]' \
  '(-L --label)'{-L,--label}'+[text label at bottom of window]:text' \
  '(-F --labelfg)'{-F,--labelfg}'+[label foreground color]:color' \
  '(-B --labelbg)'{-B,--labelbg}'+[label background color]:color' \
  '--withdrawn[start in withdrawn state]' \
  '--normalstate[start in normal state]' \
  '(-e --execute)'{-e,--execute}'+[execute COMMAND on left click]:command' \
  '(-p --promisc)'{-p,--promisc}'+[set device promiscuous]:device' \
  '(-u --unpromisc)'{-u,--unpromisc}'+[unset device promiscuous]:device' \
  '-d+[polling delay (microseconds)]:delay' \
  '(-D --driver)'{-D,--driver}'+[stat driver]:driver' \
  '(-W --device)'{-W,--device}'+[watch statistics for device]:device' \
  '(-X --display)'{-X,--display}'+[X display]:display' && ret=0

return ret
