#compdef wmnet

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-W+[network device]:dev:' \
  '-T+[interface type]:type:(eth ppp lo wireless)' \
  '-d+[X display]:display:' \
  '-g+[geometry]:geom:' \
  '-bw+[border width]:px:' \
  '-i+[update interval ms]:ms:' \
  '-l+[led color]:color:' \
  '-rxcolor+[rx color]:color:' \
  '-txcolor+[tx color]:color:' \
  '-max+[max bytes for scale]:n:' \
  '-A[adaptive scaling]' \
  '-B[binary scaling]' \
  '-c+[click action cmd]:cmd:' && ret=0

return ret
