#compdef abuseipdb
# _abuseipdb — AbuseIPDB abuseipdb CLI client to the AbuseIPDB REST API querying community-maintained IP reputation reports for SSH-brute-force web-attack scanning hacking spam DDoS submitting confirmed-abuse reports clearing checking blocks bulk-IP whitelist scoring confidence category-mask (AbuseIPDB team, Python); click
# upstream: https://www.abuseipdb.com/

_abuseipdb() {
    local -a sub=(
        'check:check single IP'
        'report:submit a report'
        'check-block:check CIDR block'
        'blacklist:download blacklist'
        'clear-address:clear your reports for an IP'
        'bulk-report:bulk submit reports'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-k+[api key]:str:' \
        '--api-key=+[key]:str:' \
        '--days=+[N]:n:' \
        '--max-age-days=+[N]:n:' \
        '--verbose-flag[include comments verbose]' \
        '--limit=+[N]:n:' \
        '--confidence-min=+[N]:n:' \
        '--plaintext[plain text output]' \
        '--only-countries=+[list]:str:' \
        '--except-countries=+[list]:str:' \
        '--country-code=+[code]:str:' \
        '-f+[format]:f:(json yaml text csv plaintext)' \
        '--format=+[format]:f:(json yaml text csv plaintext)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'abuseipdb subcommand' sub ;;
        args)
            case $words[1] in
                check|clear-address) _arguments '*:ip address:' ;;
                check-block) _arguments '*:cidr:' ;;
                report) _arguments \
                    '--ip=+[ip]:str:' \
                    '--categories=+[ids]:str:' \
                    '--comment=+[text]:str:' ;;
                bulk-report) _arguments '1:csv file:_files -g "*.csv"' ;;
            esac
            ;;
    esac
}

_abuseipdb "$@"
