#compdef ods-enforcerd ods-enforcer ods-signer ods-ksmutil ods-signerd
# _ods — OpenDNSSEC binaries (enforcer + signer family used to automate per-zone DNSSEC; ods-enforcerd / ods-signerd are daemons, ods-enforcer + ods-signer + ods-ksmutil are control clients; -c config file, -f foreground, -v verbose, -V version, -1 single shot, --version, --help; control clients accept subcommands: start, stop, queue, flush, zone add/delete/list, key rollover, policy import/export)
# upstream: https://github.com/opendnssec/opendnssec
# Subcommands from opendnssec/opendnssec on tip.

_ods() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '-f[foreground]' \
        '-v[verbose]' \
        '-1[single shot]' \
        '*::command:'
}

_ods "$@"
