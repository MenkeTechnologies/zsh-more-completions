#compdef bundler-audit bundle-audit

# Zsh completion for bundler-audit (Bundler dependency vulnerability auditing)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:check for vulnerable gems'
      'update:update the advisory database'
      'stats:show advisory database statistics'
      'version:show version'
    )
    _describe -t commands 'bundler-audit command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--database=[path to advisory database]:directory:_directories' \
          '--update[update the advisory database before checking]' \
          '*--ignore=[advisory ID to ignore]:advisory' \
          '--gemfile-lock=[path to Gemfile.lock]:file:_files' \
          '--format=[output format]:format:(terminal json)' \
          {-q,--quiet}'[suppress output]' \
          {-v,--verbose}'[verbose output]' && ret=0
        ;;
      update)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--database=[path to advisory database]:directory:_directories' && ret=0
        ;;
      stats)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--database=[path to advisory database]:directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
