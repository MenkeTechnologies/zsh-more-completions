#compdef VBoxNetAdpCtl
# Documentation: https://man.archlinux.org/search?q=VBoxNetAdpCtl
# Reference accessed: 2026-05-16

# VBoxNetAdpCtl: VirtualBox host-only network adapter control
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '1:interface:' \
  '2:action:(add remove)' \
  '*::VBoxNetAdpCtl args:_files' && ret=0
return ret
