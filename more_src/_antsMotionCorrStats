#compdef antsMotionCorrStats
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsMotionCorrStats.cxx — summary statistics for an antsMotionCorr output (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-x --mask)'{-x+,--mask=}'[mask image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-m --moco)'{-m+,--moco=}'[motion-correction parameters CSV]:file:_files -g "*.csv"' \
    '(-o --output)'{-o+,--output=}'[output stats file]:file:_files -g "*.csv"' \
    '(-t --transform)'{-t+,--transform=}'[transform type]:n:_default' \
    '(-f --framewise)'{-f,--framewise}'[per-frame summary]' \
    '--spatial-map=[spatial map]:file:_files -g "*.{nii,nii.gz}"' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
