#compdef zkg
# Documentation: https://docs.zeek.org/projects/package-manager/en/stable/zkg.html
# Reference accessed: 2026-05-30
# zkg — Zeek package manager. Companion to existing Zeek/Bro coverage
# (_bro covers zeek + bro; _zeekctl, _zeek-cut, _zeek-archiver,
# _zeek-client, _zeek-config exist individually). zkg manages package
# install/upgrade/load/etc for Zeek scripts.

local curcontext="$curcontext" state line ret=1

# Global flags that apply at the top level (before any subcommand) and
# also propagate into subcommands.
local -a _zkg_global
_zkg_global=(
  '(- *)--version[display program version]'
  '--configfile=[custom config file path]:file:_files'
  '--user[store state in users home directory]'
  '*-v[verbose debug output (stackable)]'
  '*--verbose[verbose debug output (stackable)]'
  '*--extra-source=[additional package source NAME=URL]:source:'
)

local -a _subcmds
_subcmds=(
  'test:execute unit tests for specified packages'
  'install:add packages from sources or git URLs (marks as loaded)'
  'remove:unload and remove previously installed packages'
  'uninstall:alias for remove'
  'purge:unload and remove all installed packages'
  'bundle:create distributable bundle of package collection'
  'unbundle:extract and install packages from bundle'
  'refresh:fetch latest metadata + check for upgrades'
  'upgrade:update packages to newest available'
  'load:mark packages for automatic loading by Zeek'
  'unload:remove packages from automatic loading list'
  'pin:prevent specified packages from being upgraded'
  'unpin:allow packages to be upgraded'
  'list:display packages by category'
  'search:find packages by name/metadata (substring/regex)'
  'info:show detailed metadata + installation status'
  'config:output current configuration with defaults'
  'autoconfig:generate config using zeek-config script'
  'env:output shell commands to set ZEEKPATH'
  'create:generate new package in directory'
  'template:template info subcommand group'
)

_arguments -C -s -S \
  $_zkg_global \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'zkg subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      test)
        _arguments \
          '--version=[package version (tag/branch/commit)]:version:' \
          '*:package:' && ret=0
        ;;
      install)
        _arguments \
          '--skiptests[omit unit tests before setup]' \
          '--nodeps[skip dependency validation]' \
          '--nosuggestions[do not auto-install recommended]' \
          '--version=[package version]:version:' \
          '--force[bypass confirmation prompts]' \
          '*--user-var=[set package variables NAME=VAL]:spec:' \
          '*:package:' && ret=0
        ;;
      remove|uninstall)
        _arguments \
          '--force[skip confirmation prompt]' \
          '--nodeps[skip dependency validation]' \
          '*:package:' && ret=0
        ;;
      purge)
        _arguments \
          '--force[skip confirmation prompt]' && ret=0
        ;;
      bundle)
        _arguments \
          '--force[skip confirmation prompt]' \
          '--nodeps[skip dependency validation]' \
          '--nosuggestions[exclude suggested packages]' \
          '*--manifest=[packages via file or list]:file:_files' \
          '1:bundle output file:_files' \
          '*:package:' && ret=0
        ;;
      unbundle)
        _arguments \
          '--replace[remove existing packages before install]' \
          '--force[bypass prompts and variables]' \
          '*--user-var=[assign package variables NAME=VAL]:spec:' \
          '1:bundle file:_files' && ret=0
        ;;
      refresh)
        _arguments \
          '--aggregate[crawl and consolidate source metadata]' \
          '--fail-on-aggregate-problems[exit on metadata issues]' \
          '--push[upload local source changes upstream]' \
          '*--sources=[target specific sources]:source:' && ret=0
        ;;
      upgrade)
        _arguments \
          '--skiptests[omit unit tests]' \
          '--nodeps[skip dependency validation]' \
          '--nosuggestions[do not auto-install recommended]' \
          '--force[bypass prompts and variables]' \
          '*--user-var=[assign package variables NAME=VAL]:spec:' \
          '*:package:' && ret=0
        ;;
      load)
        _arguments \
          '--nodeps[skip dependency validation]' \
          '*:package:' && ret=0
        ;;
      unload)
        _arguments \
          '--force[skip confirmation prompt]' \
          '--nodeps[skip dependency validation]' \
          '*:package:' && ret=0
        ;;
      list)
        _arguments \
          '--nodesc[display names only]' \
          '--include-builtin[include Zeek built-in packages]' \
          '*:category:(installed not_installed loaded unloaded outdated all)' && ret=0
        ;;
      info)
        _arguments \
          '--version=[inspect specific version]:version:' \
          '--nolocal[read remote metadata instead]' \
          '--include-builtin[include Zeek built-in packages]' \
          '--json[output in JSON format]' \
          '--jsonpretty=[pretty-print JSON spaces]:spaces:' \
          '--allvers[show all version metadata]' \
          '*:package:' && ret=0
        ;;
      autoconfig)
        _arguments \
          '--force[skip confirmation prompt]' && ret=0
        ;;
      create)
        _arguments \
          '--packagedir=[output directory (required)]:dir:_files -/' \
          '--version=[template version]:version:' \
          '*--features=[include optional features]:feature:' \
          '--template=[alternate template repository URL]:url:' \
          '--force[bypass prompts and variables]' \
          '*--user-var=[assign package variables NAME=VAL]:spec:' && ret=0
        ;;
      template)
        _arguments -C \
          '1: :->tmpl_sub' \
          '*:: :->tmpl_args' && ret=0
        case $state in
          tmpl_sub)
            _describe -t commands 'template subcommand' \
              'info:display available template versions and features' && ret=0
            ;;
          tmpl_args)
            case $words[1] in
              info)
                _arguments \
                  '--json[output in JSON format]' \
                  '--jsonpretty=[pretty-print JSON spaces]:spaces:' \
                  '--version=[report on specific template version]:version:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      search)
        _arguments '*:term:' && ret=0
        ;;
      pin|unpin)
        _arguments '*:package:' && ret=0
        ;;
      config|env)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
