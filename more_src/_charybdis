#compdef charybdis charybdis-ircd ircd
# _charybdis — Charybdis IRC server daemon (charybdis-ircd/charybdis)
# upstream: https://github.com/charybdis-ircd/charybdis
# Flags from ircd/ircd.c (lgetopt myopts[]).

_charybdis() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version and exit]' \
        '-configfile=[ircd.conf file path]:file:_files -g "*.conf"' \
        '-logfile=[ircd.log file path]:file:_files -g "*.log"' \
        '-pidfile=[PID file path]:file:_files' \
        '-foreground[run in foreground (no daemonize)]' \
        '-conftest[validate config and exit]'
}

_charybdis "$@"
