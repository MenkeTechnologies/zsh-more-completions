#compdef roxygen2 roxygenize
# _roxygen2 — Hadley Wickham Peter Danenberg roxygen2 R inline documentation system CLI converting @-tagged comments to Rd help files NAMESPACE entries and S3/S4/R5/R6 method roxygen markup (rstudio team, R); R argparse
# upstream: https://github.com/r-lib/roxygen2

_roxygen2() {
    local -a sub=(
        'roxygenize:document a package'
        'roxygenise:document a package'
        'load-pkgload:load with pkgload'
        'load-installed:load installed'
        'load-source:source files'
        'load-installed-or-source:installed or source'
        'rd-template:create rd template'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'roxygen2 subcommand' sub ;;
        args)
            case $words[1] in
                roxygenize|roxygenise) _arguments \
                    '--package-dir=+[dir]:dir:_files -/' \
                    '--roclets=+[csv]:str:' \
                    '--load=+[mode]:m:(pkgload installed source installed-or-source)' \
                    '--clean[clean]' \
                    '--quiet[quiet]' \
                    '*:package dir:_files -/' ;;
                rd-template) _arguments \
                    '--name=+[name]:str:' \
                    '--type=+[t]:t:(function class data package method)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_roxygen2 "$@"
