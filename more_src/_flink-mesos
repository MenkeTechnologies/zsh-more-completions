#compdef mesos-appmaster.sh flink-mesos
# _flink-mesos — Apache Flink Mesos session/AppMaster (deprecated; spawns a long-running Mesos framework that hosts Flink JM + scales TaskManagers; --configDir, --webuiport, --host, --containerImage, --memory, --numTaskManagers, --memoryPerTaskManager, --cpusPerTaskManager, --diskPerTaskManager; flag set inherited from FlinkMesosCli)
# upstream: https://github.com/apache/flink (deprecated)
# Flags from Apache Flink flink-mesos (legacy) on tip.

_flink-mesos() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--configDir+[config dir]:dir:_files -/' \
        '--webuiport+[port]:port:' \
        '--host+[host]:host:_hosts' \
        '--containerImage+[image]:image:' \
        '--memory+[memory]:size:' \
        '--numTaskManagers+[N]:n:' \
        '--memoryPerTaskManager+[MiB]:mb:' \
        '--cpusPerTaskManager+[cpus]:n:' \
        '--diskPerTaskManager+[MiB]:mb:' \
        '*-D+[KEY=VALUE]:property:'
}

_flink-mesos "$@"
