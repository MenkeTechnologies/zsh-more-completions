#compdef vcfallelicprimitives
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfallelicprimitives.md
# Decompose complex VCF alleles into allelic primitives (gaps and SNPs)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --algorithm)'{-a,--algorithm}'[choose alignment algorithm]:algorithm:(SW WF)' \
  '(-m --use-mnps)'{-m,--use-mnps}'[retain MNPs as separate events]' \
  '(-t --tag-parsed)'{-t,--tag-parsed}'[annotate decomposed records with the source record position]:flag' \
  '(-L --max-length)'{-L,--max-length}'[do not manipulate records with REF/ALT longer than LEN]:length' \
  '(-k --keep-info)'{-k,--keep-info}'[maintain site and allele-level annotations when decomposing]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
