#compdef adnsresfilter
# Documentation: adnsresfilter --help (GNU adns)
# Source: filter IP addresses on stdin -> stdout, replacing with hostnames via GNU adns.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-t --timeout)'{-t+,--timeout=}'[max output delay ms]:milliseconds:' \
    '(-w --wait)'{-w,--wait}'[always wait for query timeout]' \
    '(-b --brackets)'{-b,--brackets}'[require [...] around IPs]' \
    '(-a --address)'{-a,--address}'[always include [address] in output]' \
    '(-u --unchecked)'{-u,--unchecked}'[do not forward-map for checking]' \
    '--config=[config text override of resolv.conf]:text:' \
    '--debug[turn on adns debugging]' \
    && ret=0

return ret
