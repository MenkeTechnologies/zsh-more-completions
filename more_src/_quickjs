#compdef qjs qjsc
# _quickjs — QuickJS small embeddable JavaScript engine (Fabrice Bellard); ES2023-compliant + BigInt + std/os modules
# upstream: https://github.com/bellard/quickjs

_quickjs() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c[compile single .js file]' \
        '-e+[evaluate expression]:expr:' \
        '-I+[include script]:file:_files -g "*.js"' \
        '-i[force interactive REPL]' \
        '-m[load module]' \
        '--script[force script mode]' \
        '--module[force module mode]' \
        '--std[use std/os globally]' \
        '--unhandled-rejection[error on unhandled rejection]' \
        '--memory-limit=+[memory limit bytes]:n:' \
        '--stack-size=+[stack size bytes]:n:' \
        '--no-string-interning[no string interning]' \
        '-q[do not show prompt]' \
        '-d[dump CallFrame as JSON]' \
        '-T[dump info from compiled bytecode]' \
        '*:script:_files -g "*.js"'
}

_quickjs "$@"
