#compdef airshare
# Documentation: https://github.com/KuroLabs/Airshare/blob/master/airshare/cli.py
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# KuroLabs/Airshare — https://airshare.readthedocs.io/en/latest/cli.html — mDNS LAN transfers.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-t[send text instead of files]' \
  '-u[upload/receive from multiple peers]' \
  '-fp[send files whose paths are on clipboard]' \
  '-cs[send clipboard contents]' \
  '-cr[receive and copy to clipboard]' \
  '-p+[override port (default 8000)]:port' \
  '1:code word: ' \
  '*:files to send:_files' && ret=0

return ret
