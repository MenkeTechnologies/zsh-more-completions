#compdef MFEKpathops
# Documentation: https://github.com/MFEK/pathops
# Apply boolean path operations to a UFO .glif glyph

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '1:subcommand:(BOOLEAN CLEAR FIT REFIGURE help)' \
  '*::args:_files' && ret=0

return ret
