#compdef create-solid

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-t --template)'{-t,--template}'[specify a project template]:template' \
  '(--ts --typescript)'{--ts,--typescript}'[use TypeScript]' \
  '--name=[project name]:name' \
  '1:project directory:_directories' && ret=0

return ret
