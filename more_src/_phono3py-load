#compdef phono3py-load
# Documentation: https://phonopy.github.io/phono3py/command-options.html
# phono3py: run phono3py by auto-loading phono3py.yaml settings

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-c+[unit cell structure file]:file:_files' \
  '--pa=[transformation matrix to primitive cell]:matrix' \
  '--mesh=[Gamma-centered k-point mesh dimensions]:mesh' \
  '--br[thermal conductivity with RTA method]' \
  '--lbte[solve linearized phonon Boltzmann equation]' \
  '--isotope[include phonon-isotope scattering]' \
  '--nac[apply non-analytical term correction]' \
  '--ts=[explicit temperature values]:temps' \
  '--tmin=[minimum temperature]:tmin' \
  '--tmax=[maximum temperature]:tmax' \
  '--tstep=[temperature step]:tstep' \
  '--fc2[read 2nd-order force constants from fc2.hdf5]' \
  '--fc3[read 3rd-order force constants from fc3.hdf5]' \
  '--fc-symmetry[symmetrize force constants]' \
  '--full-pp[calculate all phonon-phonon interaction elements]' \
  '--write-gamma[write imaginary self-energy to HDF5]' \
  '--read-gamma[read imaginary self-energy from HDF5]' \
  '--gruneisen[compute mode-Gruneisen parameters from fc3]' \
  '--jdos[calculate joint density of states]' \
  '--hdf5-compression=[HDF5 compression method]:method:(gzip lzf None)' \
  '*:file:_files' && ret=0

return ret
