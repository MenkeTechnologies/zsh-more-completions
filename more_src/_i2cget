#compdef i2cget
# _i2cget — Linux i2c-tools i2cget CLI for reading a register from an I2C device specifying bus address register data with byte word block I2C-block SMBus access modes interactive confirm (i2c-tools team, C); getopt
# upstream: https://git.kernel.org/pub/scm/utils/i2c-tools/i2c-tools.git

_i2cget() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-y[disable interactive confirm]' \
        '-f[force]' \
        '-a[allow addresses 0x00-0x07 and 0x78-0x7f]' \
        '*:i2cbus chip-address data-address mode:'
}

_i2cget "$@"
