#compdef foamToVTK
# Documentation: https://www.openfoam.com/documentation/user-guide/6-solving/6.2-data-processing
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/postProcessing/dataConversion/foamToVTK/foamToVTK.C
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show application documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[case directory]:dir:_directories' \
    '-parallel[run in parallel]' \
    '-roots+[slave root directories]:dirs:_default' \
    '-noFunctionObjects[do not execute functionObjects]' \
    '-fileHandler+[override fileHandler]:handler:_default' \
    '-libs+[pre-load libraries]:libs:_default' \
    '-region+[mesh region]:region:_default' \
    '-fields+[fields to convert (e.g. "(p T U)")]:fields:_default' \
    '-cellSet+[restrict to cellSet]:set:_default' \
    '-faceSet+[restrict to faceSet]:set:_default' \
    '-pointSet+[restrict to pointSet]:set:_default' \
    '-polyhedra+[cell types to write as polyhedra]:type:(none polyhedra all)' \
    '-excludePatches+[patches to exclude]:patches:_default' \
    '-ascii[write VTK in ASCII format]' \
    '-surfaceFields[write surfaceScalarFields (e.g. phi)]' \
    '-nearCellValue[use cell value on patches]' \
    '-noInternal[no internal-field file, patches only]' \
    '-noPointValues[no pointFields]' \
    '-allPatches[combine all patches into single file]' \
    '-noFaceZones[no faceZones]' \
    '-noLinks[do not link processor VTK files]' \
    '-useTimeName[use time name instead of time index]' \
    && ret=0

return ret
