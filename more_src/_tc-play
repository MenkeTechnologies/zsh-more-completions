#compdef tc-play
# TrueCrypt-compatible disk encryption

local ret=1

_arguments -s -S \
  '-c[create new volume]' \
  '-C[create hidden volume]' \
  '-d[specify device]:device:_files' \
  '-i[print volume information]' \
  '-j[specify keyfile]:keyfile:_files' \
  '-m[specify mapping name]:mapping name:' \
  '-s[specify system encryption]' \
  '-u[protect hidden volume]' \
  '-w[use weak keys (for testing)]' \
  '-x[specify TrueCrypt header location]:header file:_files' \
  '--modify[modify volume]' \
  '--fde[full disk encryption]' \
  '--use-backup[use backup headers]' \
  '-a[specify cipher algorithm]:algorithm:(AES AES-256-XTS SERPENT TWOFISH)' \
  '-b[specify PBKDF PRF algorithm]:hash:(RIPEMD160 SHA512 whirlpool)' \
  '-h[show help]' \
  '--help[show help]' && ret=0

return ret
