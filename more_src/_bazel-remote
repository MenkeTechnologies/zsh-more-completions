#compdef bazel-remote
# Documentation: https://github.com/buchgr/bazel-remote
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bazel-remote: remote cache server for Bazel

_arguments -s -S \
  '--config_file=[YAML config file (replaces CLI flags)]:file:_files' \
  '--dir=[disk cache root directory]:directory:_directories' \
  '--max_size=[approximate max cache size in GiB]:gib:' \
  '--storage_mode=[CAS blob storage format]:mode:(zstd uncompressed)' \
  '--zstd_implementation=[zstd implementation]:impl:(go cgo)' \
  '--http_address=[HTTP listen address host:port]:addr:' \
  '--grpc_address=[gRPC listen address host:port]:addr:' \
  '--profile_address=[net/pprof listen address]:addr:' \
  '--tls_cert_file=[TLS certificate]:file:_files' \
  '--tls_key_file=[TLS key]:file:_files' \
  '--tls_ca_file=[mutual TLS CA cert]:file:_files' \
  '--min_tls_version=[minimum TLS version]:version:(1.0 1.1 1.2 1.3)' \
  '--htpasswd_file=[basic auth htpasswd file]:file:_files' \
  '--ldap.url=[LDAP URL for auth]:url:' \
  '--max_blob_size=[max accepted blob size in bytes]:bytes:' \
  '--max_queued_uploads=[max queued disk writes]:n:' \
  '--num_uploaders=[parallel upload goroutines]:n:' \
  '--http_read_timeout=[HTTP read timeout]:duration:' \
  '--http_write_timeout=[HTTP write timeout]:duration:' \
  '--idle_timeout=[close idle connections after duration]:duration:' \
  '--enable_endpoint_metrics[expose Prometheus metrics]' \
  '--experimental_remote_asset_api[enable remote asset API]' \
  '--s3.endpoint=[S3 endpoint]:url:' \
  '--s3.bucket=[S3 bucket name]:bucket:' \
  '--s3.prefix=[S3 key prefix]:prefix:' \
  '--gcs_proxy.bucket=[GCS bucket]:bucket:' \
  '--azblob.tenant_id=[Azure tenant ID]:id:' \
  '--http_proxy.url=[upstream HTTP cache proxy URL]:url:' \
  '--grpc_proxy.url=[upstream gRPC cache proxy URL]:url:' \
  '--help[show usage]' \
  '*::arguments: _default'
