#compdef bazel-remote

_arguments -s -S \
  '--dir=[Disk cache root directory]:directory:_directories' \
  '--max_size=[Approximate max cache size in GiB]:gib:' \
  '--http_address=[HTTP listen address host:port]:addr:' \
  '--grpc_address=[gRPC listen address host:port]:addr:' \
  '--profile_address=[net/pprof listen address]:addr:' \
  '--idle_timeout=[Close idle connections after duration]:duration:' \
  '--max_queued_uploads=[Max concurrent disk writes]:n:' \
  '--enable_endpoint_metrics[Expose Prometheus metrics]' \
  '--experimental_remote_asset_api[Enable remote asset API]' \
  '--help[Show usage]' \
  '*::arguments: _default'
