#compdef cocode
# Documentation: https://github.com/Pipelex/cocode
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cocode is an AI-powered code repository analyzer (Pipelex).

_cocode() {
    local line state
    local -a commands
    commands=(
        'analyze:Analyze git diffs or code'
        'repox:Convert repository to AI-readable formats'
        'repo:Extract repository fundamentals'
        'features:Extract feature documentation'
        'github:GitHub helpers (auth, repo-info, branches, labels)'
        'doc:Update or proofread documentation'
        'changelog:Generate changelogs from git diffs'
        'ai_instructions:Refresh AGENTS.md/CLAUDE.md/cursor rules'
        'validate:Verify setup and pipeline configurations'
    )

    _arguments -C \
        '--help[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'cocode command' commands
            ;;
        args)
            case $line[1] in
                analyze)
                    _arguments \
                        '1:subcommand:(diff)' \
                        '*:args:'
                    ;;
                repox)
                    _arguments \
                        '1:subcommand:(convert)' \
                        '--output-filename[Output filename]:file:_files' \
                        '*:path:_files -/'
                    ;;
                repo)
                    _arguments \
                        '1:subcommand:(extract_fundamentals)' \
                        '*:path:_files -/'
                    ;;
                features)
                    _arguments \
                        '1:subcommand:(extract)' \
                        '--output-filename[Output filename]:file:_files' \
                        '*:path:_files'
                    ;;
                github)
                    _arguments \
                        '1:subcommand:(auth repo-info check-branch list-branches sync-labels)' \
                        '--dry-run[do not apply changes]' \
                        '--delete-extra[delete labels not in source]' \
                        '*:args:'
                    ;;
                doc)
                    _arguments \
                        '1:subcommand:(update proofread)' \
                        '*:path:_files -/'
                    ;;
                changelog)
                    _arguments \
                        '1:subcommand:(update)' \
                        '*:path:_files -/'
                    ;;
                ai_instructions)
                    _arguments \
                        '1:subcommand:(update)' \
                        '*:path:_files -/'
                    ;;
                validate)
                    _arguments \
                        '*:args:'
                    ;;
            esac
            ;;
    esac
}

_cocode "$@"
