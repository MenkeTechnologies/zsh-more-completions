#compdef cocode

_cocode() {
    local line state
    local -a commands
    commands=(
        'analyze:Analyze git diffs or code'
        'repox:Convert repository to AI-readable formats'
        'repo:Extract repository fundamentals'
        'features:Extract feature documentation'
        'github:Sync GitHub labels or other integrations'
    )

    _arguments -C \
        '--help[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'cocode command' commands
            ;;
        args)
            case $line[1] in
                analyze)
                    _arguments \
                        '1:subcommand:(diff)' \
                        '*:args:'
                    ;;
                repox)
                    _arguments \
                        '1:subcommand:(convert)' \
                        '--output-filename[Output filename]:file:_files' \
                        '*:path:_files -/'
                    ;;
                repo)
                    _arguments \
                        '1:subcommand:(extract_fundamentals)' \
                        '*:path:_files -/'
                    ;;
                features)
                    _arguments \
                        '1:subcommand:(extract)' \
                        '--output-filename[Output filename]:file:_files' \
                        '*:path:_files'
                    ;;
                github)
                    _arguments \
                        '1:subcommand:(sync-labels)' \
                        '*:args:'
                    ;;
            esac
            ;;
    esac
}

_cocode "$@"
