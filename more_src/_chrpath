#compdef chrpath
# Documentation: https://man.archlinux.org/search?q=chrpath
# Reference accessed: 2026-05-16

_arguments \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-d --delete)'{-d,--delete}'[delete rpath from binary]' \
  '(-c --convert)'{-c,--convert}'[convert rpath to runpath or vice versa]' \
  '(-r --replace)'{-r,--replace}'[replace rpath]:new rpath' \
  '(-l --list)'{-l,--list}'[list rpath]' \
  '(-k --keepgoing)'{-k,--keepgoing}'[keep going on errors]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '*:ELF file:_files'
