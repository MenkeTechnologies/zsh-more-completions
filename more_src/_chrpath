#compdef chrpath
# Documentation: https://manpages.debian.org/trixie/chrpath/chrpath.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-d --delete)'{-d,--delete}'[delete rpath/runpath from binary]' \
  '(-c --convert)'{-c,--convert}'[convert rpath to runpath]' \
  '(-r --replace)'{-r,--replace}'[replace rpath (equal or shorter length)]:new rpath:' \
  '(-l --list)'{-l,--list}'[list rpath (default)]' \
  '(-k --keepgoing)'{-k,--keepgoing}'[process all arguments before reporting error]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '*:ELF file:_files'
