#compdef memcached-cli
# Documentation: https://github.com/progrhyme/perl5-App-Memcached-CLI
# Reference accessed: 2026-05-16
# Verified: upstream progrhyme/perl5-App-Memcached-CLI README. Perl CLI;
# interactive REPL by default, batch mode when a memcached command is
# given as positional args. Note: the unrelated `memcached-tool` from
# the memcached server package has a different interface
# (`<host\:port> stats|display|dump`).
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# memcached-cli: interactive memcached client (Perl App::Memcached::CLI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--man[show man page]' \
  '(-a --addr)'{-a+,--addr=}'[server address HOST[\:PORT] or unix socket path]:addr:' \
  '(-t --timeout)'{-t+,--timeout=}'[connection timeout seconds (default 1)]:seconds:' \
  '(-d --debug)'{-d,--debug}'[show debug logs]' \
  '*:command:' && ret=0
return ret
