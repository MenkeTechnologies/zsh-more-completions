#compdef albert
# Documentation: https://github.com/albertlauncher/albert
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for albert (desktop application launcher)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--toggle[Toggle visibility of the launcher]' \
  '--show[Show the launcher]' \
  '--hide[Hide the launcher]' \
  '--restart[Restart albert]' \
  '--quit[Quit albert]' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-v --version)'{-v,--version}'[Print version]' && ret=0

return ret
