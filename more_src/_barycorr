#compdef barycorr
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/barycorr.html
# Apply barycentric time correction to FITS event/timing files

local ret=1

_arguments -s -S \
  'infile=[input FITS file to correct]:infile:_files' \
  'outfile=[output FITS file with corrected times]:outfile:_files' \
  'orbitfiles=[orbit ephemeris file(s), GEOCENTER to skip]:orbitfiles:_files' \
  'clockfile=[clock correction file, CALDB or NONE]:clockfile:' \
  'ra=[right ascension in decimal degrees]:ra:' \
  'dec=[declination in decimal degrees]:dec:' \
  'refframe=[coordinate reference frame]:refframe:(ICRS FK5)' \
  'ephem=[JPL planetary ephemeris selection]:ephem:' \
  'barytime=[append BARYTIME column instead of overwriting TIME]:barytime:(yes no)' \
  'tolerance=[no longer used]:tolerance:' \
  'chatter=[verbosity level 1-5]:chatter:(1 2 3 4 5)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
