#compdef pixz
# Documentation: https://github.com/vasi/pixz/blob/master/src/pixz.1.asciidoc
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pixz - parallel, indexed xz compressor

_arguments -s \
  '-d[decompress]' \
  '-l[list archive contents]' \
  '-x+[extract members whose path starts with PATH]:PATH:' \
  '-i+[input file]:file:_files' \
  '-o+[output file]:file:_files' \
  '-e[use slower "extreme" compression]' \
  '-p+[CPU cores to use]:N:' \
  '-t[force non-tarball mode (disable tar auto-detect)]' \
  '-f+[block size as fraction of LZMA dictionary (default 2.0)]:fraction:' \
  '-q+[compression queue block allocation]:size:' \
  '-0[compression level 0 (fastest)]' \
  '-1[compression level 1]' \
  '-2[compression level 2]' \
  '-3[compression level 3]' \
  '-4[compression level 4]' \
  '-5[compression level 5]' \
  '-6[compression level 6 (default)]' \
  '-7[compression level 7]' \
  '-8[compression level 8]' \
  '-9[compression level 9 (smallest)]' \
  '-h[show help]' \
  '*:file:_files'
