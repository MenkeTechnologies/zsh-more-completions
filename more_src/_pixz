#compdef pixz

# Zsh completion for pixz - parallel indexed xz compressor

_arguments -s -S \
  '-d[decompress]' \
  '-x[extract]' \
  '-l[list files]' \
  '-e[use extreme compression (slow)]' \
  '-p+[number of CPU cores to use]:N:' \
  '-t[tarball file mode - index tar entries]' \
  '-f+[fan-out size]:N:' \
  '-o+[output file]:file:_files' \
  '-i+[input file]:file:_files' \
  '-0[fastest compression]' \
  '-1[fast compression]' \
  '-2[compression level 2]' \
  '-3[compression level 3]' \
  '-4[compression level 4]' \
  '-5[medium compression]' \
  '-6[compression level 6 (default)]' \
  '-7[high compression]' \
  '-8[higher compression]' \
  '-9[maximum compression]' \
  '*:file:_files'
