#compdef sugabor
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/sugabor.c
# output a time-frequency representation of seismic data via Gabor transform

local ret=1

_arguments -s -S \
  'dt=[dt]:dt:' \
  'fmin=[fmin]:fmin:' \
  'fmax=[fmax]:fmax:' \
  'beta=[beta]:beta:' \
  'band=[band]:band:' \
  'alpha=[alpha]:alpha:' \
  'verbose=[verbose]:verbose:' \
  'holder=[holder]:holder:' \
  'n1=[n1]:n1:' \
  'n2=[n2]:n2:' \
  'n3=[n3]:n3:' \
  '*:file:_files' && ret=0

return ret
