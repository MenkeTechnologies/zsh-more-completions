#compdef hgGoldGapGl
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: put chromosome .agp and .gl files into the browser database

local ret=1

_arguments -s -S \
  '-noGl[do not process GL bits]' \
  '-chrom=[process only a single chromosome]:chr' \
  '-chromLst=[chrom subdirectories named in this file]:file:_files' \
  '-noLoad[generate SQL files without loading tables]' \
  '-verbose[verbosity level]:n' \
  '1:database:' \
  '2:gsDir or agpFile:_files' \
  '3:ooSubDir:_files -/' && ret=0

return ret
