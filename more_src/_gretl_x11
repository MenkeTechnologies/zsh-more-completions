#compdef gretl_x11
# Documentation: https://www.mankier.com/1/gretl
# gretl - GNU Regression, Econometrics and Time-series Library (X11 GUI)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[give help information and exit]' \
  '(-v --version)'{-v,--version}'[give version information and exit]' \
  '(-r --run)'{-r,--run}'[open a script]:script:_files' \
  '(-c --dump)'{-c,--dump}'[dump the configuration file]' \
  '(-d --db)'{-d,--db}'[open a local database]:database:_files' \
  '(-w --webdb)'{-w,--webdb}'[open a remote database]' \
  '(-e --english)'{-e,--english}'[force use of English]' \
  '*:data file:_files' && ret=0

return ret
