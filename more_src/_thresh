#compdef thresh
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss198.html
# KAPPA THRESH - edit an NDF to replace values between or outside two thresholds

local ret=1

_arguments -C \
  'IN=[input NDF]:NDF file:_files' \
  'OUT=[output NDF]:NDF file:_files' \
  'THRLO=[lower threshold value]:value:' \
  'THRHI=[upper threshold value]:value:' \
  'NEWLO=[replacement value for pixels below THRLO (or Bad)]:value:' \
  'NEWHI=[replacement value for pixels above THRHI (or Bad)]:value:' \
  'COMP=[array component to threshold]:component:(Data Quality Error Variance)' \
  'TITLE=[title for the output NDF]:title:' \
  '*:NDF file:_files' && ret=0

return ret
