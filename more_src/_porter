#compdef porter

local -a _porter_commands
_porter_commands=(
  'build:build a bundle'
  'create:create a bundle'
  'install:install a bundle'
  'upgrade:upgrade an installation'
  'uninstall:uninstall an installation'
  'invoke:invoke a custom action'
  'explain:explain a bundle'
  'inspect:inspect a bundle'
  'list:list installed bundles'
  'show:show an installation'
  'copy:copy a bundle'
  'archive:archive a bundle'
  'publish:publish a bundle'
  'lint:lint a bundle'
  'schema:print the JSON schema'
  'storage:manage stored data'
  'mixins:mixin commands'
  'plugins:plugin commands'
  'credentials:credential commands'
  'parameters:parameter commands'
  'installations:installation commands'
  'completion:generate shell completion script'
  'version:print version information'
  'help:help about any command'
)

_arguments -C \
  '--debug[enable debug logging]' \
  '--debug-plugins[enable plugin debug logging]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'porter commands' _porter_commands
    ;;
  args)
    case "$words[1]" in
      install|upgrade|uninstall)
        _arguments \
          '(-c --cred)'{-c,--cred}'[credential set name]:cred' \
          '(-p --param)'{-p,--param}'[parameter]:param' \
          '--param-file[parameter file]:file:_files' \
          '(-r --reference)'{-r,--reference}'[bundle reference]:ref' \
          '--force[force operation]' \
          '--allow-docker-host-access[allow docker host access]' \
          '(-n --namespace)'{-n,--namespace}'[namespace]:namespace' \
          '--name[installation name]:name' \
          '--label[label key=value]:label'
        ;;
      build)
        _arguments \
          '--name[bundle name]:name' \
          '--version[bundle version]:version' \
          '--file[path to porter.yaml]:file:_files' \
          '--dir[path to build context]:dir:_directories' \
          '--no-lint[skip linting]'
        ;;
      publish)
        _arguments \
          '--archive[path to archive]:file:_files' \
          '(-r --reference)'{-r,--reference}'[bundle reference]:ref' \
          '--registry[registry]:registry' \
          '--tag[tag]:tag'
        ;;
      list)
        _arguments \
          '(-o --output)'{-o,--output}'[output format]:format:(plaintext json yaml)' \
          '--all-namespaces[list across all namespaces]' \
          '(-n --namespace)'{-n,--namespace}'[namespace]:namespace' \
          '--name[filter by name]:name' \
          '--label[filter by label]:label'
        ;;
      mixins)
        _arguments '1:subcommand:(list install uninstall search feed)'
        ;;
      plugins)
        _arguments '1:subcommand:(list install uninstall search show)'
        ;;
      credentials)
        _arguments '1:subcommand:(list show generate edit delete apply)'
        ;;
      parameters)
        _arguments '1:subcommand:(list show generate edit delete apply)'
        ;;
    esac
    ;;
esac
