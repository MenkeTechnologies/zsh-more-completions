#compdef cbq

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[print shell version]' \
  '(-e --engine)'{-e,--engine=}'[cluster URL]:url:' \
  '(-ne --no-engine)'{-ne,--no-engine}'[start without connecting to a query service]' \
  '(-u --user)'{-u,--user=}'[username]:user:_users' \
  '(-p --password)'{-p,--password=}'[password]:password:' \
  '(-c --credentials)'{-c,--credentials=}'[bucket:password,bucket:password... credentials]:creds:' \
  '(-ncfg --networkconfig)'{-ncfg,--networkconfig=}'[connection mode]:mode:(auto default external)' \
  '--cacert=[CA certificate]:file:_files' \
  '--cert=[client cert chain]:file:_files' \
  '--key=[client private key]:file:_files' \
  '--no-ssl-verify[skip TLS verification]' \
  '-skip-verify[skip TLS verification]' \
  '(-s --script)'{-s,--script=}'[execute a single N1QL/SQL++ statement and exit]:stmt:' \
  '(-f --file)'{-f,--file=}'[execute statements from file and exit]:file:_files' \
  '(-o --output)'{-o,--output=}'[write query output to file]:file:_files' \
  '(-t --timeout)'{-t,--timeout=}'[query timeout duration]:duration:' \
  '--pretty=[pretty-print JSON output]:flag:(true false)' \
  '(-a --analytics)'{-a,--analytics}'[connect to Analytics service]' \
  '(-b --batch)'{-b,--batch=}'[batch mode]:mode:(on off)' \
  '(-qc --query_context)'{-qc,--query_context=}'[set query_context]:ctx:' \
  '(-ad --advise)'{-ad,--advise}'[run ADVISE on supplied queries]' \
  '(-q --quiet)'{-q,--quiet}'[suppress startup banner]' \
  '--exit-on-error[exit on first error]'
