#compdef netgen

# Netgen: automatic 3D tetrahedral mesh generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-batchmode[run in batch mode (no GUI)]' \
  '-geofile=[geometry input file]:file:_files -g "*.(geo|in2d|stl|step|stp|igs)"' \
  '-meshfile=[output mesh file]:file:_files -g "*.(vol|mesh)"' \
  '-meshfiletype=[mesh file format]:format:(Neutral Format Surface OpenFOAM Permas FEAP Elmer DIFFPACK TET Abaqus Gmsh)' \
  '-meshsize=[global maximum mesh element size]:val:' \
  '-meshsizefile=[mesh size definition file]:file:_files' \
  '-loadgeom[load geometry without meshing]' \
  '-meshscale=[scale factor for mesh]:val:' \
  '-cmd=[batch-mode command string]:cmd:' \
  '-localh[allow local mesh refinement]' \
  '-veryfine[very fine mesh density]' \
  '-fine[fine mesh density]' \
  '-moderate[moderate density (default)]' \
  '-coarse[coarse density]' \
  '-verycoarse[very coarse density]' \
  '-V[verbose output]' \
  '*:geometry file:_files -g "*.(geo|in2d|stl|step|stp|igs|brep|iges)"' && ret=0
return ret
