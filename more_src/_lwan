#compdef lwan
# Documentation: https://lwan.ws/

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-c,--config}'=[path to config file]:file:_files' \
  {-l,--listen}'=[listener spec (addr:port)]:address:' \
  {-r,--root}'=[path to serve files from]:directory:_files -/' \
  && return 0
