#compdef butteraugli
# Documentation: https://github.com/google/butteraugli
# butteraugli — perceptual image difference metric (PNG/JPG), optional PNM heatmap

local ret=1

_arguments -s -S \
  '1:image1:_files -g "*.(png|jpg|jpeg|PNG|JPG|JPEG)"' \
  '2:image2:_files -g "*.(png|jpg|jpeg|PNG|JPG|JPEG)"' \
  '3:heatmap output:_files -g "*.(pnm|PNM)"' && ret=0

return ret
