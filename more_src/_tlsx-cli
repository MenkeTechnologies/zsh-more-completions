_tlsx-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[host:port]:str:' \
        '-host=+[host:port]:_hosts' \
        '*-u+[target]:str:' \
        '-l+[input list]:file:_files' \
        '-list=+[file]:file:_files' \
        '-p+[port]:str:' \
        '-port=+[port]:n:' \
        '-r+[resolvers]:str:' \
        '-resolvers=+[hosts]:str:' \
        '-c+[concurrency]:n:' \
        '-rl+[rate limit]:n:' \
        '-sm+[scan mode]:m:(ctls ztls openssl auto)' \
        '-scan-mode=+[m]:m:(ctls ztls openssl auto)' \
        '-tlsversion[show TLS version]' \
        '-tv[show TLS version]' \
        '-cipher[show cipher]' \
        '-cn[show CN]' \
        '-san[show SAN]' \
        '-so[show subject org]' \
        '-sn[show serial number]' \
        '-ej[expired]' \
        '-sj[self-signed]' \
        '-mc[mismatched]' \
        '-re[revoked]' \
        '-un[untrusted]' \
        '-pe[show probe status]' \
        '-fp[print fingerprint]' \
        '-cert[show cert]' \
        '-cc[show cert chain]' \
        '-ji[JARM identifier]' \
        '-jarm[JARM]' \
        '-ja3[JA3]' \
        '-ja4[JA4]' \
        '-min-version+[v]:v:(ssl30 tls10 tls11 tls12 tls13)' \
        '-max-version+[v]:v:(ssl30 tls10 tls11 tls12 tls13)' \
        '-tps+[tls preset]:str:' \
        '-config+[file]:file:_files -g "*.yaml *.yml"' \
        '-resp[full response]' \
        '-resp-only[response only]' \
        '-rd+[response delay sec]:n:' \
        '-sa+[serverName]:str:' \
        '-servername=+[name]:str:' \
        '-cs+[cipher suite]:str:' \
        '-ws[wildcard sans]' \
        '-dns[DNS names]' \
        '-mm[mirror match]' \
        '-rs[random servername]' \
        '-o+[output file]:file:_files' \
        '-output=+[file]:file:_files' \
        '-j[JSON output]' \
        '-json[JSON output]' \
        '-silent[silent]' \
        '-nc[no color]' \
        '-no-color[no color]' \
        '-stats[stats]' \
        '-timeout+[sec]:n:' \
        '-retries+[N]:n:' \
        '*:target:'
}

