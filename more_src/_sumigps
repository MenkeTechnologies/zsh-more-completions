#compdef sumigps
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/migration_inversion/sumigps.c
# Phase-shift (Gazdag) migration of zero-offset SU data

local ret=1

_arguments -s -S \
  'dt=[time sampling interval]:dt' \
  'dx=[midpoint sampling interval]:dx' \
  'ffil=[trapezoidal frequency filter corners]:ffil' \
  'tmig=[times corresponding to interval velocities in vmig]:tmig' \
  'vmig=[interval velocities corresponding to times in tmig]:vmig' \
  'vfile=[file containing velocities]:file:_files' \
  'nxpad=[number of traces to pad with zeros before FFT]:nxpad' \
  'ltaper=[length of linear taper for left and right edges]:ltaper' \
  'verbose=[verbose=1 echoes information]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
