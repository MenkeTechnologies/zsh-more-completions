#compdef arduino-cli
# Documentation: https://github.com/arduino/arduino-cli (internal/cli/cli.go cobra rootCmd)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'board:board management operations'
  'cache:cache management'
  'compile:compile sketches'
  'completion:generate shell completions'
  'config:configuration management'
  'core:core platform operations'
  'daemon:run as a daemon service'
  'debug:debugging functionality'
  'generatedocs:documentation generation'
  'lib:library management'
  'monitor:serial port monitoring'
  'outdated:check for outdated packages'
  'profile:profile management'
  'sketch:sketch operations'
  'update:update package index'
  'upgrade:upgrade packages'
  'upload:upload sketches to boards'
  'burnbootloader:burn bootloader to boards'
  'version:display version information'
  'feedback:feedback submission'
  'help:show help for a subcommand'
)

local -a _root_flags
_root_flags=(
  '(-v --verbose)'{-v,--verbose}'[print logs on standard output]'
  '--log[alternate verbose logging]'
  '--log-level=[set minimum log level]:level:(trace debug info warn error fatal panic)'
  '--log-file=[log file path]:file:_files'
  '--log-format=[log format]:format:(text json)'
  '--format=[command output format]:format:(text json jsonmini yaml)'
  '--json[output results in JSON format]'
  '*--additional-urls=[board manager URLs (comma-separated)]:urls:'
  '--no-color[disable colored terminal output]'
  '--config-file=[custom configuration file location]:file:_files'
  '--config-dir=[custom data directory path]:dir:_directories'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -C \
  $_root_flags \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'arduino-cli subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _board _core _lib _config _sketch _profile
    _board=(
      'attach:attach a board to a sketch'
      'details:print details about a board'
      'list:list connected boards'
      'listall:list all installable boards'
      'search:search for a board'
    )
    _core=(
      'download:download cores'
      'install:install one or more cores'
      'list:list installed cores'
      'search:search for cores'
      'uninstall:uninstall cores'
      'update-index:update the index of cores'
      'upgrade:upgrade installed cores'
    )
    _lib=(
      'deps:check dependencies for a library'
      'download:download libraries'
      'examples:list examples for a library'
      'install:install libraries'
      'list:list installed libraries'
      'search:search for libraries'
      'uninstall:uninstall libraries'
      'update-index:update the libraries index'
      'upgrade:upgrade installed libraries'
    )
    _config=(
      'add:add a value to a setting'
      'delete:delete a config key'
      'dump:print the current configuration'
      'get:print a config value'
      'init:write empty configuration to standard location'
      'remove:remove a value from a setting'
      'set:set a config value'
    )
    _sketch=(
      'archive:create a zip archive of a sketch'
      'new:create a new sketch'
    )
    _profile=(
      'init:initialize the profiles section'
      'dump:print the profile'
      'install:install missing packages required by the profile'
    )
    case $line[1] in
      board) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'board' _board && ret=0 ;;
      core) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'core' _core && ret=0 ;;
      lib) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'lib' _lib && ret=0 ;;
      config) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'config' _config && ret=0 ;;
      sketch) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'sketch' _sketch && ret=0 ;;
      profile) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'profile' _profile && ret=0 ;;
      completion) _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      compile|upload|debug|monitor) _files -/ && ret=0 ;;
    esac
    ;;
esac

return ret
