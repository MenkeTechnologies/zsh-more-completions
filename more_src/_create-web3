#compdef create-web3
# Documentation: https://www.npmjs.com/package/create-web3
# Reference accessed: 2026-05-23
# Verified: npx create-web3 --help.

# Zsh completion for create-web3 - scaffold a Web3 project

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--ts[initialize as TypeScript project]' \
  '--typescript[initialize as TypeScript project]' \
  '--use-npm[bootstrap using npm]' \
  ':project directory:_directories' && ret=0

return ret
