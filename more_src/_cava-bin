#compdef cava
# _cava-bin — cava console-based audio visualizer (C); spectrum bars on ALSA/PulseAudio/PipeWire/JACK/sndio/FIFO/output
# upstream: https://github.com/karlstav/cava

_cava-bin() {
    _arguments \
        '(-p --config)'{-p,--config}'+[config file]:file:_files' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version-only)'{-V,--version-only}'[print version only]'
}

_cava-bin "$@"
