#compdef dlt-receive
# Documentation: https://github.com/COVESA/dlt-daemon/blob/master/doc/dlt-receive.1.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-h[show help]' \
  '-a[payload as ASCII]' \
  '-x[payload as hex]' \
  '-m[payload as hex and ASCII]' \
  '-s[only headers]' \
  '-o+[output DLT file]:file:_files' \
  '-c+[storage limit]:size:' \
  '-v[verbose]' \
  '-S[serial header on send]' \
  '-R[resync serial header]' \
  '-y[serial device mode]' \
  '-b+[serial baudrate]:rate:' \
  '-e+[ECU ID]:id:' \
  '-f+[filter file]:file:_files' \
  '-j+[JSON filter file]:file:_files' \
  '-p+[UDP/TCP port]:port:' \
  ':host or device:'
