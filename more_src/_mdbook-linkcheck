#compdef mdbook-linkcheck
# Documentation: https://man.archlinux.org/search?q=mdbook-linkcheck
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--standalone[run standalone without mdbook]' \
  '1:book directory:_directories' && return 0
