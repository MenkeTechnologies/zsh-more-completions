#compdef reset-ftrace-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/reset-ftrace.8
# reset state of ftrace, disabling all tracing (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-f[force, delete ftrace lock file]' \
  '-q[quiet, reset but say nothing]' && ret=0

return ret
