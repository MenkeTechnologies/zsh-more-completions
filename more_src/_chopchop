#compdef chopchop gochopchop
# Documentation: https://man.archlinux.org/search?q=chopchop
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'scan:scan a target URL'
  'plugins:list signatures/plugins'
)

_arguments -C \
  '(-v --verbosity)'{-v,--verbosity}'=[log level]:level:(debug info warn error fatal panic)' \
  '--threads=[thread count]:n:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'chopchop subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (scan)
        _arguments -s \
          '(-c --signatures)'{-c,--signatures}'=[signatures YAML]:file:_files' \
          '(-k --insecure)'{-k,--insecure}'[insecure TLS]' \
          '(-u --url-file)'{-u,--url-file}'=[URL file]:file:_files' \
          '(-b --max-severity)'{-b,--max-severity}'=[max severity]:severity:(High Medium Low Informational)' \
          '(-e --export)'{-e,--export}'=[export]:fmt:(csv json)' \
          '--export-filename=[export filename]:name:' \
          '(-t --timeout)'{-t,--timeout}'=[timeout]:seconds:' \
          '--severity-filter=[filter]:severity:(High Medium Low Informational)' \
          '--plugin-filters=[plugins]:names:' \
          '*:url:' && ret=0 ;;
      (plugins)
        _arguments -s \
          '(-c --signatures)'{-c,--signatures}'=[signatures]:file:_files' \
          '(-s --severity)'{-s,--severity}'=[severity]:severity:(High Medium Low Informational)' && ret=0 ;;
    esac
    ;;
esac

return ret
