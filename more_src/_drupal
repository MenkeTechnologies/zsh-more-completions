#compdef drupal drupal-cli drupal-console
# _drupal — Drupal Console developer toolkit CLI alias (Drupal Console team, PHP); Symfony Console
# upstream: https://github.com/hechoendrupal/drupal-console

_drupal() {
    local -a sub=(
        'about:show DrupalConsole info'
        'cache:cache subcommands'
        'chain:run multiple commands from yaml'
        'check:check Drupal site'
        'commands:list commands'
        'composerize:composerize site'
        'config:configuration subcommands'
        'cron:cron subcommands'
        'database:database subcommands'
        'debug:debug subcommands'
        'devel:devel commands'
        'docker:docker commands'
        'features:features subcommands'
        'generate:scaffold modules/themes/etc.'
        'help:show help'
        'image:image subcommands'
        'init:install autocomplete and config'
        'install:install Drupal'
        'list:list commands'
        'locale:locale subcommands'
        'migrate:migrate subcommands'
        'module:module subcommands'
        'multisite:multisite subcommands'
        'php-help:show php help'
        'queue:queue subcommands'
        'rest:REST subcommands'
        'router:router subcommands'
        'self-update:self-update'
        'self-uninstall:self-uninstall'
        'server:start dev server'
        'service:service subcommands'
        'settings:settings subcommands'
        'site:site subcommands'
        'snapshot:snapshot subcommands'
        'state:state subcommands'
        'taxonomy:taxonomy subcommands'
        'test:test subcommands'
        'theme:theme subcommands'
        'translation:translation subcommands'
        'update:update subcommands'
        'user:user subcommands'
        'views:views subcommands'
        'yaml:yaml subcommands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--root=+[Drupal root]:dir:_files -/' \
        '--uri=+[multisite uri]:str:' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--target=+[site alias]:str:' \
        '-t+[site alias]:str:' \
        '--learning[learning mode]' \
        '-l[learning mode]' \
        '--yes[assume yes]' \
        '-y[assume yes]' \
        '--shell[interactive shell]' \
        '-s[interactive shell]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'drupal subcommand' sub ;;
        args)
            case $words[1] in
                module|theme) _arguments \
                    '1:cmd:(install uninstall download path debug update list)' \
                    '*:name:' ;;
                cache) _arguments \
                    '1:cmd:(rebuild clean)' \
                    '*:bin:' ;;
                cron) _arguments \
                    '1:cmd:(execute release debug)' \
                    '*:arg:' ;;
                user) _arguments \
                    '1:cmd:(create delete login:url login:clear-attempts login:password-reset password password:hash password:reset login:url role roles update)' \
                    '*:arg:' ;;
                site) _arguments \
                    '1:cmd:(install maintenance new statistics status)' \
                    '*:arg:' ;;
                generate) _arguments \
                    '1:type:(controller entity event-subscriber form module plugin service test theme)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(export import diff debug single-export single-import override)' \
                    '*:arg:' ;;
                database) _arguments \
                    '1:cmd:(dump restore client log connect drop import)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_drupal "$@"
