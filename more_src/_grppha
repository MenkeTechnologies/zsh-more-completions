#compdef grppha
# Manipulates OGIP standard PHA FITS file

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input OGIP standard PHA FITS file]:input file:_files' \
  'outfile=[output file to create]:output file:_files' \
  'comm=[command string for the initial prompt]:command:' \
  'tempc=[command string for subsequent prompts]:command:' \
  'chatter=[verbosity level]:level:' \
  'clobber=[overwrite pre-existing output file]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
