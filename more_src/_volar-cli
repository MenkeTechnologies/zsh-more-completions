#compdef volar-cli vue-tsc
# Documentation: https://man.archlinux.org/search?q=volar-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--noEmit[do not emit output files]' \
  '--watch[watch input files]' \
  '--declaration[generate .d.ts files]' \
  '--emitDeclarationOnly[emit only .d.ts]' \
  '*-p+[tsconfig.json file]:file:_files -g "tsconfig*.json"' \
  '*--project=[tsconfig.json file]:file:_files -g "tsconfig*.json"' \
  '*:Vue file:_files -g "*.vue"' && ret=0

return ret
