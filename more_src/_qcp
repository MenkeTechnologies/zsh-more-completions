#compdef qcp
# Documentation: https://man.archlinux.org/search?q=qcp
# Reference accessed: 2026-05-16

# Zsh completion for qcp QUIC copier (crazyscot/qcp). Merged from qcp/src/cli/args.rs, qcp/src/client/options.rs, and qcp/src/config/structure.rs (clap flatten + infer_long_args).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--server[remote server mode internals]' \
  '--show-config[print effective configuration and exit]' \
  '--config-files[print config file paths and exit]' \
  '--help-buffers[kernel UDP buffer tips]' \
  '--list-features[print protocol features and exit]' \
  '--log-file=[log stderr to file]:file:_files' \
  '(-4)-4[force IPv4 / inet]' \
  '(-6)-6[force IPv6 / inet6]' \
  '--debug[set RUST_LOG=qcp=debug unless overridden]' \
  '(-q --quiet --debug)'{-q,--quiet}'[minimal output]' \
  '(-s --statistics --quiet)'{-s,--statistics}'[extra transfer stats]' \
  '--stats[same as --statistics]' \
  '--remote-debug[debug logs from remote]' \
  '--remote-trace[trace logs from remote]' \
  '--profile[emit timing profile after run]' \
  '--dry-run[exercise control channel only]' \
  '--remote-config[print negotiated remote configuration]' \
  '(-p --preserve)'{-p,--preserve}'[preserve modes and mtimes where possible]' \
  '(-r --recurse)'{-r,--recurse}'[recursive directory copy like scp]' \
  '--rx=[inbound bandwidth cap bytes or SI suffix]:bandwidth:' \
  '--rx-bw=[alias of --rx]:bandwidth:' \
  '--tx=[outbound bandwidth cap bytes or SI suffix]:bandwidth:' \
  '--tx-bw=[alias of --tx]:bandwidth:' \
  '--rtt=[expected RTT ms]:ms:' \
  '--congestion=[cubic|bbr|new-reno]:algorithm:(cubic bbr new-reno)' \
  '--initial-congestion-window=[initial cwnd bytes or SI suffix]:bytes:' \
  '--cwnd=[alias of --initial-congestion-window]:bytes:' \
  '--port=[local UDP port or range]:ports:' \
  '(-P --remote-port)'{-P,--remote-port=}'[remote UDP port or range]:ports:' \
  '--timeout=[QUIC endpoint timeout seconds]:seconds:' \
  '--udp-buffer=[kernel UDP buffer bytes or SI suffix]:bytes:' \
  '--packet-threshold=[reorder loss detection N]:N:' \
  '--time-threshold=[reorder loss detection x RTT]:multiplier:' \
  '--initial-mtu=[pre-PMTU bytes]:bytes:' \
  '--min-mtu=[min path MTU bytes]:bytes:' \
  '--max-mtu=[max PMTU search bytes]:bytes:' \
  '--address-family=[IP stack]:family:(inet inet6 any)' \
  '--ssh=[ssh client path]:path:_files' \
  '--remote-qcp-binary=[remote qcp executable path]:path:' \
  '*-S+[extra ssh option or flag for ssh]' \
  '-l=[default remote user]:user:_users' \
  '--remote-user=[default remote user]:user:_users' \
  '*--ssh-config=[alternate ssh_config paths]:file:_files' \
  '--ssh-subsystem[use ssh subsystem instead of remote argv]' \
  '--subsystem[same as --ssh-subsystem]' \
  '--color=-[console colour mode]:mode:(auto always never on off yes no none)' \
  '--colour=-[alias of --color]:mode:(auto always never on off yes no none)' \
  '--tls-auth-type=[TLS credential type]:type:(any x509 raw-public-key)' \
  '--aes256[prefer AES256 suites where possible]' \
  '--io-buffer-size=[read/write buffer bytes or SI suffix]:bytes:' \
  '--time-format=[log timestamp style]:format:(local utc utc-micro rfc3339)' \
  '*::source or dest:_default'
