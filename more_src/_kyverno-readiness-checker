#compdef kyverno-readiness-checker readiness-checker
# _kyverno-readiness-checker — Kyverno release-hook readiness/cleanup multitool (kyverno/kyverno)
# upstream: https://github.com/kyverno/kyverno
# Subcommands + flags from cmd/readiness-checker/main.go on tip.

_kyverno-readiness-checker() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                check-endpoints:'wait for a Service to have ready endpoints'
                check-http:'wait for a Service HTTP endpoint to respond'
                scale-deploy:'scale Kyverno deployments down/up by label'
                delete-webhooks:'delete webhook configurations by label'
            )
            _describe -t commands 'readiness-checker command' cmds
            ;;
        args)
            case $words[1] in
                check-endpoints)
                    _arguments \
                        '-service-name=[Service name]:name:' \
                        '-namespace=[Kubernetes namespace]:ns:' \
                        '-timeout=[total wait timeout]:dur:'
                    ;;
                check-http)
                    _arguments \
                        '-service-name=[Service name]:name:' \
                        '-namespace=[Kubernetes namespace]:ns:' \
                        '-path=[HTTP endpoint path]:path:' \
                        '-https[use HTTPS]' \
                        '-port=[Service port]:port:' \
                        '-timeout=[HTTP request timeout]:dur:'
                    ;;
                scale-deploy)
                    _arguments \
                        '-namespace=[Kubernetes namespace]:ns:' \
                        '-replicas=[desired replica count]:n:' \
                        '-label=[label selector for deployments]:sel:'
                    ;;
                delete-webhooks)
                    _arguments \
                        '-label=[label selector for webhooks]:sel:'
                    ;;
            esac
            ;;
    esac
}

_kyverno-readiness-checker "$@"
