#compdef roughtime

# Roughtime: rough-time time-synchronisation protocol client (Cloudflare)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-config[config file]:file:_files' \
  '-server[server to query (host:port)]:host:port:' \
  '-publickey[server public key (hex/base64)]:key:' \
  '-timeout[query timeout]:sec:' \
  '-out[output JSON file]:file:_files' \
  '*::Roughtime args:_files' && ret=0
return ret
