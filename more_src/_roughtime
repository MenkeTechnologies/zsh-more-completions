#compdef roughtime
# Documentation: https://github.com/cloudflare/roughtime
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# roughtime: Roughtime client/server (secure time)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'sync:request authenticated time from a server'
  'query:query a single server'
  'serve:run a roughtime server'
  'genkey:generate root key pair'
  'sign:sign certificate / message'
  'verify:verify response from server'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'roughtime command' commands && ret=0 ;;
esac
return ret
