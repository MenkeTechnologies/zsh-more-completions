#compdef melos

# Zsh completion for melos - Dart/Flutter monorepo management tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'bootstrap:link local packages and install dependencies'
      'clean:clean workspace'
      'exec:execute a command in each package'
      'list:list packages in the workspace'
      'publish:publish packages'
      'run:run a script defined in melos.yaml'
      'version:bump package versions'
      'analyze:run dart analyze in packages'
      'format:run dart format in packages'
      'test:run tests in packages'
    )
    _describe -t commands 'melos command' commands && ret=0
    ;;
  (args)
    local -a common_flags=(
      '--scope[include packages by name]:pattern'
      '--ignore[exclude packages by name]:pattern'
      '--diff[filter packages based on git diff]:ref'
      '--dir-exists[filter packages with a directory]:dir'
      '--file-exists[filter packages with a file]:file'
      '--flutter[filter Flutter packages]'
      '--no-private[exclude private packages]'
      '--depends-on[filter packages depending on]:package'
      '--no-depends-on[filter packages not depending on]:package'
      '--since[filter packages changed since ref]:ref'
      '--include-dependents[include dependent packages]'
      '--include-dependencies[include dependency packages]'
      '(-h --help)'{-h,--help}'[show help]'
      '--verbose[verbose output]'
      '--no-verbose[non-verbose output]'
      '--sdk-path[Dart SDK path]:path:_files -/'
    )

    case ${words[1]} in
      bootstrap)
        _arguments $common_flags && ret=0
        ;;
      exec)
        _arguments \
          '--concurrency[number of concurrent processes]:number' \
          '--fail-fast[stop on first failure]' \
          '--order-dependents[run in dependency order]' \
          $common_flags \
          '*:command' && ret=0
        ;;
      list)
        _arguments \
          '--long[show extended info]' \
          '--parsable[parsable output]' \
          '--relative[show relative paths]' \
          '--json[JSON output]' \
          '--graph[dependency graph]' \
          '--gviz[graphviz output]' \
          $common_flags && ret=0
        ;;
      run)
        _arguments \
          '--no-select[skip selection prompt]' \
          $common_flags \
          ':script name' && ret=0
        ;;
      version)
        _arguments \
          '--prerelease[use prerelease versioning]' \
          '--graduate[graduate prerelease packages]' \
          '--changelog[update changelogs]' \
          '--no-changelog[skip changelog updates]' \
          '--git-tag-version[create git tags]' \
          '--no-git-tag-version[skip git tags]' \
          '--message[git commit message]:message' \
          '--force-publish[force publish all packages]' \
          '--yes[skip confirmation]' \
          $common_flags && ret=0
        ;;
      *)
        _arguments $common_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
