#compdef goresym

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d[print default packages]' \
  '-e[print extended information]' \
  '-f[filter functions by regex]:pattern:' \
  '-p[print file paths]' \
  '-t[print type information]' \
  '-w[print source file tree]' \
  '-human[human readable output]' \
  '-json[JSON output]' \
  '-version[show version]' \
  '1:binary:_files' \
  && ret=0

return ret
