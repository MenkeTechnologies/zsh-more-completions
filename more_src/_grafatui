#compdef grafatui
# Source: cargo binstall grafatui@0.1.7
# Probed via: completions zsh
# Repository: https://github.com/fedexist/grafatui

autoload -U is-at-least

_grafatui() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--prometheus-url=[Prometheus URL (e.g., http\://localhost\:9090)]:PROMETHEUS_URL:_default' \
'--range=[Time range to query (e.g., 5m, 1h, 3d) (default\: 5m)]:DURATION:_default' \
'--step=[Query step resolution (e.g., 5s, 30s, 1m) (default\: 5s)]:DURATION:_default' \
'--grafana-json=[Grafana dashboard JSON file to import (e.g., ./dashboard.json)]:FILE:_files' \
'--tick-rate=[Legacy UI tick rate in milliseconds; redraws now happen on input and data refresh]:TICK_RATE:_default' \
'--refresh-rate=[Data refresh rate in milliseconds (Prometheus fetch interval) (default\: 1000)]:MS:_default' \
'*--query=[Additional PromQL queries to append as panels]:EXPR:_default' \
'*--var=[Template variables to override (e.g., --var instance=server1)]:KEY=VALUE:_default' \
'--theme=[Color theme (default, dracula, monokai, solarized-dark, solarized-light, gruvbox, tokyo-night, catppuccin)]:NAME:_default' \
'--threshold-marker=[Marker symbol to use for threshold lines (dashed, dot, braille, block, bar, quadrant, sextant, octant)]:MARKER:_default' \
'--autogrid-color=[Color to use for automatic grid lines and labels (e.g., gray, dark-gray, #666666)]:COLOR:_default' \
'--export-dir=[Directory for SVG/PNG exports and recordings]:DIR:_files' \
'--export-format=[Image format to export]:FORMAT:(svg png both)' \
'--record-max-frames=[Maximum number of changed frames to keep in one recording; must be greater than zero]:COUNT:_default' \
'--config=[Configuration file path (e.g., ./grafatui.toml)]:FILE:_files' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_grafatui_commands" \
"*::: :->grafatui" \
&& ret=0
    case $state in
    (grafatui)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:grafatui-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(man)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_grafatui__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:grafatui-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(man)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_grafatui_commands] )) ||
_grafatui_commands() {
    local commands; commands=(
'completions:Generate shell completions' \
'man:Generate man page' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'grafatui commands' commands "$@"
}
(( $+functions[_grafatui__completions_commands] )) ||
_grafatui__completions_commands() {
    local commands; commands=()
    _describe -t commands 'grafatui completions commands' commands "$@"
}
(( $+functions[_grafatui__help_commands] )) ||
_grafatui__help_commands() {
    local commands; commands=(
'completions:Generate shell completions' \
'man:Generate man page' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'grafatui help commands' commands "$@"
}
(( $+functions[_grafatui__help__completions_commands] )) ||
_grafatui__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'grafatui help completions commands' commands "$@"
}
(( $+functions[_grafatui__help__help_commands] )) ||
_grafatui__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'grafatui help help commands' commands "$@"
}
(( $+functions[_grafatui__help__man_commands] )) ||
_grafatui__help__man_commands() {
    local commands; commands=()
    _describe -t commands 'grafatui help man commands' commands "$@"
}
(( $+functions[_grafatui__man_commands] )) ||
_grafatui__man_commands() {
    local commands; commands=()
    _describe -t commands 'grafatui man commands' commands "$@"
}

if [ "$funcstack[1]" = "_grafatui" ]; then
    _grafatui "$@"
else
    compdef _grafatui grafatui
fi
