#compdef condor_run
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_run.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_run: submit a one-line HTCondor job and wait for the result.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-u[universe (default vanilla)]:universe:(vanilla scheduler local grid java)' \
  '-a[add submit command to implied submit description]:submitcmd:' \
  '-getenv[include getenv = true in submit description]' \
  '*:command:' && ret=0
return ret
