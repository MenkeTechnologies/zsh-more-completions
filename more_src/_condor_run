#compdef condor_run

# condor_run: submit a one-line condor job and wait for the result
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-u[universe]:universe:(vanilla standard scheduler local grid java)' \
  '-a[append attribute]:attr=value:' \
  '*:command:' && ret=0
return ret
