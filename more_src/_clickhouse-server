#compdef clickhouse-server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-C+,--config-file=}'[server config file]:file:_files -g "*.(xml|yaml|yml)"' \
  '--daemon[run in daemon mode]' \
  '--application=[application name]:name:' \
  '--logger.level=[log level]:level:(trace debug information warning error fatal none)' \
  '--logger.log=[log file]:file:_files' \
  '--logger.errorlog=[error log file]:file:_files' \
  '--logger.size=[max log file size]:size:' \
  '--logger.count=[max archive logs]:n:' \
  '--logger.console[log to console]' \
  '--http_port=[HTTP port]:port:' \
  '--tcp_port=[TCP port]:port:' \
  '--mysql_port=[MySQL protocol port]:port:' \
  '--postgresql_port=[PostgreSQL protocol port]:port:' \
  '--interserver_http_port=[interserver HTTP port]:port:' \
  '--listen_host=[listen address]:host:' \
  '--max_connections=[max connections]:n:' \
  '--max_concurrent_queries=[max concurrent queries]:n:' \
  '--keep_alive_timeout=[keep alive (seconds)]:secs:' \
  '--mark_cache_size=[mark cache size]:bytes:' \
  '--uncompressed_cache_size=[uncompressed cache]:bytes:' \
  '--mmap_cache_size=[mmap cache]:n:' \
  '--query_cache.size=[query cache size]:bytes:' \
  '--max_server_memory_usage=[max server memory]:bytes:' \
  '--openSSL.server.certificateFile=[SSL certificate]:file:_files' \
  '--openSSL.server.privateKeyFile=[SSL private key]:file:_files' \
  '--openSSL.server.caConfig=[CA config]:file:_files' \
  '--path=[data path]:dir:_files -/' \
  '--tmp_path=[temp path]:dir:_files -/' \
  '--user_files_path=[user files path]:dir:_files -/' \
  '--ddl_allow_long_path[allow long paths in DDL]' \
  '--mlock_executable[mlock executable]' \
  '--remap_executable[remap executable]' \
  '--profile=[settings profile]:profile:' \
  '--metric_log.flush_interval_milliseconds=[metric log flush interval]:ms:' && ret=0

return ret
