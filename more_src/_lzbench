#compdef lzbench
# Documentation: https://man.archlinux.org/search?q=lzbench
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a+[codec list]:codecs:' \
  '-b+[block size]:kb:' \
  '-c+[N copies of input]:n:' \
  '-d[decompress only]' \
  '-e[exhaustive (all levels)]' \
  '-i+[N runs for compress benchmarks]:n:' \
  '-j+[N runs for decompress benchmarks]:n:' \
  '-l[list compressors]' \
  '-m+[level range]:range:' \
  '-o+[output format]:fmt:(0 1 2 3 4)' \
  '-p+[print result every N seconds]:sec:' \
  '-r[recursive scan]' \
  '-s+[min compressors size]:n:' \
  '-T+[total time per codec sec]:sec:' \
  '-t+[time per loop ms]:ms:' \
  '-v[verbose]' \
  '-x[disable real-time priority]' \
  '*:file:_files' && ret=0

return ret
