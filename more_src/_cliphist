#compdef cliphist

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--max-items=[max items to store]:count' \
  '--max-dedupe-search=[max items to search for duplicates]:count' \
  '--preview-width=[width of preview]:width' \
  '1:command:(store list decode delete wipe)' && ret=0

return ret
