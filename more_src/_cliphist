#compdef cliphist
# Documentation: https://github.com/sentriz/cliphist
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'store:write clipboard changes to a history file'
  'list:list clipboard history with id and preview'
  'decode:decode an entry by id'
  'delete:remove a selected item from history'
  'delete-query:delete entries matching a query'
  'wipe:clear database'
  'compact:compact database'
  'version:show version'
)

_arguments -C \
  '-max-items=[max stored items]:count:' \
  '-max-dedupe-search=[max items to search for duplicates]:count:' \
  '-max-store-size=[max clipboard item size]:size:' \
  '-min-store-length=[minimum character count to store]:count:' \
  '-preview-width=[max preview characters]:width:' \
  '-db-path=[custom database location]:file:_files' \
  '-config-path=[custom configuration file]:file:_files' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'cliphist command' commands && ret=0 ;;
esac

return ret
