#compdef opensm

# opensm: InfiniBand subnet manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-C[print config and exit]' \
  '--create-config[print config and exit]' \
  '-g[GUID]:guid:' \
  '--guid=[GUID]:guid:' \
  '-p[priority]:n:' \
  '--priority=[priority]:n:' \
  '-l[max-LMC]:n:' \
  '--lmc=[max-LMC]:n:' \
  '-x[mode]:mode:' \
  '--exit_on_fatal=[exit on fatal]:bool:(TRUE FALSE)' \
  '-f[log file]:file:_files' \
  '--log_file=[log file]:file:_files' \
  '-s[sweep interval (sec)]:s:' \
  '--sweep=[sweep interval (sec)]:s:' \
  '-r[reassign LIDs]' \
  '--reassign_lids[reassign LIDs]' \
  '-Q[QoS enabled]' \
  '--qos[QoS enabled]' \
  '-D[log level]:level:' \
  '--debug=[log level]:level:' \
  '-d[debug flags]:flags:' \
  '--no_multicast[disable multicast]' \
  '--smkey=[SM key]:hex:' \
  '--cache-options=[cache options]:opts:' \
  '*::opensm args:_files' && ret=0
return ret
