#compdef mmdbinspect
# Documentation: https://man.archlinux.org/search?q=mmdbinspect
# Reference accessed: 2026-05-16

_arguments -s \
  '*-db[mmdb file path or glob]:file:_files -g "*.mmdb"' \
  '-include-aliased-networks[include aliased networks]' \
  '-include-build-time[include DB build timestamp]' \
  '-include-empty-values[include empty-data networks]' \
  '-include-networks-without-data[include null-data networks]' \
  '-jsonl[JSONL output]' \
  '*:ip-or-cidr:'
