#compdef peakmax
# Documentation: https://www.ccp4.ac.uk/html/peakmax.html
# CCP4: search an electron-density map for peaks

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'MAPIN[input map file to search]:map:_files -g "*.(map|ccp4)"' \
  'XYZOUT[output sorted peak list in PDB format]:output:_files' \
  'XYZFRC[output peaks with fractional coordinates]:output:_files' \
  'PEAKS[output unsorted peaks file]:output:_files' \
  '*:keyword:(THRESHOLD OUTPUT BFACTOR RESIDUE ATNAME CHAIN NUMPEAKS ORTHOGONALIZATION PATTERSON XYZLIMIT EXCLUDE END)' && ret=0

return ret
