#compdef vorbisgain

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-a[album mode (single gain for all files)]' \
  '-c[clean - remove ReplayGain tags]' \
  '-C[convert old format ReplayGain tags]' \
  '-d[display results only, no changes]' \
  '-f[fast mode - skip already tagged files]' \
  '-n[no change mode - compute but do not write]' \
  '-r[recursive, process subdirectories]' \
  '-s[silent mode - no output]' \
  '-q[quiet mode - less output]' \
  '*:ogg vorbis file:_files -g "*.ogg(-.)"' && ret=0

return ret
