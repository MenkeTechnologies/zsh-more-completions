#compdef mariadb-fix-extensions
# Documentation: https://man.archlinux.org/search?q=mariadb-fix-extensions
# Reference accessed: 2026-05-16

# mariadb-fix-extensions: rename .ISM/.ISD to .MYI/.MYD for old MyISAM tables
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)-V[show version]' \
  '*:data directory:_files -/' && ret=0
return ret
