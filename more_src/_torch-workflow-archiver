#compdef torch-workflow-archiver
# Documentation: https://github.com/pytorch/serve/tree/master/workflow-archiver
# Create a TorchServe workflow archive (.war) from a workflow DAG specification

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--workflow-name=[exported workflow name (.war)]:name:' \
  '--spec-file=[path to .yaml workflow DAG specification]:file:_files -g "*.yaml *.yml"' \
  '--handler=[python file with pre-process and post-process logic]:file:_files -g "*.py"' \
  '--export-path=[directory where the exported .war is saved]:dir:_files -/' \
  '--extra-files=[comma separated extra dependency files]:files:_files' \
  '(-f --force)'{-f,--force}'[overwrite existing .war with the same name]' && ret=0

return ret
