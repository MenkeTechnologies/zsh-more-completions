#compdef cljstyle
# _cljstyle — Greenlight cljstyle Clojure source formatter CLI alias (greglook team, Clojure); custom argparse
# upstream: https://github.com/greglook/cljstyle

_cljstyle() {
    local -a sub=(
        'check:check formatting'
        'find:find files that need formatting'
        'fix:rewrite files to be formatted'
        'pipe:read from stdin write to stdout'
        'config:show config'
        'version:show version'
        'migrate:migrate config from older versions'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--report[print report]' \
        '--no-report[no report]' \
        '--stats=+[stats file]:file:_files' \
        '--timeout=+[seconds]:n:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cljstyle subcommand' sub ;;
        args)
            case $words[1] in
                check|fix|find) _arguments \
                    '*:path:_files' \
                    '--timeout=+[seconds]:n:' \
                    '--no-color[no color]' \
                    '--report[print report]' ;;
                config) _arguments '*:path:_files' ;;
            esac
            ;;
    esac
}

_cljstyle "$@"
