#compdef scalafix
# Documentation: https://man.archlinux.org/search?q=scalafix
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '(-c --config)'{-c+,--config=}'[scalafix config file]:file:_files -g "*.conf"' \
  '*-r+[run rule]:rule:' \
  '*--rules=[run rule]:rule:' \
  '--auto-classpath[infer classpath from semanticdb dirs]' \
  '*--auto-classpath-roots=[scan dirs]:dirs:' \
  '--classpath=[classpath]:cp:' \
  '--sourceroot=[source root]:dir:_files -/' \
  '--scalac-options=[options to scalac]:opts:' \
  '--scala-version=[scala version]:ver:' \
  '--check[fail if would produce diff]' \
  '--diff[only fix files that differ]' \
  '--diff-base=[git revision to compare]:rev:' \
  '--exclude=[exclude pattern]:pat:' \
  '*--files=[file or dir to fix]:file:_files' \
  '--format=[output format]:fmt:(default sbt)' \
  '--no-stale-semanticdb[fail if stale semanticdb]' \
  '--non-interactive[non-interactive output]' \
  '--out-from=[regex to find input]:re:' \
  '--out-to=[regex to find output]:re:' \
  '--quiet-parse-errors[suppress parse error logs]' \
  '--triggered[triggered mode]' \
  '--syntactic[only syntactic rules]' \
  '--stdout[print fixed code to stdout]' \
  '--test[same as --check]' \
  '--tool-classpath=[additional classpath for rules]:cp:' \
  '--settings.[scalafix settings prefix]' \
  '--print-applied-rules[print applied rules]' \
  '*: :_files -g "*.scala"' && ret=0

return ret
