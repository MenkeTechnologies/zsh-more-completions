#compdef knockpy
# _knockpy — guelfoweb knockpy CLI subdomain enumeration and brute-force tool for python3 using DNS resolvers wordlist passive sources Censys VirusTotal threatcrowd HackerTarget hackertarget Sublist3r passive-and-active DNS-zone-transfer wildcard-detection bypass CNAME-chasing results CSV JSON HTML (guelfoweb team, Python); click
# upstream: https://github.com/guelfoweb/knock

_knockpy() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d+[domain]:str:' \
        '--domain=+[domain]:str:' \
        '-w+[wordlist]:file:_files' \
        '--wordlist=+[file]:file:_files' \
        '-r+[resolvers]:str:' \
        '--resolvers=+[ips]:str:' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-T+[timeout]:n:' \
        '--timeout=+[sec]:n:' \
        '--useragent=+[ua]:str:' \
        '-c+[code filter]:str:' \
        '--codes=+[list]:str:' \
        '-i+[ips only]' \
        '--ip[only show IPs]' \
        '-x[disable wildcard check]' \
        '--no-wildcard[disable wildcard check]' \
        '--no-http[skip HTTP probe]' \
        '--no-https[skip HTTPS probe]' \
        '-R+[recursive depth]:n:' \
        '--recursive[recursive enumeration]' \
        '-S+[passive sources]:str:' \
        '--sources=+[list]:str:' \
        '-O+[output dir]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '-J+[json output]:file:_files -g "*.json"' \
        '--json=+[file]:file:_files -g "*.json"' \
        '-C+[csv output]:file:_files -g "*.csv"' \
        '--csv=+[file]:file:_files -g "*.csv"' \
        '-H+[html output]:file:_files -g "*.html"' \
        '--html=+[file]:file:_files -g "*.html"' \
        '*:domain:'
}

_knockpy "$@"
