#compdef elvish

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--buildinfo[show build info]' \
  '--json[show build info as JSON]' \
  '-c+[execute command string]:command' \
  '--compileonly[compile only, do not execute]' \
  '--cpuprofile=[write CPU profile]:file:_files' \
  '--db=[path to database]:file:_files' \
  '--daemon[run as daemon]' \
  '--logfile=[path to log file]:file:_files' \
  '--lsp[run as language server]' \
  '--rc=[path to rc file]:file:_files' \
  '--norc[do not load rc file]' \
  '--sock=[daemon socket path]:file:_files' \
  '*:script file:_files'
