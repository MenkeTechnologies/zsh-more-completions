#compdef tflint

# Zsh completion for tflint - Terraform linter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '--init[install plugins]' \
  '--module[inspect modules]' \
  '--force[return zero exit status even with issues]' \
  '(-f --format)'{-f,--format}'[output format]:format:(default json checkstyle junit compact sarif)' \
  '--recursive[run in each directory recursively]' \
  '*--filter[filter issues by file name]:file:_files' \
  '--color[enable colorized output]' \
  '--no-color[disable colorized output]' \
  '--call-module-type[type of module calls to expand]:type:(all local none)' \
  '--minimum-failure-severity[set minimum severity for exit code 2]:severity:(error warning notice)' \
  '--chdir[switch to a different working directory]:dir:_directories' \
  '*--var[set a Terraform variable]:key=value' \
  '*--var-file[set Terraform variables from a file]:file:_files' \
  '--enable-rule[enable a specific rule]:rule' \
  '--disable-rule[disable a specific rule]:rule' \
  '--only[enable only specific rules]:rule' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0

return ret
