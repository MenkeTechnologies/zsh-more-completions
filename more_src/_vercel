#compdef vercel

# Zsh completion for vercel (Vercel platform CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global_opts=(
  '--cwd[set the current working directory]:dir:_directories'
  '(-d --debug)'{-d,--debug}'[enable debug mode]'
  '(-Q --global-config)'{-Q,--global-config}'[path to the global config directory]:dir:_directories'
  '(-h --help)'{-h,--help}'[show help information]'
  '(-A --local-config)'{-A,--local-config}'[path to the local configuration file]:file:_files'
  '--no-color[disable color output]'
  '(-S --scope)'{-S,--scope}'[set the scope (team or user)]:scope:'
  '(-t --token)'{-t,--token}'[login token]:token:'
  '(-v --version)'{-v,--version}'[print version]'
)

local -a subcommands=(
  'alias:manage domain aliases'
  'bisect:bisect a deployment to find a regression'
  'build:build the project'
  'certs:manage SSL certificates'
  'deploy:deploy the project'
  'dev:start a local development server'
  'dns:manage DNS records'
  'domains:manage domains'
  'env:manage environment variables'
  'git:manage Git provider repository'
  'init:initialize a new project from an example'
  'inspect:inspect a deployment'
  'link:link a local directory to a Vercel project'
  'list:list deployments'
  'login:log in to your Vercel account'
  'logout:log out of your Vercel account'
  'logs:display deployment logs'
  'project:manage projects'
  'promote:promote a deployment'
  'pull:pull environment variables and project settings'
  'redeploy:redeploy a deployment'
  'remove:remove a deployment'
  'rollback:rollback to a previous deployment'
  'target:manage deployment targets'
  'teams:manage teams'
  'whoami:show the currently logged in user'
)

_arguments -s -S -C \
  $global_opts \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'vercel command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      deploy)
        _arguments -s -S \
          $global_opts \
          '(-A --local-config)'{-A,--local-config}'[path to the local configuration file]:file:_files' \
          '--archive[compress the deployment code]:format:(tgz)' \
          '(-b --build-env)'{-b,--build-env}'[set build environment variable]:key=value:' \
          '(--confirm -y --yes)'{--confirm,-y,--yes}'[skip questions when setting up new project]' \
          '(-e --env)'{-e,--env}'[set environment variable]:key=value:' \
          '(-m --meta)'{-m,--meta}'[set metadata]:key=value:' \
          '(-n --name)'{-n,--name}'[set the name of the deployment]:name:' \
          '--no-clipboard[do not copy the URL to clipboard]' \
          '--no-wait[do not wait for the deployment to complete]' \
          '(-p --public)'{-p,--public}'[make the deployment URL accessible by anyone]' \
          '--prebuilt[deploy pre-built output]' \
          '--prod[deploy to production]' \
          '--regions[set deployment regions]:regions:' \
          '(-S --scope)'{-S,--scope}'[set the scope]:scope:' \
          '--with-cache[retain build cache]' \
          '*:path:_files' && ret=0
        ;;
      alias)
        local -a alias_commands=(
          'ls:list all aliases'
          'rm:remove an alias'
          'set:set an alias'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->alias_cmd' \
          '*::arg:->alias_args' && ret=0
        case $state in
          alias_cmd)
            _describe -t commands 'alias subcommand' alias_commands && ret=0
            ;;
          alias_args)
            case $line[1] in
              set)
                _arguments -s -S $global_opts ':deployment url:' ':alias:' && ret=0
                ;;
              rm)
                _arguments -s -S $global_opts ':alias:' && ret=0
                ;;
              ls)
                _arguments -s -S $global_opts && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      certs)
        local -a certs_commands=(
          'add:add an SSL certificate'
          'issue:issue an SSL certificate'
          'ls:list SSL certificates'
          'rm:remove an SSL certificate'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->certs_cmd' \
          '*::arg:->certs_args' && ret=0
        case $state in
          certs_cmd)
            _describe -t commands 'certs subcommand' certs_commands && ret=0
            ;;
          certs_args)
            case $line[1] in
              add)
                _arguments -s -S $global_opts '--crt[certificate file]:file:_files' '--key[key file]:file:_files' '--ca[CA certificate]:file:_files' ':domain:' && ret=0
                ;;
              issue)
                _arguments -s -S $global_opts '*:domain:' && ret=0
                ;;
              rm)
                _arguments -s -S $global_opts ':certificate id:' && ret=0
                ;;
              ls)
                _arguments -s -S $global_opts && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      dns)
        local -a dns_commands=(
          'add:add a DNS record'
          'import:import DNS records from a zonefile'
          'ls:list DNS records'
          'rm:remove a DNS record'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->dns_cmd' \
          '*::arg:->dns_args' && ret=0
        case $state in
          dns_cmd)
            _describe -t commands 'dns subcommand' dns_commands && ret=0
            ;;
          dns_args)
            case $line[1] in
              add)
                _arguments -s -S $global_opts ':domain:' ':name:' ':type:(A AAAA ALIAS CNAME MX SRV TXT CAA)' ':value:' && ret=0
                ;;
              import)
                _arguments -s -S $global_opts ':domain:' ':zonefile:_files' && ret=0
                ;;
              rm)
                _arguments -s -S $global_opts ':record id:' && ret=0
                ;;
              ls)
                _arguments -s -S $global_opts ':domain:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      domains)
        local -a domains_commands=(
          'add:add a domain'
          'buy:buy a domain'
          'inspect:inspect a domain'
          'ls:list domains'
          'move:move a domain to another scope'
          'rm:remove a domain'
          'transfer-in:transfer in a domain'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->domains_cmd' \
          '*::arg:->domains_args' && ret=0
        case $state in
          domains_cmd)
            _describe -t commands 'domains subcommand' domains_commands && ret=0
            ;;
          domains_args)
            _arguments -s -S $global_opts ':domain:' && ret=0
            ;;
        esac
        ;;
      env)
        local -a env_commands=(
          'add:add an environment variable'
          'ls:list environment variables'
          'pull:pull environment variables to a local file'
          'rm:remove an environment variable'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->env_cmd' \
          '*::arg:->env_args' && ret=0
        case $state in
          env_cmd)
            _describe -t commands 'env subcommand' env_commands && ret=0
            ;;
          env_args)
            case $line[1] in
              add)
                _arguments -s -S $global_opts ':name:' ':environment:(production preview development)' && ret=0
                ;;
              pull)
                _arguments -s -S $global_opts ':filename:_files' && ret=0
                ;;
              rm)
                _arguments -s -S $global_opts ':name:' ':environment:(production preview development)' && ret=0
                ;;
              ls)
                _arguments -s -S $global_opts && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      git)
        local -a git_commands=(
          'connect:connect a Git repository to a project'
          'disconnect:disconnect a Git repository from a project'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->git_cmd' \
          '*::arg:->git_args' && ret=0
        case $state in
          git_cmd)
            _describe -t commands 'git subcommand' git_commands && ret=0
            ;;
          git_args)
            _arguments -s -S $global_opts ':git url:' && ret=0
            ;;
        esac
        ;;
      project)
        local -a project_commands=(
          'add:add a project'
          'ls:list projects'
          'rm:remove a project'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->project_cmd' \
          '*::arg:->project_args' && ret=0
        case $state in
          project_cmd)
            _describe -t commands 'project subcommand' project_commands && ret=0
            ;;
          project_args)
            case $line[1] in
              add)
                _arguments -s -S $global_opts ':name:' && ret=0
                ;;
              rm)
                _arguments -s -S $global_opts ':name:' && ret=0
                ;;
              ls)
                _arguments -s -S $global_opts && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      target)
        local -a target_commands=(
          'add:add a deployment target'
          'ls:list deployment targets'
          'rm:remove a deployment target'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->target_cmd' \
          '*::arg:->target_args' && ret=0
        case $state in
          target_cmd)
            _describe -t commands 'target subcommand' target_commands && ret=0
            ;;
          target_args)
            _arguments -s -S $global_opts ':target:' && ret=0
            ;;
        esac
        ;;
      teams)
        local -a teams_commands=(
          'add:create a new team'
          'invite:invite a member to a team'
          'list:list all teams'
          'switch:switch to a different team'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->teams_cmd' \
          '*::arg:->teams_args' && ret=0
        case $state in
          teams_cmd)
            _describe -t commands 'teams subcommand' teams_commands && ret=0
            ;;
          teams_args)
            case $line[1] in
              invite)
                _arguments -s -S $global_opts ':email:' && ret=0
                ;;
              *)
                _arguments -s -S $global_opts && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      dev)
        _arguments -s -S \
          $global_opts \
          '--listen[specify the port to listen on]:port:' && ret=0
        ;;
      init)
        _arguments -s -S \
          $global_opts \
          '(-f --force)'{-f,--force}'[force overwrite]' \
          ':example name:' \
          ':directory:_directories' && ret=0
        ;;
      inspect)
        _arguments -s -S $global_opts ':deployment url:' && ret=0
        ;;
      link)
        _arguments -s -S \
          $global_opts \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '(-p --project)'{-p,--project}'[project name]:project:' && ret=0
        ;;
      list|ls)
        _arguments -s -S \
          $global_opts \
          '--meta[filter by metadata]:key=value:' && ret=0
        ;;
      login)
        _arguments -s -S \
          $global_opts \
          '--github[log in with GitHub]' \
          '--gitlab[log in with GitLab]' \
          '--bitbucket[log in with Bitbucket]' \
          ':email:' && ret=0
        ;;
      logs)
        _arguments -s -S \
          $global_opts \
          '(-f --follow)'{-f,--follow}'[follow the log output]' \
          ':deployment url:' && ret=0
        ;;
      pull)
        _arguments -s -S \
          $global_opts \
          '--environment[set the environment]:env:(production preview development)' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' && ret=0
        ;;
      remove|rm)
        _arguments -s -S \
          $global_opts \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '--safe[skip deployments with an active alias]' \
          '*:deployment name or url:' && ret=0
        ;;
      redeploy)
        _arguments -s -S \
          $global_opts \
          '--no-wait[do not wait for the deployment to complete]' \
          ':deployment url:' && ret=0
        ;;
      rollback)
        _arguments -s -S \
          $global_opts \
          '--timeout[time to wait for rollback to complete]:timeout:' \
          ':deployment id or url:' && ret=0
        ;;
      promote)
        _arguments -s -S \
          $global_opts \
          '--timeout[time to wait for promotion to complete]:timeout:' \
          ':deployment id or url:' && ret=0
        ;;
      bisect)
        _arguments -s -S \
          $global_opts \
          '--good[known good deployment URL or ID]:deployment:' \
          '--bad[known bad deployment URL or ID]:deployment:' \
          '--path[URL path to test]:path:' \
          '--run[test script command]:command:' && ret=0
        ;;
      build)
        _arguments -s -S \
          $global_opts \
          '--output[output directory]:dir:_directories' \
          '--prod[build for production]' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' && ret=0
        ;;
      logout|whoami)
        _arguments -s -S $global_opts && ret=0
        ;;
    esac
    ;;
esac

return ret
