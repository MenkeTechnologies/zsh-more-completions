#compdef vercel vc
# Documentation: https://vercel.com/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for vercel (Vercel platform CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global_opts=(
  '--cwd=[set the current working directory]:dir:_directories'
  '(-d --debug)'{-d,--debug}'[enable debug mode]'
  '(-Q --global-config)'{-Q,--global-config=}'[path to the global config directory]:dir:_directories'
  '(-h --help)'{-h,--help}'[show help information]'
  '(-A --local-config)'{-A,--local-config=}'[path to the local configuration file]:file:_files'
  '--no-color[disable color output]'
  '(-S --scope)'{-S,--scope=}'[set the scope (team or user)]:scope:'
  '(-t --token)'{-t,--token=}'[login token]:token:'
  '(-v --version)'{-v,--version}'[print version]'
)

local -a subcommands=(
  'activity:view activity events'
  'alerts:list recent alerts'
  'alias:manage domain aliases'
  'api:make authenticated HTTP requests to Vercel API'
  'bisect:bisect a deployment to find a regression'
  'blob:interact with Vercel Blob storage'
  'build:build the project'
  'buy:purchase Vercel products'
  'cache:manage CDN and Data cache'
  'certs:manage SSL certificates'
  'contract:view contract commitment information'
  'curl:make HTTP requests to Vercel deployments'
  'deploy:deploy the project'
  'dev:start a local development server'
  'dns:manage DNS records'
  'domains:manage domains'
  'env:manage environment variables'
  'flags:manage feature flags'
  'git:manage Git provider repository'
  'guidance:enable/disable guidance messages'
  'help:show help for a command'
  'httpstat:visualize HTTP request timing'
  'init:initialize a new project from an example'
  'inspect:inspect a deployment'
  'install:install a marketplace integration'
  'integration:manage marketplace integrations'
  'integration-resource:manage integration resources'
  'link:link a local directory to a Vercel project'
  'list:list deployments'
  'login:log in to your Vercel account'
  'logout:log out of your Vercel account'
  'logs:display deployment logs'
  'mcp:set up MCP client configuration'
  'metrics:query observability metrics'
  'microfrontends:work with microfrontends configuration'
  'open:open project in Vercel Dashboard'
  'project:manage projects'
  'promote:promote a deployment'
  'pull:pull environment variables and project settings'
  'redeploy:redeploy a deployment'
  'redirects:manage project-level redirects'
  'remove:remove a deployment'
  'rollback:rollback to a previous deployment'
  'rolling-release:manage rolling releases'
  'routes:manage project-level routing rules'
  'switch:switch between team scopes'
  'target:manage deployment targets'
  'teams:manage teams'
  'telemetry:enable/disable telemetry collection'
  'usage:view billing usage and costs'
  'webhooks:manage webhooks'
  'whoami:show the currently logged in user'
)

_arguments -s -S -C \
  $global_opts \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'vercel command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      deploy)
        _arguments -s -S \
          $global_opts \
          '--archive=[compress deployment code]:format:(tgz)' \
          '*'{-b,--build-env=}'[set build environment variable]:key=value:' \
          '(-y --yes)'{-y,--yes}'[skip questions]' \
          '*'{-e,--env=}'[set environment variable]:key=value:' \
          '*'{-m,--meta=}'[set metadata]:key=value:' \
          '(-n --name)'{-n,--name=}'[deployment name]:name:' \
          '--no-clipboard[do not copy URL to clipboard]' \
          '--no-wait[do not wait for deployment to complete]' \
          '(-p --public)'{-p,--public}'[make deployment URL public]' \
          '--prebuilt[deploy pre-built output]' \
          '--prod[deploy to production]' \
          '--target=[deployment target]:target:' \
          '*:path:_files' && ret=0
        ;;
      alias)
        _values 'alias subcommand' 'ls:list aliases' 'set:set an alias' 'rm:remove an alias' && ret=0
        ;;
      certs)
        _values 'certs subcommand' 'ls:list certs' 'issue:issue a cert' 'rm:remove a cert' && ret=0
        ;;
      dns)
        _values 'dns subcommand' 'ls:list DNS records' 'add:add a record' 'rm:remove a record' 'import:import zonefile' && ret=0
        ;;
      domains)
        _values 'domains subcommand' 'ls:list domains' 'add:add a domain' 'rm:remove a domain' 'buy:buy a domain' 'inspect:inspect a domain' 'move:move a domain' 'transfer-in:transfer in a domain' && ret=0
        ;;
      env)
        _values 'env subcommand' 'ls:list env vars' 'add:add env var' 'update:update env var' 'rm:remove env var' 'pull:pull env vars to file' 'run:run command with env vars' && ret=0
        ;;
      git)
        _values 'git subcommand' 'ls:list providers' 'connect:connect a repo' 'disconnect:disconnect a repo' && ret=0
        ;;
      project)
        _values 'project subcommand' 'ls:list projects' 'add:add a project' 'rm:remove a project' 'inspect:inspect a project' && ret=0
        ;;
      target)
        _values 'target subcommand' 'list:list targets' 'ls:list targets' && ret=0
        ;;
      teams)
        _values 'teams subcommand' 'list:list teams' 'add:create a team' 'invite:invite a member' && ret=0
        ;;
      blob)
        _values 'blob subcommand' 'list:list blobs' 'put:upload a blob' 'get:download a blob' 'del:delete a blob' 'copy:copy a blob' && ret=0
        ;;
      cache)
        _values 'cache subcommand' 'purge:purge cache' 'invalidate:invalidate cache by tag' 'dangerously-delete:dangerously delete' && ret=0
        ;;
      flags)
        _values 'flags subcommand' 'list:list flags' 'create:create flag' 'set:set flag' 'open:open flag' && ret=0
        ;;
      guidance)
        _values 'guidance subcommand' 'enable' 'disable' 'status' && ret=0
        ;;
      telemetry)
        _values 'telemetry subcommand' 'enable' 'disable' 'status' && ret=0
        ;;
      dev)
        _arguments -s -S \
          $global_opts \
          '--listen=[port to listen on]:port:' \
          '--port=[port]:port:' && ret=0
        ;;
      init)
        _arguments -s -S \
          $global_opts \
          '(-f --force)'{-f,--force}'[force overwrite]' \
          ':example name:' \
          ':directory:_directories' && ret=0
        ;;
      inspect)
        _arguments -s -S $global_opts \
          '--logs[show logs]' \
          '--wait[wait for deployment to complete]' \
          ':deployment url:' && ret=0
        ;;
      link)
        _arguments -s -S \
          $global_opts \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '(-p --project)'{-p,--project=}'[project name]:project:' \
          '*:path:_directories' && ret=0
        ;;
      list|ls)
        _arguments -s -S \
          $global_opts \
          '*--meta=[filter by metadata]:key=value:' && ret=0
        ;;
      login)
        _arguments -s -S \
          $global_opts \
          '--github[log in with GitHub]' \
          '--gitlab[log in with GitLab]' \
          '--bitbucket[log in with Bitbucket]' \
          ':email:' && ret=0
        ;;
      logs)
        _arguments -s -S \
          $global_opts \
          '(-f --follow)'{-f,--follow}'[follow log output]' \
          ':deployment url:' && ret=0
        ;;
      pull)
        _arguments -s -S \
          $global_opts \
          '--environment=[set environment]:env:(production preview development)' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' && ret=0
        ;;
      remove|rm)
        _arguments -s -S \
          $global_opts \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' \
          '--safe[skip deployments with active alias]' \
          '*:deployment name or url:' && ret=0
        ;;
      redeploy)
        _arguments -s -S \
          $global_opts \
          '--no-wait[do not wait]' \
          ':deployment url:' && ret=0
        ;;
      rollback)
        _arguments -s -S \
          $global_opts \
          ':deployment id or url:' && ret=0
        ;;
      promote)
        _arguments -s -S \
          $global_opts \
          ':deployment id or url:' && ret=0
        ;;
      bisect)
        _arguments -s -S \
          $global_opts \
          '--good=[known good deployment]:deployment:' \
          '--bad=[known bad deployment]:deployment:' \
          '--path=[URL path to test]:path:' \
          '--run=[test script command]:command:' && ret=0
        ;;
      build)
        _arguments -s -S \
          $global_opts \
          '--output=[output directory]:dir:_directories' \
          '--prod[build for production]' \
          '(-y --yes)'{-y,--yes}'[skip confirmation]' && ret=0
        ;;
      logout|whoami|open)
        _arguments -s -S $global_opts && ret=0
        ;;
    esac
    ;;
esac

return ret
