#compdef tikv-server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-A --addr)'{-A,--addr}'[set listening address]:addr:' \
  '--advertise-addr=[set advertise listening address]:addr:' \
  '--status-addr=[set status address]:addr:' \
  '--advertise-status-addr=[set advertise status address]:addr:' \
  '(-C --config)'{-C,--config}'[set config file]:file:_files' \
  '(-s --data-dir)'{-s,--data-dir}'[set data directory]:dir:_directories' \
  '--capacity=[set store capacity]:capacity:' \
  '--pd-endpoints=[set PD endpoints]:endpoints:' \
  '--labels=[set store labels]:labels:' \
  '(-L --log-level)'{-L,--log-level}'[set log level]:level:(trace debug info warn error off)' \
  '(-f --log-file)'{-f,--log-file}'[set log file]:file:_files' \
  '--log-rotation-size=[set log rotation size]:size:' \
  '--print-sample-config[print sample config to stdout]' \
  && ret=0

return ret
