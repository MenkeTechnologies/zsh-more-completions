#compdef tikv-server
# Documentation: https://docs.pingcap.com/tidb/stable/command-line-flags-for-tikv-configuration
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-A --addr)'{-A,--addr}'=[set listening address]:addr:' \
  '--advertise-addr=[set advertise listening address]:addr:' \
  '--status-addr=[set status address]:addr:' \
  '--advertise-status-addr=[set advertise status address]:addr:' \
  '(-C --config)'{-C,--config}'=[set config file]:file:_files' \
  '--config-info=[list config values in format]:format:(json toml)' \
  '--data-dir=[set data directory]:dir:_directories' \
  '--capacity=[set store capacity]:capacity:' \
  '--pd-endpoints=[set PD endpoints]:endpoints:' \
  '--pd=[set PD endpoints]:endpoints:' \
  '--labels=[set store labels]:labels:' \
  '-L[set log level]:level:(trace debug info warn error off)' \
  '--log-file=[set log file]:file:_files' \
  && ret=0

return ret
