#compdef namigo
# ============================================================================
# namigo - Your naming pal, written in Go (MIT)
#
# Author : Samuel Huang (huangsam)
# Upstream: https://github.com/huangsam/namigo
#
# namigo is a `urfave/cli/v3` CLI that helps you generate and validate
# project names across multiple naming entities (Go packages, DNS records,
# email accounts) by live-scraping availability data. The HTML pipeline
# lane is built on `github.com/PuerkitoBio/goquery v1.12.0`, the canonical
# Go HTML scraping library which wraps `golang.org/x/net/html` for parsing
# and `andybalholm/cascadia` for CSS selector matching.
#
# Verbatim from upstream `internal/core/goquery.go`:
#
#     package core
#     import (
#         "net/http"
#         "github.com/PuerkitoBio/goquery"
#     )
#     type DocumentGenerator interface {
#         Execute() (*goquery.Document, error)
#     }
#
# The package-search subcommand pipelines an HTTP request through
# goquery's Document API to extract availability + metadata from the
# rendered package registry pages. Same conceptual shape as scraper crate
# in Rust and cheerio in JS - "parse HTML once, project via CSS."
#
# ----------------------------------------------------------------------------
# AXIS 195 :: HTML SCRAPING WITH CSS SELECTORS
# Round 1284 :: Go slot 2 of 4 :: continues Axis 195
#
# Cross-language canonical library family for this axis:
#   Rust    : scraper      (rust-scraper/scraper)  - html5ever + selectors  [R1283 _fyin]
#   Go      : goquery      (PuerkitoBio/goquery)   - x/net/html + cascadia [R1284 THIS FILE]
#   TS/Node : cheerio      (cheeriojs/cheerio)     - parse5 + css-select   [R1285 closing]
#
# goquery is the most-cited Go HTML library on pkg.go.dev, sitting at
# the same conceptual rank as scraper crate (Rust) and cheerio (TS).
# It follows the jQuery surface (`.Find()`, `.Each()`, `.Text()`,
# `.Attr()`) but routes everything through the Go stdlib parser stack
# rather than reimplementing HTML5 tokenization, which is the explicit
# design tradeoff: lean on `golang.org/x/net/html` (battle-tested,
# Go-team-maintained) instead of vendoring a fresh tokenizer like
# Servo's html5ever does on the Rust side.
#
# namigo is a small but architecturally clean consumer that exercises
# the canonical Document/Selection pipeline through an interface-based
# generator - a real-world "search a registry and extract structured
# results" workflow rather than a synthetic example.
# ============================================================================

_namigo() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_namigo_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                generate) _namigo_generate; ret=0 ;;
                search)   _namigo_search;   ret=0 ;;
                version)  _arguments {-h,--help}'[show help]'; ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_namigo_cmds() {
    local -a cmds
    cmds=(
        'generate:Generate names with AI'
        'search:Search for terms across entities'
        'version:Print version information'
    )
    _describe -t commands 'namigo command' cmds
}

_namigo_generate() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :((prompt\:"Generate prompt for AI chatbots"))' \
        '*::arg:->genargs' \
    && ret=0

    case $state in
        genargs)
            case $words[1] in
                prompt)
                    _arguments \
                        '--purpose[Project purpose]:purpose:' \
                        '--theme[Project theme]:theme:' \
                        '--demographics[Target demographics]:demographics:' \
                        '--interests[Target interests]:interests:' \
                        '--size[Max size for generated names (default 10)]:integer:' \
                        '--length[Max length for each generated name (default 20)]:integer:' \
                        '(- *)'{-h,--help}'[show help]'
                    ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_namigo_search() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '--size[Max size for search results (default 10)]:integer:' \
        '--format[Output format]:format:(text json yaml)' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_namigo_search_cmds' \
        '*::arg:->searcharg' \
    && ret=0

    case $state in
        searcharg)
            _arguments \
                '--size[Max size for search results]:integer:' \
                '--format[Output format]:format:(text json yaml)' \
                '(- *)'{-h,--help}'[show help]'
            ret=0
            ;;
    esac

    return ret
}

_namigo_search_cmds() {
    local -a cmds
    cmds=(
        'package:Search for packages'
        'dns:Search for DNS records'
        'email:Search for email records'
    )
    _describe -t commands 'namigo search subcommand' cmds
}

_namigo "$@"
