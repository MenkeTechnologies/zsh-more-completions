#compdef megaclisas-status

# megaclisas-status: short status summary from LSI/MegaRAID via MegaCli
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--nagios[Nagios output format]' \
  '--debug[debug mode]' \
  '*::megaclisas-status args:_files' && ret=0
return ret
