#compdef megaclisas-status megasasctl
# Documentation: https://man.archlinux.org/search?q=megaclisas-status
# Reference accessed: 2026-05-16

# megaclisas-status: human-readable wrapper for MegaCli status
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--nagios[nagios-style status output]' \
  '--csv[output CSV]' \
  '--badlist[only print bad-state drives]' \
  '--debug[verbose debug]' \
  '*::megaclisas-status args:_files' && ret=0
return ret
