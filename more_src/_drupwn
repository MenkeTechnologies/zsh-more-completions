#compdef drupwn
# Documentation: https://man.archlinux.org/search?q=drupwn
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '--mode=[mode]:mode:(enum exploit)' \
  '--target=[target URL]:url:' \
  '--users[enumerate users]' \
  '--nodes[enumerate nodes]' \
  '--modules[enumerate modules]' \
  '--dfiles[enumerate default files]' \
  '--themes[enumerate themes]' \
  '--version=[Drupal version]:ver:' \
  '--cookies=[cookies]:cookies:' \
  '--thread=[thread count]:n:' \
  '--range=[scan range]:range:' \
  '--ua=[user agent]:ua:' \
  '--bauth=[basic auth user:pass]:cred:' \
  '--delay=[request delay]:s:' \
  '--log[enable logging]' \
  '--update[update]' \
  '--proxy=[proxy URL]:url:' \
  '--proxies=[proxies file]:file:_files'
