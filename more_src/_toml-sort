#compdef toml-sort
# Documentation: https://github.com/pappasam/toml-sort
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '(-o --output)'{-o,--output}'=[Write output to file]:file:_files' \
  '(-i --in-place)'{-i,--in-place}'[Edit files in place]' \
  '--check[Check formatting only]' \
  '(-a --all)'{-a,--all}'[Sort all keys (tables, inline tables, and arrays)]' \
  '(-I --ignore-case)'{-I,--ignore-case}'[Sort case-insensitively]' \
  '--no-sort-tables[Preserve table order]' \
  '--sort-table-keys[Sort keys within tables]' \
  '--sort-inline-tables[Sort inline table contents]' \
  '--sort-inline-arrays[Sort inline array contents]' \
  '--sort-first=[Comma-separated keys to sort first]:keys:' \
  '--no-comments[Remove all comments]' \
  '--no-header-comments[Remove leading document comments]' \
  '--no-footer-comments[Remove trailing comments]' \
  '--no-inline-comments[Remove end-of-line comments]' \
  '--no-block-comments[Remove standalone comments]' \
  '--spaces-before-inline-comment=[Spaces before inline comments]:spaces:(1 2 3 4)' \
  '--spaces-indent-inline-array=[Indent spaces for multiline arrays]:spaces:(2 4 6 8)' \
  '--trailing-comma-inline-array[Add trailing comma to multiline arrays]' \
  '*:toml files:_files -g "*.toml(-.)"'
