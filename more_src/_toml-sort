#compdef toml-sort

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '(-o --output)'{-o,--output}'=[Write output to file]:file:_files' \
  '(-i --in-place)'{-i,--in-place}'[Edit files in place]' \
  '(--check)'--check'[Check formatting only]' \
  '(-a --all)'{-a,--all}'[Sort all keys including inline structures]' \
  '(-I --ignore-case)'{-I,--ignore-case}'[Ignore case when sorting]' \
  '--no-comments[Strip comments]' \
  '*:toml files:_files -g "*.toml(-.)"'
