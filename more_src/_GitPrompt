#compdef GitPrompt
# Documentation: https://github.com/awgn/git-prompt
# Source: awgn/git-prompt — Haskell git prompt generator for bash/zsh/fish.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-p --path)'{-p+,--path=}'[git repository path (default cwd)]:dir:_files -/' \
    '(-t --theme)'{-t+,--theme=}'[color theme]:theme:_default' \
    '(-s --short)'{-s,--short}'[short/condensed output mode]' \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
