#compdef swift-sdk

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'configure:manage configuration options for installed Swift SDKs'
  'configuration:deprecated, use configure'
  'install:install a Swift SDK bundle'
  'list:list IDs of available Swift SDKs'
  'remove:remove an installed Swift SDK bundle'
  'help:show subcommand help'
)

_arguments -C \
  '(- *)--version[show version]' \
  '(- *)'{-h,-help,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'swift-sdk subcommand' subcommands && ret=0
    ;;
esac

return ret
