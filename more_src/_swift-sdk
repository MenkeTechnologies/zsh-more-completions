#compdef swift-sdk
# Documentation: https://github.com/swiftlang/swift-package-manager/tree/main/Sources/SwiftSDKCommand
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'configure:manage configuration options for installed Swift SDKs'
  'install:install a Swift SDK bundle'
  'list:list IDs of available Swift SDKs'
  'remove:remove an installed Swift SDK bundle'
)

_arguments -C \
  '(- *)--version[show version]' \
  '(- *)'{-h,-help,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'swift-sdk subcommand' subcommands && ret=0
    ;;
esac

return ret
