#compdef bcftools-gtcheck
# Documentation: http://www.htslib.org/doc/bcftools.html#gtcheck
# bcftools gtcheck: Check sample identity / discordance between genotypes

local ret=1

_arguments -s -S \
  '(--distinctive-sites)'--distinctive-sites'[Find sites that can distinguish between at least NUM sample pairs. If]:NUM:_files -/' \
  '(--dry-run)'--dry-run'[Stop after first record to estimate required time.]' \
  '(-e --exclude)'{-e,--exclude}'[Exclude sites from query file ( qry\: ) or genotype file ( gt\: ) for wh]:arg: ' \
  '(-E --error-probability)'{-E,--error-probability}'[Interpret genotypes and genotype likelihoods probabilistically. The va]:INT: ' \
  '(-g --genotypes)'{-g,--genotypes}'[VCF/BCF file with reference genotypes to compare against]:FILE:_files' \
  '(-H --homs-only)'{-H,--homs-only}'[Homozygous genotypes only, useful with low coverage data (requires -g,]' \
  '(-i --include)'{-i,--include}'[Include sites from query file ( qry\: ) or genotype file ( gt\: ) for wh]:arg: ' \
  '(--keep-refs)'--keep-refs'[Include monoallelic sites in comparison, by default they are excluded]' \
  '(--n-matches)'--n-matches'[Print only top INT matches for each sample, 0 for unlimited. Use negat]:INT: ' \
  '(--no-HWE-prob)'--no-HWE-prob'[Disable calculation of HWE probability to reduce memory requirements w]' \
  '(-o --output)'{-o,--output}'[Write to FILE rather than to standard output, where it is written by d]:FILE:_files' \
  '(-O --output-type)'{-O,--output-type}'[Write a plain ( t ) or compressed ( z ) text tab-delimited output.]:t: ' \
  '(-p --pairs)'{-p,--pairs}'[A comma-separated list of sample pairs to compare. When the -g option]:LIST: ' \
  '(-P --pairs-file)'{-P,--pairs-file}'[A file with tab-delimited sample pairs to compare. The first sample in]:FILE:_files' \
  '(-r --regions)'{-r,--regions}'[Restrict to comma-separated list of regions, see Common Options]:chr: ' \
  '(--regions-overlap)'--regions-overlap'[see Common Options]:0: ' \
  '(-t --targets)'{-t,--targets}'[see Common Options]:file:_files' \
  '(-T --targets-file)'{-T,--targets-file}'[see Common Options]:file:_files' \
  '(--targets-overlap)'--targets-overlap'[see Common Options]:0: ' \
  '(-u --use)'{-u,--use}'[specifies which tag to use in the query file ( TAG1 ) and the -g ( TAG]:TAG1: ' \
  '(-v --verbosity)'{-v,--verbosity}'[see Common Options]:INT: ' \
  '*:file:_files' && ret=0

return ret
