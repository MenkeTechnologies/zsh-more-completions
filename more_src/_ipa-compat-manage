#compdef ipa-compat-manage

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-y --password)'{-y,--password}'+[password file]:file:_files' \
  '1:command:(enable disable status)' && ret=0

return ret
