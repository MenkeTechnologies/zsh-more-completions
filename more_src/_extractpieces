#compdef extractpieces
# Documentation: https://bio3d.colorado.edu/imod/doc/man/extractpieces.html
# Extract piece coordinates from an MRC file header

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-input -InputFile)'{-input,-InputFile}'[Image file with header information to extract. If this ]:file:_files' \
  '(-output -OutputFile)'{-output,-OutputFile}'[Output file for header values. If this option is not en]:file:_files' \
  '(-mdoc -MdocMetadataFile)'{-mdoc,-MdocMetadataFile}'[Obtain values from a metadata file named with the name ]' \
  '(-other -OtherMetadataFile)'{-other,-OtherMetadataFile}'[Obtain values from the metadata file with the given nam]:file:_files' \
  '-StandardInput[Read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
