#compdef st-flash
# Documentation: https://github.com/stlink-org/stlink/blob/develop/doc/man/st-flash.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '--debug[output extra debug information]'
  '--version[print version information]'
  '--reset[reset before and after flashing]'
  '--connect-under-reset[pull reset low while connecting]'
  '--hot-plug[connect without reset]'
  '--mass-erase[mass erase before writing]'
  '--freq=[JTAG/SWD frequency in KHz]:freq:'
  '--serial=[ST-LINK device serial]:serial:'
  '--format=[file format]:format:(binary ihex)'
  '--flash=[flash size override]:size:'
  '--area=[memory area]:area:(main system otp option option_boot_add optcr optcr1)'
  '--opt[skip writing empty bytes at end]'
  '--help[display help]'
  '1:action:(read write erase reset)'
  '2:file:_files'
  '3:address:'
  '4:size:'
)

_arguments -s -S $arguments
