#compdef st-flash

local -a arguments

arguments=(
  '--debug[enable debug output]'
  '--reset[reset device after operation]'
  '--connect-under-reset[connect under reset]'
  '--hot-plug[connect without halting the target]'
  '--freq=[set SWD frequency in KHz]:freq:'
  '--serial=[select device by serial number]:serial:'
  '--format=[specify file format]:format:(binary ihex)'
  '--flash=[flash size override]:size:'
  '--area=[target area]:area:(main system otp option_bytes optcr option_bytes_boot_add)'
  '--opt[read or write option bytes]'
  '1:action:(read write erase reset)' \
  '2:file:_files'
  '3:address:'
  '4:size:'
)

_arguments -s -S $arguments
