#compdef bsky-cli
# ============================================================================
# _bsky-cli — zsh completion for atrium-rs's bsky-cli, the canonical
#              Rust Bluesky / AT Protocol command-line client
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/atrium-rs/atrium
#   Author     : sugyan and the atrium-rs collaborators
#   License    : MIT
#   Language   : Rust
#   Crate      : bsky-cli v0.1.37  (workspace member under bsky-cli/)
#   Binary     : bsky-cli  (Cargo.toml [[bin]] name = "bsky-cli",
#                           path = "src/bin/main.rs")
#   Last push  : 2026-03-26
#
# WHAT IT IS
#   bsky-cli is a Bluesky / AT Protocol command-line client built
#   directly on top of `bsky-sdk` (the typed Rust SDK that wraps
#   `atrium-api`, the canonical Rust AT Protocol bindings).  It
#   authenticates against a Personal Data Server (PDS — default
#   `https://bsky.social`), persists the resulting session to the
#   user's data directory via `dirs`, and then exposes every
#   commonly-used Bluesky read/write endpoint as a clap subcommand:
#   timeline / author-feed / list-feed / feed views, follows /
#   followers / lists, profiles, preferences, notifications, chat
#   conversation listing + message sending, post creation with image
#   embeds, and post deletion.
#
# CLI ARGUMENT GRAMMAR  (verbatim from bsky-cli/src/bin/main.rs Args
#                       struct + bsky-cli/src/commands.rs Command
#                       enum)
#   bsky-cli [GLOBAL_FLAGS] <SUBCOMMAND>
#
#   Global flags (inherited by every subcommand):
#     -p, --pds-host <URL>     Personal Data Server URL
#                                [default: https://bsky.social]
#     -l, --limit <N>          Limit the number of items returned
#                                [default: 10, range 1..=100]
#     -d, --debug              Debug print
#
#   Standard clap auto-flags:
#     -h, --help               Show help
#     -V, --version            Show version
#
#   Subcommands:
#     login                    Create an authentication session
#       -i, --identifier <ID>    Handle / DID / other server-supported
#                                identifier for the authenticating user
#       -p, --password <PASS>    Password
#
#     get-timeline             Get a view of the actor's home timeline
#
#     get-author-feed [-a <ID>]
#                              Get a view of an actor's feed
#     get-actor-feeds [-a <ID>]
#                              Get a list of feeds created by an actor
#     get-follows     [-a <ID>]
#                              Get a list of who an actor follows
#     get-followers   [-a <ID>]
#                              Get a list of an actor's followers
#     get-lists       [-a <ID>]
#                              Get a list of the lists created by an actor
#     get-profile     [-a <ID>]
#                              Get detailed profile view of an actor
#
#     get-likes        -u <URI>
#                              Get a list of likes for a given post
#     get-reposted-by  -u <URI>
#                              Get a list of reposts for a given post
#     get-feed         -u <URI>
#                              Get a view of a hydrated feed
#     get-list-feed    -u <URI>
#                              Get a view of a specified list
#     get-list         -u <URI>
#                              Get detailed info of a specified list
#     delete-post      -u <URI>
#                              Delete a post
#
#     get-preferences          Get preferences of the authenticated actor
#     list-notifications       Get a list of notifications
#     list-convos              Get a list of chat conversations
#
#     send-convo-message
#       -a, --actor <ID>         Recipient handle / DID
#       -t, --text  <TEXT>       Message text
#
#     create-post
#       -t, --text  <TEXT>       Post text
#       -i, --images <PATH>...   Image paths to embed (repeatable
#                                Vec<PathBuf>)
#
#   AT-URI format (used by every -u/--uri):
#     at://did:plc:<DID>/<COLLECTION>/<RKEY>
#     (parsed by the bsky-cli `AtUri` FromStr impl)
#
# AXIS / CORPUS POSITION
#   Direct workspace dependency on `bsky-sdk` declared in
#   bsky-cli/Cargo.toml (and through it on `atrium-api`) — the
#   canonical typed Rust AT Protocol bindings maintained by the
#   atrium-rs project (Yuki Iizuka / sugyan and the atrium-rs
#   collaborators).  atrium-api is the auto-generated, lexicon-
#   driven Rust binding to every public AT Protocol Lexicon
#   (com.atproto.* / app.bsky.* namespaces) — the Rust analogue of
#   bluesky-social/indigo's Go bindings.  bsky-sdk wraps that
#   surface in an ergonomic `BskyAgent` plus session persistence.
#   Verified via:
#     gh api repos/atrium-rs/atrium/contents/bsky-cli/Cargo.toml
#       → bsky-sdk.workspace = true
#     gh api repos/atrium-rs/atrium/contents/bsky-cli/src/commands.rs
#       → use bsky_sdk::api::types::string::AtIdentifier;
#   This entry is the Rust=128 leader bump that OPENS Axis 73
#   (AT Protocol / Bluesky SDK), pairing with future Go=
#   bluesky-social/indigo and TS-Node=@atproto/api poles to close
#   the axis at 1/1/1.
#
#   No completion for `bsky-cli` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_bsky-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-p --pds-host)'{-p+,--pds-host=}'[Personal Data Server URL (default https\://bsky.social)]:url:' \
        '(-l --limit)'{-l+,--limit=}'[limit number of items returned (default 10, 1-100)]:limit:' \
        '(-d --debug)'{-d,--debug}'[debug print]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_bsky-cli_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                login)
                    _arguments \
                        '(-i --identifier)'{-i+,--identifier=}'[handle or DID for the authenticating user]:identifier:' \
                        '(-p --password)'{-p+,--password=}'[password]:password:' && ret=0 ;;
                get-author-feed|get-actor-feeds|get-follows|get-followers|get-lists|get-profile)
                    _arguments \
                        '(-a --actor)'{-a+,--actor=}'[actor handle or DID]:actor:' && ret=0 ;;
                get-likes|get-reposted-by|get-feed|get-list-feed|get-list|delete-post)
                    _arguments \
                        '(-u --uri)'{-u+,--uri=}'[record URI (at\://did\:plc\:.../collection/rkey)]:at-uri:' && ret=0 ;;
                send-convo-message)
                    _arguments \
                        '(-a --actor)'{-a+,--actor=}'[recipient handle or DID]:actor:' \
                        '(-t --text)'{-t+,--text=}'[message text]:text:' && ret=0 ;;
                create-post)
                    _arguments \
                        '(-t --text)'{-t+,--text=}'[post text]:text:' \
                        '*'{-i+,--images=}'[image path to embed (repeatable)]:image:_files -g "*.{png,jpg,jpeg,gif,webp}"' && ret=0 ;;
                get-timeline|get-preferences|list-notifications|list-convos)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_bsky-cli_commands] )) ||
_bsky-cli_commands() {
    local -a commands
    commands=(
        'login:create an authentication session'
        'get-timeline:get a view of the actor home timeline'
        'get-author-feed:get a view of an actor feed'
        'get-likes:get a list of likes for a given post'
        'get-reposted-by:get a list of reposts for a given post'
        'get-actor-feeds:get a list of feeds created by an actor'
        'get-feed:get a view of a hydrated feed'
        'get-list-feed:get a view of a specified list'
        'get-follows:get a list of who an actor follows'
        'get-followers:get a list of an actor followers'
        'get-lists:get a list of the lists created by an actor'
        'get-list:get detailed info of a specified list'
        'get-profile:get detailed profile view of an actor'
        'get-preferences:get preferences of the authenticated actor'
        'list-notifications:get a list of notifications'
        'list-convos:get a list of chat conversations'
        'send-convo-message:send a message to a chat conversation'
        'create-post:create a new post (with optional image embeds)'
        'delete-post:delete a post'
    )
    _describe -t commands 'bsky-cli command' commands
}

_bsky-cli "$@"
