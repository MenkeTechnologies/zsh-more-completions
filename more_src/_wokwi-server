#compdef wokwi-server
# Documentation: https://github.com/MabezDev/wokwi-server
# wokwi-server: run an embedded Rust ELF binary in the Wokwi simulator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--host=[Wokwi host]:host' \
  '(-c --chip)'{-c,--chip}'=[target chip]:chip' \
  '(-b --bootloader)'{-b,--bootloader}'=[path to bootloader file]:file:_files' \
  '(-p --partition-table)'{-p,--partition-table}'=[path to partition table CSV]:file:_files' \
  '--id=[Wokwi project ID]:id' \
  '*:elf:_files' && ret=0

return ret
