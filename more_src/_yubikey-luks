#compdef yubikey-luks yubikey-luks-enroll
# Documentation: https://github.com/cornelinux/yubikey-luks/blob/master/yubikey-luks-enroll
# Reference accessed: 2026-05-16
# Verified: upstream yubikey-luks-enroll getopts.

# yubikey-luks-enroll: enroll YubiKey to a LUKS slot
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-s[LUKS slot]:slot:' \
  '-d[partition/disk]:device:_files -g "/dev/*"' \
  '-y[YubiKey slot]:yk-slot:' \
  '-c[clear slot before writing]' \
  '-v[enable debug mode]' && ret=0
return ret
