#compdef 3dpc
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dpc.html
# AFNI: principal component analysis of 3D datasets

local ret=1

_arguments -s -S \
  '-dmean[remove mean from each brick across voxels]' \
  '-vmean[remove mean from each voxel across bricks]' \
  '-vnorm[L2 normalize each voxel time series]' \
  '-normalize[L2 normalize each brick after mean removal]' \
  '-nscale[scale covariance matrix by number of samples]' \
  '-pcsave[number of principal components to save]:n:' \
  '-reduce[dimensionally reduced dataset r pp]:r:' \
  '-prefix[output dataset name]:prefix:' \
  '-1ddum[add dummy lines (999999) to top of 1D files]:n:' \
  '-verbose[enable progress reporting]' \
  '-quiet[suppress progress reporting]' \
  '-eigonly[compute only eigenvalues then exit]' \
  '-float[save eigen-bricks as floats]' \
  '-mask[mask dataset for voxel selection]:mset:_files' \
  '*:dataset:_files' && ret=0

return ret
