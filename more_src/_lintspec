#compdef lintspec
# Documentation: https://man.archlinux.org/search?q=lintspec
# Reference accessed: 2026-05-16
# Source: cargo binstall lintspec@0.17.0
# Probed via: completions --shell zsh
# Repository: https://github.com/beeb/lintspec

autoload -U is-at-least

_lintspec() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'*-e+[Path to a file or folder to exclude (can be used more than once)]:EXCLUDE:_files' \
'*--exclude=[Path to a file or folder to exclude (can be used more than once)]:EXCLUDE:_files' \
'--config=[Optional path to a TOML config file]:CONFIG:_files' \
'-o+[Write output to a file instead of stderr]:OUT:_files' \
'--out=[Write output to a file instead of stderr]:OUT:_files' \
'--inheritdoc=[Enforce that all public and external items have \`@inheritdoc\`]::INHERITDOC:(true false)' \
'--inheritdoc-override=[Enforce that internal functions and modifiers which override a parent have \`@inheritdoc\`]::INHERITDOC_OVERRIDE:(true false)' \
'--notice-or-dev=[Do not distinguish between \`@notice\` and \`@dev\` when considering "required" validation rules]::NOTICE_OR_DEV:(true false)' \
'-n+[Number of parallel workers/threads, or 0 to use the number of logical cores]:THREADS:_default' \
'--parallel=[Number of parallel workers/threads, or 0 to use the number of logical cores]:THREADS:_default' \
'*--title-ignored=[Ignore \`@title\` for these items (can be used more than once)]:TITLE_IGNORED:(contract interface library)' \
'*--title-required=[Enforce \`@title\` for these items (can be used more than once)]:TITLE_REQUIRED:(contract interface library)' \
'*--title-forbidden=[Forbid \`@title\` for these items (can be used more than once)]:TITLE_FORBIDDEN:(contract interface library)' \
'*--author-ignored=[Ignore \`@author\` for these items (can be used more than once)]:AUTHOR_IGNORED:(contract interface library)' \
'*--author-required=[Enforce \`@author\` for these items (can be used more than once)]:AUTHOR_REQUIRED:(contract interface library)' \
'*--author-forbidden=[Forbid \`@author\` for these items (can be used more than once)]:AUTHOR_FORBIDDEN:(contract interface library)' \
'*--notice-ignored=[Ignore \`@notice\` for these items (can be used more than once)]:NOTICE_IGNORED:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--notice-required=[Enforce \`@notice\` for these items (can be used more than once)]:NOTICE_REQUIRED:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--notice-forbidden=[Forbid \`@notice\` for these items (can be used more than once)]:NOTICE_FORBIDDEN:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--dev-ignored=[Ignore \`@dev\` for these items (can be used more than once)]:DEV_IGNORED:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--dev-required=[Enforce \`@dev\` for these items (can be used more than once)]:DEV_REQUIRED:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--dev-forbidden=[Forbid \`@dev\` for these items (can be used more than once)]:DEV_FORBIDDEN:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--param-ignored=[Ignore \`@param\` for these items (can be used more than once)]:PARAM_IGNORED:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--param-required=[Enforce \`@param\` for these items (can be used more than once)]:PARAM_REQUIRED:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--param-forbidden=[Forbid \`@param\` for these items (can be used more than once)]:PARAM_FORBIDDEN:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--return-ignored=[Ignore \`@return\` for these items (can be used more than once)]:RETURN_IGNORED:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--return-required=[Enforce \`@return\` for these items (can be used more than once)]:RETURN_REQUIRED:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'*--return-forbidden=[Forbid \`@return\` for these items (can be used more than once)]:RETURN_FORBIDDEN:(contract interface library constructor enum error event private-function internal-function public-function external-function modifier parsing-error struct private-variable internal-variable public-variable)' \
'--json=[Output diagnostics in JSON format]::JSON:(true false)' \
'--compact=[Compact output]::COMPACT:(true false)' \
'--sort=[Sort the results by file path]::SORT:(true false)' \
'-s+[Write diagnostics to stdout instead of stderr (when no \`--out\` file is specified)]::STDOUT:(true false)' \
'--stdout=[Write diagnostics to stdout instead of stderr (when no \`--out\` file is specified)]::STDOUT:(true false)' \
'-0+[Exit with code 0 even when there are diagnostics]::EXIT_ZERO:(true false)' \
'--exit-zero=[Exit with code 0 even when there are diagnostics]::EXIT_ZERO:(true false)' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::PATH -- One or more paths to files and folders to analyze:_files' \
":: :_lintspec_commands" \
"*::: :->lintspec" \
&& ret=0
    case $state in
    (lintspec)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:lintspec-command-$line[2]:"
        case $line[2] in
            (init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-s+[The flavor of shell for which to generate the completion script]:SHELL:(bash elvish fish powershell zsh)' \
'--shell=[The flavor of shell for which to generate the completion script]:SHELL:(bash elvish fish powershell zsh)' \
'-o+[The output directory for the file, prints to \`stdout\` if omitted]:OUT:_files -/' \
'--out=[The output directory for the file, prints to \`stdout\` if omitted]:OUT:_files -/' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_lintspec__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:lintspec-help-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_lintspec_commands] )) ||
_lintspec_commands() {
    local commands; commands=(
'init:Create a \`.lintspec.toml\` config file with default values' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'lintspec commands' commands "$@"
}
(( $+functions[_lintspec__subcmd__completions_commands] )) ||
_lintspec__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'lintspec completions commands' commands "$@"
}
(( $+functions[_lintspec__subcmd__help_commands] )) ||
_lintspec__subcmd__help_commands() {
    local commands; commands=(
'init:Create a \`.lintspec.toml\` config file with default values' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'lintspec help commands' commands "$@"
}
(( $+functions[_lintspec__subcmd__help__subcmd__completions_commands] )) ||
_lintspec__subcmd__help__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'lintspec help completions commands' commands "$@"
}
(( $+functions[_lintspec__subcmd__help__subcmd__help_commands] )) ||
_lintspec__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'lintspec help help commands' commands "$@"
}
(( $+functions[_lintspec__subcmd__help__subcmd__init_commands] )) ||
_lintspec__subcmd__help__subcmd__init_commands() {
    local commands; commands=()
    _describe -t commands 'lintspec help init commands' commands "$@"
}
(( $+functions[_lintspec__subcmd__init_commands] )) ||
_lintspec__subcmd__init_commands() {
    local commands; commands=()
    _describe -t commands 'lintspec init commands' commands "$@"
}

if [ "$funcstack[1]" = "_lintspec" ]; then
    _lintspec "$@"
else
    compdef _lintspec lintspec
fi
