#compdef gen-yaml
# _gen-yaml — emit a (re)normalized YAML form of a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/yamlgen.py (click).

_gen-yaml() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.(yaml|yml)"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(yaml yml)'
        '--raw[emit raw / unprocessed YAML (no expansion)]'
        '--no-raw[emit fully processed YAML (default)]'
        '--validateonly[validate the schema and exit (do not emit YAML)]'
        '--generate[validate then emit normalized YAML (default)]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-yaml "$@"
