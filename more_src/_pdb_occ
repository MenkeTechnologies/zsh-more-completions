#compdef pdb_occ
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Modifies the occupancy column of a PDB file (default 1.0)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[occupancy value to set, e.g. -1.0]:occupancy' \
  '*:PDB file:_files' && ret=0

return ret
