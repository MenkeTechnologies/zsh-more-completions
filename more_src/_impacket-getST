#compdef impacket-getST
# Documentation: https://github.com/fortra/impacket/blob/master/examples/getST.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-getST: request a Kerberos service ticket (S4U2Self / S4U2Proxy / RBCD).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-spn[target SPN (service/server)]:spn:' \
  '-altservice[new sname/SPN to set in ticket]:spn:' \
  '-dmsa[use Delegated Managed Service Accounts]' \
  '-impersonate[user to impersonate via S4U2Self]:user:' \
  '-additional-ticket[forwardable service ticket for S4U2Proxy]:file:_files' \
  '-u2u[request User-to-User ticket]' \
  '-self[only S4U2Self (no S4U2Proxy)]' \
  '-force-forwardable[force service ticket forwardable]' \
  '-renew[set RENEW option for TGT renewal]' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (128 or 256 bits)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '*::positional:_files' && ret=0
return ret
