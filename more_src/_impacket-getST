#compdef impacket-getST

# Impacket getST.py: request Service Ticket via S4U/PKINIT/RBCD
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-spn[service principal name]:spn:' \
  '-impersonate[user to impersonate (S4U)]:user:' \
  '-additional-ticket[additional TGT/ST .ccache]:file:_files' \
  '-pfx[PFX certificate file for PKINIT]:file:_files' \
  '-pfx-pass[PFX password]:pwd:' \
  '-pfx-base64[base64-encoded PFX]:b64:' \
  '-rdp[output ticket for RDP]' \
  '-renew[only renew an existing TGT]' \
  '-altservice[alternative service name (force AltService)]:name:' \
  '-self[request TGT (self ticket) to use with S4U2self]' \
  '-u2u[user-to-user mode]' \
  '-force-forwardable[force forwardable flag in TGS]' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos auth from ccache]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-dc-host[DC hostname]:host:' \
  '*:domain/user[:password]:' && ret=0
return ret
