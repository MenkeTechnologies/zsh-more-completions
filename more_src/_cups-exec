#compdef cups-exec
# Documentation: man cupsd-helper(8)
# Source: OpenPrinting/cups scheduler/cups-exec.c (master) — apply sandbox profile and exec (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-u+[UID to run as]:uid:_default' \
    '-g+[GID to run as]:gid:_default' \
    '-n+[nice value]:nice:_default' \
    '1:sandbox profile:_files' \
    '2:program path:_command_names -e' \
    '*::argv:_default' \
    && ret=0

return ret
