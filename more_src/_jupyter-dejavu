#compdef jupyter-dejavu
# Documentation: https://nbconvert.readthedocs.io/en/latest/dejavu.html
# jupyter-dejavu - generate static notebook output with Voila-like nbconvert defaults

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--show-input[show code cells in addition to their output]' \
  '--to=[export format to use]:format:' \
  '--output=[overwrite base name used for output files]:file:_files' \
  '--output-dir=[directory to write output to]:dir:_files -/' \
  '--template=[template name to use]:template:' \
  '--template-file=[template file to use]:file:_files' \
  '--execute[execute the notebook before converting]' \
  '--no-input[exclude input cells from output]' \
  '--stdout[write notebook output to stdout]' \
  '*:notebook:_files -g "*.ipynb"' && ret=0

return ret
