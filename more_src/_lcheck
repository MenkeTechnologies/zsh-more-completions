#compdef lcheck
# Documentation: https://doc.qt.io/qt-6/linguist-translators.html
# Reference accessed: 2026-05-19
# Verified: local `lcheck --help` (Qt Linguist tool chain).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help on commandline options]' \
  '(- *)--help-all[display help, including generic Qt options]' \
  '(- *)'{-v,--version}'[display version information]' \
  '--no-accelerator[disable the accelerator check]' \
  '--no-punctuation[disable the punctuation check]' \
  '--no-place-marker[disable the place marker check]' \
  '--no-whitespaces[disable the surrounding whitespace check]' \
  '--check-finished[enable check for translations marked as finished]' \
  '(-o --output)'{-o,--output}'+[output file for the report]:file:_files' \
  '*:TS file:_files -g "*.ts"' && ret=0

return ret
