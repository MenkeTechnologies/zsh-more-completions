#compdef docking_protocol
# Documentation: https://docs.rosettacommons.org/docs/latest/application_documentation/docking/docking-protocol
# Rosetta RosettaDock protein-protein docking application

local ret=1

_arguments -s -S \
  '-help[display all available options]' \
  '-partners+[define docking partners by chain ID (e.g. A_B)]:partners:' \
  '-randomize1[randomize first partner orientation]' \
  '-randomize2[randomize second partner orientation]' \
  '-spin[spin second partner around axes]' \
  '-dock_pert+[perturb structure with translation and rotation]:values:' \
  '-uniform_trans+[uniform random repositioning within sphere radius]:radius:' \
  '-use_ellipsoidal_randomization[randomize about ellipsoids rather than spheres]' \
  '-norepack1[prevent sidechain repacking of partner 1]' \
  '-norepack2[prevent sidechain repacking of partner 2]' \
  '-sc_min[perform extra sidechain minimization]' \
  '-low_res_protocol_only[run only low resolution portion]' \
  '-docking_local_refine[high resolution refinement only]' \
  '-dock_min[single minimization round in high resolution]' \
  '-dock_mcm_trans_magnitude+[translational perturbation magnitude (angstroms)]:magnitude:' \
  '-dock_mcm_rot_magnitude+[rotational perturbation magnitude (degrees)]:magnitude:' \
  '-docking_centroid_outer_cycles+[number of outer centroid cycles]:cycles:' \
  '-docking_centroid_inner_cycles+[number of inner centroid cycles]:cycles:' \
  '-in:file:s+[input PDB file]:pdb:_files -g "*.pdb"' \
  '-in:file:l+[list of input PDB files]:pdblist:_files' \
  '-database+[path to Rosetta database directory]:database:_files -/' \
  '-score:weights+[scoring function weights file]:weights:_files' \
  '-nstruct+[number of output structures]:nstruct:' \
  '-out:path:all+[output directory path]:path:_files -/' \
  '-out:pdb[output in PDB format]' \
  '-overwrite[overwrite existing output files]' \
  '-ex1[extra chi1 rotamer sampling]' \
  '-ex2[extra chi2 rotamer sampling]' \
  '*-mute+[suppress output from a tracer channel]:channel:' \
  '*-unmute+[enable output from a tracer channel]:channel:' \
  '*:file:_files' && ret=0

return ret
