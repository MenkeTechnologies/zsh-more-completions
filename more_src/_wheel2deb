#compdef wheel2deb
# Documentation: https://pypi.org/project/wheel2deb/
# Python wheel to Debian package converter

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '1:command:((
    convert\:"convert wheels into Debian source packages"
    build\:"build Debian binary packages from converted sources"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      convert)
        _arguments -s -S \
          '--map=[map python dist names to debian package names]:map' \
          '--depends=[additional debian dependencies]:depends' \
          '--ignore-version-specifiers[ignore version specifiers from wheel requirements]' \
          '*:wheel:_files -g "*.whl"' && ret=0
        ;;
      *)
        _arguments -s -S '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
