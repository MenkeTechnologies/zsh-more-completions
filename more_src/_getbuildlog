#compdef getbuildlog
# Documentation: https://manpages.debian.org/getbuildlog
# Source: debian/devscripts scripts/getbuildlog.sh — fetch package build logs from Debian auto-builders (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '1:package:_default' \
    '2::version pattern (or "last"/"last-all"):_default' \
    '3::architecture pattern:_default' \
    && ret=0

return ret
