#compdef seqretsplit

# EMBOSS seqretsplit: read input sequence(s) and write each one to a
# separate output file named after the sequence ID.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-feature[carry feature tables into each output file]' \
  '-firstonly[only output the first sequence]' \
  '-osformat=[output format for split files]:format:(fasta embl genbank gff swiss gcg ig pir nbrf raw msf ace text staden experiment)' \
  '-osname=[base name pattern for output files]:pattern:' \
  '-osextension=[output file extension]:ext:' \
  '-osdirectory=[output directory]:dir:_files -/' \
  '-outseq=[output sequence file mask]:file:_files' \
  '*:sequence USA:_files' && ret=0

return ret
