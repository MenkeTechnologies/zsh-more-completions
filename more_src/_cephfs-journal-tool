#compdef cephfs-journal-tool
# Documentation: https://docs.ceph.com/en/latest/cephfs/cephfs-journal-tool/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cephfs-journal-tool: examine/edit MDS journal
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--filesystem=[filesystem name]:name:' \
  '--rank=[MDS rank]:n:' \
  '--worker-n=[worker count]:n:' \
  '--worker-id=[worker id]:n:' \
  '--force-corrupt[allow corruption]' \
  '--force-init[allow init when exists]' \
  '*:cephfs-journal-tool command:(journal header event inspect import export reset recover_dentries)' && ret=0
return ret
