#compdef ocioarchive
# Documentation: https://opencolorio.readthedocs.io/
# create, extract, or inspect a .ocioz config archive

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--iconfig=[input config file path]:config:_files -g "*.ocio"' \
  '--extract[expand a .ocioz archive]' \
  '--list[view the contents of a .ocioz file]' \
  '*:archive:_files -g "*.ocioz"' && ret=0

return ret
