#compdef kiss kiss-alternatives kiss-build kiss-checksum kiss-download kiss-install kiss-list kiss-remove kiss-search kiss-update kiss-upgrade kiss-version

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'a:alternatives - list and swap alternatives'
  'alternatives:list and swap alternatives'
  'b:build - build packages'
  'build:build packages'
  'c:checksum - generate checksums'
  'checksum:generate checksums'
  'd:download - download sources'
  'download:download sources'
  'i:install - install packages'
  'install:install packages'
  'l:list - list installed packages'
  'list:list installed packages'
  'r:remove - remove packages'
  'remove:remove packages'
  's:search - search for packages'
  'search:search for packages'
  'u:update - update system and repos'
  'update:update system and repos'
  'U:upgrade - upgrade the system'
  'upgrade:upgrade the system'
  'v:version - show version'
  'version:show version'
  'chroot:enter chroot for repo'
  'depends:show package dependencies'
  'export:export installed packages tarball'
  'fork:fork remote package to local repo'
  'help:show help'
  'link:link package files'
  'maintainer:show package maintainer'
  'manifest:show package manifest'
  'new:create new package skeleton'
  'orphans:list orphan packages'
  'outdated:list outdated packages'
  'owns:show package owning file'
  'preferred:show preferred provider'
  'revdepends:show reverse dependencies'
  'repo-orphans:list repo orphans'
  'size:show package size'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kiss command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (b|build|c|checksum|d|download|i|install|r|remove|s|search|depends|fork|link|maintainer|manifest|owns|preferred|revdepends|size)
        _arguments '*:package:' && ret=0 ;;
      (l|list|outdated) _arguments '*:installed package:' && ret=0 ;;
    esac ;;
esac

return ret
