#compdef RNAplot

# ViennaRNA RNAplot: draw RNA secondary structure diagram
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-t --layout-type)'{-t,--layout-type=}'[layout algorithm]:type:(0 1 2 3 4)' \
  '(-o --output-format)'{-o,--output-format=}'[output format]:fmt:(ps eps svg gml ssv naview)' \
  '--pre=[PostScript code to insert before plot]:code:' \
  '--post=[PostScript code to insert after plot]:code:' \
  '--auto-id[auto-generate sequence ID]' \
  '--id-prefix=[ID prefix]:prefix:' \
  '--mirror[mirror the plot]' \
  '*:RNA sequence/structure file:_files' && ret=0
return ret
