#compdef aubiocut
# Documentation: https://github.com/aubio/aubio/blob/master/doc/aubiocut.txt
# Reference accessed: 2026-05-27
# Verified: upstream doc/aubiocut.txt option list (aubio/aubio)

# aubiocut: slice an audio file at onset or beat times

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-q --quiet)'{-q,--quiet}'[be quiet]' \
  '(-i --input)'{-i+,--input=}'[input audio file]:file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3|m4a)"' \
  '(-r --samplerate)'{-r+,--samplerate=}'[input sampling rate in Hz (0 keeps source rate)]:rate:' \
  '(-B --bufsize)'{-B+,--bufsize=}'[analysis window size]:win:' \
  '(-H --hopsize)'{-H+,--hopsize=}'[hop size in samples]:hop:' \
  '(-O --onset)'{-O+,--onset=}'[onset detection method]:method:(default energy hfc complex phase specdiff kl mkl specflux)' \
  '(-b --beat)'{-b,--beat}'[use beat locations instead of onset locations]' \
  '(-t --onset-threshold)'{-t+,--onset-threshold=}'[onset peak-picking threshold]:thres:' \
  '(-c --cut)'{-c,--cut}'[cut input sound file at detected labels]' \
  '(-o --output)'{-o+,--output=}'[directory for output slices]:dir:_files -/' \
  '--cut-until-nsamples=[extra samples to add at the end of each slice]:n:' \
  '--cut-until-nslices=[extra slices to add at the end of each slice]:n:' \
  '--create-first[always create first slice]' \
  '*:audio file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3|m4a)"' && ret=0

return ret
