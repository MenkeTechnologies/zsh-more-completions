#compdef karmor
# _karmor — KubeArmor CLI utility (kubearmor/kubearmor-client)
# upstream: https://github.com/kubearmor/kubearmor-client
# Subcommands from cmd/*.go on tip.

_karmor() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                install:'install KubeArmor into the cluster'
                uninstall:'uninstall KubeArmor from the cluster'
                probe:'check KubeArmor feature support in this environment'
                log:'stream KubeArmor telemetry/alerts via gRPC'
                policy:'apply or inspect KubeArmor policies'
                profile:'view per-container behavioral profile'
                recommend:'recommend policies for workloads'
                rotate-tls:'rotate KubeArmor relay TLS certificates'
                selfupdate:'update karmor to the latest release'
                sysdump:'collect a cluster support bundle'
                version:'print karmor version'
                vm:'manage non-K8s VMs with KubeArmor'
            )
            _describe -t commands 'karmor command' cmds
            ;;
        args)
            case $words[1] in
                install)
                    _arguments \
                        '(-n --namespace)'{-n,--namespace=}'[install namespace]:ns:' \
                        '(-i --image)'{-i,--image=}'[kubearmor daemonset image]:image:' \
                        '--init-image=[kubearmor init container image]:image:' \
                        '--operator-image=[kubearmor-operator image]:image:' \
                        '--controller-image=[kubearmor-controller image]:image:' \
                        '--relay-image=[kubearmor-relay-server image]:image:' \
                        '(-t --tag)'{-t,--tag=}'[image tag override]:tag:' \
                        '--relay-tag=[relay image tag override]:tag:' \
                        '--controller-tag=[controller image tag override]:tag:' \
                        '--operator-tag=[operator image tag override]:tag:' \
                        '(-a --audit)'{-a,--audit=}'[audit posture contexts]:ctx:' \
                        '(-b --block)'{-b,--block=}'[block posture contexts]:ctx:' \
                        '--host-audit=[host audit posture contexts]:ctx:' \
                        '--host-block=[host block posture contexts]:ctx:' \
                        '--viz=[telemetry visibility]:viz:' \
                        '--host-viz=[host telemetry visibility]:viz:' \
                        '--save[save manifest instead of applying]'
                    ;;
                probe)
                    _arguments \
                        '(-n --namespace)'{-n,--namespace=}'[install namespace]:ns:' \
                        '--full[deploy a probe daemonset for full info]' \
                        '(-f --format)'{-f,--format=}'[output format]:fmt:(text json no-color)' \
                        '--gRPC=[gRPC port]:port:'
                    ;;
            esac
            ;;
    esac
}

_karmor "$@"
