#compdef dub2
# _dub2 — Sönke Ludwig D Language Foundation dub2 CLI command-line frontend wrapping the dub the official package and build manager for the D programming language open-source written in D originally Sönke Ludwig now D Language Foundation creates project skeletons resolves package dependencies downloads and builds packages from registries D Hub init build run test fetch add upgrade remove search list describe convert add-local remove-local list-overrides add-override remove-override clean dustmite generate add-path remove-path lint dub.json dub.sdl Cargo-like vibe-d D-pkg D-Hub registry compiler config arch (Sönke Ludwig D Language Foundation team, D); custom argparse
# upstream: https://dub.pm/

_dub2() {
    local -a sub=(
        'add:Adds dependencies'
        'add-local:Adds a local package'
        'add-override:Adds a package override'
        'add-path:Adds a package search path'
        'build:Build package'
        'build-deep:Build all packages'
        'clean:Clean caches'
        'convert:Converts package recipe'
        'create:Creates a new project'
        'describe:Describe project'
        'dustmite:Apply dustmite'
        'fetch:Fetch package'
        'generate:Generate project files'
        'init:Initialize new project'
        'list:List installed packages'
        'list-overrides:List overrides'
        'lint:Run linter'
        'remove:Remove package'
        'remove-local:Remove a local package'
        'remove-override:Remove a package override'
        'remove-path:Remove a search path'
        'run:Build and run project'
        'search:Search registry'
        'test:Execute tests'
        'upgrade:Upgrade dependencies'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--annotate[annotate]' \
        '--bare[bare]' \
        '--build=+[type]:t:(debug release release-debug release-nobounds unittest profile profile-gc docs ddox cov cov-ctfe unittest-cov syntax)' \
        '-b+[build]:t:(debug release release-debug release-nobounds unittest profile profile-gc docs ddox cov cov-ctfe unittest-cov syntax)' \
        '--build-mode=+[mode]:m:(separate allAtOnce singleFile)' \
        '--config=+[name]:str:' \
        '-c+[config]:str:' \
        '--arch=+[arch]:str:' \
        '-a+[arch]:str:' \
        '--compiler=+[name]:str:' \
        '--debug=+[ident]:str:' \
        '*--debug=+[ident]:str:' \
        '--coverage-format=+[fmt]:str:' \
        '--coverage-output=+[file]:file:_files' \
        '--cache=+[m]:m:(system user local)' \
        '--registry=+[url]:str:' \
        '*--registry=+[url]:str:' \
        '--combined[combined]' \
        '--single[single file]' \
        '--root=+[dir]:dir:_files -/' \
        '--rdmd[use rdmd]' \
        '--force[force rebuild]' \
        '--temp-build[temp build]' \
        '--filter-versions[filter versions]' \
        '--print-builds[print builds]' \
        '--print-configs[print configs]' \
        '--print-platform[print platform]' \
        '--print-upgrades[print upgrades]' \
        '--parallel[parallel build]' \
        '--type=+[t]:t:(executable library)' \
        '-t+[type]:t:(executable library)' \
        '--format=+[fmt]:f:(visuald visualcppvcxproj sublimetext mono-d cmake fish-completions)' \
        '-f+[format]:f:(visuald visualcppvcxproj sublimetext mono-d cmake fish-completions)' \
        '--vquiet[very quiet]' \
        '--vverbose[very verbose]' \
        '--no-test[no test]' \
        '--coverage[coverage]' \
        '--coverage-ctfe[coverage ctfe]' \
        '--syntax-only[syntax only]' \
        '--main-file=+[file]:file:_files' \
        '--exclude=+[pattern]:str:' \
        '*--exclude=+[pattern]:str:' \
        '--testarg=+[arg]:str:' \
        '*--testarg=+[arg]:str:' \
        '--print-format=+[fmt]:f:(json sdl readable)' \
        '--data=+[d]:d:(version-name target-type target-name target-path target-binary-path working-directory libs source-paths import-paths import-files string-import-paths source-files dub-version main-source-file root-package compiler-info)' \
        '*--data=+[d]:d:(version-name target-type target-name target-path target-binary-path working-directory libs source-paths import-paths import-files string-import-paths source-files dub-version main-source-file root-package compiler-info)' \
        '--single-file[single file]' \
        '--vbuild[verbose build]' \
        '--no-build[no build]' \
        '--no-confirm[no confirm]' \
        '--no-deps[no deps]' \
        '--system[system override]' \
        '--user[user override]' \
        '--missing-only[missing only]' \
        '--vcolored-output=+[v]:v:(true false)' \
        '--color=+[c]:c:(auto on off)' \
        '--package=+[name]:str:' \
        '*--package=+[name]:str:' \
        '--recipe=+[file]:file:_files -g "dub.json dub.sdl *.json *.sdl"' \
        '--start-only[start only]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dub subcommand' sub ;;
        args)
            case $words[1] in
                add|remove|search|fetch|upgrade) _arguments '*:package:' ;;
                init|create) _arguments '1:name:' '2:type:(minimal vibe.d deimos)' ;;
                build|run|test|describe|generate|clean|dustmite|lint) _arguments '*:package:' ;;
            esac
            ;;
    esac
}

_dub2 "$@"
