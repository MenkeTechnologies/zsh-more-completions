#compdef pinniped-server
# _pinniped-server — Pinniped combined server entrypoint (multi-call binary; dispatches to pinniped-concierge / pinniped-supervisor / local-user-authenticator based on os.Args[0])
# upstream: https://github.com/vmware-tanzu/pinniped
# Source: cmd/pinniped-server/main.go on tip; symlink to one of the supported names — invoke via that symlink (no subcommand flags accepted directly on the dispatcher).

_pinniped-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_pinniped-server "$@"
