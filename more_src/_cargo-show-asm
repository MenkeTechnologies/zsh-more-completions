#compdef cargo-show-asm cargo-asm
# Documentation: https://github.com/pacak/cargo-show-asm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '(-p --package)'{-p,--package}'[Package to compile]:package:' \
  '--lib[Show asm for the library]' \
  '--bin=[Show asm for a binary]:binary:' \
  '--example=[Show asm for an example]:example:' \
  '--test=[Show asm for a test]:test:' \
  '--bench=[Show asm for a benchmark]:bench:' \
  '--release[Build in release mode]' \
  '--dev[Build in dev profile]' \
  '--profile=[Build with a specific profile]:profile:' \
  '--target=[Target triple]:target:' \
  '--target-cpu=[Target CPU]:cpu:' \
  '--native[Optimize for the compiler host CPU]' \
  '(-F --features)'{-F,--features}'=[Features to enable]:features:' \
  '--all-features[Enable all features]' \
  '--no-default-features[Disable default features]' \
  '--rust[Emit Rust source interleaved]' \
  '--color[Force color output]' \
  '--no-color[Disable color output]' \
  '--asm[Show assembly (default)]' \
  '--disasm[Disassemble binaries/object files]' \
  '--llvm[Show LLVM IR]' \
  '--llvm-input[Show LLVM IR before optimization]' \
  '--mir[Show Rust MIR]' \
  '--wasm[Show WebAssembly]' \
  '--mca[Run llvm-mca analysis]' \
  '--intel[Use Intel syntax]' \
  '--att[Use AT&T syntax]' \
  '--everything[Dump entire file]' \
  '--simplify[Strip non-instruction information]' \
  '--include-constants[Include constant sections]' \
  '--full-name[Use full mangled name]' \
  '--short-name[Use short name]' \
  '--keep-mangled[Keep mangled names]' \
  '(-K --keep-labels)'{-K,--keep-labels}'[Keep labels]' \
  '(-B --keep-blanks)'{-B,--keep-blanks}'[Keep blank lines]' \
  '(-R --reduce-labels)'{-R,--reduce-labels}'[Reduce labels]' \
  '-C+[Codegen flag]:flag:' \
  '-Z+[Unstable cargo flag]:flag:' \
  '(-c --context)'{-c+,--context=}'[Include N surrounding functions]:count:' \
  '--target-dir=[Target directory]:dir:_directories' \
  '--manifest-path=[Path to Cargo.toml]:file:_files' \
  '1:function name or index:' && return 0
