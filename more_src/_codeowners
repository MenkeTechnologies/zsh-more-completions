#compdef codeowners

# Zsh completion for codeowners (GitHub CODEOWNERS file validator/tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'audit:audit CODEOWNERS coverage'
  'generate:generate a CODEOWNERS file'
  'validate:validate CODEOWNERS file syntax'
  'verify:verify code ownership'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --file)'{-f,--file=}'[CODEOWNERS file path]:file:_files' \
  '(-o --owner)'{-o,--owner=}'[filter by owner]:owner:' \
  '--no-color[disable colored output]' \
  '1:command:->command' \
  '*:file:_files' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
esac

return ret
