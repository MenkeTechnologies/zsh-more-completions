#compdef kubectl-prompt
# kubectl-prompt (krew plugin): display cluster and namespace in prompt
# https://github.com/jonmosco/kube-ps1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--symbol=[prompt symbol]:symbol' \
  '--separator=[separator between context and namespace]:separator' \
  '--divider=[divider between symbol and cluster]:divider' \
  '--prefix=[prompt prefix]:prefix' \
  '--suffix=[prompt suffix]:suffix' \
  '--color-context=[context color]:color:(red green yellow blue magenta cyan white)' \
  '--color-namespace=[namespace color]:color:(red green yellow blue magenta cyan white)' \
  '--color-symbol=[symbol color]:color:(red green yellow blue magenta cyan white)'
