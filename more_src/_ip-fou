#compdef ip-fou
# Documentation: https://man.archlinux.org/man/ip-fou.8.en
# ip fou - Foo-over-UDP / GUE receive port configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip fou command' \
      'add[create FOU/GUE receive port]' 'del[delete FOU/GUE receive port]' \
      'show[display configured ports]' \
      'port[UDP port number]' 'gue[enable Generic UDP Encapsulation]' \
      'ipproto[IP protocol number]' 'local[bind to local address]' \
      'peer[peer address]' 'peer_port[peer port]' 'dev[bind to network interface]' && ret=0
    ;;
esac

return ret
