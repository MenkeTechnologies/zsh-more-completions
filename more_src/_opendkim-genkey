#compdef opendkim-genkey
# Documentation: https://man.archlinux.org/search?q=opendkim-genkey
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --append-domain)'{-a,--append-domain}'[append domain to selector]' \
  '(-b --bits)'{-b,--bits}'+[key size]:bits:(1024 2048 4096)' \
  '(-d --domain)'{-d,--domain}'+[signing domain]:domain:' \
  '(-D --directory)'{-D,--directory}'+[output directory]:dir:_files -/' \
  '(-h --hash-algorithms)'{-h,--hash-algorithms}'+[hash algorithms]:hashes:(sha1 sha256)' \
  '(-n --note)'{-n,--note}'+[note in TXT record]:note:' \
  '(-r --restricted)'{-r,--restricted}'[restricted signing]' \
  '(-s --selector)'{-s,--selector}'+[selector]:selector:' \
  '(-S --subdomains)'{-S,--subdomains}'[do not allow subdomain signing]' \
  '(-t --testkey)'{-t,--testkey}'[test key]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0

return ret
