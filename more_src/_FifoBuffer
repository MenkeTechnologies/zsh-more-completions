#compdef FifoBuffer
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/util/FifoBuffer.java
# Picard: provides a large, FIFO buffer between two processes connected by Unix pipes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--BUFFER_SIZE=[size of memory buffer in bytes]:n:' \
  '--IO_SIZE=[bytes to read/write atomically to streams]:n:' \
  '--DEBUG_FREQUENCY=[seconds between debug statistics reports]:n:' \
  '--NAME=[name to use for FIFO in debug statements]:name:' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
