#compdef dust
# Documentation: https://github.com/bootandy/dust
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dust (du + rust, bootandy/dust)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --depth)'{-d+,--depth=}'[max depth]:n:' \
  '(-T --threads)'{-T+,--threads=}'[threads]:n:' \
  '(-n --number-of-lines)'{-n+,--number-of-lines=}'[lines]:n:' \
  '(-X --ignore-directory)*'{-X+,--ignore-directory=}'[ignore dir]:dir:_files -/' \
  '(-I --ignore-all-in-file)'{-I+,--ignore-all-in-file=}'[ignore file]:file:_files' \
  '(-f --filecount)'{-f,--filecount}'[count files]' \
  '(-r --reverse)'{-r,--reverse}'[reverse output]' \
  '(-s --apparent-size)'{-s,--apparent-size}'[apparent size]' \
  '(-b --no-percent-bars)'{-b,--no-percent-bars}'[no bars]' \
  '(-B --bars-on-right)'{-B,--bars-on-right}'[bars on right]' \
  '(-c --no-colors)'{-c,--no-colors}'[no colors]' \
  '(-C --force-colors)'{-C,--force-colors}'[force colors]' \
  '(-x --limit-filesystem)'{-x,--limit-filesystem}'[limit to single fs]' \
  '(-i --invert-filter)*'{-i+,--invert-filter=}'[invert filter regex]:re:' \
  '(-e --filter)*'{-e+,--filter=}'[filter regex]:re:' \
  '(-t --file-types)'{-t,--file-types}'[group by file extension]' \
  '(-w --terminal-width)'{-w+,--terminal-width=}'[terminal width]:n:' \
  '(-P --skip-total)'{-P,--skip-total}'[skip total]' \
  '(-z --min-size)'{-z+,--min-size=}'[min size]:s:' \
  '(-D --only-dir)'{-D,--only-dir}'[only directories]' \
  '(-F --only-file)'{-F,--only-file}'[only files]' \
  '(-S --screen-reader)'{-S,--screen-reader}'[screen-reader friendly]' \
  '(--print-errors)--print-errors[print errors]' \
  '(--mtime)--mtime[modified time]' \
  '(--atime)--atime[accessed time]' \
  '(--ctime)--ctime[changed time]' \
  '(-j --output-json)'{-j,--output-json}'[JSON output]' \
  '(-y --output-format)'{-y+,--output-format=}'[unit]:f:(b k m g t kb mb gb tb)' \
  '(-M --no-bars)'{-M,--no-bars}'[disable bars]' \
  '*: :_files -/' && ret=0

return ret
