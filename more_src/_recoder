#compdef recoder
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/recoder.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS recoder: find restriction sites where silent mutations remove
# (or introduce) cleavage. Used in cloning to remove unwanted sites.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[nucleotide sequence (USA)]:DNA USA:_files' \
  '-enzymes=[comma-separated enzyme list]:list:' \
  '-sshow[display untranslated sequence]' \
  '-tshow[display translated sequence]' \
  '-outfile=[report output file]:file:_files' \
  '-rformat2=[report output format]:format:(embl genbank gff pir swiss dasgff debug listfile dbmotif diffseq draw restrict excel feattable motif nametable regions seqtable simple srs table tagseq)' \
  '*:DNA USA:_files' && ret=0
return ret
