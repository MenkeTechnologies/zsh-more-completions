#compdef recoder
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS recoder: find restriction sites where silent mutations remove
# (or introduce) cleavage. Used in cloning to remove unwanted sites.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence (coding strand)]:DNA USA:_files' \
  '-enzymes=[enzymes to test]:list:' \
  '-table=[genetic code]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '-sshow[show source sequence]' \
  '-tshow[show translation]' \
  '-outfile=[report output file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
