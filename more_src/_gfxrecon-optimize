#compdef gfxrecon-optimize
# Documentation: https://vulkan.lunarg.com/doc/view/latest/linux/capture_tools.html
# gfxrecon-optimize - produce a new optimized GFXReconstruct capture file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '--version[print version information]' \
  '1:input file:_files' \
  '2:output file:_files' && ret=0

return ret
