#compdef sqld

_arguments -s -S \
  '--db-path=[SQLite database file]:file:_files -g "*.db(-.)"' \
  '--jwt-key-file=[Key used to sign auth tokens]:file:_files' \
  '--http-listen=[HTTP API listen address]:addr:' \
  '--grpc-listen=[gRPC listen address]:addr:' \
  '--enable-console[Enable interactive web console]' \
  '--help[Show help]' \
  '*::arguments: _default'
