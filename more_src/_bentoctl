#compdef bentoctl
# _bentoctl — deploy BentoML models to any cloud platform (bentoml/bentoctl)
# upstream: https://github.com/bentoml/bentoctl
# Subcommands from bentoctl/cli/__init__.py + operator_management.py (click).

_bentoctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'init:interactive deployment-config builder'
                'generate:generate deployment artifacts'
                'build:build a deployable container image'
                'apply:apply deployment (terraform apply)'
                'destroy:destroy deployment (terraform destroy)'
                'operator:install/list/update/remove operators'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                init)
                    _arguments \
                        '--do-not-generate[skip generating template files]' \
                        '--save-path=[deployment config save dir]:dir:_files -/'
                    ;;
                generate)
                    _arguments \
                        '(-f --deployment-config-file)'{-f+,--deployment-config-file=}'[deployment config file]:file:_files -g "*.(yml|yaml)"' \
                        '--save-path=[output dir]:dir:_files -/' \
                        '--values-only[generate only values file]'
                    ;;
                apply|destroy)
                    _arguments \
                        '(-f --deployment-config-file)'{-f+,--deployment-config-file=}'[deployment config file]:file:_files -g "*.(yml|yaml)"' \
                        '--auto-approve[skip interactive approval]'
                    ;;
                operator)
                    _arguments \
                        '1:subcommand:(list install remove uninstall update)' \
                        '*::operator name or path:_files'
                    ;;
            esac
            ;;
    esac
}

_bentoctl "$@"
