#compdef nixd

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--lit-test[run in lit-test mode]' \
  '--input-style=[input style]:style:(standard delimited)' \
  '--log=[log level]:level:(error warn info debug verbose)' \
  '--pretty[pretty print JSON output]' \
  '--pch-storage=[PCH storage path]:path:_directories' \
  '--inlay-hints=[enable inlay hints]:bool:(true false)' \
  '--semantic-tokens=[enable semantic tokens]:bool:(true false)' \
  '--workers=[number of worker threads]:count' \
  '*:file:_files -g "*.nix"'
