#compdef nixd
# Documentation: https://github.com/nix-community/nixd
# Reference accessed: 2026-05-17
# Verified: nix-community/nixd README. Public docs only mention
# --inlay-hints; other flags come from underlying LLVM cl::opt
# infrastructure. NIXD_FLAGS env var passes additional args.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --lit-test/--input-style/--log/--pretty/--pch-storage/
# --semantic-tokens/--workers (not documented upstream).

# nixd: Nix language server (LSP over stdio)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--inlay-hints=[enable inlay hints]:bool:(true false)' && ret=0
return ret
