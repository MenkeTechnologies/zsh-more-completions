#compdef icecc-create-env
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/icecc-create-env.1.html
# icecc-create-env - create an Icecream build environment tarball

local ret=1

_arguments -s -S \
  '--gcc[create environment for the given gcc/g++ binaries]' \
  '--clang[create environment for the given clang binary]' \
  '*--addfile=[add an extra file to the environment tarball]:file:_files' \
  '--compression=[tarball compression type]:type:(none gzip bzip2 zstd xz)' \
  '*:compiler binary:_command_names -e' && ret=0

return ret
