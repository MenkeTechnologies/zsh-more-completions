#compdef cargo-samply
# automate profiling Rust code with the samply profiler

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--profile[build with the specified profile]:profile' \
  '(-p --package)'{-p,--package}'[package to profile (in a workspace)]:package' \
  '(-b --bin)'{-b,--bin}'[binary to run]:binary' \
  '(-e --example)'{-e,--example}'[example to run]:example' \
  '--bench[benchmark target to run]:bench' \
  '--test[test target to run]:test' \
  '--bench-flag[flag to use when running the benchmark target]:flag' \
  '--samply-args[arguments to pass to samply]:args' \
  '(-f --features)'{-f,--features}'[build features to enable]:features' \
  '--no-default-features[disable default features]' \
  '(-v --verbose)'{-v,--verbose}'[print extra output to help debug problems]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all output except errors]' \
  '(-n --no-samply)'{-n,--no-samply}'[disable the automatic samply start]' \
  '--dry-run[print the build and run commands without executing]' \
  '--no-profile-inject[do not modify Cargo.toml to add the samply profile]' \
  '--list-targets[list all available targets and exit]' \
  '*::trailing arguments:_default' && ret=0

return ret
