#compdef nxc
# Documentation: https://www.netexec.wiki/getting-started/selecting-and-using-a-protocol
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a protocols

protocols=(
  'smb:Server Message Block protocol'
  'ssh:Secure Shell protocol'
  'ldap:Lightweight Directory Access Protocol'
  'ftp:File Transfer Protocol'
  'wmi:Windows Management Instrumentation'
  'winrm:Windows Remote Management'
  'rdp:Remote Desktop Protocol'
  'vnc:Virtual Network Computing'
  'mssql:Microsoft SQL Server'
  'nfs:Network File System'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-t+[concurrent threads]:threads (default 100):' \
  '--timeout=[max timeout in seconds]:seconds:' \
  '--jitter=[random delay between connections]:interval:' \
  '--no-progress[disable progress bar]' \
  '--verbose[enable verbose output]' \
  '--debug[enable debug information]' \
  '--log=[log file]:file:_files' \
  '1: :->proto' \
  '*::arg:->args' && ret=0

case $state in
  (proto)
    _describe -t protos 'nxc protocol' protocols && ret=0 ;;
  (args)
    _arguments \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-u --user)'{-u+,--user=}'[username or user file]:user/file:_files' \
      '(-p --pass)'{-p+,--pass=}'[password or password file]:pass/file:_files' \
      '(-H --hash)'{-H+,--hash=}'[NTLM hash or hash file]:hash/file:_files' \
      '(-d --domain)'{-d+,--domain=}'[domain to authenticate to]:domain:' \
      '-id+[saved credential id]:id:' \
      '-k[use kerberos authentication]' \
      '--kerberos[use kerberos authentication]' \
      '--aesKey=[AES key for kerberos]:key:' \
      '--kdcHost=[KDC host]:host:_hosts' \
      '--use-kcache[use ccache file]' \
      '--no-bruteforce[stop on first success per target]' \
      '--continue-on-success[continue after first valid credential]' \
      '--local-auth[authenticate locally to each target]' \
      '--gen-relay-list=[generate SMB relay list]:file:_files' \
      '--port=[target port]:port:' \
      '*::target:_files' && ret=0 ;;
esac

return ret
