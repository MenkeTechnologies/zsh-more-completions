#compdef legdur
# Documentation: https://git.cyplo.dev/cyplo/legdur
# legdur - detect changes to your directories over time via file hashes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--compare-dirs[compare two directories without database files]:left:_files -/:right:_files -/' \
  '*:directory:_files -/' && ret=0

return ret
