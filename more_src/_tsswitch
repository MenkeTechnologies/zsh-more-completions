#compdef tsswitch
# _tsswitch — TSDuck tsswitch transport-stream input switcher with multi-input failover/round-robin/priority modes feeding a single output plugin (tsduck team, C++); custom argparse
# upstream: https://github.com/tsduck/tsduck

_tsswitch() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-f[fast switch]' \
        '--fast-switch[fast switch]' \
        '-d[delayed switch]' \
        '--delayed-switch[delayed switch]' \
        '-c+[cycle]:n:' \
        '--cycle=+[N]:n:' \
        '-t+[terminate after N inputs]:n:' \
        '--terminate=+[N]:n:' \
        '--monitor[monitor]' \
        '--no-reuse-port[no reuse port]' \
        '--buffer-packets=+[N]:n:' \
        '--max-input-packets=+[N]:n:' \
        '--max-output-packets=+[N]:n:' \
        '--priority-list=+[csv]:str:' \
        '--first-input=+[N]:n:' \
        '--primary-input=+[N]:n:' \
        '--receive-timeout=+[ms]:n:' \
        '--remote=+[host:port]:str:' \
        '--allow=+[host]:h:_hosts' \
        '-I+[input plugin]:p:(file null udp ip http https rist srt dektec dvb fork hides)' \
        '--input=+[input plugin]:p:(file null udp ip http https rist srt dektec dvb fork hides)' \
        '-O+[output plugin]:p:(file null udp ip http https rist srt dektec hides fork)' \
        '--output=+[output plugin]:p:(file null udp ip http https rist srt dektec hides fork)' \
        '*:input ts file:_files -g "*.ts *.m2ts *.mpeg *.mpg"'
}

_tsswitch "$@"
