#compdef anew-cli anew
# _anew-cli — TomNomNom Tom Hudson anew-cli CLI command-line frontend wrapping the anew tool for adding new lines to files skipping duplicates open-source written in Go reads lines from stdin compares against a given file and prints only the new lines optionally appending them to the file dryrun trim case-insensitive quiet rewrite (TomNomNom team, Go); flag
# upstream: https://github.com/tomnomnom/anew

_anew-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[dry run, do not append]' \
        '-q[quiet, do not print new lines]' \
        '-t[trim white space]' \
        '-r[rewrite existing file]' \
        '1:file:_files'
}

_anew-cli "$@"
