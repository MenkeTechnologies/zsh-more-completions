#compdef ntpdate-debian

# ntpdate-debian: Debian wrapper around ntpdate using /etc/default/ntpdate
local curcontext="$curcontext" ret=1
_arguments -C \
  '-4[force IPv4]' \
  '-6[force IPv6]' \
  '-a[require authentication]:keyid:' \
  '-B[force slewing instead of stepping]' \
  '-b[force stepping instead of slewing]' \
  '-d[debug - do not actually adjust time]' \
  '-e[adjust millisecond offset]:authdelay:' \
  '-k[keyfile]:file:_files' \
  '-o[NTP protocol version]:n:(1 2 3 4)' \
  '-p[number of samples per server]:n:' \
  '-q[query only - do not set clock]' \
  '-s[use syslog instead of stderr]' \
  '-t[max time to wait per server]:sec:' \
  '-u[unprivileged source port]' \
  '-v[verbose]' \
  '*:NTP server:_hosts' && ret=0
return ret
