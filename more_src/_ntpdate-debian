#compdef ntpdate-debian
# Documentation: https://linux.die.net/man/8/ntpdate
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# ntpdate-debian: distro wrapper around ntpdate (one-shot NTP time sync)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-4[force IPv4 DNS resolution]' \
  '-6[force IPv6 DNS resolution]' \
  '-a[authentication key identifier]:keyid:' \
  '-B[always slew time via adjtime]' \
  '-b[force step via settimeofday]' \
  '-d[debug mode (no clock change)]' \
  '-e[authentication processing delay]:seconds:' \
  '-k[authentication key file]:file:_files' \
  '-o[NTP version for outgoing packets]:version:(1 2 3 4)' \
  '-p[samples per server (1-8)]:n:' \
  '-q[query only, do not set]' \
  '-s[divert log output to syslog]' \
  '-t[max time waiting for server response]:seconds:' \
  '-u[use unprivileged port for outgoing packets]' \
  '-v[be verbose]' \
  '*:NTP server:_hosts' && ret=0
return ret
