#compdef zet

# https://github.com/yarrow/zet — clap (src/args.rs)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--count-files[count occurrences as number of files a line appears in]' \
  '--count-lines[count total line occurrences across input]' \
  '--count-none[disable count output]' \
  '(-c --count)'{-c,--count}'[count lines; with --files counts files]' \
  '--files[for single/multiple ops treat per-file uniqueness]' \
  '--file[alias of --files]' \
  '--lines[explicitly use line-based mode (default)]' \
  '--line[alias of --lines]' \
  '--color[when to colorize]:mode:(auto always never)' \
  '1:operation:(intersect union diff single multiple help)' \
  '*:input file:_files'
