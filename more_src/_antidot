#compdef antidot
# Documentation: https://github.com/doron-cohen/antidot
# antidot - clean up your $HOME from those pesky dotfiles

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[output verbosity]' \
  '(-r --rules)'{-r,--rules}'=[rules file path]:file:_files' \
  '1:command:(clean init update help)' \
  '*::arg:->args' && ret=0

return ret
