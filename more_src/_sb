#compdef sb
# _sb — SilverBullet markdown notebook CLI (silverbulletmd/silverbullet)
# upstream: https://github.com/silverbulletmd/silverbullet
# Subcommands + flags from cmd/cli/main.go + cli/{resolve,output}.go (cobra).

_sb() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-s --space)'{-s+,--space=}'[space to use]:space:' \
        '--url=[direct URL (skip space lookup)]:url:' \
        '--token=[direct auth token]:token:' \
        '(-t --timeout)'{-t+,--timeout=}'[request timeout in seconds (default 30)]:seconds:' \
        '--json[force JSON output (shortcut for -o json)]' \
        '--text[force human-readable output (shortcut for -o text)]' \
        '(-o --output)'{-o+,--output=}'[output format]:format:(auto text table json jsonl yaml)' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_sb_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                space)
                    _arguments '1:space subcommand:(add list remove)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_sb_commands] )) ||
_sb_commands() {
    local -a commands
    commands=(
        'space:manage space connections (add / list / remove)'
        'eval:evaluate an expression against the space'
        'lua:evaluate a Lua snippet (hidden alias of eval)'
        'script:run a Space Script by name'
        'lua-script:run a Lua script (hidden alias of script)'
        'query:run a Space Query'
        'get:read a page or attachment by name'
        'describe:print available data types and query syntax'
        'logs:tail Space Lua logs'
        'screenshot:capture a screenshot of a page'
        'repl:open an interactive REPL'
        'version:print silverbullet version'
        'upgrade:upgrade silverbullet to the latest release'
        'upgrade-edge:upgrade silverbullet to the latest edge build'
    )
    _describe -t commands 'sb command' commands
}

_sb "$@"
