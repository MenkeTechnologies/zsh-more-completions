#compdef lircrcd
# Documentation: https://manpages.debian.org/bookworm/lirc/lircrcd.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm lircrcd(8) manpage OPTIONS section.

# lircrcd: LIRC config-file sharing daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --permission)'{-p,--permission=}'[Unix socket permission (octal)]:mode:' \
  '(-o --output)'{-o,--output=}'[Unix domain socket to create]:socket:_files' \
  '1:config file:_files' && ret=0
return ret
