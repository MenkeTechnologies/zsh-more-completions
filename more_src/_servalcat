#compdef servalcat
# Documentation: https://servalcat.readthedocs.io/en/latest/commands.html
# Servalcat: structure refinement and validation for crystallography and SPA

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(refine_spa refine_spa_norefmac refine_xtal refine_xtal_norefmac fofc trim util)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $line[1] in
      util)
        _arguments \
          '1:subcommand:(symmodel map_peaks expand)' \
          '*:file:_files' && ret=0
        ;;
      refine_spa|refine_spa_norefmac)
        _arguments \
          '--halfmaps[input half maps]:file:_files' \
          '--map[single map input]:file:_files' \
          '--model[input atomic model]:file:_files' \
          '(-d --resolution)'{-d+,--resolution=}'[resolution]:resolution:' \
          '--pixel_size[override pixel size (A)]:size:' \
          '(-m --mask)'{-m+,--mask=}'[mask file]:file:_files' \
          '(-r --mask_radius)'{-r+,--mask_radius=}'[mask radius]:radius:' \
          '(-o --output_prefix)'{-o+,--output_prefix=}'[output prefix]:prefix:' \
          '--monlib[monomer library path]:dir:_files -/' \
          '--ligand[ligand cif]:file:_files' \
          '--source[scattering source]:source:(electron xray neutron)' \
          '*:file:_files' && ret=0
        ;;
      *)
        _arguments \
          '--hklin[input reflection data]:file:_files' \
          '--model[input atomic model]:file:_files' \
          '(-d --resolution)'{-d+,--resolution=}'[resolution]:resolution:' \
          '(-o --output_prefix)'{-o+,--output_prefix=}'[output prefix]:prefix:' \
          '--monlib[monomer library path]:dir:_files -/' \
          '--ligand[ligand cif]:file:_files' \
          '--source[scattering source]:source:(electron xray neutron)' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
