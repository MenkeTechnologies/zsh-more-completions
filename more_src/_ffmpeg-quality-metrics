#compdef ffmpeg-quality-metrics
# Documentation: https://github.com/slhck/ffmpeg-quality-metrics
# ffmpeg-quality-metrics — calculate VMAF/PSNR/SSIM/VIF metrics between two videos

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-n --dry-run)'{-n,--dry-run}'[do not run commands, just show what would be done]' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '(-p --progress)'{-p,--progress}'[show a progress bar]' \
  '(-k --keep-tmp)'{-k,--keep-tmp}'[keep temporary files for debugging]' \
  '--tmp-dir=[directory to store temporary files in]:dir:_files -/' \
  '(-m --metrics)'{-m,--metrics}'[metrics to calculate]:metrics' \
  '(-s --scaling-algorithm)'{-s,--scaling-algorithm}'[scaling method]:algo:(bicubic bilinear lanczos spline neighbor)' \
  '(-r --framerate)'{-r,--framerate}'[force an input framerate]:fps' \
  '--dist-delay=[delay distorted video against reference in seconds]:seconds' \
  '(-t --threads)'{-t,--threads}'[number of threads to use]:threads' \
  '--num-frames=[number of frames to analyze]:frames' \
  '--start-offset=[seek to this position before analyzing]:offset' \
  '--ffmpeg-path=[path to ffmpeg executable]:path:_files' \
  '(-o --output-file)'{-o,--output-file}'[output file for the metrics]:file:_files' \
  '(-of --output-format)'{-of,--output-format}'[output format]:format:(json csv)' \
  '--vmaf-model-path=[path to custom VMAF model file]:file:_files' \
  '--vmaf-model-params=[params to pass to the VMAF model]:params' \
  '--vmaf-threads=[value of libvmaf n_threads option]:threads' \
  '--vmaf-subsample=[value of libvmaf n_subsample option]:n' \
  '--vmaf-features=[features to enable]:features' \
  '--gui[launch interactive dashboard]' \
  '--gui-host=[dashboard host address]:host' \
  '--gui-port=[dashboard port]:port' \
  '*:file:_files' && ret=0

return ret
