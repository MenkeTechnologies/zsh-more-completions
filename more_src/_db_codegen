#compdef db_codegen
# Documentation: https://man.archlinux.org/search?q=db_codegen
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-V[print version]' \
  '-v[verbose]' \
  '-a+[language code (c)]:lang:(c)' \
  '-i+[input file]:file:_files' \
  '-o+[output file]:file:_files' && ret=0

return ret
