#compdef pngtogd2
# Documentation: https://manpages.debian.org/bookworm/libgd-tools/pngtogd2.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input PNG file:_files -g "*.png"' \
  '2:output GD2 file:_files -g "*.gd2"' \
  '3:chunk size:' \
  '4:format (1=raw, 2=compressed):(1 2)' && ret=0

return ret
