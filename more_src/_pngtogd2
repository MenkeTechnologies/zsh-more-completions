#compdef pngtogd2
# Documentation: https://man.archlinux.org/search?q=pngtogd2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input PNG file:_files -g "*.png"' \
  '2:output GD2 file:_files -g "*.gd2"' \
  '3:chunk size:' \
  '4:format (1=raw, 2=compressed):(1 2)' && ret=0

return ret
