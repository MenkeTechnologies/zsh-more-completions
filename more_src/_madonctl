#compdef madonctl
# Documentation: https://man.archlinux.org/search?q=madonctl
# Reference accessed: 2026-05-16

_arguments -s -S \
  '--config=[config file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-i --instance)'{-i,--instance}'=[Mastodon instance URL]:url:_urls' \
  '(-L --login)'{-L,--login}'=[username]:user:' \
  '(-P --password)'{-P,--password}'=[password]:pass:' \
  '(-t --token)'{-t,--token}'=[access token]:token:' \
  '(-o --output)'{-o,--output}'=[output format]:format:(plain json yaml template theme)' \
  '--template=[Go template when output=template]:template:' \
  '--template-file=[Go template file]:file:_files' \
  '--theme=[theme when output=theme]:theme:' \
  '--color=[color for template output]:mode:(auto on off)' \
  '1:command:(account accounts completion config domain-blocks emojis instance lists media oauth2 search status stream suggestions timeline toot post pouet)' \
  '*::arguments: _default'
