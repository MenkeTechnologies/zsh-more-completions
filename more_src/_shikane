#compdef shikane
# _shikane — wlroots dynamic display configurator daemon (hw0lff/shikane)
# upstream: https://github.com/hw0lff/shikane
# Flags from src/daemon.rs (clap).

_shikane() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '(-c --config)'{-c+,--config=}'[path to config file]:file:_files -g "*.toml"'
        '(-o --oneshot)'{-o,--oneshot}'[exit after applying a profile (or after no match)]'
        '(-s --socket)'{-s+,--socket=}'[IPC socket path]:file:_files'
        '(-T --timeout)'{-T+,--timeout=}'[milliseconds to wait before processing changes]:ms:'
    )
    _arguments -s $args
}

_shikane "$@"
