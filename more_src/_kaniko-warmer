#compdef kaniko-warmer
# Documentation: source-direct extraction from upstream
# GoogleContainerTools/kaniko cmd/warmer/cmd/root.go cobra
# `RootCmd.PersistentFlags().<TypeVar>(...)` declarations.
# Reference accessed: 2026-05-30 via gh api.
# Google kaniko-warmer R140b — cache-warmer sister binary to the
# main `kaniko` executor (already covered in the corpus). Pre-pulls
# image layers from a registry into a local cache directory so the
# subsequent `kaniko` build can find them without going back to the
# registry — useful for CI environments where each build runs in a
# fresh container but shares a persistent cache volume.

_arguments -s -S \
  '(-v --verbosity)'{-v+,--verbosity=}'[log level]:level:(trace debug info warn error fatal panic)' \
  '--log-format=[log output format]:format:(text color json)' \
  '--log-timestamp=[include timestamp in log output]:bool:(true false)' \
  '*'{-i+,--image=}'[image to cache (repeatable for multiple images)]:image:' \
  '(-c --cache-dir)'{-c+,--cache-dir=}'[cache directory (default /cache)]:dir:_directories' \
  '(-f --force)'{-f,--force}'[force cache overwriting]' \
  '--cache-ttl=[cache TTL (Go duration string; default 336h=2weeks)]:duration:' \
  '--insecure-pull[pull from insecure registry using plain HTTP]' \
  '--skip-tls-verify-pull[pull from registry ignoring TLS verify]' \
  '*--insecure-registry=[insecure registry using plain HTTP (repeatable)]:registry:' \
  '*--skip-tls-verify-registry=[registry that ignores TLS verify on pull (repeatable)]:registry:' \
  '*--registry-certificate=[TLS server cert per registry (URL=PATH; repeatable)]:URL=PATH:' \
  '*--registry-client-cert=[mTLS client cert per registry (URL=PATH,KEYPATH; repeatable)]:URL=CERTPATH,KEYPATH:' \
  '*--registry-map=[registry-mirror remap (original.registry=new.registry; repeatable)]:original=new:' \
  '*--registry-mirror=[registry mirror as pull-through cache (repeatable)]:mirror:' \
  '--skip-default-registry-fallback[do NOT fall back to docker.io if all mirrors miss]' \
  '--customPlatform=[build platform override (e.g. linux/amd64)]:platform:' \
  '(-d --dockerfile)'{-d+,--dockerfile=}'[Dockerfile path; warm cache for each stage'\''s base image]:file:_files' \
  '*--build-arg=[Dockerfile build-arg for dynamic base-image replacement (NAME=VALUE; repeatable)]:NAME=VALUE:'
