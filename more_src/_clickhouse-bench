#compdef clickhouse-bench clickhouse-benchmark
# Documentation: https://clickhouse.com/docs/en/operations/utilities/clickhouse-benchmark
# Reference accessed: 2026-05-16
# Verified: upstream ClickHouse docs. Real binary name is
# `clickhouse-benchmark`; `clickhouse-bench` is a common alias.
# Removed from prior file: fabricated -h/--help/-V/--version generic flags
# and bogus man.archlinux.org search URL.

# clickhouse-benchmark: ClickHouse query benchmarking tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--query=[query to execute]:query:' \
  '--query_id=[query id]:id:' \
  '--query_id_prefix=[query id prefix]:prefix:' \
  '(-c --concurrency)'{-c+,--concurrency=}'[simultaneous queries (default 1)]:n:' \
  '(-C --max_concurrency)'{-C+,--max_concurrency=}'[max concurrency]:n:' \
  '(-d --delay)'{-d+,--delay=}'[intermediate report interval seconds (default 1)]:seconds:' \
  '(-i --iterations)'{-i+,--iterations=}'[total queries (0 = forever)]:n:' \
  '(-r --randomize)'{-r,--randomize}'[randomize query order]' \
  '(-t --timelimit)'{-t+,--timelimit=}'[time limit seconds]:seconds:' \
  '(-h --host)'{-h+,--host=}'[server hostname (default localhost)]:host:_hosts' \
  '--port=[server port (default 9000)]:port:' \
  '(-s --secure)'{-s,--secure}'[use secure connection]' \
  '--reconnect=[reconnect policy]:n:' \
  '--user=[username (default "default")]:user:_users' \
  '--password=[password]:password:' \
  '--database=[database]:database:' \
  '--precise[precise query duration]' \
  '--cumulative[print cumulative report]' \
  '--client-side-time[use client-side time measurement]' \
  '--stacktrace[print server stack traces]' \
  '--stage=[query stage]:stage:(complete fetch_columns with_mergeable_state)' \
  '--confidence=[t-test confidence level 0-5 (default 5)]:level:(0 1 2 3 4 5)' \
  '--roundrobin[distribute queries round-robin]' \
  '--max-consecutive-errors=[max consecutive errors]:n:' \
  '(--continue_on_errors)--ignore-error[continue on errors]' \
  '(--ignore-error)--continue_on_errors[continue on errors]' \
  '--proto-caps[protocol capabilities]:caps:' \
  '--verbose[verbose output]' \
  '*:setting:' && ret=0
return ret
