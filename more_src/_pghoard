#compdef pghoard pghoard_archive_cleanup pghoard_archive_sync pghoard_create_keys pghoard_postgres_command pghoard_restore

local curcontext="$curcontext" ret=1

case $service in
  (pghoard)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(--short-log)--short-log[short log format]' \
      '(--config)--config=+[config file]:file:_files -g "*.json"' && ret=0 ;;
  (pghoard_restore)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(--target-dir)--target-dir=+[target directory]:dir:_files -/' \
      '(--recovery-target-action)--recovery-target-action=+[action]:action:(pause promote shutdown)' \
      '(--recovery-target-name)--recovery-target-name=+[name]:name:' \
      '(--recovery-target-time)--recovery-target-time=+[time]:time:' \
      '(--recovery-target-xid)--recovery-target-xid=+[xid]:xid:' \
      '(--restore-to-master)--restore-to-master[restore as primary]' \
      '(--target-time)--target-time=+[target time]:time:' \
      '(--overwrite)--overwrite[overwrite existing data]' \
      '(--site)--site=+[site name]:name:' \
      '(--debug)--debug[debug mode]' \
      '(--status-output-file)--status-output-file=+[status output file]:file:_files' \
      '(--preserve-until)--preserve-until=+[preserve until]:time:' && ret=0 ;;
  (pghoard_archive_cleanup|pghoard_archive_sync)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(--config)--config=+[config file]:file:_files' \
      '(--site)--site=+[site name]:name:' && ret=0 ;;
  (pghoard_create_keys)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(--key-id)--key-id=+[key id]:id:' \
      '(--config)--config=+[config file]:file:_files' \
      '(--site)--site=+[site name]:name:' && ret=0 ;;
  (pghoard_postgres_command)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '--config=+[config file]:file:_files' \
      '--mode=+[mode]:mode:(archive restore)' \
      '--site=+[site name]:name:' \
      '--xlog=+[xlog name]:name:' \
      '--output=+[output file]:file:_files' && ret=0 ;;
esac

return ret
