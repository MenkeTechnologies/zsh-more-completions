#compdef sumigpspi
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/migration_inversion/sumigpspi.c
# Gazdag's phase-shift plus interpolation depth migration

local ret=1

_arguments -s -S \
  'vfile=[vfile]:vfile:' \
  'nz=[nz]:nz:' \
  'dz=[dz]:dz:' \
  'dt=[dt]:dt:' \
  'dx=[dx]:dx:' \
  'tmpdir=[tmpdir]:tmpdir:' \
  '*:file:_files' && ret=0

return ret
