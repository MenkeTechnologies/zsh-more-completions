#compdef headlamp
# _headlamp — Headlamp Kubernetes web UI backend
# upstream: https://github.com/kubernetes-sigs/headlamp
# Flags from backend/pkg/config/config.go addGeneralFlags/addOIDCFlags/addTLSFlags/addProxyAuthFlags/addTelemetryFlags on tip.

_headlamp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--in-cluster[run in-cluster mode]' \
        '--in-cluster-context-name=[name for the in-cluster Kubernetes context]:name:' \
        '--dev[allow connections from other origins]' \
        '--cache-enabled[enable K8s cache in backend]' \
        '--no-browser[do not auto-open browser for embedded frontend]' \
        '--insecure-ssl[ignore all server SSL certificates]' \
        '--log-level=[log verbosity]:level:(debug info warn error)' \
        '--enable-dynamic-clusters[enable frontend-stored dynamic clusters]' \
        '--allow-kubeconfig-changes[allow changes to known kubeconfigs]' \
        '--watch-plugins-changes=[reload plugins on change]:bool:(true false)' \
        '--kubeconfig=[absolute path to kubeconfig]:file:_files' \
        '--skipped-kube-contexts=[contexts to ignore in kubeconfig]:csv:' \
        '--html-static-dir=[static HTML directory to serve]:dir:_files -/' \
        '--plugins-dir=[plugins directory]:dir:_files -/' \
        '--user-plugins-dir=[user-installed plugins directory]:dir:_files -/' \
        '--base-url=[base URL path (e.g. /headlamp)]:path:' \
        '--session-ttl=[session lifetime (s)]:s:' \
        '--pod-debug-image=[default debug-container image]:image:' \
        '--listen-addr=[bind address]:host:' \
        '--port=[listen port]:port:' \
        '--proxy-urls=[allow proxy requests to these URLs]:csv:' \
        '--enable-helm[enable Helm operations]' \
        '--enable-cluster-inventory[enable alpha ClusterProfile discovery]' \
        '--cluster-inventory-provider-file=[ClusterProfile providers JSON file]:file:_files' \
        '--cluster-inventory-label-selector=[ClusterProfile label selector]:selector:' \
        '--cluster-inventory-root-reconcile-interval=[ClusterProfile reconcile interval]:dur:' \
        '--cluster-inventory-no-crd-cache-ttl=[no-CRD cache TTL]:dur:' \
        '--default-light-theme=[default light-mode theme]:name:' \
        '--default-dark-theme=[default dark-mode theme]:name:' \
        '--force-theme=[force a specific theme]:name:' \
        '--unsafe-use-service-account-token[UNSAFE: in-cluster shared SA token]' \
        '--service-account-token-path=[path to service account token]:file:_files' \
        '--oidc-client-id=[OIDC client ID]:id:' \
        '--oidc-client-secret=[OIDC client secret]:secret:' \
        '--oidc-validator-client-id=[OIDC validator client ID override]:id:' \
        '--oidc-idp-issuer-url=[OIDC issuer URL]:url:_urls' \
        '--oidc-callback-url=[OIDC callback URL]:url:_urls' \
        '--oidc-validator-idp-issuer-url=[OIDC validator issuer URL override]:url:_urls' \
        '--oidc-scopes=[OIDC scopes (csv)]:csv:' \
        '--oidc-skip-tls-verify[skip OIDC TLS verification]' \
        '--oidc-ca-file=[OIDC CA file]:file:_files' \
        '--oidc-use-access-token[pass access_token instead of id_token]' \
        '--oidc-use-cookie[force OIDC cookie usage even out-of-cluster]' \
        '--oidc-use-pkce[use PKCE in OIDC flow]' \
        '--me-username-path=[JMESPath for username from JWT]:expr:' \
        '--me-email-path=[JMESPath for email from JWT]:expr:' \
        '--me-groups-path=[JMESPath for groups from JWT]:expr:' \
        '--me-user-info-url=[URL to fetch additional user info]:url:_urls' \
        '--tls-cert-path=[TLS cert file]:file:_files' \
        '--tls-key-path=[TLS key file]:file:_files' \
        '--proxy-auth[enable identity-aware proxy bypass]' \
        '--proxy-auth-username-header=[proxy username header]:header:' \
        '--proxy-auth-group-header=[proxy groups header]:header:' \
        '--proxy-auth-email-header=[proxy email header]:header:' \
        '--proxy-auth-token-header=[proxy Id token header]:header:' \
        '--service-name=[telemetry service name]:name:' \
        '--service-version=[telemetry service version]:ver:' \
        '--tracing-enabled[enable distributed tracing]' \
        '--metrics-enabled[enable metrics collection]' \
        '--otlp-endpoint=[OTLP collector endpoint]:host\:port:' \
        '--use-otlp-http[use HTTP instead of gRPC for OTLP export]' \
        '--stdout-trace-enabled[emit traces to stdout]' \
        '--sampling-rate=[trace sampling rate]:f:'
}

_headlamp "$@"
