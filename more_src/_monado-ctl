#compdef monado-ctl
# _monado-ctl — control utility for the Monado OpenXR runtime (monado/monado)
# upstream: https://gitlab.freedesktop.org/monado/monado
# Flags from src/xrt/targets/ctl/main.c (getopt_long).

_monado-ctl() {
    _arguments \
        '-p+[set primary application by client id]:id:' \
        '-f+[set focused application by client id]:id:' \
        '-i+[toggle io activity for client id]:id:' \
        '-c[recenter the OpenXR view]' \
        '--device=[target device by index]:device:' \
        '--get-brightness[get brightness for target device]' \
        '--set-brightness=[set brightness (0-100) for target device]:level:'
}

_monado-ctl "$@"
