#compdef stac-validator stac_validator
# Documentation: https://github.com/stac-utils/stac-validator
# Validate STAC objects against the STAC JSON schemas

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--core[validate core STAC object only, without extensions]' \
  '--extensions[validate extensions only]' \
  '--links[additionally validate links (default mode only)]' \
  '--assets[additionally validate assets (default mode only)]' \
  '(-c --custom)'{-c,--custom}'=[validate against a custom schema (local or remote)]:schema' \
  '(-sc --schema-config)'{-sc,--schema-config}'=[validate using a custom schema config file]:config:_files' \
  '*'{-s,--schema-map}'=[replace schema path with local schema path]:schema schema' \
  '(-r --recursive)'{-r,--recursive}'[recursively validate all related STAC objects]' \
  '(-m --max-depth)'{-m,--max-depth}'=[maximum recursion depth]:depth' \
  '(-t --trace-recursion)'{-t,--trace-recursion}'[verbose output for recursive mode]' \
  '--collections[validate /collections response]' \
  '--item-collection[validate item collection response]' \
  '--pydantic[validate using stac-pydantic models]' \
  '--verbose[enable verbose output]' \
  '--no_output[do not print output to console]' \
  '--log_file=[save full recursive output to log file]:file:_files' \
  '--schema-cache-size=[schema cache size]:size' \
  '*--header=[HTTP header to include]:header value' \
  '--no-assets-urls[do not open href links when validating assets]' \
  '(-p --pages)'{-p,--pages}'=[max pages for item-collection validation]:pages' \
  '*:stac object:_files' && ret=0

return ret
