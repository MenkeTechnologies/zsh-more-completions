#compdef check_pgbackrest
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/check_pgbackrest.1.html
# pgBackRest backup check plugin for Nagios

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help documentation]' \
  '(-V --version)'{-V,--version}'[display version information]' \
  '(-s --service)'{-s,--service}'=[Nagios service to run]:service' \
  '(-S --stanza)'{-S,--stanza}'=[stanza to check]:stanza' \
  '--repo=[repository index to operate on]:index' \
  '(-O --output)'{-O,--output}'=[output format]:format:(human json nagios nagios_strict prtg)' \
  '(-C --command)'{-C,--command}'=[pgBackRest executable file path]:file:_files' \
  '(-c --config)'{-c,--config}'=[pgBackRest configuration file]:file:_files' \
  '(-P --prefix)'{-P,--prefix}'=[prefix command for executing pgBackRest]:prefix' \
  '(-l --list)'{-l,--list}'[list available services]' \
  '--debug[enable debug message printing]' \
  '--retention-full=[max number of full backups for retention service]:num' \
  '--retention-diff=[max number of differential backups]:num' \
  '--retention-incr=[max number of incremental backups]:num' \
  '--retention-age=[max age of the latest backup]:age' \
  '--retention-age-to-full=[max age relative to the latest full backup]:age' \
  '--retention-age-to-oldest=[max age of the oldest backup]:age' \
  '--wal-segsize=[WAL segment size for archives service]:size' \
  '--ignore-archived-before=[ignore archived WALs before this time]:time' \
  '--ignore-archived-after=[ignore archived WALs after this time]:time' \
  '--latest-archive-age-alert=[alert threshold for latest archive age]:age' \
  '--extended-check[perform an extended archive check]' \
  '--max-archives-check-number=[max number of archives to check]:num' \
  '--list-archives[list archives during the check]' \
  '--list-boundaries[list archive boundaries during the check]' \
  '--target-version=[target version for check_pgb_version service]:version' && ret=0

return ret
