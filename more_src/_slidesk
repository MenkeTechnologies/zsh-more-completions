#compdef slidesk
# Documentation: https://slidesk.github.io/slidesk-doc/docs/usage/intro/
# SliDesk markdown presentation engine

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --domain)'{-d,--domain}'=[domain]:domain:' \
  '(-p --port)'{-p,--port}'=[port]:port:' \
  '(-s --save)'{-s,--save}'=[save the presentation]:path:_files' \
  '(-n --notes)'{-n,--notes}'=[open with speaker notes]:slug:' \
  '(-t --timers)'{-t,--timers}'[add timers on notes view]' \
  '(-a --transition)'{-a,--transition}'=[transition timer]:ms:' \
  '(-w --watch)'{-w,--watch}'[watch file modifications]' \
  '(-g --hidden)'{-g,--hidden}'[remove help information]' \
  '(-c --conf)'{-c,--conf}'=[use a specific .env file]:name:' \
  '(-o --open)'{-o,--open}'[open a browser]' \
  '(-x --terminal)'{-x,--terminal}'[present in a terminal window]' \
  '1:command:(create)' \
  '*::talk:_files -/' && ret=0

return ret
