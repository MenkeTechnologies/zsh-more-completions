#compdef policyd-spf policyd-spf-perl
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/policyd-spf.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. The python policyd-spf
# binary documents only -h (usage) plus an optional positional config
# file path. Removed from prior file: fabricated -v/--version,
# --debug, --file, --test long options.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show usage]' \
  '*:config file:_files' && ret=0

return ret
