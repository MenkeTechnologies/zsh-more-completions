#compdef policyd-spf policyd-spf-perl

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-f --file)'{-f,--file}'+[config file]:file:_files' \
  '(-t --test)'{-t,--test}'[test mode]' && ret=0

return ret
