# Amiberry: Amiga emulator optimized for ARM (Pi-focused)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show usage]' \
  '-f[load config file]:file:_files -g "*.uae"' \
  '--config[load config file]:file:_files -g "*.uae"' \
  '-s[set config option]:OPTION=VALUE:' \
  '-cli[console emulation]::path:_files' \
  '--cli[console emulation]::path:_files' \
  '-diskswapper=[disk swapper file]:file:_files' \
  '-cfgparam=[add config parameter]:KEY=VAL:' \
  '--model[Amiga model]:model:(A500 A500P A600 A1000 A2000 A3000 A1200 A4000 CD32 CDTV)' \
  '--statefile[restore savestate]:file:_files' \
  '--autoload[auto-load image]:file:_files -g "*.(lha|cue|iso|chd)"' \
  '--log[enable console logging]' \
  '--cdimage[mount CD image]:spec:' \
  '--jit-selftest[JIT self-test]' \
  '*:config / state / disk file:_files -g "*.(uae|uss|adf|adz|dms|ipf|iso|cue|chd|lha)"' && ret=0
return ret
