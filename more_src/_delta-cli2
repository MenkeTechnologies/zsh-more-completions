#compdef delta-cli2
# Documentation: https://dandavison.github.io/delta/full---help-output.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# delta-cli2: alternate binary name for dandavison/delta git pager
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--diff-args=[delegate diff args]:a:' \
  '--diff-so-fancy[diff-so-fancy emulation]' \
  '--diff-highlight[diff-highlight emulation]' \
  '--features=[features csv]:list:' \
  '--list-languages[list languages]' \
  '--list-syntax-themes[list syntax themes]' \
  '--show-config[show resolved config]' \
  '--show-syntax-themes[show syntax theme samples]' \
  '--show-themes[show themes]' \
  '--show-colors[show colors]' \
  '--side-by-side[side-by-side]' \
  '-s[side-by-side]' \
  '(-n --line-numbers)'{-n,--line-numbers}'[line numbers]' \
  '--navigate[file-by-file navigation]' \
  '--color-only[color without structural changes]' \
  '--raw[no input alterations]' \
  '--paging=[paging]:p:(auto always never)' \
  '--pager=[pager command]:c:' \
  '--syntax-theme=[syntax theme]:t:' \
  '--light[light terminal]' \
  '--dark[dark terminal]' \
  '--default-language=[default language]:l:' \
  '--diff-stat-align-width=[stat align]:n:' \
  '--file-added-label=[file added label]:l:' \
  '--file-modified-label=[file modified label]:l:' \
  '--file-removed-label=[file removed label]:l:' \
  '--file-renamed-label=[file renamed label]:l:' \
  '--file-style=[file style]:s:' \
  '--file-decoration-style=[file decoration]:s:' \
  '--hunk-header-decoration-style=[hunk decoration]:s:' \
  '--hunk-header-file-style=[hunk file style]:s:' \
  '--hunk-header-line-number-style=[hunk line num]:s:' \
  '--hunk-header-style=[hunk header]:s:' \
  '--keep-plus-minus-markers[keep +/-]' \
  '--minus-style=[minus style]:s:' \
  '--minus-emph-style=[minus emph style]:s:' \
  '--minus-non-emph-style=[minus non-emph]:s:' \
  '--minus-empty-line-marker-style=[minus empty marker]:s:' \
  '--plus-style=[plus style]:s:' \
  '--plus-emph-style=[plus emph]:s:' \
  '--plus-non-emph-style=[plus non-emph]:s:' \
  '--plus-empty-line-marker-style=[plus empty marker]:s:' \
  '--max-line-distance=[max line distance]:f:' \
  '--max-line-length=[max line length]:n:' \
  '--max-syntax-highlighting-substrings-per-line=[max syntax substrings]:n:' \
  '--inline-hint-style=[inline hint style]:s:' \
  '--word-diff-regex=[word diff regex]:re:' \
  '--zero-style=[zero style]:s:' \
  '--whitespace-error-style=[whitespace error]:s:' \
  '--blame-code-style=[blame code]:s:' \
  '--blame-format=[blame format]:f:' \
  '--blame-palette=[blame palette]:p:' \
  '--blame-separator-format=[blame sep format]:f:' \
  '--blame-separator-style=[blame sep style]:s:' \
  '--blame-timestamp-format=[blame timestamp]:f:' \
  '--blame-timestamp-output-format=[blame ts out]:f:' \
  '--commit-decoration-style=[commit decoration]:s:' \
  '--commit-style=[commit style]:s:' \
  '--commit-regex=[commit regex]:re:' \
  '--config=[config file]:file:_files' \
  '--no-gitconfig[no gitconfig]' \
  '--hyperlinks[render hyperlinks]' \
  '--grep-output-type=[grep output type]:t:' \
  '--true-color=[24-bit color]:m:(auto always never)' \
  '--width=[output width]:n:' \
  '--wrap-max-lines=[max wrap lines]:n:' \
  '--wrap-left-symbol=[wrap left symbol]:s:' \
  '--wrap-right-symbol=[wrap right symbol]:s:' \
  '--wrap-right-percent=[wrap right %]:n:' \
  '--wrap-right-prefix-symbol=[wrap right prefix]:s:' \
  '--tabs=[tab width]:n:' \
  '*: :_files' && ret=0

return ret
