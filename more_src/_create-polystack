#compdef create-polystack
# Documentation: https://www.npmjs.com/package/create-polystack
# Reference accessed: 2026-05-24
# Verified: npm view create-polystack bin; npx create-polystack --help output.

# Zsh completion for create-polystack - polyglot full-stack project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--lang=[project language]:lang:(java python javascript typescript php go rust ruby csharp kotlin)' \
  '--framework=[backend framework]:framework:(spring-boot fastapi django express hono elysia nextjs slim gin axum sinatra aspnet ktor)' \
  '--web-frontend=[web frontend stack]:frontend:(nextjs react-vite react-router tanstack-start nuxt sveltekit solid-start astro none)' \
  '--native-frontend=[native frontend stack]:native:(react-native-expo react-native-nativewind react-native-unistyles flutter swift-ui kotlin-compose lynx none)' \
  '--db=[database engine]:database:(none postgres mysql sqlite mongodb)' \
  '--orm=[ORM integration]:orm:(drizzle prisma typeorm sqlalchemy django-orm hibernate gorm diesel active-record ef-core exposed eloquent none)' \
  '--db-setup=[database setup helper]:db-setup:(docker neon supabase turso planetscale mongodb-atlas none)' \
  '--auth=[auth integration]:auth:(better-auth clerk auth0 supabase-auth next-auth lucia none)' \
  '--payments=[payments integration]:payments:(stripe polar paddle lemon-squeezy none)' \
  '--web-deploy=[web deployment target]:web-deploy:(vercel netlify cloudflare-pages github-pages none)' \
  '--server-deploy=[server deployment target]:server-deploy:(railway fly render cloud-run aws-apprunner none)' \
  '--pm=[package manager]:manager:(npm pnpm yarn bun uv pdm poetry rye pip auto)' \
  '--addons=[comma-separated addons]:addons:(docker readme env-example husky biome prettier github-actions)' \
  '--no-git[skip git init]' \
  '--no-install[skip auto-install step]' \
  '(-y --yes)'{-y,--yes}'[accept defaults for optional prompts]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  ':project name:' && ret=0

return ret
