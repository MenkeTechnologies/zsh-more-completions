#compdef yarn
# _yarn — Apache Hadoop YARN CLI (per-application + ResourceManager management; user commands: application, applicationattempt, container, jar, logs, classpath, queue, schedulerconf, top, node, daemonlog; admin commands: rmadmin, nodemanager, resourcemanager, scmadmin, sharedcachemanager, timelineserver, timelinereader, registrydns; --loglevel, --config)
# upstream: https://github.com/apache/hadoop (yarn)
# Subcommands from Apache Hadoop hadoop-yarn-project bin/yarn on tip.

_yarn() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--config+[hadoop config dir]:dir:_files -/' \
        '--loglevel+[log level]:level:(TRACE DEBUG INFO WARN ERROR FATAL)' \
        '--daemon=*[daemon mode]:mode:(start status stop)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'yarn command' '(application applicationattempt container jar logs classpath queue schedulerconf top node daemonlog version rmadmin nodemanager resourcemanager scmadmin sharedcachemanager timelineserver timelinereader registrydns proxyserver router fpga gpu cluster envvars help)' ;;
        args) _arguments '*:argument:_files' ;;
    esac
}

_yarn "$@"
