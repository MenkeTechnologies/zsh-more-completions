#compdef satori satori.py
# Documentation: https://github.com/xnih/satori
# Passive OS fingerprinting tool (DHCP, DNS, HTTP, NTP, SMB, SSH, SSL, TCP)

local ret=1

_arguments -s -S \
  '--version[display version information]' \
  '-i+[capture packets live from a network interface]:interface:_net_interfaces' \
  '-r+[read and analyze packets from a pcap file]:pcap file:_files' \
  '-m+[fingerprinting module to use]:module:(DHCP DNS HTTP NTP SMB SSH SSL TCP)' \
  '--ja3update[download additional SSL fingerprints]' \
  '--trisulnsm[download additional SSL fingerprints from trisulnsm]' \
  '*:pcap file:_files' && ret=0

return ret
