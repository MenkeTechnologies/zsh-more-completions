#compdef mimir

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '*-config.file=[YAML config file]:file:_files -g "*.(yaml|yml)"' \
  '-config.expand-env=[expand env in YAML]:flag:(true false)' \
  '-target=[target modules (comma-separated)]:modules:(all distributor ingester querier query-frontend query-scheduler ruler alertmanager compactor store-gateway flusher overrides-exporter write read backend)' \
  '-modules[print available modules and exit]' \
  '-log.level=[log level]:level:(debug info warn error)' \
  '-log.format=[log format]:fmt:(logfmt json)' \
  '-mem-ballast-size-bytes=[GC ballast bytes]:bytes:' \
  '-shutdown-delay=[shutdown delay duration]:duration:' \
  '-auth.multitenancy-enabled[enable multitenancy]' \
  '-auth.no-auth-tenant=[no-auth tenant id]:id:' \
  '-http.config.file=[HTTP config file]:file:_files' \
  '-tracing.enabled[enable tracing]'
