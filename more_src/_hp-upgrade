#compdef hp-upgrade
# Documentation: https://github.com/deepin-community/hplip
# Reference accessed: 2026-05-16
# Verified: upstream deepin-community/hplip upgrade.py.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# hp-upgrade: HPLIP upgrade checker
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode (default)]' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '-g[shortcut for -ldebug]' \
  '--notify[check for update and notify]' \
  '--check[check only available version]' && ret=0
return ret
