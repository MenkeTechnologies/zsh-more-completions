#compdef lasvoxel
# Documentation: https://github.com/LAStools/LAStools
# LAStools: compute a voxelization of LAS/LAZ points

local ret=1

_arguments -s -S \
  '(-v -verbose)'{-v,-verbose}'[detailed output information]' \
  '-version[display tool version]' \
  '-gui[launch with GUI]' \
  '-demo[evaluation/demo mode]' \
  '-license[show licensing information]' \
  '-step+[uniform grid cell size for x y z]:size' \
  '-step_xy+[horizontal spacing of voxel cells]:size' \
  '-step_z+[vertical spacing of voxel cells]:size' \
  '-step_z_infinite[infinite vertical spacing (single layer)]' \
  '-compute_mean_xyz[use average coordinates instead of voxel center]' \
  '-empty_voxels[include empty voxels with zero intensity]' \
  '-max_count+[maximum point count per voxel]:n' \
  '-compute_IDs_and_voxel_table[generate voxel ID mapping]' \
  '-store_IDs_in_intensity[store voxel IDs in intensity field]' \
  '-store_IDs_in_point_source[store voxel IDs in point source field]' \
  '-mem+[memory allocation in MB (default 1500)]:mb' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-merged[merge input files]' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output file suffix]:suffix' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-cores+[parallel processing on multiple cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
