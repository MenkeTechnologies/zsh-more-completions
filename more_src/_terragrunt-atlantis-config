#compdef terragrunt-atlantis-config

# Zsh completion for terragrunt-atlantis-config (transcend-io)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(generate version)
    _describe -t commands 'terragrunt-atlantis-config command' commands && ret=0
    ;;
  args)
    if [[ $words[1] == generate ]]; then
      _arguments -s -S \
        '--autoplan[enable Atlantis autoplan]' \
        '--automerge[enable Atlantis automerge]' \
        '--ignore-parent-terragrunt[skip parent configs without modules]' \
        '--create-parent-project[emit project for abstract parents]' \
        '--ignore-dependency-blocks[ignore terragrunt dependency blocks]' \
        '--parallel[allow concurrent plans]' \
        '--create-workspace[workspace per project]' \
        '--create-project-name[unique project names]' \
        '--preserve-workflows[merge with old atlantis.yaml workflows]' \
        '--preserve-projects[retain previous projects incrementally]' \
        '--cascade-dependencies[transitive depends_on]' \
        '--workflow[default Atlantis workflow name]:name' \
        '*--apply-requirements[Atlantis apply guards]:req:(approved mergeable)' \
        '--output[path to rendered atlantis.yaml]:file:_files' \
        '*--filter[globs limiting scanned paths]:glob' \
        '--root[git root for terragrunt tree]:dir:_directories' \
        '--terraform-version[pin TF version]:ver' \
        '--num-executors[parallel parse workers]:n' \
        '*--project-hcl-files[extra project.hcl names]:base' \
        '--create-hcl-project-childs[scan children under project hcl dirs]' \
        '--create-hcl-project-external-childs[scan sibling modules]' \
        '--use-project-markers[only dirs with atlantis_project local]' \
        '--execution-order-groups[populate execution_order_groups]' \
        '--depends-on[compute depends_on (needs --create-project-name)]' && ret=0
    else
      _files && ret=0
    fi
    ;;
esac

return ret
