#compdef tinyproxy
# Documentation: https://manpages.debian.org/testing/tinyproxy/tinyproxy.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '(- *)-l[display licensing]' \
  '-d[do not daemonize, stay in foreground]' \
  '-c+[use alternate configuration file]:config file:_files' && return 0
