#compdef ttf2woff
# Documentation: https://man.archlinux.org/search?q=ttf2woff
# Reference accessed: 2026-05-16

# ttf2woff: convert TrueType/OpenType font to WOFF
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[print version]' \
  '-m[metadata XML file]:file:_files' \
  '-p[private data file]:file:_files' \
  '-V[font version string]:version:' \
  '*:TTF/OTF font and output WOFF file:_files -g "*.(ttf|otf|woff)"' && ret=0
return ret
