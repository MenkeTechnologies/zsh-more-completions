#compdef xc3sprog
# Documentation: https://manpages.debian.org/testing/xc3sprog/xc3sprog.1.en.html
# JTAG programming utility for Xilinx FPGAs and PROMs

local ret=1

_arguments -s -S \
  '-h[print a help text]' \
  '-c[specify the type of JTAG cable]:cable' \
  '-j[detect the JTAG chain and list attached devices]' \
  '-p[use device at JTAG chain position]:position' \
  '-T[test the JTAG chain n times]:count' \
  '-J[run at the specified JTAG clock frequency in Hz]:freq' \
  '-e[erase the entire device]' \
  '-I[work in ISF mode to program internal serial flash]::file:_files' \
  '-R[send a reconfiguration command to the target device]' \
  '-m[search for XC2C map files in directory]:mapdir:_files -/' \
  '-d[specify the parallel port device]:device:_files' \
  '-s[use the USB device with serial number]:serialnum' \
  '-L[use libFTD2XX instead of libftdi]' \
  '-D[dump device and cable database to files]' \
  '-X[set configuration mode for XCFnnP PROM devices]:opts' \
  '-v[enable verbose output]' \
  '*:bitstream:_files' && ret=0

return ret
