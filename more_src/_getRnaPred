#compdef getRnaPred
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: get RNA for gene predictions

local ret=1

_arguments -s -S \
  '-weird[retrieve only genes with non-standard splice sites]' \
  '-cdsUpper[output coding sequence in uppercase]' \
  '-cdsOnly[output only the coding sequence]' \
  '-cdsOut=[write CDS to tab-separated file (acc, start, end)]:file:_files' \
  '-keepMasking[preserve masking as upper/lowercase]' \
  '-pslOut=[generate PSL output for genomic mRNAs]:file:_files' \
  '-suffix=[append suffix to sequence identifiers]:suf' \
  '-peptides[output translation of CDS to protein]' \
  '-exonIndices[include exon boundary indices after sequence name]' \
  '-maxSize=[limit output to specified character count]:size' \
  '-genomeSeqs=[use this nib directory or 2bit file for sequences]:spec:_files' \
  '-includeCoords[add genomic coordinates as FASTA header comment]' \
  '-genePredExt[use extended genePred format with frame information]' \
  '1:database:' \
  '2:table or file:_files' \
  '3:chromosome:' \
  '4:output fasta:_files' && ret=0

return ret
