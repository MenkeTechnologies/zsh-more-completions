#compdef enchant-lsmod-2
# Documentation: enchant-lsmod-2 -h
# Source: list installed Enchant spell-check backends/dictionaries.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '(-lang -word-chars -list-dicts)-lang[list languages supported by each backend]' \
    '(-lang -word-chars -list-dicts)-word-chars[show word-character set for language]' \
    '(-lang -word-chars -list-dicts)-list-dicts[list installed dictionaries]' \
    '1:language tag:' \
    && ret=0

return ret
