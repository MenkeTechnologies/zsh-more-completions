#compdef pacgraph

_pacgraph() {
  _arguments \
    '(-c --console)'{-c,--console}'[console mode, no GUI]' \
    '(-d --dot)'{-d,--dot}'[output in DOT format]' \
    '(-e --explicits)'{-e,--explicits}'[show only explicitly installed]' \
    '(-f --file)'{-f,--file}'=[output file]:file:_files' \
    '(-l --link-deps)'{-l,--link-deps}'[link dependencies]' \
    '(-n --no-compression)'{-n,--no-compression}'[disable name compression]' \
    '(-o --opt-deps)'{-o,--opt-deps}'[include optional dependencies]' \
    '(-p --package)'{-p,--package}'=[highlight a package]:package' \
    '(-r --raw)'{-r,--raw}'[raw SVG output]' \
    '(-s --svg)'{-s,--svg}'[SVG output]' \
    '(-t --top)'{-t,--top}'=[show top N packages by size]:count' \
    '--arch[Arch Linux mode]' \
    '--shared[show shared libraries]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]'
}

_pacgraph "$@"
