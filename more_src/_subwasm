#compdef subwasm
# _subwasm — chevdor subwasm Substrate WASM runtime inspector dump metadata version constants extract migrations and diff two runtimes for Polkadot/Kusama upgrades (chevdor team, Rust); clap
# upstream: https://github.com/chevdor/subwasm

_subwasm() {
    local -a sub=(
        'get:fetch a runtime'
        'info:show runtime info'
        'version:show version of runtime'
        'metadata:show runtime metadata'
        'compress:compress a runtime'
        'decompress:decompress a runtime'
        'diff:diff two runtimes'
        'show-reduced:show reduced metadata'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-j[json output]' \
        '--json[json output]' \
        '-c[compress output]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'subwasm subcommand' sub ;;
        args)
            case $words[1] in
                get) _arguments \
                    '--url=+[url]:str:' \
                    '--rpc=+[rpc]:str:' \
                    '--chain=+[chain]:c:(polkadot kusama westend rococo asset-hub bridge-hub collectives)' \
                    '--block=+[hash]:str:' \
                    '--output=+[file]:file:_files -g "*.wasm *.txt"' \
                    '-o+[file]:file:_files -g "*.wasm *.txt"' ;;
                info|metadata|version|compress|decompress|show-reduced) _arguments \
                    '-i+[wasm]:file:_files -g "*.wasm"' \
                    '--input=+[wasm]:file:_files -g "*.wasm"' \
                    '-o+[file]:file:_files' \
                    '--output=+[file]:file:_files' \
                    '--block=+[hash]:str:' \
                    '--chain=+[chain]:c:(polkadot kusama westend rococo)' ;;
                diff) _arguments \
                    '-a+[wasm A]:file:_files -g "*.wasm"' \
                    '-b+[wasm B]:file:_files -g "*.wasm"' \
                    '--chain-a=+[chain]:c:(polkadot kusama westend rococo)' \
                    '--chain-b=+[chain]:c:(polkadot kusama westend rococo)' ;;
            esac
            ;;
    esac
}

_subwasm "$@"
