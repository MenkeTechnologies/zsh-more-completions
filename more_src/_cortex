#compdef cortex

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config.file=[YAML config file path]:config file:_files' \
  '--config.expand-env[expand environment variables in config]' \
  '--target=[comma-separated list of targets]:target:_values -s , target all distributor ingester querier query-frontend query-scheduler table-manager compactor store-gateway ruler alertmanager configs ring-memberlist overrides-exporter flusher purger' \
  '--auth.enabled=[enable authentication]:enabled:(true false)' \
  '--auth.type=[authentication type]:type' \
  '--server.http-listen-address=[HTTP listen address]:address' \
  '--server.http-listen-port=[HTTP listen port]:port' \
  '--server.grpc-listen-address=[gRPC listen address]:address' \
  '--server.grpc-listen-port=[gRPC listen port]:port' \
  '--server.log.level=[server log level]:level:(debug info warn error)' \
  '--server.log.format=[server log format]:format:(logfmt json)' \
  '--print.config[print current config and exit]' \
  '--log.level=[log level]:level:(debug info warn error)'
