#compdef create-rsbuild
# Documentation: https://rsbuild.rs
# Reference accessed: 2026-05-24
# Verified: npx create-rsbuild --help.

# Zsh completion for create-rsbuild - Rsbuild project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --dir)'{-d,--dir=}'[create project in directory]:dir:_directories' \
  '(-t --template)'{-t,--template=}'[template name]:template:' \
  '--tools=[additional tools, comma separated]:tools:' \
  '--skill=[optional skills, comma separated]:skills:' \
  '--override[override files in target directory]' \
  ':directory:_directories' && ret=0

return ret
