#compdef canary

# NVIDIA/container-canary (Homebrew: container-canary) — cmd/*.go

local curcontext="$curcontext" state line ret=1

local -a base=(
  '(- *)'{-h,--help}'[help]'
  '(-t)'{-t,--toggle}'[upstream root placeholder (cobra)]'
)

_arguments -C -s -S \
  "$base[@]" \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a sub=(
      'validate:validate a container image against a manifest'
      'version:print version metadata'
    )
    _describe -t commands 'canary command' sub && ret=0
    ;;
  (args)
    case $line[1] in
      (validate)
        _arguments -s -S \
          "$base[@]" \
          '--file=[manifest path or URL]:file:_files' \
          '--debug[keep container running on failure]' \
          '--startup-timeout=[startup wait seconds]:seconds:' \
          '1:image:docker image:' && ret=0
        ;;
      (version)
        _arguments -s -S "$base[@]" && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
