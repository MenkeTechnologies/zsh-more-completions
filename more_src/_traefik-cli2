#compdef traefik2
# Documentation: https://github.com/traefik/traefik
# Reference accessed: 2026-05-21
# Verified: upstream cmd/traefik/traefik.go (healthcheck, version subcommands)
# and configuration knobs documented at doc.traefik.io/traefik/.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'healthcheck:run a healthcheck against Traefik'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--configfile=[config file]:file:_files -g "*.toml *.yml *.yaml"' \
  '*--configFile=[config file]:file:_files -g "*.toml *.yml *.yaml"' \
  '*--global.checknewversion=[check new version]:b:(true false)' \
  '*--global.sendanonymoususage=[send anonymous usage]:b:(true false)' \
  '*--api[enable API]' \
  '*--api.dashboard=[enable dashboard]:b:(true false)' \
  '*--api.insecure=[insecure API]:b:(true false)' \
  '*--api.debug=[enable debug API]:b:(true false)' \
  '*--accesslog=[enable access log]:b:(true false)' \
  '*--accesslog.filepath=[access log file]:file:_files' \
  '*--accesslog.format=[access log format]:f:(common json)' \
  '*--log[enable Traefik log]' \
  '*--log.level=[log level]:l:(DEBUG INFO WARN WARNING ERROR FATAL PANIC)' \
  '*--log.filepath=[log file]:file:_files' \
  '*--log.format=[log format]:f:(common json)' \
  '*--ping=[enable ping]:b:(true false)' \
  '*--metrics.prometheus=[enable Prometheus]:b:(true false)' \
  '*--metrics.influxdb=[enable InfluxDB]:b:(true false)' \
  '*--metrics.statsd=[enable StatsD]:b:(true false)' \
  '*--metrics.datadog=[enable Datadog]:b:(true false)' \
  '*--tracing.jaeger=[enable Jaeger]:b:(true false)' \
  '*--tracing.zipkin=[enable Zipkin]:b:(true false)' \
  '*--tracing.datadog=[enable Datadog tracing]:b:(true false)' \
  '*--tracing.opentelemetry=[enable OTel]:b:(true false)' \
  '*--entrypoints.web.address=[entrypoint address]:addr:' \
  '*--entrypoints.websecure.address=[secure entrypoint]:addr:' \
  '*--certificatesresolvers.le.acme.email=[ACME email]:email:' \
  '*--certificatesresolvers.le.acme.storage=[ACME storage]:file:_files' \
  '*--certificatesresolvers.le.acme.tlschallenge=[TLS challenge]:b:(true false)' \
  '*--certificatesresolvers.le.acme.httpchallenge=[HTTP challenge]:b:(true false)' \
  '*--certificatesresolvers.le.acme.dnschallenge=[DNS challenge]:b:(true false)' \
  '*--certificatesresolvers.le.acme.dnschallenge.provider=[DNS provider]:p:' \
  '*--certificatesresolvers.le.acme.caserver=[CA server URL]:url:' \
  '*--providers.docker=[enable Docker]:b:(true false)' \
  '*--providers.docker.endpoint=[Docker endpoint]:url:' \
  '*--providers.docker.exposedbydefault=[expose by default]:b:(true false)' \
  '*--providers.docker.network=[Docker network]:net:' \
  '*--providers.docker.swarmmode=[Swarm mode]:b:(true false)' \
  '*--providers.kubernetescrd=[enable K8s CRD]:b:(true false)' \
  '*--providers.kubernetesingress=[enable K8s Ingress]:b:(true false)' \
  '*--providers.kubernetesgateway=[enable K8s Gateway]:b:(true false)' \
  '*--providers.consulcatalog=[enable Consul Catalog]:b:(true false)' \
  '*--providers.consul.endpoints=[Consul endpoints csv]:list:' \
  '*--providers.etcd.endpoints=[etcd endpoints csv]:list:' \
  '*--providers.zookeeper.endpoints=[ZK endpoints csv]:list:' \
  '*--providers.redis.endpoints=[Redis endpoints csv]:list:' \
  '*--providers.file.directory=[file provider dir]:dir:_files -/' \
  '*--providers.file.filename=[file provider file]:file:_files' \
  '*--providers.file.watch=[watch files]:b:(true false)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'traefik command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
