#compdef drep
# drep — rapid genome de-replication

local curcontext="$curcontext" state line ret=1

_drep_common_args() {
  _arguments -s -S \
    '(- *)'{-h,--help}'[show help and exit]' \
    '(-g --genomes)'{-g,--genomes}'[input genomes]:*:genome files:_files' \
    '(-p --processors)'{-p,--processors}'[number of threads]:threads' \
    '(-d --debug)'{-d,--debug}'[enable debug mode]' \
    '1:work directory:_files -/' \
    "$@"
}

_drep_dereplicate() {
  _drep_common_args \
    '-comp[minimum genome completeness]:percent' \
    '-con[maximum genome contamination]:percent' \
    '-str[genome strain heterogeneity penalty]:weight' \
    '-strW[strain heterogeneity weight]:weight' \
    '-comW[completeness weight]:weight' \
    '-conW[contamination weight]:weight' \
    '-sa[secondary ANI threshold]:ANI' \
    '-pa[primary ANI threshold]:ANI' \
    '-nc[minimum coverage for alignment]:coverage' \
    '--S_algorithm[secondary clustering algorithm]:algorithm:(fastANI ANIn ANImf gANI goANI skani)' \
    '--P_algorithm[primary clustering algorithm]:algorithm:(minimap2 mashmap)' \
    '--SkipMash[skip MASH prefiltering]' \
    '--SkipSecondary[skip secondary clustering]' \
    '--ignoreGenomeQuality[ignore genome quality during dereplication]' \
    '--clusterAlg[hierarchical clustering algorithm]:algorithm:(single complete average weighted median centroid ward)' \
    '-l[minimum genome length]:length' \
    '-N50W[N50 weight]:weight' \
    '-sizeW[size weight]:weight' \
    '--S_ani[ANI threshold for secondary clustering]:ANI' \
    '--cov_thresh[minimum coverage for secondary clustering]:coverage' \
    '--coverage_method[method for calculating coverage]:method:(larger total)' \
    '--checkM_method[CheckM method]:method:(lineage_wf taxonomy_wf)' \
    '--set_recursion[set python recursion limit]:limit' \
    '--multiround_primary_clustering[cluster at multiple ANI thresholds]' \
    '--primary_chunksize[chunk size for primary clustering]:size' \
    '--greedy_secondary_clustering[use greedy clustering]' \
    '--run_tertiary_clustering[run tertiary clustering step]' \
    '--warn_dist[MASH distance to warn]:distance' \
    '--warn_sim[minimum similarity to warn]:similarity' \
    '--warn_aln[minimum alignment fraction to warn]:fraction' \
    && return 0
}

_drep_compare() {
  _drep_common_args \
    '-sa[secondary ANI threshold]:ANI' \
    '-pa[primary ANI threshold]:ANI' \
    '-nc[minimum coverage for alignment]:coverage' \
    '--S_algorithm[secondary clustering algorithm]:algorithm:(fastANI ANIn ANImf gANI goANI skani)' \
    '--P_algorithm[primary clustering algorithm]:algorithm:(minimap2 mashmap)' \
    '--SkipMash[skip MASH prefiltering]' \
    '--SkipSecondary[skip secondary clustering]' \
    '--clusterAlg[hierarchical clustering algorithm]:algorithm:(single complete average weighted median centroid ward)' \
    '--multiround_primary_clustering[cluster at multiple ANI thresholds]' \
    '--primary_chunksize[chunk size for primary clustering]:size' \
    '--greedy_secondary_clustering[use greedy clustering]' \
    && return 0
}

_drep_evaluate() {
  _drep_common_args \
    '--evaluate[evaluate quality of genomes]' \
    '-comp[minimum genome completeness]:percent' \
    '-con[maximum genome contamination]:percent' \
    '--checkM_method[CheckM method]:method:(lineage_wf taxonomy_wf)' \
    && return 0
}

_drep_filter() {
  _drep_common_args \
    '-comp[minimum genome completeness]:percent' \
    '-con[maximum genome contamination]:percent' \
    '-str[genome strain heterogeneity penalty]:weight' \
    '--ignoreGenomeQuality[ignore genome quality]' \
    '-l[minimum genome length]:length' \
    '--checkM_method[CheckM method]:method:(lineage_wf taxonomy_wf)' \
    && return 0
}

local -a subcmds
subcmds=(
  'dereplicate:de-replicate a genome set'
  'compare:compare genomes without dereplicating'
  'evaluate:evaluate genome quality'
  'filter:filter genomes by quality'
  'bonus:run bonus operations'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'drep command' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      dereplicate) _drep_dereplicate ;;
      compare) _drep_compare ;;
      evaluate) _drep_evaluate ;;
      filter) _drep_filter ;;
      bonus) _drep_common_args && ret=0 ;;
      *) _default ;;
    esac
    ;;
esac

return ret
