#compdef impacket-kintercept

# Impacket kintercept.py: intercept Kerberos pre-authentication traffic
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-listen[listen address]:host:' \
  '-port[listen port]:port:' \
  '-dst[destination KDC host]:host:' \
  '-dst-port[destination KDC port]:port:' \
  '-output[output file for captured tickets]:file:_files' \
  '*::kintercept args:_files' && ret=0
return ret
