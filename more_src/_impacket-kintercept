#compdef impacket-kintercept
# Documentation: https://github.com/fortra/impacket/blob/master/examples/kintercept.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-kintercept: TCP proxy that intercepts and rewrites Kerberos messages.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '--server-port=[target server port]:port:' \
  '--listen-port=[port to listen on]:port:' \
  '--listen-addr=[address to listen on]:addr:' \
  '--request-handler=[handler for requests (HANDLER:ARG)]:spec:' \
  '--reply-handler=[handler for replies (HANDLER:ARG)]:spec:' \
  ':target server:_hosts' && ret=0
return ret
