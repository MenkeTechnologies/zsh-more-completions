#compdef impacket-kintercept
# Documentation: https://man.archlinux.org/search?q=impacket-kintercept
# Reference accessed: 2026-05-16

# impacket-kintercept: intercept and modify Kerberos tickets
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "-debug[verbose debug output]" \
  "-ts[print timestamps in log]" \
  "-ts-utc[print timestamps in UTC]" \
  "-target-ip[target IP]:ip:" \
  "-dc-ip[domain controller IP]:ip:" \
  "-codec[codec for non-utf-8 strings]:codec:" \
  "-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:" \
  "-no-pass[do not ask for password]" \
  "-k[use Kerberos]" \
  "-aesKey[AES key in hex]:hex:" \
  "-cert-pem[pem certificate file]:file:_files" \
  "-cert-pfx[pkcs12 cert file]:file:_files" \
  "-pfx-pass[pkcs12 cert password]:pass:" \
  -listen[listen address]:host: -port[listen port]:port: -target[target Kerberos server]:host:_hosts \
  '*::impacket-kintercept args:_files' && ret=0
return ret
