#compdef telnyx
# Documentation: https://man.archlinux.org/search?q=telnyx
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:configure or check API authentication'
  'message:send and inspect SMS/MMS messages'
  'call:make and control calls'
  'number:manage phone numbers'
  'voice-profile:manage voice profiles'
  'messaging-profile:manage messaging profiles'
  'connection:manage SIP/IP/CallControl connections'
  'webhook:manage webhooks'
  'address:manage 911/E911 addresses'
  'fax:send and manage faxes'
  'storage:object storage commands'
  'wireless:wireless SIM commands'
  'verify:Verify (OTP) commands'
  'audit:audit log commands'
  'completion:generate shell completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api-key=[Telnyx API key]:key:' \
  '--profile=[CLI profile]:profile:' \
  '--format=[output format]:format:(auto explore json jsonl pretty raw yaml)' \
  '--transform=[GJSON transform]:expression:' \
  '--quiet[suppress output]' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'telnyx command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (auth)
        _arguments '*::sub:(setup status logout)' && ret=0 ;;
      (message)
        local -a msg_subs=(
          'send:send a message'
          'list:list messages'
          'get:get a message'
          'cancel:cancel a scheduled message'
        )
        _describe -t mcmds 'message subcommand' msg_subs && ret=0
        _arguments \
          '--from=[from number]:number:' \
          '--to=[to number]:number:' \
          '--text=[message text]:text:' \
          '*--media-url=[MMS media URL]:url:' \
          '--messaging-profile-id=[messaging profile id]:id:' \
          '--auto-detect[auto-detect type]' && ret=0 ;;
      (call)
        local -a call_subs=(
          'dial:place an outbound call'
          'list:list active calls'
          'get:show call details'
          'answer:answer an incoming call'
          'hangup:end a call'
          'transfer:transfer a call'
          'speak:text-to-speech in a call'
          'play:play audio'
          'gather:gather DTMF/voice input'
          'record:record a call'
          'mute:mute a call'
          'unmute:unmute a call'
          'hold:hold a call'
          'unhold:unhold a call'
          'bridge:bridge two calls'
        )
        _describe -t ccmds 'call subcommand' call_subs && ret=0
        _arguments \
          '--from=[from number]:number:' \
          '--to=[to number]:number:' \
          '--connection-id=[CallControl connection id]:id:' \
          '--audio-url=[audio URL]:url:' \
          '--voice=[TTS voice]:voice:' \
          '--language=[TTS language]:lang:' && ret=0 ;;
      (number)
        _arguments '*::sub:(search list get order delete update reserve port)' && ret=0
        _arguments \
          '--country=[country code (ISO-3166)]:country:' \
          '--locality=[locality]:city:' \
          '--region=[region]:region:' \
          '--features=[required features]:features:' \
          '--force[skip confirmation]' && ret=0 ;;
      (voice-profile|messaging-profile|connection|webhook|address)
        _arguments '*::sub:(list get create update delete)' && ret=0 ;;
      (verify)
        _arguments '*::sub:(send check)' && ret=0 ;;
      (fax)
        _arguments '*::sub:(send list get cancel delete)' && ret=0 ;;
      (storage)
        _arguments '*::sub:(buckets objects upload download presign)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
