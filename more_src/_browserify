#compdef browserify

# Zsh completion for browserify - JavaScript bundler for the browser

_arguments -s -S \
  '(-e --entry)'{-e,--entry}'[entry file]:file:_files' \
  '(-o --outfile)'{-o,--outfile}'[write bundle to outfile]:file:_files' \
  '(-r --require)'{-r,--require}'[a file to bundle up into the output]:file:_files' \
  '--external[reference file or module with external instead of bundling]:file:_files' \
  '(-i --ignore)'{-i,--ignore}'[omit a file or module from the output]:file:_files' \
  '(-x --exclude)'{-x,--exclude}'[skip a file and throw an exception if it is required]:file:_files' \
  '(-u --exclude)'{-u,--exclude}'[drop a file without throwing]:file:_files' \
  '(-t --transform)'{-t,--transform}'[a module name or path to a transform module]:transform:' \
  '(-c --command)'{-c,--command}'[a transform command]:command:' \
  '(-g --global-transform)'{-g,--global-transform}'[a global transform module]:module:' \
  '(-p --plugin)'{-p,--plugin}'[a plugin to load]:plugin:' \
  '(-d --debug)'{-d,--debug}'[enable source maps to aid in debugging]' \
  '(-s --standalone)'{-s,--standalone}'[generate standalone UMD bundle with export name]:name:' \
  '--ignore-missing[ignore missing files]' \
  '--insert-globals[always insert process, global and Buffer global]' \
  '--im[same as --insert-globals]' \
  '--insert-global-vars[comma-separated list of global vars to insert]:vars:' \
  '--igv[same as --insert-global-vars]' \
  '--detect-globals[detect the use of process, global and Buffer]' \
  '--dg[same as --detect-globals]' \
  '--bare[omits the usage of built-in node modules]' \
  '--no-builtins[omits the usage of built-in node modules]' \
  '--no-commondir[omits usage of a single common dir for file paths]' \
  '--no-bundle-external[omit external modules]' \
  '--full-paths[use full paths in the bundle]' \
  '--node[alias for --bare --no-browser-field]' \
  '--no-browser-field[use require(''fs'') instead of browser shim]' \
  '--transform-key[key to look up transforms in package.json]:key:' \
  '--list[list the files in the dep graph]' \
  '--deps[show the dependencies of the files in the dep graph]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:files:_files'
