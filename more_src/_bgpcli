#compdef bgpcli
# _bgpcli — bgpcli CLI generic BGP4 Border Gateway Protocol session-debug peering-management speaker-and-collector helper for bird gobgp frr-bgpd quagga-bgpd RouterOS OpenBSD-bgpd CLI-style query show announce withdraw policy-route-prefix-filter view-IXP-route-server (bgpcli authors team, Python); custom argparse
# upstream: https://github.com/euro-ix/bgpcli

_bgpcli() {
    local -a sub=(
        'show:show BGP state'
        'peer:peer management'
        'route:per-route queries'
        'announce:announce prefix'
        'withdraw:withdraw prefix'
        'filter:filter management'
        'policy:policy management'
        'rib:dump RIB'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-H+[host]:_hosts' \
        '--host=+[host]:_hosts' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '-A+[asn]:str:' \
        '--asn=+[asn]:str:' \
        '-N+[neighbor]:_hosts' \
        '--neighbor=+[neighbor]:_hosts' \
        '-f+[format]:f:(table json yaml csv quagga frr)' \
        '--format=+[format]:f:(table json yaml csv quagga frr)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bgpcli subcommand' sub ;;
        args)
            case $words[1] in
                show) _arguments '1:object:(neighbors routes summary memory peers protocols rib)' ;;
                peer|route) _arguments '1:op:(add remove modify show)' ;;
                announce|withdraw) _arguments '1:prefix:' ;;
            esac
            ;;
    esac
}

_bgpcli "$@"
