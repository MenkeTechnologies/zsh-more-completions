#compdef clang-tidy
# _clang-tidy-bin — LLVM clang-tidy C/C++ linter (LLVM project, C++); static analysis + auto-fix with check categories
# upstream: https://github.com/llvm/llvm-project

_clang-tidy-bin() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-checks=+[checks list]:checks:' \
        '-config=+[YAML config]:str:' \
        '-config-file=+[YAML config file]:file:_files -g "*.yaml"' \
        '-dump-config[dump config]' \
        '-explain-config[explain enabled checks]' \
        '-export-fixes=+[export fixes to YAML]:file:_files' \
        '-extra-arg=+[extra clang arg]:arg:' \
        '-extra-arg-before=+[extra clang arg before]:arg:' \
        '-fix[apply fixes]' \
        '-fix-errors[apply fixes even with errors]' \
        '-fix-notes[apply fix-it for notes]' \
        '-format-style=+[format style]:style:(none file llvm google chromium webkit microsoft)' \
        '-header-filter=+[header filter regex]:regex:' \
        '-exclude-header-filter=+[exclude header filter]:regex:' \
        '-line-filter=+[line filter JSON]:str:' \
        '-list-checks[list enabled checks]' \
        '-load=+[load plugin]:file:_files' \
        '-p=+[build path]:dir:_files -/' \
        '--quiet[quiet]' \
        '-quiet[quiet]' \
        '-store-check-profile=+[store check profile dir]:dir:_files -/' \
        '-system-headers[also check system headers]' \
        '--use-color[force color]' \
        '-use-color[force color]' \
        '-warnings-as-errors=+[warnings as errors]:str:' \
        '-vfsoverlay=+[vfs overlay file]:file:_files' \
        '*:source file:_files'
}

_clang-tidy-bin "$@"
