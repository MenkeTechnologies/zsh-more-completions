#compdef tpm2_pcrread
# _tpm2_pcrread — tpm2-software tpm2_pcrread read PCR values for specified PCRs banks and hash algorithms (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_pcrread() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-Q[do not output anything]' \
        '--format=+[output format]:f:(json yaml)' \
        '*:pcr selection:(sha1: sha256: sha384: sha512: sm3_256: sha1:0,1,2 sha256:0,1,2 sha256:all)'
}

_tpm2_pcrread "$@"
