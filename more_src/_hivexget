#compdef hivexget
# _hivexget — Red Hat libhivex hivexget CLI for reading a single value from a Windows registry hive file by full key path emitting raw value bytes string DWORD QWORD multi-string binary REG_SZ types (libguestfs team, C); getopt
# upstream: https://github.com/libguestfs/hivex

_hivexget() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-u[force UTF-8 strings]' \
        '*:hive key path value:_files -g "SYSTEM SOFTWARE SAM SECURITY DEFAULT NTUSER.DAT *.hive"'
}

_hivexget "$@"
