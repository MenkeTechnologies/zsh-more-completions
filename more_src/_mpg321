#compdef mpg321
# Documentation: https://manpages.debian.org/testing/mpg321/mpg321.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mpg321 MP3 player

local ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-g --gain)'{-g+,--gain=}'[set gain (1-100)]:n:' \
  '(-k --skip)'{-k+,--skip=}'[skip N frames into the file]:n:' \
  '(-n --frames)'{-n+,--frames=}'[decode only the first N frames]:n:' \
  '-o+[output device type]:type:(oss sun alsa alsa09 esd arts)' \
  '(-a --audiodevice)'{-a+,--audiodevice=}'[audio output device]:device:_files' \
  '(-s --stdout)'{-s,--stdout}'[output to standard out instead of audio device]' \
  '(-w --wav)'{-w+,--wav=}'[write to wav file N]:file:_files' \
  '--cdr=[write to CDR file]:file:_files' \
  '--au=[write to AU file]:file:_files' \
  '(-z --shuffle)'{-z,--shuffle}'[shuffle playlist]' \
  '(-Z --random)'{-Z,--random}'[choose files at random]' \
  '-K[enable basic keys]' \
  '--skip-printing-frames=[skip N frames between status updates]:n:' \
  '*:audio:_files' && ret=0

return ret
