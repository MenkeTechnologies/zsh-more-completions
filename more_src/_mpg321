#compdef mpg321
# Documentation: https://man.archlinux.org/search?q=mpg321
# Reference accessed: 2026-05-16

# Zsh completion for mpg321 MP3 player

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-g --gain)'{-g,--gain}'[gain]:n' \
  '*:audio:_files' && ret=0

return ret
