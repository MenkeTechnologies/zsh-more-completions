#compdef razers3
# Documentation: https://github.com/seqan/seqan/tree/main/apps/razers3
# RazerS 3: parallelized, sensitive read mapper

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --percent-identity)'{-i+,--percent-identity=}'[identity threshold 50-100]:num:' \
  '(-rr --recognition-rate)'{-rr+,--recognition-rate=}'[recognition rate / sensitivity 80-100]:num:' \
  '(-tc --thread-count)'{-tc+,--thread-count=}'[thread count]:num:' \
  '(-m --max-hits)'{-m+,--max-hits=}'[output at most NUM of the best matches]:num:' \
  '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
  '(-fl --filter)'{-fl+,--filter=}'[filter algorithm]:filter:(pigeonhole swift)' \
  '(-mr --mutation-rate)'{-mr+,--mutation-rate=}'[mutation rate percentage]:num:' \
  '(-ol --overlap-length)'{-ol+,--overlap-length=}'[k-mer seed overlap length]:num:' \
  '(-s --shape)'{-s+,--shape=}'[k-mer shape bitstring]:bitstring:' \
  '(-tr --trim-reads)'{-tr+,--trim-reads=}'[trim reads to specified length]:num:' \
  '(-ng --no-gaps)'{-ng,--no-gaps}'[consider only mismatches (Hamming distance)]' \
  '(-f --forward)'{-f,--forward}'[map to forward strand only]' \
  '(-r --reverse)'{-r,--reverse}'[map to reverse strand only]' \
  '(-ll --library-length)'{-ll+,--library-length=}'[mean library size]:num:' \
  '(-le --library-error)'{-le+,--library-error=}'[library size tolerance]:num:' \
  '(-a --alignment)'{-a,--alignment}'[include alignment details in output]' \
  '(-pa --purge-ambiguous)'{-pa,--purge-ambiguous}'[omit reads exceeding max-hit threshold]' \
  '(-dr --distance-range)'{-dr+,--distance-range=}'[filter by error distance range]:num:' \
  '*:genome and reads:_files' && ret=0

return ret
