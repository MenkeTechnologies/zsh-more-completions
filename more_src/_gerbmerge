#compdef gerbmerge
# Documentation: https://github.com/provideyourown/gerbmerge/blob/master/README.md
# gerbmerge - panelize multiple RS-274X Gerber files into one set

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print a brief summary of options]' \
  '(-v --version)'{-v,--version}'[print program version and author info]' \
  '--octagons=[set octagon rotation]:mode:(normal rotate)' \
  '--random-search[perform a randomized search of job tilings (default)]' \
  '--full-search[search all possible job tilings]' \
  '--rs-fsjobs=[number of jobs to full-search per tiling]:n' \
  '--place-file=[lay out panel from absolute job positions in file]:file:_files' \
  '--no-trim-gerber[do not trim Gerber data to board outline extents]' \
  '--no-trim-excellon[do not trim Excellon data to board outline extents]' \
  '--search-timeout=[terminate random search after N seconds]:seconds' \
  '*:config file:_files -g "*.cfg"' && ret=0

return ret
