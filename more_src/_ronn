#compdef ronn

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-r[generate roff output]' \
  '--roff[generate roff output]' \
  '-5[generate HTML output]' \
  '--html[generate HTML output]' \
  '-f[generate fragment (no header/footer)]' \
  '--fragment[generate fragment (no header/footer)]' \
  '--markdown[generate post-processed markdown output]' \
  '-m+[manual name]:manual name' \
  '--manual=[manual name]:manual name' \
  '-o+[organization name]:organization' \
  '--organization=[organization name]:organization' \
  '-d+[date]:date' \
  '--date=[date]:date' \
  '--pipe[write to stdout]' \
  '-s+[manual section]:section:(1 2 3 4 5 6 7 8)' \
  '--section=[manual section]:section:(1 2 3 4 5 6 7 8)' \
  '-S+[manual section override]:section:(1 2 3 4 5 6 7 8)' \
  '-n+[override the page name]:name' \
  '--name=[override the page name]:name' \
  '--style=[add CSS stylesheet]:stylesheet:_files -g "*.css"' \
  '-w[open page in web browser]' \
  '--warnings[show warnings]' \
  '-W[show warnings]' \
  '*:ronn file:_files -g "*.ronn"' && ret=0

return ret
