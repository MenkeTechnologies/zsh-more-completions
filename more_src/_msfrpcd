#compdef msfrpcd
# Documentation: https://github.com/rapid7/metasploit-framework/blob/master/msfrpcd
# Metasploit Framework RPC daemon

local ret=1

_arguments -s -S \
  '-a[bind to this IP address (default 0.0.0.0)]:address:_hosts' \
  '-p[bind to this port (default 55553)]:port' \
  '-U[specify the username to access msfrpcd]:username' \
  '-P[specify the password to access msfrpcd]:password' \
  '-u[URI for Web server]:uri' \
  '-t[token timeout seconds (default 300)]:seconds' \
  '-S[disable SSL on the RPC socket]' \
  '-f[run the daemon in the foreground]' \
  '-n[disable database]' \
  '-j[(JSON-RPC) start JSON-RPC server]' \
  '-k[(JSON-RPC) path to private key]:key file:_files' \
  '-c[(JSON-RPC) path to certificate]:cert file:_files' \
  '-v[(JSON-RPC) SSL enable verify (optional) client cert requests]' \
  '-h[help banner]' && ret=0

return ret
