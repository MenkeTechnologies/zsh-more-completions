#compdef certipy certipy-ad
# Documentation: https://man.archlinux.org/search?q=certipy
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'account:create/read/update/delete account'
  'auth:authenticate using PFX certificate'
  'ca:CA management'
  'cert:certificate operations'
  'find:enumerate AD CS for vulnerable templates'
  'parse:parse BOF or .reg input'
  'forge:forge a certificate'
  'relay:relay NTLM to AD CS'
  'req:request a certificate'
  'shadow:shadow credentials attacks'
  'template:template operations'
)

local -a target_args
target_args=(
  '-dc-ip=[domain controller IP]:ip:'
  '-dc-host=[domain controller host]:host:_hosts'
  '-target-ip=[target IP]:ip:'
  '-target=[target DNS/IP]:target:_hosts'
  '-ns=[nameserver]:ip:'
  '-dns-tcp[use TCP for DNS]'
  '-timeout=[connection timeout]:seconds:'
  '(-u -username)'{-u,-username}'=[username]:user:'
  '(-p -password)'{-p,-password}'=[password]:pw:'
  '-hashes=[NTLM hash]:hash:'
  '-k[use Kerberos ccache]'
  '-aes=[AES key]:key:'
  '-no-pass[skip password prompt]'
  '-ldap-scheme=[LDAP scheme]:scheme:(ldap ldaps)'
  '-ldap-port=[LDAP port]:port:'
  '-no-ldap-channel-binding[disable LDAP channel binding]'
  '-no-ldap-signing[disable LDAP signing]'
  '-ldap-simple-auth[SIMPLE LDAP auth]'
  '-ldap-user-dn=[LDAP user DN]:dn:'
)

_arguments -C \
  '(-v -version --version)'{-v,-version,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-debug --debug)'{-debug,--debug}'[debug logging]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'certipy subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (account)
        _arguments -s \
          '1:action:(create read update delete)' \
          '-user=[SAM account name]:user:' \
          '-group=[group DN]:dn:' \
          '-dns=[DNS hostname]:hostname:' \
          '-upn=[UPN]:upn:' \
          '-sam=[SAM name]:name:' \
          '-spns=[SPNs]:spns:' \
          '-pass=[password]:pw:' \
          $target_args && ret=0 ;;
      (auth)
        _arguments -s \
          '-pfx=[PFX file]:file:_files' \
          '-password=[PFX password]:pw:' \
          '-no-save[do not save TGT]' \
          '-no-hash[no NT hash request]' \
          '-print[print TGT]' \
          '-kirbi[save as Kirbi]' \
          '-dc-ip=[DC IP]:ip:' \
          '-ns=[nameserver]:ip:' \
          '-dns-tcp[TCP DNS]' \
          '-timeout=[timeout]:seconds:' \
          '-username=[username]:user:' \
          '-domain=[domain]:domain:' \
          '-ldap-shell[Schannel-LDAP shell]' \
          '-ldap-scheme=[scheme]:scheme:(ldap ldaps)' \
          '-ldap-port=[port]:port:' \
          '-ldap-user-dn=[user DN]:dn:' && ret=0 ;;
      (ca)
        _arguments -s \
          '-ca=[CA name]:name:' \
          '-enable-template=[template]:name:' \
          '-disable-template=[template]:name:' \
          '-list-templates[list templates]' \
          '-issue-request=[request id]:id:' \
          '-deny-request=[request id]:id:' \
          '-add-officer=[officer]:officer:' \
          '-remove-officer=[officer]:officer:' \
          '-add-manager=[manager]:manager:' \
          '-remove-manager=[manager]:manager:' \
          '-backup[backup CA]' \
          '-config=[config string]:config:' \
          '-dynamic-endpoint[prefer dynamic TCP]' \
          $target_args && ret=0 ;;
      (cert)
        _arguments -s \
          '-pfx=[input PFX]:file:_files' \
          '-password=[PFX password]:pw:' \
          '-key=[private key]:file:_files' \
          '-cert=[certificate]:file:_files' \
          '-export[export to PFX]' \
          '-out=[output file]:file:_files' \
          '-nocert[key only]' \
          '-nokey[cert only]' \
          '-export-password=[output PFX password]:pw:' && ret=0 ;;
      (find)
        _arguments -s \
          '-text[output as text]' \
          '-stdout[text to console]' \
          '-json[JSON output]' \
          '-csv[CSV output]' \
          '-output=[output prefix]:prefix:' \
          '-enabled[only enabled]' \
          '-dc-only[DC-only]' \
          '-vulnerable[only vulnerable]' \
          '-oids[show OIDs]' \
          '-hide-admins[hide admin perms]' \
          '-sid=[user SID]:sid:' \
          '-dn=[user DN]:dn:' \
          $target_args && ret=0 ;;
      (forge)
        _arguments -s \
          '-ca-pfx=[CA PFX]:file:_files' \
          '-ca-password=[CA password]:pw:' \
          '-upn=[UPN]:upn:' \
          '-dns=[DNS]:dns:' \
          '-sid=[SID]:sid:' \
          '-subject=[subject]:subject:' \
          '-template=[template PFX]:file:_files' \
          '-issuer=[issuer]:issuer:' \
          '-crl=[CRL LDAP path]:path:' \
          '-serial=[serial]:serial:' \
          '*-application-policies=[OID]:oid:' \
          '-smime=[smime alg]:alg:(des rc4 3des aes128 aes192 aes256)' \
          '-key-size=[key size]:n:' \
          '-validity-period=[days]:days:' \
          '-out=[output file]:file:_files' \
          '-pfx-password=[PFX password]:pw:' && ret=0 ;;
      (parse)
        _arguments -s \
          '-text[text output]' \
          '-stdout[stdout]' \
          '-json[JSON]' \
          '-csv[CSV]' \
          '-output=[output prefix]:prefix:' \
          '-format=[format]:fmt:(bof reg oc2_bof)' \
          '-domain=[domain]:domain:' \
          '-ca=[CA name]:name:' \
          '-sids=[owned SIDs]:sids:' \
          '-published=[published templates]:list:' \
          '-enabled[only enabled]' \
          '-vulnerable[only vulnerable]' \
          '-hide-admins[hide admins]' \
          '-neo4j-user=[neo4j user]:user:' \
          '-neo4j-pass=[neo4j password]:pw:' \
          '-neo4j-host=[neo4j host]:host:_hosts' \
          '-neo4j-port=[neo4j port]:port:' \
          '-use-owned-sids[use owned SIDs]' \
          '*:input file:_files' && ret=0 ;;
      (relay)
        _arguments -s \
          '-target=[proto://host]:target:' \
          '-ca=[CA name]:name:' \
          '-template=[template]:name:' \
          '-upn=[UPN]:upn:' \
          '-dns=[DNS]:dns:' \
          '-sid=[SID]:sid:' \
          '-subject=[subject]:subject:' \
          '-retrieve=[request id]:id:' \
          '-key-size=[key size]:n:' \
          '-archive-key=[CAX cert]:file:_files' \
          '-pfx-password=[pfx password]:pw:' \
          '*-application-policies=[OID]:oid:' \
          '-smime=[smime alg]:alg:(des rc4 3des aes128 aes192 aes256)' \
          '-out=[output file]:file:_files' \
          '-interface=[listen IP]:ip:' \
          '-port=[listen port]:port:' \
          '-forever[keep relaying]' \
          '-no-skip[do not skip prior]' \
          '-enum-templates[enumerate templates]' \
          '-timeout=[timeout]:seconds:' && ret=0 ;;
      (req)
        _arguments -s \
          '-ca=[CA name]:name:' \
          '-template=[template]:name:' \
          '-upn=[UPN]:upn:' \
          '-dns=[DNS]:dns:' \
          '-sid=[SID]:sid:' \
          '-subject=[subject]:subject:' \
          '-retrieve=[request id]:id:' \
          '-on-behalf-of=[domain\\acct]:account:' \
          '-pfx=[PFX file]:file:_files' \
          '-pfx-password=[pfx password]:pw:' \
          '-key-size=[key size]:n:' \
          '-archive-key[archival key]' \
          '-cax-cert[retrieve CAX cert]' \
          '-renew[renewal request]' \
          '*-application-policies=[OID]:oid:' \
          '-smime=[smime alg]:alg:(des rc4 3des aes128 aes192 aes256)' \
          '-out=[output file]:file:_files' \
          '-web[web enrollment]' \
          '-dcom[DCOM enrollment]' \
          '-dynamic-endpoint[prefer dynamic TCP]' \
          '-http-scheme=[scheme]:scheme:(http https)' \
          '-http-port=[port]:port:' \
          '-no-channel-binding[disable channel binding]' \
          $target_args && ret=0 ;;
      (shadow)
        _arguments -s \
          '1:action:(list add remove clear info auto)' \
          '-account=[target]:account:' \
          '-device-id=[device id]:id:' \
          '-out=[output file]:file:_files' \
          $target_args && ret=0 ;;
      (template)
        _arguments -s \
          '-template=[template name]:name:' \
          '-write-configuration=[json file]:file:_files' \
          '-write-default-configuration[apply ESC1 defaults]' \
          '-save-configuration=[json file]:file:_files' \
          '-no-save[skip backup]' \
          '-force[no confirmation]' \
          $target_args && ret=0 ;;
    esac
    ;;
esac

return ret
