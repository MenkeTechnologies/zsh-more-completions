#compdef masky
# Documentation: https://github.com/Z4kSec/Masky
# Remotely dump domain user credentials via AD CS without dropping NTDS

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable debugging messages]' \
  '(-ts --timestamps)'{-ts,--timestamps}'[display timestamps for each log]' \
  '(-t --threads)'{-t,--threads}'+[threadpool size (max 15)]:threads:' \
  '(-d --domain)'{-d,--domain}'+[domain name to authenticate to]:domain:' \
  '(-u --user)'{-u,--user}'+[username to authenticate with]:user:' \
  '(-p --password)'{-p,--password}'+[password to authenticate with]:password:' \
  '(-k --kerberos)'{-k,--kerberos}'[use Kerberos authentication]' \
  '(-H --hashes)'{-H,--hashes}'+[hashes to authenticate with (LM:NT)]:hashes:' \
  '-dc-ip+[IP address of the domain controller]:ip:' \
  '(-ca --certificate-authority)'{-ca,--certificate-authority}'+[certificate authority (SERVER\\CA_NAME)]:ca:' \
  '(-nh --no-hash)'{-nh,--no-hash}'[do not request NT hashes]' \
  '(-nt --no-ccache)'{-nt,--no-ccache}'[do not save ccache files]' \
  '(-np --no-pfx)'{-np,--no-pfx}'[do not save pfx files]' \
  '(-o --output)'{-o,--output}'+[output folder for results]:dir:_files -/' \
  '*:targets:' && ret=0

return ret
