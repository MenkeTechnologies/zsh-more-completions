#compdef open-webui

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'serve:start the Open WebUI server'
  'dev:start in development mode'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'open-webui command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (serve)
        _arguments \
          '--host=[bind address]:host' \
          '--port=[bind port]:port' && ret=0
        ;;
      (dev)
        _arguments \
          '--host=[bind address]:host' \
          '--port=[bind port]:port' \
          '--reload[enable hot reload]' && ret=0
        ;;
    esac
    ;;
esac

return ret
