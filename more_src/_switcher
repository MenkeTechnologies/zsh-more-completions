#compdef switcher switch
# _switcher — Gardener kubeswitch enhanced kubectl context switcher with FZF picker and multi-kubeconfig support (danielfoehrkn team, Go); cobra
# upstream: https://github.com/danielfoehrKn/kubeswitch

_switcher() {
    local -a sub=(
        'history:list previously used contexts'
        'h:list previously used contexts'
        'alias:alias subcommands'
        'list-contexts:list available contexts'
        'ls:list available contexts'
        'gardener:gardener subcommands'
        'set-context:set namespace on context'
        'set-last-context:switch to last context'
        '-:switch to previous context'
        'init:init kubeconfig store'
        'completion:generate completion'
        'hooks:hook subcommands'
        'unset-context:unset current context'
        'clean:clean temp files'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--kubeconfig-path=+[path]:str:' \
        '--kubeconfig-name=+[name]:str:' \
        '--store=+[store type]:s:(filesystem vault gardener azure-aks gke eks rancher kubeconfig-store ocm)' \
        '--show-icons=+[bool]:b:(true false)' \
        '--show-preview=+[bool]:b:(true false)' \
        '--executor-shell=+[shell]:s:(bash zsh fish)' \
        '--no-index[skip index]' \
        '--debug[debug logs]' \
        '--vault-api-address=+[vault url]:url:_urls' \
        '--config-path=+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'switcher subcommand' sub ;;
        args)
            case $words[1] in
                alias) _arguments '1:alias cmd:(ls rm)' ;;
                gardener) _arguments '1:gardener cmd:(controlplane shoot)' ;;
                hooks) _arguments '1:hooks cmd:(run list)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_switcher "$@"
