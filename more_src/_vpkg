#compdef vpkg
# Documentation: https://github.com/vpkg-project/vpkg
# vpkg - an alternative package manager for the V programming language

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(- *)help[display the help message]' \
  '(- *)version[show the program version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a cmds
    cmds=(
      'get:fetch and install packages from the registry or a git repo'
      'install:read the manifest and install necessary packages'
      'update:update packages'
      'remove:remove packages'
      'info:show the project package information'
      'link:symlink the current module into .vmodules'
      'unlink:remove the symlink from .vmodules'
      'migrate:convert a manifest to another format'
      'init:create a package manifest in the current directory'
      'release:release a new module version'
      'test:test the current library or application'
      'help:display the help message'
      'version:show the program version'
    )
    _describe -t commands 'vpkg command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      get)
        _arguments -s \
          '--force[force download of packages]' \
          '(-g --global)'{-g,--global}'[install globally into .vmodules]' \
          '*:package:' && ret=0
        ;;
      remove)
        _arguments -s '*:package:' && ret=0
        ;;
      init|migrate)
        _arguments -s '--format=[manifest file format]:format:(vpkg vmod)' && ret=0
        ;;
      test)
        _arguments -s '--files=[comma-separated test file locations]:files:' && ret=0
        ;;
      release)
        _arguments -s \
          '--inc=[version part to increment]:part:(major minor patch)' \
          '--state=[release state]:state:(alpha beta fix)' && ret=0
        ;;
    esac
    ;;
esac

return ret
