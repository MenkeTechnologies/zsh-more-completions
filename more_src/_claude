#compdef claude claude-code
# _claude — Anthropic claude official Claude Code CLI for terminal-based AI software engineering (anthropic team, TypeScript); commander
# upstream: https://github.com/anthropics/claude-code

_claude() {
    local -a sub=(
        'config:configuration subcommands'
        'mcp:Model Context Protocol subcommands'
        'doctor:run diagnostic checks'
        'update:update Claude Code'
        'install:install Claude Code'
        'login:login with API key'
        'logout:logout and clear credentials'
        'help:show help'
        'version:show version'
        'review:run code review on changes'
        'history:show conversation history'
        'session:manage sessions'
        'project:project configuration'
        'completion:generate shell completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-p+[run prompt and exit]:str:' \
        '--print=+[run prompt and exit]:str:' \
        '-c[continue most recent conversation]' \
        '--continue[continue most recent conversation]' \
        '-r+[resume session ID]:str:' \
        '--resume=+[resume session ID]:str:' \
        '--model=+[model id]:m:(claude-opus-4-7 claude-sonnet-4-6 claude-haiku-4-5-20251001 claude-opus-4-7\[1m\] sonnet opus haiku)' \
        '--add-dir=+[add allowed dir]:dir:_files -/' \
        '--allowed-tools=+[tool csv]:str:' \
        '--disallowed-tools=+[tool csv]:str:' \
        '--mcp-config=+[mcp config]:file:_files -g "*.json"' \
        '--permission-mode=+[mode]:m:(default acceptAll acceptEdits bypassPermissions plan)' \
        '--debug[debug logging]' \
        '-d[debug logging]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json stream-json)' \
        '--max-turns=+[N]:n:' \
        '--system-prompt=+[prompt]:str:' \
        '--append-system-prompt=+[prompt]:str:' \
        '--input-format=+[format]:f:(text stream-json)' \
        '--dangerously-skip-permissions[no permission prompts]' \
        '--ide[IDE mode]' \
        '--fast[fast Opus mode]' \
        '--strict-mcp-config[strict mcp config]' \
        '--no-banner[no banner]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'claude subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments '1:config cmd:(get set unset list reset show)' ;;
                mcp) _arguments '1:mcp cmd:(list get add remove enable disable serve)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                session) _arguments '1:session cmd:(list show clear delete export resume)' ;;
                project) _arguments '1:project cmd:(get set unset list)' ;;
            esac
            ;;
    esac
}

_claude "$@"
