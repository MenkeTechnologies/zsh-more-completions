#compdef qrelease
# Documentation: https://man.archlinux.org/search?q=qrelease
# Reference accessed: 2026-05-16

# qrelease: release a held PBS job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-W[wait]:delay:' \
  '-t[type]:type:(u o s)' \
  '*:jobid:' && ret=0
return ret
