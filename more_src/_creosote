#compdef creosote
# _creosote — Python unused dependency finder
# upstream: https://github.com/fredrikaverpil/creosote

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--paths=[paths to scan for imports]:paths' \
  '--exclude-deps=[dependencies to exclude from check]:deps' \
  '--deps-file=[path to dependency file]:file:_files' \
  '--sections=[dependency sections to check]:sections' \
  '--format=[output format]:format:(default no-color porcelain)' \
  '--no-virtualenv[do not scan virtual environment for identifiers]' \
  '-v[increase verbosity]' \
  '--verbose[increase verbosity]' && ret=0

return ret
