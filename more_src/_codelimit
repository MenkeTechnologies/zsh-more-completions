#compdef codelimit
# Documentation: https://getcodelimit.github.io/getting-started/standalone-usage/
# Reference accessed: 2026-05-16
# Verified: getcodelimit.github.io standalone usage docs.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h short for --help; missing real subcommands.

# codelimit: refactoring alarm CLI
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'check:check files/directories'
  'scan:scan a codebase'
  'report:produce reports'
  'app:start web UI'
)

_arguments -C \
  '--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '*--exclude=[glob exclusion pattern (repeatable)]:pattern:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'codelimit command' commands && ret=0 ;;
  (args) _files ;;
esac
return ret
