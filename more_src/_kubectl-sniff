#compdef kubectl-sniff
# Documentation: https://man.archlinux.org/search?q=kubectl-sniff
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-n[namespace]:namespace:' \
  '-c[container name]:container:' \
  '-p[privileged mode]' \
  '--socket-path=[path for socket volume]:path:' \
  '--privileged-node[run on node with hostPID]' \
  '--minikube[assume minikube cluster]' \
  '--image=[sniffer image]:image:' \
  '--tcpdump-filter=[bpf filter expression]:filter:' \
  '--timeout=[capture duration]:duration:' \
  '--proxy-timeout=[port-forward timeout]:duration:' \
  '1:pod: _default'
