#compdef i2pd
# Documentation: https://man.archlinux.org/man/i2pd.1.en
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# i2pd — full-featured C++ I2P router (PurpleI2P/i2pd)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--help[display available options]' \
  '--conf=[config file path]:file:_files' \
  '--tunconf=[tunnels config file]:file:_files' \
  '--tunnelsdir=[tunnels config directory]:dir:_files -/' \
  '--pidfile=[PID file location]:file:_files' \
  '--log=[logs destination]:dest:(stdout file syslog)' \
  '--logfile=[logfile path]:file:_files' \
  '--loglevel=[minimum log level]:level:(debug info warn error none)' \
  '--logclftime[enable CLF-formatted timestamps]' \
  '--datadir=[i2pd data storage path]:dir:_files -/' \
  '--host=[external IP address]:host' \
  '--port=[listening port]:port' \
  '--ifname=[bind to network interface]:iface' \
  '--ifname4=[bind to IPv4 interface]:iface' \
  '--ifname6=[bind to IPv6 interface]:iface' \
  '--ipv4=[enable/disable IPv4]:bool:(true false)' \
  '--ipv6[enable IPv6]' \
  '--ntcp=[enable/disable NTCP transport]:bool:(true false)' \
  '--ntcpproxy=[NTCP proxy URL]:url' \
  '--ssu=[enable/disable SSU transport]:bool:(true false)' \
  '--notransit[reject transit tunnels at startup]' \
  '--floodfill[enable floodfill router mode]' \
  '--bandwidth=[bandwidth limit]:bw' \
  '--share=[transit traffic percentage limit]:pct' \
  '--daemon[run in background]' \
  '--service[use system folders]' \
  '--family=[assign family name]:name' && ret=0

return ret
