#compdef 3dsp
# Documentation: https://github.com/bluez/bluez/blob/master/tools/3dsp.c
# Source: BlueZ tools/3dsp.c — 3D Synchronization Profile tester (display / glasses roles).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-D --display -G --glasses)'{-D,--display}'[use display role]' \
    '(-D --display -G --glasses)'{-G,--glasses}'[use glasses role]' \
    '(-i --index)'{-i+,--index=}'[controller index]:num:' \
    '(-r --raw)'{-r,--raw}'[raw device mode]' \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
