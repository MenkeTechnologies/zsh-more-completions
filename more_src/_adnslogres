#compdef adnslogres adnsheloex
# Documentation: adnslogres --help (GNU adns)
# Source: replace IP addresses in web/mail logs with names via GNU adns.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '-c+[max outstanding queries]:concurrency:' \
    '-p[use poll(2) instead of select(2)]' \
    '-d[debug output]' \
    '-C+[config text override of resolv.conf]:config:' \
    '1:log file:_files' \
    && ret=0

return ret
