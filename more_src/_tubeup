#compdef tubeup
# Documentation: https://man.archlinux.org/search?q=tubeup
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-q --quiet)'{-q,--quiet}'[only output errors]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-m --metadata)*'{-m+,--metadata=}'[metadata key=value]:kv:' \
  '--cookies=[cookies file]:file:_files' \
  '--proxy=[proxy URL]:url:' \
  '--username=[site username]:user:' \
  '--password=[site password]:password:' \
  '--ignore-existing-item[overwrite existing IA item]' \
  '--use-download-archive[use yt-dlp download archive]' \
  '--quiet-ia[suppress IA output]' \
  '*::url:' && ret=0

return ret
