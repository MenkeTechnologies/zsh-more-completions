#compdef mri_cc
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_cc
# FreeSurfer segment the corpus callosum

local ret=1

_arguments -s -S \
  '-o[write aseg including CC to output volume]:output volume:_files' \
  '-aseg[read aseg from volume]:aseg volume:_files' \
  '-sdir[set SUBJECTS_DIR]:directory path:_files -/' \
  '-lta[write rotation lta to file]:fname:_files' \
  '-f[include fornix in segmentation]' \
  '-force[process regardless of existing CC in input]' \
  '-d[subdivide into N segments]:int:' \
  '-t[set CC thickness to N mm off midline]:int:' \
  '-s[skip N voxels in rotational align]:int:' \
  '-m[max of rotations searched (default 7deg)]:float:' \
  '*:subject:' && ret=0

return ret
