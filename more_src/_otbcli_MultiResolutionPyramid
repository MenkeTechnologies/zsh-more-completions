#compdef otbcli_MultiResolutionPyramid
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_MultiResolutionPyramid.html
# Orfeo ToolBox: build a multi-resolution pyramid of an image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image file]:image:_files' \
  '-out[output image file with prefix and extension]:output:_files' \
  '-level[number of levels in the pyramid]:value:' \
  '-sfactor[subsampling factor between levels]:value:' \
  '-vfactor[variance factor used in smoothing]:value:' \
  '-fast[iteratively subsample previous level]:bool:(true false)' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
