#compdef ovitos
# Documentation: https://www.ovito.org/manual/python/introduction/advanced_topics.html
# OVITO scripting interpreter (headless console runner for Python pipeline scripts)

local ret=1

_arguments -s -S \
  '-o[load .ovito session state file before executing script]:state file:_files -g "*.ovito"' \
  '-g[start a graphical program session to follow script actions]' \
  '--nthreads=[restrict to this number of parallel CPU threads]:threads' \
  '-m[run a library module as a script (e.g. pip)]:module' \
  '*:script:_files -g "*.py"' && ret=0

return ret
