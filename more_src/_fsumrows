#compdef fsumrows
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fsumrows.txt
# Sum or average values from table columns over a range of rows

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "outfile=[output FITS file]:file:_files" \
  "cols=[columns to operate on]:" \
  "rows=[range of rows]:" \
  "operation=[sum or average]:op:(sum average)" \
  "nullval=[null value]:" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "sametype=[keep same data type]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
