#compdef blockmean blockmedian blockmode
# Documentation: https://docs.generic-mapping-tools.org/latest/blockmean.html
# Source: GenericMappingTools/gmt classic-mode blockmean/blockmedian/blockmode — bin and reduce (x,y,z) into block means/medians/modes.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-A+[fields to write to individual grids]:fields:_default' \
    '-C[output block center as location (not mean)]' \
    '-E+[extended report (stddev/min/max)]:opts:_default' \
    '-G+[write directly to grid files]:file:_files' \
    '-S+[output statistic]:stat:(m n s w)' \
    '*-V[verbose (stackable)]' \
    '-W+[weighted I/O]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-d+[nodata↔NaN replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-r[pixel registration (default gridline)]' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
