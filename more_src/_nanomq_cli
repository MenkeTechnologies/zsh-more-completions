#compdef nanomq_cli
# Documentation: https://nanomq.io/docs/en/latest/toolkit/command-line.html
# nanomq_cli - NanoMQ command-line client (pub/sub/conn/rules)

local ret=1
local -a cmds

cmds=(
  'pub:publish messages to a topic'
  'sub:subscribe to a topic'
  'conn:create connections to a broker'
  'rules:manage SQL rules'
)

_arguments -s -S \
  '(-h --host)'{-h,--host}'[broker host]:host:_hosts' \
  '(-p --port)'{-p,--port}'[broker port]:port:' \
  '(-u --user)'{-u,--user}'[username]:user:' \
  '(-P --password)'{-P,--password}'[password]:password:' \
  '(-q --qos)'{-q,--qos}'[QoS level]:qos:(0 1 2)' \
  '(-t --topic)'{-t,--topic}'[MQTT topic]:topic:' \
  '(-s --ssl)'{-s,--ssl}'[enable SSL/TLS]' \
  '--cert[certificate file]:file:_files' \
  '--key[private key file]:file:_files' \
  '--keypass[private key password]:password:' \
  '(-k --keepalive)'{-k,--keepalive}'[keep alive in seconds]:n:' \
  '(-c --clean_session)'{-c,--clean_session}'[clean session]:bool:(true false)' \
  '(-m --msg)'{-m,--msg}'[message payload (pub)]:msg:' \
  '(-r --retain)'{-r,--retain}'[set retain flag (pub)]' \
  '(-C --count)'{-C,--count}'[number of messages (pub)]:n:' \
  '(-L --limit)'{-L,--limit}'[message limit (pub)]:n:' \
  '(-I --interval)'{-I,--interval}'[interval between messages (pub)]:n:' \
  '(-l --stdin-line)'{-l,--stdin-line}'[read message per line from stdin (pub)]' \
  '--will-topic[last will topic]:topic:' \
  '--will-msg[last will message]:msg:' \
  '--will-qos[last will QoS]:qos:(0 1 2)' \
  '--will-retain[last will retain flag]' \
  '--create[create a rule (rules)]' \
  '--list[list rules (rules)]' \
  '--show[show a rule (rules)]' \
  '--delete[delete a rule (rules)]' \
  '--id[rule id (rules)]:id:' \
  '--sql[rule SQL statement (rules)]:sql:' \
  '--actions[rule actions (rules)]:actions:' \
  '1:command:->cmd' && ret=0

case $state in
  cmd) _describe -t commands 'nanomq_cli command' cmds && ret=0 ;;
esac

return ret
