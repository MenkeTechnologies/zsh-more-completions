#compdef cargo-graph
# Documentation: https://crates.io/crates/cargo-graph
# build GraphViz DOT files of dependency graphs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-I --include-versions)'{-I,--include-versions}'[include the dependency version on nodes]' \
  '--build-color[color for regular deps]:color' \
  '--build-deps[should build deps be in the graph?]:value:(true false)' \
  '--build-line-color[line color for regular deps]:color' \
  '--build-line-style[line style for build deps]:style' \
  '--build-shape[shape for regular deps]:shape' \
  '--dev-color[color for dev deps]:color' \
  '--dev-deps[should dev deps be included?]:value:(true false)' \
  '--dev-line-color[line color for dev deps]:color' \
  '--dev-line-style[line style for dev deps]:style' \
  '--dev-shape[shape for dev deps]:shape' \
  '--dot-file[output file (default stdout)]:file:_files' \
  '--lock-file[location of .lock file]:file:_files' \
  '--manifest-file[location of manifest file]:file:_files' \
  '--optional-color[color for optional deps]:color' \
  '--optional-deps[should optional deps be in the graph?]:value:(true false)' \
  '--optional-line-color[line color for optional deps]:color' \
  '--optional-line-style[line style for optional deps]:style' \
  '--optional-shape[shape for optional deps]:shape' && ret=0

return ret
