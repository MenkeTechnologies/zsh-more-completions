#compdef condor_q

# condor_q: query Condor job queue
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-pool[pool]:pool:' \
  '-name[schedd]:name:' \
  '-submitter[submitter]:user:_users' \
  '-jobads[parse jobs from file]:file:_files' \
  '-userlog[read from userlog file]:file:_files' \
  '-direct[direct query]:target:(schedd quill scheddrad)' \
  '-cluster[cluster id]:n:' \
  '-procid[process id]:n:' \
  '-global[global query]' \
  '-tot[totals only]' \
  '-totals[totals only]' \
  '-attributes[attributes]:list:' \
  '-format[printf format]:format attr:' \
  '-autoformat[autoformat]:list:' \
  '-af[autoformat]:list:' \
  '-print-format[print format file]:file:_files' \
  '-long[long format]' \
  '-l[long format]' \
  '-xml[XML output]' \
  '-json[JSON output]' \
  '-better-analyze[full analysis]' \
  '-analyze[analyze]' \
  '-run[show running]' \
  '-hold[show held]' \
  '-goodput[show goodput]' \
  '-cputime[show CPU time]' \
  '-currentrun[show current run]' \
  '-io[show IO stats]' \
  '-dag[group by DAG]' \
  '-nobatch[no batch group]' \
  '-batch[batch group (default)]' \
  '-all[show all jobs]' \
  '-allusers[show all users]' \
  '-constraint[constraint expression]:expr:' \
  '*:jobid or user:' && ret=0
return ret
