#compdef condor_q
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_q.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_q: query the HTCondor job queue.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-pool[pool]:pool:' \
  '-name[schedd name]:name:' \
  '-submitter[show jobs for submitter]:user:_users' \
  '-jobads[parse jobs from file]:file:_files' \
  '-userlog[read from user log file]:file:_files' \
  '-global[query all schedds]' \
  '-totals[totals only]' \
  '-factory[show late-materialization factories]' \
  '-jobset[show job sets]' \
  '-autocluster[show autocluster summaries]' \
  '-cputime[show CPU time]' \
  '-currentrun[show current run time only]' \
  '-cumulative-time[show cumulative time]' \
  '-dag[group by DAG]' \
  '-expert[expert output]' \
  '-grid[show grid jobs]' \
  '-grid\:ec2[show grid EC2 jobs]' \
  '-hold[show held jobs]' \
  '-hold-codes[show hold codes]' \
  '-limit[max jobs to display]:n:' \
  '-io[show IO stats]' \
  '-idle[show idle jobs]' \
  '-run[show running jobs]' \
  '-stream-results[stream results as available]' \
  '-wide[wide output]' \
  '-attributes[attributes list]:list:' \
  '-format[printf-style format]:format attr:' \
  '-autoformat[autoformat list]:list:' \
  '-af[autoformat list]:list:' \
  '-aaf[autoformat list (all)]:list:' \
  '-print-format[print-format file]:file:_files' \
  '(-l --long)-l[long ClassAd format]' \
  '-long[long ClassAd format]' \
  '-xml[XML output]' \
  '-json[JSON output]' \
  '-better-analyze[full analysis]' \
  '-analyze[analyze]' \
  '-machine[analyze against named machine]:machine:_hosts' \
  '-mconstraint[machine constraint expression]:expr:' \
  '-slotads[parse slot ads from file]:file:_files' \
  '-userprios[include user priorities in analysis]' \
  '-nouserprios[skip user priorities in analysis]' \
  '-reverse-analyze[reverse analyze]' \
  '-verbose[verbose]' \
  '-nobatch[no batch grouping]' \
  '-batch[batch grouping (default)]' \
  '-allusers[show all users]' \
  '-constraint[constraint expression]:expr:' \
  '-unmatchable[show jobs that cannot match]' \
  '*:jobid or user:' && ret=0
return ret
