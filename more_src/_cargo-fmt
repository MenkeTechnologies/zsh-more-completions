#compdef cargo-fmt
# Documentation: cargo fmt --help
# Source: Rust cargo-fmt — format all bin and lib files of the current crate via rustfmt.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-q --quiet -v --verbose)'{-q,--quiet}'[no output to stdout]' \
    '(-q --quiet -v --verbose)'{-v,--verbose}'[verbose output]' \
    '(- *)--version[print rustfmt version and exit]' \
    '*'{-p,--package=}'[package to format]:package:' \
    '--manifest-path=[Cargo.toml path]:file:_files -g "Cargo.toml"' \
    '--message-format=[message format]:format:(short json human)' \
    '--all[format all packages and local path deps]' \
    '--check[run rustfmt in check mode]' \
    '(- *)'{-h,--help}'[print help]' \
    '*::rustfmt options:_files' \
    && ret=0

return ret
