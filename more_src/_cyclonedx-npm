#compdef cyclonedx-npm
# Documentation: https://github.com/CycloneDX/cyclonedx-node-npm
# cyclonedx-npm: generate CycloneDX SBOM from npm projects

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[output version number]' \
  '--ignore-npm-errors[ignore errors of npm]' \
  '--package-lock-only[only use the lock file, ignoring node_modules]' \
  '*--omit[dependency types to omit from the installation tree]:type:(dev optional peer)' \
  '*'{-w,--workspace}'[only include dependencies for specific workspaces]:workspace:' \
  '--no-workspaces[do not include dependencies for workspaces]' \
  '--include-workspace-root[include workspace root dependencies]' \
  '--no-include-workspace-root[do not include workspace root dependencies]' \
  '--gather-license-texts[include license files as license evidence]' \
  '--flatten-components[flatten the components]' \
  '--short-PURLs[omit all qualifiers from PackageURLs]' \
  '(--sv --spec-version)'{--sv,--spec-version}'[CycloneDX spec version]:version:(1.2 1.3 1.4 1.5 1.6)' \
  '--output-reproducible[make the output reproducible]' \
  '(--of --output-format)'{--of,--output-format}'[output format]:format:(JSON XML)' \
  '(-o --output-file)'{-o,--output-file}'[path to output file (- for STDOUT)]:file:_files' \
  '--validate[validate resulting BOM before outputting]' \
  '--no-validate[disable validation of resulting BOM]' \
  '--mc-type[type of the main component]:type:(application firmware library)' \
  '(-v --verbose)'{-v,--verbose}'[increase the verbosity of messages]' \
  '*:package manifest:_files -g "*.json"' && ret=0

return ret
