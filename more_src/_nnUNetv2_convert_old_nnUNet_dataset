#compdef nnUNetv2_convert_old_nnUNet_dataset
# Documentation: https://github.com/MIC-DKFZ/nnUNet/blob/master/documentation/how_to_use_nnunet.md
# Convert an nnU-Net v1 dataset to the v2 layout

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:input folder (v1 dataset):_files -/' \
  '2:output dataset name:' && ret=0

return ret
