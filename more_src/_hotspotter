#compdef hotspotter
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/spotter/hotspotter.html
# Source: GenericMappingTools/gmt supplements/spotter — Cumulative Volcanic Amplitude (CVA) grid from seamount paths.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E+[rotation (file / plate IDs / lon/lat/angle)]:opts:_default' \
    '-G+[output grid file]:file:_files' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-D+[sampling interval along flowlines (default 0.5)]:value:_default' \
    '-N+[upper age for unknown-crust seamounts]:age:_default' \
    '-S[normalize CVA to percent of max]' \
    '-T[truncate seamount ages over upper limit]' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-qi+[input row selection]:opts:_default' \
    '-r[pixel registration (default gridline)]' \
    '-:[swap first two columns]' \
    '*:input seamount table:_files' \
    && ret=0

return ret
