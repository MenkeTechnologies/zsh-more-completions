#compdef jwt-term
# Documentation: https://man.archlinux.org/search?q=jwt-term
# Reference accessed: 2026-05-16
# Source: cargo binstall jwt-term@1.1.4
# Probed via: completions zsh
# Repository: https://github.com/felipemorandini/jwt-term

autoload -U is-at-least

_jwt-term() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_jwt-term_commands" \
"*::: :->jwt-term" \
&& ret=0
    case $state in
    (jwt-term)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:jwt-term-command-$line[1]:"
        case $line[1] in
            (decode)
_arguments "${_arguments_options[@]}" : \
'--token-env=[Read the token from the specified environment variable]:VAR_NAME:_default' \
'--json[Output raw JSON without colors (machine-readable)]' \
'-h[Print help]' \
'--help[Print help]' \
'::token -- The JWT token to decode. If omitted, reads from stdin:_default' \
&& ret=0
;;
(verify)
_arguments "${_arguments_options[@]}" : \
'--token-env=[Read the token from the specified environment variable]:VAR_NAME:_default' \
'--secret=[HMAC shared secret for signature validation]:SECRET:_default' \
'--secret-env=[Read the HMAC secret from the specified environment variable]:VAR_NAME:_default' \
'--key-file=[Path to a PEM-encoded public key file (RSA, ECDSA, or EdDSA)]:FILE:_files' \
'--jwks-url=[URL of a JWKS endpoint for remote key discovery]:URL:_default' \
'--time-travel=[Simulate a different current time for expiry/nbf checks]:EXPR:_default' \
'--json[Output raw JSON without colors (machine-readable)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::token -- The JWT token to verify. If omitted, reads from stdin:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_jwt-term__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:jwt-term-help-command-$line[1]:"
        case $line[1] in
            (decode)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(verify)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_jwt-term_commands] )) ||
_jwt-term_commands() {
    local commands; commands=(
'decode:Decode and inspect a JWT without verifying its signature' \
'verify:Verify a JWT'\''s signature using a secret, key file, or JWKS endpoint' \
'completions:Generate shell completions for the specified shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'jwt-term commands' commands "$@"
}
(( $+functions[_jwt-term__completions_commands] )) ||
_jwt-term__completions_commands() {
    local commands; commands=()
    _describe -t commands 'jwt-term completions commands' commands "$@"
}
(( $+functions[_jwt-term__decode_commands] )) ||
_jwt-term__decode_commands() {
    local commands; commands=()
    _describe -t commands 'jwt-term decode commands' commands "$@"
}
(( $+functions[_jwt-term__help_commands] )) ||
_jwt-term__help_commands() {
    local commands; commands=(
'decode:Decode and inspect a JWT without verifying its signature' \
'verify:Verify a JWT'\''s signature using a secret, key file, or JWKS endpoint' \
'completions:Generate shell completions for the specified shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'jwt-term help commands' commands "$@"
}
(( $+functions[_jwt-term__help__completions_commands] )) ||
_jwt-term__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'jwt-term help completions commands' commands "$@"
}
(( $+functions[_jwt-term__help__decode_commands] )) ||
_jwt-term__help__decode_commands() {
    local commands; commands=()
    _describe -t commands 'jwt-term help decode commands' commands "$@"
}
(( $+functions[_jwt-term__help__help_commands] )) ||
_jwt-term__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'jwt-term help help commands' commands "$@"
}
(( $+functions[_jwt-term__help__verify_commands] )) ||
_jwt-term__help__verify_commands() {
    local commands; commands=()
    _describe -t commands 'jwt-term help verify commands' commands "$@"
}
(( $+functions[_jwt-term__verify_commands] )) ||
_jwt-term__verify_commands() {
    local commands; commands=()
    _describe -t commands 'jwt-term verify commands' commands "$@"
}

if [ "$funcstack[1]" = "_jwt-term" ]; then
    _jwt-term "$@"
else
    compdef _jwt-term jwt-term
fi
