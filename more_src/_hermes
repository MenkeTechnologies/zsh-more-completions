#compdef hermes
# Documentation: https://man.archlinux.org/search?q=hermes
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '-c+[JSON config file]:file:_files -g "*.toml(-.)"' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'start:Start the multi-chain relayer'
      'listen:Listen for events over IBC subscriptions'
      'tx:Submit relayer transactions'
      'query:Query clients, connections, and channels'
      'create:Create clients, connections, or channels'
      'keys:Manage chain signing keys'
      'clear:Clear packets or counters'
      'health-check:Probe RPC endpoints'
      'config:Inspect Hermes configuration'
      'completions:Generate shell completions'
      'help:Help about any command'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
