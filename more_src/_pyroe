#compdef pyroe
# Documentation: https://pyroe.readthedocs.io/en/latest/
# pyroe: prepare references and process alevin-fry quantification results

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--filename-prefix=[output file name prefix]:prefix:' \
  '--flank-trim-length=[amount subtracted from read length for flank length]:length:' \
  '--extra-spliced=[extra spliced sequence FASTA file]:fasta:_files' \
  '--extra-unspliced=[extra unspliced sequence FASTA file]:fasta:_files' \
  '--bt-path=[path to bedtools v2.30.0 or greater]:path:_files' \
  '--no-bt[use biopython instead of bedtools]' \
  '--dedup-seqs[deduplicate identical sequences]' \
  '--no-flanking-merge[do not merge introns with added flanking length]' \
  '--write-clean-gtf[write clean GTF if invalid records encountered]' \
  '--format=[input annotation format: GTF or GFF3]:format:(GTF GFF3)' \
  '--fetch_dir=[directory to store downloaded datasets]:dir:_files -/' \
  '--force[redownload existing datasets by force]' \
  '--delete_tar[delete fetched tar files after extraction]' \
  '--quiet[suppress help messages]' \
  '1:command:(make-splici make-spliced+intron make-spliced+unspliced fetch-quant id-to-name convert)' \
  '*::args:_files' && ret=0

return ret
