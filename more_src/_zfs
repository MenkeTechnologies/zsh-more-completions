#compdef zfs
# Documentation: https://openzfs.github.io/openzfs-docs/man/master/8/zfs.8.html
# Reference accessed: 2026-05-29
# OpenZFS filesystem CLI.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'create:create a new ZFS filesystem or volume'
  'destroy:destroy datasets, snapshots, or bookmarks'
  'list:list property information for datasets in tabular form'
  'rename:rename a filesystem or snapshot'
  'upgrade:upgrade the on-disk version of filesystems'
  'snapshot:create snapshots with the given names'
  'snap:alias for snapshot'
  'rollback:roll back a dataset to a previous snapshot'
  'hold:add a hold reference to a snapshot'
  'release:remove a hold reference from a snapshot'
  'holds:show snapshots with holds'
  'diff:show differences between two snapshots'
  'clone:create a clone of the given snapshot'
  'promote:make a clone independent from its origin snapshot'
  'send:generate a send stream for replication'
  'receive:create snapshots from a stream'
  'recv:alias for receive'
  'bookmark:create a new bookmark of a snapshot or bookmark'
  'get:display properties for the given datasets'
  'set:set property values'
  'inherit:clear specified properties to inherit from ancestors'
  'mount:display or mount ZFS filesystems'
  'unmount:unmount mounted ZFS filesystems'
  'umount:alias for unmount'
  'share:share filesystems via NFS/SMB'
  'unshare:unshare filesystems'
  'allow:delegate administrative permissions'
  'unallow:remove delegated permissions'
  'load-key:load encryption keys'
  'unload-key:unload encryption keys'
  'change-key:change encryption keys'
  'jail:attach filesystem to FreeBSD jail'
  'unjail:detach filesystem from FreeBSD jail'
  'program:execute ZFS channel program'
  'project:manage projects'
  'projectspace:show project space usage'
  'redact:create redacted snapshot'
  'wait:wait for activity on dataset'
  'version:show ZFS version'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'zfs subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments \
          '-p[create non-existent parent datasets]' \
          '-u[do not mount filesystem after creation]' \
          '*-o[property=value]:property:' \
          '-s[create sparse volume (volumes only)]' \
          '-V[create volume of given size]:size:' \
          '-b[block size]:size:' \
          '*:dataset:' && ret=0
        ;;
      destroy)
        _arguments \
          '-r[recursively destroy descendents]' \
          '-R[recursively destroy clones too]' \
          '-f[force unmount before destroy]' \
          '-d[defer destroy when there are holds]' \
          '-n[dry run]' \
          '-p[parsable output]' \
          '-v[verbose]' \
          '*:dataset/snapshot:' && ret=0
        ;;
      snapshot|snap)
        _arguments \
          '-r[recursively snapshot all descendents]' \
          '*-o[property=value]:property:' \
          '*:dataset@snapname:' && ret=0
        ;;
      send)
        _arguments \
          '-D[deduplicated stream]' \
          '-I[incremental send from origin to dest]:snapshot:' \
          '-i[incremental from snapshot]:snapshot:' \
          '-R[replicate descendants]' \
          '-L[allow large blocks]' \
          '-e[embed data]' \
          '-c[compressed stream]' \
          '-h[holds]' \
          '-n[dry run]' \
          '-p[include properties]' \
          '-P[parseable output]' \
          '-v[verbose]' \
          '-r[raw encrypted stream]' \
          '-w[encrypted (raw) stream]' \
          ':snapshot:' && ret=0
        ;;
      receive|recv)
        _arguments \
          '-d[discard source path prefix]' \
          '-e[discard everything but the snapshot name]' \
          '-F[force rollback]' \
          '-h[hold the received snapshots]' \
          '-n[dry run]' \
          '-u[do not mount filesystem]' \
          '-v[verbose]' \
          '-A[abort partial receive]' \
          '-o[property=value]:property:' \
          '-x[exclude property]:property:' \
          '-s[save partial receive state]' \
          ':target dataset:' && ret=0
        ;;
      list)
        _arguments \
          '-r[recursive]' \
          '-d[recursion depth]:depth:' \
          '-H[scripted output (no headers)]' \
          '-o[properties (CSV)]:properties:' \
          '-s[sort by property]:property:' \
          '-S[reverse sort by property]:property:' \
          '-t[filter by type (filesystem/snapshot/volume/bookmark/all)]:type:(filesystem snapshot volume bookmark all)' \
          '-p[parsable output]' \
          '*:dataset:' && ret=0
        ;;
      get)
        _arguments \
          '-r[recursive]' \
          '-d[recursion depth]:depth:' \
          '-H[scripted output]' \
          '-p[parsable output]' \
          '-s[source filter]:source:(local default inherited received temporary)' \
          '-o[output fields]:fields:' \
          '-t[type filter]:type:(filesystem snapshot volume bookmark all)' \
          ':property:' \
          '*:dataset:' && ret=0
        ;;
      set)
        _arguments \
          '-u[do not update mount/share state]' \
          ':property=value:' \
          '*:dataset:' && ret=0
        ;;
      mount|unmount|umount)
        _arguments \
          '-a[mount/unmount all filesystems]' \
          '-O[overlay mount]' \
          '-v[verbose]' \
          '-f[force unmount]' \
          '*-o[mount options]:option:' \
          '*:dataset:' && ret=0
        ;;
      rollback)
        _arguments \
          '-r[destroy later snapshots]' \
          '-R[destroy later snapshots and clones]' \
          '-f[force unmount of any clones]' \
          ':snapshot:' && ret=0
        ;;
      clone)
        _arguments \
          '-p[create non-existent parent datasets]' \
          '*-o[property=value]:property:' \
          ':snapshot:' \
          ':clone:' && ret=0
        ;;
      diff)
        _arguments \
          '-F[indicate file type]' \
          '-H[scripted output]' \
          '-t[display modification times]' \
          ':snapshot1:' \
          '*:snapshot-or-fs:' && ret=0
        ;;
    esac
    ;;
esac

return ret
