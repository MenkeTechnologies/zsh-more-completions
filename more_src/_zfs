#compdef zfs
# _zfs-cli — ZFS dataset administration; create/destroy/snapshot/clone/send/receive ZFS datasets (OpenZFS)
# upstream: https://github.com/openzfs/zfs

_zfs-cli() {
    local -a sub=(
        'create:create dataset/volume'
        'destroy:destroy dataset/snapshot/bookmark'
        'snapshot:create snapshot'
        'rollback:rollback to a snapshot'
        'clone:create clone from snapshot'
        'promote:promote clone'
        'rename:rename dataset/snapshot'
        'list:list datasets'
        'set:set property'
        'get:get property'
        'inherit:inherit property'
        'send:send replication stream'
        'receive:receive replication stream'
        'recv:alias for receive'
        'mount:mount dataset'
        'unmount:unmount dataset'
        'share:share dataset'
        'unshare:unshare dataset'
        'allow:delegate permissions'
        'unallow:revoke permissions'
        'hold:hold snapshot'
        'release:release snapshot hold'
        'holds:list holds'
        'bookmark:create bookmark'
        'channel-program:run channel program'
        'diff:diff snapshots'
        'load-key:load encryption key'
        'unload-key:unload encryption key'
        'change-key:change encryption key'
        'jail:jail dataset'
        'unjail:unjail dataset'
        'program:run zfs channel program'
        'redact:create redacted snapshot'
        'wait:wait for activity'
        'project:manage project quotas'
        'projectspace:project space accounting'
        'userspace:user space accounting'
        'groupspace:group space accounting'
        'upgrade:upgrade dataset version'
        'version:show ZFS version'
    )
    _arguments -C \
        '-?[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zfs subcommand' sub ;;
        args)
            case $words[1] in
                destroy|rename|list|mount|unmount|share|unshare|snapshot|hold|release|holds|rollback|promote|diff) _arguments '*:dataset:' ;;
            esac
            ;;
    esac
}

_zfs-cli "$@"
