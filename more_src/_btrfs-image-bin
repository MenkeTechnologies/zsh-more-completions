#compdef btrfs-image
# _btrfs-image-bin — dump btrfs metadata to an image for debugging (btrfs-progs); save FS metadata to a sparse file
# upstream: https://github.com/kdave/btrfs-progs

_btrfs-image-bin() {
    _arguments \
        '-r[restore image]' \
        '-c+[compression level]:n:' \
        '-t+[threads]:n:' \
        '-w[walk all trees]' \
        '-m[restore for multiple device fs]' \
        '-o[do not mirror copies]' \
        '-s[sanitize file names]' \
        '-ss[sanitize file names + offsets]' \
        '-sss[sanitize names + offsets + sums]' \
        '-h[show help]' \
        '-V[show version]' \
        '1:device or source image:_files' \
        '2:image or device:_files'
}

_btrfs-image-bin "$@"
