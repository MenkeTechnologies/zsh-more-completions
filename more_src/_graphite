#compdef gt

# Zsh completion for gt (Graphite) - stacking tool for Git

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--quiet[suppress output]' \
  '--debug[enable debug logging]' \
  '--no-interactive[disable interactive prompts]' \
  '--no-verify[skip pre-commit hooks]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case "$state" in
  subcmd)
    local -a subcmds=(
      'auth:authenticate with Graphite'
      'branch:manage branches'
      'commit:manage commits'
      'completion:generate shell completions'
      'dash:open the Graphite dashboard'
      'demo:run a demo of Graphite'
      'docs:open the Graphite documentation'
      'downstack:manage the downstack'
      'feedback:provide feedback'
      'init:initialize Graphite in a repository'
      'log:show the branch log'
      'repo:manage repository settings'
      'stack:manage the current stack'
      'trunk:switch to the trunk branch'
      'upstack:manage the upstack'
      'user:manage user settings'
    )
    _describe -t subcommands 'gt subcommand' subcmds && ret=0
    ;;
  args)
    case "${line[1]}" in
      branch)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:branch subcommand:->branch_subcmd' \
          '*::arg:->branch_args' && ret=0
        case "$state" in
          branch_subcmd)
            local -a branch_subcmds=(
              'checkout:checkout a branch'
              'create:create a new branch'
              'delete:delete a branch'
              'fold:fold a branch into its parent'
              'info:show information about a branch'
              'rename:rename the current branch'
              'restack:restack a branch'
              'split:split the current branch'
              'squash:squash all commits in a branch'
              'submit:submit a branch for review'
              'track:track a branch with Graphite'
              'untrack:untrack a branch'
              'up:move up one branch in the stack'
              'down:move down one branch in the stack'
              'top:move to the top of the stack'
              'bottom:move to the bottom of the stack'
            )
            _describe -t subcommands 'branch subcommand' branch_subcmds && ret=0
            ;;
          branch_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '-m[commit message]:message' \
                  '--no-verify[skip pre-commit hooks]' \
                  '*:branch name' && ret=0
                ;;
              checkout|delete|info|rename|track|untrack)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '*:branch name' && ret=0
                ;;
              *)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '*:argument' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      commit)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:commit subcommand:->commit_subcmd' \
          '*::arg:->commit_args' && ret=0
        case "$state" in
          commit_subcmd)
            local -a commit_subcmds=(
              'amend:amend the current commit'
              'create:create a new commit'
            )
            _describe -t subcommands 'commit subcommand' commit_subcmds && ret=0
            ;;
          commit_args)
            _arguments -s -S \
              '(- *)'{-h,--help}'[show help]' \
              '-m[commit message]:message' \
              '--no-verify[skip pre-commit hooks]' \
              '*:argument' && ret=0
            ;;
        esac
        ;;
      stack)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:stack subcommand:->stack_subcmd' \
          '*::arg:->stack_args' && ret=0
        case "$state" in
          stack_subcmd)
            local -a stack_subcmds=(
              'submit:submit the entire stack for review'
              'restack:restack the entire stack'
              'test:test all branches in the stack'
            )
            _describe -t subcommands 'stack subcommand' stack_subcmds && ret=0
            ;;
          stack_args)
            _arguments -s -S \
              '(- *)'{-h,--help}'[show help]' \
              '*:argument' && ret=0
            ;;
        esac
        ;;
      downstack)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:downstack subcommand:->downstack_subcmd' \
          '*::arg:->downstack_args' && ret=0
        case "$state" in
          downstack_subcmd)
            local -a downstack_subcmds=(
              'edit:edit the downstack'
              'get:get a stack from a pull request'
              'submit:submit the downstack for review'
              'track:track branches in the downstack'
            )
            _describe -t subcommands 'downstack subcommand' downstack_subcmds && ret=0
            ;;
          downstack_args)
            _arguments -s -S \
              '(- *)'{-h,--help}'[show help]' \
              '*:argument' && ret=0
            ;;
        esac
        ;;
      upstack)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:upstack subcommand:->upstack_subcmd' \
          '*::arg:->upstack_args' && ret=0
        case "$state" in
          upstack_subcmd)
            local -a upstack_subcmds=(
              'onto:rebase the upstack onto a branch'
              'submit:submit the upstack for review'
              'restack:restack the upstack'
            )
            _describe -t subcommands 'upstack subcommand' upstack_subcmds && ret=0
            ;;
          upstack_args)
            _arguments -s -S \
              '(- *)'{-h,--help}'[show help]' \
              '*:argument' && ret=0
            ;;
        esac
        ;;
      log)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--long[show long format]' \
          '--reverse[reverse the log output]' \
          '--steps=[number of steps to show]:count' \
          '--classic[show classic log format]' \
          '--short[show short format]' && ret=0
        ;;
      repo)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:argument' && ret=0
        ;;
      auth|completion|dash|demo|docs|feedback|init|trunk|user)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:argument' && ret=0
        ;;
    esac
    ;;
esac

return ret
