#compdef nms

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-a[auto-decrypt after initial display]' \
  '-s[mask space characters]' \
  '-f+[foreground color]:color:(white yellow black magenta blue green red)' \
  '-c[clear screen before printing]' \
  '*:input file:_files' && ret=0

return ret
