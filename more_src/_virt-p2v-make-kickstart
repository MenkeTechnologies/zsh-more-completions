#compdef virt-p2v-make-kickstart
# Documentation: https://libguestfs.org/virt-p2v-make-kickstart.1.html
# build a virt-p2v kickstart file for booting a P2V conversion ISO

local ret=1

_arguments -s -S \
  '--help[display help information]' \
  '(-V --version)'{-V,--version}'[show the version number and exit]' \
  '--inject-ssh-identity=[embed an SSH private key into the kickstart]:id_rsa:_files' \
  '--install=[add supplementary packages]:packages' \
  '(-o --output)'{-o,--output}'[output file path (default p2v.ks)]:output:_files' \
  '--proxy=[proxy server for package downloads]:url' \
  '(-v --verbose)'{-v,--verbose}'[activate detailed logging]' \
  '*:repository:(fedora rawhide koji)' && ret=0

return ret
