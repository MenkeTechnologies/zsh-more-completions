#compdef pdb_delresname
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Removes all residues matching the given name in the PDB file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[residue name(s) to delete, e.g. -ALA or -ALA,GLY]:residue name' \
  '*:PDB file:_files' && ret=0

return ret
