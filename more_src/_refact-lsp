#compdef refact-lsp refact
# Documentation: https://man.archlinux.org/search?q=refact-lsp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--http-port=[HTTP service port]:port:' \
  '--logs-stderr[log to stderr]' \
  '--logs-to-dir=[log directory]:dir:_files -/' \
  '--address-url=[refact server URL or self-hosted]:url:' \
  '--api-key=[refact API key]:key:' \
  '--ast[enable AST indexer]' \
  '--vecdb[enable VecDB indexer]' \
  '--ast-max-files=[max files indexed by AST]:n:' \
  '--vecdb-max-files=[max files indexed by VecDB]:n:' \
  '--workspace-folder=[workspace path]:dir:_files -/' \
  '--workspace=[workspace path (alias)]:dir:_files -/' \
  '--insecure[skip TLS verification]' \
  '--basic-telemetry[basic telemetry]' \
  '--snippet-telemetry[snippet telemetry]' \
  '--integrations=[integrations config file]:file:_files -g "*.{yaml,yml,json}"' \
  '--tool-permissions=[tool permissions config]:file:_files' \
  '--enduser-client-version=[client version override]:version:' \
  '--experimental[enable experimental features]' \
  '--lsp-port=[LSP port]:port:' \
  '--lsp-stdin-stdout=[use stdin/stdout for LSP]:bool:(0 1 true false)' \
  '*::passthrough:' && ret=0

return ret
