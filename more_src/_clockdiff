#compdef clockdiff
# Documentation: man clockdiff(8)
# Source: iputils/iputils clockdiff.c (master) — measure clock difference between hosts via ICMP (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-o -o1)-o[use IP timestamp and ICMP echo]' \
    '(-o -o1)-o1[use three-term IP timestamp and ICMP echo]' \
    '(-T --time-format -I)'{-T+,--time-format=}'[time display format]:format:(ctime iso)' \
    '(-T --time-format -I)-I[shortcut for --time-format=iso]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '1:destination:_hosts' \
    && ret=0

return ret
