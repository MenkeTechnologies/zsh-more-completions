#compdef mongofiles
# Documentation: https://www.mongodb.com/docs/database-tools/mongofiles/
# Source: MongoDB Database Tools — manipulate files stored in GridFS.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(- *)--help[show help]' \
    '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
    '--quiet[quiet mode]' \
    '(- *)--version[show version]' \
    '--uri=[MongoDB connection URI]:uri:' \
    '(-h --host)'{-h+,--host=}'[hostname[:port]]:host:_hosts' \
    '--port=[TCP port]:port:' \
    '--ssl[enable TLS/SSL]' \
    '(-u --username)'{-u+,--username=}'[auth username]:user:_users' \
    '(-p --password)'{-p+,--password=}'[auth password]:password:' \
    '--authenticationDatabase=[auth database]:db:' \
    '--authenticationMechanism=[auth mechanism]:mech:(SCRAM-SHA-1 SCRAM-SHA-256 MONGODB-X509 MONGODB-AWS GSSAPI PLAIN)' \
    '(-d --db)'{-d+,--db=}'[database name]:db:' \
    '(-l --local)'{-l+,--local=}'[local filesystem filename]:file:_files' \
    '--type=[file MIME type]:mime:(image/jpeg image/png image/gif application/pdf application/json text/plain text/csv video/mp4 audio/mpeg)' \
    '(-r --replace)'{-r,--replace}'[replace existing GridFS objects]' \
    '--prefix=[GridFS collection prefix (default fs)]:prefix:' \
    '--readPreference=[read preference]:pref:(primary primaryPreferred secondary secondaryPreferred nearest)' \
    '--writeConcern=[write-concern document]:doc:' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'list:list GridFS files (optional prefix filter)'
            'search:list files whose name matches a string'
            'put:copy local files into GridFS'
            'get:copy GridFS files to local FS'
            'get_id:copy a GridFS file by ObjectId'
            'get_regex:copy GridFS files matching a regex'
            'delete:delete a GridFS file by name'
            'delete_id:delete a GridFS file by ObjectId'
        )
        _describe -t subcmds 'mongofiles command' subcmds && ret=0
        ;;
    args)
        _files
        ;;
esac

return ret
