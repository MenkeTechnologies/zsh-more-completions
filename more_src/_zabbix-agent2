#compdef zabbix-agent2 zabbix_agent2
# Documentation: https://manpages.debian.org/bookworm/zabbix-agent2/zabbix_agent2.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm zabbix_agent2(8) manpage.

# zabbix-agent2: Zabbix monitoring agent 2 (Go)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[alternate config file]:file:_files' \
  '(-R --runtime-control)'{-R,--runtime-control=}'[runtime option]:opt:(userparameter_reload log_level_increase log_level_decrease help metrics version)' \
  '(-p --print)'{-p,--print}'[print known items and exit]' \
  '(-t --test)'{-t,--test=}'[test single item and exit]:key:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output for test/print]' && ret=0
return ret
