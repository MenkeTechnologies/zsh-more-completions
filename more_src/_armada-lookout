#compdef armada-lookout lookout
# _armada-lookout — Armada job-state query API + UI backend (reads from PostgreSQL populated by armada-lookoutingester)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/lookout/main.go on tip; runtime config is YAML-driven (./config/lookout/config.yaml + --config overrides) with viper ARMADA_* env binding.

_armada-lookout() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[YAML config file (repeat or comma-separate for multiple)]:file:_files' \
        '--migrateDatabase[migrate database schema and exit instead of running the server]' \
        '--pruneDatabase[prune old jobs from the database and exit instead of running the server]'
}

_armada-lookout "$@"
