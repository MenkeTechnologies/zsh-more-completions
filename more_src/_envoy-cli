#compdef envoy
# Documentation: https://man.archlinux.org/search?q=envoy
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '(-c --config-path)'{-c+,--config-path=}'[bootstrap config]:file:_files -g "*.yaml *.yml *.json *.pb"' \
  '--config-yaml=[inline YAML config]:yaml:' \
  '--allow-unknown-static-fields[allow unknown static fields]' \
  '--allow-unknown-dynamic-fields[allow unknown dynamic fields]' \
  '--reject-unknown-dynamic-fields[reject unknown dynamic fields]' \
  '--ignore-unknown-dynamic-fields[ignore unknown dynamic fields]' \
  '--admin-address-path=[file to write admin listen address]:file:_files' \
  '(-l --log-level)'{-l+,--log-level=}'[log level]:l:(trace debug info warning error critical off)' \
  '--component-log-level=[per-component log levels]:spec:' \
  '--log-format=[log format spec]:fmt:' \
  '--log-format-prefix-with-location=[prefix with source location]:b:(0 1)' \
  '--log-format-escaped[escape log strings]' \
  '--enable-fine-grain-logging[enable fine-grain logging]' \
  '--log-path=[log file path]:file:_files' \
  '--restart-epoch=[hot-restart epoch]:n:' \
  '--service-cluster=[service cluster name]:s:' \
  '--service-node=[service node name]:s:' \
  '--service-zone=[service zone]:s:' \
  '--file-flush-interval-msec=[file flush interval ms]:ms:' \
  '--drain-time-s=[drain time s]:s:' \
  '--drain-strategy=[drain strategy]:s:(immediate gradual)' \
  '--parent-shutdown-time-s=[parent shutdown s]:s:' \
  '--mode=[run mode]:m:(serve validate init-only)' \
  '--disable-extensions=[extensions to disable csv]:list:' \
  '--bootstrap-version=[bootstrap version]:v:(2 3)' \
  '--use-dynamic-base-id[use dynamic base id]' \
  '--base-id=[base id for shared memory]:n:' \
  '--base-id-path=[file to write base id]:file:_files' \
  '--enable-mutex-tracing[enable mutex tracing]' \
  '--cpuset-threads[adjust threads to cpuset]' \
  '--concurrency=[worker thread count]:n:' \
  '--socket-path=[hot-restart socket path]:file:_files' \
  '--socket-mode=[hot-restart socket mode]:n:' \
  '--enable-core-dump[enable core dump]' \
  '--stats-tag=[stats tag k=v]:tag:' \
  '--hot-restart-version[show hot restart version and exit]' \
  '*: :_files' && ret=0

return ret
