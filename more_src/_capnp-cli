#compdef capnp-cli capnpc
# _capnp-cli — Cap'n Proto capnp/capnpc compiler CLI alias (Kenton Varda / Sandstorm.io, C++); custom argparse
# upstream: https://github.com/capnproto/capnproto

_capnp-cli() {
    local -a sub=(
        'compile:compile schema'
        'id:generate a 64-bit unique ID'
        'help:show help'
        'eval:evaluate schema'
        'convert:convert message formats'
        'decode:decode message'
        'encode:encode message'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'capnp subcommand' sub ;;
        args)
            case $words[1] in
                compile) _arguments \
                    '-I+[import path]:list:_files -/' \
                    '--import-path=+[import path]:list:_files -/' \
                    '--src-prefix=+[source prefix]:dir:_files -/' \
                    '-o+[output type:dest]:str:' \
                    '--output=+[output type:dest]:str:' \
                    '--no-standard-import[no standard import]' \
                    '*:schema:_files -g "*.capnp"' ;;
                id) _arguments '*:arg:' ;;
                eval) _arguments \
                    '-I+[import path]:list:_files -/' \
                    '--short[short output]' \
                    '*:schema-and-expr:_files' ;;
                convert) _arguments \
                    '*:input-output-type:_files' ;;
                decode|encode) _arguments \
                    '-I+[import path]:list:_files -/' \
                    '--flat[flat]' \
                    '--packed[packed]' \
                    '--short[short]' \
                    '*:schema-type:_files' ;;
            esac
            ;;
    esac
}

_capnp-cli "$@"
