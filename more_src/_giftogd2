#compdef giftogd2
# Documentation: https://docs.oracle.com/cd/E88353_01/html/E37839/giftogd2-1.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input GIF:_files -g "*.gif"' \
  '2:output GD2:_files -g "*.gd2"' \
  '3:chunk size:' \
  '4:format (1=raw, 2=compressed):(1 2)' && ret=0

return ret
