#compdef pycscope
# Documentation: https://github.com/portante/pycscope/blob/master/README.md
# cscope database generator for Python source code

local ret=1

_arguments -s -S \
  '-D[dump the concrete syntax tree for each file]' \
  '-R[recurse directories for files]' \
  '-S[interpret simple strings as symbols]' \
  '-V[print version and exit]' \
  '-f+[cross-ref output file (default cscope.out)]:reffile:_files' \
  '-i+[file listing source files to scan]:srclistfile:_files' \
  '-e+[comma-separated paths to exclude]:paths:_files -/' \
  '*:file:_files' && ret=0

return ret
