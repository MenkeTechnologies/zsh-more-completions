#compdef xrootd
# Documentation: https://xrootd.web.cern.ch/doc/dev57/xrd_config.htm
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# xrootd: eXtended ROOT daemon (high-perf data access protocol).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[display help information]' \
  '(- *)-H[display license terms]' \
  '-c+[configuration file]:file:_files -g "*.cfg"' \
  '-l+[log destination (file, dash for stderr, or @lib)]:dest:_files' \
  '-k+[log file retention (num, size, or signal)]:value:' \
  '-p+[TCP port or service name]:port:' \
  '-P+[default protocol name]:protocol:' \
  '-a+[administrative path]:path:_directories' \
  '-A+[administrative path with group write access]:path:_directories' \
  '-b[run as background process]' \
  '-d[enable debugging mode]' \
  '-I+[restrict IP version]:ver:(v4 v6)' \
  '-n+[xrootd instance name]:name:' \
  '-R+[switch to user (effective uid)]:user:_users' \
  '-s+[pid file]:file:_files' \
  '-S+[site name (1-15 chars) for monitoring]:site:' \
  '-w+[home/working directory]:dir:_directories' \
  '-W+[home/working directory with group access]:dir:_directories' \
  '-z[microsecond timestamp resolution in logs]' \
  '*:exports:' && ret=0
return ret
