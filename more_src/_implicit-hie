#compdef implicit-hie gen-hie

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --dir)'{-d,--dir}'+[project dir]:dir:_files -/' \
  '--cabal[generate for cabal]' \
  '--stack[generate for stack]' \
  '--cradle[generate cradle]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' && ret=0

return ret
