#compdef implicit-hie gen-hie
# Documentation: https://github.com/Avi-D-coder/implicit-hie
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# implicit-hie / gen-hie: generate hie.yaml for haskell-language-server in Cabal/Stack projects
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--cabal[force cabal project type]' \
  '--stack[force stack project type]' \
  '1::project dir:_files -/' && ret=0
return ret
