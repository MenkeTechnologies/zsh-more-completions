#compdef pmie_check
# _pmie_check — Performance Co-Pilot pmie_check (cron driver that ensures every pmie declared in pmie.control is running; restarts missing ones, prunes stale state, -c control file, -V verbose, -l log file, -P pidfile, -s do not start daemons, -q quiet, -m mail address, -N dry run)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmie/pmie_check on tip.

_pmie_check() {
    _arguments \
        '-c+[control file]:file:_files' \
        '-V[verbose]' \
        '-l+[log file]:file:_files' \
        '-P+[pidfile]:file:_files' \
        '-q[quiet]' \
        '-s[do not start daemons]' \
        '-m+[mail address]:addr:' \
        '-N[show would-do only]' \
        '-Z+[timezone]:tz:'
}

_pmie_check "$@"
