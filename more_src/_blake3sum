#compdef blake3sum

# Distros ship `blake3sum` alongside BLAKE3 `b3sum` — flags mirror b3sum Inner struct (BLAKE3 repo b3sum/src/main.rs).

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--keyed[32-byte key from stdin; requires file args]' \
  '--derive-key=[key derivation context]:context' \
  '(-l --length)'{-l,--length}"=[output length in bytes]:len" \
  '--seek=[output byte offset]:offset' \
  '--num-threads=[max Rayon threads]:n' \
  '--no-mmap[disable mmap (also disables multithreading)]' \
  '--no-names[omit filenames in output]' \
  '--raw[raw bytes to stdout; single input only]' \
  '--tag[BSD-style tagged output]' \
  '(-c --check)'{-c,--check}'[verify checksum files]' \
  '--quiet[with --check: skip OK lines]' \
  '*:file:_files' && ret=0

return ret
