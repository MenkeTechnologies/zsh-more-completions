#compdef create-four-app
# Documentation: https://github.com/iamnumberfourrrr/create-four-app#readme
# Reference accessed: 2026-05-24
# Verified: npm view create-four-app bin; npm readme and dist/index.js at the URL above.

# Zsh completion for create-four-app - TanStack Start/Router monorepo scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--skip-install[skip running pnpm install after scaffolding]' \
  '--no-rollback[do not remove the project directory on failure]' \
  '--force[overwrite files in an existing non-empty directory]' \
  '--in-existing[scaffold into an existing directory without prompting]' \
  '--non-interactive[skip prompts (requires --json-config)]' \
  '--json-config=[path to JSON config for non-interactive mode]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' add && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments -C \
          '--skip-install[skip running pnpm install]' \
          '--force[overwrite module files if already installed]' \
          ':module:(tailwind shadcn db auth)' && ret=0
        ;;
      *)
        _arguments -C \
          '--skip-install[skip running pnpm install after scaffolding]' \
          '--no-rollback[do not remove the project directory on failure]' \
          '--force[overwrite files in an existing non-empty directory]' \
          '--in-existing[scaffold into an existing directory without prompting]' \
          '--non-interactive[skip prompts (requires --json-config)]' \
          '--json-config=[path to JSON config file]:file:_files' \
          ':project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
