#compdef pwtadj1
# Documentation: https://pesthomepage.org/programs
# PEST utility: writes a new control file with weights adjusted so each observation group contributes equally

local ret=1

_arguments -s \
  '1:input PEST control file:_files -g "*.pst"' \
  '2:output PEST control file:_files -g "*.pst"' && ret=0

return ret
