#compdef kbdrate
# _kbdrate — Linux kbd kbdrate (set keyboard auto-repeat rate and delay on the console; -r repeats per second, -d delay before repeat (ms), -s silent (no feedback))
# upstream: https://github.com/legionus/kbd
# Flags from kbd src/kbdrate.c on tip.

_kbdrate() {
    _arguments \
        '-s[silent]' \
        '-r+[repeat rate (hz)]:rate:' \
        '-d+[delay (ms)]:delay:'
}

_kbdrate "$@"
