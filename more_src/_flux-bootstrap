#compdef flux-bootstrap
# Documentation: https://fluxcd.io/flux/cmd/flux_bootstrap/
# FluxCD bootstrap: deploy Flux on a cluster connected to a Git provider

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--context=[kubeconfig context to use]:context:' \
  '--namespace=[namespace scope for this CLI request]:namespace:' \
  '-n[namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--timeout=[timeout for this operation]:duration:' \
  '--cluster=[name of the kubeconfig cluster to use]:cluster:' \
  '--verbose[print generated objects]' \
  '*::subcommand:(bitbucket-server git gitea github gitlab)' && ret=0

return ret
