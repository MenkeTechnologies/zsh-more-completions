#compdef supplyscan
# Documentation: https://github.com/seanhalberthal/supplyscan-mcp
# Reference accessed: 2026-05-22
# Verified: internal/cli/cli.go and cmd/supplyscan/main.go cobra/flag definitions.

# Zsh completion for supplyscan - JavaScript ecosystem supply-chain security scanner

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json[output raw JSON]' \
  '--mcp[run as MCP server]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'supplyscan command' \
      'status[scanner version and IOC database info]' \
      'scan[scan project for vulnerabilities and compromises]' \
      'check[check single package@version]' \
      'refresh[update IOC database from upstream]' && ret=0
    ;;
  args)
    case $line[1] in
      scan)
        _arguments \
          '(-r --recursive)'{-r,--recursive}'[scan path recursively]' \
          '--no-dev[exclude devDependencies]' \
          '1:path:_files -/' && ret=0
        ;;
      check)
        _arguments '1:package:' '2:version:' && ret=0
        ;;
      refresh)
        _arguments '--force[force refresh IOC database]' && ret=0
        ;;
    esac
    ;;
esac

return ret
