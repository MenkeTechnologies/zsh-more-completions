#compdef gevgen
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gEvGen.cxx
# gevgen - GENIE generic neutrino event generation application

local ret=1

_arguments -s -S \
  '(-h)-h[show help and exit]' \
  '-n[number of events to generate]:nevents:' \
  '-r[MC run number]:run:' \
  '-e[neutrino energy or energy range (min,max)]:energy:' \
  '-p[neutrino PDG code]:pdg:' \
  '-t[target PDG code or weighted target mix]:target:' \
  '-f[neutrino flux (function, file, ROOT histogram, or power law)]:flux:' \
  '-F[flux direction, radius and beam spot parameters]:fluxgeom:' \
  '-o[output event filename]:outfile:_files' \
  '-w[generate weighted events]' \
  '--seed[random number seed]:seed:' \
  '--cross-sections[XML file with pre-computed cross-section splines]:xml:_files' \
  '--event-generator-list[event generator list to load]:list:' \
  '--tune[GENIE neutrino interaction model tune]:tune:' \
  '--xml-path[directory for loading XML configuration files]:dir:_files -/' \
  '--message-thresholds[XML file customizing message stream thresholds]:xml:_files' \
  '--event-record-print-level[verbosity for event record output]:level:' \
  '--mc-job-status-refresh-rate[status file update frequency]:rate:' \
  '--cache-file[cache file for reuse across jobs]:file:_files' \
  '--force-flux-ray-interaction[force interaction of all flux rays]' \
  '--enable-bare-xsec-pre-calc[enable cross-section pre-calculation]' \
  '--disable-bare-xsec-pre-calc[disable cross-section pre-calculation]' \
  '--unphysical-event-mask[16-bit mask for unphysical event acceptance]:mask:' \
  '*: :_files' && ret=0

return ret
