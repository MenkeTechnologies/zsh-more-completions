#compdef create-eth
# Documentation: https://docs.scaffoldeth.io/extensions/
# Reference accessed: 2026-05-24
# Verified: npm view create-eth bin; dist/cli.js flags and README at docs.scaffoldeth.io.

# Zsh completion for create-eth - Scaffold-ETH 2 dApp scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--skip-install[skip package installation]' \
  '--skip[alias for --skip-install]' \
  '--dev[link templates folder for development mode]' \
  '(-s --solidity-framework)'{-s,--solidity-framework=}'[smart contract framework]:framework:(foundry hardhat)' \
  '(-e --extension)'{-e,--extension=}'[extension slug from create-eth-extensions]:extension:(subgraph x402 eip-712 ponder erc-20 eip-5792 randao erc-721 porto envio drizzle-neon challenge-tokenization challenge-crowdfunding challenge-token-vendor)' \
  '(-h --help)'{-h,--help}'[display help]' \
  ':project path:_directories' && ret=0

return ret
