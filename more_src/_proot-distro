#compdef proot-distro
# Documentation: https://man.archlinux.org/search?q=proot-distro
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install Linux distribution'
  'add:install (alias)'
  'i:install (alias)'
  'in:install (alias)'
  'ins:install (alias)'
  'login:execute shell within distribution'
  'sh:login (alias)'
  'remove:delete distribution'
  'rm:remove (alias)'
  'list:show available distributions'
  'li:list (alias)'
  'ls:list (alias)'
  'rename:rename distribution'
  'mv:rename (alias)'
  'reset:delete and reinstall'
  'backup:create distribution archive'
  'bak:backup (alias)'
  'bkp:backup (alias)'
  'restore:restore from archive'
  'copy:transfer files between host and dist'
  'cp:copy (alias)'
  'clear-cache:remove cached rootfs archives'
  'clear:clear-cache (alias)'
  'cl:clear-cache (alias)'
  'help:show usage'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'proot-distro subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install|add|i|in|ins)
        _arguments \
          '--override-alias=[override alias]:name:' \
          ':distribution:' && ret=0
        ;;
      (login|sh)
        _arguments \
          '--user=[user]:user:_users' \
          '--fix-low-ports[fix low ports]' \
          '--isolated[isolated env]' \
          '--termux-home[Termux home]' \
          '--shared-tmp[shared /tmp]' \
          '*--bind=[bind src:dest]:bind:' \
          '--no-link2symlink[no link2symlink]' \
          '--no-sysvipc[no sysvipc]' \
          '--no-kill-on-exit[no kill on exit]' \
          '--no-arch-warning[no arch warning]' \
          '--kernel=[kernel string]:str:' \
          '--hostname=[hostname]:host:' \
          '--work-dir=[working dir]:dir:_files -/' \
          ':distribution:' && ret=0
        ;;
      (backup|bak|bkp)
        _arguments \
          '--output=[output file]:file:_files' \
          ':distribution:' && ret=0
        ;;
      (copy|cp)
        _arguments \
          '--move[move instead of copy]' && ret=0
        ;;
    esac
    ;;
esac

return ret
