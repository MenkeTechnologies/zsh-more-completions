#compdef proot-distro
# Documentation: https://github.com/termux/proot-distro
# Reference accessed: 2026-05-20
# Verified: upstream termux/proot-distro README.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install Linux distribution'
  'login:execute shell within distribution'
  'run:execute entrypoint of OCI image'
  'remove:delete distribution'
  'list:show installed distributions'
  'rename:rename distribution'
  'reset:delete and reinstall'
  'backup:create distribution archive'
  'restore:restore from archive'
  'copy:transfer files between host and dist'
  'sync:sync files between host and dist'
  'clear-cache:remove cached rootfs archives'
  'help:show usage'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'proot-distro subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '--name=[set custom container name]:name:' \
          '--architecture=[override target CPU architecture]:arch:' \
          ':distribution:' && ret=0
        ;;
      (login|run)
        _arguments \
          '--user=[user]:user:_users' \
          '--redirect-ports[redirect privileged ports]' \
          '--shared-home[bind host home directory]' \
          '--shared-tmp[bind host /tmp (Termux only)]' \
          '--shared-x11[bind X11 socket (Termux only)]' \
          '*--bind=[bind src:dest]:bind:' \
          '--emulator=[QEMU emulator path]:path:_files' \
          '--kernel=[kernel string]:str:' \
          '--hostname=[hostname]:host:' \
          '--work-dir=[working dir]:dir:_files -/' \
          '*--env=[set env var]:VAR=VALUE:' \
          '--isolated[skip non-essential bindings (Termux only)]' \
          '--minimal[bare-minimum proot setup (Termux only)]' \
          '--get-proot-cmd[print assembled command without running]' \
          ':distribution:' && ret=0
        ;;
      (remove|reset|rename)
        _arguments \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          ':distribution:' && ret=0
        ;;
      (backup)
        _arguments \
          '--output=[output file]:file:_files' \
          '--compress=[compression]:type:(gzip bzip2 xz none)' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          ':distribution:' && ret=0
        ;;
      (restore)
        _arguments \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          ':file:_files' && ret=0
        ;;
      (copy)
        _arguments \
          '(-r --recursive)'{-r,--recursive}'[recursive]' \
          '(-m --move)'{-m,--move}'[move instead of copy]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0
        ;;
      (sync)
        _arguments \
          '--checksum[compare by CRC32]' \
          '--delete[remove destination files not in source]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0
        ;;
      (clear-cache)
        _arguments '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0
        ;;
    esac
    ;;
esac

return ret
