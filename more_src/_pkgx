#compdef pkgx
# Documentation: https://man.archlinux.org/search?q=pkgx
# Reference accessed: 2026-05-16

_arguments -s \
  '--[end of options]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-s --silent)'{-s,--silent}'[silent]' \
  '(-j --json)'{-j,--json}'=[JSON output]:version:(v1 v2)' \
  '(-C --chdir --cd)'{-C,--chdir,--cd}'=[change directory]:dir:_files -/' \
  '--sync[sync pantry first]' \
  '(-Q --query)'{-Q,--query}'[query mode]' \
  '(-! --shebang)'{-!,--shebang}'[shebang mode]' \
  '-v[print version and continue]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*::arg: '
