#compdef codcmp
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/codcmp.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# EMBOSS codcmp: compare two codon-usage tables
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-first=[first codon usage table]:file:_files' \
  '-second=[second codon usage table]:file:_files' \
  '-outfile=[comparison report]:file:_files' \
  '*:codon usage file:_files' && ret=0
return ret
