# ============================================================================
# _ghealth — zsh completion for rudrankriyam/Google-Health-CLI (binary
#             `ghealth`), "an unofficial Google-Health-CLI for the Google
#             Health API, written in Go" — Go=149 leader bump continuing
#             Axis 94 OAuth2 / oauth2-rs via the canonical Go OAuth2 lib
#             golang.org/x/oauth2
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/rudrankriyam/Google-Health-CLI
#   Maintainer : Rudrank Riyam
#   License    : MIT
#   Stars      : 60
#   Language   : Go
#   Module     : github.com/rudrankriyam/Google-Health-CLI
#   Binary     : ghealth  (Makefile `go build -o ghealth .`)
#   Last push  : 2026-05-09
#
# WHAT IT IS
#   ghealth is "an unofficial Google-Health-CLI for the Google
#   Health API" — a Go CLI that authenticates against Google's
#   identity-provider with `golang.org/x/oauth2`'s 3-legged
#   authorization-code flow (offline-access refresh tokens
#   stored locally), then exposes the Google Health REST v4
#   surface as typed subcommands.  Coverage spans all 31 data
#   types (activity, sleep, body, heart, nutrition, mindfulness,
#   reproductive, etc.), the data-point CRUD endpoints
#   (`data list / get / create / patch`), civil and physical
#   roll-up aggregations (`rollup daily / physical`), profile +
#   settings + identity reads / writes, and a generic
#   passthrough (`api`) for un-typed endpoints.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/run.go `parseGlobal`
#                       + the inline help message — ghealth uses
#                       Go stdlib `flag`-style parsing with a
#                       hand-rolled top-level switch over
#                       subcommands)
#   ghealth [GLOBAL FLAGS] <COMMAND> [args...]
#
#   Global flags (parsed before the subcommand):
#     --json                         Force JSON output
#     --pretty                       Pretty-print JSON
#     --format <FORMAT>              Output format (alias of
#                                    --output;  auto | json |
#                                    table | csv)
#     --output <FORMAT>              Output format
#     --base-url <URL>               Override the Google Health
#                                    API base URL
#     --user <USER>                  Override the target user
#                                    id
#     --project <PROJECT>            Override the GCP project
#
#   Subcommands:
#     auth <SUBCMD>                  Manage OAuth tokens
#       login                          Run the OAuth2
#                                      authorization-code flow
#       status                         Show login status
#       revoke                         Revoke stored tokens
#
#     doctor                         Check local setup
#                                    (credentials, scopes, API
#                                     reachability)
#
#     types <SUBCMD>                 Inspect Google Health data
#                                    types
#       list                           List all 31 types
#       describe                       Describe a specific type
#
#     endpoints list                 Inspect the v4 REST surface
#
#     data <SUBCMD>                  Work with data points
#       list / get / create / patch
#
#     rollup <SUBCMD>                Query rollups
#       daily                          Civil daily roll-ups
#       physical                       Physical-activity roll-ups
#
#     profile <SUBCMD>               Read / update profile data
#       get / update
#
#     settings <SUBCMD>              Read / update settings
#       get / update
#
#     identity get                   Read user identity
#
#     agent <ARGS>                   Agent-mode helpers (LLM
#                                    integration)
#     subscribers <ARGS>             Manage push-notification
#                                    subscribers
#     api <ARGS>                     Generic Google Health API
#                                    passthrough
#     config <ARGS>                  Manage local config file
#
#     help                           Show help (also as
#                                    -h / --help)
#     version                        Show version (also as
#                                    --version)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `golang.org/x/oauth2 v0.36.0` declared
#   in go.mod — `golang.org/x/oauth2` is THE canonical Go
#   OAuth2 client library maintained by the Go team
#   (golang/oauth2, 5.3K+ stars, the official `golang.org/x/...`
#   subrepo used by every major Go OAuth2 / GCP / GitHub /
#   GitLab / Azure consumer).  oauth2 ships the typed
#   `oauth2.Config` builder (`ClientID`, `ClientSecret`,
#   `RedirectURL`, `Scopes`, `Endpoint`), the
#   `oauth2.Endpoint` set under `oauth2/google` /
#   `oauth2/github` / `oauth2/microsoft` / `oauth2/slack` /
#   `oauth2/spotify` / `oauth2/fitbit` / `oauth2/jira`
#   sub-packages, RFC 7636 PKCE via
#   `oauth2.GenerateVerifier` + `oauth2.S256ChallengeOption` /
#   `oauth2.VerifierOption`, the `oauth2.Token` struct,
#   `oauth2.TokenSource` interface, `oauth2.StaticTokenSource`,
#   `oauth2.ReuseTokenSource`, the
#   `oauth2.NewClient(ctx, ts)` HTTP-client wrapper that
#   transparently refreshes expired access tokens, the
#   `oauth2/clientcredentials` (RFC 6749 §4.4) sub-package,
#   the `oauth2/jws` JWT helper, and the `oauth2/jwt` JWT
#   bearer-token flow (`jwt.Config`).  ghealth's
#   `internal/auth` package builds an `oauth2.Config` against
#   Google's identity-provider endpoint (via
#   `oauth2/google.Endpoint`), runs the loopback IP redirect
#   flow with PKCE, persists the resulting `oauth2.Token` to
#   `~/.config/ghealth/`, and wraps the rest of the CLI in
#   `oauth2.NewClient(ctx, ts)` so every typed
#   `internal/healthapi` call gets fresh credentials
#   transparently.  Verified via:
#     gh api repos/rudrankriyam/Google-Health-CLI/contents/
#         go.mod
#       → require golang.org/x/oauth2 v0.36.0
#       → module github.com/rudrankriyam/Google-Health-CLI
#     gh api repos/rudrankriyam/Google-Health-CLI/contents/
#         cmd/run.go
#       → import "golang.org/x/oauth2"
#       → switch args[0] {
#           case "auth", "doctor", "config", "types",
#                "endpoints", "agent", "profile", "settings",
#                "identity", "data", "rollup", "subscribers",
#                "api", ... }
#     gh api repos/rudrankriyam/Google-Health-CLI/contents/
#         Makefile
#       → build: go build -o ghealth .
#   This entry is the Go=149 leader bump that continues Axis
#   94 (OAuth2 / ramosbugs/oauth2-rs) opened at R965 with
#   Rust=oauth2 via adriankumpf/tesla_auth.
#
#   No completion for `ghealth` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_ghealth() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--json[force JSON output]' \
        '--pretty[pretty-print JSON]' \
        '--format=[output format]:format:(auto json table csv)' \
        '--output=[output format (alias of --format)]:format:(auto json table csv)' \
        '--base-url=[override Google Health API base URL]:url:' \
        '--user=[override target user id]:user:' \
        '--project=[override GCP project]:project:' \
        '1: :_ghealth_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                auth)
                    _arguments \
                        '1:auth subcommand:(login status revoke)' \
                        '*::arg:' && ret=0 ;;
                types)
                    _arguments \
                        '1:types subcommand:(list describe)' \
                        '*::arg:' && ret=0 ;;
                endpoints)
                    _arguments \
                        '1:endpoints subcommand:(list)' \
                        '*::arg:' && ret=0 ;;
                data)
                    _arguments \
                        '1:data subcommand:(list get create patch)' \
                        '*::arg:' && ret=0 ;;
                rollup)
                    _arguments \
                        '1:rollup subcommand:(daily physical)' \
                        '*::arg:' && ret=0 ;;
                profile|settings)
                    _arguments \
                        '1:subcommand:(get update)' \
                        '*::arg:' && ret=0 ;;
                identity)
                    _arguments \
                        '1:identity subcommand:(get)' \
                        '*::arg:' && ret=0 ;;
                doctor|agent|subscribers|api|config|help|version)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ghealth_commands] )) ||
_ghealth_commands() {
    local -a commands
    commands=(
        'auth:manage OAuth tokens (login/status/revoke)'
        'doctor:check local setup'
        'types:inspect Google Health data types (list/describe)'
        'endpoints:inspect the v4 REST surface'
        'data:work with data points (list/get/create/patch)'
        'rollup:query rollups (daily/physical)'
        'profile:read/update profile data'
        'settings:read/update settings'
        'identity:read user identity'
        'agent:agent-mode helpers'
        'subscribers:manage push-notification subscribers'
        'api:generic Google Health API passthrough'
        'config:manage local config file'
        'help:show help'
        'version:show version'
    )
    _describe -t commands 'ghealth command' commands
}

_ghealth "$@"
