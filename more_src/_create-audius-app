#compdef create-audius-app
# Documentation: https://github.com/AudiusProject/apps
# Reference accessed: 2026-05-24
# Verified: npm view create-audius-app bin; npm readme Non-interactive section.

# Zsh completion for create-audius-app - Audius application scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-V --version)'{-V,--version}'[output the version number]' \
  '(-e --example)'{-e,--example=}'[Audius SDK example name or GitHub URL]:example:' \
  '(-h --help)'{-h,--help}'[output usage information]' \
  ':project directory:_directories' && ret=0

return ret
