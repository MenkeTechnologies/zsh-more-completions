#compdef kommit

# Kommit — https://github.com/techouse/kommit — Kotlin CLI enforcing Conventional Commits.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'install:install git hooks'
  'uninstall:remove hooks'
  'lint:validate commit message'
  'config:print/edit kommit config'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'kommit' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
