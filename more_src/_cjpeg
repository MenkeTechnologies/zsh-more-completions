#compdef cjpeg
# Documentation: https://manpages.debian.org/cjpeg.1
# Source: libjpeg / mozjpeg — JPEG encoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quality[quality 0..100 (default 75)]:n:' \
    '-grayscale[create monochrome JPEG]' \
    '-rgb[create RGB JPEG]' \
    '-optimize[optimize entropy-encoding parameters]' \
    '-progressive[create progressive JPEG]' \
    '-targa[input is Targa format]' \
    '-arithmetic[use arithmetic coding]' \
    '-dct[DCT method]:method:(int fast float)' \
    '-icc[embed ICC profile from file]:file:_files' \
    '-restart[restart marker every N MCU rows / Nb for blocks]:N:' \
    '-smooth[input smoothing strength]:n:' \
    '-maxmemory[memory limit (KB)]:n:' \
    '-outfile[output file]:file:_files' \
    '-memdst[compress to memory]' \
    '-report[report progress]' \
    '-strict[treat warnings as fatal]' \
    '-verbose[debug printout]' \
    '-debug[debug printout (alias)]' \
    '(- *)-version[print version]' \
    '-baseline[force baseline-compatible quantization tables]' \
    '-qtables[quantization tables from file]:file:_files' \
    '-qslots[quantization table per component]:slots:' \
    '-sample[sampling factors HxV per component]:HxV:' \
    '-scans[scan script file]:file:_files' \
    '*:input image:_files' \
    && ret=0

return ret
