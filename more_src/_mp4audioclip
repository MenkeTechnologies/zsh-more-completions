#compdef mp4audioclip
# Documentation: https://github.com/axiomatic-systems/Bento4/blob/master/Source/C%2B%2B/Apps/Mp4AudioClip/Mp4AudioClip.cpp
# Bento4 MP4 audio clip extractor

local ret=1

_arguments -s -S \
  '--start[start time in milliseconds (default 0)]:milliseconds' \
  '--duration[clip duration in milliseconds (default until end)]:milliseconds' \
  '*:file:_files -g "*.mp4"' && ret=0

return ret
