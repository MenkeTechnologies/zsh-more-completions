#compdef softirqslower softirqslower-bpfcc
# _softirqslower — trace slow softirq events (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/softirqslower.py (argparse).

_softirqslower() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-c --cpu)'{-c+,--cpu=}'[trace this CPU only]:cpu:'
        '1:min latency (us, default 10000):'
    )
    _arguments $args
}

_softirqslower "$@"
