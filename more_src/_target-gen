#compdef target-gen
# _target-gen — generate probe-rs target descriptions from CMSIS-Pack/ELF (probe-rs/probe-rs)
# upstream: https://github.com/probe-rs/probe-rs
# Subcommands from target-gen/src/main.rs (clap derive TargetGen).

_target-gen() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                pack:'generate target description from ARM CMSIS-Packs'
                arm:'generate from ARM root VIDX/PIDX'
                elf:'extract a flash algorithm from an ELF file'
                test:'generate target yaml from a flash algorithm Rust project'
                update:'loads and updates target descriptions from YAML files'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                pack) _arguments '1:input pack file or dir:_files' '2:output dir:_files -/' ;;
                arm) _arguments '(-l --list)'{-l,--list}'[list pack files available]' '*:family prefix:' ;;
                elf) _arguments '1:elf file:_files' ;;
                test) _arguments '*:files:_files' ;;
                update) _arguments '1:yaml file or dir:_files' ;;
            esac
            ;;
    esac
}

_target-gen "$@"
