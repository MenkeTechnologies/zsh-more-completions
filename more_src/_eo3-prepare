#compdef eo3-prepare
# Documentation: https://eodatasets.readthedocs.io/
# Prepare ODC EO3 metadata from source imagery (eodatasets3)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '(-f --datasets-path)'{-f,--datasets-path}'=[file of input dataset paths, one per line]:file:_files' \
  '(-j --jobs)'{-j,--jobs}'=[number of parallel workers]:jobs' \
  '(--overwrite-existing --skip-existing)--overwrite-existing[overwrite if exists]' \
  '(--overwrite-existing --skip-existing)--skip-existing[skip if exists]' \
  '(--embed-location --no-embed-location)--embed-location[embed the location]' \
  '(--embed-location --no-embed-location)--no-embed-location[do not embed the location]' \
  '--after-month=[limit scan to datasets newer than YEAR-MONTH]:year-month' \
  '--before-month=[limit scan to datasets older than YEAR-MONTH]:year-month' \
  '--index[index newly-generated metadata into the configured datacube]' \
  '--dry-run[show what would be created without creating it]' \
  '1:command:(landsat-l1 modis-mcd43a1 noaa-prwtr sentinel-l1)' \
  '*:path:_files' && ret=0

return ret
