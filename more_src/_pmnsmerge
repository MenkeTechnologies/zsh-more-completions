#compdef pmnsmerge
# Documentation: https://man.archlinux.org/man/pmnsmerge.1.en
# Merge multiple Performance Co-Pilot PMNS files

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '-a[process files in command line order]' \
  '(-d --dupok)'{-d,--dupok}'[allow duplicate metric names per PMID (default)]' \
  '(-f --force)'{-f,--force}'[overwrite output file if it exists]' \
  '(-v --verbose)'{-v,--verbose}'[verbose input processing]' \
  '(-x --nodups)'{-x,--nodups}'[do not allow duplicate metric names per PMID]' \
  '(-D --debug)'{-D+,--debug=}'[enable diagnostic output]:debug' \
  '*:file:_files' && ret=0

return ret
