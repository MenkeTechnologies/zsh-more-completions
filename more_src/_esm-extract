#compdef esm-extract
# Documentation: https://github.com/facebookresearch/esm#bulk_fasta
# ESM bulk embedding / representation extraction from a FASTA file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--toks_per_batch=[maximum batch size in tokens]:n:' \
  '--repr_layers=[layer indices for representation extraction]:layers:' \
  '--include=[which representations to return]:repr:(mean per_tok bos contacts)' \
  '--truncation_seq_length=[truncate sequences exceeding this length]:n:' \
  '1:model location:' \
  '2:fasta file:_files' \
  '3:output dir:_files -/' && ret=0

return ret
