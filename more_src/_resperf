#compdef resperf
# Documentation: https://manpages.debian.org/bookworm/dnsperf/resperf.1.en.html
# Source: DNS-OARC dnsperf package (sibling to _dnsperf already in repo)
# Reference accessed: 2026-05-30
# resperf — DNS resolver performance testing tool. Ramps up traffic to find
# throughput threshold for a resolver under controlled loss. Sister tool to
# dnsperf which measures authoritative servers.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show usage and exit]' \
  '-a+[local address for outgoing requests]:local-addr:_hosts' \
  '-b+[socket send/recv buffer size in kB]:kB:' \
  '-c+[constant-rate traffic duration after ramp-up (default 0)]:seconds:' \
  '-C+[act as N clients with separate sockets (default 1)]:N:' \
  '-d+[input query data file (stdin if omitted)]:file:_files' \
  '-D[set DNSSEC OK bit (enables EDNS0)]' \
  '-e[enable EDNS0 (add OPT record)]' \
  '-f+[address family]:family:(inet inet6 any)' \
  '-F+[max queries allowed to fall behind (default 1000; 0 disables)]:N:' \
  '-i+[plot data-point interval in seconds (default 0.5)]:seconds:' \
  '-L+[max acceptable query-loss percent for throughput determination]:percent:' \
  '-m+[target max query rate qps (default 100000)]:qps:' \
  '-M+[transport mode]:mode:(udp tcp dot doh)' \
  '*-O+[protocol-specific extended option]:option=value:' \
  '-p+[DNS port (default per-mode standard)]:port:' \
  '-P+[output plot data filename (default resperf.gnuplot)]:file:_files' \
  '-q+[max outstanding requests (default 64k per client)]:N:' \
  '-r+[ramp-up duration in seconds (default 60)]:seconds:' \
  '-R[reopen datafile if exhausted before completion]' \
  '-s+[server name or address (default 127.0.0.1)]:host:_hosts' \
  '-t+[request timeout in seconds (default 45)]:seconds:' \
  '-v[verbose mode (report network readiness)]' \
  '-W[log warnings/errors to stdout instead of stderr]' \
  '-x+[local port (default wildcard 0)]:port:' \
  '-y+[TSIG record: [alg:]name:base64-secret]:tsig:' \
  && ret=0

return ret
