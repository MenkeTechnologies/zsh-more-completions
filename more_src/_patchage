#compdef patchage

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-A --no-alsa)'{-A,--no-alsa}'[disable ALSA support]' \
  '(-J --no-jack)'{-J,--no-jack}'[disable JACK support]' \
  '*:file:_files' && ret=0

return ret
