#compdef patchage
# Documentation: https://manpages.debian.org/testing/patchage/patchage.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --no-alsa)'{-A,--no-alsa}'[prevent automatic attachment to ALSA at startup]' \
  '(-J --no-jack)'{-J,--no-jack}'[prevent automatic attachment to JACK at startup]' \
  '*:file:_files' && ret=0

return ret
