#compdef chplrun-udp
# Documentation: https://chapel-lang.org/docs/usingchapel/launcher.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

# chplrun-udp launches a Chapel program built with CHPL_COMM=gasnet and
# CHPL_COMM_SUBSTRATE=udp. First argument is the compiled Chapel binary;
# remaining args pass through to the program.
_arguments \
  '*::Chapel program and args:_files' && ret=0

return ret
