#compdef sensors-applet

# sensors-applet: GNOME / MATE panel applet for lm_sensors readings
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all GTK help options]' \
  '--display=[X display]:display:' \
  '*::sensors-applet args:_files' && ret=0
return ret
