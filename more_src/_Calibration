#compdef Calibration
# Documentation: https://github.com/senbox-org/s1tbx/blob/master/s1tbx-op-calibration/src/main/java/org/esa/s1tbx/calibration/gpf/CalibrationOp.java
# ESA SNAP gpt Calibration operator - radiometric calibration of SAR products

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-PsourceBandNames=-[the list of source bands]:bands' \
  '-PauxFile=-[the auxiliary file]:aux:(Latest\ Auxiliary\ File Product\ Auxiliary\ File External\ Auxiliary\ File)' \
  '-PexternalAuxFile=-[antenna elevation pattern gain auxiliary data file]:file:_files' \
  '-PoutputImageInComplex=-[output image in complex]:bool:(true false)' \
  '-PoutputImageScaleInDb=-[output image scale in dB]:bool:(true false)' \
  '-PcreateGammaBand=-[create gamma0 virtual band]:bool:(true false)' \
  '-PcreateBetaBand=-[create beta0 virtual band]:bool:(true false)' \
  '-PselectedPolarisations=-[the list of polarisations]:pols' \
  '-PoutputSigmaBand=-[output sigma0 band]:bool:(true false)' \
  '-PoutputGammaBand=-[output gamma0 band]:bool:(true false)' \
  '-PoutputBetaBand=-[output beta0 band]:bool:(true false)' \
  '*:source product:_files' && ret=0

return ret
