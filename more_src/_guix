#compdef guix

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'archive:export/import store files'
      'build:build packages or derivations'
      'challenge:challenge substitute servers'
      'container:process isolation'
      'copy:copy store items to/from a remote'
      'deploy:deploy operating systems'
      'describe:describe current channel revisions'
      'download:download a file and add to store'
      'edit:edit package definitions'
      'environment:set up development environments'
      'gc:garbage collect the store'
      'git:manage Git repositories'
      'graph:show package dependency graph'
      'hash:compute cryptographic hash'
      'home:manage home environment'
      'import:import package metadata'
      'install:install packages'
      'lint:check packages for issues'
      'offload:set up build offloading'
      'pack:create application bundles'
      'package:manage packages and profiles'
      'processes:list running Guix processes'
      'publish:publish substitutes'
      'pull:update the Guix distribution'
      'refresh:update package definitions'
      'remove:remove packages'
      'repl:start Guile REPL with Guix modules'
      'search:search for packages'
      'shell:spawn one-off software environment'
      'show:show package details'
      'size:show closure sizes'
      'style:format package definitions'
      'system:manage the operating system'
      'time-machine:run Guix from another revision'
      'upgrade:upgrade packages'
      'weather:check substitute availability'
    )
    _describe -t commands 'guix command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install|remove|upgrade|show|search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-p+[profile]:profile:_files' \
          '--profile=[profile]:profile:_files' \
          '-v[be verbose]' \
          '--verbose[be verbose]' \
          '-n[dry run]' \
          '--dry-run[dry run]' \
          '*:package' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[build from file]:file:_files' \
          '--file=[build from file]:file:_files' \
          '-e+[build expression]:expression' \
          '--expression=[build expression]:expression' \
          '-S+[source of package]:package' \
          '--source=[source of package]:package' \
          '-s+[target system]:system' \
          '--system=[target system]:system' \
          '-K[keep failed build tree]' \
          '--keep-failed[keep failed build tree]' \
          '-n[dry run]' \
          '--dry-run[dry run]' \
          '-r+[symlink to result]:link:_files' \
          '--root=[symlink to result]:link:_files' \
          '--no-substitutes[do not use substitutes]' \
          '*:package' && ret=0
        ;;
      gc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-C+[collect until free space]:size' \
          '--collect-garbage=[collect until free space]:size' \
          '-F+[free at least this much space]:size' \
          '--free-space=[free at least this much space]:size' \
          '-d[delete dead store items]' \
          '--delete[delete dead store items]' \
          '--optimize[optimize store by deduplication]' \
          '--list-dead[list dead store items]' \
          '--list-live[list live store items]' && ret=0
        ;;
      shell)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-D[include development inputs]' \
          '--development[include development inputs]' \
          '-f+[package file]:file:_files' \
          '--file=[package file]:file:_files' \
          '--pure[unset existing environment variables]' \
          '-C[run in container]' \
          '--container[run in container]' \
          '-N[share network in container]' \
          '--network[share network in container]' \
          '--share=[share host directory]:directory:_directories' \
          '--expose=[expose host directory read-only]:directory:_directories' \
          '*:package' && ret=0
        ;;
      pull)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-l[list generations]' \
          '--list-generations[list generations]' \
          '--channels=[channel file]:file:_files' \
          '-N[do not authenticate channel]' \
          '--allow-downgrades[allow downgrades]' \
          '-n[dry run]' \
          '--dry-run[dry run]' && ret=0
        ;;
      system)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(reconfigure build init vm vm-image container docker-image list-generations switch-generation roll-back describe delete-generations extension-graph shepherd-graph)' \
          '*:config file:_files' && ret=0
        ;;
      home)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(reconfigure build list-generations switch-generation roll-back describe delete-generations)' \
          '*:config file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
