#compdef fault
# Documentation: https://github.com/AUCOHL/Fault
# Fault open-source design-for-testing (DFT) toolchain

local ret=1
local context state line
typeset -A opt_args

local -a subcmds
subcmds=(
  'atpg:automatic test pattern generation (default)'
  'cut:cut away flip-flops from a netlist'
  'synth:synthesize a netlist with yosys'
  'assemble:assemble test vectors'
  'tap:add a JTAG TAP controller'
  'chain:stitch a scan chain'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--clock=[clock signal name held high during simulations]:clock:' \
  '--reset=[reset signal name held low during simulations]:reset:' \
  '*--ignoring=[inputs to bypass when performing operations]:input:' \
  '--active-low[reset signal is active-low]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'fault command' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      synth)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[output netlist path]:file:_files' \
          '(-l --liberty)'{-l,--liberty}'=[liberty file]:file:_files' \
          '(-t --top)'{-t,--top}'=[top module]:module:' \
          '(-B --blackboxModel)'{-B,--blackboxModel}'=[blackbox model files]:files:_files' \
          '*:verilog:_files -g "*.v"' && ret=0
        ;;
      atpg)
        _arguments -s \
          '(-o --output)'{-o,--output}'=[output JSON path]:file:_files' \
          '(-c --cellModel)'{-c,--cellModel}'=[cell model file]:file:_files' \
          '*'{-D,--define}'=[define statements for simulation]:define:' \
          '*'{-I,--include}'=[extra verilog models to include]:file:_files' \
          '*:netlist:_files -g "*.v"' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
