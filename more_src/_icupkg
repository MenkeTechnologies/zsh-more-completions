#compdef icupkg icuswap genbrk gencfu gennorm2 gencmn gensprep
# Documentation: source-direct extraction from upstream
# unicode-org/icu — per-tool `static UOption options[]={...}`
# arrays in icu4c/source/tools/<name>/<name>.{cpp,c}.
# UOPTION macros decoded source-direct from
# icu4c/source/tools/toolutil/uoptions.h:
#   UOPTION_HELP_H              -> "help", 'h', UOPT_NO_ARG
#   UOPTION_HELP_QUESTION_MARK  -> "help", '?', UOPT_NO_ARG (alias)
#   UOPTION_VERBOSE             -> "verbose", 'v', UOPT_NO_ARG
#   UOPTION_QUIET               -> "quiet", 'q', UOPT_NO_ARG
#   UOPTION_COPYRIGHT           -> "copyright", 'c', UOPT_NO_ARG
#   UOPTION_DESTDIR             -> "destdir", 'd', UOPT_REQUIRES_ARG
#   UOPTION_SOURCEDIR           -> "sourcedir", 's', UOPT_REQUIRES_ARG
#   UOPTION_ENCODING            -> "encoding", 'e', UOPT_REQUIRES_ARG
#   UOPTION_ICUDATADIR          -> "icudatadir", 'i', UOPT_REQUIRES_ARG
#   UOPTION_BUNDLE_NAME         -> "bundle-name", 'b', UOPT_REQUIRES_ARG
# Long-only flags decoded source-direct from `'\1'` placeholder
# short-char (icupkg --ignore-deps/--auto_toc_prefix/
# --auto_toc_prefix_with_type/--toc_prefix, gennorm2 --csource/
# --combined/--fast).
# Reference accessed: 2026-05-30 via gh api.
# unicode-org icu R176 — 7-stem multi-binary harvest of the
# core ICU `icu4c/source/tools/` data-builder + endian-swap +
# package-management binaries shipped alongside the already-
# covered ICU companions (uconv, genrb, pkgdata, genccode,
# gencnval, gendict, makeconv, icu-config, icuinfo,
# icuexportdata).  Sister tools to the heavily-covered Unicode
# / charset / locale family (recode, iconvconfig, fc-* font-
# config family) already in the corpus.

local -a uopt_shared=(
  '(-h --help -?)'{-h,--help,-\\?}'[print help and exit]'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '(-c --copyright)'{-c,--copyright}'[embed ICU copyright in the generated data]'
)

case $service in

  icupkg)
    # icupkg manages ICU resource-bundle .dat package files
    # (build/swap/extract/add/remove members).
    _arguments -s -S \
      $uopt_shared \
      '(-t --type)'{-t+,--type=}'[output data type/endianness/cs (l|b|e for little/big/EBCDIC)]:type:(l b e)' \
      '(-C --comment)'{-C+,--comment=}'[comment to embed in the output package]:comment:' \
      '(-s --sourcedir)'{-s+,--sourcedir=}'[input source directory]:dir:_files -/' \
      '(-d --destdir)'{-d+,--destdir=}'[output destination directory]:dir:_files -/' \
      '(-w --writepkg)'{-w,--writepkg}'[write modified package even if no changes were made]' \
      '(-m --matchmode)'{-m+,--matchmode=}'[member-name match mode for -a/-r/-x lists]:mode:(noslash)' \
      '--ignore-deps[ignore dependencies between data items]' \
      '(-a --add)'{-a+,--add=}'[add items listed in FILE (one item per line)]:file:_files' \
      '(-r --remove)'{-r+,--remove=}'[remove items listed in FILE]:file:_files' \
      '(-x --extract)'{-x+,--extract=}'[extract items listed in FILE]:file:_files' \
      '(-l --list)'{-l,--list}'[list package contents]' \
      '(-o --outlist)'{-o+,--outlist=}'[write the package member list to FILE]:file:_files' \
      '--auto_toc_prefix[auto-derive table-of-contents prefix from output package name]' \
      '--auto_toc_prefix_with_type[same as --auto_toc_prefix but include the type]' \
      '--toc_prefix=[explicit table-of-contents prefix string]:prefix:' \
      '1:input package (.dat):_files -g "*.dat"' \
      '2:output package (.dat) (omit for in-place):_files -g "*.dat"'
    ;;

  icuswap)
    # icuswap swaps the endianness / charset family of an ICU
    # data file in place or to a new file.
    _arguments -s -S \
      $uopt_shared \
      '(-t --type)'{-t+,--type=}'[target type/endianness/cs (l|b|e)]:type:(l b e)' \
      '1:input ICU data file:_files' \
      '2:output ICU data file (omit for in-place):_files'
    ;;

  genbrk)
    # genbrk compiles a break-iterator rules source file (.txt)
    # into a binary RBBI rules file.
    _arguments -s -S \
      $uopt_shared \
      '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
      '(-r --rules)'{-r+,--rules=}'[input rules text file]:file:_files -g "*.txt"' \
      '(-o --out)'{-o+,--out=}'[output binary rules file]:file:_files' \
      '(-i --icudatadir)'{-i+,--icudatadir=}'[icudatadir override]:dir:_files -/' \
      '(-d --destdir)'{-d+,--destdir=}'[output destination directory]:dir:_files -/'
    ;;

  gencfu)
    # gencfu compiles Unicode confusables data (UTS #39) into
    # an ICU SpoofChecker binary data file.
    _arguments -s -S \
      $uopt_shared \
      '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
      '(-r --rules)'{-r+,--rules=}'[input confusables.txt rules file]:file:_files -g "*.txt"' \
      '(-w --wsrules)'{-w+,--wsrules=}'[(deprecated) whole-script confusables rules file]:file:_files -g "*.txt"' \
      '(-o --out)'{-o+,--out=}'[output binary confusables file]:file:_files' \
      '(-i --icudatadir)'{-i+,--icudatadir=}'[icudatadir override]:dir:_files -/' \
      '(-d --destdir)'{-d+,--destdir=}'[output destination directory]:dir:_files -/'
    ;;

  gennorm2)
    # gennorm2 compiles Unicode normalization input data into
    # binary .nrm files used by Normalizer2.
    _arguments -s -S \
      $uopt_shared \
      '(-s --sourcedir)'{-s+,--sourcedir=}'[input source directory]:dir:_files -/' \
      '(-o --output)'{-o+,--output=}'[output .nrm file]:file:_files -g "*.nrm"' \
      '(-u --unicode)'{-u+,--unicode=}'[Unicode version of the input data]:ver:' \
      '--csource[emit a C source file instead of binary]' \
      '--combined[combine input files into a single Normalizer2 file]' \
      '--fast[skip slow consistency checks]' \
      '*:input txt file:_files -g "*.txt"'
    ;;

  gencmn)
    # gencmn packages a list of individual ICU data files into
    # a single .dat memory-mapped file.
    _arguments -s -S \
      $uopt_shared \
      '(-d --destdir)'{-d+,--destdir=}'[output destination directory]:dir:_files -/' \
      '(-C --comment)'{-C+,--comment=}'[comment embedded in output package]:comment:' \
      '(-n --name)'{-n+,--name=}'[output base name]:name:' \
      '(-t --type)'{-t+,--type=}'[output data type (dat|c|cpp etc.)]:type:' \
      '(-S --source)'{-S,--source}'[generate C source instead of binary]' \
      '(-e --entrypoint)'{-e+,--entrypoint=}'[C source entrypoint symbol name]:sym:' \
      '(-s --sourcedir)'{-s+,--sourcedir=}'[input source directory]:dir:_files -/' \
      '1:max size:' \
      '2:listing-file (one filename per line; - for stdin):_files'
    ;;

  gensprep)
    # gensprep compiles StringPrep profile data (rfc3454-style)
    # into a binary .spp file used by usprep.
    _arguments -s -S \
      $uopt_shared \
      '(-d --destdir)'{-d+,--destdir=}'[output destination directory]:dir:_files -/' \
      '(-s --sourcedir)'{-s+,--sourcedir=}'[input source directory]:dir:_files -/' \
      '(-i --icudatadir)'{-i+,--icudatadir=}'[icudatadir override]:dir:_files -/' \
      '(-b --bundle-name)'{-b+,--bundle-name=}'[output bundle base name]:name:' \
      '(-n --normalization)'{-n+,--normalization=}'[normalization profile name]:name:' \
      '(-m --norm-correction)'{-m+,--norm-correction=}'[normalization-correction file]:file:_files' \
      '(-k --check-bidi)'{-k,--check-bidi}'[apply RFC 3454 BIDI check]' \
      '(-u --unicode)'{-u+,--unicode=}'[Unicode version of input data]:ver:' \
      '*:input txt file:_files -g "*.txt"'
    ;;

esac
