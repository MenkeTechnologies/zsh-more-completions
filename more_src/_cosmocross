#compdef cosmocross x86_64-linux-cosmo-gcc aarch64-linux-cosmo-gcc x86_64-linux-cosmo-g++ aarch64-linux-cosmo-g++
# Documentation: https://github.com/jart/cosmopolitan/blob/master/tool/cosmocc/bin/cosmocross
# Reference accessed: 2026-05-27
# Verified: upstream tool/cosmocc/bin/cosmocross shell script argv parser

# Zsh completion for cosmocross (single-architecture cosmopolitan
# compiler driver).
# The script derives its target architecture from its own invocation
# name (e.g. x86_64-linux-cosmo-gcc, aarch64-linux-cosmo-g++) via
# ARCH=${PROG%%-*}. It then forwards to the matching cosmo gcc/g++,
# objcopy, strip, plus the helpers tlscc, fixupobj, zipcopy.

local arguments

arguments=(
  '-mcosmo[define _COSMO_SOURCE for cosmopolitan extensions]'
  '-mdbg[link against the debug runtime]'
  '-mtiny[link against the tiny runtime]'
  '-msysv[build for System V ABI only]'
  '-moptlinux[build optimized Linux-only binaries]'
  '-mtinylinux[build tiny Linux-only binaries]'
  '-mno-red-zone[disable the x86_64 System V red zone]'
  '-ffast-math[link crtfastmath.o for fast math semantics]'
  '-funsafe-math-optimizations[link crtfastmath.o for fast math semantics]'
  '-fomit-frame-pointer[omit frame pointer where possible]'
  '-fportcosmo[generate cosmopolitan-portable code]'
  '-save-temps[keep intermediate build outputs]'
  '-v[verbose: print invoked subprocesses]'
  '-c[compile and assemble only, do not link]'
  '-S[compile only, do not assemble or link]'
  '-E[preprocess only]'
  '-M[generate dependency file only]'
  '-MM[generate dependency file, system headers excluded]'
  '-MD[generate dependency file alongside compilation]'
  '-MMD[generate dependency file alongside compilation, no system headers]'
  '-MF+[write generated dependency file to FILE]:file:_files'
  '-MQ+[quoted target name for dependency rule]:target:'
  '-MT+[target name for dependency rule]:target:'
  '-o+[write output to FILE]:file:_files'
  '-s[strip output]'
  '-x+[language of subsequent input files]:lang:(c c++ c-header c++-header assembler none)'
  '-O+[optimization level]:level:(0 1 2 3 s g fast)'
  '-dumpversion[print compiler version number]'
  '--version[print compiler version banner]'
  '--help[display README]'
  '*-D+[predefine NAME=VALUE macro]:macro:'
  '*-U+[undefine NAME macro]:macro:'
  '*-I+[add include search directory]:directory:_files -/'
  '*-L+[add library search directory]:directory:_files -/'
  '*-l+[link with library NAME]:library:'
  '*-iquote+[add quoted include search directory]:directory:_files -/'
  '*-isystem+[add system include search directory]:directory:_files -/'
  '*-include+[force include header at start of each input]:file:_files'
  '*-T+[use linker script FILE]:file:_files'
  '*:filename:_files -g "*.(c|cc|cxx|cpp|C|c++|i|ii|o|a|h|hpp|hxx|S|s)(-.)"'
)

_arguments -s -S $arguments
