#compdef jack-smf-player
# play a standard MIDI file through JACK MIDI

local ret=1

_arguments -s -S \
  '-a+[automatically connect to named input port]:port' \
  '-d[when throttling, drop messages instead of delaying]' \
  '-n[do not start JACK transport at startup]' \
  '-q[be quiet, do not print SMF metaevent messages]' \
  '-s[do not create per-track output ports]' \
  '-t[do not use JACK transport]' \
  '-l[loop the song forever]' \
  '-V[show version]' \
  '-r+[output rate limit in Kbaud]:rate' \
  '*:MIDI file:_files -g "*.(mid|smf|MID)"' && ret=0

return ret
