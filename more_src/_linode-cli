#compdef linode-cli

# Zsh completion for linode-cli - Linode CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--text[output in text format]' \
  '--json[output in JSON format]' \
  '--markdown[output in markdown format]' \
  '--pretty[pretty-print JSON output]' \
  '--delimiter=[column delimiter]:delimiter' \
  '--no-headers[suppress column headers]' \
  '--all[return all results]' \
  '--format=[columns to display]:format' \
  '--suppress-warnings[suppress warnings]' \
  '--page=[page number]:page' \
  '--page-size=[results per page]:page size' \
  '--as-user=[act as user]:username' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'linodes:Manage Linode instances'
      'volumes:Manage block storage volumes'
      'nodebalancers:Manage NodeBalancers'
      'domains:Manage DNS domains'
      'stackscripts:Manage StackScripts'
      'images:Manage images'
      'regions:List available regions'
      'account:Manage account'
      'networking:Manage networking'
      'databases:Manage databases'
      'object-storage:Manage object storage'
      'lke:Manage Linode Kubernetes Engine'
    )
    _describe -t commands 'linode-cli command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      linodes)
        local -a subcmds=(
          'create:Create a Linode'
          'list:List Linodes'
          'view:View a Linode'
          'update:Update a Linode'
          'delete:Delete a Linode'
          'boot:Boot a Linode'
          'reboot:Reboot a Linode'
          'shutdown:Shut down a Linode'
          'clone:Clone a Linode'
          'resize:Resize a Linode'
          'rebuild:Rebuild a Linode'
          'rescue:Boot into rescue mode'
          'ips:List IP addresses'
          'migrate:Migrate a Linode'
          'mutate:Upgrade a Linode'
        )
        _describe -t subcmds 'linodes subcommand' subcmds && ret=0
        ;;
      volumes)
        local -a subcmds=(
          'create:Create a volume'
          'list:List volumes'
          'view:View a volume'
          'update:Update a volume'
          'delete:Delete a volume'
          'attach:Attach a volume'
          'detach:Detach a volume'
          'clone:Clone a volume'
          'resize:Resize a volume'
        )
        _describe -t subcmds 'volumes subcommand' subcmds && ret=0
        ;;
      nodebalancers)
        local -a subcmds=(
          'create:Create a NodeBalancer'
          'list:List NodeBalancers'
          'view:View a NodeBalancer'
          'update:Update a NodeBalancer'
          'delete:Delete a NodeBalancer'
          'configs:Manage NodeBalancer configs'
          'nodes:Manage NodeBalancer nodes'
        )
        _describe -t subcmds 'nodebalancers subcommand' subcmds && ret=0
        ;;
      domains)
        local -a subcmds=(
          'create:Create a domain'
          'list:List domains'
          'view:View a domain'
          'update:Update a domain'
          'delete:Delete a domain'
          'records:Manage domain records'
          'clone:Clone a domain'
          'import:Import a domain'
        )
        _describe -t subcmds 'domains subcommand' subcmds && ret=0
        ;;
      stackscripts)
        local -a subcmds=(
          'create:Create a StackScript'
          'list:List StackScripts'
          'view:View a StackScript'
          'update:Update a StackScript'
          'delete:Delete a StackScript'
        )
        _describe -t subcmds 'stackscripts subcommand' subcmds && ret=0
        ;;
      images)
        local -a subcmds=(
          'create:Create an image'
          'list:List images'
          'view:View an image'
          'update:Update an image'
          'delete:Delete an image'
        )
        _describe -t subcmds 'images subcommand' subcmds && ret=0
        ;;
      regions)
        local -a subcmds=(
          'list:List regions'
          'view:View a region'
          'avail:View region availability'
        )
        _describe -t subcmds 'regions subcommand' subcmds && ret=0
        ;;
      account)
        local -a subcmds=(
          'view:View account info'
          'settings:Manage account settings'
          'events:List events'
          'invoices:List invoices'
          'payments:List payments'
          'transfer:View network transfer'
          'users:Manage users'
        )
        _describe -t subcmds 'account subcommand' subcmds && ret=0
        ;;
      networking)
        local -a subcmds=(
          'ips:List IP addresses'
          'ip-view:View an IP address'
          'ip-update:Update an IP address'
          'vlans:Manage VLANs'
          'firewalls:Manage firewalls'
        )
        _describe -t subcmds 'networking subcommand' subcmds && ret=0
        ;;
      lke)
        local -a subcmds=(
          'clusters-list:List LKE clusters'
          'cluster-create:Create an LKE cluster'
          'cluster-view:View an LKE cluster'
          'cluster-delete:Delete an LKE cluster'
          'pools:Manage node pools'
          'kubeconfig:View kubeconfig'
          'dashboard-url:Get dashboard URL'
        )
        _describe -t subcmds 'lke subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
