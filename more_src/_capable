#compdef capable capable-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/capable.py argparse)
# Reference accessed: 2026-05-29
# capable — trace kernel capability(7) checks (BCC/eBPF). Audits cap_capable() with PID/TID/comm/CAP.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[include non-audit checks]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-K --kernel-stack)'{-K,--kernel-stack}'[output kernel stack trace]' \
  '(-U --user-stack)'{-U,--user-stack}'[output user stack trace]' \
  '(-x --extra)'{-x,--extra}'[show extra fields in TID and INSETID columns]' \
  '--cgroupmap=[trace cgroups in this BPF map only]:map:' \
  '--mntnsmap=[trace mount namespaces in this BPF map only]:map:' \
  '--unique[do not repeat stacks for the same pid or cgroup]' \
  && ret=0

return ret
