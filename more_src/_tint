# tint_lookup <name> - Look up theme by name
#
# Stdout: full theme string (#bg:#fg:#00:#01:...:#15)
# Returns: 0 if found, 1 if not found
tint_lookup() {
    local name="$1"
    local line
    # case pattern is quoted so $name matches literally, not as a glob.
    while IFS= read -r line; do
        case "$line" in
            "$name:"*) printf '%s' "${line#*:}"; return 0 ;;
        esac
    done <<EOF
$TINT_PALETTE
EOF
    return 1
}

# tint_resolve <input> - Resolve name/hex/"reset" to theme value
#
# For hex input: returns #rrggbb. For name: returns full theme string.
# For "reset": returns empty.
# Returns: 0 on success, 1 on failure (safe under set -e)
tint_resolve() {
    local input="$1"
    [ "$input" = "reset" ] && return 0
    case "$input" in
        '#'[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F])
            printf '%s' "$input"; return 0 ;;
        '#'[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F])
            # Expand 3-digit hex to 6-digit (#abc → #aabbcc)
            local h="${input#\#}"
            local c1="${h%??}" c3="${h#??}" c2
            c2="${h#?}"; c2="${c2%?}"
            printf '%s' "#${c1}${c1}${c2}${c2}${c3}${c3}"; return 0 ;;
    esac
    # Guard lookup failure to prevent set -e from aborting caller
    tint_lookup "$input" || return 1
}

# tint_list - Print all palette entries
#
# Stdout: theme names, one per line
tint_list() {
    local name _rest
    printf '%s\n' "$TINT_PALETTE" | while IFS=: read -r name _rest; do
        printf '%s\n' "$name"
    done
}

# _tint_palette_get <n> - Get nth palette entry (1-indexed)
#
# Stdout: name:#hex entry
_tint_palette_get() {
    printf '%s\n' "$TINT_PALETTE" | sed -n "${1}p"
}

# _tint_palette_count - Get number of palette entries
#
# Stdout: integer count
_tint_palette_count() {
    # Count non-empty lines. grep -c exits non-zero when no matches,
    # so we capture output first to avoid || echo appending a second "0"
    local count
    count=$(printf '%s\n' "$TINT_PALETTE" | grep -c . 2>/dev/null) || count=0
    printf '%s' "$count"
}

