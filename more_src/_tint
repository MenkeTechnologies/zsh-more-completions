# _tint_usage - Print usage information to stdout
_tint_usage() {
    cat <<'EOF'
tint - terminal theme switcher

Switch your terminal's color theme. Run tint to pick interactively,
or tint <name> to set one directly. Each theme sets background,
foreground, and all 16 ANSI colors. Add .tint files to directories
for automatic theme switching.

USAGE
    tint                      Interactive picker with live preview
    tint <name|hex>           Set theme directly
    tint random               Pick a random theme
    tint reset                Reset to terminal default
    tint completions <shell>  Output shell completions (bash/zsh/fish)
    tint hook <shell>         Output shell integration code
    tint -h, --help           Show this help
    tint -l, --list           List available themes
    tint -v, --version        Show version

INTERACTIVE CONTROLS
    ←/→  h/l              Navigate themes
    ↑/↓  k/j              Navigate themes
    Enter                 Select theme
    Esc  q                Cancel (restore original)

EXAMPLES
    tint dracula          Set by name
    tint "#002b36"        Set by hex code
    tint random           Surprise me
    tint reset            Reset to terminal default
    tint --list           Show all available themes

SHELL INTEGRATION
    Add to your shell's rc file:

        # bash (~/.bashrc)
        eval "$(tint hook bash)"

        # zsh (~/.zshrc)
        eval "$(tint hook zsh)"

    Create .tint files in project directories:

        echo "dracula" > ~/projects/myproject/.tint
        echo "reset" > ~/projects/personal/.tint    # reset to default

    The hook walks up from $PWD to / looking for the nearest .tint file.
    Themes are sticky — if no .tint is found, the current theme is kept.
    Place a .tint in ~ for a global default.

    Hook output is silent on success; errors (unknown theme, malformed
    .tint, etc.) print to stderr. Set TINT_HOOK_VERBOSE=1 to also print
    "tint: <theme> from <path>" each time the hook applies a theme.

CONFIGURATION
    User themes:          $XDG_CONFIG_HOME/tint/themes/
                          (or $TINT_PALETTE_DIR to override location)

    Drop any file with theme entries into the directory. Files are read
    in alphabetical order and appended to the built-in palette.

    Theme format (one per line):
        name:#bg:#fg:#00:#01:#02:#03:#04:#05:#06:#07:#08:#09:#10:#11:#12:#13:#14:#15
    Each value is a #RRGGBB hex color (bg, fg, then 16 ANSI colors 0-15).

MORE INFO
    https://github.com/corygabrielsen/tint
EOF
}

# _tint_hook_bash - Output bash shell integration code
#
# Outputs a self-contained hook that auto-applies .tint themes on directory change.
# Designed for: eval "$(tint hook bash)"
_tint_hook_bash() {
    cat <<'HOOK'
_tint_hook() {
    local _tint_ret=$?
    if [ "${_TINT_HOOK_PWD:-}" = "$PWD" ]; then
        return "$_tint_ret"
    fi
    _TINT_HOOK_PWD="$PWD"
    local _tint_dir="$PWD" _tint_file=""
    # Guard against non-absolute PWD (would loop forever in walk-up)
    case "$_tint_dir" in /*) ;; *) return "$_tint_ret" ;; esac
    while true; do
        if [ -f "$_tint_dir/.tint" ] && [ -r "$_tint_dir/.tint" ]; then
            _tint_file="$_tint_dir/.tint"
            break
        fi
        if [ "$_tint_dir" = "/" ]; then
            break
        fi
        _tint_dir="${_tint_dir%/*}"
        if [ -z "$_tint_dir" ]; then
            _tint_dir="/"
        fi
    done
    if [ -z "$_tint_file" ]; then
        _TINT_HOOK_COLOR=""
        return "$_tint_ret"
    fi
    local _tint_color
    _tint_color=$(command sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]#.*//; s/[[:space:]]*$//' "$_tint_file" | command grep -m1 -E '^(#[0-9a-fA-F]{3}$|#[0-9a-fA-F]{6}$|[^#-])' || true)
    if [ -z "$_tint_color" ]; then
        _TINT_HOOK_COLOR=""
        return "$_tint_ret"
    fi
    # Cache by .tint value. Theme-file edits under TINT_PALETTE_DIR
    # don't invalidate; re-run `tint <name>` manually.
    if [ "$_tint_color" = "${_TINT_HOOK_COLOR:-}" ]; then
        return "$_tint_ret"
    fi
    _TINT_HOOK_COLOR="$_tint_color"
    # Uses `tint` by name (standard convention; cf. direnv, zoxide, starship).
    # stderr passes through so errors (unknown theme, malformed .tint, etc.)
    # surface to the user — previously suppressed, which silently broke hooks.
    # TINT_HOOK_VERBOSE=1 opts into direnv-style "applied X from Y" messages.
    # `if` form neutralizes errexit: bash skips `set -e` propagation for
    # commands in tested conditions (`if`, `while`, `until`, `&&`, `||`).
    # Subshell isolates against bash 3.2 (macOS) errexit-in-function quirks
    # where `set -e` could leak across function boundaries; the subshell's
    # exit code is what `if` tests.
    if ( command tint "$_tint_color" >/dev/null ); then
        if [ "${TINT_HOOK_VERBOSE:-0}" = "1" ]; then
            printf 'tint: %s from %s\n' "$_tint_color" "$_tint_file" >&2
        fi
    fi
    return "$_tint_ret"
}
# Prepend to PROMPT_COMMAND, handling both string and array forms (Bash 5.1+)
if [[ "$(declare -p PROMPT_COMMAND 2>/dev/null)" == "declare -a"* ]]; then
    # Array form: prepend so _tint_hook captures $? from user's last command
    _tint_found=0
    for _tint_pc in "${PROMPT_COMMAND[@]}"; do
        [[ "$_tint_pc" == "_tint_hook" ]] && _tint_found=1 && break
    done
    (( _tint_found )) || PROMPT_COMMAND=("_tint_hook" "${PROMPT_COMMAND[@]}")
    unset _tint_found _tint_pc
elif [[ ! "${PROMPT_COMMAND:-}" =~ (^|[;[:space:]])_tint_hook($|[;[:space:]]) ]]; then
    PROMPT_COMMAND="_tint_hook${PROMPT_COMMAND:+;$PROMPT_COMMAND}"
fi
_tint_hook
HOOK
}

# _tint_hook_zsh - Output zsh shell integration code
#
# Outputs a self-contained hook that auto-applies .tint themes on directory change.
# Uses chpwd_functions (native zsh dir-change hook, no PWD cache needed).
# Designed for: eval "$(tint hook zsh)"
_tint_hook_zsh() {
    cat <<'HOOK'
_tint_hook() {
    # Skip during zle widgets (tab completion, etc.) — zsh's _cd
    # handler can temporarily change PWD, triggering chpwd spuriously
    [[ -n "${WIDGET:-}" ]] && return
    local _tint_dir="$PWD" _tint_file=""
    # Guard against non-absolute PWD (would loop forever in walk-up)
    case "$_tint_dir" in /*) ;; *) return ;; esac
    while true; do
        if [ -f "$_tint_dir/.tint" ] && [ -r "$_tint_dir/.tint" ]; then
            _tint_file="$_tint_dir/.tint"
            break
        fi
        if [ "$_tint_dir" = "/" ]; then
            break
        fi
        _tint_dir="${_tint_dir%/*}"
        if [ -z "$_tint_dir" ]; then
            _tint_dir="/"
        fi
    done
    if [ -z "$_tint_file" ]; then
        _TINT_HOOK_COLOR=""
        return
    fi
    local _tint_color
    _tint_color=$(command sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]#.*//; s/[[:space:]]*$//' "$_tint_file" | command grep -m1 -E '^(#[0-9a-fA-F]{3}$|#[0-9a-fA-F]{6}$|[^#-])' || true)
    if [ -z "$_tint_color" ]; then
        _TINT_HOOK_COLOR=""
        return
    fi
    # Cache by .tint value. Theme-file edits under TINT_PALETTE_DIR
    # don't invalidate; re-run `tint <name>` manually.
    if [ "$_tint_color" = "${_TINT_HOOK_COLOR:-}" ]; then
        return
    fi
    _TINT_HOOK_COLOR="$_tint_color"
    # Uses `tint` by name (standard convention; cf. direnv, zoxide, starship).
    # stderr passes through so errors (unknown theme, malformed .tint, etc.)
    # surface to the user — previously suppressed, which silently broke hooks.
    # TINT_HOOK_VERBOSE=1 opts into direnv-style "applied X from Y" messages.
    # `if ( ... )` guard prevents a non-zero exit from `tint` from aborting
    # the hook when the user's shell is running under `set -e` / errexit;
    # the subshell additionally isolates any state changes.
    if ( command tint "$_tint_color" >/dev/null ); then
        if [ "${TINT_HOOK_VERBOSE:-0}" = "1" ]; then
            printf 'tint: %s from %s\n' "$_tint_color" "$_tint_file" >&2
        fi
    fi
}
if [[ -z "${chpwd_functions[(r)_tint_hook]-}" ]]; then
    chpwd_functions+=(_tint_hook)
fi
_tint_hook
HOOK
}

# _tint_main - CLI entry point, dispatch subcommand or launch interactive picker
_tint_main() {
    # Explicit empty argument is invalid, not interactive mode
    if [ $# -gt 0 ] && [ -z "$1" ]; then
        echo "error: theme name cannot be empty" >&2
        exit 1
    fi
    # Reject extra arguments — most commands take zero, completions/hook take one
    if [ $# -gt 1 ] && [ "$1" != "completions" ] && [ "$1" != "hook" ]; then
        echo "error: unexpected argument: $2" >&2
        echo "Run 'tint --help' for usage" >&2
        exit 1
    fi
    if [ $# -gt 2 ]; then
        echo "error: unexpected argument: $3" >&2
        echo "Run 'tint --help' for usage" >&2
        exit 1
    fi
    case "${1:-}" in
        "")
            # Interactive mode requires bash for read -n/-t (single-char input).
            # We use /bin/sh shebang so non-interactive commands work on systems
            # without bash (Alpine, busybox). Re-exec into bash for interactive.
            # shellcheck disable=SC3028,SC3054
            if ! (eval '[ "${BASH_VERSINFO[0]+_}" = _ ]') 2>/dev/null; then
                # $0 contains the full path even when invoked via PATH - dash, zsh,
                # and busybox sh all resolve it. If bash is available, re-exec into
                # it. On systems without bash (e.g., Alpine), fall through to error.
                if command -v bash >/dev/null 2>&1; then
                    exec bash "$0" "$@"
                fi
                echo "error: interactive mode requires bash" >&2
                echo "usage: tint <theme|hex>  or  tint --list" >&2
                exit 1
            fi
            if ! tint_supports_color; then
                echo "error: interactive mode requires a terminal" >&2
                echo "usage: tint <theme|hex>  or  tint --list" >&2
                exit 1
            fi
            # local is safe: the shebang re-exec ensures bash before _tint_main
            # Cancel (return 1) and unchanged (return 0, empty output) both produce
            # no stdout — this is intentional. The CLI always exits 0 for interactive
            # mode; the library-level tint_pick distinguishes them via return code.
            local _tint_result
            if _tint_result=$(tint_pick); then
                if [ -n "$_tint_result" ]; then printf '%s\n' "$_tint_result"; fi
            fi
            ;;
        -h|--help)
            _tint_usage
            ;;
        -l|--list)
            tint_list
            ;;
        -v|--version)
            echo "tint $TINT_VERSION"
            ;;
        -*)
            echo "Unknown option: $1" >&2
            echo "Run 'tint --help' for usage" >&2
            exit 1
            ;;
        completions)
            # ${2-bash} (no colon): defaults only when unset; empty "" hits *)
            case "${2-bash}" in
                bash) _tint_completions_bash ;;
                zsh)  _tint_completions_zsh ;;
                fish) _tint_completions_fish ;;
                *)
                    echo "error: unknown shell: $2" >&2
                    echo "Supported: bash, zsh, fish" >&2
                    exit 1
                    ;;
            esac
            ;;
        hook)
            if [ $# -ne 2 ]; then
                echo "error: usage: tint hook <bash|zsh>" >&2
                exit 1
            fi
            case "$2" in
                bash) _tint_hook_bash ;;
                zsh)  _tint_hook_zsh ;;
                *)
                    echo "error: unsupported shell: $2" >&2
                    echo "Supported shells: bash, zsh" >&2
                    exit 1
                    ;;
            esac
            ;;
        random)
            local count entry name theme idx
            count=$(_tint_palette_count)
            if [ "$count" -eq 0 ]; then
                echo "No themes in palette" >&2
                exit 1
            fi
            # Build seed in awk to avoid shell arithmetic octal pitfalls.
            # date +%N output can have leading zeros (octal in shell) or be
            # non-numeric on BSD/macOS. awk handles all of these safely.
            idx=$(awk -v max="$count" -v pid="$$" -v sec="$(date +%s)" \
                      -v nsec="$(date +%N 2>/dev/null || echo 0)" \
                      -v rnd="${RANDOM:-0}" \
                'BEGIN{ srand(pid * sec + rnd + (nsec+0)); print int(rand()*max)+1 }')
            entry=$(_tint_palette_get "$idx")
            name="${entry%%:*}"
            theme="${entry#*:}"
            tint_set "$theme"
            echo "$name"
            ;;
        reset)
            tint_reset
            # Symmetric with the apply-by-name and apply-by-hex paths.
            echo "reset"
            ;;
        *)
            # shellcheck disable=SC3043
            local resolved
            if resolved=$(tint_resolve "$1") && [ -n "$resolved" ]; then
                tint_set "$resolved"
                # For hex input, echo the normalized value (e.g., #abc → #aabbcc).
                # For named themes, echo the name the user typed.
                case "$1" in
                    '#'*) echo "${resolved%%:*}" ;;
                    *)    echo "$1" ;;
                esac
            else
                echo "Unknown theme: $1" >&2
                echo "Run 'tint --list' for available themes" >&2
                exit 1
            fi
            ;;
    esac
}

# _tint_is_main - Detect whether this script is executed vs sourced
#
# Detection hierarchy: Bash (BASH_SOURCE) → Zsh (ZSH_EVAL_CONTEXT) → POSIX
# (grep $0 for marker URL). When invoked as "bash tint" or "sh tint", $0 is
# the script path, not the shell.
#
# Returns: 0 if executed directly, 1 if sourced
# shellcheck disable=SC3028,SC3054
_tint_is_main() {
    # Bash: BASH_SOURCE[0] is array syntax that only works under bash.
    # Test array access in a subshell first — if BASH_VERSION leaks via
    # environment into dash/sh, the subshell catches the fatal "Bad
    # substitution" error without killing the parent script.
    if (eval '[ "${BASH_SOURCE[0]+_}" = _ ]') 2>/dev/null; then
        [ "${BASH_SOURCE[0]}" = "$0" ]
        return
    fi
    # Zsh: when executed, context is "toplevel" or "toplevel:shfunc"
    # When sourced, context contains ":file:"
    if [ -n "${ZSH_EVAL_CONTEXT:-}" ]; then
        case "$ZSH_EVAL_CONTEXT" in
            *:file:*|*:file) return 1 ;;  # Sourced
            toplevel*) return 0 ;;        # Executed
            *) return 1 ;;
        esac
    fi
    # POSIX fallback: check if $0 actually IS this script.
    # When executed (even via symlink/rename): $0 resolves to tint, which
    # contains our unique header URL. When sourced from another script: $0
    # is the calling script or shell, which won't have our marker.
    # Fast path: known shell names are definitely sourced.
    case "${0##*/}" in
        sh|dash|ash|bash|zsh|ksh|csh|tcsh|fish|-*) return 1 ;;
    esac
    # For other $0 values (symlinks, renames, or sourcing from scripts),
    # check if $0 contains our unique header URL (won't appear in caller scripts).
    # Note: a caller that includes this exact URL line would be a false positive,
    # but this is the best available POSIX heuristic (no reliable sourced-vs-exec
    # detection exists in POSIX sh). The anchored full URL makes collisions
    # negligible in practice.
    if [ -f "$0" ] && grep -qm1 '^# https://github.com/corygabrielsen/tint$' "$0" 2>/dev/null; then
        return 0  # Executed (tint, symlink, renamed copy)
    fi
    return 1  # Sourced from another script
}

if _tint_is_main; then
    set -eu
    _tint_main "$@"
fi
