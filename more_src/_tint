# _tint_load_palette - Build TINT_PALETTE from built-ins + $TINT_PALETTE_DIR.
# Built-ins win on name collision (deduped by name, first wins).
_tint_load_palette() {
    # TINT_PALETTE_DIR wins (empty = hermetic). Absolute only;
    # relative would resolve against $PWD.
    local _tint_theme_dir=""
    if [ "${TINT_PALETTE_DIR+set}" = "set" ]; then
        case "$TINT_PALETTE_DIR" in /*|'') _tint_theme_dir="$TINT_PALETTE_DIR" ;; esac
    else
        case "${XDG_CONFIG_HOME:-}" in
            /*) _tint_theme_dir="$XDG_CONFIG_HOME/tint/themes" ;;
            *) case "${HOME:-}" in
                /*) _tint_theme_dir="$HOME/.config/tint/themes" ;;
               esac ;;
        esac
    fi

    if [ -n "$_tint_theme_dir" ] && [ -d "$_tint_theme_dir" ] && [ -r "$_tint_theme_dir" ]; then
        # ls -1A (not glob): handles empty dirs, dotfiles, symlinks. Env
        # sanitization defeats user aliases / QUOTING_STYLE / CLICOLOR_FORCE.
        # Heredoc expansion is one-pass per POSIX: $() output below is read
        # verbatim, so filenames containing $(), backticks, or $VAR aren't
        # re-interpreted by the shell.
        set --
        local _tint_theme_name _tint_theme_path
        while IFS= read -r _tint_theme_name; do
            [ -z "$_tint_theme_name" ] && continue
            _tint_theme_path="$_tint_theme_dir/$_tint_theme_name"
            if [ -f "$_tint_theme_path" ] && [ -r "$_tint_theme_path" ]; then
                set -- "$@" "$_tint_theme_path"
            fi
        done <<EOF
$(
            unset CLICOLOR_FORCE CLICOLOR
            # LC_ALL=C pins ls sort collation.
            # shellcheck disable=SC2012  # filenames with newlines unsupported
            LC_ALL=C QUOTING_STYLE=literal command ls -1A "$_tint_theme_dir"
        )
EOF
    fi

    # awk required (no fallback). Built-ins on stdin, drop-ins as operands —
    # awk records don't cross files (POSIX), so a missing trailing newline
    # can't merge the last entry of one file with the first of the next.
    TINT_PALETTE=$(printf '%s\n' "$_TINT_DEFAULT_PALETTE" | command awk '
        BEGIN { FS = ":" }
        {
            sub(/[[:space:]]#.*/, "")
            sub(/^[[:space:]]+/, "")
            sub(/[[:space:]]+$/, "")
        }
        /^[a-zA-Z0-9][a-zA-Z0-9_-]*(:#[0-9a-fA-F]{6}){18}$/ && !seen[$1]++
    ' - "$@") || true
}

_tint_load_palette

# tint_reload_palette - Rebuild TINT_PALETTE after changing
# TINT_PALETTE_DIR / XDG_CONFIG_HOME / HOME post-source.
tint_reload_palette() {
    _tint_load_palette
}

