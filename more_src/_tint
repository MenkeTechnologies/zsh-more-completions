#compdef tint
# Documentation: https://github.com/corygabrielsen/tint
# Reference accessed: 2026-05-16
# Verified: upstream corygabrielsen/tint README + bin/tint script header.
# Removed from prior file: bogus man.archlinux.org search URL;
# the entire prior file was the upstream tint shell script body embedded
# verbatim (a generator bug — not a zsh completion at all).

# tint: terminal theme switcher (OSC 11 background-color)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'completions:print zsh completion code'
  'hook:print shell hook to load tint'
  'reset:reset terminal to default colors'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--list[list available themes]' \
  '1: :->arg' \
  '*::rest:->rest' && ret=0

case $state in
  (arg)
    _alternative \
      'commands:command:_describe "tint command" commands' \
      'themes:theme:_default' && ret=0
    ;;
esac
return ret
