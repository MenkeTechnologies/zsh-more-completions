# Terminal Functions
# =============================================================================

# tint_set <theme|bg> [<fg>] - Set terminal colors from theme string or bare hex
#
# Theme string mode (#bg:#fg:#00:#01:...:#15):
#   tint_set "theme_str"        — set bg, fg, and 16 ANSI colors from theme
#   tint_set "theme_str" "#fg"  — override theme fg with explicit fg
#   tint_set "theme_str" ""     — set bg + ANSI colors, leave fg untouched
#
# Bare hex mode (#RRGGBB):
#   tint_set "#bg"        — auto-compute fg from background luma
#   tint_set "#bg" "#fg"  — use explicit fg
#   tint_set "#bg" ""     — set bg only, leave fg untouched (unknown original)
#
# Why >/dev/tty 2>/dev/null?
#
# /dev/tty is a "magic" device that refers to the process's controlling terminal.
# It's not a real file - it's a kernel abstraction. The device node exists in the
# filesystem (so [ -e /dev/tty ] and [ -w /dev/tty ] return true), but writing to
# it fails with ENXIO ("No such device or address") when no terminal is attached.
#
# This happens in: cron jobs, systemd services, `dash -c '...'`, detached processes.
# We suppress stderr rather than pre-checking because:
#   1. [ -w /dev/tty ] tests permission bits, not device connectivity
#   2. [ -t 0 ] can be true while /dev/tty still fails (edge cases)
#   3. Silently failing is correct behavior - no terminal means nothing to tint
#
# Implementation notes:
#   - Subshell ( ... ) ensures the redirection error itself is captured
#   - 2>/dev/null on the subshell catches "No such device or address"
#   - || true prevents set -e from treating tty absence as fatal
#   - This pattern works across bash, dash, and other POSIX shells
#
tint_set() {
    local bg fg_seq="" ansi_seq=""
    case "$1" in
        *:*)
            # Full theme string: #bg:#fg:#00:#01:...:#15
            bg="${1%%:*}"
            local rest="${1#*:}" _tint_theme_fg
            _tint_theme_fg="${rest%%:*}"
            rest="${rest#*:}"
            if [ $# -ge 2 ] && [ -n "$2" ]; then
                fg_seq="${_TINT_ESC}]10;${2}${_TINT_ESC}\\"
            elif [ $# -lt 2 ]; then
                fg_seq="${_TINT_ESC}]10;${_tint_theme_fg}${_TINT_ESC}\\"
            fi
            # Build OSC 4;N;color sequences for 16 ANSI colors
            local i=0 color
            while [ -n "$rest" ]; do
                color="${rest%%:*}"
                ansi_seq="${ansi_seq}${_TINT_ESC}]4;${i};${color}${_TINT_ESC}\\"
                i=$((i + 1))
                if [ "$rest" = "${rest#*:}" ]; then break; fi
                rest="${rest#*:}"
            done
            ;;
        *)
            # Bare hex
            bg="$1"
            if [ $# -ge 2 ] && [ -n "$2" ]; then
                fg_seq="${_TINT_ESC}]10;${2}${_TINT_ESC}\\"
            elif [ $# -lt 2 ]; then
                fg_seq="${_TINT_ESC}]10;$(_tint_fg_for_bg "$bg")${_TINT_ESC}\\"
            fi
            ;;
    esac
    # When $# >= 2 but $2 is empty: skip OSC 10 (caller doesn't know the
    # original foreground, so leave it untouched rather than guessing)
    ( printf '%s' "${_TINT_ESC}]11;${bg}${_TINT_ESC}\\${fg_seq}${ansi_seq}" >/dev/tty ) 2>/dev/null || true
}

# tint_reset - Reset to terminal profile default via OSC 111 (bg) + OSC 110 (fg) + OSC 104 (ANSI)
# See tint_set for /dev/tty handling explanation.
tint_reset() {
    ( printf '\033]111\033\\\033]110\033\\\033]104\033\\' >/dev/tty ) 2>/dev/null || true
}

# _tint_query_osc_color <osc_code> - Query terminal for an OSC color
#
# Uses ( ) instead of { } so trap/stty changes can't leak to caller.
# All terminal I/O goes through /dev/tty explicitly, so the subshell
# capture ($(...)) doesn't interfere with stdin/stdout.
#
# Timeout: stty `time 2` = 200ms. This is a deliberate tradeoff: long enough
# for all known local and remote terminals to respond (the response is a single
# write from the terminal emulator), but short enough that non-responding
# terminals (e.g. TERM=dumb, serial consoles) don't block for seconds.
#
# Stdout: #rrggbb hex value
# Returns: 0 on success, 1 if terminal doesn't respond
_tint_query_osc_color() (
    old_settings=$(stty -g 2>/dev/null </dev/tty) || exit 1
    stty raw -echo min 0 time 2 </dev/tty 2>/dev/null || {
        stty "$old_settings" </dev/tty 2>/dev/null
        exit 1
    }
    trap 'stty "$old_settings" </dev/tty 2>/dev/null' EXIT

    printf '\033]%s;?\033\\' "$1" >/dev/tty
    response=$(dd bs=64 count=1 2>/dev/null </dev/tty | tr -d '\000')

    # Explicit restore (trap also fires on exit as safety net)
    stty "$old_settings" </dev/tty 2>/dev/null

    # Extract RGB: rgb:RRRR/GGGG/BBBB -> #RRGGBB (first 2 hex digits each)
    #
    # XParseColor allows 1-4 hex digits per component (h|hh|hhh|hhhh), but all known
    # terminals respond with 4 digits: xterm, VTE, urxvt, kitty, alacritty, foot (since
    # 2022). The regex requires 2+ digits, which safely handles all real-world responses.
    # See: https://codeberg.org/dnkl/foot/issues/971 (foot aligned to 4-digit standard)
    hex=$(printf '%s' "$response" | sed -n 's/.*rgb:\([0-9a-fA-F]\{2\}\)[0-9a-fA-F]*\/\([0-9a-fA-F]\{2\}\)[0-9a-fA-F]*\/\([0-9a-fA-F]\{2\}\)[0-9a-fA-F]*.*/#\1\2\3/p' | tr '[:upper:]' '[:lower:]')
    # Empty means no rgb: in response (timeout or unparsable) — treat as failure
    [ -n "$hex" ] || exit 1
    printf '%s' "$hex"
)

# _tint_query_terminal_bg - Query terminal for current background color (OSC 11)
_tint_query_terminal_bg() { _tint_query_osc_color 11; }

# _tint_query_terminal_fg - Query terminal for current foreground color (OSC 10)
_tint_query_terminal_fg() { _tint_query_osc_color 10; }

# tint_supports_color - Check if terminal likely supports OSC color sequences
#
# This is a heuristic, not a guarantee. We check:
#   1. TERM is not "dumb" (indicates minimal/no capabilities)
#   2. /dev/tty is writable (we have a controlling terminal)
#
# Note: [ -t 1 ] (stdout is a tty) is insufficient - we write to /dev/tty,
# not stdout. A process can have stdout redirected but still have a
# controlling terminal, or vice versa.
#
# We don't detect terminal multiplexers (tmux/screen) here. OSC 11 may or
# may not work through them depending on configuration. Users in tmux who
# want to change the *outer* terminal color need passthrough sequences,
# which we don't currently support.
#
# Returns: 0 if color support is likely, 1 otherwise
tint_supports_color() {
    [ "${TERM:-dumb}" != "dumb" ] || return 1
    # Try opening /dev/tty for writing - this is the definitive check
    ( printf '' >/dev/tty ) 2>/dev/null || return 1
    return 0
}

# _tint_fg_for_bg <hex> - Compute readable foreground color for a background
#
# Returns #000000 (black) for light backgrounds, #ffffff (white) for dark.
# Uses BT.601 luma: (R*299 + G*587 + B*114) / 1000, threshold > 128.
#
# POSIX-portable: uses printf '%d' "0x..." for hex-to-decimal conversion
# and parameter expansion (${hex#??}) for substring advancement.
#
# Stdout: #000000 or #ffffff
_tint_fg_for_bg() {
    local hex="$1" r g b luma
    # Strip leading # if present
    hex="${hex#\#}"
    r=$(printf '%d' "0x${hex%????}")
    hex="${hex#??}"
    g=$(printf '%d' "0x${hex%??}")
    hex="${hex#??}"
    b=$(printf '%d' "0x$hex")
    luma=$(( (r * 299 + g * 587 + b * 114) / 1000 ))
    if [ "$luma" -gt 128 ]; then
        printf '#000000'
    else
        printf '#ffffff'
    fi
}

# =============================================================================
# Interactive Picker
# =============================================================================
#
# State reference (all globals used by the picker subsystem):
#
#   Picker model                     Type  Description      Set by
#   ───────────────────────────────  ────  ───────────────  ───────────────────────────────────────────────────
#   _TINT_PICKER_IDX                 int   cursor pos       init_picker, find_default_index, model_move_cursor
#   _TINT_PICKER_OLD_IDX             int   prev cursor pos  init_picker, model_move_cursor
#   _TINT_PICKER_DEFAULT             int   star marker pos  find_default_index (caller arg) | init_picker (auto-detect fallback)
#   _TINT_PICKER_ORIGINAL_THEME_IDX  int   original theme   init_picker (auto-detect from queried bg + fg; 0 if ambiguous)
#   _TINT_PICKER_TOTAL               int   entry count      load_palette_arrays
#   _TINT_PICKER_VISIBLE             int   window rows      init_picker
#   _TINT_PICKER_KEY                 str   last keypress    read_key
#   _TINT_PICKER_EXIT_REASON         str   exit cause       install_signal_traps, accept_selection, picker_loop
#   _TINT_PICKER_SCROLLED            int   window shifted   init_picker, update_scroll_window
#   _TINT_PICKER_RESIZED             int   resize pending   install_signal_traps, handle_resize
#   _TINT_PICKER_WIN_START           int   top visible idx  init_picker, update_scroll_window
#   _TINT_PICKER_WIN_END             int   bot visible idx  init_picker, update_scroll_window
#
#   Resource flags                Type             Description     Set by
#   ────────────────────────────  ───────────────  ──────────────  ───────────────────────────────────────────────────
#   _TINT_PICKER_CURSOR_HIDDEN    bool             cursor hidden   install_signal_traps, hide_cursor, restore_terminal
#   _TINT_PICKER_ALT_SCREEN       bool             alt-screen on   install_signal_traps, setup_terminal, restore_terminal
#   _TINT_PICKER_TRAPS_INSTALLED  bool             traps set       install_signal_traps, restore_terminal
#   _TINT_PICKER_SAVED_STTY       str              original stty   install_signal_traps, setup_terminal
#   _TINT_PICKER_RENDERED_ROWS    int              rows on screen  init_picker, render_all, restore_terminal
#   _TINT_PICKER_PREVIEWED        bool             preview active  init_picker, apply_preview_color
#   _TINT_PICKER_INTERRUPTED      int (0/130/143)  signal code     install_signal_traps, traps
#   _TINT_PICKER_ORIGINAL_BG      str              starting bg     init_picker
#   _TINT_PICKER_ORIGINAL_FG      str              starting fg     init_picker
#
#   Palette arrays (0 = "unchanged" entry)
#
#   _tint_themes[i] is the source of truth — the full colon-delimited theme
#   string (#bg:#fg:#00:...:#15). The other arrays are denormalized caches
#   to avoid repeated string parsing in the render loop (runs every keystroke).
#
#   Name                      Type  Description
#   ────────────────────────  ────  ────────────────────────────────────────────
#   _tint_themes_name[i]      str   theme name (unique identifier)
#   _tint_themes_bg[i]        str   bg hex (#RRGGBB) — for render-row color gate
#   _tint_themes[i]           str   full theme value (#bg:#fg:#00:...:#15)
#   _tint_themes_fg[i]        str   fg hex (#RRGGBB) — pre-lowercased from theme
#   _tint_themes_bg_r/g/b[i]  int   bg RGB components (for ANSI 48;2;r;g;b)
#   _tint_themes_fg_r/g/b[i]  int   fg RGB components (for ANSI 38;2;r;g;b)
#
#   Session context (locals in tint_pick, visible via dynamic scoping)
#   Name                 Type  Description
#   ───────────────────  ────  ────────────────────────────────
#   _tint_saved_traps    str   caller's INT/TERM traps
#   _tint_saved_exit     str   caller's EXIT trap
#   _tint_esc_timeout    str   escape sequence timeout
#   _tint_read_timeout   str   keystroke polling timeout
#   _tint_palette_count  int   number of palette entries
#   _tint_last_idx       int   alias for _TINT_PICKER_TOTAL - 1

# --- Picker: Terminal Helpers ---

# _tint_hide_cursor - Hide the terminal cursor and set the hidden flag
#
# Sets: _TINT_PICKER_CURSOR_HIDDEN
# Flag set before write so a signal between them errs on the safe side
# (_tint_restore_terminal shows a cursor that was never hidden — harmless no-op).
_tint_hide_cursor() { _TINT_PICKER_CURSOR_HIDDEN=1; printf '\e[?25l' >/dev/tty; }

# _tint_get_terminal_height - Get the number of terminal lines
#
# Stdout: integer line count (defaults to 24)
_tint_get_terminal_height() {
    local n
    n=$(tput lines 2>/dev/null) || n="${LINES:-24}"
    case "$n" in *[!0-9]*|"") n=24 ;; esac
    printf '%s' "$n"
}

# _tint_erase_picker - Clear all picker output from the terminal
#
# Cursor is on the scroll indicator line (N rows below first palette row,
# which is 1 line below the hint line).
# Move up to the hint line and erase everything below.
# Note: if a signal fires mid-render, _TINT_PICKER_RENDERED_ROWS may not match
# the actual cursor position, causing \e[J to clear a few extra lines.
# Terminal clamps cursor-up at row 1, so this is cosmetic and transient.
_tint_erase_picker() {
    local n="${_TINT_PICKER_RENDERED_ROWS:-0}"
    if [ "$n" -gt 0 ]; then
        printf '\e[%dA' "$(( n + 1 ))" >/dev/tty
    fi
    # \e[J clears from cursor to end of screen without scrolling
    printf '\r\e[J' >/dev/tty
}

# --- Picker: Teardown ---

# _tint_restore_original_colors - Restore terminal to pre-picker colors
#
# Uses the best available strategy:
#   1. Original bg matched a known theme → apply full theme (bg + ANSI),
#      using queried fg if available (user may have set fg independently)
#   2. Original bg queried but no theme match → set bg + fg, reset ANSI
#      palette to terminal defaults (can't query individual ANSI colors)
#   3. Nothing queried → full reset (OSC 110 + 111 + 104)
#
# No-op if no preview was ever applied (_TINT_PICKER_PREVIEWED=0), because
# terminal state hasn't been modified.
#
# Reads: _TINT_PICKER_PREVIEWED, _TINT_PICKER_ORIGINAL_THEME_IDX, _TINT_PICKER_ORIGINAL_BG,
#   _TINT_PICKER_ORIGINAL_FG, _tint_themes[] (via dynamic scoping)
_tint_restore_original_colors() {
    if [ "${_TINT_PICKER_PREVIEWED:-0}" -eq 0 ]; then return; fi
    # shellcheck disable=SC3054
    if [ "${_TINT_PICKER_ORIGINAL_THEME_IDX:-0}" -gt 0 ] && [ -n "${_tint_themes[$_TINT_PICKER_ORIGINAL_THEME_IDX]+x}" ]; then
        # Original bg matched a known theme — restore bg + ANSI from theme.
        # Use queried fg if available; otherwise let the theme's fg apply.
        # shellcheck disable=SC3054
        if [ -n "${_TINT_PICKER_ORIGINAL_FG:-}" ]; then
            tint_set "${_tint_themes[$_TINT_PICKER_ORIGINAL_THEME_IDX]}" "$_TINT_PICKER_ORIGINAL_FG"
        else
            tint_set "${_tint_themes[$_TINT_PICKER_ORIGINAL_THEME_IDX]}"
        fi
    elif [ -n "${_TINT_PICKER_ORIGINAL_BG:-}" ]; then
        if [ -z "${_TINT_PICKER_ORIGINAL_FG:-}" ]; then
            # Can't restore fg (query failed) — reset to terminal default
            ( printf '\033]110\033\\' >/dev/tty ) 2>/dev/null || true
        fi
        tint_set "$_TINT_PICKER_ORIGINAL_BG" "${_TINT_PICKER_ORIGINAL_FG:-}"
        # No theme match and no way to query ANSI originals (no terminal
        # supports querying all 16 ANSI colors). Resetting to defaults is
        # the least-bad option: it restores the terminal's configured theme
        # palette rather than leaving previewed ANSI colors stuck.
        ( printf '\033]104\033\\' >/dev/tty ) 2>/dev/null || true
    else
        tint_reset
    fi
}

# _tint_restore_terminal - Unified teardown for all exit paths
#
# Idempotent: safe to call multiple times (signal handler + normal return).
# Uses resource flags to skip work that was never started or already undone.
# Delegates color restoration to _tint_restore_original_colors.
#
# Reads: _TINT_PICKER_EXIT_REASON (decides whether to restore original theme)
_tint_restore_terminal() {
    if [ "${_TINT_PICKER_CURSOR_HIDDEN:-0}" -eq 1 ]; then
        printf '\e[?25h' >/dev/tty
        _TINT_PICKER_CURSOR_HIDDEN=0
    fi
    if [ "${_TINT_PICKER_RENDERED_ROWS:-0}" -gt 0 ]; then
        _tint_erase_picker
        _TINT_PICKER_RENDERED_ROWS=0
    fi
    if [ -n "${_TINT_PICKER_SAVED_STTY:-}" ]; then
        stty "$_TINT_PICKER_SAVED_STTY" </dev/tty 2>/dev/null
    fi
    # Exit the alternate screen buffer — terminal restores the contents
    # that were on screen before the picker entered. OSC bg/fg/palette
    # state set during the session persists; only the buffer view is
    # swapped back. Order matters: do this before _tint_restore_original_colors
    # so the user's original buffer is what receives the restored colors.
    if [ "${_TINT_PICKER_ALT_SCREEN:-0}" -eq 1 ]; then
        printf '\e[?1049l' >/dev/tty
        _TINT_PICKER_ALT_SCREEN=0
    fi
    if [ "$_TINT_PICKER_EXIT_REASON" != "confirm" ]; then
        _tint_restore_original_colors
    fi
    if [ "${_TINT_PICKER_TRAPS_INSTALLED:-0}" -eq 1 ]; then
        trap - EXIT INT TERM WINCH
        eval "${_tint_saved_traps:-}"
        eval "${_tint_saved_exit:-}"
        _TINT_PICKER_TRAPS_INSTALLED=0
    fi
}

# --- Picker: Model ---

# _tint_model_move_cursor <direction> - Update cursor index with wrapping
#
# Pure model: no terminal I/O.
#
# Sets: _TINT_PICKER_IDX, _TINT_PICKER_OLD_IDX
_tint_model_move_cursor() {
    _TINT_PICKER_OLD_IDX=$_TINT_PICKER_IDX
    if [ "$1" = "up" ]; then
        _TINT_PICKER_IDX=$(( _TINT_PICKER_IDX > 0 ? _TINT_PICKER_IDX - 1 : _tint_last_idx ))
    else
        _TINT_PICKER_IDX=$(( _TINT_PICKER_IDX < _tint_last_idx ? _TINT_PICKER_IDX + 1 : 0 ))
    fi
}

# _tint_update_scroll_window - Compute the scroll window that keeps _TINT_PICKER_IDX visible
#
# Pure model: no terminal I/O.
# Edge-triggered: only shifts the window when the cursor would move off-screen.
# This minimizes full redraws (most keypresses stay within the window and use
# incremental rendering via _tint_render_changed_rows).
#
# Sets: _TINT_PICKER_WIN_START, _TINT_PICKER_WIN_END, _TINT_PICKER_SCROLLED
_tint_update_scroll_window() {
    local old_start=$_TINT_PICKER_WIN_START
    if [ "$_TINT_PICKER_VISIBLE" -ge "$_TINT_PICKER_TOTAL" ]; then
        _TINT_PICKER_WIN_START=0
        _TINT_PICKER_WIN_END=$(( _TINT_PICKER_TOTAL - 1 ))
    elif [ "${_TINT_PICKER_WIN_END:-0}" -eq 0 ] && [ "$_TINT_PICKER_RENDERED_ROWS" -eq 0 ]; then
        # Initial window: center around cursor
        local half=$(( _TINT_PICKER_VISIBLE / 2 ))
        _TINT_PICKER_WIN_START=$(( _TINT_PICKER_IDX - half ))
        if [ "$_TINT_PICKER_WIN_START" -lt 0 ]; then _TINT_PICKER_WIN_START=0; fi
        _TINT_PICKER_WIN_END=$(( _TINT_PICKER_WIN_START + _TINT_PICKER_VISIBLE - 1 ))
        if [ "$_TINT_PICKER_WIN_END" -ge "$_TINT_PICKER_TOTAL" ]; then
            _TINT_PICKER_WIN_END=$(( _TINT_PICKER_TOTAL - 1 ))
            _TINT_PICKER_WIN_START=$(( _TINT_PICKER_WIN_END - _TINT_PICKER_VISIBLE + 1 ))
        fi
    elif [ "$_TINT_PICKER_IDX" -lt "$_TINT_PICKER_WIN_START" ]; then
        _TINT_PICKER_WIN_START=$_TINT_PICKER_IDX
        _TINT_PICKER_WIN_END=$(( _TINT_PICKER_WIN_START + _TINT_PICKER_VISIBLE - 1 ))
    elif [ "$_TINT_PICKER_IDX" -gt "$_TINT_PICKER_WIN_END" ]; then
        _TINT_PICKER_WIN_END=$_TINT_PICKER_IDX
        _TINT_PICKER_WIN_START=$(( _TINT_PICKER_WIN_END - _TINT_PICKER_VISIBLE + 1 ))
    fi
    if [ "$_TINT_PICKER_WIN_START" -ne "$old_start" ]; then
        _TINT_PICKER_SCROLLED=1
    else
        _TINT_PICKER_SCROLLED=0
    fi
}

# --- Picker: View ---

# _tint_render_hint_line - Print the keyboard hint line above the picker
_tint_render_hint_line() {
    printf '\e[2m  \xe2\x86\x91/\xe2\x86\x93 Navigate   Enter: Select   Esc: Cancel\e[0m\n' >/dev/tty
}

# _tint_render_row <row_idx> <highlighted> - Append one formatted picker row to _tint_picker_buf
#
# Accessed via dynamic scoping from the caller. Each row has:
#   - A 2-char prefix: "> " (cursor), "* " (default/current), or "  "
#   - A colored background strip with index, hex value, and name
#
# Reads: _TINT_PICKER_DEFAULT, _TINT_PICKER_TOTAL, _TINT_PICKER_ORIGINAL_BG,
#   _tint_themes_name[], _tint_themes_bg[], _tint_themes_bg_r/g/b[], _tint_themes_fg_r/g/b[]
_tint_render_row() {
    local row_idx="$1" highlighted="$2"
    local name hex r g b num_width marker label row
    num_width=${#_TINT_PICKER_TOTAL}

    if [ "$row_idx" -eq 0 ]; then
        if [ -n "$_TINT_PICKER_ORIGINAL_BG" ]; then name="(unchanged)"; else name="(reset to default)"; fi
        hex="$_TINT_PICKER_ORIGINAL_BG"
    else
        # shellcheck disable=SC3054
        name="${_tint_themes_name[$row_idx]}"
        # shellcheck disable=SC3054
        hex="${_tint_themes_bg[$row_idx]}"
    fi

    # Row 0 and the matching palette entry both get * (same color).
    if [ "$highlighted" -eq 1 ]; then
        marker="> "
    elif [ "$row_idx" -eq "$_TINT_PICKER_DEFAULT" ] || { [ "$row_idx" -eq 0 ] && [ "$_TINT_PICKER_DEFAULT" -gt 0 ]; }; then
        marker="* "
    else
        marker="  "
    fi

    local padded
    # shellcheck disable=SC3045
    printf -v label '%*d.  %s' "$num_width" "$((row_idx + 1))" "$name"
    # shellcheck disable=SC3045
    printf -v padded "%-${_TINT_PICKER_ROW_WIDTH}s" "$label"

    # hex non-empty means we have color data (RGB arrays populated) —
    # render with colored background. Empty for row 0 when original bg unknown.
    if [ -n "$hex" ]; then
        # shellcheck disable=SC3054
        r="${_tint_themes_bg_r[$row_idx]}" g="${_tint_themes_bg_g[$row_idx]}" b="${_tint_themes_bg_b[$row_idx]}"
        # shellcheck disable=SC3054
        local fg_r="${_tint_themes_fg_r[$row_idx]}" fg_g="${_tint_themes_fg_g[$row_idx]}" fg_b="${_tint_themes_fg_b[$row_idx]}"
        # No SGR 2 dim: would distort each theme's actual fg preview.
        # shellcheck disable=SC3045
        printf -v row '%s\e[38;2;%d;%d;%d;48;2;%d;%d;%dm %s\e[0m' "$marker" "$fg_r" "$fg_g" "$fg_b" "$r" "$g" "$b" "$padded"
    else
        row="${marker}${padded}"
    fi
    # shellcheck disable=SC3054,SC3024,SC3003
    _tint_picker_buf+=$'\r\e[K'"${row}"$'\n'
}

# _tint_apply_preview_color - Apply the highlighted theme as a live preview
#
# Provides live preview as the user navigates the picker.
# Always previews fg alongside bg (via auto-compute) even when the original
# fg is unknown — skipping fg would leave text unreadable on light themes.
#
# Sets: _TINT_PICKER_PREVIEWED
_tint_apply_preview_color() {
    if [ "$_TINT_PICKER_IDX" -eq 0 ]; then
        _tint_restore_original_colors
        return
    else
        _TINT_PICKER_PREVIEWED=1
        # shellcheck disable=SC3054
        tint_set "${_tint_themes[$_TINT_PICKER_IDX]}"
    fi
}

# _tint_render_scroll_indicator - Append scroll indicator to _tint_picker_buf
#
# Shows how many entries are hidden above/below (e.g., "↑ 3 more · ↓ 5 more").
_tint_render_scroll_indicator() {
    # shellcheck disable=SC3024,SC3003
    _tint_picker_buf+=$'\r\e[K'
    local indicator=""
    if [ "$_TINT_PICKER_WIN_START" -gt 0 ] && [ "$_TINT_PICKER_WIN_END" -lt $(( _TINT_PICKER_TOTAL - 1 )) ]; then
        # shellcheck disable=SC3045
        printf -v indicator '\e[2m  \xe2\x86\x91 %d more \xc2\xb7 \xe2\x86\x93 %d more\e[0m' "$_TINT_PICKER_WIN_START" "$(( _TINT_PICKER_TOTAL - 1 - _TINT_PICKER_WIN_END ))"
    elif [ "$_TINT_PICKER_WIN_START" -gt 0 ]; then
        # shellcheck disable=SC3045
        printf -v indicator '\e[2m  \xe2\x86\x91 %d more\e[0m' "$_TINT_PICKER_WIN_START"
    elif [ "$_TINT_PICKER_WIN_END" -lt $(( _TINT_PICKER_TOTAL - 1 )) ]; then
        # shellcheck disable=SC3045
        printf -v indicator '\e[2m  \xe2\x86\x93 %d more\e[0m' "$(( _TINT_PICKER_TOTAL - 1 - _TINT_PICKER_WIN_END ))"
    fi
    # shellcheck disable=SC3024
    _tint_picker_buf+="$indicator"
}

# _tint_render_all - Full redraw of the picker
#
# Repaints every visible row plus the scroll indicator. Output is
# buffered into _tint_picker_buf and flushed in a single write() to avoid
# flicker and reduce PTY backpressure (especially over SSH).
#
# Callers must update model state (_tint_update_scroll_window) first.
#
# Sets: _TINT_PICKER_RENDERED_ROWS
_tint_render_all() {
    local i highlighted

    # Build entire frame into _tint_picker_buf, then write in one shot.
    local _tint_picker_buf=""

    # Move cursor up to first row position (for redraw).
    if [ "${_TINT_PICKER_RENDERED_ROWS:-0}" -gt 0 ]; then
        # shellcheck disable=SC3045
        printf -v _tint_picker_buf '\e[%dA' "$(( _TINT_PICKER_RENDERED_ROWS ))"
    fi

    # Draw each visible row (appends to _tint_picker_buf via dynamic scoping)
    local rows_printed=0
    i=$_TINT_PICKER_WIN_START
    while [ "$i" -le "$_TINT_PICKER_WIN_END" ]; do
        if [ "$i" -eq "$_TINT_PICKER_IDX" ]; then highlighted=1; else highlighted=0; fi
        _tint_render_row "$i" "$highlighted"
        rows_printed=$(( rows_printed + 1 ))
        i=$(( i + 1 ))
    done

    _tint_render_scroll_indicator
    printf '%s' "$_tint_picker_buf" >/dev/tty
    _TINT_PICKER_RENDERED_ROWS=$rows_printed
}

# _tint_render_changed_rows <old_idx> - Incremental repaint of two changed rows
#
# Only repaints the previously highlighted row (unhighlight) and the newly
# highlighted row (highlight). Used when the scroll window hasn't changed,
# reducing output from ~2KB (full frame) to ~200B (two rows). This prevents
# PTY buffer deadlocks when the master side isn't draining continuously.
#
# Reads: _TINT_PICKER_IDX, _TINT_PICKER_WIN_START, _TINT_PICKER_RENDERED_ROWS
_tint_render_changed_rows() {
    local old_idx="$1"
    # shellcheck disable=SC3024,SC3003
    local _tint_picker_buf="" _tmp=""
    local old_pos=$(( old_idx - _TINT_PICKER_WIN_START ))
    local new_pos=$(( _TINT_PICKER_IDX - _TINT_PICKER_WIN_START ))

    # Move from scroll indicator line up to old row
    # shellcheck disable=SC3045
    printf -v _tint_picker_buf '\e[%dA' "$(( _TINT_PICKER_RENDERED_ROWS - old_pos ))"

    # Render old row (unhighlighted) — appends \r\e[K...row...\n to _tint_picker_buf
    _tint_render_row "$old_idx" 0

    # Cursor is now at old_pos + 1; navigate to new_pos
    local diff=$(( new_pos - old_pos - 1 ))
    if [ "$diff" -gt 0 ]; then
        # shellcheck disable=SC3045
        printf -v _tmp '\e[%dB' "$diff"
        # shellcheck disable=SC3024
        _tint_picker_buf+="$_tmp"
    elif [ "$diff" -lt 0 ]; then
        # shellcheck disable=SC3045
        printf -v _tmp '\e[%dA' "$(( -diff ))"
        # shellcheck disable=SC3024
        _tint_picker_buf+="$_tmp"
    fi

    # Render new row (highlighted)
    _tint_render_row "$_TINT_PICKER_IDX" 1

    # Move back to scroll indicator line (cursor is at new_pos + 1)
    local down=$(( _TINT_PICKER_RENDERED_ROWS - new_pos - 1 ))
    if [ "$down" -gt 0 ]; then
        # shellcheck disable=SC3045
        printf -v _tmp '\e[%dB' "$down"
        # shellcheck disable=SC3024
        _tint_picker_buf+="$_tmp"
    fi

    printf '%s' "$_tint_picker_buf" >/dev/tty
}

# _tint_render_cursor_move - Render after a cursor move
#
# Applies preview color, then uses incremental rendering when the scroll
# window didn't change, falling back to full redraw when scrolling occurred.
#
# Reads: _TINT_PICKER_SCROLLED, _TINT_PICKER_OLD_IDX
_tint_render_cursor_move() {
    _tint_apply_preview_color
    # Render is non-fatal (signal races shouldn't abort the picker). Plain
    # `cmd || true` inside a function called under `set -e` doesn't suppress
    # errexit on bash 3.2 (macOS). Save and restore the errexit option around
    # the render calls instead — works on bash 3.2 and 4+.
    local _e=0
    case $- in *e*) _e=1 ;; esac
    set +e
    if [ "$_TINT_PICKER_SCROLLED" -eq 1 ]; then
        _tint_render_all
    else
        _tint_render_changed_rows "$_TINT_PICKER_OLD_IDX"
    fi
    [ "$_e" = "1" ] && set -e
    return 0
}

# _tint_handle_resize - Recalculate layout and redraw after terminal resize
#
# Called from the picker loop when SIGWINCH sets _TINT_PICKER_RESIZED.
# Erases the current picker, recalculates the visible window size,
# reprints the hint line, and does a full redraw.
#
# Sets: _TINT_PICKER_VISIBLE, _TINT_PICKER_RESIZED
_tint_handle_resize() {
    _TINT_PICKER_RESIZED=0

    _tint_erase_picker

    # Recalculate visible rows from new terminal height
    local term_lines
    term_lines=$(_tint_get_terminal_height)
    _TINT_PICKER_VISIBLE=$(( term_lines - 2 ))
    if [ "$_TINT_PICKER_VISIBLE" -gt "$_TINT_PICKER_TOTAL" ]; then _TINT_PICKER_VISIBLE=$_TINT_PICKER_TOTAL; fi
    if [ "$_TINT_PICKER_VISIBLE" -lt 1 ]; then _TINT_PICKER_VISIBLE=1; fi

    # Reset scroll window state to trigger re-centering around current cursor
    _TINT_PICKER_WIN_END=0
    _TINT_PICKER_RENDERED_ROWS=0

    # Reprint hint line and full frame
    _tint_render_hint_line
    _tint_update_scroll_window
    _tint_render_all
}

# --- Picker: Input ---

# _tint_read_key - Read one logical keypress
#
# Reads raw bytes from /dev/tty and normalizes escape sequences into
# logical key names. Uses _tint_esc_timeout (set in _tint_setup_terminal)
# to distinguish bare Escape from arrow key sequences.
#
# Sets: _TINT_PICKER_KEY - normalized key name:
#   "up" | "down"     Arrow/vim keys
#   "confirm"         Enter key
#   "cancel"          Bare Esc (no following sequence)
#   "q"               Q key
#   ""                Timeout (no key pressed)
# Returns: 0 on success or timeout, 1 on EOF/error
_tint_read_key() {
    _TINT_PICKER_KEY=""
    local key key2 key3
    if ! IFS= read -rn1 -t "$_tint_read_timeout" key </dev/tty; then
        # Timeout with no data — loop back to check signals.
        # If a byte arrived at the timeout boundary, key is non-empty;
        # fall through to process it normally rather than aborting.
        if [ -z "${key:-}" ]; then return 0; fi
    fi
    case "$key" in
        "$_TINT_ESC")
            # CSI: ESC [ A/B/C/D (most terminals)
            # SS3: ESC O A/B/C/D (some terminals, notably older xterm modes)
            if IFS= read -rn1 -t "$_tint_esc_timeout" key2 </dev/tty 2>/dev/null; then
                case "$key2" in
                    "["|"O")
                        IFS= read -rn1 -t "$_tint_esc_timeout" key3 </dev/tty 2>/dev/null || return 0
                        case "$key3" in
                            A|D) _TINT_PICKER_KEY=up ;;   # Up/Left → up
                            B|C) _TINT_PICKER_KEY=down ;;  # Down/Right → down
                        esac
                        ;;
                esac
            else
                _TINT_PICKER_KEY=cancel
            fi
            ;;
        h|k) _TINT_PICKER_KEY=up ;;
        l|j) _TINT_PICKER_KEY=down ;;
        q)   _TINT_PICKER_KEY=q ;;
        "")  _TINT_PICKER_KEY=confirm ;;
    esac
}

# --- Picker: Session ---

# _tint_accept_selection - Confirm selection: teardown, apply theme, print result
#
# Model: sets _TINT_PICKER_EXIT_REASON=confirm so _tint_restore_terminal skips
# background restore. View: tears down terminal, applies selected theme,
# and prints theme name to stdout.
#
# Stdout: theme name (empty if unchanged/reset)
_tint_accept_selection() {
    # Model: mark as confirmed
    _TINT_PICKER_EXIT_REASON=confirm
    # View: teardown and apply final theme
    _tint_restore_terminal
    if [ "$_TINT_PICKER_IDX" -eq 0 ]; then
        _tint_restore_original_colors
    else
        # shellcheck disable=SC3054
        tint_set "${_tint_themes[$_TINT_PICKER_IDX]}"
        # shellcheck disable=SC3054
        printf '%s' "${_tint_themes_name[$_TINT_PICKER_IDX]}"
    fi
}


# _tint_load_palette_arrays - Parse palette into parallel arrays with pre-computed RGB/fg
#
# Single read pass over $TINT_PALETTE.
#
# Sets: _tint_palette_count, _TINT_PICKER_TOTAL, _tint_last_idx (via dynamic scoping),
#   _tint_themes_name[], _tint_themes_bg[], _tint_themes[], _tint_themes_fg[],
#   _tint_themes_bg_r/g/b[], _tint_themes_fg_r/g/b[]
_tint_load_palette_arrays() {
    local line name theme bg
    i=0
    while IFS= read -r line; do
        [ -z "$line" ] && continue
        name="${line%%:*}"
        theme="${line#*:}"
        bg="${theme%%:*}"
        # _tint_load_palette validates format, but guard here too for direct callers.
        # Both bg and fg must be valid before we increment i, otherwise partial
        # entries pollute the arrays (bg stored but fg missing).
        case "$bg" in '#'[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F]) ;; *) continue ;; esac
        # shellcheck disable=SC3057
        local _fg_raw="${theme#*:}"
        _fg_raw="${_fg_raw%%:*}"
        case "$_fg_raw" in '#'[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F]) ;; *) continue ;; esac
        i=$((i + 1))
        # shellcheck disable=SC3054
        _tint_themes_name[i]="$name"
        # shellcheck disable=SC3054
        _tint_themes[i]="$theme"
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_bg_r[i]=$((16#${bg:1:2}))
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_bg_g[i]=$((16#${bg:3:2}))
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_bg_b[i]=$((16#${bg:5:2}))
        # printf -v: bash builtin (no fork). %02x always produces lowercase.
        # Bash 3.2 (macOS) rejects array-element targets for printf -v, so
        # write to a scalar then assign — works on bash 3.2+.
        local _bg_hex
        # shellcheck disable=SC3045,SC3054
        printf -v _bg_hex '#%02x%02x%02x' "${_tint_themes_bg_r[$i]}" "${_tint_themes_bg_g[$i]}" "${_tint_themes_bg_b[$i]}"
        # shellcheck disable=SC3054
        _tint_themes_bg[i]="$_bg_hex"
        # Lowercase fg hex (no fork). _fg_raw already validated above.
        # printf %02x produces lowercase hex, matching the bg path above.
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_fg_r[i]=$((16#${_fg_raw:1:2}))
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_fg_g[i]=$((16#${_fg_raw:3:2}))
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_fg_b[i]=$((16#${_fg_raw:5:2}))
        local _fg_hex
        # shellcheck disable=SC3045,SC3054
        printf -v _fg_hex '#%02x%02x%02x' "${_tint_themes_fg_r[$i]}" "${_tint_themes_fg_g[$i]}" "${_tint_themes_fg_b[$i]}"
        # shellcheck disable=SC3054
        _tint_themes_fg[i]="$_fg_hex"
    done <<EOF
$TINT_PALETTE
EOF
    _tint_palette_count=$i
    _TINT_PICKER_TOTAL=$(( _tint_palette_count + 1 ))
    _tint_last_idx=$(( _TINT_PICKER_TOTAL - 1 ))
}

# _tint_report_osc11_error - Print diagnostic when OSC 11 detection fails
#
# Includes environment-specific hints for tmux and SSH.
_tint_report_osc11_error() {
    cat >&2 <<'ERRMSG'
Error: terminal does not support OSC 11 (background color escape sequences).

tint uses OSC 11 to get and set the terminal background color.
Your terminal did not respond to the background color request,
which means tint cannot preview or apply colors.
ERRMSG
    if [ -n "${TMUX:-}" ]; then
        echo "  Hint: try running: tmux set -g allow-passthrough on" >&2
    elif [ -n "${SSH_TTY:-}${SSH_CONNECTION:-}" ]; then
        echo "  Hint: try reconnecting with: ssh -t" >&2
    fi
    printf '%s\n' "  Try: printf '\033]11;?\033\\\\'" >&2
    printf '  A supported terminal will echo back the current background color.\n' >&2
}

# _tint_compute_unchanged_entry - Pre-compute RGB for the original background and foreground
#
# Sets: _tint_themes_bg_r[0], _tint_themes_bg_g[0], _tint_themes_bg_b[0],
#        _tint_themes_fg_r[0], _tint_themes_fg_g[0], _tint_themes_fg_b[0]
_tint_compute_unchanged_entry() {
    if [ -n "$_TINT_PICKER_ORIGINAL_BG" ]; then
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_bg_r[0]=$((16#${_TINT_PICKER_ORIGINAL_BG:1:2}))
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_bg_g[0]=$((16#${_TINT_PICKER_ORIGINAL_BG:3:2}))
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_bg_b[0]=$((16#${_TINT_PICKER_ORIGINAL_BG:5:2}))
    fi
    if [ -n "$_TINT_PICKER_ORIGINAL_FG" ]; then
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_fg_r[0]=$((16#${_TINT_PICKER_ORIGINAL_FG:1:2}))
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_fg_g[0]=$((16#${_TINT_PICKER_ORIGINAL_FG:3:2}))
        # shellcheck disable=SC3054,SC3057,SC3052
        _tint_themes_fg_b[0]=$((16#${_TINT_PICKER_ORIGINAL_FG:5:2}))
    else
        # No fg queried — use luma-based black or white
        # shellcheck disable=SC3054
        if [ $(( (_tint_themes_bg_r[0] * 299 + _tint_themes_bg_g[0] * 587 + _tint_themes_bg_b[0] * 114) / 1000 )) -gt 128 ]; then
            _tint_themes_fg_r[0]=0; _tint_themes_fg_g[0]=0; _tint_themes_fg_b[0]=0
        else
            _tint_themes_fg_r[0]=255; _tint_themes_fg_g[0]=255; _tint_themes_fg_b[0]=255
        fi
    fi
}

# _tint_find_default_index <current> - Match current value to a palette index
#
# Accepts a theme name, #RRGGBB hex, or full theme string (#bg:#fg:#00:...).
# Names match _tint_themes_name[]; hex/full strings match _tint_themes_bg[],
# with fg as a tiebreaker when a full theme string is provided.
#
# Sets: _TINT_PICKER_IDX, _TINT_PICKER_DEFAULT (if a match is found)
# Reads: _tint_palette_count, _tint_themes_name[], _tint_themes_bg[] (via dynamic scoping)
_tint_find_default_index() {
    local current="$1"
    [ -z "$current" ] && return 0
    local i=1
    # Try name match first (the common case for theme-based workflows)
    while [ "$i" -le "$_tint_palette_count" ]; do
        # shellcheck disable=SC3054
        if [ "${_tint_themes_name[$i]}" = "$current" ]; then
            _TINT_PICKER_IDX=$i
            _TINT_PICKER_DEFAULT=$_TINT_PICKER_IDX
            return 0
        fi
        i=$((i + 1))
    done
    # Fall back to hex match (for bare #RRGGBB input or full theme strings).
    # Theme disambiguation for restore is handled separately in _tint_init_picker
    # using bg+fg matching against the terminal's queried colors.
    local current_hex current_fg="" resolve_input="$current"
    # Full theme strings (#bg:#fg:#00:...) aren't valid tint_resolve input.
    # Extract bg for resolving, and fg for disambiguation when themes share a bg.
    case "$resolve_input" in
        *:*)
            current_fg="${resolve_input#*:}"
            current_fg=$(printf '%s' "${current_fg%%:*}" | tr '[:upper:]' '[:lower:]')
            resolve_input="${resolve_input%%:*}"
            ;;
    esac
    current_hex=$(tint_resolve "$resolve_input" 2>/dev/null) || return 0
    # tint_resolve returns full theme string for names; extract bg hex
    current_hex=$(printf '%s' "${current_hex%%:*}" | tr '[:upper:]' '[:lower:]')
    [ -z "$current_hex" ] && return 0
    # When fg is available (full theme string input), prefer bg+fg match.
    # Falls back to first bg-only match if fg doesn't narrow to one.
    local _first_bg_match=0
    i=1
    while [ "$i" -le "$_tint_palette_count" ]; do
        # shellcheck disable=SC3054
        if [ "${_tint_themes_bg[$i]}" = "$current_hex" ]; then
            if [ -n "$current_fg" ]; then
                # shellcheck disable=SC3054
                if [ "${_tint_themes_fg[$i]}" = "$current_fg" ]; then
                    _TINT_PICKER_IDX=$i
                    _TINT_PICKER_DEFAULT=$_TINT_PICKER_IDX
                    return 0
                fi
                if [ "$_first_bg_match" -eq 0 ]; then _first_bg_match=$i; fi
            else
                _TINT_PICKER_IDX=$i
                _TINT_PICKER_DEFAULT=$_TINT_PICKER_IDX
                return 0
            fi
        fi
        i=$((i + 1))
    done
    # No bg+fg match found — fall back to first bg-only match
    if [ "$_first_bg_match" -gt 0 ]; then
        _TINT_PICKER_IDX=$_first_bg_match
        _TINT_PICKER_DEFAULT=$_TINT_PICKER_IDX
    fi
}

# _tint_install_signal_traps - Save caller traps and install picker signal handlers
#
# EXIT is saved separately — in command substitution (hex=$(tint_pick)),
# restoring EXIT would fire the caller's trap prematurely.
# Uses BASH_SUBSHELL (Bash 3.0+) instead of BASHPID (Bash 4.0+)
# for macOS Bash 3.2 compatibility.
#
# Sets: _tint_saved_traps, _tint_saved_exit, _TINT_PICKER_INTERRUPTED,
#   _TINT_PICKER_RESIZED, _TINT_PICKER_CURSOR_HIDDEN, _TINT_PICKER_EXIT_REASON,
#   _TINT_PICKER_KEY, _TINT_PICKER_SAVED_STTY, _TINT_PICKER_TRAPS_INSTALLED
_tint_install_signal_traps() {
    _tint_saved_traps=$(trap -p INT TERM WINCH 2>/dev/null || true)
    # shellcheck disable=SC3028
    if [ "${BASH_SUBSHELL:-0}" -eq 0 ]; then
        _tint_saved_exit=$(trap -p EXIT 2>/dev/null || true)
    else
        _tint_saved_exit=""
    fi

    # Flag-based signal handling avoids killing the parent shell when
    # sourced as a library. The read loop checks _TINT_PICKER_INTERRUPTED.
    _TINT_PICKER_INTERRUPTED=0
    _TINT_PICKER_RESIZED=0
    _TINT_PICKER_CURSOR_HIDDEN=0
    _TINT_PICKER_ALT_SCREEN=0
    _TINT_PICKER_EXIT_REASON=""
    _TINT_PICKER_KEY=""
    # Clear stale stty snapshot so a signal between trap install and the
    # new stty -g can't restore wrong state.
    _TINT_PICKER_SAVED_STTY=""
    # Install traps before stty -echo so a signal in the gap can't leave
    # the terminal with echo disabled. Every interrupt path runs the
    # same teardown prefix (mark interrupt + restore terminal); INT/TERM
    # additionally record the signal-derived exit code (130 = 128+SIGINT,
    # 143 = 128+SIGTERM). Factored into one local so the shared prefix
    # has a single source of truth.
    local on_interrupt='_TINT_PICKER_EXIT_REASON=interrupt; _tint_restore_terminal'
    # The double-quoted form expands $on_interrupt now (at trap install)
    # rather than when the signal fires — exactly what we want, since it
    # bakes the shared prefix into each trap body as a literal string.
    # shellcheck disable=SC2064
    trap "$on_interrupt" EXIT
    # shellcheck disable=SC2064
    trap "$on_interrupt; _TINT_PICKER_INTERRUPTED=130" INT
    # shellcheck disable=SC2064
    trap "$on_interrupt; _TINT_PICKER_INTERRUPTED=143" TERM
    trap '_TINT_PICKER_RESIZED=1' WINCH
    _TINT_PICKER_TRAPS_INSTALLED=1
}

# _tint_setup_terminal - Configure terminal for picker: stty, cursor, timeouts
#
# Sets: _TINT_PICKER_SAVED_STTY, _tint_esc_timeout, _tint_read_timeout
# Returns: non-zero if interrupted during setup
_tint_setup_terminal() {
    if [ "$_TINT_PICKER_INTERRUPTED" -ne 0 ]; then _tint_restore_terminal; return "$_TINT_PICKER_INTERRUPTED"; fi
    # Enter the alternate screen buffer. Treats the picker as a modal app:
    # the prior screen contents are saved by the terminal and restored on
    # exit (via \e[?1049l in _tint_restore_terminal). The picker can use
    # the full terminal height regardless of where the user invoked it
    # from, and quitting leaves no trace in the user's scrollback.
    #
    # Set the flag *before* writing the escape: if a signal fires between
    # the assignment and the printf, teardown will emit \e[?1049l on a
    # buffer that never entered alt-screen — but \e[?1049l is a no-op when
    # not in alt-screen, so the conservative pattern is harmless. The
    # opposite order would lose the exit on interrupt, leaving the user
    # stuck in the alt-screen buffer. Matches _tint_hide_cursor's pattern.
    if [ "${_TINT_PICKER_ALT_SCREEN:-0}" -eq 0 ]; then
        _TINT_PICKER_ALT_SCREEN=1
        printf '\e[?1049h' >/dev/tty
    fi
    # Non-canonical mode: -echo suppresses keystroke echo, -icanon disables
    # line buffering. Without -icanon, bash's read -n1 toggles canonical mode
    # per call, creating a window for escape sequence byte delays.
    _TINT_PICKER_SAVED_STTY=$(stty -g </dev/tty 2>/dev/null)
    stty -echo -icanon </dev/tty 2>/dev/null
    _tint_hide_cursor

    # Timing constants for _tint_read_key:
    #
    #   _tint_esc_timeout  — distinguishes bare Escape (cancel) from the start
    #     of an arrow key sequence (ESC + "[" + letter). With -icanon set above,
    #     bytes arrive without line-buffering delays, so 10ms suffices. On very
    #     slow links where arrow keys don't register, vim keys (h/j/k/l) bypass
    #     this timeout entirely since they're single bytes.
    #
    #   _tint_read_timeout — main loop polling interval. Short enough to feel
    #     responsive, long enough that the signal-check loop doesn't busy-wait.
    #
    # Bash 4+ supports fractional timeouts; Bash 3.x needs integer (1s min).
    _tint_esc_timeout=0.01
    # shellcheck disable=SC3028
    _tint_read_timeout=0.5
    # shellcheck disable=SC3028
    if [ "${BASH_VERSINFO[0]:-3}" -lt 4 ]; then
        _tint_esc_timeout=1
        _tint_read_timeout=1
    fi
    if [ "$_TINT_PICKER_INTERRUPTED" -ne 0 ]; then _tint_restore_terminal; return "$_TINT_PICKER_INTERRUPTED"; fi
    _tint_render_hint_line
    # Model: compute scroll window for initial cursor position
    _tint_update_scroll_window
    # View: apply preview color and render initial frame
    _tint_apply_preview_color
    _tint_render_all
}

# _tint_init_picker [<current>] - Set up picker session state
#
# Loads palette, queries terminal, installs traps, renders initial frame.
#
# Sets (via dynamic scoping from tint_pick):
#   _tint_themes_name[], _tint_themes_bg[], _tint_themes_fg[],
#   _tint_themes_bg_r/g/b[], _tint_themes_fg_r/g/b[],
#   _tint_saved_traps, _tint_saved_exit, _tint_esc_timeout, _tint_read_timeout,
#   _tint_palette_count, _tint_last_idx
# Returns: non-zero on failure (no bash, no tty, no OSC 11 support)
_tint_init_picker() {
    _TINT_PICKER_IDX=0
    _TINT_PICKER_DEFAULT=0

    _tint_load_palette_arrays

    # Calculate visible window size based on terminal height
    local term_lines
    term_lines=$(_tint_get_terminal_height)
    _TINT_PICKER_VISIBLE=$(( term_lines - 2 ))  # reserve hint + scroll indicator
    if [ "$_TINT_PICKER_VISIBLE" -gt "$_TINT_PICKER_TOTAL" ]; then _TINT_PICKER_VISIBLE=$_TINT_PICKER_TOTAL; fi
    if [ "$_TINT_PICKER_VISIBLE" -lt 1 ]; then _TINT_PICKER_VISIBLE=1; fi
    _TINT_PICKER_RENDERED_ROWS=0
    _TINT_PICKER_WIN_START=0
    _TINT_PICKER_WIN_END=0
    _TINT_PICKER_OLD_IDX=0
    _TINT_PICKER_SCROLLED=0

    if ! _TINT_PICKER_ORIGINAL_BG=$(_tint_query_terminal_bg); then
        _tint_report_osc11_error
        return 1
    fi
    _TINT_PICKER_ORIGINAL_FG=$(_tint_query_terminal_fg) || _TINT_PICKER_ORIGINAL_FG=""
    _TINT_PICKER_PREVIEWED=0

    _tint_compute_unchanged_entry
    # _TINT_PICKER_DEFAULT controls the star marker. _TINT_PICKER_IDX (initial
    # cursor) follows it ONLY when the caller's <current> arg matches; the
    # auto-detect fallback below sets the star but leaves the cursor at 0.
    _tint_find_default_index "${1:-}"
    # _TINT_PICKER_ORIGINAL_THEME_IDX: theme matching the terminal's current colors.
    # Auto-detected from actual terminal state, independent of the caller's hint.
    # Strategy: collect all themes whose bg matches, then narrow by fg when
    # available. If still ambiguous (0 or 2+ candidates), fall back to 0 so the
    # restore path uses direct bg/fg restore instead of a potentially wrong theme.
    # Known limitation: bg+fg match is a heuristic — a user could share bg+fg
    # with a theme but have different ANSI colors. However, matching is still
    # the best option: the alternative (ANSI reset to terminal defaults) is
    # worse for the overwhelmingly common case where bg+fg match implies the
    # theme. Individual ANSI colors can't be queried portably (no OSC 4 query).
    _TINT_PICKER_ORIGINAL_THEME_IDX=0
    if [ -n "$_TINT_PICKER_ORIGINAL_BG" ]; then
        local _candidates="" _candidate_count=0
        local _i=1
        while [ "$_i" -le "$_tint_last_idx" ]; do
            # shellcheck disable=SC3054
            if [ "${_tint_themes_bg[$_i]}" = "$_TINT_PICKER_ORIGINAL_BG" ]; then
                _candidates="${_candidates:+$_candidates }$_i"
                _candidate_count=$((_candidate_count + 1))
            fi
            _i=$((_i + 1))
        done
        if [ "$_candidate_count" -gt 0 ] && [ -n "$_TINT_PICKER_ORIGINAL_FG" ]; then
            # fg available — require both bg AND fg to match, so we don't
            # restore the wrong ANSI palette for a user whose bg happens to
            # coincide with a theme but whose fg/ANSI colors differ.
            local _fg_candidates="" _fg_count=0
            for _i in $_candidates; do
                # shellcheck disable=SC3054
                if [ "${_tint_themes_fg[$_i]}" = "$_TINT_PICKER_ORIGINAL_FG" ]; then
                    _fg_candidates="${_fg_candidates:+$_fg_candidates }$_i"
                    _fg_count=$((_fg_count + 1))
                fi
            done
            if [ "$_fg_count" -eq 1 ]; then
                _TINT_PICKER_ORIGINAL_THEME_IDX=$_fg_candidates
            fi
        elif [ "$_candidate_count" -eq 1 ]; then
            # No fg available — trust the sole bg match
            _TINT_PICKER_ORIGINAL_THEME_IDX=$_candidates
        fi
    fi
    # If no explicit current matched, use auto-detect for the star marker too
    if [ "$_TINT_PICKER_DEFAULT" -eq 0 ] && [ "$_TINT_PICKER_ORIGINAL_THEME_IDX" -gt 0 ]; then
        _TINT_PICKER_DEFAULT=$_TINT_PICKER_ORIGINAL_THEME_IDX
    fi
    _tint_install_signal_traps
    _tint_setup_terminal
}

# _tint_run_picker_loop - Input loop for the interactive picker
#
# Reads keystrokes via _tint_read_key and dispatches to action functions.
#
# Stdout: theme name (on confirm only, empty if unchanged)
# Returns: 0 if theme selected, 1 if cancelled or error
_tint_run_picker_loop() {
    while true; do
        if [ "$_TINT_PICKER_INTERRUPTED" -ne 0 ]; then _tint_restore_terminal; return "$_TINT_PICKER_INTERRUPTED"; fi
        if [ "$_TINT_PICKER_RESIZED" -eq 1 ]; then _tint_handle_resize; fi
        # Timeout ensures signal flag (_TINT_PICKER_INTERRUPTED) gets checked even
        # when bash restarts read after a caught signal (SA_RESTART behavior).
        _tint_read_key || { _TINT_PICKER_EXIT_REASON=cancel; _tint_restore_terminal; return 1; }
        if [ "$_TINT_PICKER_INTERRUPTED" -ne 0 ]; then _tint_restore_terminal; return "$_TINT_PICKER_INTERRUPTED"; fi
        if [ "$_TINT_PICKER_RESIZED" -eq 1 ]; then _tint_handle_resize; fi
        case "$_TINT_PICKER_KEY" in
            up|down)
                # Model
                _tint_model_move_cursor "$_TINT_PICKER_KEY"
                _tint_update_scroll_window
                # View
                _tint_render_cursor_move
                ;;
            q|cancel) _TINT_PICKER_EXIT_REASON=cancel; _tint_restore_terminal; return 1 ;;
            confirm)  _tint_accept_selection; return 0 ;;
        esac
    done
}

# tint_pick [<current>] - Interactive theme picker with live preview
#
# Stdout: theme name (on confirm only, empty if unchanged)
# Returns: 0 if theme selected, 1 if cancelled or error
tint_pick() {
    # Bash required for read -n/-t used in interactive picker.
    # Test actual bash array syntax in a subshell — simple presence checks
    # like ${BASH_VERSINFO:-} can be fooled by env var spoofing (e.g.,
    # BASH_VERSINFO=5 in dash). Only real bash can parse array subscripts.
    # The subshell catches the fatal "Bad substitution" without killing us.
    # shellcheck disable=SC3028,SC3054
    if ! (eval '[ "${BASH_VERSINFO[0]+_}" = _ ]') 2>/dev/null; then
        printf 'tint_pick: requires bash\n' >&2
        return 1
    fi
    # TTY required for interactive display. CLI entry (_tint_main) checks this
    # before calling tint_pick, but library callers may invoke it directly in
    # headless contexts (e.g., scripts, CI). Guard here to fail early with a
    # clear message rather than dying on the first >/dev/tty write.
    if ! (: >/dev/tty) 2>/dev/null; then
        printf 'tint_pick: requires a terminal (no TTY detected)\n' >&2
        return 1
    fi

    # Session-scoped locals. Visible to _tint_init_picker, _tint_run_picker_loop,
    # _tint_restore_terminal, and render functions via bash dynamic scoping.
    local i _tint_palette_count _tint_last_idx
    # shellcheck disable=SC3054
    local -a _tint_themes_name _tint_themes_bg _tint_themes _tint_themes_fg \
             _tint_themes_bg_r _tint_themes_bg_g _tint_themes_bg_b \
             _tint_themes_fg_r _tint_themes_fg_g _tint_themes_fg_b
    local _tint_saved_traps _tint_saved_exit
    local _tint_esc_timeout _tint_read_timeout

    _tint_init_picker "${1:-}" || return $?
    _tint_run_picker_loop
}

# =============================================================================
# Shell Completions
# =============================================================================
#
# Generated scripts hardcode "tint" as the command name (standard convention
# shared by direnv, zoxide, starship; matches the hook functions above).
# Users who rename the binary via symlink should search-and-replace "tint"
# with the new name in the generated output.
#
# All runtime lookups use `command tint` to bypass aliases/functions.

# _tint_completions_bash - Output bash tab completion code
#
# Outputs a completion function for bash's `complete` builtin.
# Designed for: eval "$(tint completions bash)"
_tint_completions_bash() {
    cat <<'BASH_COMP'
_tint_completions() {
    # COMP_WORDS and COMP_CWORD are always set by bash's completion system;
    # defensive defaults (${..-}) for set -u resilience at no cost.
    local cur opts
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]-}"

    # Second argument: shell name for completions/hook
    if (( COMP_CWORD == 2 )); then
        case "${COMP_WORDS[1]-}" in
            completions)
                COMPREPLY=( $(compgen -W "bash zsh fish" -- "$cur") ) ;;
            hook)
                COMPREPLY=( $(compgen -W "bash zsh" -- "$cur") ) ;;
        esac
        return
    fi

    # No completions beyond second argument
    if (( COMP_CWORD > 2 )); then
        return
    fi

    # First argument: flags, subcommands, or theme names
    opts="-h --help -l --list -v --version"
    if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
    else
        local names
        names=$(command tint --list 2>/dev/null)
        COMPREPLY=( $(compgen -W "$names completions hook random reset" -- "$cur") )
    fi
}
complete -F _tint_completions tint
BASH_COMP
}

# _tint_completions_zsh - Output zsh tab completion code
#
# Outputs a compdef function for zsh's completion system.
# Designed for: eval "$(tint completions zsh)"
_tint_completions_zsh() {
    cat <<'ZSH_COMP'

_tint() {
    local -a subcommands flags themes

    if (( CURRENT == 2 )); then
        subcommands=(
            'random:Pick a random theme'
            'reset:Reset to terminal default'
            'completions:Output shell completions'
            'hook:Output shell integration code'
        )
        themes=( ${(f)"$(command tint --list 2>/dev/null)"} )

        # Flags only when user types -; otherwise subcommands + themes
        if [[ "${words[CURRENT]}" == -* ]]; then
            flags=(
                {-h,--help}':Show help'
                {-l,--list}':List available themes'
                {-v,--version}':Show version'
            )
            _describe -t flags 'flag' flags
        else
            zstyle ':completion:*:*:tint:*' group-name ''
            _describe -t subcommands 'subcommand' subcommands
            _describe -t themes 'theme' themes
        fi
    elif (( CURRENT == 3 )); then
        case "${words[2]}" in
            completions)
                _values 'shell' bash zsh fish ;;
            hook)
                _values 'shell' bash zsh ;;
        esac
    fi
}

# compdef requires compinit; guard so eval before compinit doesn't error.
# Place eval after compinit in .zshrc for completions to register.
if (( $+functions[compdef] )); then
    compdef _tint tint
fi
ZSH_COMP
}

# _tint_completions_fish - Output fish tab completion code
#
# Outputs complete commands for fish's completion system.
# Designed for: tint completions fish > ~/.config/fish/completions/tint.fish
_tint_completions_fish() {
    cat <<'FISH_COMP'
# Fish completions for tint
complete -c tint -x

# True when completing the first argument (no positional arg entered yet)
function __tint_needs_command
    set -l cmd (commandline -opc)
    test (count $cmd) -eq 1
end

# Options (first argument only)
complete -c tint -n __tint_needs_command -s h -l help -d 'Show help'
complete -c tint -n __tint_needs_command -s l -l list -d 'List available themes'
complete -c tint -n __tint_needs_command -s v -l version -d 'Show version'

# Subcommands (first argument only)
complete -c tint -n __tint_needs_command -a 'completions' -d 'Output shell completions'
complete -c tint -n __tint_needs_command -a 'hook' -d 'Output shell integration code'
complete -c tint -n __tint_needs_command -a 'random' -d 'Pick a random theme'
complete -c tint -n __tint_needs_command -a 'reset' -d 'Reset to terminal default'

# Subcommand arguments (second argument only)
complete -c tint -n 'test (count (commandline -opc)) -eq 2; and __fish_seen_subcommand_from completions' -xa 'bash zsh fish'
complete -c tint -n 'test (count (commandline -opc)) -eq 2; and __fish_seen_subcommand_from hook' -xa 'bash zsh'

# Theme names (first argument only)
complete -c tint -n __tint_needs_command -a "(command tint --list 2>/dev/null)" -d 'Theme name'
FISH_COMP
}

