#     -o ~/.local/bin/tint && chmod +x ~/.local/bin/tint
#
# Usage:
#   tint                      Interactive picker with live preview
#   tint <name|hex>           Set directly (e.g., "dracula", "#002b36")
#   tint random               Pick a random theme
#   tint reset                Reset to terminal default
#   tint completions <shell>  Output shell completions (bash/zsh/fish)
#   tint hook <shell>         Output shell integration code
#   tint -h, --help           Show help
#   tint -l, --list           List available themes
#   tint -v, --version        Show version
#
# Library usage:
#   . /path/to/tint               # `source` also works in bash/zsh
#   tint_supports_color       # Check if terminal supports OSC color sequences
#   tint_lookup "dracula"     # Palette name → theme string
#   tint_resolve "dracula"    # Name → theme string, hex → expanded #rrggbb
#   tint_set "$theme_string"  # Set theme (bg + fg + 16 ANSI colors)
#   tint_reset                # Reset to terminal default
#   tint_list                 # Print all theme names
#   tint_pick "$current"      # Interactive picker → theme name
#   tint_reload_palette       # Rebuild TINT_PALETTE after changing
#                             #   TINT_PALETTE_DIR / XDG_CONFIG_HOME / HOME
#
# Configuration:
#   TINT_PALETTE_DIR      Drop-in theme dir; files appended to built-ins.
#                         Default: $XDG_CONFIG_HOME/tint/themes
#
#   Theme format: name:#bg:#fg:#00:#01:#02:#03:#04:#05:#06:#07:#08:#09:#10:#11:#12:#13:#14:#15
#   (name + bg + fg + 16 ANSI colors, all #RRGGBB hex)
#
# =============================================================================

