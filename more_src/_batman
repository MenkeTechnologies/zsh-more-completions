#compdef batman
# Documentation: https://github.com/eth-p/bat-extras/blob/master/doc/batman.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# batman (bat-extras): bat-powered man pager

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--export-env[export environment variables for shell integration]' \
  '*:man page:_man' && ret=0

return ret
