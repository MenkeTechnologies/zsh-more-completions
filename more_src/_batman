#compdef batman

# Zsh completion for batman (bat-extras - bat-powered man pages)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--paging=[paging mode]:mode:(auto always never)' \
  '--color=[colorize output]:when:(auto always never)' \
  '--theme=[bat theme]:theme' \
  '--style=[output style]:style' \
  '*:man page:_man' && ret=0

return ret
