#compdef starparser
# Documentation: https://github.com/sami-chaaban/starparser
# Manipulate and mine RELION .star files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input star file]:file:_files' \
  '--f=[second input star file]:file:_files' \
  '--o=[output filename]:file:_files' \
  '--t=[output file type]:type:' \
  '--c=[column specification]:column:' \
  '--q=[query terms]:query:' \
  '--e[exact match]' \
  '--opticsless[treat as RELION 3.0 file]' \
  '--extract[extract matching particles]' \
  '--limit=[limit by column condition]:cond:' \
  '--count[count particles]' \
  '--count_mics[count micrographs]' \
  '--list_column=[list column values]:column:' \
  '--find_shared=[find shared between files]:column:' \
  '--match_mics[match micrographs]' \
  '--extract_optics[extract optics]' \
  '--extract_min=[extract min]:val:' \
  '--extract_if_nearby[extract if nearby]' \
  '--extract_clusters=[extract clusters]:val:' \
  '--extract_indices=[extract by indices]:file:_files' \
  '--extract_random=[extract random subset]:n:' \
  '--remove_poses[remove pose columns]' \
  '--split=[split into N files]:n:' \
  '--split_classes[split by class]' \
  '--split_optics[split by optics]' \
  '--sort_by=[sort by column]:column:' \
  '--operate=[operate on column]:expr:' \
  '--operate_columns=[operate on columns]:expr:' \
  '--remove_column=[remove column]:column:' \
  '--remove_particles[remove matching particles]' \
  '--remove_duplicates=[remove duplicates]:column:' \
  '--remove_mics_list=[remove micrographs in list]:file:_files' \
  '--keep_mics_list=[keep micrographs in list]:file:_files' \
  '--insert_column=[insert column]:column:' \
  '--replace_column=[replace column]:column:' \
  '--copy_column=[copy column]:spec:' \
  '--reset_column=[reset column value]:spec:' \
  '--swap_columns=[swap columns]:spec:' \
  '--insert_optics_column=[insert optics column]:column:' \
  '--fetch_from_nearby[fetch from nearby]' \
  '--import_mic_values=[import micrograph values]:file:_files' \
  '--import_particle_values=[import particle values]:file:_files' \
  '--regroup=[regroup particles]:n:' \
  '--swap_optics[swap optics]' \
  '--new_optics=[create new optics group]:name:' \
  '--expand_optics[expand optics]' \
  '--relegate[remove optics table]' \
  '--histogram=[plot histogram of column]:column:' \
  '--plot_orientations[plot orientation distribution]' \
  '--plot_class_iterations=[plot class iterations]:val:' \
  '--plot_class_proportions[plot class proportions]' \
  '--plot_coordinates[plot coordinates]' && ret=0

return ret
