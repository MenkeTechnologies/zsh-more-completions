#compdef CuraEngine cura-engine
# Documentation: https://github.com/Ultimaker/CuraEngine/blob/main/src/Application.cpp
# Reference accessed: 2026-05-27
# Verified: upstream Application.cpp printCall/printHelp and slice/connect handling

# Zsh completion for CuraEngine (Ultimaker standalone slicing engine)

local curcontext="$curcontext" state line ret=1

local -a _cura_subcommands
_cura_subcommands=(
  'slice:process 3D models and generate G-code'
  'connect:connect to host via command socket (ARCUS builds only)'
  'help:display usage information'
)

_arguments -C \
  '-v[increase verbose level (show log messages)]' \
  '-m+[set thread count for processing]:thread count:' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'CuraEngine subcommand' _cura_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      slice)
        _arguments \
          '-v[increase verbose level]' \
          '-p[log progress information]' \
          '-m+[set thread count]:thread count:' \
          '-d+[definition search paths (colon-separated)]:search paths:' \
          '*-j+[register settings and defaults from JSON file]:settings json:_files -g "*.json"' \
          '*-l+[load STL model for processing]:model:_files -g "*.(stl|STL|obj|OBJ|3mf|3MF)"' \
          '*-o+[output G-code file]:output:_files' \
          '*-s+[override individual setting (key=value)]:key=value:' \
          '*-r+[load JSON file with resolved setting values]:resolved settings:_files -g "*.json"' \
          '*-e+[switch setting focus to specified extruder train]:extruder number:' \
          '-g[focus settings on current mesh group (one-at-a-time printing)]' \
          '--next[start a new mesh group for one-at-a-time printing]' && ret=0
        ;;
      connect)
        _arguments \
          '-v[enable debug-level logging]' \
          '-m+[configure thread pool size]:thread count:' \
          '1:host:_hosts' && ret=0
        ;;
      help)
        _message 'no more arguments' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
