#compdef mdbook-mermaid

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'install:install mermaid assets into book'
      'supports:check if a renderer is supported'
      'test:test the preprocessor'
    )
    _describe -t commands 'mdbook-mermaid command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:book directory:_directories' && ret=0
        ;;
      supports)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:renderer name' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
