#compdef cargo-upgrade
# Documentation: https://github.com/killercup/cargo-edit
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for `cargo upgrade` (from the cargo-edit suite).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-V --version)'{-V,--version}'[Print version]' \
  '(-n --dry-run)'{-n,--dry-run}'[Display changes without applying them]' \
  '--manifest-path=[Cargo.toml]:file:_files -g "*.toml"' \
  '--rust-version=[Override rust-version setting]:ver:' \
  '--ignore-rust-version[Disregard rust-version specification]' \
  '*'{-p+,--package=}'[Crate to upgrade (PKGID[@VERSION])]:package:' \
  '*--exclude=[Crates to exclude]:package:' \
  '(-q --quiet)'{-q,--quiet}'[Decrease logging]' \
  '*'{-v,--verbose}'[Increase logging]' \
  '--locked[Require Cargo.toml is current]' \
  '--compatible=[Upgrade to latest compatible version]:mode:(allow ignore)' \
  '(-i --incompatible)'{-i,--incompatible=}'[Upgrade to latest incompatible version]:mode:(allow ignore)' \
  '--pinned=[Upgrade pinned to latest incompatible version]:mode:(allow ignore)' \
  '--recursive=[Recursively update locked dependencies]:b:(true false)' \
  '-Z+[Unstable nightly flags]:flag:' && ret=0

return ret
