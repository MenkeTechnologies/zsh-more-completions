#compdef cargo-upgrade

# Zsh completion for cargo-upgrade (cargo upgrade subcommand from cargo-edit)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '--dry-run[Print changes to be made without actually writing the manifest]' \
  '--manifest-path=[Path to Cargo.toml]:file:_files' \
  '-p+[Package to upgrade]:package' \
  '--package=[Package to upgrade]:package' \
  '-q[Do not print cargo log messages]' \
  '--quiet[Do not print cargo log messages]' \
  '-v[Use verbose output]' \
  '--verbose[Use verbose output]' \
  '--color=[Coloring]:when:(auto always never)' \
  '--frozen[Require Cargo.lock and cache are up to date]' \
  '--locked[Require Cargo.lock is up to date]' \
  '--offline[Run without accessing the network]' \
  '--all[Upgrade all packages in the workspace]' \
  '--workspace[Upgrade all packages in the workspace]' \
  '--exclude=[Packages to exclude from upgrade]:package' \
  '--incompatible=[How to handle incompatible upgrades]:handling:(allow)' \
  '--pinned[Upgrade pinned dependencies too]' \
  '--recursive[Recursively update locked dependencies]' \
  '*:crate' && ret=0

return ret
