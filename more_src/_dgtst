#compdef dgtst
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/dgtst.1.html
# PT-Scotch: test the consistency of a distributed source graph

local ret=1

_arguments -s \
  '-h[display help]' \
  '-r-[set root process for centralized files (default 0)]:pnum' \
  '-V[display version and copyright]' \
  '*:file:_files' && ret=0

return ret
