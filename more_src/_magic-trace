#compdef magic-trace
# Documentation: https://github.com/janestreet/magic-trace
# magic-trace collects and displays high-resolution traces using Intel Processor Trace

local curcontext="$curcontext" state line ret=1

_arguments -s -C \
  '(- *)'{-help,--help}'[show help]' \
  '1:command:((attach\:"attach to a running process" run\:"run a program under trace"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '(- *)'{-help,--help}'[show help]' \
      '-pid[PID of process to attach to]:pid:_pids' \
      '-trigger[take a snapshot when this symbol is called]:symbol' \
      '-multi-snapshot[take snapshots on each trigger, not just one]' \
      '-output[trace output file]:file:_files' \
      '-snapshot-size[snapshot ring buffer size in bytes]:bytes' \
      '-timer-resolution[timer resolution (Low Normal High)]:res:(Low Normal High)' \
      '-sampling[use perf sampling mode instead of Intel PT]' \
      '-full-execution[record full execution, not just a snapshot]' \
      '-trace-include-kernel[include kernel stacks (requires root)]' \
      '-callgraph-mode[callstack reconstruction mode]:mode' \
      '*:program:_command_names' && ret=0
    ;;
esac

return ret
