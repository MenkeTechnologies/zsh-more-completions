#compdef archivemount
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/archivemount.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for archivemount
# Upstream: File system for accessing archives using libarchive
# Conservative fallback — run `archivemount --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
