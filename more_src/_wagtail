#compdef wagtail

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:create a new Wagtail project'
  'publish_scheduled:publish or unpublish scheduled objects'
  'publish_scheduled_pages:deprecated alias of publish_scheduled'
  'fixtree:scan and fix DB tree errors'
  'move_pages:relocate pages from one parent to another'
  'purge_revisions:delete old revisions'
  'purge_embeds:remove cached embed objects'
  'update_index:rebuild search index'
  'wagtail_update_index:alias of update_index'
  'rebuild_references_index:populate cross-reference table'
  'show_references_index:display references index summary'
  'wagtail_update_image_renditions:regenerate image renditions'
  'convert_mariadb_uuids:MariaDB UUID conversion for Django 5.0+'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--settings=[settings module]:settings:' \
  '--pythonpath=[directory to add to PYTHONPATH]:dir:_files -/' \
  '--traceback[show full Python traceback]' \
  '--no-color[disable colorized output]' \
  '(-v --verbosity)'{-v,--verbosity=}'[verbosity level]:level:(0 1 2 3)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'wagtail subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '--template=[project template]:template:' && ret=0
        ;;
      (purge_revisions)
        _arguments \
          '--days=[older than days]:days:' \
          '--pages[only pages]' \
          '--non-pages[only non-pages]' && ret=0
        ;;
      (update_index|wagtail_update_index)
        _arguments \
          '--backend=[search backend]:backend:' \
          '--chunk_size=[chunk size]:n:' \
          '--schema-only[only update schema]' && ret=0
        ;;
      (wagtail_update_image_renditions)
        _arguments \
          '--purge-only[only purge old renditions]' && ret=0
        ;;
    esac
    ;;
esac

return ret
