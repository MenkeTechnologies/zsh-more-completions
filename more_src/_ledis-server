#compdef ledis-server
# Documentation: https://github.com/ledisdb/ledisdb/blob/master/cmd/server.go
# LedisDB server, a high-performance Redis-protocol NoSQL database

local ret=1

_arguments -s -S \
  '-config=[ledisdb config file]:file:_files -g "*.(toml|conf)"' \
  '-addr=[ledisdb listen address]:addr:' \
  '-data_dir=[ledisdb base data directory]:dir:_files -/' \
  '-db_name=[db to use, overwrites config db name]:dbname:' \
  '-databases=[ledisdb maximum database number]:n:' \
  '-slaveof=[make the server a slave of another instance]:master:' \
  '-readonly[set readonly mode]' \
  '-rpl[enable replication]' \
  '-rpl_sync[enable sync replication]' \
  '-ttl_check=[TTL check interval]:seconds:' \
  '-pprof[enable pprof]' \
  '-pprof_port=[pprof http port]:port:' && ret=0

return ret
