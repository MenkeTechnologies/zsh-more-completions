#compdef clearml-cli clearml2 clearml-task clearml-data clearml-agent
# _clearml-cli — Allegro AI ClearML clearml-cli CLI command-line frontend wrapping the ClearML open-source MLOps platform managing experiments tasks datasets queues workers projects models pipelines deployments daemon-server agent init enqueue execute upload archive clone publish remote-execute (Allegro AI team, Python); argparse
# upstream: https://clear.ml/

_clearml-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'init:initialize ClearML config'
        'task:task operations'
        'experiment:experiment operations'
        'dataset:dataset operations'
        'queue:queue operations'
        'worker:worker operations'
        'project:project operations'
        'model:model registry'
        'pipeline:pipeline operations'
        'agent:run a ClearML Agent'
        'enqueue:enqueue a task'
        'execute:execute a script'
        'upload:upload artifact'
        'archive:archive task'
        'clone:clone task'
        'publish:publish task'
        'serving:Serving operations'
        'app:app operations'
        'session:session operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-server=+[url]:str:' \
        '--web-server=+[url]:str:' \
        '--files-server=+[url]:str:' \
        '--access-key=+[key]:str:' \
        '--secret-key=+[secret]:str:' \
        '--token=+[token]:str:' \
        '--project=+[name]:str:' \
        '--task=+[name]:str:' \
        '--name=+[name]:str:' \
        '--tag=+[tag]:str:' \
        '--script=+[file]:file:_files -g "*.py *.ipynb"' \
        '--requirements=+[file]:file:_files -g "*.txt requirements.txt"' \
        '--branch=+[name]:str:' \
        '--commit=+[hash]:str:' \
        '--repo=+[url]:str:' \
        '--working-dir=+[dir]:dir:_files -/' \
        '--queue=+[name]:str:' \
        '-c+[config file]:file:_files -g "clearml.conf *.conf *.yaml *.yml"' \
        '--config=+[file]:file:_files -g "*.conf *.yaml *.yml"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'clearml-cli subcommand' sub ;;
        args)
            case $words[1] in
                task|experiment|dataset|queue|worker|project|model|pipeline|serving|app|session) _arguments '1:op:(list get create update delete archive clone publish enqueue dequeue execute close pause resume)' '*:id:' ;;
                agent) _arguments '1:op:(daemon foreground execute build init list)' '*:queue:' ;;
            esac
            ;;
    esac
}

_clearml-cli "$@"
