#compdef pt-archiver
# Documentation: https://docs.percona.com/percona-toolkit/pt-archiver.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--analyze=[run ANALYZE TABLE on source/dest]:s|d|sd' \
  '--ascend-first[ascend only first column of index]' \
  '--ask-pass[prompt for password]' \
  '--buffer[buffer output to file and flush at commit]' \
  '--buffer-stdout[enable STDOUT buffering (default)]' \
  '--no-buffer-stdout[disable STDOUT buffering]' \
  '--bulk-delete[delete each chunk with one statement]' \
  '--bulk-delete-limit[append --limit to bulk delete (default)]' \
  '--no-bulk-delete-limit[do not append --limit to bulk delete]' \
  '--bulk-insert[insert each chunk with LOAD DATA INFILE]' \
  '--channel=[replication channel name]:channel' \
  '(-A --charset)'{-A+,--charset=}'[default character set]:charset' \
  '--check-charset[check connection/table charsets match (default)]' \
  '--no-check-charset[skip charset compatibility check]' \
  '--check-columns[verify source/dest columns match (default)]' \
  '--no-check-columns[skip column existence check]' \
  '--check-interval=[pause duration when replica lag detected]:duration' \
  '*--check-replica-lag=[pause until replica lag below threshold]:DSN' \
  '*--check-slave-lag=[deprecated; use --check-replica-lag]:DSN' \
  '(-c --columns)'{-c+,--columns=}'[comma-separated columns to archive]:columns' \
  '--commit-each[commit after each fetched set]' \
  '*--config=[comma-separated config files]:file:_files' \
  '(-D --database)'{-D+,--database=}'[database name]:database' \
  '(-F --defaults-file)'{-F+,--defaults-file=}'[MySQL defaults file]:file:_files' \
  '--delayed-insert[use INSERT DELAYED]' \
  '--dest=[destination DSN]:DSN' \
  '--dry-run[print queries and exit]' \
  '--file=[output filename (DATE_FORMAT codes ok)]:file:_files' \
  '--for-update[add FOR UPDATE to SELECT]' \
  '--header[print column headers]' \
  '--high-priority-select[add HIGH_PRIORITY to SELECT]' \
  '(-h --host)'{-h+,--host=}'[MySQL host]:host:_hosts' \
  '--ignore[use INSERT IGNORE]' \
  '--limit=[rows per fetch/archive statement]:rows' \
  '--local[exclude OPTIMIZE/ANALYZE from binlog]' \
  '--low-priority-delete[add LOW_PRIORITY to DELETE]' \
  '--low-priority-insert[add LOW_PRIORITY to INSERT]' \
  '--max-flow-ctl=[pause if PXC flow control exceeds threshold]:percent' \
  '--max-lag=[max replication lag before pause]:duration' \
  '(-s --mysql_ssl)'{-s+,--mysql_ssl=}'[create SSL MySQL connection]:int' \
  '--no-ascend[disable ascending index optimization]' \
  '--no-delete[do not delete archived rows]' \
  '--optimize=[OPTIMIZE TABLE on source/dest]:s|d|sd' \
  '--output-format=[output format]:format:(dump csv)' \
  '(-p --password)'{-p+,--password=}'[MySQL password]:password' \
  '--pid=[PID file path]:file:_files' \
  '--plugin=[Perl module plugin]:module' \
  '(-P --port)'{-P+,--port=}'[MySQL port]:port' \
  '--primary-key-only[archive only primary key columns]' \
  '--progress=[print progress every N rows]:rows' \
  '--purge[delete rows without archiving]' \
  '--quick-delete[add QUICK to DELETE]' \
  '(-q --quiet)'{-q,--quiet}'[suppress normal output]' \
  '--replace[use REPLACE INTO]' \
  '--retries=[retry count for timeouts/deadlocks]:count' \
  '--run-time=[max execution time]:duration' \
  '--safe-auto-increment[prevent archiving max AUTO_INCREMENT row (default)]' \
  '--no-safe-auto-increment[allow archiving max AUTO_INCREMENT row]' \
  '--sentinel=[exit if file exists]:file:_files' \
  '*--set-vars=[MySQL variables as comma-separated pairs]:vars' \
  '--share-lock[use LOCK IN SHARE MODE]' \
  '--skip-foreign-key-checks[skip foreign key checks]' \
  '--sleep=[seconds to sleep between fetches]:seconds' \
  '--sleep-coef=[multiply last SELECT time for sleep]:coef' \
  '(-S --socket)'{-S+,--socket=}'[socket file]:file:_files' \
  '--source=[source DSN (required)]:DSN' \
  '--statistics[print timing statistics]' \
  '--stop[create sentinel file to stop running instances]' \
  '--txn-size=[rows per transaction]:rows' \
  '--unstop[remove sentinel file]' \
  '(-u --user)'{-u+,--user=}'[MySQL username]:user:_users' \
  '--version-check[check for software updates (default)]' \
  '--no-version-check[skip version update check]' \
  '--where=[WHERE clause (required)]:clause' \
  '--why-quit[print reason for exiting]' && ret=0

return ret
