#compdef pt-archiver

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--bulk-delete[delete in bulk]' \
  '--bulk-delete-limit=[bulk delete limit]:rows:' \
  '--bulk-insert[insert in bulk]' \
  '--charset=[default character set]:charset:' \
  '--check-charset[check character set compatibility]' \
  '--check-columns[check column existence]' \
  '--check-interval=[check interval]:seconds:' \
  '--check-slave-lag=[check lag on slave]:DSN:' \
  '--columns=[columns to archive]:columns:' \
  '--commit-each[commit after each set]' \
  '--config=[config file]:config file:_files' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--delayed-insert[use INSERT DELAYED]' \
  '--dest=[destination DSN]:DSN:' \
  '--dry-run[dry run]' \
  '--file=[file to write archived rows]:file:_files' \
  '--for-update[add FOR UPDATE to SELECT]' \
  '--header[print column headers]' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--ignore[use INSERT IGNORE]' \
  '--limit=[rows per statement]:rows:' \
  '--local[do not write to binlog]' \
  '--max-lag=[max replication lag]:seconds:' \
  '--max-load=[max load before throttling]:load spec:' \
  '--no-ascend[do not use ascending index optimization]' \
  '--no-delete[do not delete archived rows]' \
  '--optimize=[OPTIMIZE TABLE]:table:' \
  '--output-format=[output format]:format:(dump csv)' \
  '--password=[MySQL password]:password:' \
  '--pid=[PID file]:pid file:_files' \
  '--plugin=[Perl module plugin]:module:' \
  '--port=[MySQL port]:port:' \
  '--primary-key-only[only fetch primary key columns]' \
  '--progress=[print progress]:count:' \
  '--purge[purge instead of archive]' \
  '--quiet[quiet output]' \
  '--replace[use REPLACE INTO]' \
  '--retries=[retry count]:count:' \
  '--run-time=[max run time]:duration:' \
  '--sentinel=[sentinel file]:file:_files' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--share-lock[use LOCK IN SHARE MODE]' \
  '--skip-foreign-key-checks[skip foreign key checks]' \
  '--sleep=[sleep between commits]:seconds:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--source=[source DSN]:DSN:' \
  '--statistics[print statistics]' \
  '--stop[stop archiving]' \
  '--txn-size=[transaction size]:rows:' \
  '--user=[MySQL user]:username:' \
  '--where=[WHERE clause]:where:' \
  '--why-quit[print why archiver stopped]' && ret=0

return ret
