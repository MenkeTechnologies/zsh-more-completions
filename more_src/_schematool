#compdef schematool schematool.sh hive-schematool

_arguments -s \
  '(- *)-help[show help]' \
  '-initSchema[initialize schema]' \
  '-initSchemaTo=[initialize schema to specific version]:version:' \
  '-initOrUpgradeSchema[initialize or upgrade schema]' \
  '-upgradeSchema[upgrade schema]' \
  '-upgradeSchemaFrom=[upgrade schema from version]:version:' \
  '-info[print schema info]' \
  '-validate[validate schema]' \
  '-createCatalog=[create catalog]:name:' \
  '-alterCatalog=[alter catalog]:name:' \
  '-mergeCatalog=[merge catalog]:name:' \
  '-moveDatabase=[move database]:db:' \
  '-moveTable=[move table]:tbl:' \
  '-dropAllDatabases[drop all databases]' \
  '-createUser[create Hive user]' \
  '-createLogsTable=[create logs table]:flag:(true false)' \
  '-addServerForCDC[add server for CDC]' \
  '-dbType=[database type]:type:(derby mysql postgres oracle mssql hive)' \
  '-metaDbType=[metastore DB type]:type:(derby mysql postgres oracle mssql)' \
  '-url=[JDBC URL]:url:' \
  '-driver=[JDBC driver class]:class:' \
  '-userName=[database username]:user:_users' \
  '-passWord=[database password]:password:' \
  '-dbOpts=[database options]:opts:' \
  '-verbose[verbose output]' \
  '-dryRun[dry run]' \
  '-yes[skip confirmations]' \
  '-servers=[scheme://auth list]:servers:' \
  '-toCatalog=[target catalog]:name:' \
  '-fromCatalog=[source catalog]:name:' \
  '-catalogLocation=[catalog location]:location:' \
  '-catalogDescription=[catalog description]:desc:' \
  '-ifNotExists[skip if exists]' \
  '-fromDatabase=[source database]:db:' \
  '-toDatabase=[target database]:db:' \
  '-hiveUser=[Hive user]:user:_users' \
  '-hivePassword=[Hive password]:password:' \
  '-hiveDb=[Hive database]:db:' \
  '-retentionPeriod=[retention period in days]:days:'
