#compdef OpenSwathChromatogramExtractor
# Documentation: https://www.openms.org/documentation/html/TOPP_OpenSwathChromatogramExtractor.html
# OpenMS: extracts ion chromatograms (XICs) from MS data for given transitions

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '*-in[input files (mzML)]:file:_files -g "*.mzML"' \
  '-tr[transition file (TraML or CSV)]:file:_files' \
  '-out[output file (mzML)]:file:_files' \
  '-rt_norm[RT normalization file (trafoXML)]:file:_files' \
  '-min_upper_edge_dist[minimal distance to edge in Th]:double:' \
  '-rt_window[extraction window in RT (seconds)]:double:' \
  '-ion_mobility_window[extraction window in ion mobility (ms)]:double:' \
  '-mz_window[extraction window in m/z (Th)]:double:' \
  '-ppm[specify m/z extraction window in ppm]' \
  '-is_swath[input is SWATH data]' \
  '-extract_MS1[extract MS1 transitions from precursor values]' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
