#compdef motuclient motu-client
# Documentation: https://github.com/clstoulouse/motu-client-python/blob/master/README.md
# Motu client - download oceanographic data subsets from a Motu server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, only errors]' \
  '--verbose[verbose mode]' \
  '--noisy[noisy debug mode]' \
  '(-u --user)'{-u,--user}'=[Motu server username]:user:' \
  '(-p --pwd)'{-p,--pwd}'=[Motu server password]:pass:' \
  '--auth-mode=[authentication mode]:mode:(none basic cas)' \
  '--proxy-server=[proxy server URL]:url:' \
  '--proxy-user=[proxy username]:user:' \
  '--proxy-pwd=[proxy password]:pass:' \
  '(-m --motu)'{-m,--motu}'=[Motu server URL]:url:' \
  '(-s --service-id)'{-s,--service-id}'=[service identifier]:id:' \
  '(-d --product-id)'{-d,--product-id}'=[product/dataset identifier]:id:' \
  '(-y --latitude-min)'{-y,--latitude-min}'=[minimum latitude]:lat:' \
  '(-Y --latitude-max)'{-Y,--latitude-max}'=[maximum latitude]:lat:' \
  '(-x --longitude-min)'{-x,--longitude-min}'=[minimum longitude]:lon:' \
  '(-X --longitude-max)'{-X,--longitude-max}'=[maximum longitude]:lon:' \
  '(-z --depth-min)'{-z,--depth-min}'=[minimum depth]:depth:' \
  '(-Z --depth-max)'{-Z,--depth-max}'=[maximum depth]:depth:' \
  '(-t --date-min)'{-t,--date-min}'=[start date]:date:' \
  '(-T --date-max)'{-T,--date-max}'=[end date]:date:' \
  '*'{-v,--variable}'=[variable to extract]:variable:' \
  '(-o --out-dir)'{-o,--out-dir}'=[output directory]:dir:_files -/' \
  '(-f --out-name)'{-f,--out-name}'=[output filename]:file:_files' \
  '(-D --describe-product)'{-D,--describe-product}'[describe the product instead of downloading]' \
  '--size[print the size of the requested download]' \
  '(-S --sync-mode)'{-S,--sync-mode}'[synchronous download mode]' \
  '--console-mode[print output to stdout instead of a file]' \
  '--block-size=[download block size in bytes]:bytes:' \
  '--socket-timeout=[socket timeout in seconds]:seconds:' \
  '--user-agent=[HTTP user agent header]:agent:' \
  '--outputWritten=[output format]:format:(netcdf netcdf4)' \
  '--config-file=[configuration file]:file:_files' \
  '*:config file:_files' && ret=0

return ret
