#compdef bedPileUps
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# find (exact) overlaps if any in bed input

local ret=1

_arguments -s -S \
  '-name[include BED name field 4 when evaluating uniqueness]' \
  '-tab[use tabs to parse fields]' \
  '*:in bed:_files -g "*.bed"' && ret=0

return ret
