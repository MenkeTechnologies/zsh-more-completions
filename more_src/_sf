#compdef sf

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'org:manage Salesforce orgs'
  'project:work with Salesforce projects'
  'deploy:deploy metadata to an org'
  'retrieve:retrieve metadata from an org'
  'auth:authenticate with orgs'
  'config:configure CLI'
  'alias:manage aliases'
  'data:work with org data'
  'apex:execute and manage Apex'
  'lightning:Lightning components'
  'package:manage packages'
  'package1:manage 1GP packages'
  'plugins:manage CLI plugins'
  'agent:Agentforce agent commands'
  'analytics:Tableau CRM/Analytics'
  'community:experience cloud'
  'force:legacy sfdx force commands'
  'function:Salesforce Functions (deprecated)'
  'hardis:sfdx-hardis (third-party)'
  'limits:org limits'
  'login:authenticate to an org (alias for org login)'
  'logout:log out of an org'
  'open:open an org in browser'
  'release:release management'
  'schema:metadata schema'
  'sobject:standard/custom object operations'
  'static-resource:static resource management'
  'template:project templates'
  'user:org user management'
  'visualforce:Visualforce components'
  'autocomplete:set up shell completion'
  'commands:list all CLI commands'
  'help:show help'
  'update:update the CLI'
  'version:show CLI version'
  'whoami:show authenticated user'
  'which:show command location'
  'env:Heroku environment integration'
  'info:show CLI info'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--json[output as JSON]' \
  '--flags-dir=[directory of flag files]:dir:_files -/' \
  '*--target-org=[target org alias/username]:org:' \
  '*-o+[target org]:org:' \
  '*--target-dev-hub=[Dev Hub alias/username]:hub:' \
  '*-v+[Dev Hub]:hub:' \
  '--api-version=[API version]:version:' \
  '--loglevel=[log level]:level:(trace debug info warn error fatal)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sf subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (org)
        _values 'org action' \
          'create' 'delete' 'display' 'list' 'login' 'logout' 'open' \
          'resume' 'use' 'assign' 'create-scratch' 'create-sandbox' \
          'create-snapshot' 'create-shape' 'delete-sandbox' 'delete-scratch' \
          'delete-shape' 'delete-snapshot' 'list-auth' 'list-metadata' \
          'list-metadata-types' 'list-snapshots' 'list-shapes' 'login-access-token' \
          'login-device' 'login-jwt' 'login-sfdx-url' 'login-web' \
          'refresh-sandbox' 'reset-password' 'resume-sandbox' \
          'resume-snapshot' 'resume-scratch' 'sample' 'unassign' \
          'generate-password' 'show-resource' && ret=0
        ;;
      (project)
        _values 'project action' \
          'convert' 'deploy' 'generate' 'list-ignored' 'reset' 'retrieve' && ret=0
        ;;
      (deploy)
        _arguments \
          {-m+,--metadata=}'[comma-separated metadata to deploy]:components:' \
          {-d+,--source-dir=}'[source directory]:dir:_files -/' \
          {-x+,--manifest=}'[manifest file]:file:_files -g "*.xml"' \
          {-c,--check-only}'[validate only]' \
          {-r,--ignore-warnings}'[ignore warnings]' \
          {-w+,--wait=}'[wait minutes]:n:' \
          '--api-version=[API version]:version:' \
          {-l+,--test-level=}'[test level]:level:(NoTestRun RunSpecifiedTests RunLocalTests RunAllTestsInOrg)' \
          '*-t+[test name]:test:' \
          '--dry-run[dry run]' \
          '--verbose[verbose]' \
          '--concise[concise output]' \
          '--purge-on-delete[purge on delete]' \
          '--ignore-conflicts[ignore conflicts]' \
          '--coverage-formatters=[coverage formats]:formats:' \
          '--results-dir=[results directory]:dir:_files -/' && ret=0
        ;;
      (retrieve)
        _values 'retrieve action' 'metadata' 'start' 'preview' 'resume' 'report' && ret=0
        ;;
      (auth)
        _values 'auth action' \
          'web login' 'jwt grant' 'sfdx-url store' 'device login' 'list' 'logout' && ret=0
        ;;
      (config)
        _values 'config action' \
          'get' 'list' 'set' 'unset' && ret=0
        ;;
      (data)
        _values 'data action' \
          'create record' 'delete bulk' 'delete record' 'delete resume' \
          'export tree' 'export bulk' 'export resume' 'get record' \
          'import bulk' 'import resume' 'import tree' 'query' 'query resume' \
          'search' 'update record' 'update bulk' 'update resume' \
          'upsert bulk' 'upsert resume' && ret=0
        ;;
      (apex)
        _values 'apex action' \
          'generate class' 'generate trigger' 'list log' 'tail log' 'get log' \
          'run' 'run test' 'get test' 'execute' && ret=0
        ;;
      (alias)
        _values 'alias action' 'list' 'set' 'unset' && ret=0
        ;;
      (package|package1)
        _values 'package action' \
          'create' 'delete' 'install' 'install report' 'installed list' \
          'list' 'push-upgrade abort' 'push-upgrade list' 'push-upgrade report' \
          'push-upgrade schedule' 'uninstall' 'uninstall report' \
          'update' 'version create' 'version delete' 'version displayancestry' \
          'version list' 'version promote' 'version report' 'version update' && ret=0
        ;;
      (autocomplete)
        _values 'shell' 'bash' 'fish' 'powershell' 'zsh' && ret=0
        ;;
      (plugins)
        _values 'plugins action' \
          'install' 'inspect' 'link' 'reset' 'uninstall' 'update' 'trust' \
          'list' && ret=0
        ;;
    esac
    ;;
esac

return ret
