#compdef yoda-config
# Documentation: https://yoda.hepforge.org/
# yoda-config - query YODA build/link configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--prefix[show the installation prefix]' \
  '--includedir[path to directory containing YODA headers]' \
  '--libdir[path to directory containing YODA libraries]' \
  '--pythonpath[path(s) to YODA Python package directory]' \
  '--guess-prefix[try to use the runtime prefix]' \
  '--cflags[-I string for compiler flags]' \
  '--cppflags[-I string for compiler flags]' \
  '--cxxflags[-I string for compiler flags]' \
  '--ldflags[-L/-l string for linker flags]' \
  '--libs[-L/-l string for linker flags]' \
  '--ldadd[-L/-l string for linker flags]' \
  '--version[show the YODA release version number]' && ret=0

return ret
