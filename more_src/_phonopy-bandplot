#compdef phonopy-bandplot
# Documentation: https://phonopy.github.io/phonopy/auxiliary-tools.html
# Plot phonon band structure from phonopy band.yaml/band.hdf5

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--hdf5[read HDF5 format]' \
  '--dmax=[maximum DOS plotted]:dmax' \
  '--dos=[dos.dat file to plot alongside the band structure]:file:_files' \
  '--dos-factor=[factor to multiply with DOS]:factor' \
  '--dos-xlabel=[x-label of DOS]:label' \
  '--factor=[conversion factor to favorite frequency unit]:factor' \
  '--fmax=[maximum frequency plotted]:fmax' \
  '--fmin=[minimum frequency plotted]:fmin' \
  '--gnuplot[output in gnuplot data style]' \
  '(-i --indices)'{-i,--indices}'=[indices like "1 2, 3 4 5 6"]:indices' \
  '--legend[show legend]' \
  '(-o --output)'{-o,--output}'=[output filename of PDF plot]:file:_files' \
  '--ylabel=[y-label of band structure]:label' \
  '--mev[convert unit to meV assuming THz input]' \
  '(-t --title)'{-t,--title}'=[title of plot]:title' \
  '*:band file:_files -g "*.(yaml|hdf5)"' && ret=0

return ret
