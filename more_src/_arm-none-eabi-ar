#compdef arm-none-eabi-ar
# _arm-none-eabi-ar — Arm Limited arm-none-eabi-ar CLI for the bare-metal ARM cross-archiver maintaining static-library archives create extract list verbose update index member modify object replace symbol-table (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-ar() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[delete members]' \
        '-m[move members]' \
        '-p[print members]' \
        '-q[quick append]' \
        '-r[replace]' \
        '-s[create index]' \
        '-t[list contents]' \
        '-x[extract members]' \
        '-c[create archive]' \
        '-o[preserve mod times]' \
        '-u[update]' \
        '-l[list]' \
        '-N+[count]:n:' \
        '-S[no symbol table]' \
        '-T[thin archive]' \
        '-D[deterministic]' \
        '-U[non-deterministic]' \
        '*:archive members:_files -g "*.a *.o"'
}

_arm-none-eabi-ar "$@"
