#compdef nix-info
# Documentation: https://github.com/NixOS/nixpkgs/blob/master/pkgs/tools/nix/info/info.sh
# get high level Nix/NixOS info to help with debugging

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --markdown)'{-m,--markdown}'[format output for a GitHub issue (implies --host-os --sandbox)]' \
  '--sandbox[include sandbox configuration]' \
  '--host-os[include host OS details]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' && ret=0

return ret
