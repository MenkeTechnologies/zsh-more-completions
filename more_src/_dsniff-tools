#compdef dsniff arpspoof dnsspoof macof filesnarf mailsnarf msgsnarf urlsnarf webspy webmitm sshmitm sshow tcpkill2 tcpnice2 dnsiff dsniff-cli

local curcontext="$curcontext" state line ret=1

case $service in
  (dsniff)
    _arguments -C \
      '-c[half-duplex TCP]' \
      '-d[debug]' \
      '-m[automatic protocol detection]' \
      '-n[no resolve]' \
      '-i+[interface]:if:_net_interfaces' \
      '-s+[snaplen]:n:' \
      '-f+[services file]:file:_files' \
      '-t+[trigger]:t:' \
      '-r+[read pcap]:file:_files -g "*.pcap *.cap"' \
      '-w+[write file]:file:_files' \
      '-X[trim non-ASCII]' \
      '*:filter:' && ret=0 ;;
  (arpspoof|dnsspoof|macof)
    _arguments -C \
      '-i+[interface]:if:_net_interfaces' \
      '-c+[cleanup target]:t:(own host both)' \
      '-t+[target host]:host:_hosts' \
      '-r[poison both ways]' \
      '-f+[hosts file]:file:_files' \
      '*: :' && ret=0 ;;
  (filesnarf|mailsnarf|msgsnarf|urlsnarf)
    _arguments -C \
      '-i+[interface]:if:_net_interfaces' \
      '-n[no resolve]' \
      '-p+[pattern]:re:' \
      '-r+[pcap file]:file:_files -g "*.pcap"' \
      '-v[invert match]' \
      '*:filter:' && ret=0 ;;
  (webspy|webmitm|sshmitm)
    _arguments -C \
      '-i+[interface]:if:_net_interfaces' \
      '-d[debug]' \
      '*: :_hosts' && ret=0 ;;
  (sshow)
    _arguments -C \
      '-i+[interface]:if:_net_interfaces' \
      '-n[no resolve]' \
      '*: :' && ret=0 ;;
esac

return ret
