#compdef dsniff arpspoof dnsspoof macof filesnarf mailsnarf msgsnarf urlsnarf webspy webmitm sshmitm sshow tcpkill2 tcpnice2 dnsiff dsniff-cli
# Documentation: https://man.archlinux.org/search?q=dsniff
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (dsniff|dnsiff|dsniff-cli)
    # hackerschoice/dsniff dsniff.8 (2.5): live capture OR pcap, plus DPI triggers.
    _arguments -C \
      '-v[verbose; show banners]' \
      '-c[half-duplex TCP stream reassembly]' \
      '-a[show all results (do not suppress duplicates)]' \
      '-d[debug]' \
      '-m[force protocol detection / DPI on known services]' \
      '-D[disable DPI (decode only known services)]' \
      '-N[resolve IP addresses to hostnames]' \
      '-P[promiscuous mode]' \
      '-C[force color even when stdout is not a tty]' \
      '(-p)*-i+[interface]:interface:_net_interfaces' \
      '(-i)*-p+[read packets from pcap instead of the network]:pcap file:_files -g "*.pcap *.cap"' \
      '-s+[analyze at most this many bytes per connection]:snaplen:' \
      '-f+[services file overriding built-in triggers]:services file:_files' \
      '-M+[Unix magic file for custom DPI rules]:magic file:_files' \
      '-t+[comma-separated port/proto=service triggers]:triggers:' \
      '*:pcap filter expression:' && ret=0 ;;
  (tcpkill2)
    # tcpkill.8: -i if; optional -1 .. -9 brute-force level; tcpdump expression.
    _arguments -C \
      '-i+[interface]:interface:_net_interfaces' \
      '-1[lowest packet-injection effort (RST landing)]' \
      '-2[injection effort level 2]' \
      '-3[injection effort level 3 (default)]' \
      '-4[injection effort level 4]' \
      '-5[injection effort level 5]' \
      '-6[injection effort level 6]' \
      '-7[injection effort level 7]' \
      '-8[injection effort level 8]' \
      '-9[highest injection effort]' \
      '*:tcpdump filter expression:' && ret=0 ;;
  (tcpnice2)
    # tcpnice.8: pick attack shape; -i if; tcpdump expression.
    _arguments -C \
      '-A[inject tiny TCP window advertisements]' \
      '-I[inject ICMP source quench replies]' \
      '-M[inject ICMP fragmentation-needed with tiny MTU]' \
      '-i+[interface]:interface:_net_interfaces' \
      '*:tcpdump filter expression:' && ret=0 ;;
  (arpspoof|dnsspoof|macof)
    _arguments -C \
      '-i+[interface]:if:_net_interfaces' \
      '-c+[cleanup target]:t:(own host both)' \
      '-t+[target host]:host:_hosts' \
      '-r[poison both ways]' \
      '-f+[hosts file]:file:_files' \
      '*: :' && ret=0 ;;
  (filesnarf|mailsnarf|msgsnarf|urlsnarf)
    _arguments -C \
      '-i+[interface]:if:_net_interfaces' \
      '-n[no resolve]' \
      '-p+[pattern]:re:' \
      '-r+[pcap file]:file:_files -g "*.pcap"' \
      '-v[invert match]' \
      '*:filter:' && ret=0 ;;
  (webspy|webmitm|sshmitm)
    _arguments -C \
      '-i+[interface]:if:_net_interfaces' \
      '-d[debug]' \
      '*: :_hosts' && ret=0 ;;
  (sshow)
    _arguments -C \
      '-i+[interface]:if:_net_interfaces' \
      '-n[no resolve]' \
      '*: :' && ret=0 ;;
esac

return ret
