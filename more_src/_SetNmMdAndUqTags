#compdef SetNmMdAndUqTags
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#SetNmMdAndUqTags
# Picard: fix the NM, MD, and UQ tags in a coordinate-sorted SAM/BAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[the BAM or SAM file to fix]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[the fixed BAM or SAM output file]:bam:_files -g "*.(bam|sam)"' \
  {-R=,--REFERENCE_SEQUENCE=}'[reference sequence FASTA]:fasta:_files -g "*.(fa|fasta)"' \
  '--IS_BISULFITE_SEQUENCE=[whether the file contains bisulfite sequence]:bool:(true false)' \
  '--SET_ONLY_UQ=[only set the UQ tag, leaving NM and MD unchanged]:bool:(true false)' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
