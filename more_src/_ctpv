#compdef ctpv
# Documentation: https://github.com/NikitaIvanovV/ctpv
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Terminal file preview helper (used with lf, ranger, etc.).

_arguments -s -S \
  '-h[show help]' \
  '-l[list all previews]' \
  '-m[print extension and MIME type for files]' \
  '-s+[start server with the given ID]:id' \
  '-c+[clear image for server ID]:id' \
  '-e+[kill server with the given ID]:id' \
  '-d[enable debug messages]' \
  '*:args:_files'
