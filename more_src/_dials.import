#compdef dials.import
# Documentation: https://dials.github.io/documentation/programs/dials_import.html
# DIALS: import images into experiment models

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--show-config[show full list of parameters]' \
  '--expert-level=[set expert level for parameter display]:level' \
  '--phil=[read parameters from phil file]:phil file:_files' \
  'output.experiments=[output experiment filename]:file:_files' \
  'output.log=[log filename]:file:_files' \
  'output.compact=[use compact JSON representation]:bool:(True False)' \
  'input.template=[image sequence template with # for numbers]:template' \
  'input.directory=[directory containing images]:dir:_files -/' \
  'input.reference_geometry=[reference geometry from .expt file]:file:_files' \
  'input.split=[scan splitting by frames per block or ranges]:split' \
  'input.ignore_unhandled=[ignore unhandled input files]:bool:(True False)' \
  'input.allow_multiple_sequences=[allow multiple sequences]:bool:(True False)' \
  'geometry.beam.wavelength=[override beam wavelength]:wavelength' \
  'geometry.beam.probe=[beam probe type]:probe:(x-ray electron neutron)' \
  'geometry.detector.mosflm_beam_centre=[beam centre Mosflm convention]:centre' \
  'geometry.detector.distance=[detector distance]:distance' \
  'geometry.goniometer.axis=[goniometer rotation axis]:axis' \
  'geometry.scan.oscillation=[image oscillation override]:oscillation' \
  'geometry.scan.image_range=[image range override]:range' \
  'lookup.mask=[apply mask to imported data]:file:_files' \
  'lookup.gain=[apply gain correction]:file:_files' \
  'lookup.pedestal=[apply pedestal correction]:file:_files' \
  'lookup.dx=[geometry offset correction x]:file:_files' \
  'lookup.dy=[geometry offset correction y]:file:_files' \
  '*:image file:_files' && ret=0

return ret
