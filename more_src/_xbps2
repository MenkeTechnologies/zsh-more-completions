#compdef xbps2 xbps-install2 xbps-remove2 xbps-query2 xbps-pkgdb2 xbps-reconfigure2 xbps-fbulk2
# _xbps2 — Void Linux Juan Romero Pardines xbps2 CLI command-line frontend wrapping the XBPS X Binary Package System the package manager for Void Linux open-source written in C originally Juan Romero Pardines core package manager and tool ecosystem for Void Linux uses libxbps xbps-install xbps-remove xbps-query xbps-checkvers xbps-create xbps-dgraph xbps-digest xbps-fbulk xbps-pkgdb xbps-reconfigure xbps-rindex xbps-uchroot xbps-uhelper xbps-uunshare xbps-alternatives sync update install remove query repo orphans automatic search list info config (Void Linux Juan Romero Pardines team Đoàn Trần Công Danh, C); custom argparse
# upstream: https://docs.voidlinux.org/xbps/

_xbps2() {
    local -a sub=(
        'install:install packages'
        'remove:remove packages'
        'query:query packages'
        'pkgdb:check/fix DB'
        'reconfigure:reconfigure packages'
        'alternatives:manage alternatives'
        'checkvers:check versions'
        'create:create binary package'
        'dgraph:show dep graph'
        'digest:compute file digest'
        'fbulk:bulk build'
        'rindex:index a repo'
        'uchroot:user-chroot'
        'uhelper:misc helper'
        'uunshare:user-unshare'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-C+[config file]:file:_files -g "xbps.d/*.conf *.conf"' \
        '--config=+[file]:file:_files -g "*.conf"' \
        '-c+[cache dir]:dir:_files -/' \
        '--cachedir=+[dir]:dir:_files -/' \
        '-r+[root dir]:dir:_files -/' \
        '--rootdir=+[dir]:dir:_files -/' \
        '--repository=+[uri]:str:' \
        '*--repository=+[uri]:str:' \
        '-R[repo mode]' \
        '-i[ignore conf repos]' \
        '--ignore-conf-repos[ignore conf repos]' \
        '-y[no confirm]' \
        '--yes[no confirm]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '-D[show download]' \
        '-A[automatic]' \
        '--automatic[automatic]' \
        '-f[force]' \
        '--force[force]' \
        '-F[force reinstall]' \
        '-S[sync]' \
        '--sync[sync repos]' \
        '-u[update]' \
        '--update[update]' \
        '-x[full deptree]' \
        '-O[clean orphans]' \
        '--orphan[orphans]' \
        '-l[list pkgs]' \
        '--list-pkgs[list pkgs]' \
        '-L[list repos]' \
        '--list-repos[list repos]' \
        '-m[manual mode]' \
        '--manual[manual mode]' \
        '-s+[search regex]:str:' \
        '--search=+[regex]:str:' \
        '-o+[query property]:str:' \
        '--property=+[prop]:str:' \
        '-p+[property]:str:' \
        '*-p+[prop]:str:' \
        '-R[use repos]' \
        '-i[install]' \
        '-X+[regex]:str:' \
        '--regex[use regex]' \
        '-M[manual install]' \
        '--mode=+[m]:m:(install upgrade remove)' \
        '--repos=+[uri]:str:' \
        '--include=+[pattern]:str:' \
        '--exclude=+[pattern]:str:' \
        '--reproducible[reproducible]' \
        '--purge[purge orphans]' \
        '--keep-conf[keep conf]' \
        '--privileged-trigger-only[privileged trigger only]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xbps subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|query|reconfigure|alternatives|create|digest|checkvers) _arguments '*:package:' ;;
                pkgdb) _arguments '*:package:' ;;
            esac
            ;;
    esac
}

_xbps2 "$@"
