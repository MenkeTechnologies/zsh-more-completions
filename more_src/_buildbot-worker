#compdef buildbot-worker
# Documentation: https://docs.buildbot.net/latest/manual/cmdline.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create-worker:populate a directory as a worker base'
  'start:start a worker'
  'stop:stop a worker'
  'restart:restart a worker'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'buildbot-worker command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create-worker)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '(-f --force)'{-f,--force}'[overwrite existing files]' \
          '(-r --relocatable)'{-r,--relocatable}'[generate paths relative to base]' \
          '(-k --keepalive)'{-k+,--keepalive=}'[keepalive interval (s)]:n:' \
          '(-u --umask)'{-u+,--umask=}'[file umask]:umask:' \
          '*::basedir_master_workername_pw:_files -/' && ret=0 ;;
      (start|restart)
        _arguments \
          '--nodaemon[do not daemonize]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '*::basedir:_files -/' && ret=0 ;;
      (stop)
        _arguments \
          '*::basedir:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
