#compdef sieve-filter
# _sieve-filter — filter an existing IMAP mailbox via a Sieve script (dovecot/pigeonhole)
# upstream: https://github.com/dovecot/pigeonhole
# Flags from src/sieve-tools/sieve-filter.c (getopt).

_sieve-filter() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-c+[Dovecot config file]:file:_files'
        '-C[force Sieve script compilation]'
        '-D[enable Sieve debug output]'
        '-e[actually execute filter actions]'
        '-m+[default mailbox for kept messages]:mailbox:'
        '*-P+[load this Sieve plugin]:plugin:'
        '-q+[output mailbox for discarded messages]:mailbox:'
        '-Q+[shell command to receive discarded messages]:cmd:'
        '-s+[supplementary Sieve script]:file:_files -g "*.sieve"'
        '-u+[run as this user]:user:_users'
        '-v[verbose output]'
        '-W[write resulting filtered messages back to source mailbox]'
        '-x+[extra Sieve extensions to enable]:extensions:'
        '1:script file:_files -g "*.sieve"'
        '2:source mailbox:'
        '3:discard action:(keep move delete expunge)'
    )
    _arguments -s -S $args
}

_sieve-filter "$@"
