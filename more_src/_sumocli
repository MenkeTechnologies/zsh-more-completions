#compdef sumocli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:configure credentials interactively'
  'apps:install or list Sumo apps'
  'collectors:manage collectors'
  'sources:manage data sources'
  'content:manage saved content (folders, dashboards, searches)'
  'users:manage users'
  'roles:manage roles'
  'connections:manage connections'
  'fields:manage extracted fields'
  'field-extraction-rules:manage field extraction rules'
  'partitions:manage partitions'
  'scheduled-views:manage scheduled views'
  'transformation-rules:manage transformation rules'
  'tokens:manage API tokens'
  'monitors:manage monitors'
  'access-keys:manage access keys'
  'archive:archive ingestion jobs'
  'service-allowlist:service allowlist settings'
  'alerts:manage alerts'
  'lookup-tables:manage lookup tables'
  'metrics-search:run metrics searches'
  'search-job:run a search job'
  'help:show help'
  'completion:generate shell completion'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cred-file=[credentials file]:file:_files' \
  '--profile=[credential profile]:profile:' \
  '--verbose[verbose output]' \
  '--output=[output format]:format:(json yaml table)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

local -a crud_subs=(
  'list:list resources'
  'get:get a single resource'
  'create:create a resource'
  'update:update a resource'
  'delete:delete a resource'
)

case $state in
  (cmd) _describe -t cmds 'sumocli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (collectors|sources|users|roles|connections|fields|field-extraction-rules|partitions|scheduled-views|transformation-rules|tokens|monitors|access-keys|alerts|lookup-tables|apps)
        _describe -t actions 'action' crud_subs && ret=0 ;;
      (content)
        _arguments '*::sub:(list get import export move copy delete folders permissions)' && ret=0 ;;
      (search-job)
        _arguments \
          '(-q --query)'{-q+,--query=}'[search query]:query:' \
          '(-f --from)'{-f+,--from=}'[start time]:time:' \
          '(-t --to)'{-t+,--to=}'[end time]:time:' \
          '--time-zone=[time zone]:tz:' && ret=0 ;;
      (login)
        _arguments \
          '--access-id=[access id]:id:' \
          '--access-key=[access key]:key:' \
          '--endpoint=[Sumo Logic endpoint]:url:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
