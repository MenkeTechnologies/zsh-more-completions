#compdef cups-config
# Documentation: cups-config --help (CUPS 26)
# Source: print the build flags / library paths needed to link against CUPS.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show CUPS version]' \
    '--api-version[show API version]' \
    '--build[show build identifier]' \
    '--cflags[show CFLAGS]' \
    '--datadir[show data directory]' \
    '--ldflags[show LDFLAGS]' \
    '--libs[show libraries needed]' \
    '--image[include image library (with --libs)]' \
    '--static[use static libraries (with --libs)]' \
    '--serverbin[show server-binary directory]' \
    '--serverroot[show server config root]' \
    && ret=0

return ret
