#compdef badread
# Documentation: https://man.archlinux.org/search?q=badread
# Reference accessed: 2026-05-16

# Badread — rrwick/Badread badread/__main__.py — subcommands: simulate, error_model, qscore_model, plot.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'simulate:generate simulated long reads'
  'error_model:build error model from alignments'
  'qscore_model:build qscore model from alignments'
  'plot:plot identities along reference'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'badread command' subcmds && ret=0
    ;;
  rest)
    case $line[1] in
      simulate)
        _arguments -s -S \
          '--reference=[FASTA]:file:_files' \
          '--quantity=[count or depth like 25x]:qty' \
          '--length=[mean,stdev fragment len]:spec' \
          '--identity=[identity distribution]:spec' \
          '--error_model=[built-in or file]:model' \
          '--qscore_model=[built-in or file]:model' \
          '--seed=[RNG seed]:int' \
          '--start_adapter=[rate,amount]:spec' \
          '--end_adapter=[rate,amount]:spec' \
          '--start_adapter_seq=[DNA or len]:seq' \
          '--end_adapter_seq=[DNA or len]:seq' \
          '--junk_reads=[percent junk]:float' \
          '--random_reads=[percent random]:float' \
          '--chimeras=[percent chimeras]:float' \
          '--glitches=[rate,size,skip]:spec' \
          '--small_plasmid_bias[lose tiny plasmids when frag long]' && ret=0
        ;;
      error_model)
        _arguments -s -S \
          '--reference=[FASTA]:file:_files' \
          '--reads=[FASTQ]:file:_files' \
          '--alignment=[PAF]:file:_files' \
          '--k_size=[k-mer size]:int' \
          '--max_alignments=[limit alignments]:int' \
          '--max_alt=[alt k-mers cap]:int' && ret=0
        ;;
      qscore_model)
        _arguments -s -S \
          '--reference=[FASTA]:file:_files' \
          '--reads=[FASTQ]:file:_files' \
          '--alignment=[PAF]:file:_files' \
          '--k_size=[k-mer size]:int' \
          '--max_alignments=[limit alignments]:int' \
          '--max_del=[collapse long dels]:int' \
          '--min_occur=[min CIGAR count]:int' \
          '--max_output=[max model lines]:int' && ret=0
        ;;
      plot)
        _arguments -s -S \
          '--reference=[FASTA]:file:_files' \
          '--reads=[FASTQ]:file:_files' \
          '--alignment=[PAF]:file:_files' \
          '--window=[bp window]:int' \
          '--qual[include qscores in plot]' \
          '--no_plot[no GUI plots]' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
