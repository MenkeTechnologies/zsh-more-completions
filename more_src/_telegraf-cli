#compdef telegraf-cli telegrafd
# _telegraf-cli — InfluxData Telegraf metrics agent CLI alias (InfluxData, Go); spf13/cobra
# upstream: https://github.com/influxdata/telegraf

_telegraf-cli() {
    local -a sub=(
        'help:show help'
        'config:print config'
        'plugins:list plugins'
        'secrets:manage secrets'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.(conf|toml)"' \
        '--config-directory=+[config directory]:dir:_files -/' \
        '--config-url-watch-interval=+[config url watch interval]:dur:' \
        '--config-url-retry-attempts=+[config url retry attempts]:n:' \
        '--watch-config=+[watch config strategy]:s:(poll inotify)' \
        '--debug[debug log level]' \
        '--quiet[quiet log level]' \
        '--test[test inputs once and exit]' \
        '--test-wait=+[test wait]:dur:' \
        '--once[run once and exit]' \
        '--input-filter=+[input filter]:list:' \
        '--input-list[list inputs]' \
        '--output-filter=+[output filter]:list:' \
        '--output-list[list outputs]' \
        '--aggregator-filter=+[aggregator filter]:list:' \
        '--processor-filter=+[processor filter]:list:' \
        '--secretstore-filter=+[secretstore filter]:list:' \
        '--pidfile=+[pid file]:file:_files' \
        '--pprof-addr=+[pprof addr]:addr:' \
        '--section-filter=+[section filter]:list:' \
        '--sample-config[print full sample config]' \
        '--password[prompt for password]' \
        '--user=+[user]:str:_users' \
        '--usage=+[print usage for]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'telegraf subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments \
                    '--input-filter=+[input filter]:list:' \
                    '--output-filter=+[output filter]:list:' \
                    '--aggregator-filter=+[aggregator filter]:list:' \
                    '--processor-filter=+[processor filter]:list:' \
                    '--section-filter=+[section filter]:list:' ;;
                plugins) _arguments \
                    '1:cmd:(list inputs outputs aggregators processors)' ;;
                secrets) _arguments \
                    '1:cmd:(list get set delete)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_telegraf-cli "$@"
