#compdef abuild newapkbuild abuild-keygen abuild-sign abuild-fetch abuild-rmtemp

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'all:run all default commands'
  'build:compile and install package'
  'check:run tests'
  'checksum:generate source file checksums'
  'clean:remove temp build and install dirs'
  'cleancache:remove downloaded sources'
  'cleanoldpkg:remove old binary packages'
  'cleanpkg:remove built binary and source pkgs'
  'deps:install make/run dependencies'
  'fetch:fetch sources'
  'help:show help'
  'index:regenerate APKINDEX'
  'listpkg:list target packages'
  'package:install project into pkgdir'
  'prepare:apply patches'
  'rootbld:build package in clean chroot'
  'rootpkg:run package and create apks as fakeroot'
  'snapshot:create giturl snapshot and upload'
  'sourcecheck:check if remote source exists upstream'
  'srcpkg:make a source package'
  'undeps:uninstall installed makedepends'
  'unpack:unpack sources'
  'up2date:check if package is up to date'
  'verify:check signatures'
  'validate:basic APKBUILD validation'
)

_arguments -C \
  '-h[show help]' \
  '-A[print CARCH and exit]' \
  '-c[enable colored output]' \
  '-d[disable dependency checking]' \
  '-f[force specified command]' \
  '-F[force run as root]' \
  '-k[keep built packages]' \
  '-K[keep buildtime temp dirs]' \
  '-m[disable colors]' \
  '-P+[REPODEST]:dir:_files -/' \
  '-q[quiet]' \
  '-r[install missing dependencies]' \
  '-s+[source package dest]:dir:_files -/' \
  '-v[verbose]' \
  '*: :->cmd' && ret=0

case $state in
  (cmd) _describe -t cmds 'abuild command' commands && ret=0 ;;
esac

return ret
