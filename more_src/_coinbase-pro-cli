#compdef coinbase-pro-cli coinbase-pro coinbase-advanced-trade-cli coinbase-advanced
# _coinbase-pro-cli — Coinbase coinbase-pro-cli coinbase-advanced-trade-cli CLI command-line frontend wrapping the Coinbase Pro Coinbase Advanced Trade cryptocurrency exchange REST WebSocket API managing accounts orders fills products candles trades ticker book stats currencies fees address-book payment-methods transfers limits (Coinbase team, Go); cobra
# upstream: https://www.coinbase.com/advanced-trade-api

_coinbase-pro-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'order:order operations'
        'fill:fill operations'
        'product:product operations'
        'candle:candle data'
        'trade:trade operations'
        'ticker:ticker operations'
        'book:order book'
        'stats:stats operations'
        'currency:currency operations'
        'fee:fee operations'
        'address-book:address book'
        'payment-method:payment method operations'
        'transfer:transfer operations'
        'limit:limit operations'
        'portfolio:portfolio operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--passphrase=+[phrase]:str:' \
        '--api-url=+[url]:str:' \
        '--sandbox[use sandbox]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coinbase-pro-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list place cancel cancel-all status)' \
                    '--product-id=+[id]:str:' \
                    '--side=+[s]:s:(buy sell)' \
                    '--type=+[t]:t:(limit market stop)' \
                    '--size=+[N]:str:' \
                    '--price=+[N]:str:' \
                    '--time-in-force=+[t]:t:(GTC GTT IOC FOK)' \
                    '*:order id:' ;;
                account|fill|trade|currency|fee|address-book|payment-method|transfer|limit|portfolio) _arguments '1:op:(list get create update delete)' '*:id:' ;;
                product|candle|ticker|book|stats) _arguments \
                    '--product-id=+[id]:str:' \
                    '--granularity=+[g]:g:(60 300 900 3600 21600 86400)' \
                    '--limit=+[N]:n:' ;;
            esac
            ;;
    esac
}

_coinbase-pro-cli "$@"
