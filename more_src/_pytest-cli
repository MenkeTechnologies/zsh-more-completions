#compdef pytest py.test
# Documentation: https://man.archlinux.org/search?q=pytest
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version -V)'{-V,--version}'[show version]' \
  '(-x --exitfirst)'{-x,--exitfirst}'[stop on first failure]' \
  '--maxfail=[stop after N failures]:n:' \
  '--strict-config[strict config]' \
  '--strict-markers[strict markers]' \
  '-c+[config file]:file:_files -g "*.cfg *.ini *.toml"' \
  '--config-file=[config file]:file:_files' \
  '--continue-on-collection-errors[continue on collection errors]' \
  '--rootdir=[root dir]:dir:_files -/' \
  '--co[only collect, do not run]' \
  '--collect-only[only collect]' \
  '--pyargs[args are import paths]' \
  '--ignore=[ignore path]:p:_files' \
  '--ignore-glob=[ignore glob]:p:' \
  '--deselect=[deselect path]:p:' \
  '--confcutdir=[conftest cut-off]:dir:_files -/' \
  '--noconftest[no conftest.py]' \
  '--keep-duplicates[keep duplicate tests]' \
  '--collect-in-virtualenv[collect in venv]' \
  '--import-mode=[import mode]:m:(prepend append importlib)' \
  '--doctest-modules[run doctests in modules]' \
  '--doctest-glob=[doctest glob]:p:' \
  '--doctest-ignore-import-errors[ignore doctest import errors]' \
  '--doctest-continue-on-failure[continue on doctest failure]' \
  '--doctest-report=[doctest report]:r:(none cdiff ndiff udiff only_first_failure)' \
  '-k+[expression matching test names]:expr:' \
  '-m+[only run tests matching marker expr]:expr:' \
  '--markers[show available markers]' \
  '-x[exit on first failure]' \
  '-l[show locals on failure]' \
  '--showlocals[show locals on failure]' \
  '--no-showlocals[no show locals]' \
  '--tb=[traceback style]:t:(auto long short line native no)' \
  '--show-capture=[capture style]:c:(no stdout stderr log all)' \
  '--full-trace[full traceback]' \
  '-r+[short test summary]:c:(f s x X p P a A E)' \
  '--rA[summary all]' \
  '--rfE[summary failures+errors]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-vv[very verbose]' \
  '--no-header[no header]' \
  '--no-summary[no summary]' \
  '--color=[color]:c:(auto yes no)' \
  '--code-highlight=[highlight]:c:(yes no)' \
  '--lf[run last failed]' \
  '--last-failed[run last failed]' \
  '--ff[failed first]' \
  '--failed-first[failed first]' \
  '--nf[new first]' \
  '--new-first[new first]' \
  '--cache-show=[show cache]:p:' \
  '--cache-clear[clear cache]' \
  '--lfnf=[lf nf mode]:m:(all none)' \
  '-p+[plugin]:p:' \
  '--no-fold-skipped[no fold skipped]' \
  '--trace-config[trace config]' \
  '--debug=[debug log]:file:_files' \
  '--override-ini=[k=v override]:v:' \
  '-o+[k=v override]:v:' \
  '--assert=[assert mode]:m:(plain rewrite)' \
  '--setup-show[show setup]' \
  '--setup-only[only setup]' \
  '--setup-plan[only setup plan]' \
  '--basetemp=[temp dir]:dir:_files -/' \
  '--instafail[show failures inline]' \
  '--co-only[collect only]' \
  '-s[no capture]' \
  '--capture=[capture]:c:(no fd sys tee-sys tee-fd)' \
  '--no-cov[disable coverage]' \
  '--cov=[coverage path]:p:_files -/' \
  '--cov-report=[cov report]:r:(term term-missing annotate html xml json)' \
  '--cov-fail-under=[cov threshold %]:n:' \
  '--cov-config=[cov config]:file:_files' \
  '--no-cov-on-fail[no cov on fail]' \
  '-n+[xdist workers]:n:' \
  '--numprocesses=[xdist workers]:n:' \
  '--dist=[xdist]:d:(load loadfile loadscope each no)' \
  '--tx=[xdist transports]:t:' \
  '*: :_files -g "*.py"' && ret=0

return ret
