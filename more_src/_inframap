#compdef inframap

# Inframap CLI completion

_inframap_subcommands() {
  local -a subcmds=(
    'generate:Generate a graph from infrastructure'
    'prune:Prune a Terraform state'
  )
  _describe -t commands 'inframap subcommand' subcmds
}

_inframap() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_inframap_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        generate|prune)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--tfstate=[path to Terraform state file]:tfstate file:_files' \
            '--hcl=[path to HCL directory]:hcl path:_directories' \
            '--gcp-project=[GCP project ID]:project' \
            '--aws-profile=[AWS profile name]:profile' \
            '--raw-edges[show raw edges]' \
            '--clean[clean graph output]' \
            '--connections[show connections]' \
            '--external-nodes[show external nodes]' \
            '--printer=[output format]:printer:(dot cytoscape)' \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_inframap "$@"
