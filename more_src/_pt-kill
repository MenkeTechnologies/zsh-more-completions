#compdef pt-kill

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--busy-time=[match queries running longer than]:seconds:' \
  '--charset=[default character set]:charset:' \
  '--config=[config file]:config file:_files' \
  '--daemonize[run as daemon]' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--group-by=[group queries by]:attribute:(fingerprint user host db state command info)' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--idle-time=[match idle connections longer than]:seconds:' \
  '--ignore-command=[ignore commands]:commands:' \
  '--ignore-db=[ignore databases]:databases:' \
  '--ignore-host=[ignore hosts]:hosts:' \
  '--ignore-info=[ignore query patterns]:pattern:' \
  '--ignore-state=[ignore states]:states:' \
  '--ignore-user=[ignore users]:users:' \
  '--interval=[check interval]:seconds:' \
  '--kill[kill matching queries]' \
  '--kill-busy-commands=[commands to consider busy]:commands:' \
  '--kill-query[kill query but not connection]' \
  '--log=[log file]:log file:_files' \
  '--match-command=[match commands]:commands:' \
  '--match-db=[match databases]:databases:' \
  '--match-host=[match hosts]:hosts:' \
  '--match-info=[match query patterns]:pattern:' \
  '--match-state=[match states]:states:' \
  '--match-user=[match users]:users:' \
  '--password=[MySQL password]:password:' \
  '--pid=[PID file]:pid file:_files' \
  '--port=[MySQL port]:port:' \
  '--print[print matching queries]' \
  '--query-count=[min number of matching queries]:count:' \
  '--rds[Amazon RDS mode]' \
  '--run-time=[max run time]:duration:' \
  '--sentinel=[sentinel file]:file:_files' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--user=[MySQL user]:username:' \
  '--victims=[how to select victims]:method:(oldest all all-but-oldest)' \
  '--wait-after-kill=[wait after killing]:seconds:' \
  '--wait-before-kill=[wait before killing]:seconds:' && ret=0

return ret
