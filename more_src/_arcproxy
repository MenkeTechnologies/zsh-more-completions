#compdef arcproxy
# Documentation: https://www.nordugrid.org/arc/arc7/users/client_tools.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# arcproxy: ARC client proxy management
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-d[debug level]:level:(FATAL ERROR WARNING INFO VERBOSE DEBUG)' \
  '--debug=[debug level]:level:(FATAL ERROR WARNING INFO VERBOSE DEBUG)' \
  '-P[proxy file]:file:_files' \
  '--proxy=[proxy file]:file:_files' \
  '-C[user cert]:file:_files' \
  '--cert=[user cert]:file:_files' \
  '-K[user key]:file:_files' \
  '--key=[user key]:file:_files' \
  '-T[CA dir]:dir:_files -/' \
  '--cadir=[CA dir]:dir:_files -/' \
  '-c[constraint]:expr:' \
  '--constraint=[constraint]:expr:' \
  '-S[VOMS group]:vo:' \
  '--voms=[VOMS group]:vo:' \
  '-V[validity period]:duration:' \
  '--validity=[validity period]:duration:' \
  '-I[show info]' \
  '--info[show info]' \
  '-r[remove proxy]' \
  '--remove[remove proxy]' \
  '-N[skip password]' \
  '--passwordsource=[password source]:src:' \
  '*::arcproxy args:_files' && ret=0
return ret
