#compdef litefs
# _litefs — LiteFS distributed SQLite filesystem (superfly/litefs)
# upstream: https://github.com/superfly/litefs

_litefs() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)-help[show help]' \
        '1: :_litefs_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                mount)
                    _arguments \
                        '-config=[config file]:file:_files -g "*.yml(|.yaml)"' \
                        '-fuse-debug[enable FUSE debug logging]' \
                        '-help[show help]' && ret=0 ;;
                export)
                    _arguments \
                        '-name=[database name]:name:' \
                        '-help[show help]' \
                        '1:output file:_files' && ret=0 ;;
                import)
                    _arguments \
                        '-name=[database name]:name:' \
                        '-help[show help]' \
                        '1:input file:_files' && ret=0 ;;
                version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_litefs_commands] )) ||
_litefs_commands() {
    local -a commands
    commands=(
        'mount:mount the LiteFS FUSE filesystem'
        'export:export a database to a file'
        'import:import a database from a file'
        'version:show version'
    )
    _describe -t commands 'litefs command' commands
}

_litefs "$@"
