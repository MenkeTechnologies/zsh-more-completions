#compdef litefs

# Zsh completion for litefs - LiteFS distributed SQLite

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'mount:Mount the FUSE file system'
      'export:Export a database'
      'import:Import a database'
    )
    _describe -t commands 'litefs command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      mount)
        _arguments -s -S \
          '-config=[config file path]:config file:_files' \
          '-fuse-debug[enable FUSE debug logging]' && ret=0
        ;;
      export)
        _arguments -s -S \
          '-config=[config file path]:config file:_files' \
          '-name=[database name]:name' \
          '(-o)-o+[output file path]:output file:_files' && ret=0
        ;;
      import)
        _arguments -s -S \
          '-config=[config file path]:config file:_files' \
          '-name=[database name]:name' \
          '(-i)-i+[input file path]:input file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
