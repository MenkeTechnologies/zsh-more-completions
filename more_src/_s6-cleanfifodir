#compdef s6-cleanfifodir
# _s6-cleanfifodir — s6 pipe-tools s6-cleanfifodir (sweep an ftrigw fifodir: delete client FIFOs whose process has exited; used to garbage-collect a long-running ftrigw subscriber set)
# upstream: https://github.com/skarnet/s6
# Source: src/pipe-tools/s6-cleanfifodir.c on tip; positional only.

_s6-cleanfifodir() {
    _arguments '1:fifodir:_files -/'
}

_s6-cleanfifodir "$@"
