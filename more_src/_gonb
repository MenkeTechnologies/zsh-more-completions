#compdef gonb

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--install[install kernel in Jupyter]' \
  '--kernel=[kernel directory]:directory:_directories' \
  '--force[force installation]' \
  '--loglevel=[log level]:level:(panic fatal error warn info debug trace)' \
  '--extra_args=[extra args for go build]:args' \
  '*:notebook:_files -g "*.ipynb(-.)"' && return 0
