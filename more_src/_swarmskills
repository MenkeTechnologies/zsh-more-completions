#compdef swarmskills
# Documentation: https://github.com/swarmclawai/swarmskills
# Reference accessed: 2026-05-22
# Verified: README.md CLI usage section.

# Zsh completion for swarmskills - skills/plugins across coding agent CLIs

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--tool[target CLI tool]:tool:' \
  '--from[source tool for sync]:tool:' \
  '--to[destination tools for sync]:tools:' \
  '--copy[copy files instead of symlinking]' \
  '--force[overwrite on sync]' \
  '--all[sync all skills]' \
  '--detected[only detected tools]' \
  '--skills[list skills mode]' \
  '--all-tools[cross-tool discovery]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'swarmskills command' \
      'list[list skills or plugins]' \
      'show[show skill content]' \
      'search[search skills plugins marketplaces]' \
      'sync[sync skill across tools]' \
      'enable[enable Claude Code plugin]' \
      'disable[disable Claude Code plugin]' \
      'install[install Claude Code plugin]' \
      'tools[manage supported tools]' \
      'marketplace[manage Claude marketplaces]' && ret=0
    ;;
  args)
    case $line[1] in
      tools)
        _values 'tools action' list detect add-custom remove-custom set-default get-default clear-default && ret=0
        case $line[2] in
          detect|remove-custom)
            _arguments '1:tool key:' && ret=0
            ;;
          add-custom)
            _arguments '1:tool key:' '2:skills path:directory:_directories' '--name[display name]:name:' && ret=0
            ;;
          set-default)
            _arguments '1:tool key:(all)' && ret=0
            ;;
        esac
        ;;
      marketplace)
        _values 'marketplace action' list add refresh remove && ret=0
        case $line[2] in
          add)
            _arguments '1:marketplace name:' '2:owner/repo:' && ret=0
            ;;
          refresh|remove)
            _arguments '1:marketplace name:' && ret=0
            ;;
        esac
        ;;
      sync|show|search|enable|disable|install)
        _arguments '1:skill or plugin:' && ret=0
        ;;
    esac
    ;;
esac

return ret
