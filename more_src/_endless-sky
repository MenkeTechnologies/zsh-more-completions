#compdef endless-sky
# Documentation: https://github.com/endless-sky/endless-sky/wiki/CommandLineOptions
# Reference accessed: 2026-05-16

# Endless Sky: open-source space trading and combat game
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-r[resources directory]:dir:_files -/' \
  '--resources=[resources directory]:dir:_files -/' \
  '-c[config directory]:dir:_files -/' \
  '--config=[config directory]:dir:_files -/' \
  '-d[debug mode]' \
  '--debug[debug mode]' \
  '-p[parse data and exit]' \
  '--parse[parse data and exit]' \
  '-t[take screenshot snapshot]' \
  '--talk[show conversation script]' \
  '--scenario=[load a scenario]:file:_files' \
  '*::endless-sky args:_files' && ret=0
return ret
