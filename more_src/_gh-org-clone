#compdef gh-org-clone gh-pr-repl gh-provision-envs gh-start gh-submodule-add
# Documentation: upstream READMEs at github.com/{crguezl/gh-org-clone,nobe4/gh-pr-repl,AyogoHealth/gh-provision-envs,balvig/gh-start,crguezl/gh-submodule-add}
# Reference accessed: 2026-05-30
# gh-extension family round 16. Continued cross-language harvest with
# emphasis on bulk-org operations.
# Hunt-note: gh-start is the Ruby Cookpad-derived workflow tool from
# balvig/gh-start, distinct from jasonappah/gh-start (Rust WIP) which
# was deferred in round 167. The Ruby variant has documented surface,
# so this completion targets it; if a user has the Rust WIP installed
# the surface would be a strict subset (single positional).

local curcontext="$curcontext" state line ret=1

case $service in

  gh-org-clone)
    # crguezl/gh-org-clone — batch-clone all repos in an organization.
    # Optional interactive fzf selection when no repos are specified.
    _arguments -s -S \
      '(-s --search)-s+[GitHub Search API query]:query:' \
      '(-s --search)--search=[GitHub Search API query]:query:' \
      '(-r --regexp)-r+[filter results via regex]:pattern:' \
      '(-r --regexp)--regexp=[filter results via regex]:pattern:' \
      '(-c --csr)-c+[comma-separated repository list]:repos:' \
      '(-c --csr)--csr=[comma-separated repository list]:repos:' \
      '(-f --file)-f+[load repo list from file]:file:_files' \
      '(-f --file)--file=[load repo list from file]:file:_files' \
      '(-k --fork)-k+[fork inclusion mode]:mode:(true only false)' \
      '(-k --fork)--fork=[fork inclusion mode]:mode:(true only false)' \
      '(-n --dryrun)-n[preview cloning without executing]' \
      '(-n --dryrun)--dryrun[preview cloning without executing]' \
      '(-o --org)-o+[organization name]:org:' \
      '(-o --org)--org=[organization name]:org:' \
      '--default[set org as default for future use]' \
      '(-D --depth)-D+[shallow clone depth]:N:' \
      '(-D --depth)--depth=[shallow clone depth]:N:' \
      '(-p --parallel)-p+[concurrent clone processes]:N:' \
      '(-p --parallel)--parallel=[concurrent clone processes]:N:' \
      && ret=0
    ;;

  gh-pr-repl)
    # nobe4/gh-pr-repl — interactive REPL for managing PRs.
    # Bare invocation = PR from current branch.
    # 1+ positionals: branch reference (OWNER/REPO/BRANCH) or PR URL.
    _arguments -s -S \
      '*:PR reference (OWNER/REPO/BRANCH or PR URL):' \
      && ret=0
    ;;

  gh-provision-envs)
    # AyogoHealth/gh-provision-envs — provision env vars + secrets from JSON.
    #   gh provision-envs -c config.json -R owner/repo
    _arguments -s -S \
      '(-c)-c+[JSON config file (required)]:file:_files -g "*.json"' \
      '(-R)-R+[target repository (owner/repo)]:repo:' \
      && ret=0
    ;;

  gh-start)
    # balvig/gh-start — start a new work item (branch + draft PR).
    #   gh start "description"  — generate branch + open draft PR
    #   gh start [issue-url]    — use issue to populate branch + PR
    _arguments -s -S \
      '1:description or GitHub issue URL:' \
      && ret=0
    ;;

  gh-submodule-add)
    # crguezl/gh-submodule-add — batch-add repos as submodules.
    _arguments -s -S \
      '(-C --clone)-C[clone only, skip submodule setup]' \
      '(-C --clone)--clone[clone only, skip submodule setup]' \
      '(-o --org)-o+[organization or user]:org:' \
      '(-o --org)--org=[organization or user]:org:' \
      '(-s --search)-s+[GitHub Search API query]:query:' \
      '(-s --search)--search=[GitHub Search API query]:query:' \
      '(-r --regexp)-r+[filter results via regex]:pattern:' \
      '(-r --regexp)--regexp=[filter results via regex]:pattern:' \
      '(-k --fork)-k+[fork inclusion]:mode:' \
      '(-k --fork)--fork=[fork inclusion]:mode:' \
      '(-p --parallel)-p+[concurrent processes (default 2)]:N:' \
      '(-p --parallel)--parallel=[concurrent processes (default 2)]:N:' \
      '(-D --depth)-D+[shallow clone depth]:N:' \
      '(-D --depth)--depth=[shallow clone depth]:N:' \
      && ret=0
    ;;

esac

return ret
