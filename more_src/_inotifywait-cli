#compdef inotifywait-cli
# _inotifywait-cli — Rohan McGovern inotify-tools inotifywait wait for filesystem events CLI alias (inotify-tools team, C); custom argparse
# upstream: https://github.com/inotify-tools/inotify-tools

_inotifywait-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-@+[exclude file]:file:_files' \
        '--exclude=+[regex]:str:' \
        '--excludei=+[regex case-insensitive]:str:' \
        '--include=+[regex]:str:' \
        '--includei=+[regex case-insensitive]:str:' \
        '-m[monitor continuously]' \
        '--monitor[monitor continuously]' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '--fromfile=+[file]:file:_files' \
        '-d[daemon]' \
        '--daemon[daemon]' \
        '-o+[output file]:file:_files' \
        '--outfile=+[output file]:file:_files' \
        '-s[syslog]' \
        '--syslog[syslog]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-qq[very quiet]' \
        '-P[no follow symlinks]' \
        '--no-dereference[no follow symlinks]' \
        '--no-newline[no newline]' \
        '--format=+[format]:str:' \
        '--timefmt=+[strftime format]:str:' \
        '-c[csv output]' \
        '--csv[csv output]' \
        '-e+[events csv]:str:' \
        '--event=+[events csv]:str:' \
        '-t+[timeout seconds]:n:' \
        '--timeout=+[timeout seconds]:n:' \
        '*:files:_files'
}

_inotifywait-cli "$@"
