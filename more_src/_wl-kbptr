#compdef wl-kbptr
# Documentation: https://github.com/moverest/wl-kbptr
# wl-kbptr: control the mouse pointer with the keyboard on Wayland

local ret=1

_arguments -s -S \
  '--help-config[print help for configuration parameters]' \
  '--version[show version and OpenCV support status]' \
  '--print-only[print the location instead of moving the pointer]' \
  '*-o[set a configuration option (key=value)]:option:_default' && ret=0

return ret
