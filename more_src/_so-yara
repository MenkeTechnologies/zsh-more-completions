#compdef so-yara
# _so-yara — Security Onion so-yara CLI for managing YARA rules across Security Onion sensor fleet enabling disabling adding deleting rules pushing custom rulesets to Strelka scanners and Zeek file analysers (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-yara() {
    local -a sub=(
        'list:list installed YARA rules'
        'add:add YARA rule'
        'remove:remove YARA rule'
        'enable:enable YARA rule'
        'disable:disable YARA rule'
        'search:search for rules'
        'push:push rules to sensors'
        'reload:reload rules'
        'test:test rules against file'
        'compile:compile rules'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-f[force]' \
        '--force[force]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'so-yara subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '--name=+[name]:str:' \
                    '--category=+[c]:c:(strelka zeek custom)' \
                    '*:rule file:_files -g "*.yar *.yara"' ;;
                remove|enable|disable) _arguments '*:rule name:' ;;
                search) _arguments \
                    '--pattern=+[regex]:str:' \
                    '--tag=+[tag]:str:' ;;
                test|compile) _arguments \
                    '--rule=+[file]:file:_files -g "*.yar *.yara"' \
                    '*:sample file:_files' ;;
            esac
            ;;
    esac
}

_so-yara "$@"
