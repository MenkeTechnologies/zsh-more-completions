#compdef pfscut
# Documentation: http://pfstools.sourceforge.net/man1/pfscut.1.html
# pfstools: cut a rectangle out of frames in a pfs stream

local ret=1

_arguments -s -S \
  '(-l --left)'{-l,--left}'=[columns to cut from the left edge]:columns' \
  '(-r --right)'{-r,--right}'=[columns to cut from the right edge]:columns' \
  '(-t --top)'{-t,--top}'=[rows to cut from the top edge]:rows' \
  '(-b --bottom)'{-b,--bottom}'=[rows to cut from the bottom edge]:rows' \
  '(-W --width)'{-W,--width}'=[width of output image]:new_width' \
  '(-H --height)'{-H,--height}'=[height of output image]:new_height' \
  '(-h --help)'{-h,--help}'[print list of command line options]' && ret=0

return ret
