#compdef MagneticField
# Documentation: https://geographiclib.sourceforge.io/C++/doc/MagneticField.1.html
# GeographicLib: compute the Earth's magnetic field

local ret=1

_arguments -s -S \
  '-n[use named magnetic field model instead of wmm2025]:name:' \
  '-d[read magnetic models from dir]:dir:_files -/' \
  '-N[limit model degree to Nmax]:Nmax:' \
  '-M[limit model order to Mmax]:Mmax:' \
  '-t[evaluate field at given time]:time:' \
  '-c[evaluate field on a circle of latitude (time lat h)]:time:' \
  '-r[toggle reporting of field rate of change]' \
  '-w[toggle longitude-first flag]' \
  '-T[signal error if time exceeds model range by tguard years]:tguard:' \
  '-H[signal error if height exceeds model range by hguard meters]:hguard:' \
  '-p[set output precision]:prec:' \
  '-v[print magnetic model information on stderr]' \
  '--comment-delimiter[set comment delimiter]:delim:' \
  '--version[print version and exit]' \
  '(-h --help)-h[print usage and exit]' \
  '(-h --help)--help[print full documentation and exit]' \
  '--input-file[read input from file]:infile:_files' \
  '--input-string[read input from string]:string:' \
  '--line-separator[set line separator character]:linesep:' \
  '--output-file[write output to file]:outfile:_files' && ret=0

return ret
