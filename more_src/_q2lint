#compdef q2lint
# Documentation: https://github.com/qiime2/q2lint
# Linter for official QIIME 2 software; validates header text and copyrights

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--disable-install-requires-check[skip install_requires validation in setup.py]' \
  '--update-copyright-year[update copyright year statements in project files]' && ret=0

return ret
