#compdef IsobaricAnalyzer
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: extract and quantify isobaric reporter ions (iTRAQ/TMT)

local ret=1

_arguments -s -S \
  '-in[input raw/picked data file (mzML)]:input file:_files' \
  '-out[output consensusXML file]:output file:_files' \
  '-type[isobaric quantitation method]:type:(itraq4plex itraq8plex tmt6plex tmt10plex tmt11plex tmt16plex tmt18plex tmt32plex tmt35plex)' \
  '-extraction:select_activation[filter MSn scans by activation method]:method:' \
  '-extraction:reporter_mass_shift[allowed mass deviation in Th]:value:' \
  '-extraction:min_precursor_intensity[minimum precursor intensity]:value:' \
  '-extraction:min_reporter_intensity[minimum reporter ion intensity]:value:' \
  '-quantification:isotope_correction[enable isotope correction]:bool:' \
  '-quantification:normalization[enable channel normalization]:bool:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
