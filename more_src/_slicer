#compdef slicer
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/fslwiki/Miscvis
# FSL: take 3D image and produce 2D pictures of slices

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-L[label slices with slice number]' \
  '-l[use a different lut/colour map]:lut:_files' \
  '-s[scaling for size of image]:scale:' \
  '-i[specify intensity min and max for display]:min: :max:' \
  '-e[use threshold for edges]:thresh:' \
  '-t[produce semi-transparent (dithered) edges]' \
  '-n[use nearest-neighbour interpolation]' \
  '-u[do not put left-right labels in output]' \
  '-x[output sagittal slice]:slice: :output:_files' \
  '-y[output coronal slice]:slice: :output:_files' \
  '-z[output axial slice]:slice: :output:_files' \
  '-a[output mid-sagittal, -coronal and -axial in one]:output:_files' \
  '-A[output all axial slices into one picture]:width: :output:_files' \
  '-S[output every Nth axial slice]:every: :width: :output:_files' \
  '*:image:_files' && ret=0

return ret
