#compdef sonar-scanner

# Zsh completion for SonarQube Scanner

_arguments -s -S \
  '-D+[define property]:property=value:' \
  '-Dsonar.projectKey=[project key]:key:' \
  '-Dsonar.projectName=[project name]:name:' \
  '-Dsonar.projectVersion=[project version]:version:' \
  '-Dsonar.sources=[source directories]:directories:_files -/' \
  '-Dsonar.tests=[test directories]:directories:_files -/' \
  '-Dsonar.host.url=[SonarQube server URL]:url:' \
  '-Dsonar.token=[authentication token]:token:' \
  '-Dsonar.login=[login]:login:' \
  '-Dsonar.password=[password]:password:' \
  '-Dsonar.language=[language]:language:' \
  '-Dsonar.sourceEncoding=[source encoding]:encoding:(UTF-8 ISO-8859-1 ASCII)' \
  '-Dsonar.exclusions=[file exclusions]:patterns:' \
  '-Dsonar.inclusions=[file inclusions]:patterns:' \
  '-Dsonar.test.exclusions=[test exclusions]:patterns:' \
  '-Dsonar.coverage.exclusions=[coverage exclusions]:patterns:' \
  '-Dsonar.java.binaries=[Java binaries directory]:directory:_files -/' \
  '-Dsonar.java.libraries=[Java libraries]:directory:_files -/' \
  '-Dsonar.verbose=[verbose mode]:bool:(true false)' \
  '-Dsonar.scanner.metadataFilePath=[metadata file]:file:_files' \
  '-Dsonar.qualitygate.wait=[wait for quality gate]:bool:(true false)' \
  '-Dsonar.qualitygate.timeout=[quality gate timeout]:seconds:' \
  '-Dsonar.working.directory=[working directory]:directory:_files -/' \
  '-Dsonar.projectBaseDir=[project base directory]:directory:_files -/' \
  '-X[debug mode]' \
  '-e[produce execution error messages]' \
  '-h[show help]' \
  '-v[show version]'
