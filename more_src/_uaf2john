#compdef uaf2john
# Documentation: https://github.com/openwall/john/blob/bleeding-jumbo/src/uaf2john.c
# uaf2john (JtR) — convert OpenVMS SYSUAF to passwd. Usage (Unix): uaf2john uaf_file [output-file].

local ret=1

_arguments -s -S \
  '1:SYSUAF raw record file:_files' \
  '2:optional output passwd file (default stdout):_files' \
  && ret=0

return ret
