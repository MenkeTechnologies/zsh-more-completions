#compdef pdb_reatom
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Renumbers atom serials in the PDB file starting from a given value

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[starting atom serial number, e.g. -1]:start number' \
  '-h36[use hybrid36 numbering when serials exceed 99999]' \
  '*:PDB file:_files' && ret=0

return ret
