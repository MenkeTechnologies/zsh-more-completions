#compdef agg

# Zsh completion for agg (asciinema gif generator)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--cols[override terminal columns]:columns' \
  '--rows[override terminal rows]:rows' \
  '--font-family[specify font family]:font family' \
  '--font-size[specify font size]:font size' \
  '--font-dir[extra font directory]:directory:_files -/' \
  '--idle-time-limit[limit idle time to given seconds]:seconds' \
  '--line-height[line height]:height' \
  '--speed[playback speed]:speed' \
  '--fps-cap[set FPS cap]:fps' \
  '--last-frame-duration[duration of last frame]:seconds' \
  '--theme[color theme]:theme:(asciinema dracula monokai solarized-dark solarized-light)' \
  '--renderer[rendering method]:renderer:(fontdue resvg)' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:input cast file:_files -g "*.cast"' \
  '2:output gif file:_files -g "*.gif"' && ret=0

return ret
