#
#  System.Console.GetOpt distinctive features:
#    - SHIPS WITH `base` PACKAGE — zero external dependencies, available
#      in every GHC installation; no library to install
#    - RECORD-BASED option pattern — caller defines `data Options`
#      record, populates each field via action functions
#    - `OptDescr a` DATA TYPE — wraps short chars + long names + arg
#      descriptor + help description: `Option [Char] [String]
#      (ArgDescr a) String`
#    - `ArgDescr a` SUM TYPE — three variants: `NoArg a` (boolean flag),
#      `ReqArg (String -> a) String` (REQUIRED value with metavar),
#      `OptArg (Maybe String -> a) String` (OPTIONAL value with metavar)
#    - `Option` SHORT-CHAR LIST — first arg is `[Char]` allowing
#      MULTIPLE short forms — e.g. `Option "h?"` accepts both `-h`
#      AND `-?` for help
#    - `Option` LONG-NAME LIST — second arg is `[String]` allowing
#      MULTIPLE long forms per option
#    - ACTION FUNCTIONS — typical pattern is `[OptDescr (Options ->
#      IO Options)]` where each option's action TRANSFORMS the options
#      record (record-update style); `foldl (>>=) defaultOptions
#      actions` collects all transformations
#    - `getOpt :: ArgOrder a -> [OptDescr a] -> [String] -> ([a],
#      [String], [String])` — TRIPLE RESULT: (actions, non-options,
#      errors)
#    - `ArgOrder` SUM TYPE — `RequireOrder` (options must come first),
#      `Permute` (options can be interspersed with positionals), or
#      `ReturnInOrder` (positionals returned as actions in order)
#    - `usageInfo :: String -> [OptDescr a] -> String` — auto-generates
#      help text from `OptDescr` list with proper formatting
#    - PURE FUNCTIONAL — `getOpt` is a PURE function (no IO); caller
#      runs actions in IO monad to apply mutations
#    - NO automatic --help / --version — caller must define them as
#      `Option`s with `exitSuccess` actions
#    - NO automatic subcommands — caller hand-rolls subcommand dispatch
#      via positional arg switching
#    - NO type coercion — caller writes `read arg` or `reads arg` for
#      numeric parsing, with explicit error handling
#  Distinct from R270 Haskell optparse-applicative (functional applicative
#  combinator with `<$>`/`<*>`/`<|>` and auto-generated --help/--version,
#  rich types, error messages with suggestions), R313 Idris 2 System.GetOpts
#  (inspired by Haskell GetOpt but Idris language with dependent types),
#  R272 C POSIX getopt (C language, similar semantics), R325 OCaml stdlib
#  Arg (similar mutable ref-cell binding style but OCaml; uses spec
#  variant constructors like `Arg.Set`/`Arg.String`/`Arg.Int`), R367
#  AWK gawk getopt.awk (POSIX getopt in AWK).  System.Console.GetOpt's
#  approach: PURE FUNCTION `getOpt :: ArgOrder -> [OptDescr a] -> [String]
#  -> ([a], [String], [String])` + RECORD-BASED option transformations
#  + ACTION FUNCTIONS that update record fields + `ArgDescr a` SUM TYPE
#  (NoArg / ReqArg / OptArg) + MULTIPLE SHORT-CHAR FORMS PER OPTION
#  + `usageInfo` auto-help — corpus's **first documented zero-dependency-
#  base-package-GNU-getopt-style Haskell CLI library**.  Brings
#  cross-language CLI library taxonomy variant count to 112; Haskell
#  ecosystem now has 2 documented CLI libraries.
#
#  Surface (verbatim from arbtt-* main files, dispatched per binary):
#
#  arbtt-capture (capture-main.hs):
#    -h, -?, --help                Show help and exit
#    -V, --version                 Show version
#    -f, --logfile FILE            Use FILE instead of ~/.arbtt/capture.log
#    -r, --sample-rate RATE        Sample rate in seconds (default: 60)
#    -d, --dump                    Dump one sample to stdout instead of
#                                  writing to log
#
#  arbtt-stats (stats-main.hs):
#    -h, -?, --help                Show help and exit
#    -V, --version                 Show version
#    --logfile FILE                Use FILE instead of ~/.arbtt/capture.log
#    --categorizefile FILE         Use FILE instead of ~/.arbtt/categorize.cfg
#    -x, --exclude TAG             Ignore samples with this tag/category
#    -o, --only TAG                Only samples with this tag/category
#    --also-inactive               Include samples tagged "inactive"
#    -f, --filter COND             Only samples matching condition
#    -m, --min-percentage PERC     Hide tags below PERC% (default: 1)
#    --output-exclude TAG          Remove tags from output
#    --output-only TAG             Include only these tags in output
#    -i, --information             Show general statistics
#    -t, --total-time              Show total time for each tag
#    -c, --category CAT            Show statistics for CATEGORY
#    --each-category               Show statistics for every category
#    --intervals TAG               Show interval-based report
#    --dump-samples                Output every sample (debug)
#    --output-format FORMAT        Output: text | csv | tsv (default: text)
#    --for-each PERIOD             Repeater: day | month | year
#
#  arbtt-dump (dump-main.hs):
#    -h, -?, --help                Show help and exit
#    -V, --version                 Show version
#    -f, --logfile FILE            Use FILE instead of ~/.arbtt/capture.log
#    -t, --format FORMAT           Output format: Human | Show | JSON
#                                  (default: Human)
#    -i, --first NUMBER            Only dump first N samples
#    -l, --last NUMBER             Only dump last N samples
#
#  arbtt-import (import-main.hs):
#    -h, -?, --help                Show help and exit
#    -V, --version                 Show version
#    -f, --logfile FILE            Output log file path
#
#  arbtt-recover (recover-main.hs):
#    -h, -?, --help                Show help and exit
#    -V, --version                 Show version
#    -f, --logfile FILE            Log file to recover
# ============================================================================

_arbtt-capture() {
  local context state state_descr line
  typeset -A opt_args

  case $service in
    arbtt-capture)
      _arguments -s -S \
        '(-h -\? --help)'{-h,-\?,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --logfile)'{-f,--logfile}'=[log file path]:file:_files' \
        '(-r --sample-rate)'{-r,--sample-rate}'=[sample rate in seconds (default 60)]:seconds' \
        '(-d --dump)'{-d,--dump}'[dump one sample to stdout]'
      ;;
    arbtt-stats)
      _arguments -s -S \
        '(-h -\? --help)'{-h,-\?,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--logfile=[log file path]:file:_files' \
        '--categorizefile=[categorize config path]:file:_files' \
        '*'{-x,--exclude}'=[ignore samples with tag/category]:tag' \
        '*'{-o,--only}'=[only samples with tag/category]:tag' \
        '--also-inactive[include samples tagged inactive]' \
        '*'{-f,--filter}'=[only samples matching condition]:condition' \
        '(-m --min-percentage)'{-m,--min-percentage}'=[hide tags below PERC% (default 1)]:percentage' \
        '*--output-exclude=[remove tags from output]:tag' \
        '*--output-only=[include only these tags in output]:tag' \
        '(-i --information)'{-i,--information}'[show general statistics]' \
        '(-t --total-time)'{-t,--total-time}'[show total time for each tag]' \
        '*'{-c,--category}'=[show statistics for category]:category' \
        '--each-category[show statistics for every category]' \
        '*--intervals=[show interval-based report]:tag' \
        '--dump-samples[output every sample (debug)]' \
        '--output-format=[output format]:format:(text csv tsv)' \
        '*--for-each=[repeater period]:period:(day month year)'
      ;;
    arbtt-dump)
      _arguments -s -S \
        '(-h -\? --help)'{-h,-\?,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --logfile)'{-f,--logfile}'=[log file path]:file:_files' \
        '(-t --format)'{-t,--format}'=[output format]:format:(Human Show JSON)' \
        '(-i --first)'{-i,--first}'=[only dump first N samples]:number' \
        '(-l --last)'{-l,--last}'=[only dump last N samples]:number'
      ;;
    arbtt-import)
      _arguments -s -S \
        '(-h -\? --help)'{-h,-\?,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --logfile)'{-f,--logfile}'=[output log file path]:file:_files'
      ;;
    arbtt-recover)
      _arguments -s -S \
        '(-h -\? --help)'{-h,-\?,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --logfile)'{-f,--logfile}'=[log file to recover]:file:_files'
      ;;
  esac
}

_arbtt-capture "$@"
