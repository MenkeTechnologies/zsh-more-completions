#compdef pg_createsubscriber
# Documentation: https://www.postgresql.org/docs/17/app-pgcreatesubscriber.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# pg_createsubscriber: convert a physical standby into a logical subscriber
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-d[database name]:dbname:' \
  '--database=[database name]:dbname:' \
  '-D[target data dir (subscriber)]:dir:_files -/' \
  '--pgdata=[target data dir (subscriber)]:dir:_files -/' \
  '-n[dry-run]' \
  '--dry-run[dry-run]' \
  '-p[subscriber port]:port:' \
  '--subscriber-port=[subscriber port]:port:' \
  '-P[publisher connection string]:conninfo:' \
  '--publisher-server=[publisher connection string]:conninfo:' \
  '-s[socket directory]:dir:_files -/' \
  '--socket-directory=[socket directory]:dir:_files -/' \
  '-t[recovery timeout (sec)]:seconds:' \
  '--recovery-timeout=[recovery timeout (sec)]:seconds:' \
  '-T[publication name]:pubname:' \
  '--publication=[publication name]:pubname:' \
  '-U[subscriber user]:user:_users' \
  '--subscriber-username=[subscriber user]:user:_users' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--config-file=[config file]:file:_files' \
  '*::pg_createsubscriber args:_files' && ret=0
return ret
