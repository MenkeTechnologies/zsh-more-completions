#compdef pg_createsubscriber
# Documentation: https://www.postgresql.org/docs/17/app-pgcreatesubscriber.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pg_createsubscriber: convert a physical standby into a logical subscriber
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-d+,--database=}'[database name]:dbname:' \
  '(-D --pgdata)'{-D+,--pgdata=}'[target data dir (subscriber)]:dir:_files -/' \
  '(-n --dry-run)'{-n,--dry-run}'[dry-run]' \
  '(-p --subscriber-port)'{-p+,--subscriber-port=}'[subscriber port]:port:' \
  '(-P --publisher-server)'{-P+,--publisher-server=}'[publisher connection string]:conninfo:' \
  '(-s --socketdir)'{-s+,--socketdir=}'[postmaster socket directory]:dir:_files -/' \
  '(-t --recovery-timeout)'{-t+,--recovery-timeout=}'[recovery timeout (sec)]:seconds:' \
  '(-U --subscriber-username)'{-U+,--subscriber-username=}'[subscriber user]:user:_users' \
  '*'{-v,--verbose}'[verbose (repeat for debug)]' \
  '--config-file=[postgresql.conf location]:file:_files' \
  '*--publication=[publication name]:pubname:' \
  '*--replication-slot=[replication slot name]:slot:' \
  '*--subscription=[subscription name]:subname:' && ret=0
return ret
