#compdef packetq
# Documentation: https://raw.githubusercontent.com/DNS-OARC/PacketQ/develop/src/packetq.cpp
# run SQL queries directly on pcap files (DNS-OARC), output JSON/CSV/XML/text

local ret=1

_arguments -s -S \
  '-h[display help]' \
  '-v[display version and exit]' \
  '*-s+[set the SQL statement, can be given multiple times]:sql statement' \
  '-l+[set maximum number of packets to process from all files]:limit' \
  '-j[output JSON (default)]' \
  '-c[output CSV]' \
  '-t[output text table]' \
  '-x[output XML]' \
  '-d[run web server in daemon mode]' \
  '-p+[set the port number to listen on]:port' \
  '-w+[set the root directory for the web content]:directory:_files -/' \
  '-r+[set the root for the pcap files to make available]:directory:_files -/' \
  '-m+[set the maximum number of concurrent connections]:max connections' \
  '--rfc1035[escape DNS names using RFC1035 format]' \
  '*:pcap file:_files' && ret=0

return ret
