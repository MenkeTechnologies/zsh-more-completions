#compdef funcalc
# Documentation: https://linux.die.net/man/1/funcalc
# funcalc - perform calculations on columns of a FITS binary table

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a[user arguments to pass to the compiled program]:argstr' \
  '-e[funcalc expression]:expr' \
  '-f[file containing funcalc expression]:file:_files' \
  '-l[libs to add to link command]:libs' \
  '-n[output generated code instead of compiling and executing]' \
  '-p[generate named program, no execution]:prog' \
  '-u[die if any variable is undeclared]' \
  '*:fits table:_files' && ret=0

return ret
