#compdef mikmod
# Documentation: https://linux.die.net/man/1/mikmod
# mikmod - play soundtracker etc. modules on a Unix machine

local ret=1

_arguments -s -S \
  '(-d --driver)'{-d,--driver}'[use the specified device driver, 0 is autodetect]:driver' \
  '(-o --output)'{-o,--output}'[set bit depth and channel config]:output:(8m 8s 16m 16s)' \
  '(-f --frequency)'{-f,--frequency}'[mixing frequency in hertz]:freq' \
  '(-i --interpolate)'{-i,--interpolate}'[enable interpolated mixing]' \
  '--nointerpolate[disable interpolated mixing]' \
  '(-hq --hqmixer)'{-hq,--hqmixer}'[activate high-quality software mixer]' \
  '--nohqmixer[deactivate high-quality mixer]' \
  '(-s --surround)'{-s,--surround}'[enable surround sound mixing]' \
  '--nosurround[disable surround mixing]' \
  '(-r --reverb)'{-r,--reverb}'[configure reverb intensity 0-15]:reverb' \
  '(-v --volume)'{-v,--volume}'[playback volume 0-100%]:volume' \
  '(-F --fadeout)'{-F,--fadeout}'[fade volume during final pattern]' \
  '--nofadeout[skip fade-out]' \
  '(-l --loops)'{-l,--loops}'[allow backwards loops within modules]' \
  '--noloops[disable backwards loops]' \
  '(-a --panning)'{-a,--panning}'[process panning effects]' \
  '--nopanning[disable panning effect processing]' \
  '(-x --protracker)'{-x,--protracker}'[enable protracker speed effects]' \
  '--noprotracker[disable extended speed effects]' \
  '(-c --curious)'{-c,--curious}'[search for hidden patterns in modules]' \
  '--nocurious[skip hidden pattern search]' \
  '(-p --playmode)'{-p,--playmode}'[set playlist mode 0-3]:mode:(0 1 2 3)' \
  '(-t --tolerant)'{-t,--tolerant}'[continue despite unreadable modules]' \
  '--notolerant[halt on problematic modules]' \
  '(-S --realtime)'{-S,--realtime}'[enable real-time scheduling]:enable:(Y N)' \
  '--norealtime[disable real-time scheduling]' \
  '(-q --quiet)'{-q,--quiet}'[run without interactive commands]' \
  '(-te --terse)'{-te,--terse}'[simplified display format]' \
  '(-n --information)'{-n,--information}'[list drivers and module loaders]' \
  '(-V --version)'{-V,--version}'[display version information]' \
  '(-h --help)'{-h,--help}'[show options summary]' \
  '--norc[skip configuration file parsing]' \
  '*:file:_files' && ret=0

return ret
