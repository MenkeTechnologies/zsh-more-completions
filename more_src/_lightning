#compdef lightning

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'login:authenticate to lightning.ai'
  'logout:sign out'
  'run:run an App'
  'init:scaffold App or Component'
  'install:install App or Component'
  'list:list resources'
  'show:show resources'
  'stop:stop a running App'
  'fork:duplicate an App'
  'tree:print CLI command tree'
  'fit:run trainer fit (LightningCLI)'
  'validate:run trainer validate (LightningCLI)'
  'test:run trainer test (LightningCLI)'
  'predict:run trainer predict (LightningCLI)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'lightning subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _values 'run target' 'app' && ret=0
        ;;
      (init)
        _values 'init target' 'app' 'component' 'pl-app' 'react-ui' && ret=0
        ;;
      (install)
        _values 'install target' 'app' 'component' && ret=0
        ;;
      (list)
        _values 'list target' 'apps' && ret=0
        ;;
      (show)
        _values 'show target' 'logs' && ret=0
        ;;
    esac
    ;;
esac

return ret
