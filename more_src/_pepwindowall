#compdef pepwindowall
# pepwindowall - Draw Kyte-Doolittle hydropathy plot for a protein alignment

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequences[input aligned protein sequences]:file:_files' \
  '-graph[output graphics device type]:device:' \
  '-datafile[AAINDEX entry data file]:file:_files' \
  '-window[window size for hydropathy calculations]:size:' \
  '-normalize[normalize calculated data values]' \
  '-auto[turn off prompts]' \
  '-stdout[write to standard output]' \
  '-filter[read stdin, write stdout]' \
  '-options[prompt for all parameter values]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report program messages]' \
  '-version[display version number]' \
  '*:alignment file:_files' && ret=0

return ret
