#compdef gurk

# https://github.com/boxdot/gurk-rs — Signal SMS TUI (`gurk --help`)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '-V[version]' \
  '--version[version]' \
  '--config=-[config.toml]:file:_files' \
  '--db-path=-[SQLite path]:file:_files' \
  '*:phone/subcommand:_default'
