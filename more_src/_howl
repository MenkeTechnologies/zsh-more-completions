#compdef howl

# Howl: lightweight editor for productive programmers (Lua/Moonscript)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-r --reuse)'{-r,--reuse}'[reuse existing instance if any]' \
  '(-n --no-reuse)'{-n,--no-reuse}'[force fresh instance]' \
  '--no-profile[start without user profile]' \
  '--quit[tell running instance to quit]' \
  '*:file [+line]:_files' && ret=0
return ret
