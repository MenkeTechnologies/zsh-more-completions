#compdef calligraphy
# Documentation: https://github.com/jonascarpay/calligraphy
# Render Haskell call graphs and structures from HIE files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display version information]' \
  '(-d --output-dot)'{-d,--output-dot}'=[.dot output path]:file:_files' \
  '(-p --output-png)'{-p,--output-png}'=[.png output path (requires dot engine)]:file:_files' \
  '(-s --output-svg)'{-s,--output-svg}'=[.svg output path (requires dot engine)]:file:_files' \
  '(-m --output-mermaid)'{-m,--output-mermaid}'=[Mermaid output path]:file:_files' \
  '--stdout-dot[output graphviz dot to stdout]' \
  '--stdout-mermaid[output Mermaid to stdout]' \
  '--stdout-svg[output SVG to stdout]' \
  '--render-engine=[render engine to use with --output-png and --output-svg]:cmd' \
  '--ddump-hie-file[debug dump raw HIE files]' \
  '--ddump-lexical-tree[debug dump the reconstructed lexical structure]' \
  '--ddump-final[debug dump the final tree after processing]' \
  '*'{-e,--exclude}'=[exclude modules by name or filepath]:module' \
  '--hidden[search paths with a leading period]' \
  '*'{-i,--input}'=[filepaths to search for HIE files]:path:_files' \
  '--hide-calls[disable display of call arrows]' \
  '--hide-types[disable display of type arrows]' \
  '--show-key[reveal internal keys alongside identifiers]' \
  '--show-ghc-key[reveal GHC keys with identifiers]' \
  '--show-module-path[display module filepaths instead of module names]' \
  '--show-line[include line numbers in output]' \
  '--show-line-col[include line and column numbers in output]' \
  '--no-cluster-modules[do not draw modules as clusters]' \
  '--force-cluster-modules[force module clustering even with single modules]' \
  '--exports-only[remove all non-exported bindings]' \
  '--hide-local-bindings[remove all non-exported bindings]' \
  '--collapse-modules[collapse all nodes into a single node per module]' \
  '--collapse-classes[merge class node children edges into itself]' \
  '--hide-classes[remove all class nodes and their children]' \
  '--collapse-data[merge data node children edges into itself]' \
  '--hide-data[remove all data nodes and their children]' \
  '--collapse-values[merge value node children edges into itself]' \
  '--hide-values[remove all value nodes and their children]' \
  '--collapse-constructors[merge constructor node children edges into itself]' \
  '--hide-constructors[remove all constructor nodes and their children]' \
  '--hide-records[remove all record nodes]' \
  '*'{-f,--forward-root}'=[hide everything not a transitive dependency of roots]:name' \
  '*'{-r,--reverse-root}'=[hide everything not a reverse transitive dependency of roots]:name' \
  '--max-depth=[limit the maximum search depth]:int' \
  '--follow-parent[follow edges from child to parent]' \
  '--no-follow-parent[do not follow edges from child to parent]' \
  '--follow-child[follow edges from parent to children]' \
  '--no-follow-child[do not follow edges from parent to children]' \
  '--follow-value[follow normal edges]' \
  '--no-follow-value[do not follow normal edges]' \
  '--follow-type[follow type edges]' \
  '--no-follow-type[do not follow type edges]' \
  '*:module:' && ret=0

return ret
