#compdef getfits
# Documentation: http://tdc-www.harvard.edu/software/wcstools/
# getfits: extract a portion of a FITS or IRAF image into a new FITS file (WCSTools)

local ret=1

_arguments -s -S \
  '-d[write FITS file(s) to this directory]:directory:_files -/' \
  '-i[log rows as they are copied at this interval]:num' \
  '-k[file of keyword names to delete from output header]:file:_files' \
  '-o[output name for one file]:name:_files' \
  '-s[write output to standard output]' \
  '-x[dimensions of image section to be extracted]:dx:_message dx' \
  '-v[verbose]' \
  '*:FITS file:_files -g "*.(fits|fit|fts|FITS|FIT|FTS|imh)"' && ret=0

return ret
