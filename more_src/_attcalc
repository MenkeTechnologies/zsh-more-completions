#compdef attcalc
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/attcalc/node4.html
# Calculate linearized sky coordinates on an event-by-event basis

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--eventset=[input events set]:file:_files' \
  '--attitudelabel=[source of attitude data]:label:(ahf fixed om)' \
  '--refpointlabel=[source of celestial reference point coordinates]:label:(nom obj pnt user)' \
  '--fixedra=[RA of spacecraft attitude]:ra' \
  '--fixeddec=[Dec of spacecraft attitude]:dec' \
  '--fixedposangle=[position angle of spacecraft attitude]:angle' \
  '--nominalra=[celestial RA of central reference point]:ra' \
  '--nominaldec=[celestial Dec of central reference point]:dec' \
  '--imagesize=[half-size of final image in degrees]:degrees' \
  '--withatthkset=[use atthkgen output file]:bool:(Y N)' \
  '--atthkset=[location of atthkgen output file]:file:_files' \
  '--withmedianpnt=[use median vs mean PNT values]:bool:(Y N)' \
  '--calctlmax=[calculate TLMIN, TLMAX from actual X,Y range]:bool:(Y N)' \
  '--setpnttouser=[set RA_PNT, DEC_PNT to user-supplied values]:bool:(Y N)' \
  '*:param=value:_default' && ret=0

return ret
