#compdef CollectArraysVariantCallingMetrics
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/arrays/CollectArraysVariantCallingMetrics.java
# Picard: collects summary and per-sample metrics about variant calls in a genotyping array VCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input VCF file for analysis]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[path prefix of output metrics files]:file:_files' \
  '--DBSNP=[reference dbSNP file in dbSNP or VCF format]:file:_files' \
  '--CALL_RATE_PF_THRESHOLD=[threshold for autocall pass determination]:n:' \
  '(-SD --SEQUENCE_DICTIONARY)'{-SD,--SEQUENCE_DICTIONARY}'=[sequence dictionary to speed dbSNP loading]:file:_files' \
  '--NUM_PROCESSORS=[number of threads to split the task over]:n:' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
