#compdef flrig
# Documentation: https://man.archlinux.org/search?q=flrig
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug-level=+[debug level]:lvl:(0 1 2 3 4 5)' \
  '--config-dir=+[config dir]:dir:_files -/' \
  '--server-address=+[xmlrpc address]:addr:' \
  '--server-port=+[xmlrpc port]:port:' && ret=0

return ret
