#compdef bader
# Documentation: https://theory.cm.utexas.edu/henkelman/code/bader/
# bader — grid-based Bader charge analysis of a charge density file

local ret=1

_arguments -s -S \
  '-h[print description of options]' \
  '-v[print version information]' \
  '-c[partitioning method for charge]:method:(bader voronoi)' \
  '-n[partitioning method for atomic populations]:method:(bader voronoi)' \
  '-b[basin assignment algorithm]:algorithm:(neargrid ongrid weight)' \
  '-r[refine edge method]:refine:' \
  '-ref[reference charge file]:reference charge:_files' \
  '-vac[vacuum density handling]:vacuum:(off auto)' \
  '-p[print options]:print:(all_atom all_bader sel_atom sel_bader sum_atom sum_bader atom_index bader_index)' \
  '-i[input charge file format]:format:(cube chgcar)' \
  '-cp[calculate critical points]' \
  '*:charge file:_files' && ret=0

return ret
