#compdef charge
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/charge.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# EMBOSS charge: plot net charge along a protein sequence
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-seqall=[protein sequence(s)]:protein USA:_files' \
  '-window=[window size for averaging]:size:' \
  '-aadata=[AA properties data file]:file:_files' \
  '-plot[produce graph output]' \
  '-graph=[graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-outfile=[report output file]:file:_files' \
  '*:protein USA:_files' && ret=0
return ret
