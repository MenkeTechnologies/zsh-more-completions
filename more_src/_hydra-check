autoload -U is-at-least

_hydra-check() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-a+[System architecture to check]:ARCH:(x86_64-linux aarch64-linux x86_64-darwin aarch64-darwin)' \
'--arch=[System architecture to check]:ARCH:(x86_64-linux aarch64-linux x86_64-darwin aarch64-darwin)' \
'-c+[Channel to check packages for]:CHANNEL:(nixpkgs-unstable nixos-unstable nixos-unstable-small staging-next stable)' \
'--channel=[Channel to check packages for]:CHANNEL:(nixpkgs-unstable nixos-unstable nixos-unstable-small staging-next stable)' \
'(-c --channel)--jobset=[Specify jobset to check packages for]:JOBSET:_default' \
'--shell-completion=[Print generated completions for a given shell]:SHELL:(bash elvish fish powershell zsh)' \
'--url[Only print the hydra build url, then exit]' \
'--json[Output json]' \
'-s[Write only the latest build even if last build failed]' \
'--short[Write only the latest build even if last build failed]' \
'-l[Fetch more entries if possible (might be slower)]' \
'--long[Fetch more entries if possible (might be slower)]' \
'-e[Print details about specific evaluations instead of packages]' \
'--eval[Print details about specific evaluations instead of packages]' \
'(-e --eval)-t[Query the release tests of the given channel (jobset)]' \
'(-e --eval)--tests[Query the release tests of the given channel (jobset)]' \
'(-e --eval)-r[Combine information from channel evals and release --tests]' \
'(-e --eval)--releases[Combine information from channel evals and release --tests]' \
'-v[Print more debugging information]' \
'--verbose[Print more debugging information]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'*::PACKAGES:_default' \
&& ret=0
}

(( $+functions[_hydra-check_commands] )) ||
_hydra-check_commands() {
    local commands; commands=()
    _describe -t commands 'hydra-check commands' commands "$@"
}

if [ "$funcstack[1]" = "_hydra-check" ]; then
    _hydra-check "$@"
else
    compdef _hydra-check hydra-check
fi
