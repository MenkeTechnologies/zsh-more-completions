#compdef btcwallet
# Documentation: https://github.com/btcsuite/btcwallet/blob/master/config.go
# Reference accessed: 2026-05-27
# Verified: upstream btcsuite/btcwallet config.go config struct (go-flags tags)

# Zsh completion for btcwallet (btcsuite Bitcoin wallet daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[display version information and exit]' \
  '(-C --configfile)'{-C+,--configfile=}'[path to configuration file]:file:_files' \
  '(-A --appdata)'{-A+,--appdata=}'[application data directory for wallet config, databases and logs]:dir:_files -/' \
  '--create[create the wallet if it does not exist]' \
  '--createtemp[create a temporary simulation wallet (pass=password) in the data directory]' \
  '--testnet[use the test Bitcoin network (version 3)]' \
  '--testnet4[use the test Bitcoin network (version 4)]' \
  '--simnet[use the simulation test network]' \
  '--signet[use the signet test network]' \
  '*--signetchallenge=[custom signet network challenge hex]:hex:' \
  '*--signetseednode=[seed node for the signet network]:host\:port:' \
  '--regtest[use the regression test network]' \
  '--noinitialload[defer wallet creation/opening on startup, allow loading wallets over RPC]' \
  '(-d --debuglevel)'{-d+,--debuglevel=}'[logging level]:level:(trace debug info warn error critical)' \
  '--logdir=[directory to log output]:dir:_files -/' \
  '--profile=[enable HTTP profiling on given port (1024-65535)]:port:' \
  '--dbtimeout=[timeout value used when opening the wallet database]:duration:' \
  '--walletpass=[public wallet password (only if wallet was created with one)]:password:' \
  '(-c --rpcconnect)'{-c+,--rpcconnect=}'[hostname/IP and port of btcd RPC server to connect to]:host\:port:' \
  '--cafile=[file containing root certs to authenticate TLS connections with btcd]:file:_files' \
  '--noclienttls[disable TLS for the RPC client (only allowed for localhost)]' \
  '--btcdusername=[username for btcd authentication]:user:' \
  '--btcdpassword=[password for btcd authentication]:password:' \
  '--proxy=[connect via SOCKS5 proxy]:host\:port:' \
  '--proxyuser=[username for proxy server]:user:' \
  '--proxypass=[password for proxy server]:password:' \
  '--usespv[enable experimental SPV chain synchronization instead of RPC]' \
  '*'{-a+,--addpeer=}'[add a peer to connect with at startup]:host\:port:' \
  '*--connect=[connect only to the specified peers at startup]:host\:port:' \
  '--maxpeers=[max number of inbound and outbound peers]:n:' \
  '--banduration=[how long to ban misbehaving peers (s, m, h)]:duration:' \
  '--banthreshold=[max ban score before disconnecting and banning peers]:score:' \
  '--rpccert=[file containing the certificate file]:file:_files' \
  '--rpckey=[file containing the certificate key]:file:_files' \
  '--onetimetlskey[generate a new TLS certpair at startup, write only the cert to disk]' \
  '--noservertls[disable TLS for the RPC server (only allowed for localhost)]' \
  '*--rpclisten=[listen for legacy RPC connections on this interface/port]:host\:port:' \
  '--rpcmaxclients=[max number of legacy RPC clients for standard connections]:n:' \
  '--rpcmaxwebsockets=[max number of legacy RPC websocket connections]:n:' \
  '(-u --username)'{-u+,--username=}'[username for legacy RPC and btcd auth]:user:' \
  '(-P --password)'{-P+,--password=}'[password for legacy RPC and btcd auth]:password:' \
  '*--experimentalrpclisten=[listen for experimental gRPC connections on this interface/port]:host\:port:' \
  '(-b --datadir)'{-b+,--datadir=}'[DEPRECATED -- use appdata instead]:dir:_files -/' \
  '(- *)'{-h,--help}'[show help message]' && ret=0

return ret
