#compdef mris_sample_parc
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_sample_parc
# FreeSurfer sample a volume parcellation onto a surface annotation

local ret=1

_arguments -s -S \
  '-sdir[subjects directory (default $SUBJECTS_DIR)]:directory:_files -/' \
  '-surf[surface (default white)]:filename:_files' \
  '-fix[fix topology of labels smaller than N vertices]:number:' \
  '-replace[replace label N with deeper ones]:number:' \
  '-trans[translate number_in to number_out]:translation:' \
  '-projmm[project N mm along surface normal]:number:' \
  '-proj[same as -projmm]:number:' \
  '-projfrac[project N percent along normal (default 0.5)]:number:' \
  '-file[translation file (default cma_parcellation_colors.txt)]:filename:_files' \
  '-ct[embed color table into output annotation]:filename:_files' \
  '-v[diagnostic level (default 0)]:number:' \
  '-f[apply mode filter N times to parcellation]:number:' \
  '-a[smooth surface N times (default 0)]:number:' \
  '-w[window size for sampling (default 7)]:number:' \
  '-t[thickness file (default thickness)]:filename:_files' \
  '-u[change largest connected unknown region to label]:number:' \
  '--help[print help]' \
  '--version[print version]' \
  '*:arg:_files' && ret=0

return ret
