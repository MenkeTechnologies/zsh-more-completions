#compdef cb clipboard

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:action:->actions' \
  '*:: :->args' && ret=0

case $state in
  actions)
    local -a actions=(
      'copy:copy content to clipboard'
      'cut:cut content to clipboard'
      'paste:paste content from clipboard'
      'clear:clear clipboard'
      'show:show clipboard contents'
      'edit:edit clipboard contents'
      'add:add content to clipboard'
      'remove:remove content from clipboard'
      'note:add note to clipboard'
      'swap:swap clipboard contents'
      'status:show clipboard status'
      'info:show clipboard info'
      'load:load clipboard from file'
      'import:import from file'
      'export:export to file'
      'history:show clipboard history'
      'ignore:ignore clipboard entry'
      'search:search clipboard'
      'config:configure clipboard'
    )
    _describe -t actions 'clipboard action' actions && ret=0
    ;;
  args)
    case ${words[1]} in
      copy|cut|add|load|import)
        _arguments '*:file:_files' && ret=0
        ;;
      paste|export)
        _arguments '*:destination:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
