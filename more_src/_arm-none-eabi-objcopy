#compdef arm-none-eabi-objcopy
# _arm-none-eabi-objcopy — Arm Limited arm-none-eabi-objcopy CLI for the bare-metal ARM cross-objcopy converting ELF object files to Intel HEX binary Motorola S-Record raw binary symbol manipulation strip rename-section (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-objcopy() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-I+[input format]:f:(binary ihex srec elf32-littlearm elf32-bigarm)' \
        '--input-target=+[input format]:f:(binary ihex srec elf32-littlearm elf32-bigarm)' \
        '-O+[output format]:f:(binary ihex srec elf32-littlearm elf32-bigarm)' \
        '--output-target=+[output format]:f:(binary ihex srec elf32-littlearm elf32-bigarm)' \
        '-F+[both format]:f:(binary ihex srec elf32-littlearm)' \
        '--target=+[format]:f:(binary ihex srec elf32-littlearm)' \
        '-B+[bfd architecture]:str:' \
        '--binary-architecture=+[bfd architecture]:str:' \
        '-K+[symbol]:str:' \
        '--keep-symbol=+[symbol]:str:' \
        '-N+[symbol]:str:' \
        '--strip-symbol=+[symbol]:str:' \
        '-G+[symbol]:str:' \
        '--keep-global-symbol=+[symbol]:str:' \
        '-L+[symbol]:str:' \
        '--localize-symbol=+[symbol]:str:' \
        '-W+[symbol]:str:' \
        '--weaken-symbol=+[symbol]:str:' \
        '-S[strip all]' \
        '--strip-all[strip all]' \
        '-g[strip debug]' \
        '--strip-debug[strip debug]' \
        '-x[discard all locals]' \
        '--discard-all[discard all locals]' \
        '-X[discard locals]' \
        '--discard-locals[discard locals]' \
        '-j+[section]:str:' \
        '--only-section=+[section]:str:' \
        '-R+[section]:str:' \
        '--remove-section=+[section]:str:' \
        '--rename-section=+[old=new]:str:' \
        '--add-section=+[name=file]:str:' \
        '--gap-fill=+[hex]:str:' \
        '--pad-to=+[hex]:str:' \
        '--set-start=+[hex]:str:' \
        '--change-start=+[hex]:str:' \
        '--change-section-address=+[name=hex]:str:' \
        '--prefix-sections=+[prefix]:str:' \
        '*:input output:_files'
}

_arm-none-eabi-objcopy "$@"
