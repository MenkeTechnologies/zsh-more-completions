#compdef boost
# _boost — Boost client for Filecoin storage deals (filecoin-project/boost)
# upstream: https://github.com/filecoin-project/boost
# Subcommands from cmd/boost/main.go.

_boost() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--repo=[path to the boost repo]:dir:_files -/' \
        '--vv[very-verbose output]' \
        '--json[emit JSON output]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_boost_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '--api-sealer=[Lotus miner API token info]:token:' \
                        '--api-sector-index=[sector index API token info]:token:' \
                        '--wallet-publish-storage-deals=[wallet for publishing storage deals]:address:' \
                        '--wallet-deal-collateral=[wallet for posting deal collateral]:address:' && ret=0 ;;
                deal)
                    _arguments \
                        '--provider=[storage provider miner address]:miner:' \
                        '--http-url=[HTTP URL where the data is hosted]:url:' \
                        '--commp=[piece CID]:cid:' \
                        '--car-size=[size of the CAR file in bytes]:bytes:' \
                        '--piece-size=[size of the piece in bytes]:bytes:' \
                        '--payload-cid=[root payload CID]:cid:' \
                        '--storage-price=[storage price per GiB epoch]:attoFIL:' \
                        '--start-epoch=[start epoch for the deal]:epoch:' \
                        '--duration=[deal duration in epochs]:epochs:' \
                        '--verified=[deal verified flag]:bool:(true false)' \
                        '--wallet=[wallet address used to fund the deal]:address:' && ret=0 ;;
                deal-status)
                    _arguments \
                        '--provider=[storage provider miner address]:miner:' \
                        '--deal-uuid=[deal UUID to look up]:uuid:' && ret=0 ;;
                retrieve)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[output CAR file]:file:_files' \
                        '--provider=[storage provider miner address]:miner:' \
                        '1:payload CID:' && ret=0 ;;
                offline-deal)
                    _arguments \
                        '--provider=[storage provider miner address]:miner:' \
                        '--commp=[piece CID]:cid:' \
                        '--car-file=[CAR file containing the payload]:file:_files' && ret=0 ;;
                provider)
                    _arguments \
                        '1: :(list-deals storage-ask retrieval-ask)' && ret=0 ;;
                wallet)
                    _arguments \
                        '1: :(new list balance send default)' \
                        '*:wallet arg:' && ret=0 ;;
                direct-deal-allocate)
                    _arguments \
                        '--provider=[storage provider miner address]:miner:' \
                        '--piece-cid=[piece CID]:cid:' \
                        '--piece-size=[piece size in bytes]:bytes:' \
                        '--term-min=[minimum allocation term in epochs]:epochs:' \
                        '--term-max=[maximum allocation term in epochs]:epochs:' && ret=0 ;;
                direct-deal-get-allocations)
                    _arguments \
                        '--client=[client address]:address:' && ret=0 ;;
                list-claims)
                    _arguments \
                        '--provider=[storage provider miner address]:miner:' && ret=0 ;;
                client-extend-deal)
                    _arguments \
                        '--deal-uuid=[deal UUID to extend]:uuid:' \
                        '--end-epoch=[new end epoch]:epoch:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_boost_commands] )) ||
_boost_commands() {
    local -a commands
    commands=(
        'init:initialize the boost client repo'
        'deal:make an online storage deal with a Filecoin storage provider'
        'deal-status:query the status of a storage deal'
        'retrieve:retrieve content from a Filecoin storage provider'
        'offline-deal:make an offline storage deal (data shipped out-of-band)'
        'provider:query storage providers (deals, asks)'
        'wallet:manage the local boost wallet'
        'direct-deal-allocate:allocate a verified direct-data deal'
        'direct-deal-get-allocations:list verified direct-data allocations'
        'list-claims:list verified-data claims for a provider'
        'client-extend-deal:extend an existing deal duration'
    )
    _describe -t commands 'boost command' commands
}

_boost "$@"
