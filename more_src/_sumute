#compdef sumute
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/windowing_sorting_muting/sumute.c
# SUMUTE - mute above or below a user-defined polygonal curve

local ret=1

_arguments -s -S \
  'xmute=[array of position values]:x:' \
  'tmute=[array of corresponding time values (sec)]:t:' \
  'nmute=[number of x,t values defining mute]:n:' \
  'xfile=[file containing position values]:f:_files' \
  'tfile=[file containing corresponding time values]:f:_files' \
  'hmute=[key header word specifying mute time]:k:' \
  'key=[key header word specifying trace offset]:k:' \
  'ntaper=[number of points to taper]:n:' \
  'mode=[mute mode (0 above, etc.)]:m:(0 1 2 3 4)' \
  'linvel=[constant velocity for linear/hyperbolic mute]:l:' \
  'tm0=[time shift of linear/hyperbolic mute]:t:' \
  'twindow=[vector of mute zone widths in time]:t:' \
  'twfile=[file of mute zone widths]:f:_files' \
  '*:SU file:_files' && ret=0

return ret
