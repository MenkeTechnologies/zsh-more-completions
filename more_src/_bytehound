#compdef bytehound

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'preload:run a command with the memory profiler preloaded'
  'gather:gather profiling data from a data source'
  'server:start the web UI server to view profiling data'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'bytehound command' commands && ret=0
    ;;
  args)
    case $line[1] in
      server)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --port)'{-p,--port}'[port to listen on]:port number' \
          '(-d --data)'{-d,--data}'[path to profiling data file]:data file:_files' \
          '--host[host address to bind to]:host address' \
          '--debug[enable debug mode]' && ret=0
        ;;
      preload)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output path for profiling data]:output path:_files' \
          '(--)--[command to profile]' \
          '*:: :_normal' && ret=0
        ;;
      gather)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-s --source)'{-s,--source}'[data source path]:source path:_files' \
          '(-o --output)'{-o,--output}'[output path for gathered data]:output path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
