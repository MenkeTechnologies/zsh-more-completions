#compdef FlexPepDock
# Documentation: https://docs.rosettacommons.org/docs/latest/application_documentation/docking/flex-pep-dock
# Rosetta FlexPepDock peptide-protein docking and refinement application

local ret=1

_arguments -s -S \
  '-help[display all available options]' \
  '-flexpep_prepack[prepack mode: optimize side chains before docking]' \
  '-lowres_abinitio[low-resolution ab-initio peptide docking]' \
  '-pep_refine[high-resolution peptide refinement]' \
  '-lowres_preoptimize[low-resolution pre-optimization]' \
  '-flexpep_score_only[score input without docking]' \
  '-flexPepDockingMinimizeOnly[minimization-only mode]' \
  '-receptor_chain+[receptor chain ID]:chain:' \
  '-peptide_chain+[peptide chain ID]:chain:' \
  '-peptide_anchor+[peptide anchor residue]:residue:' \
  '-design_peptide[allow peptide design]' \
  '-ref_startstruct+[reference start structure]:pdb:_files -g "*.pdb"' \
  '-frag3+[3-residue fragment library]:frag3:_files' \
  '-frag5+[5-residue fragment library]:frag5:_files' \
  '-frag9+[9-residue fragment library]:frag9:_files' \
  '-in:file:s+[input PDB file]:pdb:_files -g "*.pdb"' \
  '-in:file:l+[list of input PDB files]:pdblist:_files' \
  '-database+[path to Rosetta database directory]:database:_files -/' \
  '-score:weights+[scoring function weights file]:weights:_files' \
  '-nstruct+[number of output structures]:nstruct:' \
  '-out:path:all+[output directory path]:path:_files -/' \
  '-out:pdb[output in PDB format]' \
  '-overwrite[overwrite existing output files]' \
  '-ex1[extra chi1 rotamer sampling]' \
  '-ex2[extra chi2 rotamer sampling]' \
  '*-mute+[suppress output from a tracer channel]:channel:' \
  '*-unmute+[enable output from a tracer channel]:channel:' \
  '*:file:_files' && ret=0

return ret
