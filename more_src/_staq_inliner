#compdef staq_inliner
# Documentation: https://github.com/softwareQinc/staq/wiki/The-staq-tool-suite
# staq tool: inline gate declarations in OpenQASM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--clear-decls[remove inlined gate declarations]' \
  '--inline-stdlib[inline all gate declarations including qelib1.inc]' \
  '--ancilla-name=[set ancilla register name]:name' && ret=0

return ret
