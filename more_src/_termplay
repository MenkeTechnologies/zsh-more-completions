#compdef termplay
# Documentation: https://github.com/jD91mZM2/termplay
# termplay - convert images to ANSI sequences and play videos in the terminal

local ret=1

_arguments -s \
  '--help[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '(-q --quiet)'{-q,--quiet}'[ignore TUI things for simple image viewing]' \
  '(-c --converter)'{-c,--converter}'=[how the image should be displayed]:converter:(color256 halfblock sixel truecolor)' \
  '(-h --height)'{-h,--height}'=[set the height]:height' \
  '(-r --rate)'{-r,--rate}'=[set the framerate]:rate' \
  '--ratio=[set the terminal font ratio]:ratio' \
  '(-w --width)'{-w,--width}'=[set the width]:width' \
  '1:path:_files' && ret=0

return ret
