#compdef sshs

# Zsh completion for sshs - SSH connection manager TUI

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
  '(-k --key)'{-k,--key}'[SSH key to use]:SSH key:_files' \
  '(-p --port)'{-p,--port}'[port number]:port' \
  '(-u --user)'{-u,--user}'[SSH user]:user' \
  '(-C --command)'{-C,--command}'[execute command on remote host]:command'
