#compdef jazzer

local curcontext="$curcontext" state line ret=1

_arguments \
  '--help[show help message]' \
  '--cp[classpath for the target]:classpath:_files' \
  '--target_class[fully qualified name of the target class]:class name' \
  '--target_method[target method name]:method name' \
  '--autofuzz[auto-fuzz a method signature]:method signature' \
  '--agent_path[path to the Jazzer agent]:agent path:_files -g "*.jar"' \
  '--instrumentation_includes[glob patterns for instrumentation includes]:patterns' \
  '--instrumentation_excludes[glob patterns for instrumentation excludes]:patterns' \
  '--custom_hooks[custom hook classes]:hook classes' \
  '--keep_going[number of findings before stopping]:count' \
  '--reproducer_path[directory for reproducer files]:directory:_directories' \
  '--coverage_report[output coverage report file]:report file:_files' \
  '--coverage_dump[output coverage dump file]:dump file:_files' \
  '--fuzz_test[fuzz test class to run]:class name' \
  '--seed[initial seed for PRNG]:seed' \
  '--runs[number of fuzzing runs]:runs' \
  '--dict[dictionary file for fuzzing]:dictionary file:_files' \
  '*:target arguments' \
  && ret=0

return ret
