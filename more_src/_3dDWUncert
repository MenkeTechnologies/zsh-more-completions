#compdef 3dDWUncert
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dDWUncert.html
# AFNI: estimate uncertainty of DTI parameters via jackknife

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-inset[input 4D diffusion-weighted dataset]:file:_files' \
  '-input[DTI parameter file prefix]:inpref:_files' \
  '-input_list[file listing DTI parameter files]:file:_files' \
  '-grads[gradient direction file]:file:_files' \
  '-bmatrix_Z[b-matrix file with zero rows]:file:_files' \
  '-bmatrix_FULL[full b-matrix file]:file:_files' \
  '-iters[number of jackknife iterations]:number:' \
  '-mask[mask dataset]:mask:_files' \
  '-calc_thr_FA[FA threshold for calculations]:ff:' \
  '-csf_fa[FA value assigned to CSF voxels]:number:' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '*:dataset:_files' && ret=0

return ret
