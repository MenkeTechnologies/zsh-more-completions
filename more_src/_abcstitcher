#compdef abcstitcher
# Documentation: https://github.com/alembic/alembic/blob/master/bin/AbcStitcher/AbcStitcher.cpp
# Alembic: stitch multiple Alembic archives into one

local ret=1

_arguments -s -S \
  '-v[verbose; print each IObject being processed]' \
  '-hold[fill missing samples with the first or previous sample]' \
  '*:alembic archive:_files -g "*.abc"' && ret=0

return ret
