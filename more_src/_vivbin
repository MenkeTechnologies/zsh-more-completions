#compdef vivbin
# Documentation: https://vivisect.readthedocs.io/en/latest/vivisect/quickstart.html
# Vivisect binary analysis workspace tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-M --module)'{-M,--module}'[run file as analysis module in non-gui mode and exit]:file:_files' \
  '(-A --skip-analysis)'{-A,--skip-analysis}'[do not do an initial auto-analysis pass]' \
  '(-B --bulk)'{-B,--bulk}'[do not start the gui, just load, analyze and save]' \
  '(-C --cprofile)'{-C,--cprofile}'[output vivisect performance profiling info]' \
  '*'{-O,--option}'[set configuration option (<sec>.<opt>=<json>)]:option' \
  '(-p --parser)'{-p,--parser}'[manually specify parser module]:parser:(pe elf blob macho ihex srec)' \
  '(-s --storage)'{-s,--storage}'[specify storage module by name]:storage' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-V --version)'{-V,--version}'[add file version to save filename]' \
  '*:file:_files' && ret=0

return ret
