#compdef shotman

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[capture mode]:mode:(region output window)' \
  '--capture[capture mode]:mode:(region output window)' \
  '-C[copy to clipboard on capture]' \
  '-S[save on capture]' \
  '-d[set save directory]:directory:_files -/' && ret=0

return ret
