#compdef sc2clean
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss51.html
# SMURF SC2CLEAN - clean SCUBA-2 time-series data

local ret=1

_arguments -C \
  'IN=[input files to be cleaned]:NDF file:_files' \
  'OUT=[output files]:NDF file:_files' \
  'OUTFILES=[text file listing output NDFs]:file:_files' \
  'CONFIG=[cleaning parameter values (keyword=value)]:config:' \
  'BBM=[bad bolometer mask files]:NDF file:_files' \
  'COM=[NDF for the calculated common mode]:NDF file:_files' \
  'GAI=[NDF for gain/offset/correlation coefficients]:NDF file:_files' \
  'FLAT=[flatfield the data]:flag:(TRUE FALSE)' \
  'FLATMETH=[flatfield calculation method]:method:(POLYNOMIAL TABLE)' \
  'FLATORDER=[polynomial order for flatfield]:order:' \
  'FLATSNR=[signal-to-noise threshold for responsivity]:snr:' \
  'FLATUSENEXT=[use previous and following flatfields]:flag:(TRUE FALSE)' \
  'MAXLEN=[maximum concatenated length in seconds]:seconds:' \
  'PADSTART=[samples to pad at data start]:count:' \
  'PADEND=[samples to pad at data end]:count:' \
  'RESIST=[bolometer resistor settings]:config:' \
  'RESPMASK=[responsivity-based masking]:flag:(TRUE FALSE)' \
  'USEDARKS=[use darks to mask data]:flag:(TRUE FALSE)' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:NDF file:_files' && ret=0

return ret
