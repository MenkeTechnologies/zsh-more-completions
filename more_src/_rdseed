#compdef rdseed
# IRIS: read an FDSN SEED format volume

local ret=1

_arguments -s -S \
  '-a[retrieve the abbreviation dictionaries]' \
  '-b+[set seismogram input buffer size (bytes)]:bytes' \
  '-c[retrieve volume table of contents]' \
  '-C+[retrieve comments (STN or CHN)]:arg:(STN CHN)' \
  '-d[output data records]' \
  '-e[extract event/station data]' \
  '-E[output filename will include endtime]' \
  '-f+[input file name]:file:_files' \
  '-g+[alternate SEED volume for metadata]:file:_files' \
  '(-h -u)-h[show help]' \
  '-i[ignore location codes]' \
  '-k[strip records with a zero sample count]' \
  '-l[list contents of each record in the volume]' \
  '-o+[specify output format (numeric)]:format' \
  '-p[output poles and zeros]' \
  '-q+[output directory]:dir:_files -/' \
  '-Q+[data quality]:quality:(E D M Q R)' \
  '-R[print response data]' \
  '-s[retrieve all station header information]' \
  '-S[retrieve station summary information]' \
  '-t[show start/stop times, start blocks of events]' \
  '(-u -h)-u[show usage]' \
  '-v+[select volume number]:volume' \
  '-x[use summary file]' \
  '-z+[check for reversals and apply sign correction]:level:(0 1 2 3)' \
  '*:arg:_files' && ret=0

return ret
