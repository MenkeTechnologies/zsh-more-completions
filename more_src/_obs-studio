#compdef obs

# Zsh completion for OBS Studio

_arguments -s -S \
  '--collection=[set scene collection]:collection:' \
  '--profile=[set profile]:profile:' \
  '--scene=[start with scene]:scene:' \
  '--studio-mode[enable studio mode]' \
  '--minimize-to-tray[minimize to system tray]' \
  '--startstreaming[automatically start streaming]' \
  '--startrecording[automatically start recording]' \
  '--startreplaybuffer[automatically start replay buffer]' \
  '--startvirtualcam[automatically start virtual camera]' \
  '--multi[allow multiple instances]' \
  '--portable[use portable mode]' \
  '--always-on-top[make OBS always on top]' \
  '--verbose[enable verbose logging]' \
  '--unfiltered_log[do not connect the brolog filter]' \
  '--disable-updater[disable built-in updater]' \
  '--disable-missing-files-check[disable missing files check]' \
  '--disable-shutdown-check[disable unclean shutdown check]' \
  '--safe-mode[start in safe mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]'
