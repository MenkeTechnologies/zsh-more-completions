#compdef pgbouncer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d[run in background as daemon]' \
  '-R[do an online restart]' \
  '-q[be quiet - do not log to stdout]' \
  '-v[increase verbosity]' \
  '(-u --user)'{-u,--user}'[assume identity of user]:user:_users' \
  '1:config file:_files' && ret=0

return ret