#compdef fslorient
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/utilities/fslutils.html
# fslorient - get/set orientation information (sform/qform) in image header

local ret=1

_arguments -s -S \
  '-getorient[print FSL left-right orientation]' \
  '-getsform[print 16 elements of the sform matrix]' \
  '-getqform[print 16 elements of the qform matrix]' \
  '-setsform[set 16 elements of the sform matrix]' \
  '-setqform[set 16 elements of the qform matrix]' \
  '-getsformcode[print integer sform code]' \
  '-getqformcode[print integer qform code]' \
  '-setsformcode[set integer sform code]' \
  '-setqformcode[set integer qform code]' \
  '-copysform2qform[set the qform equal to the sform]' \
  '-copyqform2sform[set the sform equal to the qform]' \
  '-deleteorient[remove orient info from header]' \
  '-forceradiological[make FSL radiological header]' \
  '-forceneurological[make FSL neurological header]' \
  '-swaporient[swap FSL radiological and FSL neurological]' \
  '*:image file:_files' && ret=0

return ret
