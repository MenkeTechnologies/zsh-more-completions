#compdef gmt2kml
# Documentation: https://docs.generic-mapping-tools.org/latest/gmt2kml.html
# Source: GenericMappingTools/gmt classic-mode gmt2kml — convert GMT tables to KML for Google Earth.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[altitude mode]:mode:(absolute relative_to_ground relative_to_sea_floor)' \
    '-C+[CPT for coloring]:cpt:_files -g "*.cpt(-.)"' \
    '-D+[HTML description snippet file]:file:_files' \
    '-E+[line/polygon rendering (extrude/tessellate)]:opts:_default' \
    '-F+[feature type]:type:(e l p s t w)' \
    '-G+[fill color (symbols/polygons) or label font color]:color:_default' \
    '-I+[custom icon URL]:url:_urls' \
    '-K[allow appending more KML later]' \
    '-L+[extended data columns for KML attrs]:opts:_default' \
    '-N+[feature naming convention]:opts:_default' \
    '-O[append KML to existing file]' \
    '-Q+[wiggle plot params (azimuth, scale)]:opts:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[scale icons / name labels]:opts:_default' \
    '-T+[document title + folder name]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[pen for lines/outlines]:pen:_default' \
    '-Z+[visibility / altitude / LOD / fade]:opts:_default' \
    '*:input table:_files' \
    && ret=0

return ret
