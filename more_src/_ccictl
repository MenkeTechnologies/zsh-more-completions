#compdef ccictl
# Documentation: https://support.huaweicloud.com/intl/en-us/devg-cci2/ccictl.html
# Huawei Cloud Container Instance (CCI) kubectl-like command line tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help information]' \
  '--version[display ccictl version]' \
  '--cliconfig=[specify alternate config file location]:file:_files' \
  '--kubeconfig=[kubeconfig file reference]:file:_files' \
  '(-s --server)'{-s,--server}'+[API server address and port]:server:' \
  '(-o --output)'{-o,--output}'+[output format]:format:(json yaml wide custom-columns jsonpath name)' \
  '--sort-by=[sort results by JSONPath expression]:expr:' \
  '(-n --namespace)'{-n,--namespace}'+[target namespace]:namespace:' \
  '-l+[label selector]:selector:' \
  '-f+[file or directory input]:file:_files' \
  '--all[all resources]' \
  '-i[interactive mode]' \
  '-t[TTY allocation]' \
  '--follow[stream output]' \
  '--watch[monitor updates]' \
  '*:command:(get create apply delete describe edit exec logs rollout set config api-resources api-versions explain version)' && ret=0

return ret
