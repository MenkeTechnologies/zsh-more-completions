#compdef simple_dcraw
# Documentation: https://github.com/LibRaw/LibRaw/blob/master/samples/simple_dcraw.cpp
# Reference accessed: 2026-05-21
# Verified: upstream samples/simple_dcraw.cpp source. Only these flags exist:
# -T, -v, -e, -E, -4, -C, -L.
# Removed from prior file: fabricated -D (mentioned only in dcraw emulation
# string but not parsed), -i (no source path).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-T[output TIFF instead of .pgm/.ppm]' \
  '-v[verbose output]' \
  '-e[extract thumbnail (single)]' \
  '-E[extract all thumbnails]' \
  '-4[16-bit linear mode]' \
  '-C[install progress callback]' \
  '-L[list supported cameras and exit]' \
  '*:raw file:_files -g "*.(raw|cr2|cr3|nef|orf|arw|raf|dng|rw2|pef|srw|rwl|RAW|CR2|CR3|NEF|ORF|ARW|RAF|DNG|RW2|PEF|SRW|RWL)"' && ret=0

return ret
