#compdef simple_dcraw
# Documentation: https://man.archlinux.org/search?q=simple_dcraw
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-D[document mode]' \
  '-T[output TIFF instead of PPM]' \
  '-v[verbose]' \
  '-e[extract embedded thumbnail]' \
  '-i[show camera info only]' \
  '-4[16-bit linear]' \
  '*:raw file:_files -g "*.(raw|cr2|cr3|nef|orf|arw|raf|dng|rw2|pef|srw|rwl)"' && ret=0

return ret
