#compdef docformatter

# Zsh completion for docformatter - formats Python docstrings to PEP 257

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --recursive)'{-r,--recursive}'[drill down directories recursively]' \
  '*'{-e,--exclude}'[exclude files/directories matching glob]:glob pattern:' \
  '(-d --diff)'{-d,--diff}'[print diff of changes]' \
  '(-c --check)'{-c,--check}'[return error code if changes are needed]' \
  '(-i --in-place)'{-i,--in-place}'[make changes in-place]' \
  '--wrap-summaries=[wrap summary lines at given length]:length:' \
  '--wrap-descriptions=[wrap description lines at given length]:length:' \
  '--make-summary-multi-line[add newlines around one-line summary]' \
  '--force-wrap[force wrapping even if it would not normally be done]' \
  '--tab-width=[number of spaces per tab for indentation]:width:' \
  '--pre-summary-newline[add newline before summary]' \
  '--split-before-logical-operator[split before logical operator in descriptions]' \
  '--post-description-blank[add blank line after description]' \
  '--close-quotes-on-newline[place closing quotes on a newline]' \
  '--force-one-line-docstring[force one-line docstrings]' \
  '--non-strict[do not strictly follow PEP 257]' \
  '--quiet[suppress output]' \
  '*:files:_files -g "*.py"'
