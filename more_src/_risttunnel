#compdef risttunnel

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-l+,--local-ip=}'[local tunnel IP/PREFIX]:ip:' \
  {-o+,--output-url=}'[RIST output URL]:url:' \
  {-b+,--input-url=}'[RIST input URL]:url:' \
  {-S+,--statsinterval=}'[statistics interval (ms)]:ms:' \
  {-e+,--encryption-password=}'[encryption password]:password:' \
  {-t+,--encryption-type=}'[encryption type]:type:(0 128 256)' \
  {-p+,--profile=}'[profile]:profile:(0 1 2)' \
  {-n+,--cname=}'[CNAME]:cname:' \
  {-v+,--verbose-level=}'[verbose level]:level:(-1 0 1 2 3 4 5 6 7)' && ret=0

return ret
