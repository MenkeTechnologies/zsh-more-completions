#compdef sfdijkstra
# Documentation: https://github.com/ahay/src/blob/master/user/pwd/Mdijkstra.c
# Madagascar: Dijkstra's shortest-path algorithm in 2-D

local ret=1

_arguments -s -S \
  'ref1=[source point, first dimension]:ref1' \
  'ref2=[source point, second dimension]:ref2' \
  'nf=[number of final points]:nf' \
  'fin1=[destination coordinates, first dimension]:fin1' \
  'fin2=[destination coordinates, second dimension]:fin2' \
  'paths=[output path filenames]:paths:_files' \
  '*:RSF file:_files' && ret=0

return ret
