#compdef gto
# Git Tag Ops - artifact versioning and stage management via Git tags

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'assign:assign a stage to an artifact version'
      'deprecate:deprecate an artifact'
      'doctor:check GTO setup'
      'enrich:enrich artifact metadata'
      'history:show artifact version history'
      'register:register a new artifact version'
      'show:show artifact state'
      'stages:show available stages'
      'tag:create a Git tag for GTO'
    )
    _describe -t commands 'gto command' commands && ret=0
    ;;
  args)
    case $line[1] in
      assign)
        _arguments \
          '--version[version to assign]:version:' \
          '--stage[stage to assign]:stage:' \
          '--name[artifact name]:name:' \
          '--repo[path to repo]:repo:_files -/' && ret=0
        ;;
      register)
        _arguments \
          '--version[version to register]:version:' \
          '--name[artifact name]:name:' \
          '--repo[path to repo]:repo:_files -/' && ret=0
        ;;
      show|history)
        _arguments \
          '--repo[path to repo]:repo:_files -/' \
          '*:artifact:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
