#compdef sfnmo
# Documentation: http://www.ahay.org/RSF/sfnmo.html
# Madagascar: normal moveout, compatible with sfvscan

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'half=[if y, second axis is half-offset instead of full offset]' \
  'str=[maximum stretch allowed]' \
  'mute=[mute zone]' \
  'CDPtype=[CDP type]' \
  'slowness=[if y, use slowness instead of velocity]' \
  'squared=[if y, the slowness or velocity is squared]' \
  'h0=[reference offset]' \
  'extend=[trace extension]' \
  'offset=[auxiliary offset input file]:file:_files' \
  'mask=[integer mask input file]:file:_files' \
  's=[shifted NMO parameter file]:file:_files' \
  'a=[Taner NMO parameter file]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
