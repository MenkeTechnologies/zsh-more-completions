#compdef lemonbar

# Zsh completion for lemonbar - lightweight xcb based bar

_arguments -s -S \
  '-h[show help]' \
  '-g+[set the bar geometry (widthxheight+x+y)]:geometry:' \
  '-b[set the bar at the bottom of the screen]' \
  '-d[force docking (use this if your WM isn''t EWMH-compliant)]' \
  '-f+[set the font name]:font name:' \
  '-a+[set the maximum number of clickable areas]:number:' \
  '-p[make the bar permanent (don''t exit after EOF)]' \
  '-n+[set the WM_NAME atom value of the bar]:name:' \
  '-u+[set underline/overline thickness (pixels)]:pixels:' \
  '-B+[set background color]:color:' \
  '-F+[set foreground color]:color:' \
  '-o+[add a vertical offset to the text]:pixels:' \
  '-U+[set underline color]:color:'
