#compdef lemonbar
# Documentation: https://github.com/LemonBoy/bar
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lemonbar - lightweight xcb-based bar.

_arguments -s -S \
  '-h[show help]' \
  '-g+[bar geometry widthxheight+x+y]:geometry:' \
  '-b[dock the bar at the bottom of the screen]' \
  '-d[force docking without WM]' \
  '*-f+[set the font name (repeatable)]:font name:' \
  '-p[make the bar permanent (do not exit after EOF)]' \
  '-n+[set the WM_NAME atom value of the bar]:name:' \
  '-u+[set underline width in pixels]:pixels:' \
  '-B+[set background color]:color:' \
  '-F+[set foreground color]:color:' \
  '-U+[set underline color]:color:' \
  '*-o+[set next output name (multi-monitor)]:name:'
