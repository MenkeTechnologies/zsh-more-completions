#compdef next
# _next-cli — Next.js React framework CLI (Vercel); dev/build/start + scaffolding
# upstream: https://github.com/vercel/next.js

_next-cli() {
    local -a sub=(
        'dev:run in development mode'
        'build:create production build'
        'start:start production server (after build)'
        'export:export static HTML (legacy)'
        'lint:run ESLint'
        'info:print system info'
        'telemetry:enable/disable telemetry'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'next subcommand' sub ;;
        args)
            case $words[1] in
                dev) _arguments \
                    '(-p --port)'{-p,--port}'+[port]:port:' \
                    '(-H --hostname)'{-H,--hostname}'+[hostname]:host:_hosts' \
                    '--turbo[use Turbopack]' \
                    '--experimental-https[enable HTTPS]' \
                    '--experimental-https-key+[https key]:file:_files' \
                    '--experimental-https-cert+[https cert]:file:_files' \
                    '*:dir:_files -/' ;;
                start) _arguments \
                    '(-p --port)'{-p,--port}'+[port]:port:' \
                    '(-H --hostname)'{-H,--hostname}'+[hostname]:host:_hosts' \
                    '--keepAliveTimeout+[keep-alive ms]:n:' \
                    '*:dir:_files -/' ;;
                build) _arguments \
                    '--profile[generate React profile]' \
                    '--debug[debug]' \
                    '--no-mangling[disable mangling]' \
                    '--experimental-build-mode+[mode]:mode:(default compile generate)' \
                    '*:dir:_files -/' ;;
                lint) _arguments \
                    '--dir+[lint dir]:dir:_files -/' \
                    '--file+[file glob]:glob:' \
                    '--fix[autofix]' \
                    '--quiet[quiet]' \
                    '--max-warnings+[max warnings]:n:' \
                    '--cache[enable cache]' \
                    '--cache-location+[cache file]:file:_files' \
                    '--no-cache[disable cache]' ;;
                telemetry) _arguments '1:action:(enable disable status)' ;;
            esac
            ;;
    esac
}

_next-cli "$@"
