#compdef lighteval
# Documentation: https://github.com/huggingface/lighteval
# Hugging Face Lighteval all-in-one toolkit for evaluating LLMs across backends

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--output-dir=[directory for results and details]:dir:_files -/' \
  '--save-details[save per-sample evaluation details]' \
  '--max-samples=[limit number of samples per task]:n:' \
  '--override-batch-size=[override the model batch size]:size:' \
  '--num-fewshot-seeds=[number of few-shot seeds to run]:n:' \
  '--public-run[make the pushed run public]' \
  '--push-to-hub[push results to the Hugging Face Hub]' \
  '1:command:(eval accelerate vllm sglang nanotron endpoint custom tasks baseline)' \
  '*::arg:->args' && ret=0

return ret
