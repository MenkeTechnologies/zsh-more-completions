#compdef alluxio

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'format:format Alluxio master and all workers'
  'formatJournal:format Alluxio master journal locally'
  'formatMasters:format Alluxio master nodes'
  'formatWorker:format Alluxio worker nodes'
  'bootstrapConf:generate a config file if one does not exist'
  'fs:filesystem CLI for interacting with Alluxio'
  'fsadmin:admin CLI for the Alluxio filesystem'
  'table:(deprecated) table service CLI'
  'getConf:look up a configuration key, or print all configuration'
  'job:job service CLI'
  'logLevel:set or get log level of Alluxio servers'
  'runClass:run the main method of an Alluxio class'
  'runTest:run an end-to-end test on an Alluxio cluster'
  'runTests:run all end-to-end tests on an Alluxio cluster'
  'runHmsTests:test integration between Alluxio and Hive metastore'
  'runHdfsMountTests:test integration between Alluxio and HDFS path'
  'runJournalCrashTest:test the master journal in a crash scenario'
  'runUfsIOTest:test Alluxio throughput to UFS path'
  'runUfsTests:test integration between Alluxio and target UFS'
  'readJournal:read journal file from stdin to human-readable stdout'
  'upgradeJournal:upgrade journal v0 to v1'
  'killAll:kill processes containing the WORD'
  'copyDir:copy a path to all master/worker nodes'
  'clearCache:clear OS buffer cache of the machine'
  'docGen:generate docs automatically'
  'version:print Alluxio version'
  'validateConf:validate Alluxio conf'
  'validateEnv:validate Alluxio environment'
  'collectInfo:collect troubleshooting information'
  'cache:worker-related file system and format operations'
  'conf:get, set, and validate configuration'
  'exec:run an Alluxio class main method or end-to-end tests'
  'generate:generate docs automatically'
  'info:retrieve and display info about a running cluster'
  'initiate:initialization operations such as format and validate'
  'journal:journal related operations'
  'process:start, stop, and other process operations'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '*-D-[set Alluxio property]:property:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'alluxio subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (fs)
        _values 'fs action' \
          'cat' 'checkConsistency' 'checksum' 'chgrp' 'chmod' 'chown' \
          'copyFromLocal' 'copyToLocal' 'count' 'cp' 'distributedCp' \
          'du' 'free' 'getCapacityBytes' 'getCmdStatus' 'getfacl' \
          'getSyncPathList' 'getUsedBytes' 'head' 'help' 'leader' \
          'load' 'loadMetadata' 'location' 'ls' 'masterInfo' 'mkdir' \
          'mount' 'mv' 'needsSync' 'persist' 'pin' 'rm' 'setfacl' \
          'setReplication' 'setTtl' 'startSync' 'stat' 'stopSync' \
          'tail' 'test' 'touch' 'unmount' 'unpin' 'unsetTtl' 'updateMount' && ret=0
        ;;
      (fsadmin)
        _values 'fsadmin action' \
          'backup' 'journal' 'doctor' 'getBlockInfo' 'metrics' 'pathConf' \
          'report' 'statelock' 'ufs' 'updateConf' \
          'decommissionWorker' 'enableWorker' && ret=0
        ;;
      (job)
        _values 'job action' \
          'leader' 'ls' 'stat' 'cancel' 'getCmdStatus' 'load' && ret=0
        ;;
      (info)
        _values 'info action' \
          'cache' 'collect' 'doctor' 'nodes' 'report' 'version' && ret=0
        ;;
      (initiate)
        _values 'initiate action' \
          'format' 'validate' 'copyDir' 'clearOSCache' && ret=0
        ;;
      (process)
        _values 'process action' 'start' 'stop' && ret=0
        ;;
      (journal)
        _values 'journal action' 'format' 'read' 'checkpoint' 'quorum' && ret=0
        ;;
      (cache)
        _values 'cache action' 'format' 'free' && ret=0
        ;;
      (conf)
        _values 'conf action' 'get' 'log' 'set' 'validate' && ret=0
        ;;
      (exec)
        _values 'exec target' \
          'class' 'basicIOTest' 'hdfsMountTest' 'ufsTest' 'ufsIOTest' && ret=0
        ;;
      (generate)
        _values 'generate target' 'docs' && ret=0
        ;;
      (table)
        _values 'table action' \
          'attachdb' 'detachdb' 'ls' 'stat' 'sync' 'transform' 'transformStatus' && ret=0
        ;;
      (logLevel)
        _arguments \
          '--target=[target server]:server:' \
          '--logName=[logger name]:name:' \
          '--level=[level]:level:(TRACE DEBUG INFO WARN ERROR FATAL OFF ALL)' && ret=0
        ;;
    esac
    ;;
esac

return ret
