#compdef futhark

# Zsh completion for futhark (parallel functional language compiler)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'c:compile to sequential C'
  'opencl:compile to C with OpenCL'
  'cuda:compile to C with CUDA'
  'multicore:compile to multicore C'
  'python:compile to Python'
  'pyopencl:compile to Python with PyOpenCL'
  'ispc:compile to ISPC'
  'check:type-check source file'
  'doc:generate documentation'
  'test:run test programs'
  'bench:benchmark programs'
  'literate:process literate Futhark programs'
  'repl:interactive REPL'
  'hash:print hash of program'
  'pkg:package manager'
  'fmt:format source file'
  'tokens:print token stream'
  'query:query information about source'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'futhark command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (c|opencl|cuda|multicore|ispc)
        _arguments \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--library[generate library instead of executable]' \
          '--server[generate server binary]' \
          '-w[disable warnings]' \
          '--Werror[treat warnings as errors]' \
          '--safe[disable unsafe operations]' \
          '1:source file:_files -g "*.fut(N)"' && ret=0
        ;;
      (python|pyopencl)
        _arguments \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--library[generate library]' \
          '-w[disable warnings]' \
          '--Werror[treat warnings as errors]' \
          '1:source file:_files -g "*.fut(N)"' && ret=0
        ;;
      (check)
        _arguments \
          '-w[disable warnings]' \
          '--Werror[treat warnings as errors]' \
          '1:source file:_files -g "*.fut(N)"' && ret=0
        ;;
      (test)
        _arguments \
          '--backend[backend to test with]:backend:(c opencl cuda multicore python pyopencl ispc)' \
          '--runner[program to run compiled tests]:runner:_command_names' \
          '--pass-option[pass option to runner]:option' \
          '--no-terminal[disable terminal output]' \
          '--no-tuning[disable auto-tuning]' \
          '--concurrency[number of parallel tests]:count' \
          '*:test file:_files -g "*.fut(N)"' && ret=0
        ;;
      (bench)
        _arguments \
          '--backend[backend to benchmark]:backend:(c opencl cuda multicore ispc)' \
          '--runner[program to run benchmarks]:runner:_command_names' \
          '--runs[number of benchmark runs]:count' \
          '--json[write JSON output]:file:_files' \
          '--timeout[timeout per run]:seconds' \
          '--no-tuning[disable auto-tuning]' \
          '*:benchmark file:_files -g "*.fut(N)"' && ret=0
        ;;
      (doc)
        _arguments \
          '(-o --output-directory)'{-o,--output-directory}'[output directory]:directory:_files -/' \
          '*:source file:_files -g "*.fut(N)"' && ret=0
        ;;
      (pkg)
        local -a pkg_cmds=(
          'add:add a package dependency'
          'check:check that package manifest is valid'
          'fmt:format package manifest'
          'init:initialize a new package'
          'remove:remove a package dependency'
          'sync:synchronize packages'
          'upgrade:upgrade packages'
          'versions:list available versions'
        )
        _arguments '1:pkg subcommand:->pkg_sub' '*:: :->pkg_args' && ret=0
        case $state in
          (pkg_sub) _describe -t commands 'pkg subcommand' pkg_cmds && ret=0 ;;
          (pkg_args) _arguments '*:package' && ret=0 ;;
        esac
        ;;
      (repl)
        _arguments '1:source file:_files -g "*.fut(N)"' && ret=0
        ;;
      (literate)
        _arguments \
          '--backend[backend to use]:backend:(c opencl cuda multicore python pyopencl)' \
          '--stop-on-error[stop on first error]' \
          '*:literate file:_files -g "*.fut(N)"' && ret=0
        ;;
      (fmt)
        _arguments '*:source file:_files -g "*.fut(N)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
