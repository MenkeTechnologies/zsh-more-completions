#compdef nomad-cli
# _nomad-cli — HashiCorp Nomad workload orchestrator CLI alias (HashiCorp, Go); custom argparse
# upstream: https://github.com/hashicorp/nomad

_nomad-cli() {
    local -a sub=(
        'acl:access control list commands'
        'agent:start nomad agent'
        'agent-info:show agent info'
        'alloc:allocation commands'
        'config:config commands'
        'deployment:deployment commands'
        'eval:evaluation commands'
        'event:stream events'
        'exec:exec inside an alloc task'
        'fmt:format hcl jobspec'
        'job:job commands'
        'license:license commands'
        'login:authenticate to Nomad'
        'monitor:tail agent log'
        'namespace:namespace commands (Enterprise)'
        'node:node commands'
        'operator:operator commands'
        'plugin:plugin commands'
        'quota:resource quota commands (Enterprise)'
        'recommendation:recommendation commands (Enterprise)'
        'run:submit a job'
        'sentinel:sentinel policy commands (Enterprise)'
        'server:server commands'
        'service:service commands'
        'setup:setup integrations'
        'status:show status'
        'stop:stop a running job'
        'system:system commands'
        'tls:TLS commands'
        'ui:open the Nomad UI'
        'validate:validate jobspec'
        'var:variable commands'
        'version:show version'
        'volume:volume commands'
        'workload-identity:workload identity'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-address=+[Nomad HTTP address]:url:_urls' \
        '--address=+[Nomad HTTP address]:url:_urls' \
        '-region=+[region]:str:' \
        '--region=+[region]:str:' \
        '-namespace=+[namespace]:str:' \
        '--namespace=+[namespace]:str:' \
        '-token=+[ACL token]:str:' \
        '--token=+[ACL token]:str:' \
        '-ca-cert=+[CA cert]:file:_files' \
        '-ca-path=+[CA path]:dir:_files -/' \
        '-client-cert=+[client cert]:file:_files' \
        '-client-key=+[client key]:file:_files' \
        '-tls-server-name=+[TLS server name]:str:' \
        '-tls-skip-verify[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nomad subcommand' sub ;;
        args)
            case $words[1] in
                job) _arguments \
                    '1:cmd:(allocs deployments dispatch eval evaluations history inspect periodic plan promote restart revert run scale scaling-events status stop validate)' \
                    '*:arg:' ;;
                alloc) _arguments \
                    '1:cmd:(checks exec fs logs restart sign signal status stop)' \
                    '*:arg:' ;;
                node) _arguments \
                    '1:cmd:(config drain eligibility meta status)' \
                    '*:arg:' ;;
                operator) _arguments \
                    '1:cmd:(api autopilot client-state debug gossip metrics raft scheduler snapshot)' \
                    '*:arg:' ;;
                server) _arguments \
                    '1:cmd:(force-leave join members)' \
                    '*:arg:' ;;
                acl) _arguments \
                    '1:cmd:(auth-method binding-rule bootstrap policy role token)' \
                    '*:arg:' ;;
                deployment) _arguments \
                    '1:cmd:(fail list pause promote resume status unblock)' \
                    '*:arg:' ;;
                eval) _arguments \
                    '1:cmd:(delete list status)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(validate)' \
                    '*:arg:' ;;
                run|stop|validate|status|inspect|monitor|agent-info|exec) _arguments '*:job-or-arg:' ;;
            esac
            ;;
    esac
}

_nomad-cli "$@"
