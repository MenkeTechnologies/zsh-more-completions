#compdef doxx
# Documentation: https://man.archlinux.org/search?q=doxx
# Reference accessed: 2026-05-16

# https://github.com/bgreenwell/doxx — repo metadata fetcher (`doxx --help`)
_arguments -s -S \
  '--help[help]' \
  '--version[version]' \
  '(-o --output)'{-o,--output}'=-[write path]:file:_files' \
  '*:repository slug or URL:_default'
