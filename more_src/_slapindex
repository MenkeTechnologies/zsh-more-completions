#compdef slapindex
# _slapindex — OpenLDAP slapindex (offline rebuild of one or more indexes against the running database files; -F config dir, -f slapd.conf, -b suffix, -n database number, -q quick mode, -t attribute name filter, -d debug level, -v verbose, -V version, -h help; positional argument is an optional attribute name list)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slapindex)
# Flags from OpenLDAP servers/slapd/slapcommon.c on tip.

_slapindex() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F+[config dir]:dir:_files -/' \
        '-f+[slapd.conf]:file:_files' \
        '-b+[suffix]:dn:' \
        '-n+[database number]:n:' \
        '-q[quick mode]' \
        '-t+[attribute filter]:attr:' \
        '-d+[debug level]:level:' \
        '-v[verbose]' \
        '*:attribute:'
}

_slapindex "$@"
