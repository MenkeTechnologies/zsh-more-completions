#compdef taskopen
# Documentation: https://github.com/jschlatow/taskopen/blob/master/doc/man/taskopen.1.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (taskopen 2.0).

local curcontext="$curcontext" state line ret=1
local -a subcommands
subcommands=(
  'batch:switch to batch mode'
  'any:switch to any mode'
  'version:print version information'
  'diagnostics:print diagnostics'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[print additional info messages]' \
  '--debug[print debug messages]' \
  '(-s --sort)'{-s+,--sort=}'[sort key list]:keys:' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-a --active-tasks)'{-a+,--active-tasks=}'[active tasks filter]:filter:' \
  '(-x --execute)'{-x+,--execute=}'[override executed command]:cmd:' \
  '(-f --filter-command)'{-f+,--filter-command=}'[override filter command]:cmd:' \
  '(-i --inline-command)'{-i+,--inline-command=}'[override inline command]:cmd:' \
  '--args=[user-defined $ARGS for actions]:arguments:' \
  '--include=[only consider listed actions]:actions:' \
  '--exclude=[exclude listed actions]:actions:' \
  '(-A --All)'{-A,--All}'[query all tasks including completed and deleted]' \
  '1: :->cmd' \
  '*::filter:->filters' && ret=0

case $state in
  (cmd) _describe -t subcommands 'taskopen subcommand' subcommands && ret=0 ;;
  (filters) _arguments '*:task filter:' && ret=0 ;;
esac

return ret
