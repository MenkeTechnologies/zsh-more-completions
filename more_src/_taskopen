#compdef taskopen

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-a[query all active tasks]' \
  '-A[query all tasks including completed]' \
  '-n[only show file annotations]' \
  '-N[only show note annotations]' \
  '-l[list annotations]' \
  '-L[list annotations with task info]' \
  '-b[batch mode]' \
  '-s=[sort by]:field:(urgency priority due)' \
  '-f=[filter expression]:filter' \
  '-c=[configuration file]:file:_files' \
  '-e=[command to execute]:command' \
  '-x[execute label commands]' \
  '-i[interactive mode]' \
  '-m[force mutt for mail annotations]' \
  '-r[raw output]' \
  '*:task filter'
