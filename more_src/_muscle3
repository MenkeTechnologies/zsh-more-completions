#compdef muscle3 muscle
# Documentation: https://man.archlinux.org/search?q=muscle3
# Reference accessed: 2026-05-16

# MUSCLE 3.x: multiple sequence alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '-in[input sequence file]:file:_files' \
  '-in1[first input for profile-profile alignment]:file:_files' \
  '-in2[second input for profile-profile alignment]:file:_files' \
  '-out[output alignment]:file:_files' \
  '-clw[Clustal output]' \
  '-clwstrict[strict Clustal output]' \
  '-fasta[FASTA output (default)]' \
  '-html[HTML output]' \
  '-msf[GCG MSF output]' \
  '-phyi[PHYLIP interleaved output]' \
  '-phys[PHYLIP sequential output]' \
  '-log[log file]:file:_files' \
  '-loga[append log file]:file:_files' \
  '-maxiters[max refinement iterations]:n:' \
  '-maxhours[time budget in hours]:hrs:' \
  '-maxmb[memory budget in MB]:MB:' \
  '-quiet[suppress diagnostic output]' \
  '-stable[output in input order]' \
  '-group[output in alignment order]' \
  '-tree1[first guide tree input]:file:_files' \
  '-tree2[second guide tree input]:file:_files' \
  '-usetree[use stored guide tree]:file:_files' \
  '-profile[profile-profile alignment]' \
  '-refine[refine existing alignment]' \
  '-refinew[refine within window]' \
  '-version[print version]' \
  '*:sequence file:_files -g "*.(fa|fasta|seq|aln)"' && ret=0
return ret
