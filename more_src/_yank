#compdef yank

# Zsh completion for yank - yank terminal output to clipboard

_arguments \
  '(-d --delimiter)'{-d,--delimiter}'[use delimiter instead of newline]:delimiter' \
  '(-g --grep)'{-g,--grep}'[filter output through grep]:pattern' \
  '(-l --line)'{-l,--line}'[use full line selection]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-x --xsel-arg)'{-x,--xsel-arg}'[argument to pass to selection command]:arg' \
  '--[run command with selected field as last argument]' \
  '*:: :_command_names'
