#compdef yank
# Documentation: https://raw.githubusercontent.com/mptre/yank/master/yank.1
# Reference accessed: 2026-05-21
# Verified: upstream yank.1 man page at the URL above.

# Zsh completion for yank - yank terminal output to clipboard

_arguments \
  '-1[auto-select if only one field is recognized]' \
  '-d+[delimiter sequence]:delim:' \
  '-g+[POSIX extended regular expression pattern]:pattern:' \
  '-i[ignore case]' \
  '-l[use default delimiters except space]' \
  '-v[print version]' \
  '-x[use alternate screen]' \
  '--[command and args to run with selected field on stdin]' \
  '*:: :_command_names'
