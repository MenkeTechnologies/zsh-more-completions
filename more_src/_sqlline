#compdef sqlline

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '-u+[JDBC URL]:url:' \
  '-n+[username]:user:_users' \
  '-p+[password]:password:' \
  '-d+[JDBC driver class]:class:' \
  '-e+[execute query and exit]:query:' \
  {-f+,--run=}'[execute script file]:file:_files -g "*.(sql|hql)"' \
  '--color=[colorize output]:flag:(true false)' \
  '--outputformat=[output format]:format:(table vertical csv tsv xmlattrs xmlelements json)' \
  '--maxColumnWidth=[max column width]:n:' \
  '--maxWidth=[max terminal width]:n:' \
  '--showHeader=[show column headers]:flag:(true false)' \
  '--headerInterval=[header interval]:n:' \
  '--silent=[silent mode]:flag:(true false)' \
  '--fastConnect=[skip table list]:flag:(true false)' \
  '--escapeOutput=[escape control symbols]:flag:(true false)' \
  '--nullValue=[NULL representation]:string:' \
  '--numberFormat=[number format pattern]:pattern:' \
  '--dateFormat=[date format]:pattern:' \
  '--timeFormat=[time format]:pattern:' \
  '--timestampFormat=[timestamp format]:pattern:' \
  '--force=[continue on errors]:flag:(true false)' \
  '--isolation=[transaction isolation]:level:' \
  '--autoCommit=[autocommit]:flag:(true false)' \
  '--autosave=[autosave preferences]:flag:(true false)' \
  '--showWarnings=[show warnings]:flag:(true false)' \
  '--showNestedErrs=[show nested errors]:flag:(true false)' \
  '--showElapsedTime=[show elapsed time]:flag:(true false)' \
  '--verbose=[verbose]:flag:(true false)' \
  '--truncateTable=[truncate wide columns]:flag:(true false)' \
  '--incremental=[incremental fetch]:flag:(true false)' \
  '--connectInteractionMode=[connect interaction mode]:mode:(useNthPassword askCredentials notAskCredentials)' \
  '--script=[script file alias of -f]:file:_files -g "*.(sql|hql)"' \
  '*:additional:_files' && ret=0

return ret
