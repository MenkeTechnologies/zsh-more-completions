#compdef digifil
# Documentation: https://dspsr.sourceforge.net/manuals/
# DSPSR: convert/filterbank baseband data, optionally coherently dedispersing.

local ret=1

_arguments -s -S \
  '--threads=[number of threads for processing]:n:' \
  '(-b --bits)'{-b+,--bits=}'[number of bits per sample output]:bits:' \
  '-B+[block size in megabytes]:mb:' \
  '-c[keep offset and scale constant]' \
  '-2[disable 2-bit excision]' \
  '-F+[create a filterbank (voltages only)]:nchan:' \
  '-x+[backward FFT length in voltage filterbank]:nfft:' \
  '-K[remove inter-channel dispersion delays]' \
  '-D+[set the dispersion measure]:dm:' \
  '-t+[decimate in time]:factor:' \
  '-f+[decimate in frequency]:factor:' \
  '-d+[polarization output format selection]:npol:' \
  '-P+[process only a single polarization of input]:pol:' \
  '-I+[rescale interval duration in seconds]:seconds:' \
  '-s+[data scale factor to apply]:scale:' \
  '-o+[output filename]:file:_files' \
  '-p[revert to FPT order]' \
  '*:input data file:_files' && ret=0

return ret
