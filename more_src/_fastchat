#compdef fastchat
# Documentation: https://github.com/lm-sys/FastChat
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for FastChat - typically invoked as python -m fastchat.serve.<module>

_arguments \
  '--model-path[model identifier (local path or HF repo)]:model:' \
  '--num-gpus[number of GPUs for model parallelism]:n:' \
  '--max-gpu-memory[max memory per GPU (e.g. 8GiB)]:mem:' \
  '--device[device type]:device:(cpu cuda mps xpu npu)' \
  '--load-8bit[enable 8-bit compression]' \
  '--cpu-offloading[offload weights exceeding GPU capacity to CPU]' \
  '--style[output style]:style:(rich simple)' \
  '--controller[controller URL (default http://localhost:21001)]:url:' \
  '--port[worker port assignment]:port:' \
  '--worker[worker URL]:url:' \
  '--register-api-endpoint-file[JSON file with API endpoint registrations]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]'
