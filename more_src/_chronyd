#compdef chronyd
# _chronyd — Miroslav Lichvar chronyd (chrony NTP daemon; tracks clocks via NTP/PTP, supports RTC, hwclock, refclocks, NTPv4 + NTS, asymmetric jitter compensation)
# upstream: https://github.com/mlichvar/chrony
# Flags from main.c print_help on tip; positional args after flags are configuration directives.

_chronyd() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-4 -6)-4[force IPv4]' \
        '(-4 -6)-6[force IPv6]' \
        '-f+[configuration file]:file:_files' \
        '-n[do not daemonize]' \
        '*-d[do not daemonize + log to stderr (repeat enables debug)]' \
        '-l+[log file]:file:_files' \
        '-L+[logging threshold]:level:' \
        '-p[print configuration and exit]' \
        '-q[set clock once and exit]' \
        '-Q[log clock offset and exit]' \
        '-r[reload dump files]' \
        '-R[adapt configuration for restart]' \
        '-s[set clock from RTC]' \
        '-t+[exit after N seconds]:sec:' \
        '-u+[run as user]:user:_users' \
        '-U[do not check for root]' \
        '-F+[seccomp filter level]:level:' \
        '-P+[process priority]:n:' \
        '-m[lock memory (mlockall)]' \
        '-x[do not control the system clock]' \
        '-N+[notify-supervisor fd]:fd:' \
        '*::directive:'
}

_chronyd "$@"
