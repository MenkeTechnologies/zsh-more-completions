#compdef coremltools coreml-convert coremlcompiler
# _coremltools — Apple Core ML tools convert/compile model utilities CLI alias (Apple, Python); custom argparse
# upstream: https://github.com/apple/coremltools

_coremltools() {
    local -a sub=(
        'convert:convert from another framework'
        'compile:compile mlmodel to mlmodelc'
        'predict:predict using a model'
        'info:show model info'
        'optimize:optimize model'
        'compress:compress model weights'
        'palettize:palettize model'
        'prune:prune model'
        'quantize:quantize model'
        'validate:validate model'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--input=+[input model]:file:_files' \
        '-i+[input model]:file:_files' \
        '--output=+[output model]:file:_files' \
        '-o+[output model]:file:_files' \
        '--minimum-deployment-target=+[min deployment target]:t:(iOS13 iOS14 iOS15 iOS16 iOS17 macOS10.15 macOS11 macOS12 macOS13 macOS14)' \
        '--compute-units=+[compute units]:c:(ALL CPU_ONLY CPU_AND_GPU CPU_AND_NE)' \
        '--compute-precision=+[compute precision]:p:(FLOAT32 FLOAT16 INT8)' \
        '--source=+[source framework]:f:(pytorch tensorflow keras onnx mlprogram)' \
        '--target=+[target format]:t:(mlmodel mlpackage)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coremltools subcommand' sub ;;
        args)
            case $words[1] in
                convert) _arguments \
                    '--input=+[input model]:file:_files' \
                    '-i+[input model]:file:_files' \
                    '--output=+[output model]:file:_files -g "*.mlmodel *.mlpackage"' \
                    '-o+[output model]:file:_files -g "*.mlmodel *.mlpackage"' \
                    '--input-types=+[input types]:str:' \
                    '--input-shapes=+[input shapes]:str:' \
                    '--source=+[source framework]:f:(pytorch tensorflow keras onnx)' ;;
                compile) _arguments \
                    '*:mlmodel:_files -g "*.mlmodel *.mlpackage"' ;;
                predict) _arguments \
                    '--model=+[model]:file:_files -g "*.mlmodel *.mlpackage *.mlmodelc"' \
                    '--inputs=+[input dict]:str:' \
                    '*:arg:' ;;
                quantize|palettize|prune|optimize|compress) _arguments \
                    '--mode=+[mode]:str:' \
                    '--nbits=+[nbits]:n:' \
                    '--threshold=+[threshold]:f:' \
                    '--target-sparsity=+[target sparsity]:f:' \
                    '*:model:_files' ;;
                validate|info) _arguments \
                    '*:model:_files' ;;
            esac
            ;;
    esac
}

_coremltools "$@"
