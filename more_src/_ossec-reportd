#compdef ossec-reportd
# Documentation: https://www.ossec.net/docs/programs/ossec-reportd.html
# OSSEC report generation tool (reads alerts on stdin)

local ret=1

_arguments -s \
  '-V[version and license message]' \
  '-h[show help]' \
  '*-d[debug mode (repeat to increase verbosity)]' \
  '-s[show the alert dump]' \
  '-t[test configuration]' \
  '-u[run as this user]:user:_users' \
  '-g[run as this group]:group:_groups' \
  '-D[chroot directory]:directory:_directories' \
  '-f[filter results: filter value]:filter:(group rule level location user srcip filename)' \
  '-n[create a description for the report]:name:' \
  '-r[show related entries: filter value]:filter:(group rule level location user srcip filename)' && ret=0

return ret
