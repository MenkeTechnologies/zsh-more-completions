#compdef cwltool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--outdir=[output directory]:dir:_files -/' \
  '--tmpdir-prefix=[tmp dir path prefix]:prefix:' \
  '--tmp-outdir-prefix=[tmp output dir prefix]:prefix:' \
  '--cachedir=[cache directory]:dir:_files -/' \
  '--basedir=[base directory for resolving paths]:dir:_files -/' \
  '--leave-tmpdir[do not delete tmpdir]' \
  '--rm-tmpdir[remove tmpdir on exit]' \
  '--keep-container-on-error[keep container on workflow failure]' \
  '--leave-container[do not remove container on success]' \
  '--rm-container[remove container after success]' \
  '--user-space-docker-cmd=[user-space docker]:cmd:' \
  '--singularity[use Singularity]' \
  '--podman[use Podman]' \
  '--no-container[disable container use]' \
  '--debug[debug output]' \
  '--quiet[suppress non-error output]' \
  '--verbose[verbose output]' \
  '--log-dir=[directory for log output]:dir:_files -/' \
  '--js-console[print JavaScript console messages]' \
  '--strict[strict CWL validation]' \
  '--non-strict[allow CWL extensions]' \
  '--validate[validate CWL document only]' \
  '--print-pre[print CWL before preprocessing]' \
  '--print-rdf[print CWL as RDF]' \
  '--print-dot[print CWL as DOT graph]' \
  '--print-deps[print CWL dependencies]' \
  '--print-supported-versions[print supported CWL versions]' \
  '--print-subgraph[print a subgraph]' \
  '--rdf-serializer=[RDF serializer]:serializer:(turtle xml json-ld n3)' \
  '--enable-pull[enable docker pull]' \
  '--disable-pull[disable docker pull]' \
  '--parallel[run independent steps in parallel]' \
  '--no-doc-cache[disable document cache]' \
  '--strict-memory-limit[fail if memory exceeded]' \
  '--strict-cpu-limit[fail if CPU exceeded]' \
  '--no-prov-deduplicate[do not dedup provenance]' \
  '--provenance=[record provenance to RO directory]:dir:_files -/' \
  '--enable-ext[enable cwltool extensions]' \
  '--disable-color[disable colored output]' \
  '*--preserve-environment=[env var to preserve]:var:' \
  '--preserve-entire-environment[preserve full env]' \
  '--enable-host-net[allow host network]' \
  '--default-container=[default container image]:image:' \
  '--no-match-user[do not run as the calling user inside container]' \
  '--target=[target output id]:id:' \
  '--single-process=[run only a single step]:step:' \
  '--make-template[generate parameter template]' \
  '--print-targets[print output targets]' \
  '--pack[pack CWL into a single doc]' \
  '*::cwl_or_job:_files -g "*.{cwl,yml,yaml,json}"' && ret=0

return ret
