#compdef cargo-add cargo-rm cargo-upgrade cargo-set-version

local curcontext="$curcontext" state line ret=1

case $service in
  cargo-add)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '--dev[add as dev dependency]' \
      '-D[add as dev dependency]' \
      '--build[add as build dependency]' \
      '-B[add as build dependency]' \
      '--optional[mark as optional dependency]' \
      '--no-optional[do not mark as optional]' \
      '--rename=[rename dependency]:name:' \
      '--features=[features to activate]:features:' \
      '--no-default-features[do not add default features]' \
      '--default-features[add default features]' \
      '-p+[package to modify]:package:' \
      '--package=[package to modify]:package:' \
      '--manifest-path=[path to Cargo.toml]:manifest:_files -g "Cargo.toml"' \
      '--path=[local path dependency]:path:_directories' \
      '--git=[git repository URL]:url:' \
      '--branch=[git branch]:branch:' \
      '--tag=[git tag]:tag:' \
      '--rev=[git revision]:revision:' \
      '--registry=[registry to use]:registry:' \
      '-q[quiet output]' \
      '--quiet[quiet output]' \
      '--dry-run[dry run]' \
      '*:crate names:' && ret=0
    ;;
  cargo-rm)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '--dev[remove from dev dependencies]' \
      '-D[remove from dev dependencies]' \
      '--build[remove from build dependencies]' \
      '-B[remove from build dependencies]' \
      '-p+[package to modify]:package:' \
      '--package=[package to modify]:package:' \
      '--manifest-path=[path to Cargo.toml]:manifest:_files -g "Cargo.toml"' \
      '-q[quiet output]' \
      '--quiet[quiet output]' \
      '--dry-run[dry run]' \
      '*:crate names:' && ret=0
    ;;
  cargo-upgrade)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '--all[upgrade all dependencies]' \
      '--workspace[upgrade all packages in workspace]' \
      '--incompatible[allow incompatible upgrades]' \
      '--pinned[upgrade pinned dependencies]' \
      '--manifest-path=[path to Cargo.toml]:manifest:_files -g "Cargo.toml"' \
      '-p+[package to upgrade]:package:' \
      '--package=[package to upgrade]:package:' \
      '--exclude=[exclude packages]:packages:' \
      '--recursive[upgrade recursively]' \
      '-i+[limit to compatible versions]:version:' \
      '-q[quiet output]' \
      '--quiet[quiet output]' \
      '--dry-run[dry run]' \
      '*:crate names:' && ret=0
    ;;
  cargo-set-version)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '--bump=[bump version]:level:(major minor patch)' \
      '--metadata=[set build metadata]:metadata:' \
      '-p+[package to modify]:package:' \
      '--package=[package to modify]:package:' \
      '--manifest-path=[path to Cargo.toml]:manifest:_files -g "Cargo.toml"' \
      '--workspace[modify all packages in workspace]' \
      '--all[modify all packages]' \
      '--exclude=[exclude packages]:packages:' \
      '-q[quiet output]' \
      '--quiet[quiet output]' \
      '--dry-run[dry run]' \
      '1:version:' && ret=0
    ;;
esac

return ret
