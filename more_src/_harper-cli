#compdef harper-cli
# Documentation: https://github.com/Automattic/harper
# Reference accessed: 2026-05-23
# Verified: harper CLI (see also _harper).

# Zsh completion for harper-cli - grammar checker CLI package name

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'lint:lint file for grammar errors'
  'parse:parse and show token tree'
  'count:count words'
  'words:list words'
  'sentences:list sentences'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*:: :->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'harper command' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      lint|parse|count|words|sentences)
        _arguments ':file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
