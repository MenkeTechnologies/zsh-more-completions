#compdef buffchan
# Documentation: man buffchan(8)
# Source: InterNetNews/inn backends/buffchan.c — buffered channel feed for innd (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-b -u)-b[buffered I/O]' \
    '(-b -u)-u[unbuffered I/O]' \
    '-c+[close output after N items]:N:_default' \
    '-C+[close output after N seconds]:secs:_default' \
    '-d+[output directory]:dir:_files -/' \
    '-f+[number of fields per article line]:N:_default' \
    '-l+[flush every N items]:N:_default' \
    '-L+[flush every N seconds]:secs:_default' \
    '-m+[mapping file]:file:_files' \
    '-p+[write pid to file]:file:_files' \
    '-r[do not redirect stderr to errlog]' \
    '-s+[output filename format string]:fmt:_default' \
    && ret=0

return ret
