#compdef btwisted
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/btwisted.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS btwisted: calculate energy of B-DNA twist
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output]' \
  '-filter[read stdin/write stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[report version]' \
  '-outfile=[output filename]:file:_files' \
  '-sequence=[DNA sequence]:file:_files' \
  '-angledata=[data file with twist angles]:file:_files' \
  '-energydata=[data file with stacking energies]:file:_files' \
  '*:DNA sequence:_files' && ret=0

return ret
