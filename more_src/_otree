#compdef otree
# Documentation: https://github.com/fioncat/otree
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# https://github.com/fioncat/otree — clap (src/cmd.rs)
_arguments -s -S \
  '--help[show help]' \
  '--version[print version]' \
  '--build-info[print build info]' \
  '--config=-[config file]:file:_files' \
  '(-t --content-type)'{-t,--content-type}'=-[input format]:type:(json yaml toml xml hcl jsonl)' \
  '(-o --to)'{-o,--to}'=-[convert output format]:type:(json yaml toml xml hcl jsonl any)' \
  '--disable-header[hide header]' \
  '--disable-footer[hide footer]' \
  '--disable-filter[disable filter widget]' \
  '--tree-disable-selected-highlight[no selection highlight in tree]' \
  '--tree-selected-symbol=-[symbol for selected tree node]:symbol:' \
  '--filter-ignore-case[case-insensitive filter]' \
  '--filter-exclude-mode[hide non-matching items when filtering]' \
  '(-f --header-format)'{-f,--header-format}'=-[header format string]:format:' \
  '(-V --vertical)'{-V,--vertical}'[vertical split layout]' \
  '(-H --horizontal)'{-H,--horizontal}'[horizontal split layout]' \
  '(-s --size)'{-s,--size}'=-[tree pane percent 10–80]:percent:' \
  '--disable-highlight[no syntax highlight in data pane]' \
  '(-w --wrap)'{-w,--wrap}'[wrap long lines in data pane]' \
  '--show-config[print effective config]' \
  '--ignore-config[ignore config files; use defaults]' \
  '--max-data-size=-[max read size MiB]:n:' \
  '(-R --live-reload)'{-R,--live-reload}'[reload when file changes]' \
  '--debug=-[write debug log to file]:file:_files' \
  '*:: :_files' \
