#compdef create-fullstack-app
# Documentation: https://www.npmjs.com/package/create-fullstack-app
# Reference accessed: 2026-05-23
# Verified: npm view create-fullstack-app bin; npm readme Options; package templates tree.

# Zsh completion for create-fullstack-app - TypeScript fullstack/API/website generator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--only-website[generate only a website project]' \
  '--only-api[generate only an API project]' \
  '--no-install[skip npm install in generated project]' \
  '--github[add GitHub issue/PR templates and Actions config]' \
  '--template-api=[API template]:template:(express fastify fastify-prisma nest strapi)' \
  '--template-website=[website template]:template:(next nuxt)' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[output version number]' \
  ':project name:' && ret=0

return ret
