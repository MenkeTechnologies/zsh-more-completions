#compdef nats-top
# Documentation: https://github.com/nats-io/nats-top
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-s[NATS server address]:address' \
  '-m[HTTP monitoring port]:port' \
  '-ms[HTTPS monitoring port]:port' \
  '-n[limit connections requested]:count' \
  '-d[screen refresh interval seconds]:seconds' \
  '-r[max refreshes before exit]:max' \
  '-o[snapshot output file]:file:_files' \
  '-l[output file delimiter (use with -o)]:delim' \
  '-sort[sort field]:field:(cid subs pending msgs_to msgs_from bytes_to bytes_from idle last lang version)' \
  '-cert[client certificate for HTTPS]:file:_files' \
  '-key[client key for HTTPS]:file:_files' \
  '-cacert[CA certificate for HTTPS]:file:_files' \
  '-k[skip SSL certificate verification]' \
  '-b[display traffic in raw bytes]' \
  '(-u --display-subscriptions-column)'{-u,--display-subscriptions-column}'[show subscriptions column on launch]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' && ret=0
return ret
