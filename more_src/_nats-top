#compdef nats-top

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-s[server address]:address' \
  '-m[monitoring port]:port' \
  '-ms[monitoring address]:address' \
  '-n[number of iterations]:count' \
  '-d[delay between updates in seconds]:seconds' \
  '-sort[sort by field]:field:(cid subs pending msgs_to msgs_from bytes_to bytes_from lang idle last)' \
  '-lookup[lookup subscription by subject]:subject' \
  '-l[look up subscriptions]' \
  '-b[display raw bytes]' \
  '--http-user[HTTP basic auth user]:user' \
  '--http-password[HTTP basic auth password]:password' \
  '-version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0
return ret
