#compdef arachni_rest_server
# Documentation: https://github.com/Arachni/arachni/wiki/REST-server
# Arachni REST API server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[output this message]' \
  '--version[show version information]' \
  '--address=[hostname or IP address to bind to]:address' \
  '--port=[port to listen to]:port' \
  '--reroute-to-logfile[reroute all output to log-files]' \
  '--verbose[show verbose output]' \
  '--debug=[show debugging information]:level:(1 2 3)' \
  '--only-positives[only output positive results]' \
  '--authentication-username=[username for HTTP authentication]:user' \
  '--authentication-password=[password for HTTP authentication]:password' \
  '--ssl-ca=[location of the CA certificate (.pem)]:file:_files' \
  '--ssl-private-key=[location of the SSL private key (.pem)]:file:_files' \
  '--ssl-certificate=[location of the SSL certificate (.pem)]:file:_files' && ret=0

return ret
