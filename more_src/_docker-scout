#compdef docker-scout

# Zsh completion for docker scout - Docker image analysis

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'compare:compare two images'
  'cves:display CVEs for an image'
  'enroll:enroll an organization with Docker Scout'
  'environment:manage environments'
  'integration:manage integrations'
  'policy:evaluate policies'
  'push:push an image analysis'
  'quickview:quick overview of an image'
  'recommendations:display recommendations'
  'repo:manage repositories'
  'sbom:generate SBOM for an image'
  'stream:manage streams'
  'version:show version'
  'watch:watch repositories for new images'
)

_arguments -s -S \
  '--debug[debug mode]' \
  '--org=[namespace of Docker organization]:org:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'docker scout command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      cves)
        _arguments \
          '--format=[output format]:format:(packages sarif json)' \
          '--locations[print package locations]' \
          '--only-fixed[filter to only fixed CVEs]' \
          '--only-unfixed[filter to only unfixed CVEs]' \
          '--only-severity=[filter by severity]:severity:(critical high medium low unspecified)' \
          '--only-package=[filter by package name]:package:' \
          '--only-package-type=[filter by package type]:type:(apk deb rpm npm pip gem golang nuget)' \
          '--org=[namespace of Docker organization]:org:' \
          '--platform=[platform of image]:platform:' \
          '--exit-code[return exit code based on findings]' \
          '*:image:'
        ;;
      quickview)
        _arguments \
          '--org=[namespace of Docker organization]:org:' \
          '--platform=[platform of image]:platform:' \
          '*:image:'
        ;;
      sbom)
        _arguments \
          '--format=[output format]:format:(list spdx syft cyclonedx)' \
          '--org=[namespace of Docker organization]:org:' \
          '--platform=[platform of image]:platform:' \
          '--output=[write output to file]:file:_files' \
          '*:image:'
        ;;
    esac
    ;;
esac

return ret
