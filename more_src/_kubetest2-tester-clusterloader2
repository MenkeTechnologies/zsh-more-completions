#compdef kubetest2-tester-clusterloader2
# _kubetest2-tester-clusterloader2 — kubetest2 tester running ClusterLoader2 scale tests (kubernetes-sigs/kubetest2)
# upstream: https://github.com/kubernetes-sigs/kubetest2
# Flags from pkg/testers/clusterloader2/cl2.go (gpflag).

_kubetest2-tester-clusterloader2() {
    _arguments \
        '*--suites=[scale testing suite (e.g. load density)]:suite:(load density)' \
        '*--test-overrides=[config override files]:file:_files' \
        '*--test-configs=[test config files]:file:_files' \
        '--provider=[cluster provider]:provider:(gke gce skeleton aws kind)' \
        '--kubeconfig=[kubeconfig path]:file:_files' \
        '--repo-root=[path to kubernetes/perf-tests repo]:dir:_files -/' \
        '--report-dir=[directory for summary files]:dir:_files -/' \
        '--nodes=[number of nodes (0=auto-detect)]:n:' \
        '--enable-prometheus-server[set up prometheus server in the cluster]' \
        '--prometheus-pvc-storage-class=[prometheus PVC storage class]:class:' \
        '--extra-args=[additional clusterloader2 arguments]:args:'
}

_kubetest2-tester-clusterloader2 "$@"
