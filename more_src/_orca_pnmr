#compdef orca_pnmr
# Documentation: https://www.faccts.de/docs/orca/6.0/manual/contents/detailed/utilities.html
# Compute paramagnetic NMR shielding from EPR g, A and D tensors

local ret=1

_arguments -s -S \
  '-i[read input from BaseName.pnmr.inp]' \
  '-v[verbose output]' \
  '*:base name' && ret=0

return ret
