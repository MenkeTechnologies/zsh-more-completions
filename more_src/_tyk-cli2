#compdef tyk-cli2 tyk2
# _tyk-cli2 — Tyk Technologies tyk-cli2 CLI command-line frontend wrapping the Tyk Open Source API Gateway full lifecycle API management on premise cloud and hybrid open-source written in Go originally written by Martin Buhr now Tyk Technologies platform built around Tyk Gateway Tyk Dashboard Tyk Pump Tyk Sync API Definitions OAS-OpenAPI Postman SwaggerImporter portal RPC start stop pump bundle build push pull sync get apis policies hashed-keys gateway dashboard portal users orgs analytics certs cluster certificate (Tyk Technologies team Martin Buhr Leonid Bugaev, Go); custom argparse
# upstream: https://tyk.io/

_tyk-cli2() {
    local -a sub=(
        'start:start Tyk Gateway'
        'stop:stop Tyk Gateway'
        'bundle:bundle plugin'
        'lint:lint API definitions'
        'import:import APIs'
        'sync:sync APIs'
        'dump:dump APIs'
        'publish:publish APIs'
        'pump:run Tyk Pump'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "tyk.conf *.conf *.yaml *.yml *.json"' \
        '--conf=+[file]:file:_files -g "tyk.conf *.conf *.yaml *.yml *.json"' \
        '--log-level=+[l]:l:(debug info warning error)' \
        '--log-format=+[f]:f:(text json)' \
        '--debug[debug]' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--memprofile[memory profile]' \
        '--cpuprofile[CPU profile]' \
        '--block-profile=+[N]:n:' \
        '--httpprofile[HTTP profile]' \
        '--mutex-profile=+[N]:n:' \
        '--coprocess[coprocess]' \
        '--coprocess-grpc-server=+[url]:str:' \
        '--openssl-conf=+[file]:file:_files' \
        '--enable-coprocess[enable coprocess]' \
        '--no-pid[no PID file]' \
        '--pid-file=+[file]:file:_files -g "*.pid"' \
        '--db-app-conf-options-tags=+[tags]:str:' \
        '--use-db-app-configs[use DB app configs]' \
        '--use-rpc-config[use RPC config]' \
        '--dashboard-connection-string=+[url]:str:' \
        '--policies-source=+[s]:s:(file service rpc)' \
        '--policy-record-name=+[file]:file:_files' \
        '--policy-connection-string=+[url]:str:' \
        '--app-path=+[dir]:dir:_files -/' \
        '--middleware-path=+[dir]:dir:_files -/' \
        '--manifest=+[file]:file:_files -g "manifest.json *.json"' \
        '--dashboard-url=+[url]:str:' \
        '--secret=+[secret]:str:' \
        '--auth=+[token]:str:' \
        '--target=+[url]:str:' \
        '--swagger=+[file]:file:_files' \
        '--upstream=+[url]:str:' \
        '--listen-path=+[path]:str:' \
        '--as-mock[as mock]' \
        '--update[update existing]' \
        '--cmd=+[cmd]:str:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--gateway-secret=+[secret]:str:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tyk subcommand' sub ;;
        args)
            case $words[1] in
                bundle) _arguments '1:op:(build push pull)' '*:arg:' ;;
                sync) _arguments '1:op:(publish dump rich-dump)' '*:arg:' ;;
                pump) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_tyk-cli2 "$@"
