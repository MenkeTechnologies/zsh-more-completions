#compdef glfsheal
# Documentation: https://man.archlinux.org/search?q=glfsheal
# Reference accessed: 2026-05-16

# glfsheal: GlusterFS self-heal info / management
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  'info[show heal info]' \
  'info-summary[show heal summary]' \
  'split-brain-info[show split-brain info]' \
  'statistics[show heal statistics]' \
  'statistics-heal-count[show heal counts]' \
  'heal-failed[show failed heal entries]' \
  'granular-entry-heal[granular entry heal]' \
  'enable[enable heal]' \
  'disable[disable heal]' \
  'glusterfs-logical-path[resolve logical path]' \
  '1:VOLNAME:' \
  '*::glfsheal args:_files' && ret=0
return ret
