#compdef pcf2bdf
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/pcf2bdf.1.html
# Convert X11 PCF font files to BDF format

local ret=1

_arguments -s -S \
  '-v[very verbose output]' \
  '-o[write bdf to named file instead of stdout]:output file:_files' \
  '*:pcf font file:_files -g "*.pcf(|.gz)"' && ret=0

return ret
