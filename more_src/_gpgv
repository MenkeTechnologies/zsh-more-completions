#compdef gpgv
# Documentation: gpgv --help on gpgv (GnuPG) 2.5.20
# Source: GnuPG gpgv — check signatures against known trusted keys (no keyring management).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-q --quiet)'{-q,--quiet}'[somewhat more quiet]' \
    '*--keyring=[take keys from KEYRING file]:file:_files' \
    '(-o --output)'{-o,--output=}'[write output to FILE]:file:_files' \
    '--ignore-time-conflict[timestamp conflicts only a warning]' \
    '--status-fd=[write status info to this FD]:fd:' \
    '*--weak-digest=[reject signatures made with ALGO]:algo:(MD5 SHA1 SHA224 SHA256 SHA384 SHA512 RIPEMD160)' \
    '*'{-N,--print-notation=}'[print notation NAME to stdout]:name:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:signed file:_files' \
    && ret=0

return ret
