#compdef textadept

# Zsh completion for textadept - editor

_arguments -s -S \
  '(-e --execute)'{-e,--execute}'[execute Lua code]:code:' \
  '(-f --force)'{-f,--force}'[force unique instance]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --line)'{-l,--line}'[jump to LINE number]:line:' \
  '(-n --nosession)'{-n,--nosession}'[do not load session on startup]' \
  '(-p --preserve)'{-p,--preserve}'[preserve ^Q and ^S flow control sequences]' \
  '(-s --session)'{-s,--session}'[load session file NAME]:name:_files' \
  '(-u --userhome)'{-u,--userhome}'[set user data directory to DIR]:directory:_files -/' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '*:files:_files'
