#compdef xh-rs
# Documentation: https://man.archlinux.org/search?q=xh-rs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-j --json)'{-j,--json}'[(default) JSON request]' \
  '(-f --form)'{-f,--form}'[form-encoded body]' \
  '(--multipart)--multipart[multipart body]' \
  '(--raw)--raw=[raw body]:b:' \
  '(--pretty)--pretty=[pretty]:p:(all colors format none)' \
  '(-s --style)'{-s+,--style=}'[output style]:s:(auto solarized monokai fruity)' \
  '(--response-charset)--response-charset=[charset]:c:' \
  '(--response-mime)--response-mime=[mime]:m:' \
  '(-p --print)'{-p+,--print=}'[print options]:opts:' \
  '(-h --headers)'{-h,--headers}'[print headers only]' \
  '(-b --body)'{-b,--body}'[print body only]' \
  '(-m --meta)'{-m,--meta}'[print meta]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(--debug)--debug[debug]' \
  '(--all)--all[print all responses]' \
  '(-P --history-print)'{-P+,--history-print=}'[history print]:opts:' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-S --stream)'{-S,--stream}'[stream output]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-d --download)'{-d,--download}'[download]' \
  '(-c --continue)'{-c,--continue}'[continue download]' \
  '(--session)--session=[session name]:s:' \
  '(--session-read-only)--session-read-only=[read-only session]:s:' \
  '(-A --auth-type)'{-A+,--auth-type=}'[auth type]:t:(basic bearer digest)' \
  '(-a --auth)'{-a+,--auth=}'[auth user[:pass]]:auth:' \
  '(--bearer)--bearer=[bearer token]:t:' \
  '(--ignore-netrc)--ignore-netrc[ignore netrc]' \
  '(--offline)--offline[offline]' \
  '(--check-status)--check-status[exit-code on HTTP errors]' \
  '(-F --follow)'{-F,--follow}'[follow redirects]' \
  '(--max-redirects)--max-redirects=[max redirects]:n:' \
  '(--max-headers)--max-headers=[max headers]:n:' \
  '(--timeout)--timeout=[timeout]:t:' \
  '(--proxy)*--proxy=[proxy URL]:url:' \
  '(--verify)--verify=[verify cert]:v:(yes no PATH)' \
  '(--cert)--cert=[client cert]:file:_files' \
  '(--cert-key)--cert-key=[client key]:file:_files' \
  '(--ssl)--ssl=[TLS version]:v:(auto tls1 tls1.1 tls1.2 tls1.3)' \
  '(--https)--https[default to https]' \
  '(--http-version)--http-version=[HTTP version]:v:(1.0 1.1 2 2-prior-knowledge)' \
  '(-I --ignore-stdin)'{-I,--ignore-stdin}'[ignore stdin]' \
  '(-x --proxy)*'{-x+,--proxy=}'[proxy]:p:' \
  '(--curl)--curl[print equivalent curl]' \
  '(--curl-long)--curl-long[print long curl]' \
  '(--no-keepalive)--no-keepalive[no keep-alive]' \
  '(--print-config-paths)--print-config-paths[print config paths]' \
  '(--generate)--generate=[generate completion]:shell:(bash zsh fish powershell elvish)' \
  '*: :' && ret=0

return ret
