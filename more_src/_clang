#compdef clang clang++ cc gcc g++
# Documentation: clang --help (LLVM)
# Source: LLVM clang — C / C++ / Objective-C compiler driver.
# Reference accessed: 2026-06-10
# NOTE: covers the most-used flags; clang exposes thousands. For full
# coverage rely on the live `clang --help-hidden` output.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-###[print but do not run compilation commands]' \
    '--analyze[run static analyzer]' \
    '--analyzer-output=[static analyzer report format]:fmt:(html plist plist-multi-file plist-html sarif sarif-html text)' \
    '*-B+[search PREFIX for executables/libs/data]:prefix:_files -/' \
    '-CC[preserve comments through macros]' \
    '--config=[configuration file]:file:_files' \
    '-c[compile only; do not link]' \
    '-E[run preprocessor only]' \
    '-S[compile to assembly; do not assemble]' \
    '*-D+[define preprocessor macro]:NAME[=VALUE]:' \
    '*-U+[undefine preprocessor macro]:NAME:' \
    '*-I-[include directory]:dir:_files -/' \
    '*-iquote-[quote-include directory]:dir:_files -/' \
    '*-isystem-[system-include directory]:dir:_files -/' \
    '*-idirafter-[include directory after system]:dir:_files -/' \
    '*-include+[force-include header]:file:_files' \
    '*-imacros+[include macros from file]:file:_files' \
    '*-F-[framework search directory]:dir:_files -/' \
    '-nostdinc[skip standard include path]' \
    '-nostdinc++[skip C++ standard include path]' \
    '-nostdlib[skip standard library at link]' \
    '-static[produce static binary]' \
    '-shared[produce shared library]' \
    '-fPIC[position-independent code]' \
    '-fPIE[position-independent executable]' \
    '-pie[link a PIE]' \
    '-pthread[enable pthreads]' \
    '-g[generate debug info]' \
    '-g0[no debug info]' \
    '-g1[minimal debug info]' \
    '-g3[max debug info incl macros]' \
    '-gdwarf[DWARF debug info]' \
    '-O[optimize (=O1)]' \
    '-O0[no optimization]' \
    '-O1[level-1 optimization]' \
    '-O2[level-2 optimization]' \
    '-O3[level-3 optimization]' \
    '-Os[optimize for size]' \
    '-Oz[optimize aggressively for size]' \
    '-Ofast[fastest; sacrifices IEEE]' \
    '-W*[warning flag]:warning:' \
    '-w[suppress all warnings]' \
    '-Werror[treat warnings as errors]' \
    '-Wall[enable common warnings]' \
    '-Wextra[enable extra warnings]' \
    '-Wpedantic[strict ISO compliance warnings]' \
    '-std=[language standard]:std:(c89 c90 c99 c11 c17 c23 gnu89 gnu90 gnu99 gnu11 gnu17 gnu23 c++98 c++03 c++11 c++14 c++17 c++20 c++23 c++26 gnu++98 gnu++03 gnu++11 gnu++14 gnu++17 gnu++20 gnu++23 gnu++26)' \
    '-x+[input language]:lang:(c c-header c++ c++-header objective-c objective-c++ assembler cuda hip ir)' \
    '-arch+[Darwin architecture]:arch:(i386 x86_64 x86_64h arm64 arm64e)' \
    '-target+[target triple]:triple:' \
    '-mcpu=[target CPU]:cpu:' \
    '-mtune=[tune for CPU]:cpu:' \
    '-march=[target architecture]:arch:' \
    '-isysroot+[system root]:dir:_files -/' \
    '--sysroot=[system root]:dir:_files -/' \
    '*-L-[library search directory]:dir:_files -/' \
    '*-l-[link with library]:lib:' \
    '-Wl,*[pass options to linker]:opt:' \
    '-Xlinker+[pass arg to linker]:arg:' \
    '-rpath+[runtime library search path]:dir:_files -/' \
    '-o+[output file]:file:_files' \
    '-v[verbose]' \
    '-fsanitize=[runtime sanitizer]:san:(address thread memory undefined leak dataflow cfi safe-stack)' \
    '-fopenmp[enable OpenMP]' \
    '-fno-rtti[disable RTTI]' \
    '-fno-exceptions[disable exceptions]' \
    '-fexceptions[enable exceptions]' \
    '-fvisibility=[symbol visibility]:vis:(default hidden internal protected)' \
    '-fstack-protector[enable stack protector]' \
    '-fstack-protector-strong[strong stack protector]' \
    '-fstack-protector-all[all stack protector]' \
    '-fno-stack-protector[disable stack protector]' \
    '-flto[link-time optimization]' \
    '-flto=[LTO mode]:mode:(thin full)' \
    '-fcolor-diagnostics[colorize diagnostics]' \
    '-fno-color-diagnostics[no color diagnostics]' \
    '-fdiagnostics-show-template-tree[show C++ template diff tree]' \
    '-ferror-limit=[max errors to emit]:n:' \
    '-fmessage-length=[wrap diagnostics at N cols]:n:' \
    '--help[show help]' \
    '--help-hidden[show hidden help]' \
    '--version[show version]' \
    '*:source file:_files -g "*.{c,cc,cpp,cxx,c++,m,mm,h,hh,hpp,hxx,S,s,o,a,dylib,so}"' \
    && ret=0

return ret
