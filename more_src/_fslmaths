#compdef fslmaths
# fslmaths — mathematical operations on neuroimaging volumes

_fslmaths_operations=(
  '-add:add following input or value'
  '-sub:subtract following input or value'
  '-mul:multiply by following input or value'
  '-div:divide by following input or value'
  '-rem:modulus remainder'
  '-abs:absolute value'
  '-bin:binarise (threshold at 0)'
  '-recip:reciprocal'
  '-sqrt:square root'
  '-sqr:square'
  '-log:natural logarithm'
  '-exp:exponential'
  '-nan:replace NaN with 0'
  '-nanm:create NaN mask'
  '-rand:add uniform random noise'
  '-randn:add Gaussian random noise'
  '-thr:threshold below value'
  '-uthr:upper threshold above value'
  '-max:max of image and following input'
  '-min:min of image and following input'
  '-inm:intensity normalisation to mean'
  '-ing:intensity normalisation global'
  '-range:set output range'
  '-Tmean:mean across time'
  '-Tstd:standard deviation across time'
  '-Tmin:min across time'
  '-Tmax:max across time'
  '-Tmedian:median across time'
  '-kernel:set kernel (gauss/sphere/box/file)'
  '-fmean:mean filter'
  '-fmedian:median filter'
  '-dilM:mean dilation of nonzero voxels'
  '-eroF:erosion filter'
  '-edge:edge detection'
  '-mas:apply mask image'
  '-roi:extract ROI (xmin xsize ymin ysize zmin zsize tmin tsize)'
  '-odt:output data type (char/short/int/float/double/input)'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:input volume:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '*:: :_files -g "*.{nii,nii.gz,img,hdr}"'
