#compdef staraniso
# Documentation: https://www.globalphasing.com/staraniso/manual/staraniso.html
# STARANISO - anisotropy analysis and Bayesian estimation of structure factors

local ret=1

_arguments -s -S \
  'HKLIN[input MTZ file containing reflection data]:mtz:_files' \
  'HKLOUT[output MTZ file for processed reflection data]:mtz:_files' \
  'DISP=-[enable display/output mode]:flag:(t f)' \
  'LABF=-[output MTZ labels for structure factor amplitudes]:labels' \
  '*:keyword or file:_files' && ret=0

return ret
