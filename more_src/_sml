#compdef sml
# Documentation: https://man.archlinux.org/search?q=sml
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '@SMLload=+[load image]:file:_files' \
  '@SMLalloc=+[arena size kb]:kb:' \
  '@SMLrun=+[run-time options]:opts:' \
  '@SMLversion[print version]' \
  '@SMLverbose[verbose]' \
  '@SMLquiet[quiet]' \
  '@SMLdebug=+[debug file]:file:_files' \
  '-m+[load mlb]:file:_files -g "*.mlb"' \
  '-32[32-bit mode]' \
  '-64[64-bit mode]' \
  '-Cprint.depth=+[print depth]:n:' \
  '-Ccm.verbose=+[CM verbose]:b:(true false)' \
  '*:sml file:_files -g "*.{sml,sig,ml}"' && ret=0

return ret
