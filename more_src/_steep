#compdef steep

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:type-check Ruby source code'
  'stats:show statistics of the type check'
  'init:generate Steepfile in the current directory'
  'langserver:start language server'
  'watch:watch mode for type checking'
  'binstub:generate binstubs'
  'project:manage projects'
  'vendor:vendor RBS files'
  'checkfile:type-check a single file'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'steep command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      check)
        _arguments -s -S \
          '--steepfile=[specify Steepfile]:file:_files' \
          '--log-level=[set log level]:level:(fatal error warn info debug)' \
          '--log-output=[set log output]:output:_files' \
          '--severity-level=[set severity level]:level:(warning error information hint)' \
          '--with-expectations[check expectations]' \
          '--save-expectations[save expectations]' \
          '-j+[set number of jobs]:count' \
          '--jobs=[set number of jobs]:count' \
          '*:file:_files -g "*.rb"' && ret=0
        ;;
      watch)
        _arguments -s -S \
          '--steepfile=[specify Steepfile]:file:_files' \
          '--log-level=[set log level]:level:(fatal error warn info debug)' \
          '-j+[set number of jobs]:count' \
          '--jobs=[set number of jobs]:count' && ret=0
        ;;
      langserver)
        _arguments -s -S \
          '--steepfile=[specify Steepfile]:file:_files' \
          '--log-level=[set log level]:level:(fatal error warn info debug)' \
          '--log-output=[set log output]:output:_files' \
          '-j+[set number of jobs]:count' \
          '--jobs=[set number of jobs]:count' && ret=0
        ;;
      init)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
