#compdef raidautorun
# Documentation: https://man.archlinux.org/search?q=raidautorun
# Reference accessed: 2026-05-16

# raidautorun: legacy tool to auto-detect RAID partitions and start arrays
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-v[verbose]' \
  '*:raid device:_files -g "/dev/md*"' && ret=0
return ret
