#compdef zef

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install dependencies by name or path'
  'uninstall:uninstall specified distributions'
  'test:run tests on a distribution path'
  'fetch:fetch and extract distribution source'
  'build:run the builder for a distribution path'
  'look:fetch and shell into the distribution path'
  'update:update package indexes for repositories'
  'upgrade:upgrade specific distributions'
  'search:show distribution candidates for the given terms'
  'info:show detailed distribution information'
  'browse:open browser to various support URLs'
  'list:list available or installed distributions'
  'depends:list all dependencies for an identity'
  'rdepends:list distributions depending on an identity'
  'locate:lookup installed module info'
  'smoke:run smoke testing on available modules'
  'nuke:delete directory/prefix matching config path or CURLI name'
)

_arguments -C \
  '(- *)--version[show version]' \
  '--install-to=[short name or spec of CompUnit::Repository to install to]:name:' \
  '--config-path=[path to zef config file]:file:_files' \
  '--fetch-timeout=[fetch timeout in seconds]:seconds:' \
  '--extract-timeout=[extract timeout in seconds]:seconds:' \
  '--build-timeout=[build timeout in seconds]:seconds:' \
  '--test-timeout=[test timeout in seconds]:seconds:' \
  '--install-timeout=[install timeout in seconds]:seconds:' \
  '--fetch-degree=[parallel fetch jobs]:n:' \
  '--test-degree=[parallel test jobs]:n:' \
  '--update[force refresh of all module indexes]' \
  '--update=-[force refresh for ecosystem]:ecosystem:' \
  '--/update[skip refreshing all module indexes]' \
  '--/update=-[skip refresh for ecosystem]:ecosystem:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'zef command' subcommands && ret=0
    ;;
esac

return ret
