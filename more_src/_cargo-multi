#compdef cargo-multi
# Documentation: https://man.archlinux.org/search?q=cargo-multi
# Reference accessed: 2026-05-16

# https://gitlab.com/imp/cargo-multi — run cargo commands across workspace crates

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::cargo_multi_arguments:_default' && return 0
