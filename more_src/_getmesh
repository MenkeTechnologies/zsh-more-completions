#compdef getmesh
# Documentation: https://istio.tetratelabs.io/
# getmesh: CLI to manage certified, compliant and tested Istio distributions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(fetch switch list version check-upgrade config-validate istioctl gen-ca prune show update mesh completion)' \
  '*::arg:->args' && ret=0

return ret
