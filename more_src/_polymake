#compdef polymake

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '-A+[application name]:application:(polytope fan graph matroid topaz tropical fulton ideal common)' \
  '--reconfigure[reconfigure settings]' \
  '--config-path=[configuration file]:file:_files' \
  '-d[debug mode]' \
  '-v[verbose mode]' \
  '--script=[run script]:script:_files' \
  '--iscript=[run interactive script]:script:_files' \
  '-n[no output]' \
  '--touch[touch modified files]' \
  '--ignore-schedule[ignore scheduling]' \
  '*:file or expression:_files' && ret=0

return ret
