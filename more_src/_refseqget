#compdef refseqget
# Documentation: https://man.archlinux.org/search?q=refseqget
# Reference accessed: 2026-05-16

# EMBOSS refseqget: read and write reference sequence entries from a
# refseq data resource (e.g. UniRef, RefSeq genomic).
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show command-line help and exit]' \
  '-auto[turn off prompts; use defaults]' \
  '-stdout[write to stdout]' \
  '-filter[stdin/stdout filter mode]' \
  '-options[force prompts for ACD qualifiers]' \
  '-debug[debug log]' \
  '-verbose[verbose informational output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[print version]' \
  '-refsequence=[input reference sequence USA (e.g. embl-rod:human)]:USA:' \
  '-outrefseq=[output reference sequence file]:file:_files' \
  '-orformat=[output reference sequence format]:format:(fasta embl genbank refseq refseqp)' \
  '-orname=[base name for split output files]:name:' \
  '-orextension=[extension for output files]:ext:' \
  '*:reference sequence USA:' && ret=0

return ret
