#compdef dragonfly

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[Show help]' \
  '(- *)--version[Show version]' \
  '--port[Port to listen on]:port' \
  '--bind[Bind address]:address' \
  '--requirepass[Set password]:password' \
  '--maxmemory[Maximum memory limit]:bytes' \
  '--dbfilename[RDB filename]:filename' \
  '--dir[Working directory]:directory:_files -/' \
  '--save_schedule[Cron expression for RDB save schedule]:schedule' \
  '--keys_output_limit[Limit for keys output]:limit' \
  '--hz[Server frequency]:hz' \
  '--tcp_backlog[TCP listen backlog]:number' \
  '--timeout[Client idle timeout in seconds]:seconds' \
  '--tcp-keepalive[TCP keepalive interval]:seconds' \
  '--loglevel[Log level]:level:(debug verbose notice warning)' \
  '--logfile[Log file path]:file:_files' \
  '--databases[Number of databases]:number' \
  '--proactor_threads[Number of proactor threads]:threads' \
  '--cache_mode[Enable cache mode]' \
  '--snapshot_cron[Cron expression for snapshots]:cron' \
  '--dbnum[Number of databases]:number' \
  '--memcached_port[Memcached compatible port]:port' \
  '--admin_port[Admin port]:port' \
  '--primary_port_http_enabled[Enable HTTP on primary port]' \
  '--admin_nopass[Allow admin connections without password]' \
  '*:config file:_files' && ret=0

return ret
