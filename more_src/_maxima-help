#compdef maxima-help
# Documentation: https://man.archlinux.org/search?q=maxima-help
# Reference accessed: 2026-05-16

# maxima-help: GUI launcher for Maxima online help
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*:topic:' && ret=0
return ret
