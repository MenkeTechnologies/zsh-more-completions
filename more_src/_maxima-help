#compdef maxima-help
# Documentation: https://maxima.sourceforge.io/docs/manual/maxima_singlepage.html
# Reference accessed: 2026-05-19
# Verified: maxima-help is a thin launcher script for Maxima online help with no
# documented command-line interface in the upstream Maxima manual.
# STUB: minimal completion (topic argument plus standard help).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*:topic:' && ret=0
return ret
