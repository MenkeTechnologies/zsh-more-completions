#compdef doctoc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--notitle[do not add a title to the table of contents]' \
  '--maxlevel=[limit TOC entries to headings up to this level]:level:(1 2 3 4 5 6)' \
  '--entryprefix=[prefix for each TOC entry]:prefix' \
  '--title=[title for the table of contents]:title' \
  '--github[use GitHub-compatible anchors]' \
  '--gitlab[use GitLab-compatible anchors]' \
  '--bitbucket[use Bitbucket-compatible anchors]' \
  '--nodejs[use Node.js-compatible anchors]' \
  '--ghost[use Ghost-compatible anchors]' \
  '-u[update only existing TOC]' \
  '--update-only[update only existing TOC]' \
  '-s[make TOC links use stdout]' \
  '--stdout[print result to stdout]' \
  '*:file or directory:_files' && ret=0

return ret
