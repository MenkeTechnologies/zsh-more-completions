#compdef nix-direnv-reload nix-direnv
# Documentation: https://github.com/nix-community/nix-direnv
# Reference accessed: 2026-05-27
# Verified: upstream direnvrc (nix-community/nix-direnv)
# Note: nix-direnv is a direnv stdlib extension (sourced from $XDG_CONFIG_HOME/direnv/direnvrc),
#       not a standalone CLI. The only executable it installs is `nix-direnv-reload`, a generated
#       shim placed under "$(direnv_layout_dir)/bin/nix-direnv-reload" by _nix_direnv_preflight.
#       That shim takes no flags or positional arguments; it just calls
#       `_nix_direnv_force_reload=1 direnv exec "$PWD" true`.
#       The direnvrc-exported names (use_flake, use_nix, nix_direnv_version,
#       nix_direnv_watch_file, nix_direnv_manual_reload, nix_direnv_disallow_fallback)
#       are direnv .envrc helpers, not shell commands, so they have no completion surface.

local curcontext="$curcontext" state line ret=1

_arguments \
  '(- *)'{-h,--help}'[show help (passthrough; not consumed by the script itself)]' \
  '*: :_files' && ret=0

return ret
