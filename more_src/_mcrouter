#compdef mcrouter
# Documentation: https://github.com/facebook/mcrouter/wiki/Command-line-options
# Memcached protocol router for scaling memcached deployments

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --config-file)'{-f,--config-file=}'[config file to use]:file:_files' \
  '--config-str=[configure from a JSON string]:json:' \
  '--validate-config[check config for syntax errors and exit]' \
  '(-R --route-prefix)'{-R,--route-prefix=}'[default routing prefix]:prefix:' \
  '(-p --port)'{-p,--port}'+[port(s) to listen on, comma separated]:ports:' \
  '--num-proxies=[run with N proxy threads]:n:' \
  '(-t --server-timeout)'{-t,--server-timeout=}'[destination timeout in ms]:ms:' \
  '--timeouts-until-tko=[mark soft TKO after this many timeouts]:n:' \
  '(-r --probe-timeout-initial)'{-r,--probe-timeout-initial=}'[initial TKO probe interval]:ms:' \
  '(-K --keepalive-count)'{-K,--keepalive-count=}'[TCP KEEPALIVE count]:n:' \
  '(-i --keepalive-interval)'{-i,--keepalive-interval=}'[TCP KEEPALIVE interval]:n:' \
  '(-I --keepalive-idle)'{-I,--keepalive-idle=}'[TCP KEEPALIVE idle time]:n:' \
  '--stats-root=[root directory for stats files]:dir:_files -/' \
  '--stats-logging-interval=[time between stat file updates]:ms:' \
  '(-L --log-path)'{-L,--log-path=}'[path for log file]:file:_files' && ret=0

return ret
