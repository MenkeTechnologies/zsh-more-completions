#compdef mfcal
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/mfcal.html
# MIRIAD mfcal - bandpass and gain calibration for multichannel data

local ret=1

_arguments -s -S \
  'vis=[input visibility data file]:vis:_files' \
  'line=[line type specification]:line' \
  'stokes=[Stokes parameters to process]:stokes' \
  'edge=[channels to drop at window edges]:edge' \
  'select=[uv selection]:select' \
  'flux=[source flux, reference freq GHz, spectral index]:flux' \
  'refant=[reference antenna]:refant' \
  'minants=[minimum antenna count for a solution]:minants' \
  'interval=[gain and passband intervals in minutes]:interval' \
  'tol=[solution convergence tolerance]:tol' \
  'options=[delay,nopassol,interpolate,oldflux]:options' \
  '*:visibility data:_files' && ret=0

return ret
