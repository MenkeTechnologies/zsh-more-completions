#compdef pvresize
# _pvresize — resize a physical volume (LVM2); update the LVM PV size to use the full underlying device
# upstream: https://gitlab.com/lvmteam/lvm2

_pvresize() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-y --yes)'{-y,--yes}'[no prompts]' \
        '--setphysicalvolumesize+[force size]:size:' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '*:pv device:_files'
}

_pvresize "$@"
