#compdef kubectl-klock
# kubectl-klock (krew plugin): real-time events view of Kubernetes objects
# https://github.com/applejag/kubectl-klock

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[watch all namespaces]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-l --selector)'{-l+,--selector=}'[label selector]:selector' \
  '--field-selector=[field selector]:selector' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(wide)' \
  '--no-headers[do not print headers]' \
  '--show-kind[show resource kind]' \
  '--show-labels[show all labels]' \
  '--sort-by=[sort field]:field' \
  '*:resource type'
