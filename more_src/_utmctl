#compdef utmctl
# Documentation: https://docs.getutm.app/scripting/scripting/
# command-line control of UTM virtual machines on macOS

local ret=1
local -a subcmds

subcmds=(
  'list:enumerate all registered virtual machines'
  'status:query the status of a virtual machine'
  'start:start a VM or resume a suspended VM'
  'suspend:suspend a running VM to memory'
  'stop:shut down a running VM'
  'attach:redirect serial input/output to this terminal'
  'file:guest agent file operations'
  'exec:execute an application on the guest'
  'ip-address:list IP addresses of the guest network interfaces'
  'clone:clone an existing VM'
  'delete:delete a virtual machine'
  'usb:USB device handling'
  'version:display the version number'
)

_arguments -s -S \
  '(-d --debug)'{-d,--debug}'[show debug logging]' \
  '--hide[hide the main UTM window]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'utmctl command' subcmds && ret=0 ;;
esac

return ret
