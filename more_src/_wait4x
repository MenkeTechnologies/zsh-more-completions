#compdef wait4x
# Documentation: https://man.archlinux.org/search?q=wait4x
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--timeout[timeout duration]:duration' \
  '--interval[check interval duration]:duration' \
  '--backoff-policy[backoff policy]:policy:(constant exponential)' \
  '--backoff-exponential-max-interval[max interval for exponential backoff]:duration' \
  '--invert-check[invert the check result]' \
  '--log-level[log level]:level' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'http:wait for HTTP endpoint'
      'tcp:wait for TCP connection'
      'mysql:wait for MySQL connection'
      'postgresql:wait for PostgreSQL connection'
      'redis:wait for Redis connection'
      'mongodb:wait for MongoDB connection'
      'rabbitmq:wait for RabbitMQ connection'
      'influxdb:wait for InfluxDB connection'
      'temporal:wait for Temporal connection'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      http)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*--status-code[expected HTTP status code]:code' \
          '--timeout[request timeout]:duration' \
          '--method[HTTP method]:method' \
          '*--header[HTTP header]:header' \
          '--body[request body]:body' \
          '--expect-body-json[expected JSON in response body]:json' \
          '--expect-body-xpath[expected XPath in response body]:xpath' \
          '--no-redirect[do not follow redirects]' \
          '--insecure-skip-tls-verify[skip TLS verification]' \
          ':url' && ret=0
        ;;
      tcp)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':address (host\:port)' && ret=0
        ;;
      mysql)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':dsn' && ret=0
        ;;
      postgresql)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':dsn' && ret=0
        ;;
      redis)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--password[Redis password]:password' \
          '--key[key to check]:key' \
          ':url' && ret=0
        ;;
      mongodb)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':url' && ret=0
        ;;
      rabbitmq)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':url' && ret=0
        ;;
      influxdb)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':url' && ret=0
        ;;
      temporal)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':address' && ret=0
        ;;
    esac
    ;;
esac

return ret
