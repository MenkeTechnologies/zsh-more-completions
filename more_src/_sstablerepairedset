#compdef sstablerepairedset

local curcontext="$curcontext" state line ret=1

_arguments \
  '--really-set[confirm set (required)]' \
  '--is-repaired[mark as repaired]' \
  '--is-unrepaired[mark as unrepaired]' \
  '-f+[file with sstable list]:file:_files' \
  '*:sstable:_files' && ret=0

return ret
