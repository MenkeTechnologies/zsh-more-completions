#compdef sstablerepairedset
# Documentation: https://cassandra.apache.org/doc/latest/cassandra/managing/tools/sstable/sstablerepairedset.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '--really-set[confirm set (required)]' \
  '--is-repaired[mark as repaired]' \
  '--is-unrepaired[mark as unrepaired]' \
  '-f+[file with sstable list]:file:_files' \
  '*:sstable:_files' && ret=0

return ret
