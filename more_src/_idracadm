#compdef idracadm

# Dell iDRAC racadm CLI (older version)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-r[remote iDRAC IP]:ip:' \
  '-u[username]:user:' \
  '-p[password]:pwd:' \
  '-i[interactive prompt for password]' \
  '-s[SSH mode]' \
  '*::racadm subcommand:_files' && ret=0
return ret
