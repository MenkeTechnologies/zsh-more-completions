#compdef simplifyify
# Documentation: https://github.com/JS-DevTools/simplifyify
# Reference accessed: 2026-05-23
# Verified: simplifyify --help usage from README.

# Zsh completion for simplifyify - Browserify/Watchify bundler CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bundle)'{-b,--bundle}'[create non-minified bundle]' \
  '(-m --minify)'{-m,--minify}'[create minified bundle]' \
  '(-c --coverage)'{-c,--coverage}'[coverage-instrumented bundle]' \
  '(-d --debug)'{-d,--debug}'[emit source maps]' \
  '(-w --watch)'{-w,--watch}'[watch and rebuild]' \
  '(-o --outfile)'{-o+,--outfile=}'[output file or directory]:dest:' \
  '(-x --exclude)'{-x+,--exclude=}'[exclude glob]:pattern:' \
  '(-s --standalone)'{-s+,--standalone=}'[UMD export name]:name:' \
  '*:source:_files' && ret=0

return ret
