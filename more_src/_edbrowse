#compdef edbrowse

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-c[edit default config file]' \
  '-e[exit on error (batch mode)]' \
  '-m+[mail interactive reader]:account:' \
  '-f[fetch mail from all accounts]' \
  '-fm[fetch and read email interactively]' \
  '-pm[mail without filters]' \
  '-pfm[fetch and read without filters]' \
  '-d0[silent debug]' \
  '-d1[file/page sizes]' \
  '-d2[URL and redirects]' \
  '-d3[javascript exec and errors]' \
  '-d4[socket connections and headers]' \
  '-d5[messages to/from javascript]' \
  '-d6[show javascript to execute]' \
  '-d7[reformatted regex]' \
  '-d8[freed lines, gc]' \
  '*: :_files' && ret=0

return ret
