#compdef edbrowse
# Documentation: http://edbrowse.org/usersguide.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help / usage]' \
  '-v[show version]' \
  '-c[edit default config file (.ebrc)]' \
  '-e[exit on error (batch mode)]' \
  '-m+[mail interactive reader / send mail]:account:' \
  '-f[fetch mail from all accounts]' \
  '-fm[fetch and read email interactively]' \
  '-pm[mail without filters]' \
  '-pfm[fetch and read without filters]' \
  '-b[browse each file/URL or activate plugins]' \
  '-d0[silent debug]' \
  '-d1[file/page sizes (default)]' \
  '-d2[URL and redirects]' \
  '-d3[javascript exec and errors]' \
  '-d4[socket connections and headers]' \
  '-d5[messages to/from javascript]' \
  '-d6[show javascript to execute]' \
  '-d7[reformatted regex]' \
  '-d8[freed lines, gc]' \
  '-d9[maximum debug]' \
  '*: :_files' && ret=0

return ret
