#compdef puredns

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'bruteforce:bruteforce subdomains using a wordlist'
      'resolve:resolve a list of domains'
      'wildcards:detect wildcard domains'
    )
    _describe -t commands 'puredns command' commands && ret=0
    ;;
  args)
    case $line[1] in
      bruteforce)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-r,--resolvers}'=[file with DNS resolvers]:resolver file:_files' \
          {-d,--domains}'=[file with root domains]:domains file:_files' \
          {-n,--resolvers-trusted}'=[file with trusted resolvers]:trusted resolvers:_files' \
          {-l,--limit}'=[limit of public DNS queries per second]:limit' \
          '--rate-limit=[limit of trusted DNS queries per second]:rate' \
          '--wildcard-tests=[number of wildcard tests]:count' \
          '--wildcard-batch=[batch size for wildcard detection]:size' \
          {-q,--quiet}'[quiet mode]' \
          {-w,--write}'=[output file for valid domains]:output file:_files' \
          '--write-massdns=[output file for massdns results]:output file:_files' \
          '--write-wildcards=[output file for wildcard domains]:output file:_files' \
          '--skip-sanitize[skip sanitization of input]' \
          '--skip-wildcard[skip wildcard detection]' \
          '--skip-validation[skip initial validation of resolvers]' \
          '--bin=[path to massdns binary]:massdns binary:_files' \
          '1:wordlist:_files' \
          '2:domain' && ret=0
        ;;
      resolve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-r,--resolvers}'=[file with DNS resolvers]:resolver file:_files' \
          {-n,--resolvers-trusted}'=[file with trusted resolvers]:trusted resolvers:_files' \
          {-l,--limit}'=[limit of public DNS queries per second]:limit' \
          '--rate-limit=[limit of trusted DNS queries per second]:rate' \
          '--wildcard-tests=[number of wildcard tests]:count' \
          '--wildcard-batch=[batch size for wildcard detection]:size' \
          {-q,--quiet}'[quiet mode]' \
          {-w,--write}'=[output file for valid domains]:output file:_files' \
          '--write-massdns=[output file for massdns results]:output file:_files' \
          '--write-wildcards=[output file for wildcard domains]:output file:_files' \
          '--skip-sanitize[skip sanitization of input]' \
          '--skip-wildcard[skip wildcard detection]' \
          '--skip-validation[skip initial validation of resolvers]' \
          '--bin=[path to massdns binary]:massdns binary:_files' \
          '1:domain list:_files' && ret=0
        ;;
      wildcards)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-r,--resolvers}'=[file with DNS resolvers]:resolver file:_files' \
          {-n,--resolvers-trusted}'=[file with trusted resolvers]:trusted resolvers:_files' \
          '--wildcard-tests=[number of wildcard tests]:count' \
          '--wildcard-batch=[batch size for wildcard detection]:size' \
          {-q,--quiet}'[quiet mode]' \
          {-w,--write}'=[output file for valid domains]:output file:_files' \
          '1:domain list:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
