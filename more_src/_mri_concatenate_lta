#compdef mri_concatenate_lta
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_concatenate_lta
# Concatenate two LTA transforms into one

local ret=1

_arguments -s -S \
  '-tal[source/template files when lta2 is talairach.xfm]:src:_files:template:_files' \
  '-invert1[reverse transformation of lta_1 before application]' \
  '-invert2[reverse transformation of lta_2 before application]' \
  '-invertout[reverse the final output LTA]' \
  '-out_type[output LTA format 0=VOX2VOX 1=RAS2RAS]:type:(0 1)' \
  '-subject[subject identifier in output LTA]:subject:' \
  '-rmsdiff[RMS difference between transforms]:radius:outfile:_files' \
  '*:lta file:_files' && ret=0

return ret
