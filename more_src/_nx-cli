#compdef nx
# _nx-cli — Nx monorepo build system (Nrwl); affected-graph, caching, task orchestration for JS/Go/Rust/etc.
# upstream: https://github.com/nrwl/nx

_nx-cli() {
    local -a sub=(
        'init:initialize nx in current repo'
        'add:add a plugin'
        'affected:run for affected projects'
        'build:build a project'
        'serve:serve a project'
        'test:test a project'
        'lint:lint a project'
        'e2e:run e2e tests'
        'run:run any target'
        'run-many:run a target for many projects'
        'generate:run a generator'
        'g:alias for generate'
        'graph:open project graph in browser'
        'list:list installed plugins'
        'migrate:migrate workspace + deps'
        'report:print env diagnostic info'
        'reset:reset nx cache and daemon'
        'show:show project/projects info'
        'connect:connect workspace to nx cloud'
        'release:run release lifecycle'
        'sync:sync changes from generators'
        'view-logs:view daemon log'
        'watch:watch workspace and run target'
        'workspace-generator:run workspace generator'
        'daemon:control nx daemon'
        'login:login to nx cloud'
        'logout:logout from nx cloud'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--verbose[verbose log]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nx subcommand' sub ;;
        args)
            case $words[1] in
                run|run-many|affected|build|serve|test|lint|e2e) _arguments \
                    '--target+[target]:target:' \
                    '--projects+[projects]:projects:' \
                    '--all[run for all projects]' \
                    '--exclude+[exclude projects]:projects:' \
                    '--parallel+[parallel jobs]:n:' \
                    '--configuration+[configuration]:cfg:' \
                    '--skip-nx-cache[skip cache]' \
                    '--watch[watch]' \
                    '--head+[head ref]:ref:' \
                    '--base+[base ref]:ref:' ;;
                generate|g) _arguments \
                    '1:generator:' \
                    '--dry-run[dry run]' \
                    '--interactive[force prompts]' \
                    '--no-interactive[no prompts]' \
                    '*:args:' ;;
                migrate) _arguments \
                    '--from+[from versions]:str:' \
                    '--to+[to versions]:str:' \
                    '--run-migrations[execute pending migrations]' ;;
                show) _arguments '1:show what:(projects project)' '*:project:' ;;
                daemon) _arguments '1:daemon cmd:(start stop status)' ;;
            esac
            ;;
    esac
}

_nx-cli "$@"
