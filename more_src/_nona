#compdef nona

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-o+[output filename]:file:_files' \
  '-m+[output format]:fmt:(JPEG JPEG_m TIFF TIFF_m TIFF_multilayer TIFF_multilayer_mask PNG PNG_m HDR HDR_m EXR EXR_m)' \
  '-z+[TIFF compression]:type:(NONE LZW DEFLATE PACKBITS)' \
  '-c[use cropped TIFF]' \
  '-r ldr[output LDR]' \
  '-r hdr[output HDR]' \
  '-e+[exposure layers]:val:' \
  '-i+[image to interpolate]:n:' \
  '-g+[interp function]:fn:(poly3 spline16 spline36 sinc256 spline64 bilinear nearest sinc1024)' \
  '-t+[threads]:n:' \
  '-S+[crop output to ROI]:roi:' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
