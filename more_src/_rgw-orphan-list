#compdef rgw-orphan-list
# Documentation: https://docs.ceph.com/en/latest/man/8/rgw-orphan-list/
# rgw-orphan-list - list potentially orphaned RADOS objects for an RGW pool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:pool:_message "rados pool name"' && ret=0

return ret
