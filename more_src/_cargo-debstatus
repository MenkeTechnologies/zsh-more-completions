#compdef cargo-debstatus
# Documentation: https://github.com/kpcyrd/cargo-debstatus
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-p --package)'{-p,--package}'=[root package]:pkg:' \
  '--include=[workspace include]:list:' \
  '--exclude=[workspace exclude]:list:' \
  '--features=[features]:list:' \
  '--all-features[all features]' \
  '--no-default-features[no defaults]' \
  '--target=[triple]:triple:' \
  '--all-targets[all targets]' \
  '--skip-cache[skip disk cache]' \
  '(-j --concurrency)'{-j,--concurrency}'=[connections]:n:' \
  '--no-dev-dependencies[skip dev]' \
  '--manifest-path=[manifest]:file:_files' \
  '(-w --collapse-workspace)'{-w,--collapse-workspace}'[collapse workspace]' \
  '(-i --invert)'{-i,--invert}'[invert tree]' \
  '--no-indent[list mode]' \
  '--prefix-depth[prefix depth]' \
  '(-a --all)'{-a,--all}'[no truncate]' \
  '--json[JSON output]' \
  '(-d --duplicate)'{-d,--duplicate}'[duplicates only]' \
  '--charset=[charset]:charset:(utf8 ascii)' \
  '(-f --format)'{-f,--format}'=[format]:fmt:' \
  '*'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--color=[when]:when:(auto always never)' \
  '--frozen[frozen]' \
  '--locked[locked]' \
  '--offline[offline]' \
  '*-Z[unstable]:flag:'
