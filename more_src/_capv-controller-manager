#compdef capv-controller-manager
# _capv-controller-manager — Cluster API vSphere provider controller manager (CAPV)
# upstream: https://github.com/kubernetes-sigs/cluster-api-provider-vsphere
# Flags from main.go (pflag) on tip.

_capv-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-election-id=[leader-election lock name]:name:' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--namespace=[restrict CAPV to a single namespace]:ns:' \
        '--watch-filter=[watch-filter label value]:value:' \
        '--profiler-address=[pprof bind address]:host\:port:' \
        '--contention-profiling[enable contention profiling]' \
        '*--skip-crd-migration-phases=[CRD migration phases to skip]:list:' \
        '--sync-period=[informer resync period]:dur:' \
        '--kube-api-qps=[Kubernetes API QPS]:f:' \
        '--kube-api-burst=[Kubernetes API burst]:n:' \
        '--clustercache-client-qps=[clustercache client QPS]:f:' \
        '--clustercache-client-burst=[clustercache client burst]:n:' \
        '--clustercache-concurrency=[clustercache concurrent reconciles]:n:' \
        '--vspherecluster-concurrency=[VSphereCluster concurrent reconciles]:n:' \
        '--vspheremachine-concurrency=[VSphereMachine concurrent reconciles]:n:' \
        '--vspheremachinetemplate-concurrency=[VSphereMachineTemplate concurrent reconciles]:n:' \
        '--providerserviceaccount-concurrency=[ProviderServiceAccount concurrent reconciles]:n:' \
        '--servicediscovery-concurrency=[ServiceDiscovery concurrent reconciles]:n:' \
        '--vspherevm-concurrency=[VSphereVM concurrent reconciles]:n:' \
        '--vsphereclusteridentity-concurrency=[VSphereClusterIdentity concurrent reconciles]:n:' \
        '--vspheredeploymentzone-concurrency=[VSphereDeploymentZone concurrent reconciles]:n:' \
        '--virtualmachinegroup-concurrency=[VirtualMachineGroup concurrent reconciles]:n:' \
        '--pod-name=[name of the manager pod]:name:' \
        '--credentials-file=[supervisor credentials file]:file:_files' \
        '--network-provider=[supervisor network provider]:name:' \
        '--vm-operator-api-version=[VM Operator API version]:ver:' \
        '--webhook-port=[webhook server port]:port:' \
        '--webhook-cert-dir=[webhook serving cert dir]:dir:_files -/' \
        '--webhook-cert-name=[webhook cert file name]:name:' \
        '--webhook-key-name=[webhook key file name]:name:' \
        '--health-addr=[health probe bind address]:host\:port:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_capv-controller-manager "$@"
