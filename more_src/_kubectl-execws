#compdef kubectl-execws
# Documentation: https://man.archlinux.org/search?q=kubectl-execws
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '(-i --stdin)'{-i,--stdin}'[stdin]' \
  '(-t --tty)'{-t,--tty}'[tty]' \
  '*:args:_default'
