#compdef cargo-script

# Zsh completion for cargo-script - run Rust scripts

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'script:run a Rust script'
      'expr:evaluate a Rust expression'
      'loop:run a Rust loop expression'
      'templates:manage script templates'
      'file-association:manage file associations'
      'pkg-path:show where script packages are stored'
      'clear-cache:clear compilation cache'
    )
    _describe -t commands 'cargo-script command' commands && ret=0
    ;;
  args)
    case $line[1] in
      script)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--build-only[only build, do not run]' \
          '--count[count iterations]' \
          '--debug[compile in debug mode]' \
          '-e+[extra dependency]:dependency' \
          '--dep=[extra dependency]:dependency' \
          '-x+[extra extern crate]:crate' \
          '--extern=[extra extern crate]:crate' \
          '--features=[features to enable]:features' \
          '--force[force recompilation]' \
          '--gen-pkg-only[generate package only]' \
          '--loop=[loop expression]:expression' \
          '--pkg-path[print package path]' \
          '--test[compile and run tests]' \
          '--bench[compile and run benchmarks]' \
          '1:script:_files -g "*.rs"' \
          '*:script arguments' && ret=0
        ;;
      expr)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-e+[extra dependency]:dependency' \
          '--dep=[extra dependency]:dependency' \
          '1:expression' && ret=0
        ;;
      loop)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-e+[extra dependency]:dependency' \
          '--dep=[extra dependency]:dependency' \
          '--count[output iteration count]' \
          '1:expression' && ret=0
        ;;
    esac
    ;;
esac

return ret
