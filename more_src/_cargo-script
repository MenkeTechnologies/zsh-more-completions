#compdef cargo-script
# Documentation: https://github.com/DanielKeep/cargo-script
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Note: DanielKeep/cargo-script is unmaintained as of 2026-05-17;
# `rust-script` (https://github.com/fornwall/rust-script) is the
# maintained fork.  Built-in `cargo script` from Cargo proper is
# experimental as of this date (RFC 3424).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--build-only[only build, do not run]' \
  '--count[count iterations (with --loop)]' \
  '--debug[compile in debug mode]' \
  '*-e+[extra dependency spec]:dependency' \
  '*--dep=[extra dependency spec]:dependency' \
  '*-x+[extra extern crate]:crate' \
  '*--extern=[extra extern crate]:crate' \
  '--features=[features to enable]:features' \
  '--force[force recompilation]' \
  '--gen-pkg-only[generate package only, do not compile]' \
  '--expr=[evaluate expression]:expression' \
  '--loop=[loop over stdin lines]:expression' \
  '--pkg-path[print package path]' \
  '--test[compile and run tests]' \
  '--bench[compile and run benchmarks]' \
  '--clear-cache[clear cargo-script cache]' \
  '--templates[print available templates]' \
  '--unstable-features=[unstable features]:feature' \
  '1:script:_files -g "*.rs"' \
  '*:script arguments' && ret=0

return ret
