#compdef tsarr
# Documentation: https://man.archlinux.org/search?q=tsarr
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a top_commands services

top_commands=(
  'config:configure tsarr (init/set/show)'
  'doctor:test connections to all services'
  'completions:install shell completion'
  'help:show help'
)

services=(
  'radarr:Radarr (movies)'
  'sonarr:Sonarr (TV)'
  'lidarr:Lidarr (music)'
  'readarr:Readarr (books)'
  'prowlarr:Prowlarr (indexers)'
  'bazarr:Bazarr (subtitles)'
  'qbittorrent:qBittorrent client'
  'seerr:Overseerr/Jellyseerr'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--instance=[named instance]:instance:' \
  '--table[table output]' \
  '--json[JSON output]' \
  '--quiet[IDs only output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

local -a actions=(
  'list:list resources'
  'get:get a single resource'
  'create:create a resource'
  'update:update a resource'
  'delete:delete a resource'
  'search:trigger a search'
  'refresh:refresh metadata'
)

case $state in
  (cmd)
    _alternative \
      'svcs:service:_describe -t svcs "service" services' \
      'cmds:top-level command:_describe -t cmds "command" top_commands' && ret=0 ;;
  (args)
    case $line[1] in
      (radarr)
        _arguments '*::resource:(movie moviefile profile tag queue rootfolder system history calendar notification downloadclient blocklist wanted importlist customformat)' && ret=0
        _describe -t actions 'action' actions ;;
      (sonarr)
        _arguments '*::resource:(series episode episodefile profile tag queue rootfolder system history calendar notification downloadclient blocklist wanted importlist)' && ret=0 ;;
      (lidarr)
        _arguments '*::resource:(artist album trackfile profile tag queue rootfolder system history calendar notification downloadclient blocklist wanted importlist)' && ret=0 ;;
      (readarr)
        _arguments '*::resource:(author book bookfile profile tag queue rootfolder system history calendar notification downloadclient blocklist wanted importlist)' && ret=0 ;;
      (prowlarr)
        _arguments '*::resource:(indexer search app tag indexerstats notification downloadclient system)' && ret=0 ;;
      (bazarr)
        _arguments '*::resource:(series movie episode provider language system)' && ret=0 ;;
      (qbittorrent)
        _arguments '*::resource:(torrents status)' && ret=0 ;;
      (seerr)
        _arguments '*::resource:(requests search users status)' && ret=0 ;;
      (config)
        _arguments '*::sub:(init set show test)' && ret=0 ;;
      (completions)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
