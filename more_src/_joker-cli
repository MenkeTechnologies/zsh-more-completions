#compdef joker-cli
# _joker-cli — Roman Bataev joker small Clojure interpreter and linter in Go CLI alias (candid82 team, Go); custom argparse
# upstream: https://github.com/candid82/joker

_joker-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-e+[expression]:str:' \
        '--eval=+[expression]:str:' \
        '--lint[lint mode]' \
        '--lintclj[lint as clj]' \
        '--lintcljs[lint as cljs]' \
        '--lintjoker[lint as joker]' \
        '--lintedn[lint as edn]' \
        '--working-dir=+[working dir]:dir:_files -/' \
        '--exit-to-repl[start repl on lint error]' \
        '--no-readline[no readline]' \
        '--profile=+[profile name]:str:' \
        '--hashmap-threshold=+[threshold]:n:' \
        '--rules=+[rules file]:file:_files' \
        '--cpuprofile=+[file]:file:_files' \
        '--memprofile=+[file]:file:_files' \
        '--no-color[no color]' \
        '--repl[start repl]' \
        '*:files:_files -g "*.{clj,cljs,cljc,joke,edn}"'
}

_joker-cli "$@"
