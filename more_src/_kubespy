#compdef kubespy

# Zsh completion for Kubespy - observing Kubernetes resources in real time

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'trace:Trace changes to a Kubernetes resource'
      'status:Watch the status of a Kubernetes resource'
      'changes:Watch for changes to a Kubernetes resource'
    )
    _describe -t commands 'kubespy command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      trace|status|changes)
        _arguments -s -S \
          '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]:namespace' \
          '--kubeconfig=[path to kubeconfig]:kubeconfig file:_files' \
          '--context=[Kubernetes context]:context' \
          '-h[show help]' \
          '--help[show help]' \
          '1:resource type:(deploy deployment service svc pod configmap cm secret ingress statefulset daemonset job cronjob)' \
          '2:resource name' && ret=0
        ;;
    esac
    ;;
esac

return ret
