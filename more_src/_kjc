#compdef kjc
# Documentation: (Debian manpage unreachable)
# Reference accessed: 2026-05-16
# Verified: kjc upstream documentation unreachable (Debian manpage
# returns 404). KOPI Java Compiler uses GNU getopt with javac-
# compatible options. Conservative javac-compatible subset retained
# per "do not delete files" directive.
# Removed from prior file: fabricated -h/--help/-V/--version generic
# flags and bogus man.archlinux.org search URL.

# kjc: KOPI Java Compiler (javac-compatible)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-d[output directory]:dir:_files -/' \
  '-classpath[class search path]:path:_files -/' \
  '-sourcepath[source search path]:path:_files -/' \
  '-source[source release]:release:' \
  '-target[target release]:release:' \
  '-encoding[source encoding]:encoding:' \
  '*:Java source:_files -g "*.java(-.)"' && ret=0
return ret
