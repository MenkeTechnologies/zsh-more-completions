#compdef kjc
# Documentation: https://github.com/kopiLeft/Kopi/blob/master/src/org/kopi/kopi/comp/kjc/KjcOptions.xml
# Reference accessed: 2026-05-19
# Verified: upstream KOPI KjcOptions.xml option definitions at the URL.
# Corrected from prior file: real options come from KjcOptions.xml.
# Removed fabricated -sourcepath/-target; classpath is -C/--classpath
# (not -classpath); added -b/-j/-n/-w/--nowarn/-O/-D/-t/-g/-A/-f.

# kjc: KOPI Java Compiler

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(-b --beautify)'{-b,--beautify}'[beautify the source code]' \
  '(-v --verbose)'{-v,--verbose}'[print verbose progress information]' \
  '(-j --java)'{-j,--java}'[generate Java source instead of bytecode]' \
  '(-e --encoding)'{-e,--encoding}'[source file encoding]:encoding:' \
  '(-n --nowrite)'{-n,--nowrite}'[do not write any class files]' \
  '(-w --warning)'{-w,--warning}'[warning level]:level:' \
  '--nowarn[generate no warnings]' \
  '(-O --optimize)'{-O,--optimize}'[optimization level]:level:' \
  '(-D --deprecation)'{-D,--deprecation}'[report use of deprecated APIs]' \
  '(-t --extdirs)'{-t,--extdirs}'[extension directories]:dirs:_files -/' \
  '(-d --destination)'{-d,--destination}'[output directory for class files]:dir:_files -/' \
  '(-C --classpath)'{-C,--classpath}'[class search path]:path:_files -/' \
  '(-g --debug)'{-g,--debug}'[generate debugging information]' \
  '(-s --source)'{-s,--source}'[source release level]:release:' \
  '(-A --assertion)'{-A,--assertion}'[assertion handling]:mode:' \
  '(-f --filter)'{-f,--filter}'[message filter class]:filter:' \
  '*:Java source:_files -g "*.java(-.)"' && ret=0
return ret
