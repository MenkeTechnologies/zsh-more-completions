#compdef sfhalfint
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mhalfint.c
# Madagascar: half-order integration or differentiation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'adj=[if y, apply adjoint]:flag:(y n)' \
  'inv=[if y, do differentiation instead of integration]:flag:(y n)' \
  'rho=[leaky integration constant]:value' \
  '*:RSF file:_files' && ret=0

return ret
