#compdef openmpt123
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/openmpt123.1.html
# Reference accessed: 2026-05-20
# Verified: openmpt123(1) manpage - command line libopenmpt module player.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--help-keyboard[show UI keyboard hotkeys]' \
  '(- *)--version[show version]' \
  '--short-version[show version number only]' \
  '--long-version[show extended version information]' \
  '--credits[display contributor list]' \
  '--license[show license text]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '--info[show module info]' \
  '--ui[interactive UI mode]' \
  '--batch[batch mode]' \
  '--render[render to file]' \
  '--probe[probe module without playing]' \
  '--banner[show banner]' \
  '--no-banner[suppress banner]' \
  '--progress[show playback progress]' \
  '--no-progress[hide playback progress]' \
  '--meters[show peak meters]' \
  '--no-meters[hide peak meters]' \
  '--channel-meters[show channel peak meters (experimental)]' \
  '--no-channel-meters[hide channel peak meters]' \
  '--pattern[show pattern (experimental)]' \
  '--no-pattern[hide pattern display]' \
  '--details[show song details]' \
  '--no-details[hide song details]' \
  '--message[show song message]' \
  '--no-message[hide song message]' \
  '--terminal-width=[terminal width]:n:' \
  '--terminal-height=[terminal height]:n:' \
  '--update=[UI refresh interval (ms)]:ms:' \
  '--driver=[output driver]:driver:(default sdl2 alsa pulseaudio waveout coreaudio portaudio sndio jack)' \
  '--device=[output device]:device:' \
  '--buffer=[buffer size (ms)]:ms:' \
  '--period=[period size (ms)]:ms:' \
  '--stdout[stream raw audio to standard output]' \
  '--output-type=[PCM output type (render mode)]:type:' \
  '(-o --output)'{-o+,--output=}'[write to file instead of device]:file:_files' \
  '--force[overwrite existing output files]' \
  '--samplerate=[sample rate]:rate:(8000 11025 22050 44100 48000 88200 96000 192000)' \
  '--channels=[output channels]:n:(1 2 4)' \
  '--float[float output]' \
  '--no-float[16-bit integer output]' \
  '--gain=[output gain (dB)]:dB:' \
  '--stereo=[stereo separation]:percent:' \
  '--filter=[filter taps]:n:(1 2 4 8)' \
  '--ramping=[ramping]:n:' \
  '--dither=[dithering method]:n:(0 1 2 3)' \
  '--tempo=[playback speed multiplier]:mult:' \
  '--pitch=[pitch multiplier]:mult:' \
  '--subsong=[subsong index, -1=all]:n:' \
  '--repeat=[repeat count, -1=loop forever]:n:' \
  '--seek=[seek to second]:seconds:' \
  '--end-time=[stop after seconds]:seconds:' \
  '--playlist=[load song list from file]:file:_files' \
  '--randomize[randomize playlist order]' \
  '--no-randomize[do not randomize playlist]' \
  '--shuffle[shuffle playback]' \
  '--no-shuffle[do not shuffle]' \
  '--restart[auto-restart at end]' \
  '--no-restart[do not auto-restart]' \
  '--ctl=[set libopenmpt ctl]:k=v:' \
  '*:module file:_files' && ret=0

return ret
