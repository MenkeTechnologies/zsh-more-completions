#compdef reldist
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/reldist.html
# relative distance distribution between two sets (bedtools reldist)

local ret=1

_arguments -s -S \
  '-a[BED/GFF/VCF file A]:file:_files' \
  '-b[BED/GFF/VCF file B]:file:_files' \
  '-detail[report relative distance for each A interval]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
