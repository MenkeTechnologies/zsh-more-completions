#compdef mdbook-include-filter
# _mdbook-include-filter — filter included content by #hashtag/@mention (d4nyl0/mdbook-include-filter)
# upstream: https://github.com/d4nyl0/mdbook-include-filter
# Subcommand from src/main.rs (clap App).

_mdbook-include-filter() {
    _arguments \
        '1:command:(supports)' \
        '2:renderer:(html epub markdown latex)'
}

_mdbook-include-filter "$@"
