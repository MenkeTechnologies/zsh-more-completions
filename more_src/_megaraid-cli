#compdef megaraid-cli
# Documentation: https://man.archlinux.org/search?q=megaraid-cli
# Reference accessed: 2026-05-16

# megaraid-cli: wrapper around storcli/MegaCli (distro packaging)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*::megaraid-cli args:_files' && ret=0
return ret
