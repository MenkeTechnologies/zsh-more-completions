#compdef gambas3
# Documentation: http://gambaswiki.org/wiki/doc/cmdline
# Source: Gambas BASIC v3 command-line interpreter (gbx3 entry point).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-V,--full-version}'[show full version]' \
    '(- *)'{-h,--help}'[show help]' \
    '(-L --license)'{-L,--license}'[show license]' \
    '(-f --fast)'{-f,--fast}'[fast arithmetic mode]' \
    '(-s --safe-mode)'{-s,--safe-mode}'[safe mode]' \
    '(-t --trace)'{-t,--trace}'[trace mode]' \
    '(-T --term)'{-T,--term}'[run in terminal]' \
    '(-q --quit)'{-q,--quit}'[quit after compilation]' \
    '(-Q --query)'{-Q,--query}'[query the application]' \
    '(-l --library-path)'{-l+,--library-path=}'[specify library path]:dir:_files -/' \
    '*::project file or class:_files' \
    && ret=0

return ret
