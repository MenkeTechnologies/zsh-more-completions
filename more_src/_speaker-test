#compdef speaker-test
# Documentation: https://manpages.debian.org/speaker-test.1
# Source: alsa-utils — multichannel speaker positional / pink-noise test signal.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-c --channels)'{-c+,--channels=}'[N channels in stream]:n:' \
    '(-D --device)'{-D+,--device=}'[PCM device name]:name:' \
    '(-f --frequency)'{-f+,--frequency=}'[sine wave frequency (Hz)]:hz:' \
    '(- *)--help[print usage help]' \
    '(-b --buffer)'{-b+,--buffer=}'[buffer size in usec]:usec:' \
    '(-p --period)'{-p+,--period=}'[period size in usec]:usec:' \
    '(-P --nperiods)'{-P+,--nperiods=}'[number of periods]:n:' \
    '(-r --rate)'{-r+,--rate=}'[stream rate (Hz)]:hz:(8000 16000 22050 32000 44100 48000 88200 96000 176400 192000)' \
    '(-t --test)'{-t+,--test=}'[test type]:type:(pink st2095 sine wav)' \
    '(-l --nloops)'{-l+,--nloops=}'[number of loops]:n:' \
    '(-s --speaker)'{-s+,--speaker=}'[single-shot test for given channel]:channel:' \
    '(-w --wavfile)'{-w+,--wavfile=}'[WAV file for playback]:file:_files -g "*.wav"' \
    '(-W --wavdir)'{-W+,--wavdir=}'[directory of WAV files for playback]:dir:_directories' \
    '(-m --chmap)'{-m+,--chmap=}'[channel map override]:map:' \
    '(-X --force-frequency)'{-X,--force-frequency}'[allow frequency outside 30-8000 Hz]' \
    && ret=0

return ret
