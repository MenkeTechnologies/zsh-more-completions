#compdef copyhd
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/copyhd.html
# MIRIAD copyhd - copy header items between datasets

local ret=1

_arguments -s -S \
  'in=[input data-set name]:in:_files' \
  'out=[output data-set name (must already exist)]:out:_files' \
  'items=[list of items to be copied across]:items' \
  '*:dataset:_files' && ret=0

return ret
