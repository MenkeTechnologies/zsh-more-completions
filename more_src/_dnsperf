#compdef dnsperf

# Zsh completion for dnsperf (DNS performance testing tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[local address to bind to]:address' \
  '-b[buffer size]:bytes' \
  '-c[number of concurrent connections]:count' \
  '-d[input data file]:file:_files' \
  '-D[enable DNSSEC DO bit]' \
  '-e[enable EDNS]:size' \
  '-E[DNS-over-HTTPS]:url' \
  '-f[address family]:family:(inet inet6 any)' \
  '-h[show help]' \
  '-l[run length in seconds]:seconds' \
  '-m[transport mode]:mode:(udp tcp dot doh)' \
  '-n[max number of queries]:count' \
  '-O[set socket option]:option' \
  '-p[port]:port' \
  '-q[max outstanding queries]:count' \
  '-Q[max queries per second]:qps' \
  '-s[server address]:address:_hosts' \
  '-S[stats interval in seconds]:seconds' \
  '-t[query timeout in seconds]:seconds' \
  '-T[number of threads]:threads' \
  '-u[update mode]' \
  '-v[verbose mode]' \
  '-V[show version]' \
  '-W[log warnings and above]' \
  '-x[local port]:port' \
  '-y[TSIG key]:name\:secret' && ret=0

return ret
