#compdef dnsperf
# Documentation: https://codeberg.org/DNS-OARC/dnsperf
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dnsperf (DNS performance testing tool from DNS-OARC)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[local address to bind to]:address' \
  '-b[buffer size in KB]:bytes' \
  '-B[read input in TCP-stream binary format]' \
  '-c[number of clients/connections]:count' \
  '-d[input data file]:file:_files' \
  '-D[set DNSSEC DO bit]' \
  '-e[enable EDNS 0]' \
  '-E[send EDNS option]:code\:value' \
  '-f[address family]:family:(inet inet6 any)' \
  '-j[JSON output]' \
  '-l[run length in seconds]:seconds' \
  '-m[transport mode]:mode:(udp tcp dot doh)' \
  '-n[max number of file passes]:count' \
  '-p[server port]:port' \
  '-q[max outstanding queries]:count' \
  '-Q[max queries per second]:qps' \
  '-s[server address]:address:_hosts' \
  '-S[stats interval in seconds]:seconds' \
  '-t[query timeout in seconds]:seconds' \
  '-T[number of threads]:threads' \
  '-u[send dynamic updates]' \
  '-v[verbose mode]' \
  '-W[log warnings and above to stdout]' \
  '-x[local port]:port' \
  '-y[TSIG key]:[alg\:]name\:secret' \
  '--doh-uri=[DoH URI template]:uri:' \
  '--doh-method=[DoH method]:method:(GET POST)' \
  '--suppress=[suppress message types]:types:' \
  '--num-queries-per-conn=[queries per connection]:n:' \
  '--verbose-interval-stats[verbose per-interval stats]' \
  '--latency-histogram[output latency histogram]' \
  '--qps-threshold-wait=[wait seconds when QPS threshold hit]:n:' \
  '--tls-sni=[TLS SNI hostname]:host:' && ret=0

return ret
