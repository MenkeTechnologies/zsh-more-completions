#compdef apt-cdrom-check
# Documentation: Ubuntu update-notifier
# Source: Ubuntu update-notifier apt-cdrom-check (sh) — check if mounted media is an apt CD.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:mount point:_files -/' \
    && ret=0

return ret
