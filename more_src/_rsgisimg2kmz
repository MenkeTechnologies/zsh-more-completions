#compdef rsgisimg2kmz
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgisimg2kmz RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input image.]:value:_files' \
  '(-o --output)'{-o,--output}'[Output KMZ.]:value:_files' \
  '(-b --bands)'{-b,--bands}'[Comma seperated set of bands. Either single or r,g,b.]:value:_files' \
  '(-n --noproj)'{-n,--noproj}'[Do not re-project the image to lat/long.]' \
  '(-f --finite)'{-f,--finite}'[Apply a finite mask to the input image before stretching.]' \
  '*:file:_files' && ret=0

return ret
