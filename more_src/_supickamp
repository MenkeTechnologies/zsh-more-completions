#compdef supickamp
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/picking/supickamp.c
# pick amplitudes within user defined and resampled window

local ret=1

_arguments -s -S \
  'd2=[sampling interval for slow dimension]:d2' \
  'key=[header word specifying trace offset]:key' \
  'x_above=[lateral position values for upper window corner]:x_above' \
  't_above=[time values for upper window corner]:t_above' \
  't_xabove=[file: time and lateral position for upper corner]:file:_files' \
  't_xbelow=[file: time and lateral position for lower corner]:file:_files' \
  'wl=[window width if t_xbelow not specified]:wl' \
  'dt_resamp=[resampling interval within pick window]:dt_resamp' \
  'tmin=[minimum time in input trace]:tmin' \
  'x2beg=[first lateral position]:x2beg' \
  'format=[output format]:format:(ascii binary)' \
  'verbose=[output detail level]:verbose' \
  'outpar=[output parameter file path]:file:_files' \
  'arg1=[first output dimension to stdout]:arg1' \
  'arg2=[second output dimension to stdout]:arg2' \
  '*:file:_files' && ret=0


return ret
