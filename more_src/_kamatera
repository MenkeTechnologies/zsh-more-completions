#compdef kamatera kamatera-cli
# _kamatera — Kamatera Inc kamatera official CLI for the Kamatera cloud servers networks images load balancers (Kamatera team, Python); click
# upstream: https://github.com/Kamatera/kamateracli

_kamatera() {
    local -a sub=(
        'auth:authentication subcommands'
        'init:initialize config'
        'configure:configure CLI'
        'server:server subcommands'
        'network:network subcommands'
        'image:image subcommands'
        'lb:load balancer subcommands'
        'firewall:firewall subcommands'
        'datacenter:datacenter subcommands'
        'service:service subcommands'
        'queue:queue subcommands'
        'task:task subcommands'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--api-clientid=+[client id]:str:' \
        '--api-secret=+[secret]:str:' \
        '--api-server=+[api server]:host:_hosts' \
        '--config=+[config file]:file:_files' \
        '--profile=+[profile]:str:' \
        '--output=+[format]:f:(yaml json table human)' \
        '-o+[format]:f:(yaml json table human)' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kamatera subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments '1:server cmd:(list info create configure reboot power-off power-on terminate clone snapshot resize disk-add disk-resize disk-delete network-add network-edit network-delete password-reset password-add)' ;;
                network|image|lb|firewall|datacenter|service|queue|task) _arguments '1:cmd:(list info create delete update)' ;;
                auth) _arguments '1:auth cmd:(login logout status)' ;;
                configure) _arguments '1:configure cmd:(list set unset)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_kamatera "$@"
