#compdef ntpq
# _ntpq — ntp-project ntpq (standard query program for an ntpd instance; reads peer/system variables, prints peer-list, supports interactive mode)
# upstream: https://github.com/ntp-project/ntp
# Flags from ntpq/ntpq-opts.def on tip (AutoOpts).

_ntpq() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[force IPv4 name resolution]' \
        '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[force IPv6 name resolution]' \
        '*'{-c+,--command=}'[run a single ntpq command and exit (repeatable)]:cmd:' \
        '(-d --debug-level)'{-d+,--debug-level=}'[increment debug level]:n:' \
        '(-i --interactive)'{-i,--interactive}'[force interactive mode]' \
        '(-n --numeric)'{-n,--numeric}'[show numeric host addresses]' \
        '(-p --peers)'{-p,--peers}'[print peer list]' \
        '(-r --refid)'{-r+,--refid=}'[default display type for S2+ refids]:type:(hash ipv4)' \
        '(-u --unconnected)'{-u,--unconnected}'[use unconnected UDP to talk to ntpd]' \
        '(-w --wide)'{-w,--wide}'[print the full remote value]' \
        '*:host:_hosts'
}

_ntpq "$@"
