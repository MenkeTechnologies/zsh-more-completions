#compdef gtkterm
# Documentation: https://manpages.debian.org/testing/gtkterm/gtkterm.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'+[load configuration]:name:' \
  '(-p --port)'{-p,--port}'+[serial port device]:port:_files -g "/dev/tty*"' \
  '(-s --speed)'{-s,--speed}'+[baud rate]:rate:(1200 2400 4800 9600 19200 38400 57600 115200 230400)' \
  '(-b --bits)'{-b,--bits}'+[data bits]:bits:(5 6 7 8)' \
  '(-t --stopbits)'{-t,--stopbits}'+[stop bits]:bits:(1 2)' \
  '(-a --parity)'{-a,--parity}'+[parity]:parity:(odd even)' \
  '(-w --flow)'{-w,--flow}'+[flow control]:fc:(Xon CTS)' \
  '(-d --delay)'{-d,--delay}'+[end-of-line delay ms]:ms:' \
  '(-r --char)'{-r,--char}'+[end-of-line special char]:char:' \
  '(-f --file)'{-f,--file}'+[default file to transmit]:file:_files' \
  '(-e --echo)'{-e,--echo}'[enable local echo]' \
  '(-x --rts_time_before)'{-x,--rts_time_before}'+[RS485 ms before TX with RTS]:ms:' \
  '(-y --rts_time_after)'{-y,--rts_time_after}'+[RS485 ms after TX with RTS]:ms:' \
  '(-L --disable-port-lock)'{-L,--disable-port-lock}'[disable serial port lock]' && ret=0

return ret
