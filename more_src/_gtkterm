#compdef gtkterm

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[config name]:name:' \
  '(-p --port)'{-p,--port}'+[serial port]:port:_files -g "/dev/tty*"' \
  '(-s --speed)'{-s,--speed}'+[baud rate]:rate:(1200 2400 4800 9600 19200 38400 57600 115200 230400)' \
  '(-b --bits)'{-b,--bits}'+[data bits]:bits:(5 6 7 8)' \
  '(-t --stopbits)'{-t,--stopbits}'+[stop bits]:bits:(1 2)' \
  '(-a --parity)'{-a,--parity}'+[parity]:parity:(none odd even)' \
  '(-w --flow-control)'{-w,--flow-control}'+[flow control]:fc:(none xon rtscts)' \
  '(-d --delay)'{-d,--delay}'+[char delay ms]:ms:' \
  '(-r --rs485-rts-time-before)'{-r,--rs485-rts-time-before}'+[before]:n:' \
  '(-R --rs485-rts-time-after)'{-R,--rs485-rts-time-after}'+[after]:n:' \
  '(-x --echo)'{-x,--echo}'[enable echo]' \
  '(-e --new-window)'{-e,--new-window}'[new window]' \
  '(-i --no-rs485)'{-i,--no-rs485}'[no rs485]' && ret=0

return ret
