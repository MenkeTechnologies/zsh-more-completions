#compdef repgrep

# Zsh completion for repgrep (interactive ripgrep TUI)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--hidden[search hidden files and directories]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case insensitive search]' \
  '(-s --case-sensitive)'{-s,--case-sensitive}'[case sensitive search]' \
  '(-S --smart-case)'{-S,--smart-case}'[smart case search]' \
  '(-w --word-regexp)'{-w,--word-regexp}'[match whole words only]' \
  '(-e --regexp)'{-e,--regexp}'[specify pattern]:pattern' \
  '(-g --glob)'{-g,--glob}'[include or exclude files matching glob]:glob' \
  '(-t --type)'{-t,--type}'[only search files matching type]:type' \
  '(-T --type-not)'{-T,--type-not}'[exclude files matching type]:type' \
  '--no-ignore[do not respect ignore files]' \
  '--max-depth[descend at most N directories]:depth' \
  '(-F --fixed-strings)'{-F,--fixed-strings}'[treat pattern as literal string]' \
  '1:pattern' \
  '*:path:_files'
