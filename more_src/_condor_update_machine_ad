#compdef condor_update_machine_ad
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_update_machine_ad.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_update_machine_ad: update a startd machine ad in the collector
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-pool[pool]:pool:' \
  '-name[startd name]:name:' \
  '*:input file:_files' && ret=0
return ret
