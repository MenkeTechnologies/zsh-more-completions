#compdef create-terraform-module
# Documentation: https://www.npmjs.com/package/create-terraform-module
# Reference accessed: 2026-05-24
# Verified: npm view create-terraform-module bin; npx create-terraform-module --help output.

# Zsh completion for create-terraform-module - Terraform module and workflow generator

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-o --organization)'{-o,--organization}'[override Terraform Cloud organization]:org:'   '(-t --token)'{-t,--token}'[override Terraform Cloud user token]:token:'   '(-V --version)'{-V,--version}'[output version]'   '(-h --help)'{-h,--help}'[output usage information]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' token organization && ret=0
    ;;
  args)
    case $line[1] in
      token|organization)
        _arguments -C ':value:' && ret=0
        ;;
      *)
        _arguments -C           ':module name:'           ':provider:' && ret=0
        ;;
    esac
    ;;
esac

return ret
