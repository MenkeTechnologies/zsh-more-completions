#compdef sfnmo3
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mnmo3.c
# Madagascar: 3-D normal moveout

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'half=[if y, second and third axes are half-offset instead of full offset]:flag:(y n)' \
  'offset=[input file with x,y offset pairs]:file:_files' \
  'eps=[stretch regularization]:value' \
  'mute=[mute zone]:samples' \
  'extend=[trace extension]:samples' \
  '*:RSF file:_files' && ret=0

return ret
