#compdef v0
# Documentation: https://man.archlinux.org/search?q=v0
# Reference accessed: 2026-05-16

_v0() {
    local line state
    local -a commands
    commands=(
        'add:Add a v0 component to your project'
        'help:Show help for v0'
    )

    _arguments -C \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'v0 command' commands
            ;;
        args)
            case $line[1] in
                add)
                    _arguments '1:block-id:'
                    ;;
            esac
            ;;
    esac
}

_v0 "$@"
