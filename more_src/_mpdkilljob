#compdef mpdkilljob
# Documentation: https://man.archlinux.org/search?q=mpdkilljob
# Reference accessed: 2026-05-16

# mpdkilljob: terminate an MPD job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '-v[verbose]' \
  '-f[hosts file]:file:_files' \
  '*::mpdkilljob args:_files' && ret=0
return ret
