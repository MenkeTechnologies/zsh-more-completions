#compdef callgrind_annotate callgrind_control
# _callgrind — Valgrind callgrind annotator + controller (Josef Weidendorfer, C); annotate cost data and control running instance
# upstream: https://valgrind.org

_callgrind() {
    _arguments \
        '--auto+[auto annotate]:bool:(yes no)' \
        '--show+[event types to show]:events:' \
        '--show-percs+[show pct]:bool:(yes no)' \
        '--inclusive+[inclusive cost]:bool:(yes no)' \
        '--mix-by+[mix by]:by:(thread context)' \
        '--threshold+[event threshold pct]:f:' \
        '--context+[context lines]:n:' \
        '--sort+[sort key]:key:' \
        '--no-show-summary[no summary]' \
        '--csv[csv output]' \
        '--separate-jumps[separate jumps]' \
        '--separate-callers+[separate callers depth]:n:' \
        '*:callgrind.out file:_files'
}

_callgrind "$@"
