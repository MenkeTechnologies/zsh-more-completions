#compdef cargo-tomlfmt
# format Cargo.toml

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --path)'{-p,--path}'[path to the manifest (default Cargo.toml)]:file:_files' \
  '(-d --dryrun)'{-d,--dryrun}'[do not overwrite the file]' \
  '(-k --keep)'{-k,--keep}'[keep the original manifest as Cargo.toml.bak]' \
  '(-c --create)'{-c,--create}'[create a formatted manifest as Cargo.toml.new when dryrun]' && ret=0

return ret
