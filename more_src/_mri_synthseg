#compdef mri_synthseg
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/SynthSeg
# FreeSurfer contrast-agnostic whole-brain segmentation

local ret=1

_arguments -s -S \
  '--i[input scan, folder, or text file listing images]:input:_files' \
  '--o[output segmentations]:output:_files' \
  '--parc[cortical parcellation alongside segmentation]' \
  '--robust[robust variant for low-SNR clinical data]' \
  '--fast[disable postprocessing for faster predictions]' \
  '--vol[CSV path to save region volumes]:vol.csv:_files' \
  '--qc[CSV path to save quality control scores]:qc.csv:_files' \
  '--post[path for 3D posterior probability outputs]:post:_files' \
  '--resample[save internally resampled images]:resample:_files' \
  '--crop[crop inputs to shape divisible by 32]:crop:' \
  '--threads[number of Tensorflow threads]:threads:' \
  '--cpu[execute on CPU instead of GPU]' \
  '--v1[run original SynthSeg 1.0]' \
  '--ct[process CT scans, clip to 0-80 HU]' \
  '--photo[segment reconstructed dissection photos]:hemi:(left right both)' && ret=0

return ret
