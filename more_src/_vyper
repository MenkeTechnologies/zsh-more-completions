#compdef vyper

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-f+[output format]:format:(abi abi_python asm bytecode bytecode_runtime combined_json devdoc external_interface interface ir ir_json layout metadata opcodes source_map userdoc)' \
  '--format=[output format]:format:(abi abi_python asm bytecode bytecode_runtime combined_json devdoc external_interface interface ir ir_json layout metadata opcodes source_map userdoc)' \
  '--evm-version=[set EVM version]:version:(shanghai paris london berlin istanbul petersburg constantinople byzantium spurious-dragon tangerine-whistle homestead frontier)' \
  '--no-optimize[disable optimizer]' \
  '--optimize=[optimization level]:level:(none gas codesize)' \
  '-o+[output directory]:directory:_directories' \
  '--output-dir=[output directory]:directory:_directories' \
  '-p+[search path for imports]:paths' \
  '--search-paths=[search path for imports]:paths' \
  '--storage-layout-file=[storage layout override]:file:_files -g "*.json"' \
  '--experimental-codegen[use experimental code generation]' \
  '--enable-decimals[enable decimal type]' \
  '--traceback-limit=[set traceback limit]:limit' \
  '*:vyper source files:_files -g "*.vy"' && ret=0

return ret
