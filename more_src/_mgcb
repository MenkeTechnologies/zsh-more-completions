#compdef mgcb
# Documentation: https://docs.monogame.net/articles/getting_started/tools/mgcb.html
# MonoGame Content Builder command line tool

local ret=1

_arguments -s -S \
  '/outputDir=[set output directory]:directory:_files -/' \
  '/intermediateDir=[set intermediate directory]:directory:_files -/' \
  '/rebuild[force rebuild of all content]' \
  '/clean[delete all build content and intermediate files]' \
  '/incremental[skip cleaning files not produced by the current build]' \
  '/reference=[add an assembly reference]:assembly:_files' \
  '/platform=[set target platform]:platform:(Windows Xbox360 iOS Android DesktopGL MacOSX WindowsStoreApp NativeClient PlayStation4 PlayStation5 WindowsPhone8 RaspberryPi PSVita XboxOne Switch BlazorGL)' \
  '/profile=[set target graphics profile]:profile:(Reach HiDef)' \
  '/config=[set build configuration]:config:' \
  '/compress[compress the XNB content files]' \
  '/importer=[set the content importer class]:class:' \
  '/processor=[set the content processor class]:class:' \
  '/processorParam=[set a processor parameter name=value]:param:' \
  '/build=[build the given content file]:content:_files' \
  '/launchdebugger[wait for debugger to attach]' \
  '/@=[load a response file]:response file:_files' \
  '/define=[define a macro name=value]:macro:' \
  '*:content file:_files' && ret=0

return ret
