#compdef RenameSampleInVcf
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/vcf/RenameSampleInVcf.java
# Picard: rename the sample in a single-sample VCF/BCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input single-sample VCF/BCF]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output single-sample VCF]:file:_files' \
  '--OLD_SAMPLE_NAME=[assert existing sample name]:name:' \
  '--NEW_SAMPLE_NAME=[new sample name in output]:name:' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
