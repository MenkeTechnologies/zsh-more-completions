#compdef jwkgen
# Documentation: https://github.com/rakutentech/jwkgen
# jwkgen - generate asymmetric JSON Web Keys

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--help-long[show long help]' \
  '--help-man[show man page help]' \
  '--allow-unsafe[permit unsafe parameters]' \
  '--color[use color in JSON output]' \
  '(-e --curve)'{-e+,--curve=}'[named elliptic curve]:curve:(P256 P384 P521 X25519 Ed25519)' \
  '(-b --bits)'{-b+,--bits=}'[number of bits for RSA or octet keys]:bits:' \
  '--pem[output PEM format only]' \
  '--jwk[output JWK format only]' \
  '--version[show version]' \
  '1:key type:(oct rsa ec)' \
  '2:filename:_files' && ret=0

return ret
