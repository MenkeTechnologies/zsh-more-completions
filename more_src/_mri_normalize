#compdef mri_normalize
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_normalize
# FreeSurfer intensity normalization of volumes

local ret=1

_arguments -s -S \
  '-no1d[disable 1d normalization]' \
  '-nonmax_suppress[turn non-maximum suppression on(1)/off(0)]:value:(0 1)' \
  '-conform[interpolate and embed volume to 256^3]' \
  '-gentle[perform kinder gentler normalization]' \
  '-f[use control points file]:control.dat:_files' \
  '-fonly[use only control points file]:fname:_files' \
  '-lonly[use only control points in label file]:fname:_files' \
  '-label[use control points in label file]:fname:_files' \
  '-w[write ctrl point and bias field volumes]:vols:' \
  '-a[control point intensity above target (def 25.0)]:a:' \
  '-b[control point intensity below target (def 10.0)]:b:' \
  '-g[max intensity/mm gradient (def 1.000)]:g:' \
  '-n[3d normalization iterations (def 2)]:n:' \
  '-u[print usage]' \
  '-prune[turn pruning of control points on/off]:boolean:' \
  '-MASK[mask file]:maskfile:_files' \
  '-atlas[use atlas to exclude non-brain control points]:atlas:' \
  '-noskull[no skull]' \
  '-monkey[turns off 1d, sets num_3d_iter=1]' \
  '-nosnr[disable snr normalization]' \
  '-sigma[smooth bias field]:sigma:' \
  '-aseg[aseg volume]:aseg:_files' \
  '-renorm[use points exactly 110 as control points]:volume:_files' \
  '-checknorm[remove control points not in min max]:checknorm:' \
  '-r[read controlpoints biasfield]:r:' \
  '-surface[normalize based on surface skeleton]:surface:' \
  '*:volume:_files' && ret=0

return ret
