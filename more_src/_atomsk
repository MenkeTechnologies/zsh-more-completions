#compdef atomsk
# atomsk — create, convert, and manipulate atomic systems for simulations

local -a modes=(
  '--create:create an atomic system from scratch'
  '--duplicate:duplicate a system'
  '--merge:merge several systems'
  '--polycrystal:create a polycrystal'
  '--average:compute average of configurations'
  '--interpolate:interpolate between two configurations'
  '--unwrap:unwrap atoms across PBC'
  '--diff:compute difference between two systems'
  '--nye:compute Nye tensor'
  '--electric-dipoles:compute electric dipole moments'
  '--density:compute density'
  '--rdf:compute radial distribution function'
  '--all-in-one:convert all files in current directory'
  '--list:convert a list of files'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-alignx[align first cell vector with X]' \
  '-bind[bind two systems together]' \
  '-cell[modify cell vectors]:cell params:' \
  '-center[center atoms in cell]' \
  '-crack[introduce a crack]:params:' \
  '-cut[cut part of the system]:direction above/below value:' \
  '-deform[apply deformation]:axis strain:' \
  '-dislocation[introduce a dislocation]:params:' \
  '-duplicate[duplicate system]:Nx Ny Nz:' \
  '-fix[fix atoms]:direction above/below value:' \
  '-fractional[convert to fractional coordinates]' \
  '-mirror[mirror atoms]:direction value:' \
  '-orient[change crystallographic orientation]:hkl1 hkl2 hkl3:' \
  '-orthogonal-cell[find orthogonal cell]' \
  '-rebox[re-calculate bounding box]' \
  '-remove-atom[remove atoms]:selection:' \
  '-remove-doubles[remove duplicate atoms]:distance:' \
  '-remove-property[remove a property]:property name:' \
  '-rotate[rotate system]:axis angle:' \
  '-roundoff[round off coordinates]:threshold:' \
  '-select[select atoms]:method params:' \
  '-shift[shift atoms]:Sx Sy Sz:' \
  '-sort[sort atoms]:property direction:' \
  '-spacegroup[apply space group]:group:' \
  '-substitute[substitute atoms]:sp1 sp2:' \
  '-swap[swap two atom species]:sp1 sp2:' \
  '-unit[change units]:property factor:' \
  '-unskew[unskew the supercell]' \
  '-velocity[set atom velocities]:temperature:' \
  '-wrap[wrap atoms into cell]' \
  '-verbosity[set verbosity level]:level:(0 1 2 3 4)' \
  '-overw[overwrite existing files]' \
  '*:input/output file:_files'
