#compdef mpolset
# _mpolset — containers/nri-plugins helper that applies a Linux NUMA memory policy (set_mempolicy(2)) to a target process
# upstream: https://github.com/containers/nri-plugins
# Flags from cmd/mpolset/mpolset.go on tip.

_mpolset() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-mode=[memory policy mode (number, name, or "help")]:mode:(MPOL_DEFAULT MPOL_PREFERRED MPOL_BIND MPOL_INTERLEAVE MPOL_LOCAL MPOL_PREFERRED_MANY MPOL_WEIGHTED_INTERLEAVE help)' \
        '-flags=[csv of memory policy flags (or "help")]:flags:(MPOL_F_STATIC_NODES MPOL_F_RELATIVE_NODES MPOL_F_NUMA_BALANCING help)' \
        '-nodes=[csv of NUMA node ids (e.g. 0,1-3)]:nodes:' \
        '-ignore-errors[ignore errors when setting memory policy]' \
        '-v[verbose logging]' \
        '-vv[very verbose logging]' \
        '*::cmd:_command_names -e'
}

_mpolset "$@"
