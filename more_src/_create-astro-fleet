#compdef create-astro-fleet
# Documentation: https://www.npmjs.com/package/create-astro-fleet
# Reference accessed: 2026-05-23
# Verified: npm view create-astro-fleet bin; npm readme Commands and Options sections.

# Zsh completion for create-astro-fleet - Astro Fleet monorepo scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--template=[giget template source]:source:'   '--domain=[first-site domain name]:domain:'   '--preset=[site preset]:preset:(corporate saas warm)'   '--keep-demos[keep the three demo sites as reference]'   '--install[install dependencies after scaffold]'   '--no-install[skip dependency install]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' add help && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments -C           '--preset=[site preset]:preset:(corporate saas warm)'           ':domain name:'           ':preset name:(corporate saas warm)' && ret=0
        ;;
      help)
        _arguments -C && ret=0
        ;;
      *)
        _arguments -C           '--template=[giget template source]:source:'           '--domain=[first-site domain name]:domain:'           '--preset=[site preset]:preset:(corporate saas warm)'           '--keep-demos[keep demo sites as reference]'           '--install[install dependencies after scaffold]'           '--no-install[skip dependency install]'           ':fleet directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
