#compdef arbiter
# _arbiter — TiDB Binlog Arbiter (Kafka -> MySQL downstream sync)
# upstream: https://github.com/pingcap/tidb-binlog
# Flags from arbiter/config.go on tip.

_arbiter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-V[print version and exit]' \
        '--config=[arbiter config file]:file:_files' \
        '--addr=[arbiter listen host\:port]:host\:port:' \
        '-L=[log level]:level:(debug info warn error fatal)' \
        '--log-file=[log file path]:file:_files' \
        '--metrics.addr=[Prometheus pushgateway address]:host\:port:' \
        '--metrics.interval=[Prometheus push interval (s)]:s:' \
        '--open-sarama-log=[capture sarama (Kafka client) logs]:bool:(true false)' \
        '--up.initial-commit-ts=[initial Kafka commit TS (no checkpoint case)]:n:' \
        '--up.topic=[upstream Kafka topic name]:topic:' \
        '--down.worker-count=[downstream concurrency]:n:' \
        '--down.batch-size=[downstream batch size]:n:' \
        '--safe-mode=[enable safe mode (reentrant writes)]:bool:(true false)'
}

_arbiter "$@"
