#compdef bowtie2-build bowtie2-inspect hisat2-build hisat2-inspect
# Documentation: upstream {bowtie2,hisat2}-{build,inspect}(1) man
# pages at manpages.debian.org/bookworm/.
# Reference accessed: 2026-05-30 via WebFetch.
# Bowtie2/HISAT2 index tools R97 — 4-stem multi-binary harvest of
# the index-build / index-inspect sister binaries paired with the
# already-covered `bowtie2` and `hisat2` aligners. Both families
# share substantial flag patterns since HISAT2 is forked from
# Bowtie2.

case $service in

  bowtie2-build)
    # Build a Bowtie2 index from FASTA reference sequences.
    _arguments -s -S \
      '-f[reference files are FASTA (default)]' \
      '-c[reference sequences provided directly on the command line]' \
      '--large-index[force large index format even for <4Gbp ref]' \
      '(-r --noref)'{-r,--noref}'[do not build .3/.4 index files]' \
      '(-3 --justref)'{-3,--justref}'[build only .3/.4 index files]' \
      '(-a --noauto)'{-a,--noauto}'[disable automatic -p/--bmax/--dcv memory fitting]' \
      '(-p --packed)'{-p,--packed}'[use packed strings internally (slower, less memory)]' \
      '--bmax=[max bucket size for blockwise suffix-array builder]:N:' \
      '--bmaxdivn=[max bucket size as divisor of ref len (default 4)]:N:' \
      '--dcv=[diff-cover period for blockwise (default 1024)]:N:' \
      '--nodc[disable diff-cover (algorithm becomes quadratic)]' \
      '(-o --offrate)'{-o,--offrate}'=[SA sampled every 2^N BWT chars (default 5)]:N:' \
      '(-t --ftabchars)'{-t,--ftabchars}'=[chars consumed in initial lookup (default 10)]:N:' \
      '--threads=[number of threads]:N:' \
      '--seed=[random number generator seed]:N:' \
      '--debug[use debug binary with assertions]' \
      '--verbose[log the issued command]' \
      '(-q --quiet)'{-q,--quiet}'[suppress verbose output]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '1:reference FASTA (or -c sequences):_files -g "*.(fa|fasta|fna|ffn|faa)"' \
      '2:index base name:'
    ;;

  bowtie2-inspect)
    # Inspect a Bowtie2 index (recover FASTA or show summary).
    _arguments -s -S \
      '--large-index[force inspection of the large index]' \
      '--debug[use debug binary]' \
      '(-v --verbose)'{-v,--verbose}'[verbose output]' \
      '(-a --across)'{-a,--across}'=[characters across FASTA output (default 60)]:N:' \
      '(-n --names)'{-n,--names}'[print reference sequence names only]' \
      '(-s --summary)'{-s,--summary}'[print summary (ref names, lengths, index properties)]' \
      '(-o --output)'{-o,--output}'=[save output to file (default stdout)]:file:_files' \
      '(- *)'{-h,--help}'[show help]' \
      '1:bt2 index base name (no .1.bt2/.2.bt2 suffix):_files'
    ;;

  hisat2-build)
    # Build a HISAT2 index from FASTA reference sequences.
    _arguments -s -S \
      '-c[reference sequences provided directly on the command line]' \
      '--large-index[force large index format regardless of reference size]' \
      '(-a --noauto)'{-a,--noauto}'[disable automatic memory-fitting]' \
      '-p+[number of processing threads]:N:' \
      '--bmax=[max bucket size for blockwise suffix-array construction]:N:' \
      '--bmaxdivn=[bucket size as reference length divisor (default 4)]:N:' \
      '--dcv=[difference-cover period (default 1024)]:N:' \
      '--nodc[disable difference-cover algorithm]' \
      '(-r --noref)'{-r,--noref}'[skip packed reference portion]' \
      '(-3 --justref)'{-3,--justref}'[build only packed reference portion]' \
      '(-o --offrate)'{-o,--offrate}'=[SA sampling interval (default 5)]:N:' \
      '(-t --ftabchars)'{-t,--ftabchars}'=[initial lookup characters (default 10)]:N:' \
      '--localoffrate=[local SA sampling (default 3)]:N:' \
      '--localftabchars=[local lookup characters (default 6)]:N:' \
      '--snp=[SNP file]:file:_files' \
      '--haplotype=[haplotype file]:file:_files' \
      '--ss=[splice site file]:file:_files' \
      '--exon=[exon file]:file:_files' \
      '--repeat-ref=[repeat reference]:file:_files' \
      '--repeat-info=[repeat information]:file:_files' \
      '--repeat-snp=[repeat SNP data]:file:_files' \
      '--repeat-haplotype=[repeat haplotype data]:file:_files' \
      '--seed=[random number generator seed]:N:' \
      '(-q --quiet)'{-q,--quiet}'[suppress verbose output]' \
      '(- *)'{-h,--help}'[show detailed help]' \
      '(- *)--usage[print usage message]' \
      '(- *)--version[show version]' \
      '1:reference sequence files (or -c sequences):_files -g "*.(fa|fasta|fna|ffn|faa)"' \
      '2:ht2 index base name:'
    ;;

  hisat2-inspect)
    # Inspect a HISAT2 index (recover FASTA, list names, or show
    # annotations).
    _arguments -s -S \
      '--large-index[force inspection of large index]' \
      '(-a --across)'{-a,--across}'=[characters across FASTA output (default 60)]:N:' \
      '(-s --summary)'{-s,--summary}'[print summary (ref names, lengths, index properties)]' \
      '(-n --names)'{-n,--names}'[print reference sequence names only]' \
      '(-e --ht2-ref)'{-e,--ht2-ref}'[reconstruct reference from .ht2 (slow, preserves colors)]' \
      '--snp[print SNPs]' \
      '--ss[print splice sites]' \
      '--ss-all[print splice sites including those not in global index]' \
      '--exon[print exons]' \
      '(-v --verbose)'{-v,--verbose}'[verbose output]' \
      '(- *)'{-h,--help}'[show detailed help]' \
      '(- *)--usage[print usage message]' \
      '1:ht2 index base name (no .1.ht2/.2.ht2 suffix):_files'
    ;;

esac
