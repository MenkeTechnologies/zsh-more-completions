#compdef pto_move
# Documentation: https://man.archlinux.org/man/pto_move.1.en
# pto_move: move or copy Hugin .pto projects together with their images

local ret=1

_arguments -s -S \
  '--copy[copy project files and images instead of moving]' \
  '--recursive[recurse source folder maintaining structure (use case 2)]' \
  '--overwrite[overwrite all existing files without asking]' \
  '*:file:_files' && ret=0

return ret
