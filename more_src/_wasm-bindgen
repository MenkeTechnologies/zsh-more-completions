#compdef wasm-bindgen

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--out-dir=[output directory]:dir:_directories' \
  '--out-name=[set a custom output filename]:name' \
  '--target=[target environment]:target:(bundler web nodejs deno no-modules)' \
  '--no-modules[same as --target no-modules]' \
  '--no-modules-global=[global variable name for no-modules target]:name' \
  '--browser[hint that output will only be used in a browser]' \
  '--typescript[output a TypeScript definition file]' \
  '--no-typescript[do not output a TypeScript definition file]' \
  '--omit-imports[do not emit imports in generated JavaScript]' \
  '--debug[include otherwise-extraneous debug checks]' \
  '--no-demangle[do not demangle Rust symbol names]' \
  '--keep-debug[keep debug sections in wasm files]' \
  '--keep-lld-exports[keep all exports generated by LLD]' \
  '--remove-name-section[remove the name section of wasm files]' \
  '--remove-producers-section[remove the producers section]' \
  '--encode-into=[encoding method for text]:method:(test always never)' \
  '--nodejs[same as --target nodejs]' \
  '--web[same as --target web]' \
  '--bundler[same as --target bundler]' \
  '--deno[same as --target deno]' \
  '--reference-types[enable reference types]' \
  '--weak-refs[enable weak references]' \
  '--omit-default-module-path[do not add WebAssembly fallback imports]' \
  '--split-linked-modules[split linked modules out into their own files]' \
  '1:input wasm file:_files -g "*.wasm"' && ret=0

return ret
