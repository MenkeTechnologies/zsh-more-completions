#compdef wasm-bindgen
# Documentation: https://raw.githubusercontent.com/rustwasm/wasm-bindgen/main/crates/cli/src/wasm_bindgen.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--out-dir=[output directory]:dir:_directories' \
  '--out-name=[set a custom output filename (without extension; defaults to crate name)]:name' \
  '--target=[output type]:target:(bundler web nodejs deno no-modules experimental-nodejs-module)' \
  '--no-modules-global=[name of global variable to initialize for no-modules target]:name' \
  '--browser[hint that JS should only be compatible with a browser]' \
  '--no-typescript[do not emit *.d.ts file]' \
  '--omit-imports[do not emit imports in generated JavaScript]' \
  '--debug[include otherwise-extraneous debug checks in output]' \
  '--no-demangle[do not demangle Rust symbol names]' \
  '--keep-debug[keep debug sections in wasm files]' \
  '--keep-lld-exports[keep exports synthesized by LLD]' \
  '--remove-name-section[remove the debugging name section of the file]' \
  '--remove-producers-section[remove the telemetry producers section]' \
  '--encode-into=[whether or not to use TextEncoder#encodeInto]:mode:(test always never)' \
  '--omit-default-module-path[do not add WebAssembly fallback imports in generated JavaScript]' \
  '--split-linked-modules[split linked modules into separate files]' \
  '--experimental-reset-state-function[generate __wbg_reset_state function for Wasm reinitialization]' \
  '1:input wasm file:_files -g "*.wasm"' && ret=0

return ret
