#compdef pykwalify
# Documentation: https://pykwalify.readthedocs.io/en/master/
# pykwalify: YAML/JSON schema validator (Python port of kwalify)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-d --data-file)'{-d,--data-file}'=[the file to be tested]:data:_files' \
  '(-s --schema-file)'{-s,--schema-file}'=[schema definition file]:schema:_files' \
  '(-e --extension)'{-e,--extension}'=[file containing python extension]:extension:_files' \
  '--fix-ruby-style-regex[fix ruby-style regex incompatible with python regex]' \
  '--strict-rule-validation[strict validation of all keywords for all Rule objects]' \
  '--allow-assertions[enable the assert keyword in schema]' \
  '--encoding=[encoding to open data and schema files with]:encoding' \
  '(-q --quiet)'{-q,--quiet}'[suppress terminal output]' \
  '*'{-v,--verbose}'[verbose terminal output (repeatable)]' \
  '--version[display the version number and exit]' && ret=0

return ret
