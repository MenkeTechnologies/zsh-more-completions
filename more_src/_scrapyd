#compdef scrapyd

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --nodaemon)'{-n,--nodaemon}'[do not daemonize]' \
  '(-o --no_save)'{-o,--no_save}'[do not save state on shutdown]' \
  '(-p --profile)'{-p+,--profile=}'[run in profile mode, write to file]:file:_files' \
  '--pidfile=[PID file path]:file:_files' \
  '--logfile=[log file path]:file:_files' \
  '--rundir=[run directory]:dir:_files -/' \
  '--reactor=[Twisted reactor]:reactor:(default select poll epoll kqueue iocp asyncio)' \
  '--umask=[umask]:umask:' \
  '--euid[allow user/group switching]' \
  '--quiet[suppress non-essential output]' \
  '--gid=[group id]:gid:_groups' \
  '--uid=[user id]:uid:_users' \
  '--syslog[log to syslog]' \
  '--prefix=[syslog prefix]:prefix:' \
  '--python=[Python file to run]:file:_files' \
  '*::passthrough:' && ret=0

return ret
