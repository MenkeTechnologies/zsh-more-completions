#compdef afl-collect
# Documentation: https://github.com/rc0r/afl-utils
# Collect and classify crash samples from afl-fuzz sync dirs (afl-utils)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --database)'{-d,--database}'=[submit sample data into an sqlite3 database]:db:_files' \
  '(-e --execute-gdb-script)'{-e,--execute-gdb-script}'=[generate and execute a gdb+exploitable script]:script:_files' \
  '(-f --filelist)'{-f,--filelist}'=[write collected crash sample filenames into a file]:file:_files' \
  '(-g --generate-gdb-script)'{-g,--generate-gdb-script}'=[generate gdb script to run exploitable.py]:script:_files' \
  '(-j --threads)'{-j,--threads}'=[number of threads for parallel analysis]:threads' \
  '(-m --minimize-filenames)'{-m,--minimize-filenames}'[minimize crash sample file names]' \
  '(-r --remove-invalid)'{-r,--remove-invalid}'[verify and remove non-crashing/timeout samples]' \
  '(-rr --remove-unexploitable)'{-rr,--remove-unexploitable}'[remove NOT_EXPLOITABLE/PROBABLY_NOT_EXPLOITABLE samples]' \
  '(-rt --remove-timeout)'{-rt,--remove-timeout}'=[max processing time in seconds per sample]:seconds' \
  '*::sync dir and target:_files' && ret=0

return ret
