#compdef tagref
# Documentation: https://github.com/stepchowfun/tagref (src/main.rs clap derive)
# Reference accessed: 2026-05-29
# Tagref — keep cross-references between files using simple sigils.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'check:check all the tags and references (default)'
  'list-tags:list all the tags'
  'list-refs:list all the tag references'
  'list-files:list all the file references'
  'list-dirs:list all the directory references'
  'list-unused:list the unreferenced tags'
  'help:show help for a subcommand'
)

local -a _global
_global=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '*'{-p,--path=}'[directory to scan (default .)]:dir:_directories'
  '(-t --tag-sigil)'{-t,--tag-sigil=}'[sigil for tags (default tag)]:sigil:'
  '(-r --ref-sigil)'{-r,--ref-sigil=}'[sigil for tag references (default ref)]:sigil:'
  '(-f --file-sigil)'{-f,--file-sigil=}'[sigil for file references (default file)]:sigil:'
  '(-d --dir-sigil)'{-d,--dir-sigil=}'[sigil for directory references (default dir)]:sigil:'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'tagref subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      list-unused)
        _arguments \
          $_global \
          '--fail-if-any[exit with error status if any unused tags exist]' && ret=0
        ;;
      check|list-tags|list-refs|list-files|list-dirs)
        _arguments $_global && ret=0
        ;;
    esac
    ;;
esac

return ret
