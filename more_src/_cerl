#compdef cerl

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-debug[run with debug-compiled emulator]' \
  '-gdb[run under gdb]' \
  '-lldb[run under lldb]' \
  '-valgrind[run under valgrind]' \
  '-rgdb[run under remote gdb]' \
  '-emu_args[show emulator arguments]' \
  '-Werror[treat warnings as errors]' \
  '*-pa+[add to code path]:dir:_files -/' \
  '*-pz+[append to code path]:dir:_files -/' \
  '-name+[long node name]:name:' \
  '-sname+[short node name]:name:' \
  '-setcookie+[magic cookie]:cookie:' \
  '*::Erlang script and args:_files -g "*.erl"' && ret=0

return ret
