#compdef cerl
# Documentation: https://github.com/erlang/otp/blob/master/erts/etc/unix/cerl.src
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above (Erlang/OTP cerl dev wrapper).

# cerl: Erlang/OTP developer wrapper around erl with build/debug variants.
# Remaining args after cerl-specific flags are forwarded to erl(1).
local curcontext="$curcontext" ret=1
_arguments -s \
  '-debug[run debug-compiled emulator]' \
  '-lcnt[run lock-counting emulator]' \
  '-gprof[run gprof-built emulator]' \
  '-frmptr[run frame-pointer emulator]' \
  '-icount[run instruction-counting emulator]' \
  '-gcov[run code-coverage emulator]' \
  '-valgrind[run under valgrind]' \
  '-asan[run AddressSanitizer build]' \
  '-emu_type+[explicit emulator type]:type:' \
  '-emu_flavor+[emulator flavor]:flavor:' \
  '-gdb[start under gdb in Emacs]' \
  '-rgdb[start under gdb in terminal]' \
  '-lldb[start under lldb]' \
  '-break+[set gdb breakpoint then run]:function:' \
  '-core+[debug a core file (Emacs+gdb)]:file:_files' \
  '-rcore+[debug a core file (raw gdb)]:file:_files' \
  '-dump+[dump thread backtraces from core]:file:_files' \
  '-rr[record under rr]' \
  '-instr[instrumented build]' \
  '-target+[target architecture]:target:' \
  '-rootdir+[Erlang root directory]:dir:_files -/' \
  '-display+[X11 display]:display:' \
  '-nox[do not use X11]' \
  '*::erl args:_files' && ret=0
return ret
