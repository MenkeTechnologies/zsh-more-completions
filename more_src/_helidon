#compdef helidon

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:generate a new Helidon project'
  'build:build the application'
  'dev:continuous compile and restart developer loop'
  'info:print project and tooling info'
  'version:print version info'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--project=[project directory]:dir:_files -/' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'helidon subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '--batch[non-interactive mode]' \
          '--version=[Helidon version]:version:' \
          '--flavor=[Helidon flavor]:flavor:(MP SE)' \
          '--build=[build system]:system:(MAVEN GRADLE)' \
          '--archetype=[archetype name]:archetype:' \
          '--groupid=[Maven groupId]:groupid:' \
          '--artifactid=[Maven artifactId]:artifactid:' \
          '--package=[Java package]:package:' \
          '--name=[project name]:name:' \
          '--output-props-file=[save inputs to file]:file:_files' && ret=0
        ;;
      (build)
        _arguments \
          '--clean[clean before build]' \
          '--mode=[build mode]:mode:(PLAIN NATIVE JLINK)' && ret=0
        ;;
      (dev)
        _arguments \
          '--clean[clean before first build]' \
          '--fork[fork mvn execution]' \
          '--app-debug[enable application debugger]' \
          "--app-debug-no-wait[don't wait for debugger]" \
          '--app-debug-port=[debugger port]:port:' \
          '--app-jvm-args=[JVM args]:args:' \
          '--app-args=[application args]:args:' && ret=0
        ;;
      (info)
        _arguments \
          '--verbose[include sysprops, env, metadata cache]' \
          '--plain[no ANSI styling]' && ret=0
        ;;
    esac
    ;;
esac

return ret
