#compdef batchruntomo
# Documentation: https://bio3d.colorado.edu/imod/doc/man/batchruntomo.html
# batchruntomo - run automated tomographic reconstruction from directive files

local ret=1

_arguments -s -S \
  '(-directive)-directive[input file with directives for automating processing]:file:_files' \
  '(-root)-root[data set name to provide on the command line]:name' \
  '(-current)-current[directory where the tilt series is located]:dir:_files -/' \
  '(-deliver)-deliver[directory to make a subdirectory for processing in]:dir:_files -/' \
  '(-make)-make[make a subdirectory for each data set at its location]' \
  '(-check)-check[file to check for quit and finish signals]:file:_files' \
  '(-frompath)-frompath[prefix from which to translate paths]:prefix' \
  '(-topath)-topath[prefix to which to translate paths]:prefix' \
  '(-remote)-remote[path on remote machines to the working directory]:path' \
  '(-cpus)-cpus[machines to use, or number, for parallel processing]:cpus' \
  '(-single)-single[run single command files on the first CPU]' \
  '(-gpus)-gpus[machines to use for GPU parallel processing]:gpus' \
  '(-nice)-nice[priority level or niceness for running jobs]:value' \
  '(-limit)-limit[limit on number of threads when running single]:value' \
  '(-parallel)-parallel[root name sent to Gpuallocator]:name' \
  '(-maxGPUs)-maxGPUs[maximum number of GPUs to use]:count' \
  '(-queue)-queue[command for running processes on a cluster queue]:command' \
  '(-jobs)-jobs[maximum number of jobs to submit to the queue]:count' \
  '(-jcores)-jcores[number of cores available to each cluster job]:count' \
  '(-jgpus)-jgpus[number of GPUs available to each cluster job]:count' \
  '(-gqueue)-gqueue[command for running GPU processes on a second queue]:command' \
  '(-gjobs)-gjobs[maximum number of jobs for the secondary queue]:count' \
  '(-one)-one[enter 1 to do setup and process A axis, 2 to skip]:value' \
  '(-end)-end[step to end processing with]:step' \
  '(-start)-start[step to start processing with]:step' \
  '(-first)-first[skip to starting step only for the first set]' \
  '(-use)-use[rerun Tiltalign instead of using existing results]' \
  '(-exit)-exit[exit on error instead of continuing to next axis]' \
  '(-email)-email[address for sending email messages]:address' \
  '(-SMTP)-SMTP[an SMTP server for sending email messages]:server' \
  '(-validation)-validation[control directive validation]:value' \
  '(-style)-style[naming style for output image files]:value' \
  '(-pcm)-pcm[name output command files with pcm extension]:value' \
  '(-ext)-ext[extension of an existing raw stack]:ext' \
  '(-axis)-axis[axis option when just renaming stacks]:value' \
  '(-etomo)-etomo[run Etomo with the given debug level]:level' \
  '(-bypass)-bypass[run Copytomocoms directly instead of Etomo]' \
  '(-PID)-PID[print process ID]' \
  '(-help -h)'{-help,-h}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
