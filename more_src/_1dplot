#compdef 1dplot
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dplot.html
# AFNI: plot columns of AFNI .1D files as time series graphs

local ret=1

_arguments -s -S \
  '-install[install a new X11 colormap]' \
  '-sep[plot each column in a separate sub-graph (default)]' \
  '-one[plot all columns together in one graph]' \
  '-sepscl[separate sub-graphs with individual y-scales]' \
  '-noline[omit connecting lines; implies -box]' \
  '-NOLINE[like -noline but no plotting outside bounds]' \
  '-box[add small boxes at each data point]' \
  '-hist[render graphs as histograms]' \
  '-norm2[scale each series to L2 norm = 1]' \
  '-normx[scale each series to max abs value = 1]' \
  '-norm1[scale each series to L1 norm = 1]' \
  '-demean[remove mean from each series]' \
  '-x[file for x-axis values]:file:_files' \
  '-xl10[log10 transform x-axis data]' \
  '-xmulti[different x-axis values per column]:file:_files' \
  '-dx[x-axis point spacing]:dx:' \
  '-dt[x-axis point spacing]:dt:' \
  '-del[x-axis point spacing]:del:' \
  '-xzero[initial x coordinate]:x:' \
  '-tzero[initial x coordinate]:t:' \
  '-start[initial x coordinate]:start:' \
  '-nopush[prevent expanding axis ranges outward]' \
  '-ignore[skip first N rows]:N:' \
  '-use[plot only N points]:N:' \
  '-xlabel[label for x-axis]:label:' \
  '-ylabel[label for y-axis]:label:' \
  '-plabel[title above the plot]:label:' \
  '-title[title for ps/png/jpg output]:title:' \
  '-wintitle[window frame title]:title:' \
  '-naked[plot only graphs without axes or labels]' \
  '-aspect[width-to-height ratio]:ratio:' \
  '-stdin[read data from standard input]' \
  '-ps[output PostScript to stdout]' \
  '-jpg[save plot as JPEG]:file:_files' \
  '-jpeg[save plot as JPEG]:file:_files' \
  '-png[save plot as PNG]:file:_files' \
  '-pnm[save plot as PNM]:file:_files' \
  '-jpgs[JPEG output with size]:spec:' \
  '-jpegs[JPEG output with size]:spec:' \
  '-pngs[PNG output with size]:spec:' \
  '-pnms[PNM output with size]:spec:' \
  '-ytran[transform y-axis via expression]:expr:' \
  '-xtran[transform x-axis via expression]:expr:' \
  '-xaxis[x-axis range/divisions/tics]:spec:' \
  '-yaxis[y-axis range/divisions/tics]:spec:' \
  '-ynames[labels for graphs]:names:' \
  '-volreg[apply standard volume registration labels]' \
  '-thick[increase line thickness]' \
  '-THICK[double the effect of -thick]' \
  '-dashed[dash patterns for plotted lines]:spec:' \
  '-D[set environment variable for this run]:var:' \
  '-censor_RGB[color for censoring marks]:color:' \
  '-censor[mark censored time points via file]:file:_files' \
  '-CENSORTR[mark censored time indexes]:spec:' \
  '-concat[run concatenation indices]:file:_files' \
  '-rbox[draw rectangular box]:coords:' \
  '-Rbox[draw rectangular box with extra line]:coords:' \
  '-line[draw individual line segment]:coords:' \
  '*:1D file:_files' && ret=0

return ret
