#compdef helm-sigstore
# Documentation: https://github.com/sigstore/helm-sigstore/blob/main/USAGE.md
# helm sigstore: store and verify Helm chart signatures in the Rekor transparency log

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--rekor-server=[alternate Rekor instance URL]:url:' \
  '--keyring=[location of the GPG keyring]:file:_files' \
  '1:command:(upload search verify help)' \
  '*::arg:_files' && ret=0

return ret
