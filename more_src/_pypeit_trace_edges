#compdef pypeit_trace_edges
# Documentation: https://pypeit.readthedocs.io/en/release/scripts.html
# Trace slit edges

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '(-f --pypeit_file -t --trace_file)'{-f,--pypeit_file}'[PypeIt reduction file]:file:_files -g "*.pypeit"' \
  '(-f --pypeit_file -t --trace_file)'{-t,--trace_file}'[image to trace]:file:_files' \
  '(-g --group)'{-g,--group}'[calibration group to use]:group' \
  '*'{-d,--detector}'[detector(s) to process]:detector' \
  '(-s --spectrograph)'{-s,--spectrograph}'[a valid spectrograph identifier]:spectrograph' \
  '(-b --binning)'{-b,--binning}'[image binning in spectral and spatial directions]:binning' \
  '(-p --redux_path)'{-p,--redux_path}'[path to top-level output directory]:dir:_files -/' \
  '(-c --calib_dir)'{-c,--calib_dir}'[directory for calibration files]:dir' \
  '(-o --overwrite)'{-o,--overwrite}'[overwrite any existing files/directories]' \
  '--debug=[debug level]:level' && ret=0

return ret
