#compdef zfs-redact
# _zfs-redact — OpenZFS zfs redact (create a redaction bookmark that excludes specified snapshots' data from subsequent zfs send -R/-w streams; first positional is the source snapshot, second is the new redaction bookmark name, remaining args are the snapshots whose data to redact)
# upstream: https://github.com/openzfs/zfs
# Argument shape from openzfs cmd/zfs/zfs_main.c (zfs_do_redact) on tip.

_zfs-redact() {
    _arguments \
        '1:source snapshot:' \
        '2:redaction bookmark name:' \
        '*:snapshot to redact:'
}

_zfs-redact "$@"
