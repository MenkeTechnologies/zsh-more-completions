#compdef kafka-delegation-tokens

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--create[Create a delegation token]'
    '--renew[Renew a delegation token]'
    '--expire[Expire a delegation token]'
    '--describe[Describe delegation tokens]'
    '--owner-principal[Owner of the token]:principal:'
    '--renewer-principal[Renewer principal]:principal:'
    '--max-life-time-period[Max life time period in ms]:ms:'
    '--expiry-time-period[Expiry time period in ms]:ms:'
    '--hmac[HMAC of the delegation token]:hmac:'
)

_arguments -s -S $arguments
