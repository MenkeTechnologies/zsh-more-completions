#compdef puppetdb
# Documentation: https://github.com/puppetlabs/puppetdb
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcommands=(
      'export:export PuppetDB data'
      'import:import PuppetDB data'
      'delete-reports:delete reports from PuppetDB'
      'anonymize:anonymize PuppetDB export data'
      'status:show PuppetDB status'
      'version:show version information'
      'help:show help'
      'foreground:start PuppetDB in the foreground'
      'start:start PuppetDB'
      'stop:stop PuppetDB'
      'restart:restart PuppetDB'
      'reload:reload PuppetDB configuration'
    )
    _describe -t commands 'puppetdb subcommand' subcommands && ret=0
    ;;
  args)
    case ${words[1]} in
      export)
        _arguments \
          {-o,--outfile}'[output file path]:output file:_files' \
          {-a,--anonymization}'[anonymization profile]:profile:(full moderate low none)' \
          '--help[show help]' && ret=0
        ;;
      import)
        _arguments \
          {-i,--infile}'[input file path]:input file:_files' \
          '--help[show help]' && ret=0
        ;;
      delete-reports)
        _arguments \
          '--help[show help]' && ret=0
        ;;
      anonymize)
        _arguments \
          '--help[show help]' && ret=0
        ;;
      *)
        _arguments \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
