#compdef pslToPslx
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert from psl to pslx format, which includes sequences

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-masked[repeats are in lower case]' \
  ':in psl:_files' \
  ':query seq spec:_files' \
  ':target seq spec:_files' \
  ':out pslx:_files' && ret=0

return ret
