#compdef g2o_simulator3d
# Documentation: https://github.com/RainerKuemmerle/g2o/blob/master/g2o/apps/g2o_simulator/test_simulator3d.cpp
# Generate a simulated 3D SLAM graph for g2o

local ret=1

_arguments -s -S \
  '-simSteps[number of simulation steps]:n' \
  '-nLandmarks[number of landmarks]:n' \
  '-worldSize[size of the world]:size' \
  '-hasOdom[the robot has an odometry]' \
  '-hasPointSensor[the robot has a point sensor]' \
  '-hasPointDepthSensor[the robot has a point depth sensor]' \
  '-hasPointDisparitySensor[the robot has a point disparity sensor]' \
  '-hasPoseSensor[the robot has a pose sensor]' \
  '-hasCompass[the robot has a compass]' \
  '-hasGPS[the robot has a GPS]' \
  '*:output:_files -g "*.g2o"' && ret=0

return ret
