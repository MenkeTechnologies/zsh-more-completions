#compdef icemulti
# _icemulti — Project IceStorm icemulti CLI assembling multiple iCE40 bitstream images into a single multi-boot warmboot-capable image with offset alignment crc32 warmboot vectors for redundant gold-image FPGA configurations (Clifford Wolf team, C); custom argparse
# upstream: https://github.com/YosysHQ/icestorm

_icemulti() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[output file]:file:_files -g "*.bin"' \
        '-w+[N]:n:' \
        '-a+[alignment bits]:n:' \
        '-p+[boot image]:n:(0 1 2 3)' \
        '-A+[alignment power]:n:' \
        '-c[crc32]' \
        '-r[raw mode]' \
        '*:bin file:_files -g "*.bin"'
}

_icemulti "$@"
