#compdef pearl
# Documentation: https://github.com/pearl-core/pearl
# Pearl - cross-platform package manager for dotfiles, plugins and programs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-u --update-repos)'{-u,--update-repos}'[force updating the repositories during the command execution]' \
  '(-n --no-confirm)'{-n,--no-confirm}'[bypass all "Are you sure?" messages]' \
  '(-f --force)'{-f,--force}'[bypass failing hook functions]' \
  '(-c --config-file)'{-c,--config-file}'=[specify the pearl config file]:file:_files' \
  '--verbose=[set the verbosity level (-v or -vv)]:level' \
  '-v[increase verbosity]' \
  '1:command:(install update remove emerge info init search list create)' \
  '*::arg:->args' && ret=0

return ret
