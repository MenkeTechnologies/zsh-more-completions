#compdef sudmofkcw
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/dip_moveout/sudmofkcw.c
# converted-wave DMO via F-K domain for common-offset gathers

local ret=1

_arguments -s -S \
  'cdpmin=[minimum cdp for which to apply DMO]:cdpmin' \
  'cdpmax=[maximum cdp for which to apply DMO]:cdpmax' \
  'dxcdp=[distance between adjacent cdp bins (m)]:dxcdp' \
  'noffmix=[number of offsets to combine]:noffmix' \
  'tdmo=[times at which rms velocities are specified (s)]:tdmo' \
  'vdmo=[rms velocities at specified times in tdmo (m/s)]:vdmo' \
  'gamma=[velocity ratio of upgoing to downgoing waves]:gamma' \
  'ntable=[number of tabulated z/h and b/h values]:ntable' \
  'sdmo=[DMO stretch factor]:sdmo' \
  'flip=[set to 1 for negative shifts]:flip' \
  'fmax=[maximum frequency in input traces (Hz)]:fmax' \
  'verbose=[set to 1 for diagnostic output]:verbose' \
  '*:file:_files' && ret=0


return ret
