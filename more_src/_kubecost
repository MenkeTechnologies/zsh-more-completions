#compdef kubecost

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--kubeconfig=[kubeconfig file]:config file:_files' \
  '--context=[kubeconfig context]:context:' \
  '-n+[namespace]:namespace:' \
  '--namespace=[namespace]:namespace:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'cost:show cost allocation'
      'namespace:show namespace costs'
      'deployment:show deployment costs'
      'controller:show controller costs'
      'label:show costs by label'
      'pod:show pod costs'
      'node:show node costs'
      'assets:show asset costs'
      'tui:launch TUI dashboard'
      'predict:predict future costs'
      'port-forward:set up port forwarding to Kubecost'
      'completion:generate shell completion'
      'version:show version'
    )
    _describe -t commands 'kubecost command' commands && ret=0
    ;;
  args)
    case $line[1] in
      cost|namespace|deployment|controller|pod|node)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--window=[time window]:window:(1d 2d 7d 30d today yesterday lastweek lastmonth)' \
          '--aggregate=[aggregate by]:field:(namespace deployment controller label pod node)' \
          '--accumulate[accumulate results]' \
          '--idle[show idle costs]' \
          '--filter=[filter expression]:filter:' \
          '--show-all-resources[show all resources]' \
          '--show-cpu[show CPU costs]' \
          '--show-memory[show memory costs]' \
          '--show-gpu[show GPU costs]' \
          '--show-pv[show PV costs]' \
          '--show-network[show network costs]' \
          '--show-efficiency[show efficiency]' \
          '-A[show all namespaces]' && ret=0
        ;;
      port-forward)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-p+[local port]:port:' \
          '--port=[local port]:port:' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
