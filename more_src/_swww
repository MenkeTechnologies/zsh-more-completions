#compdef swww

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'clear:fill outputs with a single color'
      'clear-cache:clear the cache'
      'img:set a wallpaper image'
      'init:initialize the swww daemon'
      'kill:kill the swww daemon'
      'query:query daemon for current wallpaper'
      'restore:restore last displayed image'
      'help:show help for a subcommand'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (img)
        _arguments \
          '(-o --outputs)'{-o,--outputs}'+[comma-separated list of outputs]:outputs:' \
          '--no-resize[do not resize the image]' \
          '--resize+[resize strategy]:strategy:(no crop fit)' \
          '--fill-color+[fill color for padding]:color:' \
          '(-f --filter)'{-f,--filter}'+[filter for scaling]:filter:(Nearest Bilinear CatmullRom Mitchell Lanczos3)' \
          '(-t --transition-type)'{-t,--transition-type}'+[transition type]:type:(none simple fade left right top bottom wipe wave grow center any outer random)' \
          '--transition-step+[transition step]:step:' \
          '--transition-duration+[transition duration]:seconds:' \
          '--transition-fps+[transition FPS]:fps:' \
          '--transition-angle+[transition angle]:degrees:' \
          '--transition-pos+[transition position]:position:' \
          '--transition-bezier+[bezier curve]:curve:' \
          '--transition-wave+[wave parameters]:width,height:' \
          '--invert-y[invert y axis for transition]' \
          '*:image file:_files -g "*.{png,jpg,jpeg,gif,bmp,tiff,webp,pnm,farbfeld}(-.)"' && ret=0
        ;;
      (clear)
        _arguments \
          '(-o --outputs)'{-o,--outputs}'+[comma-separated list of outputs]:outputs:' \
          '1:color (rrggbb):' && ret=0
        ;;
      (init)
        _arguments \
          '--no-cache[do not cache images]' \
          '--no-daemon[do not daemonize]' && ret=0
        ;;
    esac
    ;;
esac

return ret
