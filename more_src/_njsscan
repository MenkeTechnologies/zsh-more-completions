#compdef njsscan
# Documentation: https://github.com/ajinabraham/njsscan
# njsscan static security scanner for Node.js applications

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show njsscan version]' \
  '--json[set output format as JSON]' \
  '--sarif[set output format as SARIF 2.1.0]' \
  '--sonarqube[set output format compatible with SonarQube]' \
  '--html[set output format as HTML]' \
  '(-o --output)'{-o,--output}'[output filename to save the result]:file:_files' \
  '(-c --config)'{-c,--config}'[location to .njsscan config file]:file:_files' \
  '--missing-controls[enable missing security controls check]' \
  '(-w --exit-warning)'{-w,--exit-warning}'[non-zero exit code on warning]' \
  '*:path:_files' && ret=0

return ret
