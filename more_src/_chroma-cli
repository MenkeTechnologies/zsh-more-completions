#compdef chroma
# Documentation: https://man.archlinux.org/search?q=chroma
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run a Chroma server'
  'install:install Chroma'
  'install-extra-deps:install extra dependencies'
  'utils:utility commands'
  'vacuum:vacuum DB'
  'help:show help'
  'browse:browse Chroma data'
  'profile:profile commands'
  'copy:copy collection'
  'env:show environment info'
  'docs:open docs'
  'completion:generate completion'
  'log:show logs'
  'update:update CLI'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'chroma command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--host=[host]:host:' \
          '--port=[port]:port:' \
          '--path=[data path]:dir:_files -/' \
          '--log-path=[log path]:file:_files' \
          '--config_file=[config file]:file:_files -g "*.yaml *.yml"' \
          '--proxy-headers[proxy headers]' \
          '*: :' && ret=0 ;;
      (utils|vacuum|browse)
        _arguments '*: :_files' && ret=0 ;;
      (profile)
        _arguments '1:subcommand:(create delete list show use)' '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
