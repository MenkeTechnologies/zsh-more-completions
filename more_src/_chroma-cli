#compdef chroma
# Documentation: https://docs.trychroma.com/docs/cli/install
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run a Chroma server locally'
  'install:install a sample app'
  'install-extra-deps:install extra dependencies'
  'utils:utility commands'
  'vacuum:vacuum the database'
  'browse:browse a Chroma database'
  'profile:profile management'
  'copy:copy data between Chroma databases'
  'db:database management on Chroma Cloud'
  'login:authenticate with Chroma Cloud'
  'env:show environment info'
  'docs:open docs'
  'update:update the CLI'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'chroma command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--host=[hostname (default localhost)]:host:' \
          '--port=[port (default 8000)]:port:' \
          '--path=[data persistence path]:dir:_files -/' \
          '--config_path=[config file path]:file:_files -g "*.yaml *.yml"' \
          '*: :' && ret=0 ;;
      (browse|copy|vacuum|utils|env|docs|update|login)
        _arguments '*: :_files' && ret=0 ;;
      (profile)
        _arguments '1:subcommand:(delete list rename show use)' '*: :' && ret=0 ;;
      (db)
        _arguments '1:subcommand:(connect create delete list)' '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
