#compdef tstabdump
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tstabdump.cpp
# tstabdump - dump PSI/SI tables from binary section files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--ignore-crc32[do not check CRC32 of input sections]' \
  '(-x --max-tables)'{-x,--max-tables}'=[maximum number of tables to dump]:n:' \
  '--no-encapsulation[with --ip-udp, receive tables as raw binary UDP messages]' \
  '*:section file:_files -g "*.bin *.sections"' && ret=0

return ret
