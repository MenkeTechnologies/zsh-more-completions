#compdef gitsign
# _gitsign-cli — Sigstore Gitsign keyless git commit signing (Sigstore project, Go); sign commits using Fulcio + Rekor
# upstream: https://github.com/sigstore/gitsign

_gitsign-cli() {
    local -a sub=(
        'attest:create attestation'
        'initialize:initialize gitsign'
        'show:show signature info'
        'verify:verify a signature'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-u+[local user]:str:' \
        '--local-user+[local user]:str:' \
        '-b[detached signature]' \
        '--detach-sign[detached signature]' \
        '-a[ASCII armor]' \
        '--armor[ASCII armor]' \
        '--verify[verify signature]' \
        '--fulcio+[Fulcio URL]:url:_urls' \
        '--rekor+[Rekor URL]:url:_urls' \
        '--oidc-issuer+[OIDC issuer]:url:_urls' \
        '--oidc-client-id+[OIDC client id]:str:' \
        '--connector-id+[connector id]:str:' \
        '--ts-server-url+[timestamp authority URL]:url:_urls' \
        '--ts-cert-chain-path+[timestamp authority cert chain]:file:_files' \
        '--include-certs+[include certs]:n:' \
        '--ignore-tlog[do not upload to transparency log]' \
        '--keyless[use keyless signing]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gitsign subcommand' sub ;;
    esac
}

_gitsign-cli "$@"
