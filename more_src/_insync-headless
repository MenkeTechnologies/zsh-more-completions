#compdef insync-headless
# Documentation: https://help.insynchq.com/en/articles/4257855-insync-3-headless-getting-started
# insync-headless: command line interface for the Insync sync process (Insync 3)

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'account:manage accounts'
      'changelog:view the change log'
      'config:manage app settings'
      'conflict:resolve conflicts'
      'error:manage errors'
      'export-option:manage export options'
      'get-proxy:view proxy settings'
      'ignore-rules:manage ignore rules'
      'pause:pause syncing'
      'quit:quit the app'
      'resume:resume syncing'
      'selective-sync:selectively sync files'
      'set-proxy:configure proxy settings'
      'start:start Insync'
      'status:get app or per-file sync status'
    )
    _describe -t commands 'insync-headless command' cmds && ret=0
    ;;
esac

return ret
