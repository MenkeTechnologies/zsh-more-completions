#compdef bagels
# Documentation: https://github.com/EnhancedJax/Bagels
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EnhancedJax/Bagels src/bagels/__main__.py (click); Homebrew: Formula/b/bagels.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(--at)--at=[custom root path]:path:_files -/' \
  '(--migrate)--migrate=[migration type]:migrate choice:(actualbudget)' \
  '(--source)--source=[source DB for migration]:file:_files' \
  '(-h)'{-h,--help}'[help]' \
  '(--version)'--version'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'bagels command' compadd -- locate
  ;;
rest)
  case $line[1] in
    locate)
      _arguments '2:what:(config database)' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
