#compdef dotnet-interactive
# Documentation: https://github.com/dotnet/interactive/blob/main/docs/command-line-interface.md
# dotnet-interactive - .NET Interactive kernel host for notebooks and REPLs

local ret=1
local -a commands

commands=(
  'jupyter:start a kernel as a Jupyter notebook server'
  'stdio:start a kernel communicating over standard input and output'
  'http:start a kernel communicating over HTTP'
)

_arguments -s -S \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '--version[display version information]' \
  '--default-kernel=[default kernel language]:kernel:(csharp fsharp pwsh)' \
  '--http-port=[HTTP port for kernel communication]:port:' \
  '--kernel-host=[host name for the kernel]:host:' \
  '--log-path=[directory to write a log file to]:dir:_files -/' \
  '--preview[enable preview features]' \
  '--path=[install kernelspecs in a specific location]:dir:_files -/' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds) _describe -t commands 'dotnet-interactive command' commands && ret=0 ;;
  args)
    if [[ $line[1] == jupyter ]]; then
      _values 'jupyter subcommand' \
        'install[install the .NET kernelspecs into Jupyter]' && ret=0
    fi ;;
esac

return ret
