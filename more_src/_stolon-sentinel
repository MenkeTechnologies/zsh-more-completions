#compdef stolon-sentinel
# Documentation: https://github.com/sorintlab/stolon
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)--help[show help]' \
  '--cluster-name[cluster name]:name' \
  '--store-backend[store backend type]:backend:(consul etcdv2 etcdv3 kubernetes)' \
  '--store-endpoints[comma-separated list of store endpoints]:endpoints' \
  '--store-cert-file[path to store client certificate]:cert file:_files' \
  '--store-key[path to store client key]:key file:_files' \
  '--store-ca-file[path to store CA certificate]:CA file:_files' \
  '--store-skip-tls-verify[skip TLS verification for store]' \
  '--initial-cluster-spec[initial cluster specification file]:spec file:_files' \
  '--log-color[enable colored log output]' \
  '--log-level[log level]:level:(info debug warn error)' \
  '--metrics-listen-address[metrics listen address]:address'
