#compdef make_pixelmap
# Documentation: https://www.desy.de/~twhite/crystfel/manual-make_pixelmap.html
# Create a pixel geometry map or bad pixel mask from a geometry file (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-o --output)'{-o+,--output=}'[output HDF5 filename]:file:_files' \
  '--badmap[create a bad pixel mask instead of a geometry map]' \
  '--good-pixel=[value for good pixels in mask]:n:' \
  '--bad-pixel=[value for bad pixels in mask]:n:' \
  '*:geometry file:_files' && ret=0

return ret
