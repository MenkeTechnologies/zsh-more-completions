#compdef gopatch
# Documentation: https://man.archlinux.org/search?q=gopatch
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-p -print)'{-p,-print}'[print diff only]' \
  '--go-name=[go binary name]:name:' \
  '1:patch file or directory:_files' \
  '*:Go packages or files:_files -g "*.go"'
