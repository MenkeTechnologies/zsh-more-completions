#compdef check-jsonschema
# Documentation: https://check-jsonschema.readthedocs.io/en/latest/usage.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# python-jsonschema/check-jsonschema - CLI to validate instance files against a JSON Schema

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--schemafile=[path or URL to JSON Schema]:schema:_files -g "*.{json,yaml,yml}"' \
  '--builtin-schema=[use a builtin schema]:schema:(vendor.github-workflows vendor.github-actions vendor.gitlab-ci vendor.travis vendor.azure-pipelines vendor.bamboo-specs vendor.bitbucket-pipelines vendor.buildkite vendor.circleci vendor.cloudbuild vendor.dependabot vendor.drone vendor.github-funding vendor.readthedocs vendor.renovate vendor.taskfile vendor.woodpecker-ci)' \
  '--check-metaschema[validate each instancefile as a JSON Schema]' \
  '--no-cache[disable schema caching]' \
  '--cache-filename=[custom cache filename]:filename' \
  '--disable-formats=[disable specified format checkers]:formats' \
  '--regex-variant=[regex syntax]:variant:(default nonunicode python)' \
  '--traceback-mode=[traceback mode]:mode:(full short)' \
  '--data-transform=[transform instance data before validation]:transform:(azure-pipelines gitlab-ci)' \
  '--default-filetype=[default filetype for instance files]:type:(json yaml toml json5)' \
  '--force-filetype=[force filetype for instance files]:type:(json yaml toml json5)' \
  '--fill-defaults[fill default values during validation]' \
  '--base-uri=[base URI for $ref resolution]:uri' \
  '--validator-class=[custom validator implementation]:dotted.path' \
  '--color=[colorize output]:mode:(auto always never)' \
  '(-o --output-format)'{-o,--output-format}'=[output format]:format:(text json)' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[reduce verbosity]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:instance file:_files' && ret=0

return ret
