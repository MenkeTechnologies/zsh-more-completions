#compdef check-jsonschema

# Zsh completion for check-jsonschema (JSON Schema validator)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--schemafile[path or URL to JSON Schema]:schema:_files -g "*.{json,yaml,yml}"' \
  '--builtin-schema[use a builtin schema]:schema:(vendor.github-workflows vendor.github-actions vendor.gitlab-ci vendor.travis vendor.azure-pipelines vendor.bamboo-specs vendor.bitbucket-pipelines vendor.buildkite vendor.circleci vendor.cloudbuild vendor.dependabot vendor.drone vendor.github-funding vendor.readthedocs vendor.renovate vendor.taskfile vendor.woodpecker-ci)' \
  '--check-metaschema[check that schema is valid]' \
  '--no-cache[disable schema caching]' \
  '--cache-filename[custom cache filename]:filename' \
  '--disable-format[disable format validation]' \
  '--format-regex[set regex format]:format:(python ecma)' \
  '--traceback-mode[set traceback mode]:mode:(full short)' \
  '--data-transform[transform data before validation]:transform:(azure-pipelines gitlab-ci)' \
  '--default-filetype[default filetype for instance files]:type:(json yaml toml json5)' \
  '(-o --output-format)'{-o,--output-format}'[output format]:format:(text json)' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:instance file:_files' && ret=0

return ret
