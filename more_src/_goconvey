#compdef goconvey

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--host[hostname to bind to]:host' \
  '--port[port to listen on]:port' \
  '--packages[number of packages to test]:count' \
  '--cover[enable coverage reporting]' \
  '--depth[directory depth to scan]:depth' \
  '--timeout[test timeout]:timeout' \
  '--poll[polling interval]:interval' \
  '--workDir[working directory]:directory:_directories' \
  '--excludedDirs[comma-separated directories to exclude]:dirs' \
  '--launchBrowser[launch browser on start]' && ret=0

return ret
