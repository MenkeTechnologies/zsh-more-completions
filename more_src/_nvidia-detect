#compdef nvidia-detect
# Documentation: https://packages.debian.org/sid/nvidia-detect
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Primary mode is no-args PCI
# scan returning the recommended driver package name; conservative stub.

# nvidia-detect: RPM Fusion NVIDIA driver detector
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-l --list)'{-l,--list}'[list supported devices]' \
  '--version[show version]' && ret=0
return ret
