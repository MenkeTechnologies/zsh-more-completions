#compdef jbrowse
# Documentation: https://jbrowse.org/jb2/docs/cli/
# JBrowse 2 command line tools

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'create:download and install JBrowse 2'
      'add-assembly:add an assembly to a config'
      'add-track:add a track to a config'
      'add-track-json:add track configuration from JSON'
      'add-connection:add a connection to a config'
      'admin-server:start an admin server'
      'text-index:create a text index for tracks'
      'make-pif:create pairwise indexed PAF (bgzip+tabix)'
      'sort-gff:sort a GFF file for tabix'
      'sort-bed:sort a BED file for tabix'
      'remove-track:remove a track configuration'
      'set-default-session:set a default session'
      'upgrade:upgrade JBrowse 2 to the latest version'
    )
    _describe -t commands 'jbrowse command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --force)'{-f,--force}'[overwrite existing installation]' \
          '(-l --listVersions)'{-l,--listVersions}'[list available versions]' \
          '--branch=[download build from named git branch]:branch' \
          '--nightly[download latest development build]' \
          '(-u --url)'{-u,--url=}'[direct URL to a release]:url' \
          '(-t --tag)'{-t,--tag=}'[version to install (vX.Y.Z)]:tag' \
          '*:directory:_files -/' && ret=0
        ;;
      add-assembly)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --type)'{-t,--type=}'[sequence type]:type:(indexedFasta bgzipFasta twoBit chromSizes custom)' \
          '(-n --name)'{-n,--name=}'[assembly name]:name' \
          '*'{-a,--alias=}'[assembly alias]:alias' \
          '--displayName=[display name]:name' \
          '--faiLocation=[FASTA index location]:file:_files' \
          '--gziLocation=[FASTA gzip index location]:file:_files' \
          '--refNameAliases=[reference name aliases file or URL]:file:_files' \
          '--refNameAliasesType=[aliases type]:type:(aliases custom)' \
          '--refNameColors=[comma-separated color strings]:colors' \
          '(--target --out)'{--target=,--out=}'[path to config file]:file:_files' \
          '(-l --load)'{-l,--load=}'[data management method]:method:(copy symlink move inPlace)' \
          '--skipCheck[skip file/URL existence check]' \
          '--overwrite[overwrite existing assembly]' \
          '(-f --force)'{-f,--force}'[skipCheck plus overwrite]' \
          '*:sequence:_files' && ret=0
        ;;
      add-track)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --trackType)'{-t,--trackType=}'[type of track]:type' \
          '(-n --name)'{-n,--name=}'[track name]:name' \
          '--indexFile=[optional index file]:file:_files' \
          '(-d --description)'{-d,--description=}'[track description]:desc' \
          '(-a --assemblyNames)'{-a,--assemblyNames=}'[assembly names]:names' \
          '--category=[categories for grouping]:categories' \
          '--config=[extra configuration settings]:config' \
          '(--target --out)'{--target=,--out=}'[path to config file]:file:_files' \
          '--subDir=[output subdirectory]:dir:_files -/' \
          '--trackId=[track identifier]:id' \
          '(-l --load)'{-l,--load=}'[file management method]:method:(copy symlink move inPlace)' \
          '--skipCheck[skip file/URL existence check]' \
          '--overwrite[overwrite existing track]' \
          '(-f --force)'{-f,--force}'[skipCheck plus overwrite]' \
          '--protocol=[force protocol]:protocol' \
          '--bed1=[bed1 for mcscan anchors]:file:_files' \
          '--bed2=[bed2 for mcscan anchors]:file:_files' \
          '*:track:_files' && ret=0
        ;;
      add-track-json)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-u --update)'{-u,--update}'[update existing track contents]' \
          '(--target --out)'{--target=,--out=}'[path to config file]:file:_files' \
          '*:json:_files' && ret=0
        ;;
      add-connection)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --type)'{-t,--type=}'[connection type]:type:(JBrowse1Connection UCSCTrackHubConnection custom)' \
          '(-a --assemblyNames)'{-a,--assemblyNames=}'[assembly names]:names' \
          '(-c --config)'{-c,--config=}'[extra configuration JSON]:json' \
          '--connectionId=[unique connection identifier]:id' \
          '(-n --name)'{-n,--name=}'[connection name]:name' \
          '(--target --out)'{--target=,--out=}'[path to config file]:file:_files' \
          '--skipCheck[skip URL existence check]' \
          '--overwrite[overwrite existing connection]' \
          '(-f --force)'{-f,--force}'[skipCheck plus overwrite]' \
          '*:url:_files' && ret=0
        ;;
      admin-server)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --port)'{-p,--port=}'[server port]:port' \
          '--root=[path to JBrowse installation root]:dir:_files -/' \
          '--bodySizeLimit=[update message size limit]:size' && ret=0
        ;;
      text-index)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '--tracks=[trackIds to index]:tracks' \
          '--excludeTracks=[tracks to exclude]:tracks' \
          '(--target --out)'{--target=,--out=}'[path to config file]:file:_files' \
          '--attributes=[attributes to index]:attrs' \
          '(-a --assemblies)'{-a,--assemblies=}'[assemblies to index]:assemblies' \
          '--force[overwrite existing indexes]' \
          '(-q --quiet)'{-q,--quiet}'[hide progress bars]' \
          '--perTrack[create index per track]' \
          '--exclude=[types to exclude]:types' \
          '--prefixSize=[prefix size for ixx index]:size' \
          '*--file=[file to index]:file:_files' \
          '--fileId=[trackId for indexes from --file]:id' \
          '--dryrun[print tracks without indexing]' && ret=0
        ;;
      make-pif)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '--out=[output file path]:file:_files' \
          '--csi[create CSI index instead of TBI]' \
          '*:paf:_files' && ret=0
        ;;
      remove-track)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(--target --out)'{--target=,--out=}'[path to config file]:file:_files' \
          '*:trackId:' && ret=0
        ;;
      set-default-session)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-s --session)'{-s,--session=}'[path to session JSON]:file:_files' \
          '(-n --name)'{-n,--name=}'[session name]:name' \
          '(-c --currentSession)'{-c,--currentSession}'[display current default session]' \
          '(--target --out)'{--target=,--out=}'[path to config file]:file:_files' \
          '--delete[delete existing default session]' && ret=0
        ;;
      upgrade)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-l --listVersions)'{-l,--listVersions}'[list available versions]' \
          '(-t --tag)'{-t,--tag=}'[version to install (vX.Y.Z)]:tag' \
          '--branch=[download from named git branch]:branch' \
          '--nightly[download latest development build]' \
          '--clean[remove old js, map and LICENSE files]' \
          '(-u --url)'{-u,--url=}'[direct URL to release]:url' \
          '*:directory:_files -/' && ret=0
        ;;
      sort-gff|sort-bed)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
