#compdef amdgpu_top

# Zsh completion for amdgpu_top (AMD GPU utilization monitor)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d+[Specify DRM device index]:index' \
  '--pci=[Specify PCI bus ID]:bus id' \
  '-r+[Refresh period in milliseconds]:period' \
  '--refresh-period=[Refresh period in milliseconds]:period' \
  '-n+[Number of iterations]:iterations' \
  '--iterations=[Number of iterations]:iterations' \
  '-J[Output in JSON format]' \
  '--json[Output in JSON format]' \
  '--dump[Dump all AMDGPU info and exit]' \
  '--gui[Launch the GUI version]' \
  '--smi[SMI-like output mode]' \
  '--single[Show single GPU view]' \
  '--select-apu[Select APU if available]' \
  '--dark-mode[Use dark mode for GUI]' \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' && ret=0

return ret
