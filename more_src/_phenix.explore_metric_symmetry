#compdef phenix.explore_metric_symmetry iotbx.explore_metric_symmetry
# Documentation: https://phenix-online.org/documentation/reference/explore_metric_symmetry.html
# Phenix: explore metric (lattice) symmetry relations of a unit cell

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--unit_cell=[unit cell parameters or file]:cell:' \
  '--space_group=[space group symbol or file]:sg:' \
  '--centring_type=[lattice centering type]:type:(P A B C I R F)' \
  '--symmetry=[file with symmetry information]:file:_files' \
  '--other_unit_cell=[second unit cell for comparison]:cell:' \
  '--other_space_group=[space group for comparison cell]:sg:' \
  '--other_centring_type=[centering for comparison cell]:type:(P A B C I R F)' \
  '--max_delta=[maximum delta for lattice symmetry in degrees]:delta:' \
  '--relative_length_tolerance=[length comparison tolerance]:tol:' \
  '--absolute_angle_tolerance=[angular tolerance]:tol:' \
  '--max_order=[maximum volume change for target cell]:n:' \
  '--graph=[generate graphviz PNG visualization]:file:_files' \
  '--start_from_p1[reduce to Niggli cell, discard input space group]' \
  '--no_point_group_graph[skip point group graph construction]' \
  '*:file:_files' && ret=0

return ret
