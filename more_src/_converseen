#compdef converseen
# Documentation: https://converseen.fasterland.net/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:image:_files -g "*.jpg *.jpeg *.png *.gif *.bmp *.tif *.tiff *.svg *.webp *.psd *.heic *.heif *.cr2 *.nef *.arw *.dng *.raw *.dds *.tga"' && ret=0

return ret
