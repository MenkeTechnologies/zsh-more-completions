#compdef tfsec
# _tfsec-cli — tfsec Terraform static analysis (Aqua Security, Go); finds security misconfigs in HCL (now part of trivy)
# upstream: https://github.com/aquasecurity/tfsec

_tfsec-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--allow-checks-to-panic[allow checks to panic]' \
        '--concise-output[concise output]' \
        '--config-file+[config file]:file:_files' \
        '--config-file-url+[config url]:url:_urls' \
        '-c+[config file]:file:_files' \
        '--custom-check-dir+[custom check dir]:dir:_files -/' \
        '--debug[debug log]' \
        '--exclude+[exclude check ids]:ids:' \
        '-e+[exclude check ids]:ids:' \
        '--exclude-downloaded-modules[exclude downloaded modules]' \
        '--exclude-path+[exclude path]:path:_files' \
        '--filter-results+[filter result regex]:regex:' \
        '--force-all-dirs[force scan all dirs]' \
        '--format+[output format]:fmt:(default csv checkstyle gif html json junit lovely markdown sarif text)' \
        '-f+[output format]:fmt:' \
        '--ignore-hcl-errors[ignore HCL errors]' \
        '--include-ignored[include ignored]' \
        '--include-passed[include passed]' \
        '--ignore-warnings[ignore warnings]' \
        '--minimum-severity+[min severity]:level:(low medium high critical)' \
        '-m+[min severity]:level:' \
        '--no-color[no color]' \
        '--no-ignores[no ignore comments]' \
        '--no-module-downloads[no module download]' \
        '--out+[output file]:file:_files' \
        '-O+[output file]:file:_files' \
        '--rego-only[only rego policies]' \
        '--rego-policy-dir+[rego policies dir]:dir:_files -/' \
        '--run-statistics[run statistics]' \
        '-s+[soft fail]' \
        '--soft-fail[soft fail]' \
        '--single-thread[single thread]' \
        '--terraform-var-file+[tfvars file]:file:_files' \
        '--update[update tfsec]' \
        '--use-colors+[use colors]:bool:' \
        '--verbose[verbose]' \
        '--workspace+[terraform workspace]:str:' \
        '*:path:_files'
}

_tfsec-cli "$@"
