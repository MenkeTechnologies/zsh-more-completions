#compdef pgtune

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-i+[input config file]:input file:_files' \
  '--input-config=[input config file]:input file:_files' \
  '-o+[output config file]:output file:_files' \
  '--output-config=[output config file]:output file:_files' \
  '-M+[total memory in bytes]:memory:' \
  '--memory=[total memory in bytes]:memory:' \
  '-T+[database type]:db type:(web oltp dw desktop mixed)' \
  '--type=[database type]:db type:(web oltp dw desktop mixed)' \
  '-c+[max number of connections]:connections:' \
  '--connections=[max number of connections]:connections:' \
  '-s+[storage type]:storage:(ssd san hdd)' \
  '--storage-type=[storage type]:storage:(ssd san hdd)' \
  '-D+[data directory]:directory:_directories' \
  '--data-dir=[data directory]:directory:_directories' \
  '-v+[PostgreSQL version]:version:(9.5 9.6 10 11 12 13 14 15 16 17)' \
  '--pg-version=[PostgreSQL version]:version:(9.5 9.6 10 11 12 13 14 15 16 17)' \
  '--cpus=[number of CPUs]:cpus:' \
  '--max-worker-processes=[max worker processes]:count:' && ret=0

return ret
