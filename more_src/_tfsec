#compdef tfsec
# Documentation: https://github.com/aquasecurity/tfsec/blob/master/internal/app/tfsec/cmd/flags.go
# Reference accessed: 2026-05-21
# Verified: upstream flags.go at the URL above.

_arguments -s -S \
  '--single-thread[run checks using a single thread]' \
  '(-G --disable-grouping)'{-G,--disable-grouping}'[disable grouping of similar results]' \
  '--ignore-hcl-errors[do not error on HCL parse errors]' \
  '--no-colour[disable coloured output]' \
  '--no-color[disable colored output]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '--update[update to latest version]' \
  '--migrate-ignores[migrate ignore codes to new ID structure]' \
  '(-f --format)'{-f,--format}'=[output format]:format:(lovely json csv checkstyle junit sarif text markdown html gif)' \
  '(-e --exclude)'{-e,--exclude}'=[rule IDs to exclude]:rules:' \
  '(-E --exclude-ignores)'{-E,--exclude-ignores}'=[ignored rules to exclude]:rules:' \
  '--filter-results=[filter results to specific checks]:filter:' \
  '(-s --soft-fail)'{-s,--soft-fail}'[run but do not return error code]' \
  '*--tfvars-file=[path to .tfvars file]:file:_files' \
  '*--var-file=[path to .tfvars file]:file:_files' \
  '*--exclude-path=[folder path to exclude]:path:_files' \
  '(-O --out)'{-O,--out}'=[output file]:file:_files' \
  '--custom-check-dir=[custom checks directory]:dir:_files -/' \
  '--custom-check-url=[download custom check from URL]:url:' \
  '--config-file=[config file to use]:file:_files' \
  '--config-file-url=[download config file from URL]:url:' \
  '--debug[enable debug logging]' \
  '--verbose[enable verbose logging]' \
  '--concise-output[reduce output and no statistics]' \
  '--exclude-downloaded-modules[remove results for downloaded modules]' \
  '--include-passed[include passed checks in output]' \
  '--include-ignored[include ignored checks in output]' \
  '--no-ignores[do not apply any ignore rules]' \
  '--force-all-dirs[include everything below provided directory]' \
  '--run-statistics[view statistics of current findings]' \
  '(-w --workspace)'{-w,--workspace}'=[workspace for ignore limits]:workspace:' \
  '(-m --minimum-severity)'{-m,--minimum-severity}'=[minimum severity to report]:severity:(CRITICAL HIGH MEDIUM LOW)' \
  '--rego-policy-dir=[directory of rego policies]:dir:_files -/' \
  '--print-rego-input[print JSON input to rego policies]' \
  '--no-module-downloads[do not download remote modules]' \
  '--rego-only[run rego policies exclusively]' \
  '--code-theme=[code annotation theme]:theme:(light dark)' \
  '--no-code[do not include code snippets in output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:directory:_files -/' && return 0
