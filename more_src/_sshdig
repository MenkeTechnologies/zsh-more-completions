#compdef sshdig
# Documentation: https://www.wireshark.org/docs/man-pages/sshdig.html
# Provide an interface to capture system calls from a remote host through SSH

local ret=1

_arguments -s -S \
  '--help[display program arguments]' \
  '--version[display program version]' \
  '--extcap-interfaces[list available interfaces]' \
  '--extcap-interface=[specify which interface to use]:interface:' \
  '--extcap-dlts[list data link types for specified interface]' \
  '--extcap-config[list configuration options for interface]' \
  '--extcap-capture-filter=[set capture filter (tshark -f)]:filter:' \
  '--capture[begin capturing and write data to fifo location]' \
  '--fifo=[save captured data to file or pipe]:path:_files' \
  '--remote-host=[address of remote host for capture]:host:_hosts' \
  '--remote-port=[SSH port on remote host]:port:' \
  '--remote-username=[SSH authentication username]:username:_users' \
  '--remote-password=[SSH authentication password]:password:' \
  '--sshkey=[path to private key (OpenSSH format)]:key:_files' \
  '--sshkey-passphrase=[passphrase for private key]:passphrase:' \
  '--proxycommand=[proxy command for SSH connection]:command:' \
  '--remote-capture-command-select=[select sysdig or custom capture command]:type:' \
  '--remote-capture-command=[custom remote capture command]:command:' \
  '--remote-priv=[privilege elevation method]:method:(none sudo doas)' \
  '--remote-priv-user=[privileged username for sudo/doas]:username:_users' \
  '--remote-filter=[remote capture filter for remote program]:filter:' \
  '--remote-count=[number of events to capture]:number:' \
  '--remote-modern-bpf[use eBPF probe instead of kernel module]' \
  '--remote-io-snaplen=[bytes to capture per I/O event]:bytes:' && ret=0

return ret
