#compdef nrfjprog

_arguments -s \
  '--program=[write hex to flash]:file:_files -g "*.hex"' \
  '--verify=[verify hex against flash]:file:_files -g "*.hex"' \
  '--fast[fast verify]' \
  '--readcode=[read code region to file]:file:_files' \
  '--readuicr=[read UICR to file]:file:_files' \
  '--readram=[read RAM to file]:file:_files' \
  '--readqspi=[read QSPI to file]:file:_files' \
  '--readregs[print CPU registers]' \
  '--memrd=[read memory address]:addr:' \
  '--w=[memory access width]:bits:(8 16 32)' \
  '--n=[count]:n:' \
  '--memwr=[write memory address]:addr:' \
  '--ramwr=[write RAM address]:addr:' \
  '--val=[value to write]:val:' \
  '--chiperase[full chip erase]' \
  '--sectorerase[sector erase]' \
  '--sectoranduicrease[sector and UICR erase]' \
  '--erasepage=[erase pages]:range:' \
  '--eraseuicr[erase UICR]' \
  '(--eraseall -e)'{--eraseall,-e}'[erase all]' \
  '--qspichiperase[QSPI chip erase]' \
  '--qspisectorerase[QSPI sector erase]' \
  '--qspieraseall[QSPI erase all]' \
  '(--reset -r)'{--reset,-r}'[system reset]' \
  '(--pinreset -p)'{--pinreset,-p}'[hardware pin reset]' \
  '(--debugreset -d)'{--debugreset,-d}'[debug reset]' \
  '--halt[halt CPU]' \
  '--run[run CPU]' \
  '--pc=[program counter]:addr:' \
  '--sp=[stack pointer]:addr:' \
  '--pinresetenable[enable pin reset]' \
  '--rbp=[readback protection]:level:(CR0 ALL)' \
  '--recover[recover device]' \
  '--family=[device family]:family:(NRF51 NRF52 NRF53 NRF54L NRF54H NRF91 UNKNOWN)' \
  '(--snr -s)'{--snr=,-s}'[debugger serial number]:sn:' \
  '(--ids -i)'{--ids,-i}'[list connected debuggers]' \
  '--com[list debugger COM ports]' \
  '(--clockspeed -c)'{--clockspeed=,-c}'[SWD clock kHz]:khz:' \
  '--deviceversion[show device version]' \
  '--jdll=[J-Link DLL]:file:_files' \
  '--ini=[ini file]:file:_files' \
  '--qspiini=[QSPI ini file]:file:_files' \
  '--log=[log file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--licenses[show licenses]'
