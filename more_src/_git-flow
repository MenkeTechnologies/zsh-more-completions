#compdef git-flow

# Zsh completion for git-flow (git branching model)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'init:initialize git-flow'
      'feature:manage feature branches'
      'bugfix:manage bugfix branches'
      'release:manage release branches'
      'hotfix:manage hotfix branches'
      'support:manage support branches'
      'log:show log of feature branch'
      'config:show git-flow configuration'
      'version:show version'
    )
    _describe -t commands 'git-flow command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (init)
        _arguments \
          '-d[use default branch naming]' \
          '-f[force reinitialization]' && ret=0
        ;;
      (feature|bugfix)
        local -a subcmds=(
          'start:start a new branch'
          'finish:finish a branch'
          'publish:publish a branch to remote'
          'pull:pull a branch from remote'
          'track:track a remote branch'
          'diff:show diff against develop'
          'rebase:rebase against develop'
          'checkout:switch to a branch'
          'delete:delete a branch'
          'list:list branches'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
          (subargs)
            case ${words[1]} in
              (start)
                _arguments \
                  '-F[fetch from origin first]' \
                  '1:name' && ret=0
                ;;
              (finish)
                _arguments \
                  '-r[rebase instead of merge]' \
                  '-F[fetch from origin first]' \
                  '-D[force delete branch]' \
                  '--no-ff[never fast-forward]' \
                  '1:name' && ret=0
                ;;
              (publish|pull|track|checkout|delete)
                _arguments '1:name' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (release)
        local -a subcmds=(
          'start:start a release'
          'finish:finish a release'
          'publish:publish a release'
          'track:track a release'
          'delete:delete a release'
          'list:list releases'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
          (subargs)
            case ${words[1]} in
              (start)
                _arguments \
                  '-F[fetch from origin first]' \
                  '1:version' && ret=0
                ;;
              (finish)
                _arguments \
                  '-F[fetch from origin first]' \
                  '-s[sign tag]' \
                  '-u[GPG key for signing]:key' \
                  '-m[tag message]:message' \
                  '-p[push to remote after finish]' \
                  '-k[keep branch after finish]' \
                  '-n[do not tag]' \
                  '--no-ff[never fast-forward]' \
                  '1:version' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (hotfix)
        local -a subcmds=(
          'start:start a hotfix'
          'finish:finish a hotfix'
          'publish:publish a hotfix'
          'delete:delete a hotfix'
          'list:list hotfixes'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
          (subargs)
            case ${words[1]} in
              (start)
                _arguments '1:version' && ret=0
                ;;
              (finish)
                _arguments \
                  '-F[fetch from origin first]' \
                  '-s[sign tag]' \
                  '-u[GPG key]:key' \
                  '-m[tag message]:message' \
                  '-p[push to remote]' \
                  '-k[keep branch]' \
                  '-n[do not tag]' \
                  '1:version' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (support)
        local -a subcmds=(
          'start:start a support branch'
          'list:list support branches'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
