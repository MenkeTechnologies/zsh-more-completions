#compdef exifprobe
# Documentation: https://manpages.debian.org/testing/exifprobe/exifprobe.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# exifprobe: probe image files and report contents (hfiguiere/exifprobe).
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-S[structure mode (default)]' \
  '-R[report mode (tagnames + decimal values, inline)]' \
  '-L[list mode (tags and values only)]' \
  '-Z[zero all optional output flags]' \
  '-c[toggle ANSI color sequences]' \
  '-a[toggle printing of file addresses/offsets]' \
  '-I[toggle indentation display]' \
  '-o[toggle inline printing of offset IFD values]' \
  '-D[limit numerical output to decimal]' \
  '-X[limit numerical output to hex]' \
  '-t[print tag numbers]' \
  '-u[print raw Unicode data]' \
  '-n[print filename at beginning of each line]' \
  '-p+[toggle printing identifiers (sections, segments, APP entries, etc.)]:items:' \
  '-e+[toggle IFD entry elements (tagnames, numbers, types, values, offsets)]:items:' \
  '-U+[dump undefined TIFF data (length or a for ASCII)]:len:' \
  '-M+[dump unrecognized MakerNotes]:len:' \
  '-A+[dump unrecognized JPEG APP segments]:len:' \
  '-B+[dump binary image data]:len:' \
  '-C+[list matching camera make+model]:make+model:' \
  '-O+[start processing at file offset]:offset:' \
  '-N+[force MakerNote version]:version:' \
  '-m+[force interpretation by camera make]:make:' \
  '-l+[force interpretation by camera model]:model:' \
  '*:file:_files -g "*.(jpg|jpeg|tif|tiff|nef|cr2|arw|dng|raw|raf|orf|rw2|pef|srw|x3f)"' && ret=0

return ret
