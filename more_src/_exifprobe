#compdef exifprobe

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-c[show classified tag data]' \
  '-d[show details for each IFD]' \
  '-e[show entries instead of summary]' \
  '-f+[output field separator]:sep:' \
  '-i+[ifd to show]:ifd:' \
  '-m[show only main image]' \
  '-q[quiet]' \
  '-r[show raw data]' \
  '-S[short summary]' \
  '-T[show tags only]' \
  '-v[verbose]' \
  '-x[hex dump unknown tags]' \
  '*:file:_files -g "*.{jpg,jpeg,tif,tiff,nef,cr2,arw,dng,raw,raf,orf,rw2,pef,srw,x3f}"' && ret=0

return ret
