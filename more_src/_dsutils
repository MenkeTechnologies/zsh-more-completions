#compdef dsutils
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss11.html
# SMURF: utilities for estimating focal plane distortion.

local ret=1

_arguments -s -S \
  'IN=[input time series cube NDF]:ndf:_files' \
  'INCAT=[text catalogue of pixel positions]:file:_files' \
  'INFITX=[2D NDF with fitted X offsets]:ndf:_files' \
  'INFITY=[2D NDF with fitted Y offsets]:ndf:_files' \
  'OUTCAT=[output catalogue file]:file:_files' \
  'OUTCODE=[output C code file]:file:_files' \
  'OUTDX=[output NDF for X corrections]:ndf:_files' \
  'OUTDY=[output NDF for Y corrections]:ndf:_files' \
  'OUTANG=[output NDF for distortion orientation]:ndf:_files' \
  'OUTFX=[output NDF for focal plane X]:ndf:_files' \
  'OUTFY=[output NDF for focal plane Y]:ndf:_files' \
  'OUTMAG=[output NDF for distortion magnitude]:ndf:_files' \
  'OUTSLICE=[output NDF for extracted time slice]:ndf:_files' \
  'BMAP=[AST dump of mapping to SKY frame]:file:_files' \
  'BORDER=[border width for edge exclusion]:n:' \
  'COLNAME=[catalogue column to extract]:col:' \
  'COLNDF=[output NDF for column values]:ndf:_files' \
  'FORWARD=[forward vs inverse PolyMap]:flag:(TRUE FALSE)' \
  'FPIXSIZE=[pixel size in mm]:size:' \
  'FXHI=[upper focal plane X in mm]:val:' \
  'FXLO=[lower focal plane X in mm]:val:' \
  'FXOFF=[focal plane X for offset removal]:val:' \
  'FYHI=[upper focal plane Y in mm]:val:' \
  'FYLO=[lower focal plane Y in mm]:val:' \
  'FYOFF=[focal plane Y for offset removal]:val:' \
  'ITIME=[time slice index to extract]:n:' \
  'LOWFACTOR=[min data sum fraction]:val:' \
  'NITER=[sigma-clipping iterations]:n:' \
  'SUBARRAY=[subarray identifier]:name:' \
  'XBOL=[test bolometer X index]:n:' \
  'YBOL=[test bolometer Y index]:n:' \
  'RADIUS=[test circle radius in bolometers]:n:' \
  '*:ndf:_files' && ret=0

return ret
