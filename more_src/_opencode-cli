#compdef opencode-cli
# Documentation: https://opencode.ai/docs/cli
# Reference accessed: 2026-05-23
# Verified: npx opencode-ai --help.

# Zsh completion for opencode-cli - OpenCode AI coding agent (alternate binary name)

local curcontext="$curcontext" state line ret=1

_opencode_cli_commands() {
  local -a commands=(
    'run:run opencode with a message'
    'providers:manage AI providers and credentials'
    'auth:alias for providers'
    'agent:manage agents'
    'session:manage sessions'
    'serve:start headless opencode server'
    'web:start server with web interface'
    'attach:attach to running opencode server'
    'models:list available models'
    'stats:token usage and cost statistics'
    'upgrade:upgrade opencode'
    'uninstall:uninstall opencode'
    'export:export session as JSON'
    'import:import session from JSON or URL'
    'github:manage GitHub agent'
    'pr:checkout GitHub PR and run opencode'
    'plugin:install plugin'
    'plug:alias for plugin'
    'db:database tools'
    'mcp:manage MCP servers'
    'acp:start ACP server'
    'completion:generate shell completion'
    'debug:debugging tools'
    'help:show help'
  )
  _describe -t commands 'opencode-cli command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :_opencode_cli_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments \
          '(-c --continue)'{-c,--continue}'[continue last session]' \
          '(-s --session)'{-s,--session=}'[session ID]:session:' \
          '(-m --model)'{-m,--model=}'[model]:model:' \
          '(-f --file)'{-f,--file=}'[attach file]:file:_files' \
          '--agent=[agent]:agent:' \
          '--format=[output format]:(default json)' \
          '--dir=[working directory]:directory:_directories' \
          '--dangerously-skip-permissions[auto-approve permissions]' \
          '*:message:' && ret=0
        ;;
      providers|auth)
        _arguments '1:subcommand:(login list logout)' && ret=0
        ;;
      agent)
        _arguments '1:subcommand:(create list)' && ret=0
        ;;
      session)
        _arguments '1:subcommand:(list delete)' && ret=0
        ;;
      serve|web)
        _arguments '(-p --port)'{-p,--port=}'[port]:port:' && ret=0
        ;;
      attach)
        _arguments '*:url:' && ret=0
        ;;
      models)
        _arguments '*:provider:provider:' && ret=0
        ;;
      upgrade)
        _arguments '*:target:version:' && ret=0
        ;;
      export)
        _arguments '*:sessionID:session:' && ret=0
        ;;
      import)
        _arguments '1:file:file:_files' && ret=0
        ;;
      pr)
        _arguments '1:number:PR number:' && ret=0
        ;;
      plugin|plug)
        _arguments '1:module:module:' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
