#compdef cabal-fmt

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-i --inplace)'{-i,--inplace}'[edit file in place]' \
  '(-c --check)'{-c,--check}'[check formatting]' \
  '(-n --no-cabal-file)'{-n,--no-cabal-file}'[do not look for cabal file]' \
  '--indent=+[indent width]:n:' \
  '--tabular[tabular mode]' \
  '--no-tabular[disable tabular]' \
  '*:cabal file:_files -g "*.cabal"' && ret=0

return ret
