#compdef eclean eclean-dist eclean-pkg

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --pretend)'{-p,--pretend}'[only display what would be cleaned]' \
  '(-q --quiet)'{-q,--quiet}'[be quiet]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-n --package-names)'{-n,--package-names}'[protect all installed versions]' \
  '(-C --nocolor)'{-C,--nocolor}'[disable colored output]' \
  '(-e --exclude-file)'{-e,--exclude-file}'+[path to exclusion file]:file:_files' \
  '(-i --interactive)'{-i,--interactive}'[ask for confirmation]' \
  '(-d --destructive)'{-d,--destructive}'[more aggressive cleaning]' \
  '(-t --time-limit)'{-t,--time-limit}'+[only clean files older than]:time:' \
  '(-s --size-limit)'{-s,--size-limit}'+[do not clean if space is below]:size:' \
  '(-f --fetch-restricted)'{-f,--fetch-restricted}'[protect fetch-restricted files]' \
  '1:action:->actions' && ret=0

case $state in
  (actions)
    local -a actions=(
      'distfiles:clean source files in /var/cache/distfiles'
      'packages:clean binary packages in /var/cache/binpkgs'
    )
    _describe -t actions 'action' actions && ret=0
    ;;
esac

return ret
