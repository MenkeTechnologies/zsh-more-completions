#compdef rke2

local -a _rke2_commands
_rke2_commands=(
  'server:run RKE2 server'
  'agent:run RKE2 agent'
  'etcd-snapshot:trigger etcd snapshot'
  'certificate:manage certificates'
  'secrets-encrypt:manage secrets encryption'
  'token:manage tokens'
  'completion:generate shell completion'
  'help:help about any command'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug[enable debug logging]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'rke2 commands' _rke2_commands
    ;;
  args)
    case "$words[1]" in
      server)
        _arguments \
          '--config[config file]:file:_files' \
          '--bind-address[bind address]:address' \
          '--advertise-address[advertise address]:address' \
          '--tls-san[additional TLS SANs]:san' \
          '--data-dir[data directory]:dir:_directories' \
          '--cluster-cidr[cluster CIDR]:cidr' \
          '--service-cidr[service CIDR]:cidr' \
          '--cluster-dns[cluster DNS]:address' \
          '--cluster-domain[cluster domain]:domain' \
          '--token[shared token]:token' \
          '--token-file[token file]:file:_files' \
          '--server[server to connect to]:url' \
          '--write-kubeconfig[kubeconfig output path]:file:_files' \
          '--write-kubeconfig-mode[kubeconfig file mode]:mode' \
          '--node-name[node name]:name' \
          '--node-label[node labels]:label' \
          '--node-taint[node taints]:taint' \
          '--cni[CNI plugin]:cni:(calico canal cilium none)' \
          '--disable[disable components]:component' \
          '--etcd-expose-metrics[expose etcd metrics]' \
          '--etcd-snapshot-schedule-cron[etcd snapshot cron]:cron' \
          '--etcd-snapshot-retention[etcd snapshot retention]:count' \
          '--kube-apiserver-arg[kube-apiserver extra args]:arg' \
          '--kube-controller-manager-arg[kube-controller-manager extra args]:arg' \
          '--kube-scheduler-arg[kube-scheduler extra args]:arg' \
          '--profile[CIS profile]:profile:(cis-1.6 cis-1.23)'
        ;;
      agent)
        _arguments \
          '--config[config file]:file:_files' \
          '--data-dir[data directory]:dir:_directories' \
          '--token[shared token]:token' \
          '--token-file[token file]:file:_files' \
          '--server[server URL]:url' \
          '--node-name[node name]:name' \
          '--node-label[node labels]:label' \
          '--node-taint[node taints]:taint' \
          '--container-runtime-endpoint[CRI endpoint]:endpoint' \
          '--snapshotter[containerd snapshotter]:snapshotter' \
          '--profile[CIS profile]:profile:(cis-1.6 cis-1.23)'
        ;;
      etcd-snapshot)
        _arguments \
          '1:subcommand:(save list delete prune)' \
          '--name[snapshot name]:name' \
          '--dir[snapshot directory]:dir:_directories' \
          '--s3[enable S3]' \
          '--s3-bucket[S3 bucket]:bucket' \
          '--s3-region[S3 region]:region' \
          '--s3-endpoint[S3 endpoint]:endpoint' \
          '--s3-folder[S3 folder]:folder'
        ;;
      certificate)
        _arguments '1:subcommand:(rotate)'
        ;;
      secrets-encrypt)
        _arguments '1:subcommand:(status enable disable prepare rotate reencrypt)'
        ;;
      token)
        _arguments \
          '1:subcommand:(create list delete rotate)' \
          '--data-dir[data directory]:dir:_directories'
        ;;
    esac
    ;;
esac
