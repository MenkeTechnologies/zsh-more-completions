#compdef stringtie
# Documentation: https://man.archlinux.org/search?q=stringtie
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '--version[show version]' \
  '-G+[reference annotation GTF]:file:_files -g "*.(gtf|gff)"' \
  '-o+[output GTF file]:file:_files' \
  '-l+[label prefix for output transcripts]:prefix:' \
  '-f+[minimum isoform fraction]:fraction:' \
  '-L[long reads mode]' \
  '-R[when long reads are provided do not assemble]' \
  '-m+[minimum transcript length]:length:' \
  '-a+[minimum anchor length for junctions]:length:' \
  '-j+[minimum junction coverage]:coverage:' \
  '-t[disable trimming of predicted transcripts]' \
  '-c+[minimum reads per bp coverage]:coverage:' \
  '-g+[max gap between reads in a bundle]:gap:' \
  '-M+[fraction of multi-mapped reads]:fraction:' \
  '-p+[number of threads]:threads:' \
  '-A+[gene abundances output]:file:_files' \
  '-B[enable output of Ballgown table files]' \
  '-b+[path for Ballgown tables]:dir:_files -/' \
  '-e[only estimate abundance for given annotation]' \
  '-x+[ignore reference sequences]:comma-separated list:' \
  '--merge[transcript merge mode]' \
  '-i+[minimum input transcript FPKM to include]:fpkm:' \
  '-T+[minimum input transcript TPM to include]:tpm:' \
  '--rf[assume stranded library - first read reverse]' \
  '--fr[assume stranded library - first read forward]' \
  '-v[verbose mode]' \
  '*:BAM file:_files -g "*.bam"' && ret=0

return ret
