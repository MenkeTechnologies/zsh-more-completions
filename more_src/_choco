#compdef choco chocolatey

# Zsh completion for Chocolatey (Windows package manager - for WSL/cross-platform)

_choco() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'install:install packages'
    'upgrade:upgrade packages'
    'uninstall:uninstall packages'
    'search:search remote packages'
    'list:list local packages'
    'info:get package information'
    'pin:manage package pins'
    'outdated:list outdated packages'
    'pack:compile a .nuspec to a .nupkg'
    'push:push a package to a source'
    'source:manage sources'
    'config:manage configuration'
    'feature:manage features'
    'apikey:manage API keys'
    'export:export list of currently installed packages'
    'template:manage package templates'
    'cache:manage download cache'
    'new:create a new package scaffold'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'choco command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        install)
          _arguments -s -S \
            '(-s --source)'{-s,--source}'[source]:source:' \
            '--version=[version to install]:version:' \
            '--pre[include prerelease versions]' \
            '--prerelease[include prerelease versions]' \
            '--x86[force x86 architecture]' \
            '--forcex86[force x86 architecture]' \
            '--ia=[installer arguments]:args:' \
            '--install-arguments=[installer arguments]:args:' \
            '-o[install all dependencies]' \
            '--override-arguments[override package arguments]' \
            '--not-silent[do not install silently]' \
            '--params=[package parameters]:params:' \
            '--package-parameters=[package parameters]:params:' \
            '--allow-downgrade[allow downgrade]' \
            '-f[force install]' \
            '--force[force install]' \
            '-n[skip PowerShell]' \
            '--skip-automation-scripts[skip PowerShell automation scripts]' \
            '-y[confirm all prompts]' \
            '--yes[confirm all prompts]' \
            '--no-progress[do not show progress]' \
            '--ignore-checksums[ignore package checksums]' \
            '--ignore-dependencies[ignore package dependencies]' \
            '--force-dependencies[force install dependencies]' \
            '--execution-timeout=[max wait time in seconds]:seconds:' \
            '--cache-location=[cache location]:directory:_files -/' \
            '--fail-on-error-output[fail on error output]' \
            '--use-system-powershell[use system PowerShell]' \
            '--no-color[do not show colors]' \
            '--limit-output[limit output]' \
            '--debug[show debug messages]' \
            '--verbose[show verbose messages]' \
            '--trace[show trace messages]' \
            '--log-file=[log file]:log file:_files' \
            '*:packages:' \
            && ret=0
          ;;
        upgrade)
          _arguments -s -S \
            '(-s --source)'{-s,--source}'[source]:source:' \
            '--version=[version to upgrade to]:version:' \
            '--pre[include prerelease versions]' \
            '--except=[packages to exclude]:packages:' \
            '-f[force upgrade]' \
            '--force[force upgrade]' \
            '-y[confirm all prompts]' \
            '--yes[confirm all prompts]' \
            '--no-progress[do not show progress]' \
            '--ignore-checksums[ignore checksums]' \
            '--ignore-dependencies[ignore dependencies]' \
            '--fail-on-unfound[fail if package not found]' \
            '--exclude-prerelease[exclude prerelease]' \
            '--use-remembered-options[use remembered options]' \
            '--limit-output[limit output]' \
            '--debug[show debug messages]' \
            '--verbose[show verbose messages]' \
            '--log-file=[log file]:log file:_files' \
            '*:packages:' \
            && ret=0
          ;;
        uninstall)
          _arguments -s -S \
            '--version=[version to uninstall]:version:' \
            '-a[uninstall all versions]' \
            '--all-versions[uninstall all versions]' \
            '--ia=[installer arguments]:args:' \
            '-x[remove dependencies]' \
            '--remove-dependencies[remove dependencies]' \
            '-f[force uninstall]' \
            '--force[force uninstall]' \
            '-y[confirm all prompts]' \
            '--yes[confirm all prompts]' \
            '--no-progress[do not show progress]' \
            '--limit-output[limit output]' \
            '--debug[show debug messages]' \
            '--verbose[show verbose messages]' \
            '*:packages:' \
            && ret=0
          ;;
        search)
          _arguments -s -S \
            '(-s --source)'{-s,--source}'[source]:source:' \
            '-e[exact match]' \
            '--exact[exact match]' \
            '--by-id-only[search by ID only]' \
            '--by-tag-only[search by tag only]' \
            '--id-starts-with[starts with]:id' \
            '--pre[include prerelease]' \
            '--approved-only[show only approved packages]' \
            '--not-broken[show only packages without known issues]' \
            '--page=[page number]:page:' \
            '--page-size=[page size]:size:' \
            '--order-by-popularity[order by popularity]' \
            '--limit-output[limit output]' \
            '1:filter:' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--debug[show debug messages]' \
            '--verbose[show verbose messages]' \
            '--limit-output[limit output]' \
            '--no-color[no colors]' \
            '--accept-license[accept license]' \
            '-y[confirm all]' \
            '--yes[confirm all]' \
            '-f[force]' \
            '--force[force]' \
            '--log-file=[log file]:log file:_files' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_choco "$@"
