#compdef elan-init
# Documentation: https://github.com/leanprover/elan
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# leanprover/elan — elan-init is the installer binary; see src/bin/elan-init.rs / `elan-init -h` for -y, --default-toolchain, export-file.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-y}'[non-interactive defaults]' \
  '--default-toolchain=[initial Lean toolchain]:toolchain' \
  '--export-file=[emit env snippet for FILE]:file:_files' \
  '--no-modify-path[do not update shell rc]' && ret=0

return ret
