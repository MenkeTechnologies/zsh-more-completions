#compdef hw-probe

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-all[probe all hardware and upload the result]' \
  '-check[check operability of hardware]' \
  '-log[save probe log to directory]:log dir:_files -/' \
  '-show[show the system probe result]' \
  '-show-dmesg[show dmesg log]' \
  '-show-devices[show list of devices]' \
  '-show-host[show host information]' \
  '-save=[save probe to specified directory]:directory:_files -/' \
  '-upload[upload local probe to database]' \
  '-decode=[decode probe from specified directory]:directory:_files -/' \
  '-import=[import probes from specified directory]:directory:_files -/' \
  '-inventory-id=[set the hardware inventory ID]:inventory ID:' \
  '-group=[set the hardware group]:group name:' \
  '-generate-inventory[generate a hardware inventory ID]' \
  '-email=[send email with results]:email address:' \
  '-fix=[add a fix for a device]:device ID:' \
  '-printers[probe printers]' \
  '-scanners[probe scanners]' \
  '-bluetooth[probe bluetooth devices]' \
  '-dump-acpi[dump ACPI tables]' \
  '-decode-acpi[decode ACPI tables]' \
  '-sudo[use sudo for privileged operations]' \
  '-flatpak[collect Flatpak information]' \
  '-snap[collect Snap information]' \
  '-appimage[collect AppImage information]' \
  '-disable=[disable specific probe]:probe type:(logs dmesg xorg xrandr pci usb sdio lsb os cpuid cpuinfo meminfo hwinfo lspci lsusb dmidecode sensors hddtemp hdparm smartctl biosdecode edid glxinfo vulkaninfo vdpauinfo vainfo)' \
  '-enable=[enable specific probe]:probe type:(logs dmesg xorg xrandr pci usb sdio lsb os cpuid cpuinfo meminfo hwinfo lspci lsusb dmidecode sensors hddtemp hdparm smartctl biosdecode edid glxinfo vulkaninfo vdpauinfo vainfo)' \
  '-maxprobe=[maximum number of probes to upload]:number:' \
  '-pc-name=[set PC name]:name:' \
  '-list[list uploaded probes]' \
  '-get-group=[get hardware group]:group ID:' \
  '-rm-group=[remove hardware group]:group ID:' \
  '-get=[download a probe from the database]:probe ID:' \
  '-hwinfo-path=[path to hwinfo binary]:hwinfo path:_files' \
  '-identify-drive=[identify a drive]:drive:_files' \
  '-identify-monitor=[identify a monitor]:monitor:' \
  '-identify-pci=[identify a PCI device]:PCI ID:' \
  '-identify-usb=[identify a USB device]:USB ID:' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[show version]' \
  && ret=0

return ret
