#compdef zfs-allow
# _zfs-allow — OpenZFS zfs allow (delegate per-user/group permissions on a dataset to non-root users; -u user, -g group, -e everyone, -s named set, -c create-time, -d only descendants, -l only this dataset; comma-separated permission list (create destroy snapshot mount send rollback receive ...))
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zfs/zfs_main.c on tip.

_zfs-allow() {
    _arguments \
        '-d[only descendents]' \
        '-l[only this dataset]' \
        '-c[creation perms]' \
        '-s+[named permission set]:set:' \
        '-u+[user]:user:_users' \
        '-g+[group]:group:_groups' \
        '-e[everyone]' \
        '*:perms or dataset:'
}

_zfs-allow "$@"
