#compdef non-session-manager
# Documentation: https://man.archlinux.org/man/extra/new-session-manager/nsmd.1.en
# New Session Manager daemon for grouping audio programs into sessions

local ret=1

_arguments -s -S \
  '--help[show help screen]' \
  '--version[show version]' \
  '--osc-port=[OSC port number]:port' \
  '--session-root=[base path for sessions]:path:_files -/' \
  '--load-session=[load existing session]:name' \
  '--gui-url=[connect to running legacy GUI]:url' \
  '--detach[detach from console]' \
  '--quiet[suppress messages except warnings and errors]' && ret=0

return ret
