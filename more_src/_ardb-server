#compdef ardb-server
# Documentation: https://github.com/yinqiwen/ardb
# Ardb: Redis-protocol compatible NoSQL with pluggable storage engines

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show usage]' \
  '(- *)'{-v,--version}'[display version]' \
  '1:config file:_files' && ret=0

return ret
