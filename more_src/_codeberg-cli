#compdef codeberg-cli berg
# _codeberg-cli — Codeberg.org public Forgejo instance CLI alias (Berrysoft/berg, Rust); clap-rs
# upstream: https://codeberg.org/Berrysoft/berg

_codeberg-cli() {
    local -a sub=(
        'auth:authenticate to codeberg'
        'auth:login:login'
        'auth:logout:logout'
        'auth:status:show auth status'
        'auth:user:show user info'
        'browse:open repo in browser'
        'clone:clone a repo'
        'config:get:get config'
        'config:set:set config'
        'config:list:list config'
        'issue:list:list issues'
        'issue:create:create issue'
        'issue:view:view issue'
        'issue:close:close issue'
        'issue:reopen:reopen issue'
        'issue:comment:comment issue'
        'label:list:list labels'
        'label:create:create label'
        'label:delete:delete label'
        'org:list:list orgs'
        'org:view:view org'
        'pull-request:list:list prs'
        'pull-request:create:create pr'
        'pull-request:view:view pr'
        'pull-request:close:close pr'
        'pull-request:reopen:reopen pr'
        'pull-request:merge:merge pr'
        'repo:list:list repos'
        'repo:create:create repo'
        'repo:view:view repo info'
        'repo:fork:fork repo'
        'repo:delete:delete repo'
        'repo:archive:archive repo'
        'repo:rename:rename repo'
        'repo:transfer:transfer repo'
        'milestone:list:list milestones'
        'milestone:create:create milestone'
        'milestone:close:close milestone'
        'release:list:list releases'
        'release:create:create release'
        'release:delete:delete release'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--repo=+[repo owner/name]:str:' \
        '-R+[repo owner/name]:str:' \
        '--token=+[api token]:str:' \
        '--instance=+[codeberg instance url]:url:_urls' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'codeberg subcommand' sub ;;
        args)
            case $words[1] in
                issue:create) _arguments \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--body=+[body]:str:' \
                    '-b+[body]:str:' \
                    '--label=+[label]:str:' \
                    '-l+[label]:str:' \
                    '--assignee=+[assignee]:str:' \
                    '-a+[assignee]:str:' \
                    '--milestone=+[milestone]:str:' ;;
                pull-request:create) _arguments \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--body=+[body]:str:' \
                    '-b+[body]:str:' \
                    '--base=+[base branch]:str:' \
                    '--head=+[head branch]:str:' \
                    '--draft[draft pr]' \
                    '--label=+[label]:str:' \
                    '--assignee=+[assignee]:str:' ;;
                clone) _arguments '1:repo:' '2:directory:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_codeberg-cli "$@"
