#compdef ncnnoptimize
# Documentation: https://github.com/Tencent/ncnn/wiki/use-ncnn-with-pytorch-or-onnx
# Optimize an ncnn model (fuse layers, fp16, etc.)

local ret=1

_arguments -s -S \
  '1:input ncnn param:_files -g "*.param"' \
  '2:input ncnn bin:_files -g "*.bin"' \
  '3:output ncnn param:_files -g "*.param"' \
  '4:output ncnn bin:_files -g "*.bin"' \
  '5:flag (0=fp32 1=fp16):(0 1)' && ret=0

return ret
