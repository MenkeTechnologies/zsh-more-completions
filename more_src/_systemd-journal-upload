#compdef systemd-journal-upload
# Documentation: https://man7.org/linux/man-pages/man8/systemd-journal-upload.service.8.html
# Reference accessed: 2026-05-21
# Verified: upstream systemd-journal-upload(8) manpage.
# Removed: -m as machine ID (-m is --merge with no arg per upstream),
# --machine (not documented).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-u --url)'{-u,--url}'=[upload destination URL]:url:' \
  '--key=[SSL key file]:file:_files' \
  '--cert=[SSL certificate file]:file:_files' \
  '--trust=[SSL CA certificate file]:file:_files' \
  '--system[upload system services and kernel entries only]' \
  '--user[upload current user entries only]' \
  '(-m --merge)'{-m,--merge}'[upload interleaved entries from all journals]' \
  '--namespace=[upload from journal namespace]:ns:' \
  '(-D --directory)'{-D,--directory}'=[upload from journal directory]:dir:_files -/' \
  '--file=[upload journal files matching glob]:glob:' \
  '--cursor=[upload from cursor location]:cur:' \
  '--after-cursor=[upload after cursor location]:cur:' \
  '--save-state=[save cursor state to file]:file:_files' \
  '--follow=[wait for new input]:flag:(yes no)' && ret=0

return ret
