#compdef psm-convert
# Documentation: https://crux.ms/commands/psm-convert.html
# Crux psm-convert: convert PSM files between formats.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--input-format=[input file format]:fmt:(auto tsv sqt pepxml mzidentml)' \
  '--distinct-matches=[matches/ions are distinct vs total]:bool:(T F)' \
  '--protein-database=[FASTA protein file path]:file:_files' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--overwrite=[replace existing files]:bool:(T F)' \
  '--parameter-file=[configuration file]:file:_files' \
  '--verbosity=[verbosity level 0-60]:level' \
  '*:psm input:_files' && ret=0

return ret
