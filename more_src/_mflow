#compdef mflow
# Documentation: https://manpages.debian.org/testing/mblaze/mflow.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream Debian man page at the URL above.
# mflow (mblaze): reflow format=flowed plain text from stdin.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[force wrapping of long lines]' \
  '*-q[prefix lines with ">" (repeatable)]' \
  '-w+[maximum line width]:width:' && ret=0

return ret
