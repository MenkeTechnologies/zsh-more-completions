#compdef sulog
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/stretching_moveout_resamp/sulog.c
# Stretch of time axis (logstretch) of SU data

local ret=1

_arguments -s -S \
  'ntmin=[minimum time sample of interest]:ntmin' \
  'outpar=[output parameter file]:file:_files' \
  'm=[length of stretched data set via nextpow(m*nt)]:m' \
  'ntau=[override length of stretched data]:ntau' \
  '*:file:_files' && ret=0

return ret
