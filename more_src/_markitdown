#compdef markitdown
# Documentation: https://man.archlinux.org/search?q=markitdown
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-x --extension)'{-x,--extension}'=[filename extension hint]:ext:' \
  '(-m --mime-type)'{-m,--mime-type}'=[MIME type hint]:mime:' \
  '(-c --charset)'{-c,--charset}'=[charset hint]:charset:' \
  '(-d --use-docintel)'{-d,--use-docintel}'[use Azure Document Intelligence]' \
  '(-e --endpoint)'{-e,--endpoint}'=[Document Intelligence endpoint]:url:' \
  '(-p --use-plugins)'{-p,--use-plugins}'[enable third-party plugins]' \
  '--list-plugins[list installed plugins]' \
  '--keep-data-uris[keep base64 data URIs in output]' \
  '1:input file:_files'
