#compdef markitdown
# Documentation: https://github.com/microsoft/markitdown
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '--version[show version]' \
  '-o+[output file]:file:_files' \
  '-x+[filename extension hint]:ext:' \
  '-m+[MIME type hint]:mime:' \
  '-c+[charset hint]:charset:' \
  '-d[use Azure Document Intelligence]' \
  '-e+[Document Intelligence endpoint]:url:' \
  '--use-plugins[enable third-party plugins]' \
  '--list-plugins[list installed plugins]' \
  '--keep-data-uris[keep base64 data URIs in output]' \
  '1:input file:_files'
