#compdef webflow-cli
# _webflow-cli — Webflow no-code site builder CLI alias (Webflow team, TypeScript)
# upstream: https://github.com/webflow/cli

_webflow-cli() {
    local -a sub=(
        'login:login to webflow'
        'logout:logout'
        'whoami:show current user'
        'sites:list sites'
        'sites:create:create site'
        'sites:delete:delete site'
        'sites:publish:publish site'
        'designer-extension:init:scaffold designer extension'
        'designer-extension:bundle:bundle designer extension'
        'apps:init:scaffold app'
        'apps:dev:start app dev server'
        'apps:install:install app on site'
        'apps:uninstall:uninstall app'
        'workspaces:list:list workspaces'
        'workspaces:scaffold:scaffold workspace template'
        'pages:list:list pages'
        'pages:publish:publish pages'
        'collections:list:list collections'
        'collections:items:list:list items'
        'collections:items:create:create item'
        'collections:items:update:update item'
        'collections:items:delete:delete item'
        'webhooks:list:list webhooks'
        'webhooks:create:create webhook'
        'webhooks:delete:delete webhook'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--token=+[api token]:str:' \
        '-t+[api token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'webflow subcommand' sub ;;
        args)
            case $words[1] in
                sites:publish) _arguments \
                    '1:site id:' \
                    '--domains=+[domain]:str:' \
                    '-d+[domain]:str:' \
                    '--all[publish to all]' ;;
                pages:publish) _arguments \
                    '1:site id:' \
                    '--page-ids=+[page ids]:str:' ;;
                apps:dev) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' ;;
            esac
            ;;
    esac
}

_webflow-cli "$@"
