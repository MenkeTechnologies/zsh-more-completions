#compdef imodchopconts
# Documentation: https://bio3d.colorado.edu/imod/doc/man/imodchopconts.html
# Chop up contours in IMOD model based on length or color

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-input -i -InputModel)'{-input,-i,-InputModel}'[Name of input model file. If this option is not entered, the]:file:_files' \
  '(-output -ou -OutputModel)'{-output,-ou,-OutputModel}'[Name of output model file. If this option is not entered,...]:file:_files' \
  '(-length -l -LengthOfPieces)'{-length,-l,-LengthOfPieces}'[The length of the new contours, i.e., the number of points...]:value' \
  '-number[is entered is to leave contours as they are. Unless]' \
  '(-overlap -ov -MinimumOverlap)'{-overlap,-ov,-MinimumOverlap}'[The minimum number of points overlapping between pieces. If...]:value' \
  '(-number -n -NumberOfPieces)'{-number,-n,-NumberOfPieces}'[This option provides an alternative way to specify how to...]:value' \
  '(-surfaces -s -AssignSurfaces)'{-surfaces,-s,-AssignSurfaces}'[Give each new contour a surface number equal to the number...]' \
  '(-colors -c -BreakAtColors)'{-colors,-c,-BreakAtColors}'[Break contours at fine-grained color changes, assigning...]:value' \
  '(-objects -ob -ObjectsToDo)'{-objects,-ob,-ObjectsToDo}'[List of objects to chop up, a comma-separate list of ranges.]:value' \
  '-StandardInput[read parameters from standard input]' \
  '-usage[print usage]' \
  '*:file:_files' && ret=0

return ret
