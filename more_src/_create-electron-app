#compdef create-electron-app
# Documentation: https://www.npmjs.com/package/create-electron-app
# Reference accessed: 2026-05-24
# Verified: npx create-electron-app --help.

# Zsh completion for create-electron-app - Electron Forge project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-t --template)'{-t,--template=}'[Forge template name]:template:' \
  '(-c --copy-ci-files)'{-c,--copy-ci-files}'[copy templated CI files]' \
  '(-f --force)'{-f,--force}'[overwrite existing directory]' \
  '--skip-git[skip git repository initialization]' \
  '--electron-version=[Electron version]:version:(latest beta nightly)' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':directory:_directories' && ret=0

return ret
