#compdef csi-resizer external-resizer
# _csi-resizer — Kubernetes CSI external-resizer sidecar (kubernetes-csi/external-resizer)
# upstream: https://github.com/kubernetes-csi/external-resizer
# Flags from cmd/csi-resizer/main.go + csi-lib-utils/standardflags/flags.go on tip.

_csi-resizer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--master=[apiserver URL override]:url:_urls' \
        '--kubeconfig=[kubeconfig file (out-of-cluster only)]:file:_files' \
        '--csi-address=[CSI driver UDS path]:path:_files' \
        '--resync-period=[informer resync interval]:dur:' \
        '--workers=[concurrent resize workers]:n:' \
        '--extra-modify-metadata[add PV/PVC metadata to ModifyVolume parameters]' \
        '--timeout=[CSI driver-socket wait timeout]:dur:' \
        '--retry-interval-start=[initial retry interval]:dur:' \
        '--retry-interval-max=[max retry interval]:dur:' \
        '--handle-volume-inuse-error=[handle volume-in-use errors]:bool:(true false)' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '--leader-election=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--http-endpoint=[diagnostics HTTP host\:port]:host\:port:' \
        '--metrics-path=[Prometheus metrics HTTP path]:path:' \
        '-v[klog verbosity level]:n:'
}

_csi-resizer "$@"
