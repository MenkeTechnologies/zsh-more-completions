#compdef aws-keychain
# Documentation: https://man.archlinux.org/search?q=aws-keychain
# Reference accessed: 2026-05-16

# Zsh completion for aws-keychain (pda/aws-keychain).

local curcontext="$curcontext" state line ret=1

(( $+functions[_aws_keychain_profiles] )) || _aws_keychain_profiles() {
  compadd -- ${${(f)"$(command aws-keychain ls 2>/dev/null)"}:#}
}

_arguments -s -S \
  '(-R --reset --remove-all)'{-R,--reset,--remove-all}'[remove all aws-keychain entries]' \
  '(-t --key-type)'{-t,--key-type}'[SSH key algorithm]:type:(ed25519 rsa ecdsa)' \
  '(-b --key-bits)'{-b,--key-bits}'[RSA/ECDSA bit length]:bits' \
  '--offline[do not touch the network]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'add:add IAM keys for a GitHub username'
      'exec:run a command with AWS_* env from a profile'
      'ls:list configured profile names'
      'migrate:migrate legacy keychain entries'
      'rm:remove keys for a profile'
    )
    _describe -t commands 'aws-keychain command' commands && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _message 'username[@github], optional: -r -d -i identity -p passphrase -t type -b bits -C comment' && ret=0
        ;;
      exec)
        if (( CURRENT == 3 )); then
          _aws_keychain_profiles && ret=0
        else
          _command_names -e && ret=0
        fi
        ;;
      rm)
        (( CURRENT == 3 )) && _aws_keychain_profiles && ret=0
        ;;
      ls|migrate) ;;
    esac
    ;;
esac

return ret
