#compdef dtrack-cli
# Documentation: https://github.com/fjbarrena/dtrack-cli
# dtrack-cli: upload BOM files to OWASP Dependency-Track

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--server=[URL of the Dependency-Track server]:url:' \
  '--bom-path=[path to the BOM file]:file:_files' \
  '--api-key=[API key with appropriate permissions]:key:' \
  '--project-name=[name for the project]:name:' \
  '--project-version=[version identifier for the project]:version:' \
  '--auto-create=[automatically create the project]:bool:(true false)' && ret=0

return ret
