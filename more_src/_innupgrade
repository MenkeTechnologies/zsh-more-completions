#compdef innupgrade
# Documentation: man innupgrade(8)
# Source: InterNetNews/inn scripts/innupgrade.in — upgrade INN config files (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-f+,--file=}'[upgrade single file]:file:_files' \
    {-t+,--type=}'[file type for the upgrade]:type:(inn.conf news.daily readers.conf nnrpd.track passwd.nntp)' \
    '1::directory:_files -/' \
    && ret=0

return ret
