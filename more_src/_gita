#compdef gita

# Zsh completion for gita (manage multiple git repos)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add repo(s)'
  'rm:remove repo(s)'
  'freeze:print repo info in YAML format'
  'clone:clone repos from a freeze file or URLs'
  'context:set or show the current context (default repo group)'
  'flags:configure custom flags for git commands'
  'color:configure color for repo display'
  'group:manage repo groups'
  'info:display info items for repos'
  'll:display summary of all repos'
  'ls:show names of registered repos'
  'rename:rename a repo'
  'shell:run a shell command in repos'
  'super:run a git command in repos'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gita command' commands && ret=0
    ;;
  (args)
    local -a repos
    repos=("${(@f)$(gita ls 2>/dev/null)}")
    case $words[1] in
      (add)
        _arguments '*:repo directory:_files -/' && ret=0
        ;;
      (rm|color|rename|flags)
        _arguments '*:repo:compadd -a repos' && ret=0
        ;;
      (clone)
        _arguments \
          '(-p --preserve-path)'{-p,--preserve-path}'[clone into subdirs preserving paths]' \
          '1:freeze file or URL:_files' && ret=0
        ;;
      (context)
        local -a groups
        groups=("${(@f)$(gita group ls 2>/dev/null)}")
        _arguments '1:context:compadd -a groups' && ret=0
        ;;
      (group)
        local -a group_cmds=(
          'add:add a group with repos'
          'rmrepos:remove repos from a group'
          'rename:rename a group'
          'rm:remove a group'
          'ls:list all groups'
        )
        _arguments '1:subcommand:->group_sub' '*:: :->group_args' && ret=0
        case $state in
          (group_sub)
            _describe -t commands 'group subcommand' group_cmds && ret=0
            ;;
          (group_args)
            _arguments '*:repo:compadd -a repos' && ret=0
            ;;
        esac
        ;;
      (ll|ls|info)
        _arguments '*:repo:compadd -a repos' && ret=0
        ;;
      (super)
        _arguments '*:git command' && ret=0
        ;;
      (shell)
        _arguments '*:shell command' && ret=0
        ;;
    esac
    ;;
esac

return ret
