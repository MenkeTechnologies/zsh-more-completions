#compdef suputgthr
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/windowing_sorting_muting/suputgthr.c
# split the stdin flow to gathers by key value

local ret=1

_arguments -s -S \
  'dir=[name of directory where to put the gathers]:dir:_files -/' \
  'key=[header key word to watch]:key' \
  'suffix=[extension of the output files]:suffix' \
  'verbose=[verbose = 1 echos information]:verbose' \
  'numlength=[length of numeric part of filename]:numlength' \
  '*:file:_files' && ret=0


return ret
