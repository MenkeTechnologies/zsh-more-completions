#compdef markdown-link-check
# Documentation: https://man.archlinux.org/search?q=markdown-link-check
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-p[parallel mode]' \
  '-q[quiet output]' \
  '-v[verbose output]' \
  '-c+[path to JSON config]:file:_files -g "*.json"' \
  '*:markdown files:_files -g "*.md" "*.markdown"'
