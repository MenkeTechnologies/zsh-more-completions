#compdef vcfrandomsample
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfrandomsample.md
# Randomly sample sites from a VCF file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --rate)'{-r,--rate}'[base sampling probability per locus]:rate' \
  '(-s --scale-by)'{-s,--scale-by}'[scale sampling likelihood by this Float info field]:key' \
  '(-p --random-seed)'{-p,--random-seed}'[use this random seed]:seed' \
  '(-q --pseudorandom-seed)'{-q,--pseudorandom-seed}'[use a pseudorandom seed]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
