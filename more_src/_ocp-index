#compdef ocp-index
# Documentation: https://github.com/OCamlPro/ocp-index
# Lightweight access to type/location info in OCaml cmi/cmt/cmti files

local ret=1
local -a subcmds

subcmds=(
  'complete:complete an identifier prefix'
  'type:print the type of an identifier'
  'locate:print the source location of an identifier'
  'print:print information about an identifier using a format string'
)

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '*-I+[add a directory to the lookup path]:dir:_files -/' \
  '--root=[set the root of the project for relative paths]:dir:_files -/' \
  '--context=[set the context from a FILE:LINE:COLUMN position]:context' \
  '--build=[set the build directory for cmt lookups]:dir:_files -/' \
  '--no-build[do not look for a build directory]' \
  '--no-stdlib[do not include the OCaml standard library]' \
  '--no-opamlib[do not include the current opam switch libraries]' \
  '(-c --color)'{-c,--color}'=[colorize the output]:when:(always never auto)' \
  '*'{-O,--open}'=[open the given module]:module' \
  '*'{-F,--full-open}'=[fully open the given module]:module' \
  '*'{-s,--show}'=[show only the listed kinds]:kinds' \
  '*'{-h,--hide}'=[hide the listed kinds of items]:kinds' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'ocp-index command' subcmds && ret=0
    ;;
esac

return ret
