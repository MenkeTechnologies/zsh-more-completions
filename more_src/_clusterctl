#compdef clusterctl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[log level verbosity]:level' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'completion:generate shell completions'
      'config:manage clusterctl configuration'
      'delete:delete providers'
      'describe:describe workload cluster'
      'generate:generate YAML templates'
      'get:get info from a management cluster'
      'init:initialize a management cluster'
      'move:move objects between management clusters'
      'upgrade:upgrade providers'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '--core=[core provider]:provider' \
          '--bootstrap=[bootstrap provider]:provider' \
          '--control-plane=[control plane provider]:provider' \
          '--infrastructure=[infrastructure provider]:provider:(aws azure gcp vsphere docker openstack metal3)' \
          '--target-namespace=[target namespace]:namespace' \
          '--kubeconfig=[kubeconfig file]:file:_files' \
          '--kubeconfig-context=[context]:context' \
          '--list-images[list required images]' \
          '--wait-providers[wait for providers]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      generate)
        _arguments '1:type:(cluster provider yaml)' && ret=0
        ;;
      upgrade)
        _arguments '1:action:(apply plan)' && ret=0
        ;;
    esac
    ;;
esac

return ret
