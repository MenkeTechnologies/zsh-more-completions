#compdef twiggy

local curcontext="$curcontext" state line ret=1

_twiggy_commands() {
  local -a commands=(
    'top:list the top code size offenders'
    'paths:find paths to a function'
    'monos:find monomorphizations of generic functions'
    'dominators:compute dominator tree'
    'diff:diff two wasm binaries'
    'garbage:find unreferenced code'
    'objectives:list objectives for code size reduction'
  )
  _describe -t commands 'twiggy command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:_twiggy_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      top)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n[maximum number of items to display]:count' \
          '(-f --format)'{-f,--format}'[output format]:format:(text json csv)' \
          '(-e --regex)'{-e,--regex}'[filter items by regex]:pattern' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      paths)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n[maximum number of items to display]:count' \
          '(-f --format)'{-f,--format}'[output format]:format:(text json csv)' \
          '(-d --max-depth)'{-d,--max-depth}'[maximum depth of paths]:depth' \
          '--max-paths[maximum number of paths]:count' \
          '(-e --regex)'{-e,--regex}'[filter items by regex]:pattern' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      monos)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n[maximum number of items to display]:count' \
          '(-f --format)'{-f,--format}'[output format]:format:(text json csv)' \
          '--using[show which generics are using a type]:type' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      dominators)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n[maximum number of items to display]:count' \
          '(-f --format)'{-f,--format}'[output format]:format:(text json csv)' \
          '(-d --max-depth)'{-d,--max-depth}'[maximum depth]:depth' \
          '(-e --regex)'{-e,--regex}'[filter items by regex]:pattern' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n[maximum number of items to display]:count' \
          '(-f --format)'{-f,--format}'[output format]:format:(text json csv)' \
          '(-e --regex)'{-e,--regex}'[filter items by regex]:pattern' \
          '1:old wasm file:_files -g "*.wasm"' \
          '2:new wasm file:_files -g "*.wasm"' && ret=0
        ;;
      garbage)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n[maximum number of items to display]:count' \
          '(-f --format)'{-f,--format}'[output format]:format:(text json csv)' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      objectives)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n[maximum number of items to display]:count' \
          '(-f --format)'{-f,--format}'[output format]:format:(text json csv)' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
    esac
    ;;
esac

return ret
