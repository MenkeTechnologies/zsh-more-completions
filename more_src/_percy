#compdef percy
# _percy — Percy visual testing CLI (percy/cli)
# upstream: https://github.com/percy/cli

_percy() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--verbose[verbose output]' \
        '--quiet[quiet output]' \
        '--silent[suppress all output]' \
        '--config=[config file]:file:_files' \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1: :_percy_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                exec)
                    _arguments \
                        '--parallel[mark as parallel build]' \
                        '--partial[mark as partial build]' \
                        '--help[show help]' \
                        '*:command:' && ret=0 ;;
                snapshot)
                    _arguments \
                        '--base-url=[base URL for snapshots]:url:' \
                        '--files=[file glob pattern]:pattern:' \
                        '--ignore=[ignore pattern]:pattern:' \
                        '--dry-run[dry run without uploading]' \
                        '--config=[config file]:file:_files' \
                        '--help[show help]' \
                        '1:snapshot directory:_files -/' && ret=0 ;;
                upload)
                    _arguments \
                        '--files=[file glob pattern]:pattern:' \
                        '--strip-extensions[strip file extensions]' \
                        '--dry-run[dry run without uploading]' \
                        '--help[show help]' \
                        '1:upload directory:_files -/' && ret=0 ;;
                storybook)
                    _arguments \
                        '--help[show help]' \
                        '*:storybook args:' && ret=0 ;;
                config)
                    _arguments \
                        '--help[show help]' \
                        '1: :(validate create migrate)' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_percy_commands] )) ||
_percy_commands() {
    local -a commands
    commands=(
        'exec:execute a command and capture snapshots'
        'snapshot:snapshot static files or pages'
        'upload:upload static snapshots'
        'storybook:capture Storybook stories'
        'config:manage Percy config'
    )
    _describe -t commands 'percy command' commands
}

_percy "$@"
