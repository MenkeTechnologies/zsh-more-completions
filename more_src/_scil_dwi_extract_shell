#compdef scil_dwi_extract_shell
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_dwi_extract_shell.html
# Scilpy: extract one or more shells from a DWI by b-value

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--out_indices=[output filename for valid indices]:file:_files' \
  '(--block-size -s)'{--block-size,-s}'=[block size for loading data]:size' \
  '(--tolerance -t)'{--tolerance,-t}'=[tolerated gap between b-values]:tol' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_dwi:_files' \
  '2:in_bval:_files' \
  '3:in_bvec:_files' \
  '4:in_bvals_to_extract:' \
  '5:out_dwi:_files' \
  '6:out_bval:_files' \
  '7:out_bvec:_files' && ret=0

return ret
