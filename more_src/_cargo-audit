#compdef cargo-audit

# Zsh completion for cargo-audit (Rust dependency vulnerability auditing)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-q[Do not print cargo log messages]' \
  '--quiet[Do not print cargo log messages]' \
  '-v[Use verbose output]' \
  '--verbose[Use verbose output]' \
  '--color=[Coloring]:when:(auto always never)' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'audit:Audit Cargo.lock for vulnerabilities (default)'
      'fix:Automatically update vulnerable dependencies'
      'bin:Audit compiled binary for vulnerabilities'
    )
    _describe -t commands 'cargo-audit command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      audit)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-d+[Advisory database directory]:dir:_directories' \
          '--db=[Advisory database directory]:dir:_directories' \
          '-D[Fetch advisory database]' \
          '--deny=[Exit with failure if vulnerability type found]:type:(unmaintained unsound yanked warnings)' \
          '-f+[Path to Cargo.lock]:file:_files' \
          '--file=[Path to Cargo.lock]:file:_files' \
          '--ignore=[Advisory ID to ignore]:id' \
          '--ignore-source[Ignore sources of packages in Cargo.lock]' \
          '-n[Skip fetching the advisory database]' \
          '--no-fetch[Skip fetching the advisory database]' \
          '--stale[Allow stale advisory database]' \
          '--target-arch=[Filter vulnerabilities by CPU arch]:arch' \
          '--target-os=[Filter vulnerabilities by OS]:os' \
          '--json[Output report in JSON format]' \
          '-q[Do not print cargo log messages]' \
          '--quiet[Do not print cargo log messages]' && ret=0
        ;;
      fix)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-d+[Advisory database directory]:dir:_directories' \
          '--db=[Advisory database directory]:dir:_directories' \
          '-D[Fetch advisory database]' \
          '-f+[Path to Cargo.lock]:file:_files' \
          '--file=[Path to Cargo.lock]:file:_files' \
          '-n[Skip fetching the advisory database]' \
          '--no-fetch[Skip fetching the advisory database]' \
          '--dry-run[Do not perform the actual fix]' \
          '-q[Do not print cargo log messages]' \
          '--quiet[Do not print cargo log messages]' && ret=0
        ;;
      bin)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-d+[Advisory database directory]:dir:_directories' \
          '--db=[Advisory database directory]:dir:_directories' \
          '-D[Fetch advisory database]' \
          '-n[Skip fetching the advisory database]' \
          '--no-fetch[Skip fetching the advisory database]' \
          '--json[Output report in JSON format]' \
          '-q[Do not print cargo log messages]' \
          '--quiet[Do not print cargo log messages]' \
          '*:binary:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
