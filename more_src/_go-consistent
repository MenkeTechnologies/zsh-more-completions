#compdef go-consistent go-critic perfguard ruleguard structlayout-optimize structlayout-pretty testifylint
# Documentation: upstream READMEs + source main.go files at
#   github.com/{quasilyte/go-consistent,go-critic/go-critic,quasilyte/go-perfguard,quasilyte/go-ruleguard,dominikh/go-tools,Antonboom/testifylint}
# Reference accessed: 2026-05-30
# Go-ecosystem linter/analyzer harvest. 7 stems via single multi-stem
# file dispatched on $service.

local curcontext="$curcontext" state line ret=1

case $service in

  go-consistent)
    # quasilyte/go-consistent — identify inconsistent code patterns.
    _arguments -s -S \
      '-v[verbose mode]' \
      '--help[show help]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  go-critic)
    # go-critic/go-critic — Go linter with ~100 diagnostics.
    local -a _subcmds _tags
    _subcmds=(
      'check:analyze specified targets for issues'
      'version:display linter version'
      'doc:retrieve documentation for installed checkers'
    )
    _tags=(
      '#diagnostic'
      '#style'
      '#performance'
      '#experimental'
      '#opinionated'
      '#security'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'go-critic subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          check)
            _arguments \
              '-v[verbose output]' \
              '-enable=[comma-separated list of checkers or tags]:checkers:' \
              '-disable=[comma-separated list of checkers]:checkers:' \
              '*:Go package or file:_files' && ret=0
            ;;
          doc)
            _arguments \
              '1:checker name:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  perfguard)
    # quasilyte/go-perfguard — Go performance analyzer (lint/optimize).
    local -a _subcmds
    _subcmds=(
      'lint:traditional static analysis'
      'optimize:profile-guided analysis'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'perfguard subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          optimize)
            _arguments \
              '--heatmap=[CPU profile file]:file:_files -g "*.out"' \
              '--fix[apply suggested fixes automatically]' \
              '*:Go package or file:_files' && ret=0
            ;;
          lint)
            _arguments \
              '--fix[apply suggested fixes automatically]' \
              '*:Go package or file:_files' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  ruleguard)
    # quasilyte/go-ruleguard — pattern-based dynamic Go linter.
    _arguments -s -S \
      '-rules=[comma-separated ruleguard file paths]:files:_files' \
      '-e=[execute a single rule from a string]:rule:' \
      '-fix[apply suggested fixes automatically]' \
      '-c[display offending lines with context]' \
      '-json[output in JSON format]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  structlayout-optimize)
    # dominikh/go-tools cmd/structlayout-optimize — reorder struct fields
    # to reduce padding. Reads structlayout JSON from stdin.
    _arguments -s -S \
      '-json[format data as JSON]' \
      '-r[break up structs and reorder fields freely]' \
      '-version[print version and exit]' \
      && ret=0
    ;;

  structlayout-pretty)
    # dominikh/go-tools cmd/structlayout-pretty — pretty-print structlayout
    # output with ASCII art. Reads structlayout JSON from stdin.
    _arguments -s -S \
      '-v[do not compact consecutive bytes of fields]' \
      '-version[print version and exit]' \
      && ret=0
    ;;

  testifylint)
    # Antonboom/testifylint — testify usage-pattern linter (25+ checkers).
    _arguments -s -S \
      '--enable-all[enable all checkers]' \
      '--enable=[comma-separated checkers to enable]:checkers:' \
      '--disable=[comma-separated checkers to disable]:checkers:' \
      '--fix[apply autofixes]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

esac

return ret
