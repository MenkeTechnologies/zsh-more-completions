#compdef animdl
# Documentation: https://man.archlinux.org/search?q=animdl
# Reference accessed: 2026-05-16

# justfoolingaround/animdl — click group animdl/__main__.py

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--version[show version]' \
  '(-x)'{-x,--disable-update}'[disable upstream version check]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      'download:download episodes'
      'grab:grab stream by URL'
      'schedule:schedule downloads'
      'search:search catalog'
      'update:update tooling metadata'
      'stream:stream anime'
    )
    _describe -t commands 'animdl command' cmds && ret=0
    ;;
  (rest)
    _arguments '*:options or args: _default' && ret=0
    ;;
esac

return ret
