#compdef cfm-predict
# Documentation: https://hub.docker.com/r/wishartlab/cfmid
# cfm-predict: predict ESI-MS/MS spectra from a molecule (CFM-ID)

local ret=1

_arguments -s \
  '1:smiles or inchi or input file:_files' \
  '2:prob_thresh (fragment pruning threshold):' \
  '3:param_file (trained model parameters):_files' \
  '4:config_file (model configuration):_files' \
  '5:annotate_fragments:(0 1)' \
  '6:output file or directory:_files' \
  '7:apply_postproc:(0 1)' \
  '8:suppress_exceptions:(0 1)' && ret=0

return ret
