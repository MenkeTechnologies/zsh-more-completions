#compdef pocketbase

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'serve:Start the web server'
      'migrate:Execute app migrations'
      'admin:Manage admin accounts (legacy)'
      'superuser:Manage superuser accounts'
      'version:Print version'
    )
    _describe -t commands 'pocketbase command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      serve)
        _arguments -s -S \
          '--http=[HTTP server address]:address' \
          '--https=[HTTPS server address]:address' \
          '--dir=[data directory]:directory:_directories' \
          '--encryptionEnv=[encryption key environment variable]:env var' \
          '--publicDir=[public static directory]:directory:_directories' \
          '--hooksDir=[hooks directory]:directory:_directories' \
          '--migrationsDir=[migrations directory]:directory:_directories' \
          '--automigrate=[enable auto migrations]:bool:(true false)' \
          '--dev[enable dev mode with auto migrations and demo data]' \
          '--indexFallback=[enable SPA-like index.html fallback]:bool:(true false)' \
          '--origins=[CORS allowed origins]:origins' && ret=0
        ;;
      migrate)
        local -a migrate_cmds=(
          'up:Run all pending migrations'
          'down:Revert the last applied migration'
          'create:Create a new migration file'
          'collections:Create a migration from existing collections'
          'history-sync:Sync the migrations history with the app state'
        )
        _describe -t commands 'migrate subcommand' migrate_cmds && ret=0
        ;;
      admin|superuser)
        local -a admin_cmds=(
          'create:Create a new account'
          'update:Update an existing account'
          'delete:Delete an account'
        )
        if [[ ${words[1]} == "superuser" ]]; then
          admin_cmds+=('upsert:Create or update an account')
        fi
        _describe -t commands "${words[1]} subcommand" admin_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
