#compdef gmx-analyze
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-analyze.html
# gmx analyze: analyze data sets (averages, autocorrelation, error estimates, fitting)

local ret=1

_arguments -s \
  '-f[xvgr/xmgr input file]:file:_files' \
  '-ac[autocorrelation function output]:file:_files' \
  '-msd[mean square displacement output]:file:_files' \
  '-cc[cosine content output]:file:_files' \
  '-dist[distribution plot output]:file:_files' \
  '-av[average over sets output]:file:_files' \
  '-ee[error estimates output]:file:_files' \
  '-fitted[fitted function output]:file:_files' \
  '-g[fitting log file]:file:_files' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-time[expect a time in the input]' \
  '-b[first time to read from set]:real:' \
  '-e[last time to read from set]:real:' \
  '-n[number of sets separated by ampersand]:int:' \
  '-d[use the derivative]' \
  '-bw[binwidth for distribution]:real:' \
  '-errbar[error bar type]:type:(none stddev error 90)' \
  '-integrate[integrate data function(s) numerically]' \
  '-aver_start[start averaging integral from this time]:real:' \
  '-xydy[interpret second data set as error in y values]' \
  '-regression[perform a linear regression analysis]' \
  '-luzar[do a Luzar and Chandler analysis]' \
  '-temp[temperature for Luzar kinetics (K)]:real:' \
  '-fitstart[time to start fitting (ps)]:real:' \
  '-fitend[time to stop fitting (ps)]:real:' \
  '-filter[cosine filter length]:real:' \
  '-power[fit data to b t^a]' \
  '-subav[subtract the average before autocorrelating]' \
  '-oneacf[calculate one ACF over all sets]' \
  '-acflen[length of ACF]:int:' \
  '-normalize[normalize ACF]' \
  '-P[order of Legendre polynomial]:order:(0 1 2 3)' \
  '-fitfn[fit function type]:fn:(none exp aexp exp_exp exp5 exp7 exp9)' \
  '-beginfit[time to begin exponential fit]:real:' \
  '-endfit[time to end exponential fit]:real:' && ret=0

return ret
