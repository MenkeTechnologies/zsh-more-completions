#compdef mri_synthstrip
# Documentation: https://surfer.nmr.mgh.harvard.edu/docs/synthstrip/
# FreeSurfer learning-based skull-stripping for any brain image

local ret=1

_arguments -s -S \
  '-i[input image]:input:_files' \
  '-o[output skull-stripped image]:output:_files' \
  '-m[save a binary brain mask]:mask:_files' \
  '--no-csf[exclude surrounding CSF from brain boundary]' \
  '-b[boundary distance from the brain]:border:' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
