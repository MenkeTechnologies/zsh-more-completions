#compdef cabin
# Documentation: https://github.com/cabinpkg/cabin
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cabin - C++ package manager and build system (Cargo-inspired).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'new:start a new Cabin project'
  'init:integrate an existing project with Cabin (cabin.toml)'
  'build:compile the project'
  'run:compile and run the generated binary'
  'test:run unit tests defined with CABIN_TEST'
  'fmt:format source code with clang-format'
  'lint:lint the project with cpplint'
  'tidy:run static analysis with clang-tidy'
  'add:add dependencies to cabin.toml'
  'remove:remove dependencies from cabin.toml'
  'help:show help'
  'version:show version'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd) _describe -t commands 'cabin command' subcmds && ret=0 ;;
  rest) _files && ret=0 ;;
esac

return ret
