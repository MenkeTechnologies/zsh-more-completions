#compdef c8

# Zsh completion for c8 - V8 code coverage

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*--reporter=[coverage reporter to use]:reporter:(text lcov html json cobertura text-lcov text-summary json-summary clover)' \
  '--check-coverage[check whether coverage is within thresholds]' \
  '--lines=[minimum line coverage percentage]:percentage:' \
  '--functions=[minimum function coverage percentage]:percentage:' \
  '--branches=[minimum branch coverage percentage]:percentage:' \
  '--statements=[minimum statement coverage percentage]:percentage:' \
  '--100[shortcut for 100% coverage on all metrics]' \
  '--all[instrument all files]' \
  '*--include=[include only files matching pattern]:glob pattern:' \
  '*--exclude=[exclude files matching pattern]:glob pattern:' \
  '--clean[clean temp directory before running]' \
  '--temp-directory=[directory for raw coverage]:directory:_directories' \
  '--reports-dir=[directory for coverage reports]:directory:_directories' \
  '*--src=[source directories]:directory:_directories' \
  '--resolve=[resolve paths in coverage]:path:' \
  '--skip-full[do not show files with 100% coverage]' \
  '--per-file[check thresholds per file]' \
  '--allow-external[allow files outside cwd]' \
  '--exclude-after-remap[apply exclusions after remapping]' \
  '--merge-async[merge async coverage results]' \
  '*--text-exclude=[exclude files from text report]:glob pattern:' \
  '*:command and arguments: _normal' && ret=0

return ret
