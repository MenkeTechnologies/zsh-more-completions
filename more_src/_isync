#compdef mbsync isync
# Documentation: https://manpages.debian.org/bookworm/isync/mbsync.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '(-a --all)'{-a,--all}'[select all configured channels]'
  '(-l --list)'{-l,--list}'[list mailboxes without synchronizing]'
  '(-c --config)'{-c,--config}'+[specify configuration file]:file:_files'
  '(-D --debug)'{-D,--debug}'[enable debugging with optional categories]'
  '(-V --verbose)'{-V,--verbose}'[enable verbose mode]'
  '(-q --quiet)'{-q,--quiet}'[suppress progress counters and notices]'
  '(-n --new)'{-n,--new}'[propagate newly appeared messages]'
  '(-d --delete)'{-d,--delete}'[propagate message deletions]'
  '(-f --flags)'{-f,--flags}'[propagate flag changes]'
  '(-N --renew)'{-N,--renew}'[upgrade placeholders to full messages]'
  '(-0 --noop)'{-0,--noop}'[do not propagate anything]'
  '(-F --full)'{-F,--full}'[all synchronization operations]'
  '(-L --pull)'{-L,--pull}'[propagate changes from far to near side]'
  '(-H --push)'{-H,--push}'[propagate changes from near to far side]'
  '(-C --create)'{-C,--create}'[override Create configuration]'
  '--create-far[override Create configuration on far side]'
  '--create-near[override Create configuration on near side]'
  '(-R --remove)'{-R,--remove}'[override Remove configuration]'
  '--remove-far[override Remove configuration on far side]'
  '--remove-near[override Remove configuration on near side]'
  '(-X --expunge)'{-X,--expunge}'[override Expunge configuration]'
  '--expunge-far[override Expunge configuration on far side]'
  '--expunge-near[override Expunge configuration on near side]'
  '(-v --version)'{-v,--version}'[show version]'
  '(-h --help)'{-h,--help}'[show help]'
  '*:channel or group:'
)

_arguments -s -S $arguments
