#compdef sfkirchinv
# Documentation: https://ahay.org/RSF/sfkirchinv.html
# Madagascar: Kirchhoff 2-D post-stack least-squares time migration with antialiasing

local ret=1

_arguments -s \
  'velocity=[auxiliary input file name]:file:_files' \
  'weight=[auxiliary input file name]:file:_files' \
  'fweight=[auxiliary input file name]:file:_files' \
  'model0=[auxiliary input file name]:file:_files' \
  'err=[output file for error]:file:_files' \
  'niter=[number of iterations]:int:' \
  'hd=[if y, apply half-derivative filter (y/n)]:bool:(y n)' \
  'ps=[if y, apply pseudo-unitary weighting (y/n)]:bool:(y n)' \
  'sw=[if > 0, select a branch of the antialiasing operation]:int:' \
  '*:rsf file:_files' && ret=0

return ret
