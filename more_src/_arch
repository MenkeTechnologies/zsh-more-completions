#compdef arch
# Documentation: man arch(1) (macOS)
# Source: arch — print architecture type or run selected architecture of a universal binary.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-32[prefer 32-bit architecture]' \
    '-64[prefer 64-bit architecture]' \
    '*-arch_name[architecture name (e.g. i386, x86_64, x86_64h, arm64, arm64e)]' \
    '*-arch+[specify architecture]:arch:(i386 x86_64 x86_64h arm64 arm64e ppc ppc64)' \
    '-c[clear environment before running]' \
    '*-d+[unset environment variable]:envname:_parameters -g "*export*"' \
    '*-e+[set environment variable]:envname=value:' \
    '(- *)-h[print usage]' \
    '*::program + args:_command_names -e' \
    && ret=0

return ret
