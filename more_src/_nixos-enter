#compdef nixos-enter

# Zsh completion for nixos-enter (enter a NixOS system chroot)

_arguments -s -S \
  '--root=[root filesystem path]:root path:_files -/' \
  '(-c --command)'{-c,--command=}'[command to run in the chroot]:command:' \
  '--silent[suppress output]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '--[remaining arguments are passed as command]:*::command:_normal'
