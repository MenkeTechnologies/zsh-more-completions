#compdef checkpolicy
# _checkpolicy — SELinux checkpolicy (compile a textual SELinux policy.conf into a binary policy file; -b binary output, -o output file, -M force MLS, -F force compat checks, -E explicit conditional, -c specify policy version, -d enable conditional debug, -t target policy type (selinux|xen), -O optimize, -V show available versions, -h help)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux checkpolicy/checkpolicy.c on tip.

_checkpolicy() {
    _arguments \
        '-h[show help]' \
        '-V[show version + supported policy versions]' \
        '-b[binary output]' \
        '-o+[output file]:file:_files' \
        '-M[force MLS]' \
        '-F[force compat checks]' \
        '-E[explicit conditional]' \
        '-c+[policy version]:version:' \
        '-d[debug conditional]' \
        '-t+[target policy type]:type:(selinux xen)' \
        '-O[optimize]' \
        '-U+[unknown handling]:handling:(allow deny reject)' \
        '1:policy.conf file:_files'
}

_checkpolicy "$@"
