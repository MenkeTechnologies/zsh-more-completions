#compdef filter gmx-filter
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-filter.html
# gmx filter: frequency filter trajectories, useful for making smooth movies

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[structure+mass database]:file:_files' \
  '-n[index file]:file:_files' \
  '-ol[low-pass filtered trajectory]:file:_files' \
  '-oh[high-pass filtered trajectory]:file:_files' \
  '-b[starting time from trajectory (ps)]:time:' \
  '-e[ending time from trajectory (ps)]:time:' \
  '-dt[frame selection interval (ps)]:time:' \
  '-nf[filter length and output interval]:int:' \
  '-all[write all low-pass filtered frames]' \
  '-nojump[remove atomic jumps across periodic boundaries]' \
  '-fit[align all frames to reference structure]' \
  '-w[view output files]' && ret=0

return ret
