#compdef ckb

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '-C+[Run as if CKB was started in directory]:config directory:_directories' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'run:Run CKB node'
      'miner:Run CKB miner'
      'export:Export CKB data'
      'import:Import CKB data'
      'list-hashes:List well known hashes'
      'init:Create or re-initialize a CKB directory'
      'replay:Replay CKB blocks'
      'stats:Print chain stats'
      'reset-data:Truncate selected database paths'
      'peer-id:Inspect or generate peer id keys'
      'migrate:Run CKB database migration'
      'daemon:Daemon control on Unix'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '--ba-advanced[Allow any block assembler code hash and args]' \
          '--skip-spec-check[Skip chain spec hash check against database]' \
          '--overwrite-spec[Overwrite stored chain spec with current config]' \
          '--assume-valid-target=[Assume-valid block header hash]:hash' \
          '--indexer[Start built-in indexer]' \
          '--rich-indexer[Start built-in rich indexer]' \
          '--daemon[Run node as background daemon (Unix)]' && ret=0
        ;;
      miner)
        _arguments \
          '(-l --limit)'{-l,--limit}'=[Exit after N nonces (0=forever)]:count' && ret=0
        ;;
      export)
        _arguments \
          '(-t --target)'{-t,--target}'=[Export target path (- for stdout)]:path:_files' \
          '--from=[Start block number or hash (inclusive)]' \
          '--to=[End block number or hash (inclusive)]' && ret=0
        ;;
      import)
        _arguments \
          '--num-threads=[Parallel import threads]:count' \
          '--skip-script-verify[Skip script verification during import]' \
          '--skip-all-verify[Skip all verifications during import]' \
          '1:Exported JSONL path:_files' && ret=0
        ;;
      list-hashes)
        _arguments \
          '(-b --bundled)'{-b,--bundled}'[List bundled chain spec hashes]' \
          '(-f --format)'{-f,--format}'=[Output format]:format:(json toml)' && ret=0
        ;;
      init)
        _arguments \
          '(-i --interactive)'{-i,--interactive}'[Interactive mode]' \
          '(-l --list-chains)'{-l,--list-chains}'[List --chain options]' \
          '(-c --chain)'{-c,--chain}'=[Chain spec name]:chain' \
          '--import-spec=[Import chain spec file or base64 from stdin (-)]' \
          '--log-to=[Log destination]:dest:(file stdout both)' \
          '(-f --force)'{-f,--force}'[Overwrite existing files]' \
          '--rpc-port=[RPC port in generated config]' \
          '--p2p-port=[P2P port in generated config]' \
          '--ba-code-hash=[Block assembler code hash]' \
          '--ba-arg+[Block assembler arg (hex)]' \
          '--ba-hash-type=[Block assembler hash type]:type:(data type data1 data2)' \
          '--ba-message=[Block assembler message (hex)]' \
          '--genesis-message=[Genesis message string for dev chains]' && ret=0
        ;;
      replay)
        _arguments \
          '--tmp-target=[Temporary target path for profiling]:directory:_directories' \
          '--profile[Enable profiling mode]' \
          '--from=[Profile from block number]' \
          '--to=[Profile to block number]' \
          '--sanity-check[Enable sanity check]' \
          '--full-verification[Enable full verification during sanity check]' && ret=0
        ;;
      stats)
        _arguments \
          '--from=[From block number]' \
          '--to=[To block number]' && ret=0
        ;;
      reset-data)
        _arguments \
          '(-f --force)'{-f,--force}'[Delete data without prompt]' \
          '--all[Delete whole data directory]' \
          '--database[Delete db only]' \
          '--indexer[Delete indexer rocksdb store]' \
          '--rich-indexer[Delete rich indexer sqlite]' \
          '--network[Delete peer store and secret key]' \
          '--network-peer-store[Delete peer_store only]' \
          '--network-secret-key[Delete secret_key only]' \
          '--logs[Delete logs only]' && ret=0
        ;;
      migrate)
        _arguments \
          '--check[Run migration need check only]' \
          '(-f --force)'{-f,--force}'[Migrate without prompt]' \
          '--include-background[Include background migrations]' && ret=0
        ;;
      peer-id)
        _arguments \
          '1:Subcommand:((gen from-secret))' \
          '--secret-path=[Secret key output/input path]:file:_files' && ret=0
        ;;
      daemon)
        _arguments \
          '--check[Check daemon status]' \
          '--stop[Stop daemon, miner, and node]' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
