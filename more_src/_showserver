#compdef showserver
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/showserver.html
# Display information on configured servers

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-servername=[single server to display]:server:' \
  '-showtypes=[filter by data type]:type:(Protein Nucleic Sequence Features)' \
  '-html[format output as HTML]' \
  '-full[display all columns]' \
  '-methods[show access methods]' \
  '-count[include count column]' \
  '-cachefile[include cache file column]' \
  '-url[include URL column]' \
  '-fields[show searchable fields]' \
  '-defined[show server definition short name]' \
  '-serverversion[display version column]' \
  '-sortby=[sort results]:by:(defined type)' \
  '-outfile=[output file]:file:_files' \
  '-only[display only selected columns]' \
  '-heading[toggle column headers]' \
  '-scope[display scope column]' \
  '-type[display type column]' \
  '-id[display ID column]' \
  '-query[display query capability column]' \
  '-all[display all-access capability column]' \
  '-comment[display comment column]' \
  '-auto[turn off prompts]' \
  '-stdout[write output to stdout]' \
  '-version[show version]' && ret=0

return ret
