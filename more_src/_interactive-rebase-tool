#compdef interactive-rebase-tool
# Documentation: https://man.archlinux.org/search?q=interactive-rebase-tool
# Reference accessed: 2026-05-16

# Zsh completion for interactive-rebase-tool (MitMaro/git-interactive-rebase-tool, [[bin]] name). Args from src/arguments.rs (pico-args).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--license[show license text]' \
  '*::git rebase todo file:_files'
