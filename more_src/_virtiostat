#compdef virtiostat virtiostat-bpfcc
# _virtiostat — virtio device IOPS / throughput / latency stats (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/virtiostat.py (argparse).

_virtiostat() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]'
        '(-d --driver)'{-d+,--driver=}'[only this virtio driver (virtio_blk, virtio_net, ...)]:driver:(virtio_blk virtio_net virtio_console virtio_scsi virtio_balloon virtio_input)'
        '(-n --devname)'{-n+,--devname=}'[only this device name]:devname:'
        '(-D --debug)'{-D,--debug}'[enable debug output]'
        '1:interval (seconds):'
        '2:output count:'
    )
    _arguments $args
}

_virtiostat "$@"
