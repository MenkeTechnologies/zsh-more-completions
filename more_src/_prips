#compdef prips
# Documentation: https://man.archlinux.org/search?q=prips
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --cidr)'{-c,--cidr}'[print range as CIDR netblocks]' \
  '(-d --delimiter)'{-d,--delimiter}'[set delimiter between addresses]:delimiter' \
  '(-e --exclude)'{-e,--exclude}'[exclude specific IP address]:IP address' \
  '(-f --format)'{-f,--format}'[set output format]:format string' \
  '(-i --increment)'{-i,--increment}'[set increment between addresses]:increment' \
  '--help[display help]' \
  '1:start IP or CIDR' \
  '2::end IP' && ret=0

return ret
