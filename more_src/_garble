#compdef garble
# Documentation: https://man.archlinux.org/search?q=garble
# Reference accessed: 2026-05-16

# Zsh completion for garble (burrowers/garble). Garble flags and subcommands from
# main.go (init flagSet, mainErr switch, usage) on the master branch. Arguments
# after the subcommand follow go build/test/run semantics; delegate with _default.

local curcontext="$curcontext" state line ret=1
local -a top

top=(
  'build:wrap "go build" with obfuscation'
  'test:wrap "go test"'
  'run:wrap "go run"'
  'reverse:de-obfuscate stack traces and similar output'
  'bug:start a bug report'
  'version:print garble version and build settings'
  'help:show help for garble or a subcommand'
)

_arguments -C -s -S \
  '--literals[obfuscate string and other literals]' \
  '--tiny[optimize for size; harder to reverse]' \
  '--debug[print debug logs to stderr]' \
  '--debugdir=[write source and obfuscated trees]:directory:_files -/' \
  '--seed=[base64 seed or the word random for non-reproducible builds]:seed:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'garble command' top && ret=0 ;;
  (args) _default && ret=0 ;;
esac

return ret
