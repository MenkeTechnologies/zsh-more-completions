#compdef virtlockd
# _virtlockd — libvirt virtlockd (lock-manager daemon used by virtlockd-style locking driver to serialize concurrent access to shared resources (disks) across libvirtd instances; -d daemonize, -f config file, -p pidfile, -t timeout seconds, -v verbose)
# upstream: https://gitlab.com/libvirt/libvirt (src/locking/lock_daemon.c)
# Flags from libvirt src/locking/lock_daemon.c on tip.

_virtlockd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-d[daemonize]' \
        '-f+[config file]:file:_files' \
        '-p+[pidfile]:file:_files' \
        '-t+[timeout seconds]:seconds:'
}

_virtlockd "$@"
