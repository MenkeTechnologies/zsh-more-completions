#compdef tunwg
# Documentation: https://github.com/ntnj/tunwg
# tunwg - WireGuard-based tunnel to expose local services with HTTPS

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-p[expose a specific port]:port:' \
  '--forward=[forwarding address]:url:' \
  '--limit=[enable HTTP basic auth with credentials]:credentials:' && ret=0

return ret
