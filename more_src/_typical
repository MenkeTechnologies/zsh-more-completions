#compdef typical
# Source: cargo binstall typical@0.15.0
# Probed via: shell-completion zsh
# Repository: https://github.com/stepchowfun/typical

autoload -U is-at-least

_typical() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-v[Print version]' \
'--version[Print version]' \
'-h[Print help]' \
'--help[Print help]' \
":: :_typical_commands" \
"*::: :->typical" \
&& ret=0
    case $state in
    (typical)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:typical-command-$line[1]:"
        case $line[1] in
            (generate)
_arguments "${_arguments_options[@]}" : \
'--rust-file=[Set the path to the Rust file to emit]:PATH:_files' \
'--typescript-dir=[Set the directory in which the TypeScript files will be emitted]:PATH:_files' \
'--list-schemas[List the schemas imported by the given schema (and the given schema itself)]' \
'-h[Print help]' \
'--help[Print help]' \
':path -- Set the path to the schema:_files' \
&& ret=0
;;
(format)
_arguments "${_arguments_options[@]}" : \
'--check[Check the formatting rather than actually doing it]' \
'-h[Print help]' \
'--help[Print help]' \
':path -- Set the path to the schema:_files' \
&& ret=0
;;
(shell-completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Bash, Fish, Zsh, PowerShell, or Elvish:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_typical__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:typical-help-command-$line[1]:"
        case $line[1] in
            (generate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(format)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(shell-completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_typical_commands] )) ||
_typical_commands() {
    local commands; commands=(
'generate:Generate code for a schema and its transitive dependencies' \
'format:Format a schema and its transitive dependencies' \
'shell-completion:Print a shell completion script. Supports Bash, Fish, Zsh, PowerShell, and Elvish.' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'typical commands' commands "$@"
}
(( $+functions[_typical__format_commands] )) ||
_typical__format_commands() {
    local commands; commands=()
    _describe -t commands 'typical format commands' commands "$@"
}
(( $+functions[_typical__generate_commands] )) ||
_typical__generate_commands() {
    local commands; commands=()
    _describe -t commands 'typical generate commands' commands "$@"
}
(( $+functions[_typical__help_commands] )) ||
_typical__help_commands() {
    local commands; commands=(
'generate:Generate code for a schema and its transitive dependencies' \
'format:Format a schema and its transitive dependencies' \
'shell-completion:Print a shell completion script. Supports Bash, Fish, Zsh, PowerShell, and Elvish.' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'typical help commands' commands "$@"
}
(( $+functions[_typical__help__format_commands] )) ||
_typical__help__format_commands() {
    local commands; commands=()
    _describe -t commands 'typical help format commands' commands "$@"
}
(( $+functions[_typical__help__generate_commands] )) ||
_typical__help__generate_commands() {
    local commands; commands=()
    _describe -t commands 'typical help generate commands' commands "$@"
}
(( $+functions[_typical__help__help_commands] )) ||
_typical__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'typical help help commands' commands "$@"
}
(( $+functions[_typical__help__shell-completion_commands] )) ||
_typical__help__shell-completion_commands() {
    local commands; commands=()
    _describe -t commands 'typical help shell-completion commands' commands "$@"
}
(( $+functions[_typical__shell-completion_commands] )) ||
_typical__shell-completion_commands() {
    local commands; commands=()
    _describe -t commands 'typical shell-completion commands' commands "$@"
}

if [ "$funcstack[1]" = "_typical" ]; then
    _typical "$@"
else
    compdef _typical typical
fi
