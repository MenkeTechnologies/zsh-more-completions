#compdef elasticsearch-translog

# elasticsearch-translog: legacy translog truncator (deprecated, use elasticsearch-shard)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '-v[verbose]' \
  '-E[config setting key=value]:kv:' \
  '-d[translog dir]:dir:_files -/' \
  '--truncate[truncate translog]' \
  '*::elasticsearch-translog args:_files' && ret=0
return ret
