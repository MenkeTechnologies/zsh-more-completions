#compdef lepton-cli
# Command-line interface for Lepton EDA (gEDA fork)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:manage configuration settings'
      'export:export schematics to various formats'
      'shell:interactive Scheme shell'
    )
    _describe -t commands 'lepton-cli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      export)
        _arguments \
          '-o[output file]:file:_files' \
          '-f[output format]:format:(png svg pdf ps eps)' \
          '-s[paper size]:size:(a4 a3 letter tabloid)' \
          '-l[landscape orientation]' \
          '-m[margins]:margins:' \
          '-c[color mode]' \
          '*:schematic file:_files -g "*.sch"' && ret=0
        ;;
      config)
        _arguments \
          '--project[project config]' \
          '--user[user config]' \
          '--system[system config]' \
          '*:setting:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
