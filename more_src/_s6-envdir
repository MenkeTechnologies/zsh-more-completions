#compdef s6-envdir s6-setlock s6-fghack s6-mkfifodir s6-cleanfifodir
# Documentation: upstream skarnet.org/software/s6/s6-{envdir,setlock,
# fghack,mkfifodir,cleanfifodir}.html
# Reference accessed: 2026-05-30 via WebFetch.
# Skarnet s6 utilities R118 — 5-stem multi-binary harvest covering
# core s6 chain-loaded process-management utilities not previously
# covered. Sister tools to R117's s6-fdholder family.

case $service in

  s6-envdir)
    # Set environment variables from a directory of files, then
    # exec prog with the new environment.
    _arguments -s -S \
      '-i[strict mode (default; exits 111 if dir missing)]' \
      '-I[loose mode (exec prog unchanged if dir missing)]' \
      '-n[preserve trailing whitespace and newlines]' \
      '-f[verbatim mode (entire file content as value)]' \
      '-L[remove the 4096-byte per-file read limit]' \
      '-c+[replace null characters with first char of NULLIS]:nullis:' \
      '1:env directory:_directories' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-setlock)
    # Acquire an advisory lock on a file, then exec prog. Lock is
    # released when prog exits.
    _arguments -s -S \
      '(-N -n -t)-n[nonblocking lock (exit 1 immediately if cannot acquire)]' \
      '(-N -n -t)-N[blocking lock (default; wait until acquired)]' \
      '(-N -n -t)-t+[timed lock (exit 1 after timeout ms)]:ms:' \
      '(-w)-r[shared lock (allows other shared locks)]' \
      '(-r)-w[exclusive lock (default)]' \
      '-d+[expose the lock on file descriptor fd in prog]:fd:' \
      '1:lock file:_files' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-fghack)
    # Opens many file descriptors writing to a single pipe, then
    # spawns prog as a child. Used to detect process backgrounding
    # in supervised services. No flags; just the prog to wrap.
    _arguments -s -S \
      '*:program and arguments:_command_names -e'
    ;;

  s6-mkfifodir)
    # Create a fifodir (a directory containing a control FIFO,
    # used by the s6-ftrig family for event notification).
    _arguments -s -S \
      '-f[force; reset permissions on existing fifodir]' \
      '-g+[restrict listenability to members of this group]:gid:' \
      '1:fifodir path:_directories'
    ;;

  s6-cleanfifodir)
    # Garbage-collect dead listeners from a fifodir.
    # No CLI options; just the fifodir path.
    _arguments -s -S \
      '1:fifodir path:_directories'
    ;;

esac
