#compdef endgame

local curcontext="$curcontext" state line ret=1

local -a global_flags
global_flags=(
  '(- *)--help[Show help]'
  '(-v --verbose)'{-v,--verbose}'[Enable verbose output]'
  '--profile[AWS profile to use]:profile:'
  '--region[AWS region]:region:'
)

_arguments -s -S -C \
  $global_flags \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcmds
    subcmds=(
      'list-resources:List AWS resources that can be exposed'
      'expose:Expose a single AWS resource'
      'smash:Expose all resources of a given service'
    )
    _describe -t commands 'endgame subcommand' subcmds && ret=0
    ;;
  args)
    local -a services
    services=(all acm ecr efs elasticsearch glacier iam kms lambda rds-snapshots s3 secretsmanager ses sns sqs)
    case $line[1] in
      list-resources)
        _arguments -s -S \
          '--service[AWS service to list]:service:(${services[@]})' \
          '--help[Show help]' && ret=0
        ;;
      expose)
        _arguments -s -S \
          '--service[AWS service]:service:(${services[@]})' \
          '--name[Resource name]:name:' \
          '--evil-principal[Principal to grant access to]:principal:' \
          '--dry-run[Dry run mode]' \
          '--undo[Undo the exposure]' \
          '--help[Show help]' && ret=0
        ;;
      smash)
        _arguments -s -S \
          '--service[AWS service]:service:(${services[@]})' \
          '--evil-principal[Principal to grant access to]:principal:' \
          '--dry-run[Dry run mode]' \
          '--undo[Undo the exposure]' \
          '--cloak[Cloak mode]' \
          '--help[Show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
