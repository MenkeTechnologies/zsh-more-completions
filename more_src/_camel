#compdef camel

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:execute Camel routes from files or code'
  'init:create new route files with sample configurations'
  'bind:generate Pipe custom resources connecting sources to sinks'
  'export:convert JBang projects to Maven-based applications'
  'ps:list running Camel integrations with PIDs'
  'get:display status details (context, routes, services, metrics, processors)'
  'top:show resource utilization and performance statistics'
  'log:tail and search integration logs'
  'trace:monitor message routing through routes'
  'version:manage and query Camel release versions'
  'cmd:execute commands within running integrations'
  'stop:terminate running integrations'
  'shell:launch interactive REPL'
  'completion:generate shell completion'
  'debug:route-level debugging'
  'jolokia:attach JVM monitoring agent'
  'hawtio:launch web console'
  'infra:manage containerized services (DBs, brokers)'
  'plugin:install/remove optional plugins'
  'config:modify local JBang configuration'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--dev[enable live-reload during development]' \
  '--background[run integration as daemon]' \
  '--console[start embedded web developer console]' \
  '*--property=[set configuration value]:value:' \
  '*--properties=[set configuration values from file]:file:_files' \
  '--camel-version=[target Camel release]:version:' \
  '*--dep=[add Maven dependency]:dep:' \
  '*--repos=[additional Maven repositories]:repos:' \
  '--profile=[execution profile]:profile:(dev test prod)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'camel subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (cmd)
        _values 'cmd action' \
          'send' 'receive' 'stub' 'load' \
          'start-route' 'stop-route' \
          'start-group' 'stop-group' \
          'enable-processor' 'disable-processor' 'logger' && ret=0
        ;;
      (get)
        _values 'get target' \
          'context' 'route' 'route-controller' 'service' \
          'metric' 'processor' 'circuit-breaker' 'kamelet' \
          'platform-http' 'thread' 'startup' 'health' 'event' \
          'rest' 'transformer' 'fault-tolerance' 'source' && ret=0
        ;;
      (config)
        _values 'config action' \
          'set' 'unset' 'list' 'get' && ret=0
        ;;
      (plugin)
        _values 'plugin action' \
          'add' 'delete' 'get' && ret=0
        ;;
      (infra)
        _values 'infra action' \
          'list' 'run' 'stop' 'log' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' && ret=0
        ;;
      (run|init|export|debug|trace)
        _files
        ret=0
        ;;
    esac
    ;;
esac

return ret
