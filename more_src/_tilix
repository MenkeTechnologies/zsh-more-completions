#compdef tilix
# Documentation: https://manpages.debian.org/testing/tilix/tilix.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-w --working-directory)'{-w,--working-directory}'=[set working directory]:directory:_files -/' \
  '(-p --profile)'{-p,--profile}'=[set profile]:profile name:' \
  '(-t --title)'{-t,--title}'=[set terminal title]:title:' \
  '(-e --command)'{-e,--command}'=[execute command]:command:_command_names' \
  '--display=[set X display]:display:' \
  '--maximize[start maximized]' \
  '--full-screen[start in full screen]' \
  '(-a --action)'{-a,--action}'=[send action to existing instance]:action:(session-add-right session-add-down app-new-session app-new-window)' \
  '(-s --session)'{-s,--session}'=[restore saved session]:session:' \
  '--minimize[start minimized]' \
  '--focus-window[focus existing window]' \
  '--new-process[start a new process]' \
  '(-q --quake)'{-q,--quake}'[open a quake terminal]' \
  '--preferences[open preferences dialog]' \
  '--geometry=[set initial geometry]:geometry:' \
  '--window-style=[set window style]:style:(normal disable-csd disable-csd-hide-toolbar borderless)' \
  '*:file:_files' && ret=0

return ret
