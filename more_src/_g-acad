#compdef g-acad
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=g-acad&sektion=1
# BRL-CAD geometry database to ACAD (ESRI) converter

local ret=1

_arguments -s \
  '-v[verbose output]' \
  '-i[output units in inches (default mm)]' \
  '-x[librt debug flag level]:level' \
  '-X[NMG debug flag level]:level' \
  '-e[error message file]:error file:_files' \
  '-D[calculational distance tolerance (mm)]:tolerance' \
  '-a[absolute tessellation tolerance]:tolerance' \
  '-r[relative tessellation tolerance]:tolerance' \
  '-n[normal tessellation tolerance]:tolerance' \
  '-P[number of CPUs]:cpus' \
  '-o[output ACAD file (default stdout)]:output:_files' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
