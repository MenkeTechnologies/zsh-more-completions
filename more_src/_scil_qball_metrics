#compdef scil_qball_metrics
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_qball_metrics.html
# Scilpy: compute q-ball metrics (GFA, NuFO, peaks) from a DWI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--sh_order=[SH order]:order' \
  '--mask=[binary mask]:mask:_files' \
  '--use_qball[use classic q-ball instead of CSA]' \
  '--not_all[only saved metrics are computed]' \
  '--b0_threshold=[b0 threshold]:thr' \
  '--skip_b0_check[skip b0 existence validation]' \
  '--sh_basis=[SH basis]:basis:(descoteaux07 tournier07 descoteaux07_legacy tournier07_legacy)' \
  '--processes=[number of sub-processes]:nbr' \
  '--gfa=[GFA output]:file:_files' \
  '--peaks=[peaks output]:file:_files' \
  '--peak_indices=[peak indices output]:file:_files' \
  '--sh=[SH output]:file:_files' \
  '--nufo=[NuFO output]:file:_files' \
  '--a_power=[anisotropic power output]:file:_files' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_dwi:_files' \
  '2:in_bval:_files' \
  '3:in_bvec:_files' && ret=0

return ret
