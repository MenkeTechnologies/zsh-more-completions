#compdef lightgbm
# Documentation: https://man.archlinux.org/search?q=lightgbm
# Reference accessed: 2026-05-16

# LightGBM: Microsoft gradient boosting CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-version[show version]' \
  'task=[task]:task:(train predict convert_model refit save_binary)' \
  'config=[config file]:file:_files' \
  '*:lightgbm key=value:_files' && ret=0
return ret
