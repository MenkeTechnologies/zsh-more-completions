#compdef pragtical
# pragtical — lightweight code editor (lite-xl fork)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a subcommands=(
  'edit:open files for editing on a new instance'
  'help:display help'
  'list:list available commands'
  'repl:start a Read-Eval-Print Loop'
  'test:run Lua test files'
  'run:run a Lua script'
)

_arguments -s -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --fork)'{-f,--fork}'[fork the editor to the background]' \
  '1:command or file:->cmd_or_file' \
  '*:: :->args' \
  && ret=0

case $state in
  (cmd_or_file)
    _alternative \
      'commands:command:_describe -t commands "pragtical command" subcommands' \
      'files:file or directory:_files' \
      && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments -s -S \
          '(-e --eval)'{-e,--eval}'[evaluate arguments as Lua code]' \
          '(-n --no-quit)'{-n,--no-quit}'[do not quit after execution]' \
          '*:Lua script:_files -g "*.lua"' \
          && ret=0
        ;;
      (test)
        _arguments -s -S \
          '(-n --no-quit)'{-n,--no-quit}'[do not quit after execution]' \
          '*:test file:_files -g "*.lua"' \
          && ret=0
        ;;
      (edit)
        _arguments '*:file:_files' && ret=0
        ;;
      (*)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
