#compdef dwinormalise
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwinormalise.html
# Source: MRtrix3/mrtrix3 bin/dwinormalise — DWI intensity normalisation dispatcher (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-intensity+[target b=0 intensity]:value:_default' \
    '-percentile+[b=0 percentile for normalisation]:n:_default' \
    '-fa_threshold+[FA threshold for white-matter mask (group)]:value:_default' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '-scratch+[scratch directory]:dir:_files -/' \
    '-continue+[continue from a previous scratch dir]:dir:_files -/' \
    '-nocleanup[do not clean up scratch directory]' \
    '-nthreads+[number of threads]:n:_default' \
    '1:algorithm:(group individual)' \
    '*:algorithm-specific arguments:_files' \
    && ret=0

return ret
