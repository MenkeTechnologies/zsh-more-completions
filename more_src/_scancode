#compdef scancode
# _scancode — license / copyright / dependency scanner (aboutcode-org/scancode-toolkit)
# upstream: https://github.com/aboutcode-org/scancode-toolkit
# Flags from src/scancode/cli.py (click).

_scancode() {
    local -a args
    args=(
        '--strip-root[strip the root path segment from result paths]'
        '--full-root[include the absolute root path in result paths]'
        '(-n --processes)'{-n+,--processes=}'[number of parallel processes]:n:'
        '--timeout=[per-file timeout in seconds]:seconds:'
        '(-q --quiet)'{-q,--quiet}'[suppress all output except errors]'
        '(-v --verbose)'{-v,--verbose}'[show file-level progress]'
        '--from-json[treat INPUT as a previous scancode JSON result]'
        '--timing[record per-step timing in the output]'
        '--max-in-memory=[max resources kept in memory before spooling]:n:'
        '--max-depth=[maximum subdirectory depth to scan (0 = unlimited)]:n:'
        '(-A --about)'{-A,--about}'[print ABOUT metadata and exit]'
        '(-V --version)'{-V,--version}'[print version and exit]'
        '--examples[print usage examples and exit]'
        '--plugins[print loaded plugins and exit]'
        '--print-options[print the set of selected options and exit]'
        '--keep-temp-files[keep temporary files after a scan completes]'
        '--check-version[check for new versions (default)]'
        '--no-check-version[skip version checks]'
        '(-l --license)'{-l,--license}'[scan files for licenses]'
        '(-c --copyright)'{-c,--copyright}'[scan files for copyright holders]'
        '(-p --package)'{-p,--package}'[scan files for package manifests]'
        '(-e --email)'{-e,--email}'[scan files for email addresses]'
        '(-u --url)'{-u,--url}'[scan files for URLs]'
        '(-i --info)'{-i,--info}'[collect basic resource information]'
        '--system-package[scan installed system packages]'
        '--package-only[only scan package manifests, skip other content]'
        '--license-text[include detected license text in results]'
        '--license-text-diagnostics[include diagnostic info on license text matches]'
        '--license-clue[include partial license matches as clues]'
        '--license-references[include SPDX license references]'
        '--license-diagnostics[include diagnostic info on license matches]'
        '--license-score=[minimum match score for licenses]:score:'
        '--unknown-licenses[detect unknown / unmatched license text]'
        '--ignore=[glob to ignore (repeatable)]:glob:'
        '--include=[glob to include (repeatable)]:glob:'
        '--max-email=[max emails reported per resource]:n:'
        '--max-url=[max URLs reported per resource]:n:'
        '--reindex-licenses[force re-indexing of the license database]'
        '--json=[write a regular JSON report to FILE]:file:_files -g "*.json"'
        '--json-pp=[write a pretty-printed JSON report to FILE]:file:_files -g "*.json"'
        '--json-lines=[write a JSON-lines report to FILE]:file:_files'
        '--html=[write an HTML report to FILE]:file:_files -g "*.html"'
        '--spdx-rdf=[write an SPDX RDF report to FILE]:file:_files -g "*.rdf"'
        '--spdx-tv=[write an SPDX tag/value report to FILE]:file:_files -g "*.spdx"'
        '--csv=[write a CSV report to FILE]:file:_files -g "*.csv"'
        '--yaml=[write a YAML report to FILE]:file:_files -g "*.(yaml|yml)"'
        '(- *)'{-h,--help}'[show help]'
        '1:file or directory to scan:_files'
    )
    _arguments -s -S $args
}

_scancode "$@"
