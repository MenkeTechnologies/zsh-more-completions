#compdef bat
# Documentation: bat --help on bat 0.26.x
# Source: sharkdp/bat — cat(1) clone with syntax highlighting and Git integration.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(-A --show-all)'{-A,--show-all}'[show non-printable chars]' \
    '--nonprintable-notation=[non-printable char notation]:notation:(unicode caret)' \
    '--binary=[treat binary content]:behavior:(no-printing as-text)' \
    '*'{-p,--plain}'[plain style, no decorations (-pp also disables paging)]' \
    '(-l --language)'{-l,--language=}'[force language for syntax highlighting]:lang:' \
    '(-H --highlight-line)'{-H,--highlight-line=}'[highlight line range N\:M]:N\:M:' \
    '--file-name=[display name for STDIN-piped file]:name:' \
    '(-d --diff)'{-d,--diff}'[only show Git-modified lines]' \
    '--diff-context=[lines of context around diff]:N:' \
    '--tabs=[tab width in spaces (0 = passthrough)]:T:' \
    '--wrap=[text-wrapping mode]:mode:(auto never character)' \
    '(-S --chop-long-lines)'{-S,--chop-long-lines}'[truncate lines longer than screen]' \
    '--terminal-width=[explicit terminal width]:width:' \
    '(-n --number)'{-n,--number}'[only line numbers (alias for --style=numbers)]' \
    '--color=[when to use color]:when:(auto never always)' \
    '--italic-text=[when to use italics]:when:(always never)' \
    '--decorations=[when to show decorations]:when:(auto never always)' \
    '(-f --force-colorization)'{-f,--force-colorization}'[force color + decorations]' \
    '--paging=[when to page]:when:(auto never always)' \
    '--pager=[pager command]:cmd:' \
    '(-m --map-syntax)*'{-m,--map-syntax=}'[map glob to syntax name]:glob\:syntax:' \
    '*--ignored-suffix=[suffix to ignore for syntax detection]:suffix:' \
    '--theme=[syntax highlighting theme]:theme:' \
    '--theme-light=[light-mode theme]:theme:' \
    '--theme-dark=[dark-mode theme]:theme:' \
    '(- *)--list-themes[list supported themes]' \
    '(-s --squeeze-blank)'{-s,--squeeze-blank}'[squeeze consecutive blank lines]' \
    '--squeeze-limit=[max consecutive empty lines]:n:' \
    '--strip-ansi=[when to strip ANSI escapes]:when:(auto always never)' \
    '--style=[components to display]:components:' \
    '(-r --line-range)*'{-r,--line-range=}'[only print line range N\:M]:N\:M:' \
    '(- *)'{-L,--list-languages}'[list supported languages]' \
    '(-u --unbuffered)'{-u,--unbuffered}'[POSIX-compliance no-op]' \
    '(- *)--completion=[print shell completion]:shell:(bash fish zsh ps1)' \
    '(- *)--diagnostic[print bug-report diagnostic info]' \
    '(- *)--acknowledgements[print acknowledgements]' \
    '--set-terminal-title[set terminal title to filename in pager]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds files
        subcmds=('cache:manage cached syntaxes and themes')
        _alternative \
            'subcmds:subcommand:_describe -t bat-subcmds "bat subcommand" subcmds' \
            'files:file:_files' \
            && ret=0
        ;;
    args)
        if [[ $line[1] == cache ]]; then
            _arguments \
                '(- *)--build[recompile syntaxes and themes]' \
                '(- *)--clear[clear cached syntaxes and themes]' \
                '--source=[user syntax+theme source dir]:dir:_files -/' \
                '--target=[output cache dir]:dir:_files -/' \
                '--blank[do not include default syntaxes/themes]' \
                '--acknowledgements[record acknowledgements]' \
                '(- *)'{-h,--help}'[show cache help]' \
                && ret=0
        else
            _files && ret=0
        fi
        ;;
esac

return ret
