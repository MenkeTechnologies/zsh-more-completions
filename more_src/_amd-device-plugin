#compdef amd-device-plugin

# amd-device-plugin: AMD GPU device plugin for Kubernetes (ROCm)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--logtostderr[log to stderr]' \
  '-v[log level]:level:' \
  '--pulse=[heartbeat interval (sec)]:seconds:' \
  '--resource-naming-strategy=[naming strategy]:strategy:(single mixed)' \
  '*::amd-device-plugin args:_files' && ret=0
return ret
