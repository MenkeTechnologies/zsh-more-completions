#compdef virtual-kubelet
# Documentation: https://virtual-kubelet.io/docs/usage/
# Virtual Kubelet - run a fake Kubernetes node backed by a cloud provider

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig=[kube config file for connecting to the API server]:file:_files' \
  '--cluster-domain=[kubernetes cluster-domain]:domain' \
  '--nodename=[kubernetes node name]:name' \
  '--os=[operating system (Linux/Windows)]:os:(Linux Windows)' \
  '--provider=[cloud provider]:provider' \
  '--provider-config=[cloud provider configuration file]:file:_files' \
  '--metrics-addr=[address to listen for metrics/stats requests]:addr' \
  '--disable-taint[disable the virtual-kubelet node taint]' \
  '--pod-sync-workers=[number of pod synchronization workers]:n' \
  '--trace-exporter=[tracing exporter to use]:exporter' \
  '--trace-service-name=[service name to register with the trace exporter]:name' \
  '*--trace-tag=[add tags to include with traces in key=value form]:tag' \
  '--trace-sample-rate=[probability of tracing samples]:rate' \
  '--full-resync-period=[how often to perform a full resync of pods]:duration' \
  '--startup-timeout=[how long to wait for the virtual-kubelet to start]:duration' \
  '--stream-idle-timeout=[maximum idle time before closing streaming connections]:duration' \
  '--stream-creation-timeout=[maximum time for establishing streaming connections]:duration' \
  '*:arg:_files' && ret=0

return ret
