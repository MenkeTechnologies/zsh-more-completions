#compdef rivet-buildplugin
# Documentation: https://rivet.hepforge.org/
# rivet-buildplugin - compile a Rivet analysis plugin library from source

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-j[number of parallel compile jobs]:jobs:' \
  '(-r --with-root)'{-r,--with-root}'[add ROOT link options]' \
  '(-n --cmd --dry-run)'{-n,--cmd,--dry-run}'[print generated commands without executing]' \
  '(-k --keep)'{-k,--keep}'[retain intermediate files after compilation]' \
  '(-v --verbose)'{-v,--verbose}'[output debug information during build]' \
  '*:source:_files' && ret=0

return ret
