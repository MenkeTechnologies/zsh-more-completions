#compdef birdc birdc6 bird-cli
# _bird-cli — CZ.NIC bird-cli birdc CLI client to the BIRD Internet Routing Daemon BGP4 OSPFv2 OSPFv3 RIP RIPng Babel BFD pipe-static-direct-RPKI-radv-ROA protocol speaker reading interactive commands over UNIX domain socket reload configure show route summary memory protocols (CZ.NIC team, C); getopt
# upstream: https://bird.network.cz/

_bird-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-l[server is local]' \
        '-v[verbose]' \
        '-r[no readline]' \
        '-s+[socket file]:file:_files' \
        '*::'
}

_bird-cli "$@"
