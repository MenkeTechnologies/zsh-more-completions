#compdef release-plz

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'update:modify package versions and changelogs'
  'release-pr:open a release PR'
  'release:publish packages and create tags'
  'init:configure release-plz GitHub Action'
  'set-version:manually set a package version'
  'generate-completions:generate shell completion'
  'generate-schema:emit JSON schema'
  'check-updates:check for newer release-plz versions'
)

_arguments -C \
  '*'{-v,--verbose}'[verbose output]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'release-plz subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (update|release-pr)
        _arguments \
          '--manifest-path=[Cargo.toml path]:file:_files -g "Cargo.toml"' \
          '--registry-manifest-path=[registry Cargo.toml]:file:_files' \
          '(-p --package)'{-p,--package=}'[package name]:name:' \
          '--no-changelog[skip changelog]' \
          '--release-date=[release date]:date:' \
          '--registry=[registry name]:name:' \
          '(-u --update-deps)'{-u,--update-deps}'[update dependencies]' \
          '--changelog-config=[git-cliff config]:file:_files' \
          '--allow-dirty[allow dirty workdir]' \
          '--repo-url=[repo URL]:url:' \
          '--git-token=[git token]:token:' \
          '--forge=[forge type]:forge:(github gitea gitlab)' \
          '--max-analyze-commits=[max commits to analyze]:n:' \
          '(-o --output)'{-o,--output=}'[output format]:fmt:(human json)' && ret=0
        ;;
      (release)
        _arguments \
          '--manifest-path=[Cargo.toml path]:file:_files -g "Cargo.toml"' \
          '--registry=[registry name]:name:' \
          '--token=[cargo token]:token:' \
          '--dry-run[dry run]' \
          '--no-verify[skip verification]' \
          '--allow-dirty[allow dirty workdir]' \
          '--repo-url=[repo URL]:url:' \
          '--git-token=[git token]:token:' \
          '--forge=[forge type]:forge:(github gitea gitlab)' \
          '(-o --output)'{-o,--output=}'[output format]:fmt:(human json)' && ret=0
        ;;
      (generate-completions)
        _values 'shell' 'bash' 'zsh' 'fish' 'elvish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
