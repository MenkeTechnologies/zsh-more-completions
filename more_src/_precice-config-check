#compdef precice-config-check
# Documentation: https://github.com/precice/config-check
# Check a preCICE configuration file for logical errors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '1:config.xml source file:_files -g "*.xml"' && ret=0

return ret
