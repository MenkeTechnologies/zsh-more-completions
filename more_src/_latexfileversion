#compdef latexfileversion
# Documentation: https://man.archlinux.org/search?q=latexfileversion
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-l[Show only the file date]'
    '-d[Show only the file date]'
    '-v[Show only the file version]'
    '-h[Show help message]'
    '*:LaTeX file:_files -g "*.{sty,cls,dtx,tex}"'
)

_arguments -s -S $arguments
