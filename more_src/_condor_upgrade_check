#compdef condor_upgrade_check
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_upgrade_check.html
# run checks to help identify issues prior to upgrading HTCondor

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage to the terminal]' \
  '--CE[run available checks for installed HTCondor-CE on host]' \
  '(-a --all)'{-a,--all}'[run all available checks ignoring the version check]' \
  '(-i --ignore)'{-i,--ignore}'[ignore checks with a matching tag]:tag' \
  '(-o --only)'{-o,--only}'[only run checks with a matching tag]:tag' \
  '(-w --warnings --no-warnings)'{-w,--warnings,--no-warnings}'[enable or disable output of warning checks]' \
  '(-t --tags)'{-t,--tags}'[display all available check tags]' \
  '(-d --dump)'{-d,--dump}'[display information about all available checks]' \
  '(-v --verbose)'{-v,--verbose}'[increase tool verbosity]' && ret=0

return ret
