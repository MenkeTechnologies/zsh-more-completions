#compdef dinitctl

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global_flags=(
  '(- *)'{-h,--help}'[show help]'
  {-s,--system}'[control system service manager]'
  {-u,--user}'[control user service manager]'
  {-p,--socket-path}'=[control socket path]:socket path:_files'
  {-q,--quiet}'[suppress output]'
  '--use-passed-cfd[use control fd passed by service manager]'
)

_arguments -s -S \
  $global_flags \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:Start a service'
      'stop:Stop a service'
      'restart:Restart a service'
      'wake:Wake a service (start without enabling)'
      'release:Release a service (reverse of wake)'
      'unpin:Unpin a service'
      'enable:Enable a service at boot'
      'disable:Disable a service at boot'
      'is-started:Check if a service is started'
      'is-failed:Check if a service has failed'
      'status:Show service status'
      'list:List services'
      'add-dep:Add a dependency'
      'rm-dep:Remove a dependency'
      'shutdown:Shut down the service manager'
      'signal:Send a signal to a service process'
      'catlog:Show service log'
      'setenv:Set an environment variable'
      'trigger:Trigger a service'
    )
    _describe -t commands 'dinitctl command' commands && ret=0
    ;;
  args)
    local -a _services
    local _sdir="${opt_args[-d]:-/etc/dinit.d}"
    if [[ -d "$_sdir" ]]; then
      _services=( ${_sdir}/*(:t) )
    fi

    case ${words[1]} in
      start|stop|restart)
        _arguments -s -S \
          '--no-wait[do not wait for service to change state]' \
          '--pin[pin the service in the requested state]' \
          '--force[force stop even if dependents exist]' \
          '*:service name:compadd -a _services' && ret=0
        ;;
      wake|release|unpin|enable|disable|is-started|is-failed|status|catlog|trigger)
        _arguments -s -S \
          '*:service name:compadd -a _services' && ret=0
        ;;
      signal)
        _arguments -s -S \
          '1:signal:_signals' \
          '2:service name:compadd -a _services' && ret=0
        ;;
      shutdown)
        _arguments -s -S \
          {-s,--system}'[shut down system manager]' \
          {-u,--user}'[shut down user manager]' && ret=0
        ;;
      add-dep|rm-dep)
        _arguments -s -S \
          '1:dependency type:(regular milestone waits-for)' \
          '2:from service:compadd -a _services' \
          '3:to service:compadd -a _services' && ret=0
        ;;
      list)
        ;;
      setenv)
        _arguments -s -S \
          '1:variable assignment (NAME=VALUE)' && ret=0
        ;;
    esac
    ;;
esac

return ret
