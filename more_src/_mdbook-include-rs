#compdef mdbook-include-rs
# _mdbook-include-rs — include portions of external Rust source files in mdbook (BrynCooke/mdbook-include-rs)
# upstream: https://github.com/BrynCooke/mdbook-include-rs
# Subcommands from src/main.rs (clap).

_mdbook-include-rs() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
                'pre-process:run the preprocessor against a book source dir'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
                pre-process) _arguments '--dir=[book source dir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_mdbook-include-rs "$@"
