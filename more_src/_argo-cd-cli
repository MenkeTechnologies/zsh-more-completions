#compdef argo-cd-cli argo-cd argocd-cli
# _argo-cd-cli — Argo Project argo-cd-cli CLI alternative wrapper around argocd providing application sync GitOps Kubernetes-native continuous-delivery operations app create get sync rollback diff projects clusters repos repocreds account session settings login logout management for the Argo CD declarative GitOps controller (Argo Project team, Go); cobra
# upstream: https://argo-cd.readthedocs.io/

_argo-cd-cli() {
    local -a sub=(
        'login:authenticate to Argo CD'
        'logout:revoke session'
        'app:application operations'
        'project:project operations'
        'cluster:cluster operations'
        'repo:repository operations'
        'repocreds:repository credentials'
        'account:account operations'
        'cert:TLS certificate operations'
        'gpg:GPG key operations'
        'context:argocd context'
        'settings:settings operations'
        'admin:admin operations'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server=+[host:port]:str:' \
        '--insecure[skip TLS verify]' \
        '--auth-token=+[token]:str:' \
        '--client-crt=+[file]:file:_files' \
        '--client-crt-key=+[file]:file:_files' \
        '--grpc-web[force gRPC-Web]' \
        '--grpc-web-root-path=+[path]:str:' \
        '--plaintext[no TLS]' \
        '--port-forward[use kube port-forward]' \
        '--port-forward-namespace=+[ns]:str:' \
        '--config=+[file]:file:_files -g "*.yaml *.json"' \
        '-o+[output format]:f:(json yaml wide tree url table)' \
        '--output=+[format]:f:(json yaml wide tree url table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'argo-cd-cli subcommand' sub ;;
        args)
            case $words[1] in
                app) _arguments '1:op:(create get list sync rollback delete diff history wait edit logs patch resources actions terminate-op set unset manifests rollback delete-resource)' '*:name:' ;;
                project|cluster|repo|repocreds|account|cert|gpg|context|settings) _arguments '1:op:(list get add remove update create delete)' '*:name:' ;;
            esac
            ;;
    esac
}

_argo-cd-cli "$@"
