#compdef oasdiff

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'diff:full diff between two OpenAPI specs'
  'summary:high-level summary of changes'
  'breaking:report only breaking changes'
  'changelog:human-readable changelog of all changes'
  'flatten:flatten allOf schemas'
  'checks:list classification rules'
  'qr:quick report (alias)'
  'completion:generate shell completion'
  'help:show help for any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

_oasdiff_common() {
  _arguments \
    '(-b --base)'{-b+,--base=}'[base OpenAPI spec]:file:_files' \
    '(-r --revision)'{-r+,--revision=}'[revision OpenAPI spec]:file:_files' \
    '(-c --composed)'{-c,--composed}'[treat base and revision as glob patterns]' \
    '(-f --format)'{-f+,--format=}'[output format]:format:(yaml json text html markdown markup junit github singleline sarif)' \
    '(-o --output-to-file)'{-o+,--output-to-file=}'[write output to file]:file:_files' \
    '--lang=[language for messages]:lang:(en ru)' \
    '--prefix-base=[prefix base paths]:prefix:' \
    '--prefix-revision=[prefix revision paths]:prefix:' \
    '--strip-prefix-base=[strip prefix from base paths]:prefix:' \
    '--strip-prefix-revision=[strip prefix from revision paths]:prefix:' \
    '--match-path=[regex for paths to include]:regex:' \
    '--filter-extension=[OpenAPI extension to exclude]:ext:' \
    '*--exclude-elements=[exclude element kinds]:element:(description examples extensions title summary endpoints)' \
    '--include-path-params[include path params in matching]' \
    '--flatten-params[merge path-level params into operations]' \
    '--flatten-allof[flatten allOf schemas]' \
    '--case-insensitive-headers[match headers case-insensitively]' \
    '--no-color[disable color output]' \
    '--fail-on=[severity to fail on]:severity:(ERR WARN INFO)' \
    '--fail-on-diff[exit 1 if any diff]' \
    '--severity-levels=[severity levels file]:file:_files'
}

case $state in
  (cmd) _describe -t cmds 'oasdiff command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (diff)
        _oasdiff_common
        _arguments \
          '--exclude-description[ignore description changes]' \
          '--exclude-examples[ignore example changes]' \
          '--summary[print summary only]' && ret=0 ;;
      (summary)
        _oasdiff_common && ret=0 ;;
      (breaking)
        _oasdiff_common
        _arguments \
          '--deprecation-days-beta=[deprecation days for beta endpoints]:n:' \
          '--deprecation-days-stable=[deprecation days for stable endpoints]:n:' \
          '*--include-checks=[additional checks]:check:' \
          '*--warn-ignore=[file with warnings to ignore]:file:_files' \
          '*--err-ignore=[file with errors to ignore]:file:_files' \
          '--attributes=[custom attributes file]:file:_files' && ret=0 ;;
      (changelog)
        _oasdiff_common
        _arguments \
          '*--include-checks=[additional checks]:check:' && ret=0 ;;
      (flatten)
        _arguments \
          '(-f --format)'{-f+,--format=}'[output format]:format:(yaml json)' \
          '*::file:_files' && ret=0 ;;
      (checks)
        _arguments \
          '--lang=[language]:lang:(en ru)' \
          '--required[only required checks]' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
