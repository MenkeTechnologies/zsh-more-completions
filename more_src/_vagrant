#compdef vagrant
# _vagrant — HashiCorp Vagrant (declarative dev VMs via Vagrantfile; subcommands: up/halt/destroy/suspend/resume/reload, ssh/winrm, status/global-status, box list/add/remove/update, snapshot, plugin install/list, cloud auth/box/box-version)
# upstream: https://github.com/hashicorp/vagrant
# Subcommands from vagrant lib/vagrant/cli.rb on tip.

_vagrant() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-v[show version]' \
        '--version[show version]' \
        '-h[show help]' \
        '--help[show help]' \
        '--no-color[disable colors]' \
        '--color[force colors]' \
        '--debug[debug output]' \
        '--timestamp[prepend timestamps]' \
        '--no-tty[no tty mode]' \
        '--machine-readable[machine-readable output]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'vagrant command' \
                '(up halt reload destroy provision suspend resume status global-status ssh ssh-config winrm winrm-config rsync rsync-auto box snapshot plugin login logout cloud connect push share init list-commands package validate version powershell port docker-logs docker-run docker-exec)'
            ;;
        args)
            case $line[1] in
                box) _describe -t commands 'box subcommand' '(add list remove repackage outdated update prune)' ;;
                snapshot) _describe -t commands 'snapshot subcommand' '(save restore list delete pop push)' ;;
                plugin) _describe -t commands 'plugin subcommand' '(install uninstall list update repair expunge)' ;;
                cloud) _describe -t commands 'cloud subcommand' '(auth box search version provider publish)' ;;
                up|halt|reload|destroy|provision|suspend|resume|ssh|status) _arguments '*:vm name:' ;;
            esac
            ;;
    esac
}

_vagrant "$@"
