(( $+functions[_twips_commands] )) ||
_twips_commands() {
    local commands; commands=(
'search:Run a single search' \
'serve:Run a search server. Use with\: https\://experiments.cubing.net/cubing.js/twsearch/text-ui.html' \
'solve-known-puzzle:Solve a known puzzle' \
'schreier-sims:Run the Schreier-Sims algorithm to calculate the number of reachable patterns' \
'gods-algorithm:Enumerate the entire pattern graph and print antipodes' \
'timing-test:Run a timing test for given definition' \
'canonical-algs:Enumerate canonical algs (move sequences) at iterative depths' \
'scramble:Generate a scramble' \
'scramble-finder:Test the scramble finder implementations directly' \
'derive:Derive scrambles' \
'benchmark:Run an internal benchmark suite' \
'completions:Print completions for the given shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'twips commands' commands "$@"
}
