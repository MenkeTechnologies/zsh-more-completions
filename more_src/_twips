autoload -U is-at-least

_twips() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_twips_commands" \
"*::: :->twips" \
&& ret=0
    case $state in
    (twips)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:twips-command-$line[1]:"
        case $line[1] in
            (search)
_arguments "${_arguments_options[@]}" : \
'--min-num-solutions=[]:MIN_NUM_SOLUTIONS:_default' \
'*--generator-moves=[A comma-separated list of moves to use. All multiples of these moves are considered. For example, \`--moves U,F,R2\` only permits half-turns on R, and all possible turns on U and F]:GENERATOR_MOVES:_default' \
'*--generator-algs=[A comma-separated list of algs to use. All multiples of these algs are considered. For example, \`--algs U,F,R2\` only permits half-turns on R, and all possible turns on U and F]:GENERATOR_ALGS:_default' \
'--check-before-solve=[Check that a position is valid before attempting to solve it. This may take extra time or memory for large puzzles]:CHECK_BEFORE_SOLVE:(auto never always)' \
'--start-prune-depth=[Depth to start the pruning table. This can avoid multiple pruning table expansions that can already be anticipated by starting with a sufficient depth]:DEPTH:_default' \
'--min-depth=[Start solution search at this depth]:MIN_DEPTH:_default' \
'--max-depth=[Stop solution search at this depth]:MAX_DEPTH:_default' \
'--continue-after=[Continue (or start) search after this alg. If the alg is a valid solution, it will be skipped]:CONTINUE_AFTER:_default' \
'--continue-at=[Continue (or start) search at this alg. If the alg is a valid solution, it will be the first one returned]:CONTINUE_AT:_default' \
'--num-threads=[Defaults to the number of logical CPU cores available]:NUM_THREADS:_default' \
'--memory-MiB=[Memory to use in MiB. See \`README.md\` for advice on how to tune memory usage]:MEBIBYTES:_default' \
'--write-prune-tables=[]:WRITE_PRUNE_TABLES:(auto never always)' \
'--cache-dir=[]:CACHE_DIR:_files' \
'--metric=[]:METRIC:_default' \
'--verbosity=[]:VERBOSITY:_default' \
'--scramble-alg=[Solve a single scramble specified directly as an argument]:SCRAMBLE_ALG:_default' \
'--experimental-target-pattern=[Use the target pattern from the specified file instead of the default start pattern from the defintion]:EXPERIMENTAL_TARGET_PATTERN:_files' \
'--random-start[Randomize the search order. This can produce different solutions the same run of each input, which is desirable for some use cases]' \
'-h[Print help]' \
'--help[Print help]' \
':def_file:_files' \
'::scramble_file -- Solve all the scrambles from the given file:_files' \
&& ret=0
;;
(serve)
_arguments "${_arguments_options[@]}" : \
'--num-threads=[Defaults to the number of logical CPU cores available]:NUM_THREADS:_default' \
'--memory-MiB=[Memory to use in MiB. See \`README.md\` for advice on how to tune memory usage]:MEBIBYTES:_default' \
'--verbosity=[]:VERBOSITY:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(solve-known-puzzle)
_arguments "${_arguments_options[@]}" : \
'--print-link=[By default, the command prints a URL for the solution to \`stderr\`. Pass this to disable the URL printing functionality]:PRINT_LINK:(true false)' \
'-h[Print help]' \
'--help[Print help]' \
':puzzle:_default' \
':scramble_setup_alg -- Scramble setup alg:_default' \
&& ret=0
;;
(schreier-sims)
_arguments "${_arguments_options[@]}" : \
'--num-threads=[Defaults to the number of logical CPU cores available]:NUM_THREADS:_default' \
'--memory-MiB=[Memory to use in MiB. See \`README.md\` for advice on how to tune memory usage]:MEBIBYTES:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':def_file:_files' \
&& ret=0
;;
(gods-algorithm)
_arguments "${_arguments_options[@]}" : \
'--start-pattern=[]:START_PATTERN:_files' \
'*--generator-moves=[A comma-separated list of moves to use. All multiples of these moves are considered. For example, \`--moves U,F,R2\` only permits half-turns on R, and all possible turns on U and F]:GENERATOR_MOVES:_default' \
'*--generator-algs=[A comma-separated list of algs to use. All multiples of these algs are considered. For example, \`--algs U,F,R2\` only permits half-turns on R, and all possible turns on U and F]:GENERATOR_ALGS:_default' \
'--metric=[]:METRIC:_default' \
'--num-threads=[Defaults to the number of logical CPU cores available]:NUM_THREADS:_default' \
'--memory-MiB=[Memory to use in MiB. See \`README.md\` for advice on how to tune memory usage]:MEBIBYTES:_default' \
'-h[Print help]' \
'--help[Print help]' \
':def_file:_files' \
&& ret=0
;;
(timing-test)
_arguments "${_arguments_options[@]}" : \
'--metric=[]:METRIC:_default' \
'--num-threads=[Defaults to the number of logical CPU cores available]:NUM_THREADS:_default' \
'--memory-MiB=[Memory to use in MiB. See \`README.md\` for advice on how to tune memory usage]:MEBIBYTES:_default' \
'-h[Print help]' \
'--help[Print help]' \
':def_file:_files' \
&& ret=0
;;
(canonical-algs)
_arguments "${_arguments_options[@]}" : \
'*--generator-moves=[A comma-separated list of moves to use. All multiples of these moves are considered. For example, \`--moves U,F,R2\` only permits half-turns on R, and all possible turns on U and F]:GENERATOR_MOVES:_default' \
'*--generator-algs=[A comma-separated list of algs to use. All multiples of these algs are considered. For example, \`--algs U,F,R2\` only permits half-turns on R, and all possible turns on U and F]:GENERATOR_ALGS:_default' \
'--metric=[]:METRIC:_default' \
'--num-threads=[Defaults to the number of logical CPU cores available]:NUM_THREADS:_default' \
'--memory-MiB=[Memory to use in MiB. See \`README.md\` for advice on how to tune memory usage]:MEBIBYTES:_default' \
'-h[Print help]' \
'--help[Print help]' \
':def_file:_files' \
&& ret=0
;;
(scramble)
_arguments "${_arguments_options[@]}" : \
'--amount=[Amount of scrambles]:AMOUNT:_default' \
'-h[Print help]' \
'--help[Print help]' \
':event_id -- Event ID (WCA or unofficial):_default' \
&& ret=0
;;
(scramble-finder)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_twips__scramble-finder_commands" \
"*::: :->scramble-finder" \
&& ret=0

    case $state in
    (scramble-finder)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:twips-scramble-finder-command-$line[1]:"
        case $line[1] in
            (search)
_arguments "${_arguments_options[@]}" : \
'--print-link=[]:PRINT_LINK:(true false)' \
'--apply-filtering[]' \
'-h[Print help]' \
'--help[Print help]' \
':event_id -- Event ID (WCA or unofficial):_default' \
