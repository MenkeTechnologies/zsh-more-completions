'--metric=[]:METRIC:_default' \
'-h[Print help]' \
'--help[Print help]' \
':def_file:_files' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':SHELL -- Print completions for the given shell.
These can be loaded/stored permanently (e.g. when using Homebrew), but they can also be sourced directly, e.g.\::(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_twips__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:twips-help-command-$line[1]:"
        case $line[1] in
            (search)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(serve)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(solve-known-puzzle)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
