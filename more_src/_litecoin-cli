#compdef litecoin-cli
# Documentation: https://github.com/litecoin-project/litecoin (src/bitcoin-cli.cpp SetupCliArgs + configure.ac BITCOIN_CLI_NAME=litecoin-cli)
# Reference accessed: 2026-05-29
# Litecoin Core RPC client (Bitcoin Core fork). Default RPC port 9332 mainnet, 19332 testnet, 38332 signet, 19443 regtest.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-version[print version and exit]' \
  '(- *)-help[print help and exit]' \
  '(- *)-?[print help and exit]' \
  '(- *)-h[print help and exit]' \
  '-conf=[configuration file (relative to datadir)]:file:_files -g "*.conf"' \
  '-datadir=[data directory]:dir:_directories' \
  '(-testnet -signet -regtest)-testnet[use Litecoin testnet (chain=test)]' \
  '(-testnet -signet -regtest)-signet[use Litecoin signet (chain=signet)]' \
  '(-testnet -signet -regtest)-regtest[use Litecoin regression test mode]' \
  '-chain=[chain to use]:chain:(main test signet regtest)' \
  '-generate[generate blocks immediately (accepts optional nblocks and maxtries)]' \
  '-getinfo[get general info from remote server (non-atomic)]' \
  '-netinfo[get network peer connection info (optional verbosity 0-4)]' \
  '-named[pass named instead of positional arguments]' \
  '-rpcclienttimeout=[timeout in seconds during HTTP requests (0 = none)]:sec:' \
  '-rpcconnect=[send commands to node running on this IP]:addr:' \
  '-rpccookiefile=[location of auth cookie]:file:_files' \
  '-rpcpassword=[password for JSON-RPC connections]:pw:' \
  '-rpcport=[connect to JSON-RPC on this port]:port:' \
  '-rpcuser=[username for JSON-RPC connections]:user:' \
  '-rpcwait[wait for RPC server to start]' \
  '-rpcwaittimeout=[timeout in seconds to wait for RPC server (0 = none)]:sec:' \
  '-rpcwallet=[send RPC for a non-default wallet (changes URL endpoint)]:wallet:' \
  '-stdin[read extra args from stdin until EOF/Ctrl-D]' \
  '-stdinrpcpass[read RPC password from stdin as a single line]' \
  '-stdinwalletpassphrase[read wallet passphrase from stdin as a single line]' \
  '*:rpc method or arg:' \
  && ret=0

return ret
