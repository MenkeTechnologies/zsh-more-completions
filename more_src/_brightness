# macOS brightness control (nriley/brightness)
_arguments -s -S \
  '-m[set brightness on main display]' \
  '-d+[specify display]:display' \
  '-v[verbose output]' \
  '-l[list current brightness levels]' \
  '*:brightness (0-1):'
