#compdef hatch-fmt
# _hatch-fmt — Hatch Python formatter (pypa/hatch)
# upstream: https://github.com/pypa/hatch

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--check[check only, do not modify files]' \
  '--linter[only run linter]' \
  '--formatter[only run formatter]' \
  '--sync[sync default config]' \
  '*:file:_files -g "*.py"'
