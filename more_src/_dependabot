#compdef dependabot
# Documentation: https://github.com/dependabot/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'update:run an update job for a package-manager/repo'
  'test:run smoke tests from a yaml file'
  'completion:generate shell completion scripts'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--proxy-image=[container image for proxy]:image' \
  '--updater-image=[container image for updater]:image' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'dependabot command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (update)
        _arguments \
          '(-f --file)'{-f,--file=}'[job description file]:file:_files -g "*.{yml,yaml}"' \
          '(-o --output)'{-o,--output=}'[output to file]:file:_files' \
          '(-p --provider)'{-p,--provider=}'[git provider]:provider:(azure bitbucket codecommit gitlab github)' \
          '(-d --directory)'{-d,--directory=}'[target subdirectory]:directory' \
          '--dry-run[dry run without making changes]' \
          '--local=[local source directory]:directory:_directories' \
          '--branch=[branch to update]:branch' \
          '--commit=[commit to use]:commit' \
          '1:package-manager:(bundler cargo composer docker elm github_actions go_modules gradle hex maven npm_and_yarn nuget pip pub swift terraform)' \
          '2:owner/repo' && ret=0
        ;;
      (test)
        _arguments \
          '(-f --file)'{-f,--file=}'[smoke test yaml]:file:_files -g "*.{yml,yaml}"' \
          '--cache=[cache directory]:dir:_directories' && ret=0
        ;;
      (completion)
        _arguments \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
