#compdef dependabot

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'update:run an update job'
  'fetch:run a fetch job'
  'validate:validate a Dependabot config file'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'dependabot command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (update)
        _arguments \
          '-f+[config file]:file:_files -g "*.{yml,yaml}"' \
          '--file=[config file]:file:_files -g "*.{yml,yaml}"' \
          '-d+[dependency names]:dependency' \
          '--dep=[dependency names]:dependency' \
          '--dry-run[dry run without making changes]' \
          '--local=[local directory for source]:directory:_directories' \
          '-o+[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '--provider=[package manager]:provider:(bundler cargo composer docker elm github_actions go_modules gradle hex maven npm_and_yarn nuget pip pub swift terraform)' \
          '--repo=[repository]:repo' \
          '--directory=[directory within repo]:directory' \
          '--branch=[branch to update]:branch' \
          '--commit=[commit to use for updates]:commit' && ret=0
        ;;
      (validate)
        _arguments \
          '1:config file:_files -g "*.{yml,yaml}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
