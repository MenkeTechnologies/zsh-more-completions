#compdef crackmapexec
# _crackmapexec-bin — CrackMapExec authorized AD pentest framework (byt3bl33d3r, Python); SMB/WinRM/LDAP/MSSQL audit (now NetExec)
# upstream: https://github.com/Pennyw0rth/NetExec

_crackmapexec-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-t+[threads]:n:' \
        '--timeout+[timeout sec]:n:' \
        '--jitter+[jitter ms]:n:' \
        '--darrell[easter egg]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '1:protocol:(smb ssh ftp ldap mssql winrm rdp vnc nfs http)' \
        '*::args:'
}

_crackmapexec-bin "$@"
