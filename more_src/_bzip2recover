#compdef bzip2recover
# _bzip2recover — bzip2recover (salvage data from damaged .bz2 archives by splitting them on block boundaries into rec00NNN${input} files which bzip2 -d can then decompress individually)
# upstream: https://gitlab.com/bzip2/bzip2
# Argument shape from bzip2/bzip2recover.c on tip.

_bzip2recover() {
    _arguments \
        '*:bz2 file:_files -g "*.bz2"'
}

_bzip2recover "$@"
