#compdef gdate
# Documentation: gdate --help (GNU coreutils date)
# Source: print or set the system date and time.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(-d --date)'{-d+,--date=}'[display time described by STRING]:string:' \
    '--debug[annotate parsed date]' \
    '(-f --file)'{-f+,--file=}'[read dates from DATEFILE]:file:_files' \
    '(-I --iso-8601)'{-I-,--iso-8601=-}'[ISO 8601 output]::format:(date hours minutes seconds ns)' \
    '--resolution[output available timestamp resolution]' \
    '(-R --rfc-email)'{-R,--rfc-email}'[RFC 5322 format]' \
    '--rfc-3339=[RFC 3339 format]:format:(date seconds ns)' \
    '(-r --reference)'{-r+,--reference=}'[display last-modified time of FILE]:file:_files' \
    '(-s --set)'{-s+,--set=}'[set time described by STRING]:string:' \
    '(-u --utc --universal)'{-u,--utc,--universal}'[UTC]' \
    '1:format string:' \
    && ret=0

return ret
