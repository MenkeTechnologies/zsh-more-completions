# cgoban3: Go board client for X11
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-fontHeight[font height (default 12)]:size:' \
  '-nocolor[disable colors]' \
  '-display[X display]:display:' && ret=0
return ret
