#compdef tuic-server
# _tuic-server — TUIC v5 QUIC-based proxy server (Itsusinn/tuic)
# upstream: https://github.com/Itsusinn/tuic
# Flags from tuic-server/src/config.rs (clap derive Cli).

_tuic-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file path]:file:_files -g "*.(yml|yaml|json|toml)"' \
        '(-d --dir)'{-d+,--dir=}'[config search directory]:dir:_files -/' \
        '(-i --init)'{-i,--init}'[generate a default config file]'
}

_tuic-server "$@"
