#compdef ESMF_RegridWeightGen
# Documentation: https://earthsystemmodeling.org/docs/release/latest/ESMF_refdoc/node3.html
# ESMF: generate interpolation weights between two grids

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print the usage message and exit]' \
  '(-s --source)'{-s,--source}'[source grid file name]:source grid file:_files' \
  '(-d --destination)'{-d,--destination}'[destination grid file name]:destination grid file:_files' \
  '(-w --weight)'{-w,--weight}'[output regridding weight file name]:weight file:_files' \
  '(-m --method)'{-m,--method}'[interpolation method]:method:(bilinear patch nearestdtos neareststod conserve conserve2nd)' \
  '(-p --pole)'{-p,--pole}'[pole extrapolation strategy]:pole:(none all teeth 1 2)' \
  '(-l --line_type)'{-l,--line_type}'[path type on the sphere]:line type:(cartesian greatcircle)' \
  '--norm_type[normalization type for conservative weights]:norm:(dstarea fracarea)' \
  '--extrap_method[unmapped point extrapolation method]:extrap:(none neareststod nearestidavg nearestd creep creepnrstd)' \
  '--extrap_num_src_pnts[source points for nearestidavg]:N' \
  '--extrap_dist_exponent[distance exponent for nearestidavg]:P' \
  '--extrap_num_levels[fill levels for creep extrapolation]:L' \
  '(-i --ignore_unmapped)'{-i,--ignore_unmapped}'[ignore unmapped destination points]' \
  '--ignore_degenerate[ignore degenerate cells in input grids]' \
  '--src_type[source grid file type]:type:(SCRIP ESMFMESH UGRID CFGRID GRIDSPEC MOSAIC TILE)' \
  '--dst_type[destination grid file type]:type:(SCRIP ESMFMESH UGRID CFGRID GRIDSPEC MOSAIC TILE)' \
  '-t[file type for both source and destination grids]:type:(SCRIP ESMFMESH UGRID CFGRID GRIDSPEC MOSAIC TILE)' \
  '-r[both source and destination grids are regional]' \
  '--src_regional[source grid is regional]' \
  '--dst_regional[destination grid is regional]' \
  '--64bit_offset[create NetCDF 64-bit offset format weight file]' \
  '--netcdf4[create NetCDF4 format weight file]' \
  '--src_missingvalue[source data variable name for mask generation]:var_name' \
  '--dst_missingvalue[destination data variable name for mask generation]:var_name' \
  '--src_coordinates[source longitude,latitude variable names]:lon,lat' \
  '--dst_coordinates[destination longitude,latitude variable names]:lon,lat' \
  '--tilefile_path[alternative file path for tile files]:path:_files -/' \
  '--src_loc[source regridding location]:loc:(center corner)' \
  '--dst_loc[destination regridding location]:loc:(center corner)' \
  '--user_areas[use provided cell areas for conservation]' \
  '--weight_only[output weights and indices only]' \
  '--check[check generated weights on an analytic field]' \
  '--checkFlag[enable more expensive extra error checking]' \
  '--no_log[turn off the ESMF log files]' \
  '--version[print ESMF version and license information and exit]' \
  '-V[print ESMF version number and exit]' && ret=0

return ret
