#compdef alacritty-msg

# Zsh completion for alacritty msg - send IPC messages to Alacritty

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create-window:create a new window in the same Alacritty process'
  'config:update the Alacritty configuration'
)

_arguments -s -S \
  '1:command:->command' \
  '(-s --socket)'{-s,--socket}'[IPC socket connection path override]:socket:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'alacritty msg command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (create-window)
        _arguments -s -S \
          '--working-directory=[start the shell in the specified directory]:directory:_files -/' \
          '--hold[remain open after child process exits]' \
          '(-T --title)'{-T,--title}'[defines the window title]:title' \
          '--class=[defines window class/app_id]:class' \
          '(-e --command)'{-e,--command}'[command and args to execute]:command:_command_names -e' && ret=0
        ;;
      (config)
        _arguments -s -S \
          '(-w --window-id)'{-w,--window-id}'[target window ID]:window ID' \
          '--reset[reset the configuration to default]' \
          '*:config options (key=value)' && ret=0
        ;;
    esac
    ;;
esac

return ret
