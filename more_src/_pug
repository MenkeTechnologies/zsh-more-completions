#compdef pug

# Zsh completion for pug - terminal file manager/viewer

_arguments -s -S \
  '(-w --workdir)'{-w,--workdir}'[starting directory]:dir:_directories' \
  '(-s --selection-path)'{-s,--selection-path}'[file to write selected paths to]:file:_files' \
  '--no-hidden[do not show hidden files]' \
  '(-d --disable-preview)'{-d,--disable-preview}'[disable file preview panel]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:path:_files' && return 0
