#compdef vcd2fst
# Documentation: https://verilator.org/guide/latest/
# Convert VCD dumpfiles to FST

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help screen]' \
  '(-v --vcdname)'{-v+,--vcdname=}'[specify VCD/FSDB/VPD/WLF input filename]:file:_files -g "*.vcd"' \
  '(-f --fstname)'{-f+,--fstname=}'[specify FST output filename]:file:_files -g "*.fst"' \
  '(-4 --fourpack)'{-4,--fourpack}'[use LZ4 for value change data (default)]' \
  '(-F --fastpack)'{-F,--fastpack}'[use fastlz instead of LZ4]' \
  '(-Z --zlibpack)'{-Z,--zlibpack}'[use zlib instead of LZ4]' \
  '(-c --compress)'{-c,--compress}'[run entire file through gzip on close]' \
  '(-p --parallel)'{-p,--parallel}'[enable parallel mode with worker thread]' \
  '*:VCD file:_files -g "*.vcd"' && ret=0

return ret
