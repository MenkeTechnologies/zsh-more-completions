#compdef wsta

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-I[print headers in output]' \
  '-H[add a custom header]:header:' \
  '-p[set a profile]:profile:' \
  '-P[print ping/pong frames]' \
  '-b[send binary frames from stdin]' \
  '-e[echo outgoing frames to stdout]' \
  '--follow-redirect[follow HTTP redirects]' \
  '--login-url[URL to login to before connecting]:url:' \
  '-l[login credentials]:user\:pass:' \
  '--frame[print frames as they arrive]' \
  '--ping[set ping interval in seconds]:seconds:' \
  '*:websocket url:' && ret=0

return ret
