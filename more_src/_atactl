#compdef atactl
# Documentation: man atactl(8)
# Source: netbsd/src sbin/atactl — ATA (IDE) device and bus control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:device:_default' \
    '2::command:(identify idle standby sleep setidle setstandby checkpower apm smart security reset)' \
    '*::arg:_default' \
    && ret=0

return ret
