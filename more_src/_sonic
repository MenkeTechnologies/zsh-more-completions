#compdef sonic
# Documentation: https://github.com/valeriansaliou/sonic
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: sonic is configured almost entirely via its .cfg file; only `-c` is
# documented for CLI use.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[configuration file]:config:_files -g "*.cfg"' && ret=0

return ret
