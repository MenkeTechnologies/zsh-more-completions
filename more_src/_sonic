#compdef sonic

# Zsh completion for Sonic - fast, lightweight search backend

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[configuration file]:config:_files -g "*.cfg"' \
  '--config=[configuration file]:config:_files -g "*.cfg"' && ret=0

return ret
