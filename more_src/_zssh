#compdef zssh

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-1[force SSH protocol version 1]' \
  '-2[force SSH protocol version 2]' \
  '-4[force IPv4 addresses only]' \
  '-6[force IPv6 addresses only]' \
  '-A[enable SSH agent forwarding]' \
  '-C[enable compression]' \
  '-f[request SSH to go to background]' \
  '-g[allow remote hosts to connect to local forwarded ports]' \
  '-N[do not execute a remote command]' \
  '-q[quiet mode]' \
  '-s[request invocation of a subsystem]' \
  '-T[disable pseudo-terminal allocation]' \
  '-t[force pseudo-terminal allocation]' \
  '-v[verbose mode]' \
  '-X[enable X11 forwarding]' \
  '-x[disable X11 forwarding]' \
  '-b+[bind address]:bind address:_hosts' \
  '-c+[select encryption cipher]:cipher' \
  '-D+[dynamic port forwarding]:port' \
  '-e+[set escape character]:character' \
  '-F+[config file]:config file:_files' \
  '-i+[identity file]:identity file:_files' \
  '-l+[login name]:login name:_users' \
  '-L+[local port forwarding]:forwarding spec' \
  '-m+[MAC algorithm]:algorithm' \
  '-o+[SSH option]:option' \
  '-p+[port]:port' \
  '-R+[remote port forwarding]:forwarding spec' \
  '*:host:_hosts' && ret=0

return ret
