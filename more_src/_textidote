#compdef textidote
# Documentation: https://man.archlinux.org/search?q=textidote
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--check+[language]:l:(en en_CA en_US en_UK fr de es nl pt pl)' \
  '--clean[remove markup before checking]' \
  '--detex[detex output]' \
  '--dict+[user dictionary]:file:_files' \
  '--encoding+[input encoding]:enc:(UTF-8 ISO-8859-1)' \
  '--firstlang+[first language]:l:' \
  '--ignore+[rules to ignore csv]:rules:' \
  '--languagemodel+[language model dir]:dir:_files -/' \
  '--map+[print line mapping]:file:_files' \
  '--name+[project name]:name:' \
  '--no-color[no color output]' \
  '--no-config[no config file]' \
  '--output+[output format]:fmt:(html json plain singleline tsv)' \
  '--quiet[quiet mode]' \
  '--read-all[read all files]' \
  '--remove+[remove env names csv]:envs:' \
  '--remove-macros+[remove macros csv]:macros:' \
  '--replace+[replacement file]:file:_files' \
  '--single-file[treat as single file]' \
  '--type+[input type]:t:(tex md)' \
  '*: :_files -g "*.tex *.md *.txt"' && ret=0

return ret
