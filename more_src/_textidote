#compdef textidote
# Documentation: https://github.com/sylvainhalle/textidote
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--check+[language for spell/grammar check]:l:(en en_CA en_US en_UK fr de es nl pt pl)' \
  '--clean[remove markup only]' \
  '--dict+[user dictionary file]:file:_files' \
  '--encoding+[input encoding]:enc:(UTF-8 ISO-8859-1)' \
  '--firstlang+[first language for false friends]:l:' \
  '--ignore+[rules to ignore csv]:rules:' \
  '--languagemodel+[n-gram language model dir]:dir:_files -/' \
  '--map+[character position mapping file]:file:_files' \
  '--no-color[disable colored output]' \
  '--no-config[skip .textidote configuration file]' \
  '--output+[output format]:fmt:(html plain singleline clickable)' \
  '--read-all[process entire file (ignore begin/end document)]' \
  '--remove+[remove env names csv]:envs:' \
  '--remove-macros+[remove macros csv]:macros:' \
  '--replace+[replacement file]:file:_files' \
  '--root+[root document path]:path:_files' \
  '--type+[input type]:t:(tex md)' \
  '*: :_files -g "*.tex *.md *.txt"' && ret=0

return ret
