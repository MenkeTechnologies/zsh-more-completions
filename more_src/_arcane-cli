#compdef arcane-cli
# Documentation: https://docs.rs/crate/arcane-cli/latest
# Reference accessed: 2026-05-23
# Verified: docs.rs / lib.rs arcane-cli README (cargo install arcane-cli).

# Zsh completion for arcane-cli - Arcane 2D game engine CLI (binary: arcane)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'new:create a new game project'
  'dev:run with hot-reload'
  'test:run all test files'
  'check:type-check project'
  'add:add a recipe to the project'
  'describe:text description of game state'
  'inspect:query specific state paths'
  'assets:manage game asset packs'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--inspector[start HTTP inspector API]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'arcane command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '--list[list available recipes]' \
          ':recipe:' && ret=0 ;;
      (assets)
        _arguments \
          '1:sub:(list search download)' \
          '*::args:' && ret=0 ;;
      (dev|describe|inspect|new|test|check)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
