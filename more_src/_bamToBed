#compdef bamToBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/bamtobed.html
# convert BAM alignments to BED/BEDPE/BED12 (bedtools bamtobed)

local ret=1

_arguments -s -S \
  '-i[input BAM file]:file:_files' \
  '-bedpe[write BAM alignments in BEDPE format]' \
  '-bed12[write blocked BED (BED12) format]' \
  '-split[report each portion of a split alignment as distinct]' \
  '-splitD[split on N and D CIGAR ops; forces -split]' \
  '-ed[use edit distance (NM) tag for BED score]' \
  '-tag[use another numeric BAM tag for BED score]:tag' \
  '-color[R,G,B color string for BED12]:color' \
  '-cigar[add the CIGAR string as a 7th column]' \
  '-mate1[always report mate one as first BEDPE block]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
