#compdef EvaluateInfoFieldConcordance
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/validation/EvaluateInfoFieldConcordance.java
# GATK: evaluate concordance of an INFO field between an eval and a truth VCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--truth=[truth VCF of passing variants]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  {-eval,--evaluation=}'[eval VCF to assess]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  {-C,--confidence=}'[confidence region interval list]:interval:_files' \
  {-S,--summary=}'[table of summary statistics output]:file:_files' \
  '--eval-info-key=[INFO key from the eval VCF]:key:' \
  '--truth-info-key=[INFO key from the truth VCF]:key:' \
  '--warn-big-differences[warn when info value differences exceed epsilon]' \
  '--epsilon=[difference tolerance]:float:' \
  '*:argument:_files' && ret=0

return ret
