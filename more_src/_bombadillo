#compdef bombadillo
# Documentation: https://man.archlinux.org/search?q=bombadillo
# Reference accessed: 2026-05-16

# Zsh completion for bombadillo - a non-web browser (Gopher, Gemini, Finger, etc.)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-tls[disable TLS]' \
  '*:URL' && ret=0

return ret
