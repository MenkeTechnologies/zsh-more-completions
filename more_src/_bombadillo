#compdef bombadillo
# Documentation: https://bombadillo.colorfield.space/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for bombadillo - a non-web browser (Gopher, Gemini, Finger, etc.)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-tls[disable TLS]' \
  '*:URL' && ret=0

return ret
