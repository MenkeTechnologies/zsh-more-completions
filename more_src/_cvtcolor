#compdef cvtcolor
# Documentation: https://www.libpng.org/pub/png/libpng-manual.txt
# Source: glennrp/libpng contrib/tools/cvtcolor.c — convert linear/sRGB RGB or grey colour components (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(-sRGB)-linear[treat input as linear-light]' \
    '(-linear)-sRGB[treat input as sRGB]' \
    '(-color)-gray[treat input as grayscale]' \
    '(-gray)-color[treat input as RGB colour]' \
    '*:component value (1-4 values):_default' \
    && ret=0

return ret
