#compdef validateManifest
# Documentation: https://github.com/ucscGenomeBrowser/kent/blob/master/src/hg/encode3/validateManifest/validateManifest.c
# Validates the ENCODE3 manifest.txt file; calls validateFiles on each file

local ret=1

_arguments -s -S \
  '-dir=[working directory, defaults to the current directory]:dir:_files -/' \
  '-encValData=[encValData dir relative to workingDir, defaults to encValData]:dir:_files -/' \
  '-help[display usage information]' && ret=0

return ret
