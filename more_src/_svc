#compdef svc
# Documentation: https://man.archlinux.org/search?q=svc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-u[up - start service]' \
  '-d[down - stop service]' \
  '-o[once - start once, do not restart]' \
  '-p[pause - SIGSTOP]' \
  '-c[continue - SIGCONT]' \
  '-h[hangup - SIGHUP]' \
  '-a[alarm - SIGALRM]' \
  '-i[interrupt - SIGINT]' \
  '-q[quit - SIGQUIT]' \
  '-1[USR1]' \
  '-2[USR2]' \
  '-t[terminate - SIGTERM]' \
  '-k[kill - SIGKILL]' \
  '-x[exit supervisor]' \
  '*:service dir:_files -/' && ret=0

return ret
