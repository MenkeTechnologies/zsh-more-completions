#compdef seek
# Documentation: https://github.com/dualeai/seek
# Reference accessed: 2026-05-22
# Verified: cmd/seek/main.go flag package.

# Zsh completion for seek - fast code search CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--version[print version and exit]' \
  '(-v --verbose)'{-v,--verbose}'[enable debug logging]' \
  '(-n --limit)'{-n,--limit}'[max files to display]:n:' \
  '--limit[max files to display]:n:' \
  '(-m --max-matches)'{-m,--max-matches}'[max matches per file]:n:' \
  '--max-matches[max matches per file]:n:' \
  '*:pattern:' && ret=0

return ret
