#compdef bitkey bitkeyctl bitkey-cli
# _bitkey — Block Bitkey CLI for the Block Inc Bitkey hardware-wallet ecosystem command-line tool managing fingerprint enrollment recovery firmware operations key sets multisig device pairing PSBT operations (block team, Rust); clap
# upstream: https://github.com/proto-at-block/bitkey

_bitkey() {
    local -a sub=(
        'pair:pair with hardware device'
        'unpair:unpair device'
        'list:list paired devices'
        'fingerprint:enroll or test fingerprint'
        'fwup:firmware update'
        'metadata:show metadata'
        'sign:sign PSBT'
        'address:show address'
        'recovery:recovery operations'
        'multisig:multisig operations'
        'keypair:keypair operations'
        'transport:transport operations'
        'mock:mock device for testing'
        'serial:open serial console'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--device-id=+[id]:str:' \
        '--testnet[use testnet]' \
        '--mainnet[use mainnet]' \
        '--no-color[no color]' \
        '--log-level=+[level]:l:(off error warn info debug trace)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bitkey subcommand' sub ;;
        args)
            case $words[1] in
                fwup) _arguments \
                    '-f+[firmware file]:file:_files -g "*.signed *.bin *.zip"' \
                    '--firmware=+[firmware file]:file:_files -g "*.signed *.bin *.zip"' \
                    '--target=+[t]:t:(application bootloader recovery)' \
                    '--force[force update]' ;;
                sign) _arguments \
                    '--psbt=+[file]:file:_files -g "*.psbt"' \
                    '--key-set=+[name]:str:' \
                    '*:psbt file:_files -g "*.psbt"' ;;
                fingerprint) _arguments \
                    '1:action:(enroll list delete test cancel)' \
                    '--index=+[N]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_bitkey "$@"
