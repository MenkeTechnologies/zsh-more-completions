#compdef qmgr

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-a[abort qmgr on any syntax error]' \
  '-c+[command]:cmd:' \
  '-e[echo commands to stdout]' \
  '-n[no commands - syntax check only]' \
  '-z[do not write to stderr]' \
  '*:server:_hosts' && ret=0

return ret
