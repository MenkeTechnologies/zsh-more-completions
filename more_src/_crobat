#compdef crobat
# _crobat — Cgboal crobat Rapid7 Sonar reverse-DNS and forward-DNS lookup CLI for security recon (cgboal team, Go); standard flag package
# upstream: https://github.com/Cgboal/SonarSearch

_crobat() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-s+[server url]:url:_urls' \
        '--server=+[server url]:url:_urls' \
        '-d+[target domain]:host:_hosts' \
        '--domain=+[target domain]:host:_hosts' \
        '-t+[search type]:t:(subdomains tld reverse all current)' \
        '--type=+[search type]:t:(subdomains tld reverse all current)' \
        '-f+[input file]:file:_files' \
        '--file=+[input file]:file:_files' \
        '-i[reverse IP lookup]' \
        '--ip[reverse IP lookup]' \
        '-c+[CIDR]:str:' \
        '--cidr=+[CIDR]:str:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-w+[wildcards csv]:str:' \
        '--wildcards=+[wildcards csv]:str:' \
        '-r[raw output]' \
        '--raw[raw output]' \
        '-q[quiet]' \
        '--quiet[quiet]'
}

_crobat "$@"
