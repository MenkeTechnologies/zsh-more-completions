#compdef canonicalheader durationcheck errchkjson errname exhaustive gochecknoglobals intrange ireturn spancheck
# Documentation: upstream READMEs at github.com/{lasiar/canonicalheader,charithe/durationcheck,breml/errchkjson,Antonboom/errname,nishanths/exhaustive,leighmcculloch/gochecknoglobals,ckaznocha/intrange,butuzov/ireturn,jjti/go-spancheck}
# Reference accessed: 2026-05-30
# Continuation of Go linter sweep R23 — 9 more single-purpose linters
# wrapping the analysis/passes framework. Most are also runnable via
# `go vet -vettool=$(which TOOL) PKG/...` and through golangci-lint.

local curcontext="$curcontext" state line ret=1

case $service in

  canonicalheader)
    # lasiar/canonicalheader — checks HTTP header names use canonical
    # capitalization (e.g. Test-HEader → Test-Header) on http.Header
    # methods Get/Set/Add/Del/Values.
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  durationcheck)
    # charithe/durationcheck — detect erroneous time.Duration multiplications.
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  errchkjson)
    # breml/errchkjson — analyze types passed to json.Marshal for
    # safe/unsafe/forbidden classifications.
    _arguments -s -S \
      '-omit-safe[disable checking for safe error returns]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  errname)
    # Antonboom/errname — enforce sentinel ErrXxx/errXxx + ErrorType
    # naming conventions.
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  exhaustive)
    # nishanths/exhaustive — switch + map exhaustiveness checker for
    # enum-like constant groups.
    _arguments -s -S \
      '-check=[what to check (comma-separated)]:checks:(switch map switch,map)' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  gochecknoglobals)
    # leighmcculloch/gochecknoglobals — flag global variables.
    # Smart-ignores: err vars, regex Compile, embedded files, _.
    _arguments -s -S \
      '-test=[analyze test files (default true)]:bool:(true false)' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  intrange)
    # ckaznocha/intrange — suggest Go 1.22 integer-range syntax for
    # `for i := 0; i < n; i++ {}` patterns.
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  ireturn)
    # butuzov/ireturn — enforce "accept interfaces, return concrete types".
    # Shorthand keywords: empty, anon, error, stdlib, generic.
    local -a _interfaces
    _interfaces=(empty anon error stdlib generic)
    _arguments -s -S \
      '--accept=[allowlist interfaces (comma-separated)]:interfaces:_values -s , "interface" $_interfaces' \
      '--reject=[blocklist interfaces (comma-separated)]:interfaces:_values -s , "interface" $_interfaces' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  spancheck)
    # jjti/go-spancheck — OpenTelemetry/OpenCensus span linter.
    local -a _checks
    _checks=(end set-status record-error)
    _arguments -s -S \
      '-checks=[span checks to run (comma-separated)]:checks:_values -s , "check" $_checks' \
      '-extra-start-span-signatures=[additional span-creation function signatures]:signatures:' \
      '-ignore-check-signatures=[function signatures to skip]:signatures:' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

esac

return ret
