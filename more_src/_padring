#compdef padring
# Documentation: https://github.com/YosysHQ/padring
# A padring generator for ASICs

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '(-L --lef)'{-L,--lef}'[LEF file describing the ASIC cells]:lef:_files -g "*.lef"' \
  '--svg[filename of SVG to generate]:svg:_files -g "*.svg"' \
  '--def[filename of DEF to generate]:def:_files -g "*.def"' \
  '--filler[filler cell prefix used when searching for filler cells]:prefix:' \
  '(-o --output)'{-o,--output}'[filename of GDS2 to generate]:gds2:_files' \
  '*:config:_files' && ret=0

return ret
