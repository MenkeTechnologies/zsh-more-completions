#compdef sesh

local curcontext="$curcontext" state line ret=1

_sesh_commands() {
  local -a commands=(
    'clone:clone a git repo and connect'
    'connect:connect to a session'
    'list:list sessions'
    'root:show root directory'
  )
  _describe -t commands 'sesh command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:_sesh_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      connect)
        _arguments -s -S \
          '(-c --command)'{-c,--command}'[run command after connecting]:command' \
          '*:session name' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[show configured sessions]' \
          '(-H --hide-attached)'{-H,--hide-attached}'[hide attached sessions]' \
          '(-i --icons)'{-i,--icons}'[show icons]' \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '(-t --tmux)'{-t,--tmux}'[show tmux sessions]' \
          '(-z --zoxide)'{-z,--zoxide}'[show zoxide results]' && ret=0
        ;;
      clone)
        _arguments -s -S \
          '*:repository' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
