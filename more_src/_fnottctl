#compdef fnottctl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dismiss:dismiss the top notification'
  'dismiss-all:dismiss all notifications'
  'actions:list actions for the top notification'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' && ret=0

case $state in
  (command)
    _describe -t commands 'fnottctl command' commands && ret=0
    ;;
esac

return ret
