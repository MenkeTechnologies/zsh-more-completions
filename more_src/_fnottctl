#compdef fnottctl
# Documentation: https://codeberg.org/dnkl/fnott
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dismiss:dismiss top notification or specific id'
  'dismiss-all:dismiss all notifications'
  'list:list active notifications'
  'pause:pause notifications'
  'unpause:resume notifications'
  'status:show daemon status'
  'actions:list actions for the top notification'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' && ret=0

case $state in
  (command)
    _describe -t commands 'fnottctl command' commands && ret=0
    ;;
esac

return ret
