#compdef sqitch
# Documentation: https://sqitch.org/docs/manual/sqitch/
# Reference accessed: 2026-05-21
# Verified: sqitch(1) OPTIONS and COMMANDS sections.
# Removed: --plan-file, --top-dir, --engine, --registry, --client, --db-name,
# --db-host, --db-port, --db-user (those are per-engine/per-target config,
# not global sqitch options).

# Zsh completion for sqitch (database change management)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:create plan file and script directories'
  'status:show current deployment status'
  'log:search and display change history'
  'add:add a new change'
  'tag:list tags or tag the latest change'
  'rework:rework an existing change'
  'target:manage target databases'
  'deploy:deploy changes to a database'
  'revert:revert changes from a database'
  'verify:verify deployed changes'
  'config:get and set Sqitch options'
  'bundle:bundle project for distribution'
  'checkout:revert and deploy changes for a VCS checkout'
  'engine:manage engine configuration'
  'plan:show the contents of the plan'
  'rebase:revert and redeploy changes'
  'show:show information about changes and tags'
  'upgrade:upgrade the registry'
  'help:display help for a command'
)

_arguments -C \
  '(- *)--help[show list of commands]' \
  '(- *)--version[print version and exit]' \
  '(- *)--man[print introductory documentation]' \
  '(- *)--etc-path[print etc directory path and exit]' \
  '(-C --chdir --cd)'{-C+,--chdir=,--cd=}'[change to directory before performing actions]:directory:_directories' \
  '--no-pager[do not pipe output into a pager]' \
  '--quiet[suppress non-error output]' \
  '*'{-V,--verbose}'[increment verbosity]' \
  '1:command:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t commands 'sqitch command' subcommands && ret=0
    ;;
esac

return ret
