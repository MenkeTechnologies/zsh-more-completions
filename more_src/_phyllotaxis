#compdef phyllotaxis
# Source: cargo binstall phyllotaxis@0.4.0
# Probed via: completions zsh
# Repository: https://github.com/OpenScribbler/phyllotaxis

autoload -U is-at-least

_phyllotaxis() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--resources=[List resource groups, or drill into a specific resource]::RESOURCES:_default' \
'--schemas=[List schemas, or view a specific schema]::SCHEMAS:_default' \
'--callbacks=[List callbacks, or view a specific callback]::CALLBACKS:_default' \
'*--endpoint=[Show endpoint detail\: --endpoint METHOD PATH]:ENDPOINT:_default:ENDPOINT:_default' \
'--related-limit=[Cap the number of related schemas shown in schema detail]:RELATED_LIMIT:_default' \
'--for=[Extract a subtree by JSON Pointer (RFC 6901), e.g. '\''/components/schemas/Pet'\'']:POINTER:_default' \
'--doc=[Named document from config, path, or URL override]:DOC:_default' \
'--add-doc=[Add a document to the library (does not make it active)]:ADD_DOC:_files' \
'--set-doc=[Switch active document by nickname, or add+activate a file path. Writes to the config that owns the nickname; for new file paths, defaults to project config (.phyllotaxis/) if one exists, otherwise user config (~/.config/phyllotaxis/). Use --global to force user config]:SET_DOC:_default' \
'--remove-doc=[Remove a document from the library by nickname]:REMOVE_DOC:_default' \
'--name=[Nickname for --add-doc or --set-doc (auto-derived from filename if omitted)]:NAME:_default' \
'--auth[Show authentication details]' \
'--used-by[Show which endpoints use this schema (use with --schemas NAME)]' \
'(--text)--json[Output in JSON format (default when stdout is piped)]' \
'(--json)--text[Output in text format (default when stdout is a terminal)]' \
'--expand[Recursively inline nested schemas (max depth 5)]' \
'--context[Show related schemas inline after endpoint detail]' \
'--example[Generate a JSON example for the request body or schema]' \
'--unset-doc[Clear the active document setting]' \
'--list-docs[Show all configured documents]' \
'--global[Force --add-doc / --set-doc to write to user config (~/.config/phyllotaxis/) instead of project config (.phyllotaxis/)]' \
'--refresh[Force re-download of remote URL specs (bypasses cache)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::document -- OpenAPI document path or URL (overrides config/env/auto-detect):_default' \
":: :_phyllotaxis_commands" \
"*::: :->phyllotaxis" \
&& ret=0
    case $state in
    (phyllotaxis)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:phyllotaxis-command-$line[2]:"
        case $line[2] in
            (search)
_arguments "${_arguments_options[@]}" : \
'--limit=[Limit results per category]:LIMIT:_default' \
'--related-limit=[Cap the number of related schemas shown in schema detail]:RELATED_LIMIT:_default' \
'(--text)--json[Output in JSON format (default when stdout is piped)]' \
'(--json)--text[Output in text format (default when stdout is a terminal)]' \
'--expand[Recursively inline nested schemas (max depth 5)]' \
'-h[Print help]' \
'--help[Print help]' \
':term -- Search term:_default' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'--doc-path=[Document file path — skips interactive prompt when provided]:DOC_PATH:_files' \
'--related-limit=[Cap the number of related schemas shown in schema detail]:RELATED_LIMIT:_default' \
'(--text)--json[Output in JSON format (default when stdout is piped)]' \
'(--json)--text[Output in text format (default when stdout is a terminal)]' \
'--expand[Recursively inline nested schemas (max depth 5)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--related-limit=[Cap the number of related schemas shown in schema detail]:RELATED_LIMIT:_default' \
'(--text)--json[Output in JSON format (default when stdout is piped)]' \
'(--json)--text[Output in text format (default when stdout is a terminal)]' \
'--expand[Recursively inline nested schemas (max depth 5)]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_phyllotaxis__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:phyllotaxis-help-command-$line[1]:"
        case $line[1] in
            (search)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_phyllotaxis_commands] )) ||
_phyllotaxis_commands() {
    local commands; commands=(
'search:Search across all endpoints and schemas' \
'init:Interactive setup — detect document and write config' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'phyllotaxis commands' commands "$@"
}
(( $+functions[_phyllotaxis__completions_commands] )) ||
_phyllotaxis__completions_commands() {
    local commands; commands=()
    _describe -t commands 'phyllotaxis completions commands' commands "$@"
}
(( $+functions[_phyllotaxis__help_commands] )) ||
_phyllotaxis__help_commands() {
    local commands; commands=(
'search:Search across all endpoints and schemas' \
'init:Interactive setup — detect document and write config' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'phyllotaxis help commands' commands "$@"
}
(( $+functions[_phyllotaxis__help__completions_commands] )) ||
_phyllotaxis__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'phyllotaxis help completions commands' commands "$@"
}
(( $+functions[_phyllotaxis__help__help_commands] )) ||
_phyllotaxis__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'phyllotaxis help help commands' commands "$@"
}
(( $+functions[_phyllotaxis__help__init_commands] )) ||
_phyllotaxis__help__init_commands() {
    local commands; commands=()
    _describe -t commands 'phyllotaxis help init commands' commands "$@"
}
(( $+functions[_phyllotaxis__help__search_commands] )) ||
_phyllotaxis__help__search_commands() {
    local commands; commands=()
    _describe -t commands 'phyllotaxis help search commands' commands "$@"
}
(( $+functions[_phyllotaxis__init_commands] )) ||
_phyllotaxis__init_commands() {
    local commands; commands=()
    _describe -t commands 'phyllotaxis init commands' commands "$@"
}
(( $+functions[_phyllotaxis__search_commands] )) ||
_phyllotaxis__search_commands() {
    local commands; commands=()
    _describe -t commands 'phyllotaxis search commands' commands "$@"
}

if [ "$funcstack[1]" = "_phyllotaxis" ]; then
    _phyllotaxis "$@"
else
    compdef _phyllotaxis phyllotaxis
fi
