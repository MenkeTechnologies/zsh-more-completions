#compdef donpapi
# Documentation: https://github.com/login-securite/DonPAPI
# Dump DPAPI secrets remotely from Active Directory hosts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-v[verbosity level]' \
  '(-o --output-directory)'{-o,--output-directory}'+[output directory]:dir:_files -/' \
  '--keep-collecting[rerun attack after X seconds]:seconds:' \
  '--threads[number of threads]:number:' \
  '--no-config[skip loading config file]' \
  '-t+[target IPs, ranges, CIDRs, hostnames, files or ALL]:target:' \
  '-d+[domain name]:domain:' \
  '-u+[username]:user:' \
  '-p+[password]:password:' \
  '-H+[NTLM hashes LMHASH:NTHASH]:hashes:' \
  '--no-pass[do not prompt for password]' \
  '-k[use Kerberos authentication]' \
  '--aesKey+[AES key for Kerberos]:hex key:' \
  '--laps+[use LAPS for local admin password]:account:' \
  '--dc-ip+[domain controller IP]:ip:' \
  '-r+[recover file path]:path:_files' \
  '-c+[collectors]:collectors:(Chromium Certificates CredMan Files Firefox MobaXterm MRemoteNG RDCMan SCCM Vaults VNC Wifi All)' \
  '(-nr --no-remoteops)'{-nr,--no-remoteops}'[disable Remote Ops]' \
  '--fetch-pvk[auto-fetch domain backup key]' \
  '--pvkfile+[PVK file path]:file:_files' \
  '--pwdfile+[password file]:file:_files' \
  '--ntfile+[NTLM hash file]:file:_files' \
  '--mkfile+[masterkeys file]:file:_files' \
  '--bind+[HTTP bind address]:address:' \
  '--port+[HTTP port]:port:' \
  '--ssl[use encrypted connection]' \
  '--basic-auth+[basic auth user:password]:auth:' \
  '*:command:(collect gui)' && ret=0

return ret
