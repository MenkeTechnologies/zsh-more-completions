#compdef jdtls
# Documentation: https://github.com/eclipse-jdtls/eclipse.jdt.ls
# jdtls - Eclipse JDT Language Server launcher

local ret=1

_arguments -s -S \
  '--validate-java-version[validate the Java version before starting]' \
  '--no-validate-java-version[skip Java version validation]' \
  '--java-executable=[path to java executable used to start runtime]:file:_files' \
  '*--jvm-arg=[an additional JVM option, use with equal sign]:arg' \
  '-data[absolute path to the workspace data directory]:dir:_files -/' \
  '-configuration[path to the platform configuration directory]:dir:_files -/' && ret=0

return ret
