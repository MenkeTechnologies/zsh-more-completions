#compdef conduwuit
# Documentation: https://github.com/girlbossceo/conduwuit (src/main/clap.rs)
# Reference accessed: 2026-05-29
# conduwuit — high-performance Matrix homeserver (Rust, conduit fork).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-c,--config=}'[TOML configuration file (repeatable)]:file:_files -g "*.toml"' \
  '*'{-O,--option=}'[override config (key=value, repeatable)]:key=value:' \
  '--read-only[stricter read-only maintenance mode]' \
  '--maintenance[run in maintenance mode while refusing connections]' \
  '--console[activate admin command console after startup]' \
  '--execute=[execute console commands automatically after startup]:commands:' \
  '--test=[functional testing mode]:mode:' \
  '--worker-threads=[tokio worker thread count (env TOKIO_WORKER_THREADS)]:n:' \
  '--global-event-interval=[tokio global queue interval (default 192)]:n:' \
  '--kernel-event-interval=[tokio event interval (default 512)]:n:' \
  '--kernel-events-per-tick=[tokio max I/O events per tick (default 512)]:n:' \
  '--worker-histogram-interval=[histogram bucket size (μs, default 25)]:n:' \
  '--worker-histogram-buckets=[histogram bucket count (default 20)]:n:' \
  '--worker-affinity=[toggle worker affinity (default true)]:bool:(true false)' \
  '--gc-on-park[enable memory reclamation when worker idles]' \
  '--gc-muzzy[enable muzzy decay for jemalloc arenas]' && ret=0

return ret
