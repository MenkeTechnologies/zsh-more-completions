#compdef jj

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'abandon:abandon a revision and rebase descendants'
  'absorb:move changes from working copy into mutable ancestors'
  'backout:apply the reverse of revisions'
  'bookmark:manage bookmarks (formerly branches)'
  'branch:manage branches (deprecated, use bookmark)'
  'commit:commit working copy and update its parent'
  'config:manage config'
  'describe:edit revision description'
  'diff:show changes in revision'
  'diffedit:open diff in editor'
  'duplicate:duplicate revisions'
  'edit:start editing revision in working copy'
  'evolog:show how revision has evolved'
  'file:file operations'
  'fix:run fixers on tree of revision'
  'git:Git interop'
  'help:show help'
  'init:create a new repo backed by Git'
  'interdiff:show diff between two diffs'
  'log:show revision history'
  'merge:create new revision merging revisions'
  'move:move changes between revisions (deprecated, use squash)'
  'new:create new working-copy revision'
  'next:move working-copy revision forward'
  'op:operation log management'
  'operation:operation log management'
  'parallelize:parallelize revisions'
  'prev:move working-copy revision backward'
  'rebase:move revisions and descendants to new parent'
  'resolve:resolve merge conflicts'
  'restore:restore paths from another revision'
  'revert:apply reverse of revisions'
  'root:show repo root path'
  'show:show revision details'
  'sign:sign a revision'
  'simplify-parents:simplify ancestors'
  'sparse:manage sparse checkout patterns'
  'split:split a revision in two'
  'squash:move changes from one revision into another'
  'status:show working-copy status'
  'tag:manage tags'
  'undo:undo the last operation'
  'unsign:unsign a revision'
  'untrack:stop tracking files'
  'util:utility commands'
  'version:show version'
  'workspace:manage workspaces'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-R+[repo dir]:dir:_files -/' \
  '*--repository=[repo dir]:dir:_files -/' \
  '*--ignore-working-copy[ignore working copy]' \
  '*--ignore-immutable[ignore immutable]' \
  '*--at-operation=[at operation]:op:' \
  '*--at-op=[at operation]:op:' \
  '*--debug[debug]' \
  '*--color=[color]:c:(always never debug auto)' \
  '*--quiet[quiet]' \
  '*--no-pager[no pager]' \
  '*--config=[config k=v]:cfg:' \
  '*--config-toml=[config TOML]:cfg:' \
  '*--config-file=[config file]:file:_files -g "*.toml"' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jj command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (log)
        _arguments \
          '(-r --revisions)*'{-r+,--revisions=}'[revset]:rev:' \
          '(-T --template)'{-T+,--template=}'[template]:t:' \
          '(-l --limit)'{-l+,--limit=}'[limit]:n:' \
          '(-n)-n+[limit]:n:' \
          '(--reversed)--reversed[reversed]' \
          '(--no-graph)--no-graph[no graph]' \
          '(--summary -s)'{-s,--summary}'[summary]' \
          '(-p --patch)'{-p,--patch}'[patch output]' \
          '(--stat)--stat[stat output]' \
          '(--types)--types[show types]' \
          '(--name-only)--name-only[name only]' \
          '(--git)--git[git format]' \
          '(--color-words)--color-words[color words]' \
          '(--tool)--tool=[diff tool]:tool:' \
          '(--ignore-all-space)--ignore-all-space[ignore all space]' \
          '(--ignore-space-change)--ignore-space-change[ignore space change]' \
          '(--context)--context=[context lines]:n:' \
          '*: :' && ret=0 ;;
      (diff|show)
        _arguments \
          '(-r --revisions)'{-r+,--revisions=}'[revision]:rev:' \
          '(--from)--from=[from rev]:rev:' \
          '(--to)--to=[to rev]:rev:' \
          '(-T --template)'{-T+,--template=}'[template]:t:' \
          '(--summary -s)'{-s,--summary}'[summary]' \
          '(--stat)--stat[stat]' \
          '(--types)--types[types]' \
          '(--name-only)--name-only[name only]' \
          '(--git)--git[git format]' \
          '(--color-words)--color-words[color words]' \
          '(--tool)--tool=[diff tool]:tool:' \
          '(--context)--context=[context lines]:n:' \
          '*: :_files' && ret=0 ;;
      (new)
        _arguments \
          '(-r --revisions)*'{-r+,--revisions=}'[parent revisions]:rev:' \
          '(-A --insert-after)*'{-A+,--insert-after=}'[insert after]:rev:' \
          '(-B --insert-before)*'{-B+,--insert-before=}'[insert before]:rev:' \
          '(-m --message)'{-m+,--message=}'[message]:m:' \
          '(--no-edit)--no-edit[no edit]' \
          '*: :' && ret=0 ;;
      (commit)
        _arguments \
          '(-m --message)'{-m+,--message=}'[message]:m:' \
          '(-i --interactive)'{-i,--interactive}'[interactive]' \
          '(--tool)--tool=[diff tool]:tool:' \
          '(--reset-author)--reset-author[reset author]' \
          '*: :_files' && ret=0 ;;
      (describe)
        _arguments \
          '(-r --revisions)'{-r+,--revisions=}'[revision]:rev:' \
          '(-m --message)*'{-m+,--message=}'[message]:m:' \
          '(--stdin)--stdin[read from stdin]' \
          '(--no-edit)--no-edit[no edit]' \
          '(--reset-author)--reset-author[reset author]' \
          '*: :' && ret=0 ;;
      (status)
        _arguments \
          '*: :_files' && ret=0 ;;
      (squash)
        _arguments \
          '(-r --revision)'{-r+,--revision=}'[revision]:rev:' \
          '(--from)--from=[from]:rev:' \
          '(--to --into)'{--to=,--into=}'[to]:rev:' \
          '(-m --message)'{-m+,--message=}'[message]:m:' \
          '(-i --interactive)'{-i,--interactive}'[interactive]' \
          '(--tool)--tool=[diff tool]:tool:' \
          '(-u --use-destination-message)'{-u,--use-destination-message}'[use dest msg]' \
          '(--keep-emptied)--keep-emptied[keep empty source]' \
          '*: :_files' && ret=0 ;;
      (rebase)
        _arguments \
          '(-r --revisions)*'{-r+,--revisions=}'[revisions]:rev:' \
          '(-s --source)'{-s+,--source=}'[source]:rev:' \
          '(-b --branch)*'{-b+,--branch=}'[branch]:rev:' \
          '(-d --destination)*'{-d+,--destination=}'[destination]:rev:' \
          '(-A --insert-after)*'{-A+,--insert-after=}'[insert after]:rev:' \
          '(-B --insert-before)*'{-B+,--insert-before=}'[insert before]:rev:' \
          '(--skip-emptied)--skip-emptied[skip emptied]' \
          '(--keep-divergent)--keep-divergent[keep divergent]' \
          '*: :' && ret=0 ;;
      (abandon)
        _arguments \
          '(-r --revisions)*'{-r+,--revisions=}'[revisions]:rev:' \
          '(--retain-bookmarks)--retain-bookmarks[retain bookmarks]' \
          '(--restore-descendants)--restore-descendants[restore descendants]' \
          '*: :' && ret=0 ;;
      (bookmark|branch)
        _arguments \
          '1:subcommand:(create delete forget list move rename set track untrack)' \
          '*: :' && ret=0 ;;
      (git)
        _arguments \
          '1:subcommand:(clone export fetch import init push remote)' \
          '*: :' && ret=0 ;;
      (op|operation)
        _arguments \
          '1:subcommand:(abandon log restore show undo diff)' \
          '*: :' && ret=0 ;;
      (workspace)
        _arguments \
          '1:subcommand:(add forget list rename root update-stale)' \
          '*: :' && ret=0 ;;
      (sparse)
        _arguments \
          '1:subcommand:(list set reset edit)' \
          '*: :' && ret=0 ;;
      (file)
        _arguments \
          '1:subcommand:(annotate chmod list show track untrack)' \
          '*: :_files' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(edit get list path set unset)' \
          '*: :' && ret=0 ;;
      (util)
        _arguments \
          '1:subcommand:(completion config-schema gc mangen markdown-help)' \
          '*: :' && ret=0 ;;
      (init)
        _arguments \
          '(--git)--git[backed by Git]' \
          '(--git-repo)--git-repo=[existing Git repo]:dir:_files -/' \
          '(--colocate)--colocate[colocate with Git]' \
          '*: :_files -/' && ret=0 ;;
      (tag)
        _arguments \
          '1:subcommand:(list)' \
          '*: :' && ret=0 ;;
      (sign|unsign)
        _arguments \
          '(-r --revisions)*'{-r+,--revisions=}'[revisions]:rev:' \
          '(--key)--key=[signing key]:k:' \
          '*: :' && ret=0 ;;
      (split)
        _arguments \
          '(-r --revision)'{-r+,--revision=}'[revision]:rev:' \
          '(-i --interactive)'{-i,--interactive}'[interactive]' \
          '(-p --parallel)'{-p,--parallel}'[parallel splits]' \
          '(--tool)--tool=[diff tool]:tool:' \
          '(-m --message)*'{-m+,--message=}'[message]:m:' \
          '*: :_files' && ret=0 ;;
      (resolve)
        _arguments \
          '(-r --revision)'{-r+,--revision=}'[revision]:rev:' \
          '(--tool)--tool=[merge tool]:tool:' \
          '(--list)--list[list conflicts]' \
          '(--quiet)--quiet[quiet]' \
          '*: :_files' && ret=0 ;;
      (restore)
        _arguments \
          '(--from)--from=[from rev]:rev:' \
          '(--to)--to=[to rev]:rev:' \
          '(-c --changes-in)'{-c+,--changes-in=}'[changes in rev]:rev:' \
          '(--restore-descendants)--restore-descendants[restore descendants]' \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
