#compdef phpactor
# _phpactor — Daniel Leech Phpactor PHP language server CLI (phpactor team, PHP); symfony console
# upstream: https://github.com/phpactor/phpactor

_phpactor() {
    local -a sub=(
        'analyse:run inspections on files'
        'blackfire:profile via blackfire'
        'cache:clear:clear cache'
        'class:copy:copy class to new namespace'
        'class:move:move class'
        'class:new:generate new class'
        'class:reflect:reflect class info'
        'class:search:search for classes'
        'class:transform:apply transformations'
        'class:inflect:inflect class members'
        'cli:dump-rpc:dump rpc command'
        'config:dump:dump configuration'
        'config:initialize:init config file'
        'config:show:show config'
        'docblock:fix:fix docblocks'
        'extension:install:install extension'
        'extension:list:list extensions'
        'extension:remove:remove extension'
        'extension:update:update extension'
        'file:offset:get offset for cursor pos'
        'index:build:build index'
        'index:clean:clean index'
        'index:query:query the index'
        'language-server:start lsp'
        'navigator:targets:list navigator targets'
        'references:find:find references'
        'rpc:invoke RPC server'
        'self-update:self update'
        'service:list:list services'
        'service:run:run service'
        'status:show status'
        'worse:dump-class:dump class'
        'completion:dump completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--working-dir=+[dir]:dir:_files -/' \
        '-d+[dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--vvv[max verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'phpactor subcommand' sub ;;
        args)
            case $words[1] in
                language-server) _arguments \
                    '--tcp-server=+[host:port]:str:' \
                    '--workspace=+[workspace]:dir:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_phpactor "$@"
