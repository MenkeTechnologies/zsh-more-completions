#compdef hwloc-ls hwloc-info hwloc-bind hwloc-calc hwloc-distrib

# Zsh completion for hwloc - hardware locality utilities

local cmd=${words[1]:t}

case $cmd in
  hwloc-ls|lstopo|lstopo-no-graphics)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '--of[output format]:format:(console ascii tikz fig png pdf svg xml synthetic)' \
      '--output-format[output format]:format:(console ascii tikz fig png pdf svg xml synthetic)' \
      '(-o --output)'{-o,--output}'[write to file]:file:_files' \
      '--input[read topology from]:source:_files' \
      '-i[read topology from]:source:_files' \
      '--if[input format]:format:(xml synthetic fsroot cpuid)' \
      '--input-format[input format]:format:(xml synthetic fsroot cpuid)' \
      '--whole-system[do not consider admin limitations]' \
      '--no-io[do not show I/O devices]' \
      '--no-bridges[do not show bridge objects]' \
      '--whole-io[show all I/O devices]' \
      '--merge[merge identical objects]' \
      '--no-factorize[do not factorize identical objects]' \
      '--restrict[restrict topology]:cpuset' \
      '--no-legend[remove legend]' \
      '--append-legend[append text to legend]:text' \
      '--fontsize[set font size]:size' \
      '--gridsize[set gridsize]:size' \
      '--no-text[do not display text in objects]' \
      '--only[only show objects of type]:type:(Machine Package Core PU L1Cache L2Cache L3Cache NUMANode)' \
      '--verbose[be verbose]' \
      '--logical[use logical indexes]' \
      '--physical[use physical indexes]' \
      '*:output file:_files'
    ;;
  hwloc-info)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '--objects[show the topology in verbose mode]' \
      '--topology[show topology info]' \
      '--support[show supported features]' \
      '--input[read topology from]:source:_files' \
      '-i[read topology from]:source:_files' \
      '--restrict[restrict topology]:cpuset' \
      '--no-io[do not show I/O devices]' \
      '--whole-system[do not consider admin limitations]' \
      '*:object type:' \
    ;;
  hwloc-bind)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '--cpubind[use cpubind]' \
      '--membind[use membind]' \
      '--mempolicy[set memory binding policy]:policy:(default firsttouch bind interleave)' \
      '--get[get current binding]' \
      '--nodeset[display as nodeset]' \
      '--physical[use physical indexes]' \
      '--logical[use logical indexes]' \
      '--single[bind on a single CPU]' \
      '--strict[use strict binding]' \
      '--pid[operate on pid]:pid' \
      '-p[operate on pid]:pid' \
      '--whole-system[do not consider admin limitations]' \
      '*:: :_normal'
    ;;
  hwloc-calc)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '--number-of[output number of objects]:type' \
      '--intersect[report intersection]:type' \
      '--hierarchical[output as hierarchy]:types' \
      '--largest[output largest containing object]' \
      '--single[singlify output]' \
      '--restrict[restrict topology]:cpuset' \
      '--whole-system[do not consider admin limitations]' \
      '--physical[use physical indexes]' \
      '--logical[use logical indexes]' \
      '--input[read topology from]:source:_files' \
      '-i[read topology from]:source:_files' \
      '*:object location'
    ;;
esac
