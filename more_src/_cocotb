#compdef cocotb-config
# Documentation: https://man.archlinux.org/search?q=cocotb-config
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--prefix[print the package-prefix]' \
  '--share[print the package-share directory]' \
  '--makefiles[print the makefiles directory]' \
  '--python-bin[print the Python binary cocotb was installed with]' \
  '--help-vars[print help about make variables]' \
  '--libpython[print the path to libpython]' \
  '--lib-dir[print the library directory]' \
  '--lib-name=[print library name for simulator]:simulator:(icarus modelsim questa xcelium vcs riviera activehdl verilator ghdl nvc cvc)' \
  '--lib-name-path=[print library path for simulator]:simulator:(icarus modelsim questa xcelium vcs riviera activehdl verilator ghdl nvc cvc)' && ret=0

return ret
