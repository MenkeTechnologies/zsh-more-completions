#compdef railway-cli2 railway2
# _railway-cli2 — Railway railway-cli2 CLI command-line frontend wrapping the Railway open-source command-line tool for the Railway platform-as-a-service for instantly deploying apps and databases from your terminal connect-instantly-bring-it-up-running Railway-CLI deploy without Docker apps databases volumes services environments login logout whoami init link unlink open status up down deploy run shell logs help config volume domain redeploy add database service variable starship service-name shell project clone fork (Railway team Jake Cooper, Rust); clap
# upstream: https://railway.app/

_railway-cli2() {
    local -a sub=(
        'add:add service or DB'
        'completion:generate shell completion'
        'connect:connect to a database'
        'deploy:deploy a project'
        'docs:open Railway docs'
        'domain:domain operations'
        'down:teardown deployment'
        'environment:environment operations'
        'help:show help'
        'init:initialize a project'
        'link:link to a project'
        'list:list project services'
        'login:authenticate'
        'logout:revoke session'
        'logs:show service logs'
        'open:open project in browser'
        'redeploy:redeploy a service'
        'remove:remove a service'
        'run:run a command'
        'service:service operations'
        'shell:shell into service'
        'ssh:SSH into a deployment'
        'starship:starship config'
        'status:show project status'
        'unlink:unlink a project'
        'up:deploy current dir'
        'variables:variable operations'
        'volume:volume operations'
        'whoami:show identity'
        'version:show version'
        'watch:watch deployment'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--json[JSON output]' \
        '-j[JSON output]' \
        '-p+[project]:str:' \
        '--project=+[id]:str:' \
        '-e+[environment]:str:' \
        '--environment=+[name]:str:' \
        '-s+[service]:str:' \
        '--service=+[name]:str:' \
        '--detach[detach]' \
        '-d[detach]' \
        '--ci[CI mode]' \
        '--browserless[no browser open]' \
        '--token=+[token]:str:' \
        '--config=+[file]:file:_files -g "railway.toml *.toml"' \
        '--filter=+[expr]:str:' \
        '--ignored=+[patterns]:str:' \
        '--no-gitignore[no gitignore]' \
        '--variable=+[k=v]:str:' \
        '*--variable=+[k=v]:str:' \
        '--shell-name=+[shell]:str:' \
        '--build-args=+[args]:str:' \
        '--no-tty[no TTY]' \
        '--include-private-network[include private net]' \
        '--no-detach[no detach]' \
        '--root[root dir]' \
        '--region=+[name]:str:' \
        '--all[all services]' \
        '--yes[skip prompts]' \
        '-y[yes]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'railway subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments '*:cmd:_command_names' ;;
                add) _arguments '1:type:(database service)' '*:arg:' ;;
                variables) _arguments '1:op:(get set delete list)' '*:arg:' ;;
                volume) _arguments '1:op:(list create delete attach detach)' '*:arg:' ;;
                domain) _arguments '1:op:(list create delete)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                environment) _arguments '1:op:(new use delete rename)' '*:arg:' ;;
                service) _arguments '1:op:(list create delete)' '*:arg:' ;;
            esac
            ;;
    esac
}

_railway-cli2 "$@"
