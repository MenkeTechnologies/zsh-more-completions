    (altium-cli)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:altium-cli-command-$line[1]:"
        case $line[1] in
            (inspect)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON (compact by default, use --pretty for formatted)]' \
'--pretty[Pretty-print JSON output (implies --json)]' \
