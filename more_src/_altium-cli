'--json[Output as JSON (compact by default, use --pretty for formatted)]' \
'--pretty[Pretty-print JSON output (implies --json)]' \
'-v[Verbose output]' \
'--verbose[Verbose output]' \
'-q[Quiet mode (errors only)]' \
'--quiet[Quiet mode (errors only)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_altium-cli_commands" \
"*::: :->altium-cli" \
&& ret=0
