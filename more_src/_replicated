#compdef replicated
# Documentation: https://docs.replicated.com/
# CLI for the Replicated Vendor Portal: manage releases, channels, customers, clusters

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--app=[app slug or app id to use]:app' \
  '--token=[API token to use]:token' \
  '*:command:(api app channel cluster completion config customer default installer instance login logout network notification policy profile registry release version vm)' && ret=0

return ret
