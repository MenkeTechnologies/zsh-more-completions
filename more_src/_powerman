#compdef powerman pm
# _powerman — LLNL HPC power-control client; speaks the powermand TCP protocol on port 10101 to query/control PDUs, IPMI BMCs, IPMI-OEM and serial-attached devices
# upstream: https://github.com/chaos/powerman

_powerman() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-1 --on)'{-1,--on}'[power on targets]' \
        '(-0 --off)'{-0,--off}'[power off targets]' \
        '(-c --cycle)'{-c,--cycle}'[cycle targets]' \
        '(-r --reset)'{-r,--reset}'[reset targets]' \
        '(-f --flash)'{-f,--flash}'[turn beacon on]' \
        '(-u --unflash)'{-u,--unflash}'[turn beacon off]' \
        '(-l --list)'{-l,--list}'[list configured targets]' \
        '(-q --query)'{-q,--query}'[query power state]' \
        '(-s --soft)'{-s,--soft}'[soft power request]' \
        '(-T --telemetry)'{-T,--telemetry}'[show protocol telemetry]' \
        '(-x --exprange)'{-x,--exprange}'[expand ranges]' \
        '(-d --device)'{-d,--device}'[show device list]' \
        '(-D --server-host)'{-D,--server-host}'+[powermand host]:host:_hosts' \
        '(-p --server-port)'{-p,--server-port}'+[powermand port]:port:' \
        '*:target node:'
}

_powerman "$@"
