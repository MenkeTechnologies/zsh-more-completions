autoload -U is-at-least

_rung() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_rung_commands" \
"*::: :->rung" \
&& ret=0
    case $state in
    (rung)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:rung-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(adopt)
_arguments "${_arguments_options[@]}" : \
'-p+[Parent branch for the adopted branch. If not provided, an interactive picker is shown]:PARENT:_default' \
'--parent=[Parent branch for the adopted branch. If not provided, an interactive picker is shown]:PARENT:_default' \
'--dry-run[Show what would be done without making changes]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::branch -- Branch to adopt. Defaults to the current branch:_default' \
&& ret=0
;;
(create)
_arguments "${_arguments_options[@]}" : \
'-m+[Commit message. If provided, stages all changes and creates a commit]:MESSAGE:_default' \
'--message=[Commit message. If provided, stages all changes and creates a commit]:MESSAGE:_default' \
'--dry-run[Show what would be done without making changes]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::name -- Name of the new branch. Optional if --message is provided:_default' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'--fetch[Fetch latest remote state before showing status]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
'-b+[Base branch to sync against (defaults to "main")]:BASE:_default' \
'--base=[Base branch to sync against (defaults to "main")]:BASE:_default' \
'--dry-run[Show what would be done without making changes]' \
'--check[Predict conflicts without performing sync. Shows which branches would have conflicts and which files]' \
'--continue[Continue a paused sync after resolving conflicts]' \
'--abort[Abort the current sync and restore from backup]' \
'--no-push[Skip pushing branches to remote after sync]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(submit)
_arguments "${_arguments_options[@]}" : \
'-t+[Custom PR title for current branch (overrides auto-generated title)]:TITLE:_default' \
'--title=[Custom PR title for current branch (overrides auto-generated title)]:TITLE:_default' \
'(--amend)-m+[Create a new commit with this message before pushing. Stages all changes first if working directory is dirty]:MESSAGE:_default' \
'(--amend)--message=[Create a new commit with this message before pushing. Stages all changes first if working directory is dirty]:MESSAGE:_default' \
'--draft[Create PRs as drafts (won'\''t trigger CI)]' \
'--dry-run[Show what would be done without making changes]' \
'--force[Force push even if lease check fails]' \
'(-m --message)--amend[Amend staged changes to the last commit before pushing. Stages all changes first if working directory is dirty]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(undo)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(merge)
_arguments "${_arguments_options[@]}" : \
'-m+[Merge method\: squash (default), merge, or rebase]:METHOD:_default' \
'--method=[Merge method\: squash (default), merge, or rebase]:METHOD:_default' \
'--no-delete[Don'\''t delete the remote branch after merge]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(nxt)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(prv)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(move)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(restack)
_arguments "${_arguments_options[@]}" : \
'--onto=[New parent branch to rebase onto]:ONTO:_default' \
'--dry-run[Show what would be done without making changes]' \
'--continue[Continue a paused restack after resolving conflicts]' \
'--abort[Abort the current restack and restore from backup]' \
'--include-children[Also move all descendant branches (children, grandchildren, etc.)]' \
'--force[Force restack even if branches have diverged from remote]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::branch -- Branch to move. Defaults to the current branch:_default' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
'--check[Only check for updates without installing]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(log)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(absorb)
_arguments "${_arguments_options[@]}" : \
'-b+[Base branch to determine rebaseable range (defaults to auto-detect)]:BASE:_default' \
'--base=[Base branch to determine rebaseable range (defaults to auto-detect)]:BASE:_default' \
'--dry-run[Show what would be absorbed without making changes]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(split)
_arguments "${_arguments_options[@]}" : \
'(--abort)--dry-run[Show what would be done without making changes]' \
'(--dry-run)--abort[Abort the current split and restore from backup]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::branch -- Branch to split. Defaults to the current branch:_default' \
&& ret=0
;;
(fold)
_arguments "${_arguments_options[@]}" : \
'(--include-children)--into-parent[Fold current branch into its parent]' \
'(--into-parent)--include-children[Fold children into current branch]' \
'(--abort)--dry-run[Show what would be done without making changes]' \
'(--dry-run)--abort[Abort the current fold and restore from backup]' \
'--json[Output as JSON (for tooling integration)]' \
'(--json)-q[Suppress informational output]' \
'(--json)--quiet[Suppress informational output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'*::branches -- Branches to fold (must be adjacent in stack). If not specified, interactive selection is used:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_rung__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:rung-help-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(adopt)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(create)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(submit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(undo)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(merge)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nxt)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(prv)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(move)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(restack)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(log)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(absorb)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(split)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(fold)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_rung_commands] )) ||
_rung_commands() {
    local commands; commands=(
'init:Initialize rung in the current repository' \
'adopt:Adopt an existing branch into the stack. \[alias\: ad\]' \
'create:Create a new branch in the stack. \[alias\: c\]' \
'status:Display the current stack status. \[alias\: st\]' \
'sync:Sync the stack by rebasing all branches. \[alias\: sy\]' \
'submit:Push branches and create/update PRs. \[alias\: sm\]' \
'undo:Undo the last sync operation. \[alias\: un\]' \
'merge:Merge the current branch'\''s PR and clean up. \[alias\: m\]' \
'nxt:Navigate to the next branch in the stack (child). \[alias\: n\]' \
'prv:Navigate to the previous branch in the stack (parent). \[alias\: p\]' \
'move:Interactive branch picker for quick navigation. \[alias\: mv\]' \
'restack:Move a branch to a different parent in the stack. \[alias\: re\]' \
'doctor:Diagnose issues with the stack and repository. \[alias\: doc\]' \
'update:Update rung to the latest version. \[alias\: up\]' \
'completions:Generate shell completions. \[alias\: comp\]' \
'log:Show commits between the base branch and HEAD' \
'absorb:Absorb staged changes into the appropriate commits. \[alias\: ab\]' \
'split:Split a branch into multiple stacked branches. \[alias\: sp\]' \
'fold:Fold adjacent branches into one. \[alias\: fo\]' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'rung commands' commands "$@"
}
