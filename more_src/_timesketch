#compdef timesketch
# Documentation: https://timesketch.org/guides/user/cli-client/
# Timesketch command-line client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--sketch=[sketch to work within]:sketch id' \
  '--output-format=[output format]:format:(json text tabular csv)' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'timesketch command' \
      'search[search events]' \
      'sketch[manage sketches]' \
      'analyze[run analyzers]' \
      'timelines[manage timelines]' \
      'events[manage events]' \
      'intelligence[manage IOCs]' \
      'config[get/set configuration]' \
      'importer[import a timeline]' \
      'saved-searches[manage saved searches]' \
      'sigma[manage sigma rules]' && ret=0
    ;;
esac

return ret
