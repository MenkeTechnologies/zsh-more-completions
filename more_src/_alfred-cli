#compdef alfred-cli alfred-app
# _alfred-cli — Alfred macOS productivity launcher AppleScript-bridge CLI alias (Running with Crayons Ltd., Objective-C); custom URL scheme
# upstream: https://www.alfredapp.com

_alfred-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--show[show alfred]' \
        '--hide[hide alfred]' \
        '--toggle[toggle alfred]' \
        '--query=+[run query]:str:' \
        '-q+[run query]:str:' \
        '--snippet=+[run snippet]:str:' \
        '-s+[run snippet]:str:' \
        '--clipboard-history[open clipboard history]' \
        '-c[open clipboard history]' \
        '--snippets[open snippets]' \
        '-S[open snippets]' \
        '--prefs[open preferences]' \
        '-p[open preferences]' \
        '--reload[reload workflows]' \
        '-r[reload workflows]' \
        '--workflow=+[run workflow id]:str:' \
        '-w+[run workflow id]:str:' \
        '--theme=+[set theme name]:str:' \
        '-t+[set theme name]:str:' \
        '--toggle-feature=+[toggle feature key]:str:' \
        '--reset-history[reset history]' \
        '--sync-folder=+[set sync folder]:dir:_files -/' \
        '--feature-flag=+[set feature flag key=value]:str:' \
        '*:arg:'
}

_alfred-cli "$@"
