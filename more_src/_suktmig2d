#compdef suktmig2d
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/migration_inversion/suktmig2d.c
# prestack time migration of a common-offset

local ret=1

_arguments -s -S \
  'vfile=[vfile]:vfile:' \
  'dx=[dx]:dx:' \
  'fcdpdata=[fcdpdata]:fcdpdata:' \
  'firstcdp=[firstcdp]:firstcdp:' \
  'lastcdp=[lastcdp]:lastcdp:' \
  'dcdp=[dcdp]:dcdp:' \
  'angmax=[angmax]:angmax:' \
  'hoffset=[hoffset]:hoffset:' \
  'nfc=[nfc]:nfc:' \
  'fwidth=[fwidth]:fwidth:' \
  'phasefac=[phasefac]:phasefac:' \
  '*:file:_files' && ret=0

return ret
