#compdef passmenu pass-otp
# _password-store — pass extensions (passmenu uses dmenu/rofi to pick a stored password and type/copy it; pass-otp adds TOTP code support via the otp subcommand; both inherit pass's selection scheme)
# upstream: https://git.zx2c4.com/password-store (extensions)
# Flags from password-store contrib/dmenu/passmenu on tip.

_password-store() {
    _arguments \
        '--type[type password via xdotool instead of copy]' \
        '--clip[copy to clipboard]' \
        '--otp[handle TOTP via pass-otp]' \
        '*::dmenu/rofi options:'
}

_password-store "$@"
