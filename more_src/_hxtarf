#compdef hxtarf
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/hxtarf.txt
# Computes and applies the HEXTE collimator response to produce a .arf file

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'phafil=[name of the input .pha file]:pha file:_files' \
  'inarf=[input effective area file]:arf file:_files' \
  'outarf=[name of the output .arf file]:output file:_files' \
  'xtefilt=[XTEFILTER file with satellite pointing]:filter file:_files' \
  'collcube=[collimator cube file for the detector]:cube file:_files' \
  'detname=[detector identifier]:detector:(PWA0 PWA1 PWA2 PWA3 PWB0 PWB1 PWB2 PWB3)' \
  'jitter=[acceptable pointing variation in arcseconds]:arcsec:' \
  'ra=[alternate right ascension]:ra:' \
  'dec=[alternate declination]:dec:' \
  'start=[observation start time]:time:' \
  'stop=[observation end time]:time:' \
  'chatter=[verbosity level]:level:' \
  'clobber=[overwrite existing output files]:flag:(yes no)' \
  'arfversn=[output ARF file format version]:version:' \
  '*:file:_files' && ret=0

return ret
