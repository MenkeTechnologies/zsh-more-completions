#compdef tweakcc
# Documentation: https://man.archlinux.org/search?q=tweakcc
# Reference accessed: 2026-05-16

# Zsh completion for tweakcc Claude Code theme utility

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:theme path:_files' && ret=0

return ret
