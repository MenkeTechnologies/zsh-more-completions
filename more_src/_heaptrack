#compdef heaptrack

# Zsh completion for heaptrack - heap memory profiler for Linux

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help information]' \
  '(- *)'{-v,--version}'[show version information]' \
  '(-d --debug)'{-d,--debug}'[set debug level]:debug level' \
  '(-o --output)'{-o,--output}'[specify output file]:output file:_files' \
  '(-p --pid)'{-p,--pid}'[attach to running process]:pid:_pids' \
  '(-r --raw)'{-r,--raw}'[record raw data without compression]' \
  '(-a --analyze)'{-a,--analyze}'[analyze a previously recorded data file]:data file:_files' \
  '1:command to profile:_command_names -e' \
  '*::command arguments: _normal' \
  && ret=0

return ret
