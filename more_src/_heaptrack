#compdef heaptrack

# Zsh completion for heaptrack - heap memory profiler

_arguments \
  '--help[show help message]' \
  '--version[show version]' \
  '(-o --output)'{-o,--output}'[specify output file]:output file:_files' \
  '(-p --pid)'{-p,--pid}'[attach to running process]:pid:_pids' \
  '--raw[do not compress output]' \
  '--analyze[analyze a heaptrack data file]:data file:_files' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '--record-only[only record, do not analyze after]' \
  '*::program:_command_names -e'
