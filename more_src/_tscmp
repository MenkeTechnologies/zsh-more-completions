#compdef tscmp
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tscmp.cpp
# tscmp - compare the content of two transport stream files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-f --format)'{-f,--format}'=[input packet format]:format:(autodetect TS M2TS RS204 duck)' \
  '--buffered-packets=[input buffer size in TS packets (default 10000)]:n:' \
  '(-b --byte-offset)'{-b,--byte-offset}'=[start reading at byte offset]:offset:' \
  '--cc-ignore[ignore continuity counters when comparing]' \
  '(-c --continue)'{-c,--continue}'[continue comparison to end of files]' \
  '(-d --dump)'{-d,--dump}'[dump content of all differing packets]' \
  '(-m --min-reorder)'{-m,--min-reorder}'=[min consecutive packets in reordered sequences]:n:' \
  '(-n --normalized)'{-n,--normalized}'[report in normalized output format]' \
  '(-p --packet-offset)'{-p,--packet-offset}'=[start reading at TS packet number]:n:' \
  '--payload-only[compare only packet payload, ignoring headers]' \
  '--pcr-ignore[ignore PCR and OPCR values when comparing]' \
  '--pid-ignore[ignore PID values when comparing packets]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output, exit status reflects equality]' \
  '(-s --search-reorder)'{-s,--search-reorder}'[search for missing or reordered packets]' \
  '--subset[legacy equivalent of --search-reorder]' \
  '(-t --threshold-diff)'{-t,--threshold-diff}'=[max differing bytes to declare packets equal]:n:' \
  '--json=[report differences in JSON to file]:file:_files' \
  '*:ts file:_files -g "*.ts *.m2ts *.mpg"' && ret=0

return ret
