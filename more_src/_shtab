#compdef shtab
# Documentation: https://docs.iterative.ai/shtab/use/
# shtab: generate shell tab-completion scripts from an argparse parser

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-s --shell)'{-s,--shell}'=[shell type to generate completion for]:shell:(bash zsh tcsh)' \
  '(-o --output)'{-o,--output}'=[output file destination]:file:_files' \
  '--prefix=[string prepended to generated functions to avoid clashes]:prefix' \
  '--preamble=[string prepended to the generated script]:preamble' \
  '--prog=[custom program name overriding parser.prog]:prog' \
  '(-u --error-unimportable)'{-u,--error-unimportable}'[raise errors if the parser is not found in PYTHONPATH]' \
  '--verbose[log debug information]' \
  '--print-own-completion[print shtab own completion]' \
  '1:parser:' && ret=0

return ret
