#compdef relion_star_handler
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: operate on, compare, split and select rows from STAR files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input STAR file(s)]:file:_files' \
  '--o=[output STAR file]:file:_files' \
  '--angpix=[pixel size (A) when ignoring optics groups]:value' \
  '--i_tablename=[read table with this name when ignoring optics]:name' \
  '--compare=[STAR file to compare the input with]:file:_files' \
  '--label1=[1st metadata label for the comparison]:label' \
  '--label2=[2nd metadata label for the comparison]:label' \
  '--label3=[3rd metadata label for the comparison]:label' \
  '--max_dist=[maximum distance to consider a match]:value' \
  '--select=[metadata label to base output selection on]:label' \
  '--minval=[minimum acceptable value for this label]:value' \
  '--maxval=[maximum acceptable value for this label]:value' \
  '--select_by_str=[string metadata label to base selection on]:label' \
  '--select_include=[select rows containing this string]:string' \
  '--select_exclude=[exclude rows containing this string]:string' \
  '--discard_on_stats[discard images if avg/stddev deviates too much]' \
  '--discard_label=[label pointing to images for discarding on stats]:label' \
  '--discard_sigma=[discard images this many sigma from ensemble]:value' \
  '--combine[combine input STAR files]' \
  '--combine_picks[combine input manual/autopick STAR files]' \
  '--check_duplicates=[label to check for duplicates]:label' \
  '--split[split the input STAR file into smaller output files]' \
  '--random_order[perform splits on randomised order]' \
  '--random_seed=[random seed for randomisation]:value' \
  '--nr_split=[split into this many equal-sized STAR files]:value' \
  '--size_split=[split into subsets of this many lines]:value' \
  '--operate=[operate on this metadata label]:label' \
  '--operate2=[operate also on this metadata label]:label' \
  '--operate3=[operate also on this metadata label]:label' \
  '--set_to=[set all values for the operate label(s) to this value]:value' \
  '--multiply_by=[multiply operate label values by this value]:value' \
  '--add_to=[add this value to operate label values]:value' \
  '--center[perform centering according to a reference position]' \
  '--center_X=[X-coordinate in reference to center on (pix)]:value' \
  '--center_Y=[Y-coordinate in reference to center on (pix)]:value' \
  '--center_Z=[Z-coordinate in reference to center on (pix)]:value' \
  '--remove_column=[remove the column with this label]:label' \
  '--add_column=[add a column with this label]:label' \
  '--add_column_value=[set this value in all rows for the added column]:value' \
  '--copy_column_from=[copy values in this column to the added column]:label' \
  '--hist_column=[calculate histogram of values in this column]:label' \
  '--in_percent[show histogram in percent]' \
  '--show_cumulative[show histogram of cumulative distribution]' \
  '--hist_bins=[number of bins for the histogram]:value' \
  '--hist_min=[minimum value for the histogram]:value' \
  '--hist_max=[maximum value for the histogram]:value' \
  '--remove_duplicates=[remove duplicated particles within this distance (A)]:value' \
  '--image_angpix=[pixel size (A/pix) of original images]:value' \
  '*:file:_files' && ret=0

return ret
