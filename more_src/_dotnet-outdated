#compdef dotnet-outdated
# Documentation: https://github.com/dotnet-outdated/dotnet-outdated
# dotnet-outdated - report and update outdated NuGet package references

local ret=1

_arguments -s -S \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '--version[display tool version]' \
  '(-i --include-auto-references)'{-i,--include-auto-references}'[include automatically referenced packages]' \
  '(-pre --pre-release)'{-pre,--pre-release}'=[pre-release detection mode]:mode:(Auto Always Never)' \
  '(-vl --version-lock)'{-vl,--version-lock}'=[restrict updates to current version]:lock:(None Major Minor)' \
  '(-t --transitive)'{-t,--transitive}'[detect transitive dependencies]' \
  '(-td --transitive-depth)'{-td,--transitive-depth}'=[transitive analysis depth]:depth:' \
  '(-u --upgrade)'{-u,--upgrade}'=[automatically upgrade packages]:mode:(Auto Prompt)' \
  '(-f --fail-on-updates)'{-f,--fail-on-updates}'[non-zero exit code when updates exist]' \
  '(-inc --include)'{-inc,--include}'=[only analyze packages matching filter]:filter:' \
  '(-exc --exclude)'{-exc,--exclude}'=[skip packages matching filter]:filter:' \
  '(-o --output)'{-o,--output}'=[write results to file]:file:_files' \
  '(-of --output-format)'{-of,--output-format}'=[report format]:format:(Json Csv Markdown)' \
  '(-ot --older-than)'{-ot,--older-than}'=[only versions older than days]:days:' \
  '(-n --no-restore)'{-n,--no-restore}'[skip restore and compatibility checks]' \
  '(-r --recursive)'{-r,--recursive}'[search recursively for projects]' \
  '(-fba --include-file-based-apps)'{-fba,--include-file-based-apps}'[include loose file-based apps]' \
  '(-ifs --ignore-failed-sources)'{-ifs,--ignore-failed-sources}'[treat source failures as warnings]' \
  '(-utd --include-up-to-date)'{-utd,--include-up-to-date}'[include up-to-date dependencies]' \
  '(-prl --pre-release-label)'{-prl,--pre-release-label}'=[restrict pre-release to label prefix]:label:' \
  '(-ncll --nuget-cred-log-level)'{-ncll,--nuget-cred-log-level}'=[NuGet credential log level]:level:' \
  '(-rt --runtime)'{-rt,--runtime}'=[runtime identifier for restore]:rid:' \
  '(-mv --maximum-version)'{-mv,--maximum-version}'=[inclusive maximum package version]:version:' \
  '*:path:_files' && ret=0

return ret
