#compdef pbzip2

# Zsh completion for pbzip2 - parallel bzip2 file compressor

_arguments -s -S \
  '-b+[block size in 100k units]:100k blocks:(1 2 3 4 5 6 7 8 9)' \
  '-c[compress or decompress to stdout]' \
  '--stdout[compress or decompress to stdout]' \
  '-d[force decompression]' \
  '--decompress[force decompression]' \
  '-f[force overwrite of output files]' \
  '--force[force overwrite of output files]' \
  '-h[show help]' \
  '--help[show help]' \
  '-k[keep (do not delete) input files]' \
  '--keep[keep (do not delete) input files]' \
  '-l[list compressed file contents]' \
  '-m+[use BYTES of memory for decompression]:bytes:' \
  '-p+[number of processors to use]:N:' \
  '-q[be quiet (suppress all output)]' \
  '--quiet[be quiet]' \
  '-r[read files recursively; only for testing]' \
  '-S[sequentially compress with one CPU]' \
  '-s+[sort files by size]:order:(asc desc none)' \
  '-t[test file integrity]' \
  '--test[test file integrity]' \
  '-v[be verbose]' \
  '--verbose[be verbose]' \
  '-V[print version number]' \
  '--version[print version number]' \
  '-z[force compression]' \
  '--compress[force compression]' \
  '-1[use fastest compression]' \
  '-9[use best compression]' \
  '*:file:_files'
