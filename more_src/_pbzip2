#compdef pbzip2
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/pbzip2.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pbzip2 - parallel bzip2 file compressor

_arguments -s -S \
  '-b+[block size in 100k units (1-9, default 9)]:100k blocks:(1 2 3 4 5 6 7 8 9)' \
  '-c[output to standard out]' \
  '--stdout[output to standard out]' \
  '-d[force decompression]' \
  '--decompress[force decompression]' \
  '-f[force overwrite of output files]' \
  '--force[force overwrite of output files]' \
  '-h[show help]' \
  '--help[show help]' \
  '-k[keep (do not delete) input files]' \
  '--keep[keep (do not delete) input files]' \
  '-l[use load average to determine processor count]' \
  '--loadavg[use load average to determine processor count]' \
  '-m+[max memory usage in MB for decompression]:MB:' \
  '-p+[number of processors to use]:N:' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '-r[read entire input into RAM before splitting]' \
  '--read[read entire input into RAM before splitting]' \
  '-S+[child thread stack size in 1KB steps]:KB:' \
  '-t[test compressed file integrity]' \
  '--test[test compressed file integrity]' \
  '-v[verbose mode]' \
  '--verbose[verbose mode]' \
  '-V[print version number]' \
  '--version[print version number]' \
  '-z[force compression]' \
  '--compress[force compression]' \
  '--fast[use fastest compression]' \
  '--best[use best compression]' \
  '--ignore-trailing-garbage=[ignore trailing garbage (0 or 1)]:val:(0 1)' \
  '-1[use fastest compression]' \
  '-9[use best compression]' \
  '*:file:_files'
