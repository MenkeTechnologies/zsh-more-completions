#compdef kueue-importer importer
# _kueue-importer — import existing pods/jobs into Kueue queues (kubernetes-sigs/kueue)
# upstream: https://github.com/kubernetes-sigs/kueue
# Subcommands + flags from cmd/importer/main.go setFlags on tip.

_kueue-importer() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '*'{-v,--verbosity}'[increase log verbosity (repeatable)]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                import:'check prerequisites and import existing pods'
            )
            _describe -t commands 'kueue-importer command' cmds
            ;;
        args)
            case $words[1] in
                import)
                    _arguments \
                        '(-n --namespace)'{-n,--namespace=}'[target namespaces (comma-sep, repeatable)]:ns:' \
                        '--queuelabel=[label key identifying target LocalQueue]:key:' \
                        '*--queuemapping=[label-value:queue-name map (key=value)]:map:' \
                        '--queuemapping-file=[YAML file with extra label→queue mappings]:file:_files' \
                        '*--add-labels=[extra label=value pairs to add (key=value)]:label:' \
                        '--qps=[client QPS]:f:' \
                        '--burst=[client burst]:n:' \
                        '(-c --concurrent-workers)'{-c,--concurrent-workers=}'[concurrent import workers]:n:' \
                        '--dry-run=[validate only, do not import]:bool:(true false)'
                    ;;
            esac
            ;;
    esac
}

_kueue-importer "$@"
