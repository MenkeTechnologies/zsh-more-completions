#compdef gpstate
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpstate.html
# Show the status of a running Greenplum Database system

local ret=1

_arguments -s -S \
  '(-? -h --help)'{-\?,-h,--help}'[display online help]' \
  '-b[display a brief summary of system state (default)]' \
  '-B[number of segments to check in parallel]:parallel_processes' \
  '-c[display mapping of primary segments to mirror segments]' \
  '-d[coordinator data directory]:dir:_files -/' \
  '-e[show primary/mirror pairs with potential issues]' \
  '-f[display standby coordinator host configuration]' \
  '-i[display Greenplum software version for each instance]' \
  '-l[log file directory]:dir:_files -/' \
  '-m[list mirror segment instances and roles]' \
  '-p[list port numbers used by the system]' \
  '-q[run in quiet mode]' \
  '-Q[check segment status in system catalog without polling]' \
  '-s[display detailed status information]' \
  '-v[display detailed status and progress information]' \
  '-x[display details of a system expansion]' && ret=0

return ret
