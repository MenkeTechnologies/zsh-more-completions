#compdef lm-eval lm_eval
# Documentation: https://github.com/EleutherAI/lm-evaluation-harness/blob/main/docs/interface.md
# EleutherAI lm-evaluation-harness CLI for few-shot evaluation of language models

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-M --model)'{-M,--model}'=[model type or provider]:model:(hf vllm sglang openai-completions openai-chat-completions local-completions local-chat-completions anthropic-chat)' \
  '(-a --model_args)'{-a,--model_args}'=[model constructor args key=value]:args:' \
  '(-t --tasks)'{-t,--tasks}'=[comma separated tasks or groups]:tasks:' \
  '(-f --num_fewshot)'{-f,--num_fewshot}'=[number of few-shot examples]:n:' \
  '(-b --batch_size)'{-b,--batch_size}'=[batch size (int, auto, auto:N)]:size:' \
  '--max_batch_size=[maximum batch size for auto-tuning]:size:' \
  '--device=[hardware target]:device:(cuda cuda:0 cpu mps)' \
  '(-o --output_path)'{-o,--output_path}'=[results directory or JSON file]:path:_files' \
  '(-L --limit)'{-L,--limit}'=[example limit per task]:n:' \
  '(-c --use_cache)'{-c,--use_cache}'=[SQLite cache path prefix]:path:_files' \
  '(-w --write_out)'{-w,--write_out}'[print prompts for debugging]' \
  '(-s --log_samples)'{-s,--log_samples}'[save model inputs and outputs]' \
  '--gen_kwargs=[generation parameters key=value]:kwargs:' \
  '--apply_chat_template[apply chat template to prompts]' \
  '--system_instruction=[custom system instruction]:text:' \
  '--include_path=[external task directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(CRITICAL ERROR WARNING INFO DEBUG)' \
  '--seed=[random seed configuration]:seed:' \
  '--trust_remote_code[allow remote code execution]' \
  '--confirm_run_unsafe_code[acknowledge arbitrary python execution]' \
  '1:command:(run ls validate)' \
  '*::arg:->args' && ret=0

return ret
