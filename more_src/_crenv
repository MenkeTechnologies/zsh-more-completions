#compdef crenv
# Documentation: https://github.com/pine/crenv
# crenv - Crystal version manager (rbenv-style)

local ret=1

_arguments -s -S \
  '--version[display crenv version number]' \
  '1:command:(commands local global shell rehash version versions which whence install init help)' \
  '*::arg:_files' && ret=0

return ret
