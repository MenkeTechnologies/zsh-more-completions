#compdef smerge

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-n[open a new window]' \
  '--new-window[open a new window]' \
  '-w[wait for the window to be closed]' \
  '--wait[wait for the window to be closed]' \
  '-b+[background mode (no window)]' \
  '--background[background mode]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'search:search for a string'
      'log:show repository log'
      'blame:show blame for a file'
      'mergetool:resolve merge conflicts'
      'diff:show diff'
    )
    _describe -t commands 'smerge command' commands && ret=0
    _files -/
    ;;
  args)
    case $line[1] in
      search)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '*:search pattern:' && ret=0
        ;;
      log)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '*:path:_files' && ret=0
        ;;
      blame)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '1:file:_files' && ret=0
        ;;
      mergetool)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '1:file:_files' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
