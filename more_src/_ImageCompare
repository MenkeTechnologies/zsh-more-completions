#compdef ImageCompare
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ImageCompare.cxx — compare test image against one or more baselines (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:testImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '*:baseline image(s):_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    && ret=0

return ret
