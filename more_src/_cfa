#compdef cfa
# Documentation: https://ncas-cms.github.io/cf-python/tutorial.html
# cfa - cf-python utility to view and aggregate CF field constructs

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display the full man page]' \
  '(-1 --one)'{-1,--one}'[treat all input files collectively as a single CF dataset]' \
  '(-o --outfile)'{-o,--outfile=}'[treat input as a single dataset and write to file]:output file:_files' \
  '(-d --directory)'{-d,--directory=}'[specify the output directory for all output files]:directory:_files -/' \
  '(-D --Directory)'{-D,--Directory}'[write each output file to its input file directory]' \
  '(-f --format)'{-f,--format=}'[set the format of the output file(s)]:format' \
  '(-e --external)'{-e,--external=}'[read external variables from the given file]:external file:_files' \
  '(-s --select)'{-s,--select=}'[select a subset of fields by property]:property' \
  '(-v --view)'{-v,--view=}'[display text descriptions]:mode:(s m c)' \
  '(-i --relaxed_identities)'{-i,--relaxed_identities}'[allow identification by long_name or netCDF names]' \
  '(-u --relaxed_units)'{-u,--relaxed_units}'[treat same standard_name with missing units as equivalent]' \
  '(-n --no_aggregation)'{-n,--no_aggregation}'[do not aggregate fields; write input as-is]' \
  '(-x --exclude)'{-x,--exclude}'[omit unaggregatable fields from the output]' \
  '--axis=[aggregate over the named axis property]:property' \
  '--equal=[require equal values for the named property]:property' \
  '--exist=[require existence of the named property]:property' \
  '--ignore=[ignore the named property when aggregating]:property' \
  '--equal_all[require all properties to be equal]' \
  '--exist_all[require all properties to exist]' \
  '--contiguous[require contiguous aggregation axes]' \
  '--no_overlap[disallow overlapping aggregation axes]' \
  '--compress=[set the netCDF compression level]:level' \
  '--double[write data in double precision]' \
  '--single[write data in single precision]' \
  '--least_sig_digit=[set the least significant digit]:digits' \
  '--no_shuffle[disable the netCDF shuffle filter]' \
  '--fletcher32[enable the fletcher32 checksum filter]' \
  '--recursive[recurse into input directories]' \
  '--follow_symlinks[follow symbolic links]' \
  '--ignore_read_error[skip files that cannot be read]' \
  '--overwrite[overwrite existing output files]' \
  '--reference_datetime=[set the reference datetime]:datetime' \
  '--unlimited=[make the named axis unlimited]:axis' \
  '*:file:_files -g "*.(nc|cdf)"' && ret=0

return ret
