#compdef kubefedctl
# _kubefedctl — KubeFed v1beta1 control-plane CLI (federate / enable-type / disable-type / join / unjoin / orphaning / version)
# upstream: https://github.com/kubernetes-sigs/kubefed
# Subcommands from pkg/kubefedctl/kubefedctl.go on tip (cobra).

_kubefedctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--context=[kubeconfig context]:ctx:' \
        '--kubefed-namespace=[KubeFed control-plane namespace]:ns:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                enable:'enable propagation of a Kubernetes type via a FederatedTypeConfig'
                disable:'disable propagation of a Kubernetes type'
                federate:'federate the resources of a Kubernetes type in a namespace'
                join:'join a Kubernetes cluster to a KubeFed control plane'
                unjoin:'unjoin a Kubernetes cluster from a KubeFed control plane'
                orphaning:'configure orphaning-deletion behaviour for a federated resource'
                version:'print kubefedctl version'
            )
            _describe -t commands 'kubefedctl subcommand' subs
            ;;
    esac
}

_kubefedctl "$@"
