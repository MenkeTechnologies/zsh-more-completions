#compdef impacket-CheckLDAPStatus
# Documentation: https://github.com/fortra/impacket/blob/master/examples/CheckLDAPStatus.py
# LDAP signing and channel binding enumeration utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-dc-ip=[IP address of a domain controller or a DNS resolver for the domain]:ip' \
  '-domain=[domain name]:domain' \
  '-debug[turn DEBUG output ON]' \
  '-timeout=[DNS timeout (default 15)]:seconds' \
  '-ts[adds timestamp to every logging output]' && ret=0

return ret
