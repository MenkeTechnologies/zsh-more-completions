#compdef clitest
# Documentation: https://github.com/aureliojargas/clitest
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# aureliojargas/clitest POSIX test runner.

local ret=1
_arguments -s \
  '(-1 --first)'{-1,--first}'[stop on first failure]' \
  '(-l --list)'{-l,--list}'[list tests only]' \
  '(-L --list-run)'{-L,--list-run}'[list with status]' \
  '(-t --test)'{-t+,--test=}'[run test range]:range:' \
  '(-s --skip)'{-s+,--skip=}'[skip test range]:range:' \
  '--pre-flight=[run before first test]:command:_default' \
  '--post-flight=[run after last test]:command:_default' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-V --version)'{-V,--version}'[version]'  \
  '(-P --progress)'{-P+,--progress=}'[progress style]:type:(test number dot none)' \
  '--color=[when to color]:when:(auto always never)' \
  '--diff-options=[diff flags]:options:' \
  '--inline-prefix=[expected output prefix]:prefix:' \
  '--prefix=[command prefix]:prefix:' \
  '--prompt=[REPL prompt string]:prompt:' \
  '*::test file:_files' && ret=0
return ret
