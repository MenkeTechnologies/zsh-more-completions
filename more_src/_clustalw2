#compdef clustalw2
# Documentation: https://manpages.debian.org/wheezy/clustalw/clustalw.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ClustalW2: same interface as ClustalW
local curcontext="$curcontext" ret=1
_arguments -C \
  '-INFILE=[input sequence file]:file:_files' \
  '-PROFILE1=[profile 1]:file:_files' \
  '-PROFILE2=[profile 2]:file:_files' \
  '-ALIGN[full multiple alignment]' \
  '-TREE[only guide tree]' \
  '-BOOTSTRAP=[bootstrap replicates]:n:' \
  '-TYPE=[DNA or PROTEIN]:type:(DNA PROTEIN)' \
  '-OUTFILE=[output alignment]:file:_files' \
  '-OUTPUT=[output format]:format:(CLUSTAL GCG GDE PHYLIP PIR NEXUS FASTA)' \
  '-OUTPUTTREE=[tree format]:format:(NJ PHYLIP DIST NEXUS)' \
  '-OUTORDER=[output order]:order:(INPUT ALIGNED)' \
  '-CASE=[character case]:case:(LOWER UPPER)' \
  '-MATRIX=[scoring matrix]:matrix:(BLOSUM PAM GONNET ID)' \
  '-DNAMATRIX=[DNA matrix]:matrix:(IUB CLUSTALW)' \
  '-GAPOPEN=[gap-open penalty]:val:' \
  '-GAPEXT=[gap-extension penalty]:val:' \
  '-QUICKTREE[fast NJ guide tree]' \
  '-CHECK[show non-default options]' \
  '*::clustalw2 options:_files' && ret=0
return ret
