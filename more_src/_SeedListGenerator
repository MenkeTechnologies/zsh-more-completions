#compdef SeedListGenerator
# Documentation: https://www.openms.org/documentation/html/TOPP_SeedListGenerator.html
# OpenMS: generates seed lists for feature detection from various inputs

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '-in[input file (mzML, idXML, featureXML, consensusXML)]:file:_files' \
  '-out_prefix[output file prefix (featureXML)]:prefix:' \
  '-use_peptide_mass[use monoisotopic mass of best peptide hit]' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
