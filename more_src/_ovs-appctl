#compdef ovs-appctl
# Documentation: https://man7.org/linux/man-pages/man8/ovs-appctl.8.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'list-commands:list supported commands'
  'version:show version'
  'vlog/list:list logging modules'
  'vlog/list-pattern:list log patterns'
  'vlog/set:set log level/spec'
  'vlog/close:close log file'
  'vlog/reopen:reopen log file'
)

_arguments -C \
  '(-t --target)'{-t,--target=}'[daemon target]:target:' \
  '(-T --timeout)'{-T,--timeout=}'[timeout secs]:secs:' \
  '(-f --format)'{-f,--format=}'[output format]:fmt:(text json)' \
  '--pretty[pretty-print JSON]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ovs-appctl subcommand' subcommands && ret=0
    ;;
esac

return ret
