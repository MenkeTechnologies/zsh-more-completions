#compdef oni2 Oni2_editor
# _oni2 — Onivim 2 editor (ReasonML / Revery) (onivim/oni2)
# upstream: https://github.com/onivim/oni2
# Flags from src/CLI/Oni_CLI.re.

_oni2() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '*-c+[execute a Vim ex command on startup (repeatable)]:cmd:'
        '-f[run attached (do not fork)]'
        '--nofork[run attached (do not fork)]'
        '(-n --new-window)'{-n,--new-window}'[open in a new window]'
        '--debug[debug log level]'
        '--debug-exthost[log extension-host activity]'
        '--trace[trace log level]'
        '--quiet[only warnings/errors]'
        '--silent[disable all logging]'
        '--no-log-colors[disable colors in log output]'
        '--disable-extensions[do not load any extension]'
        '--disable-configuration[do not load user config]'
        '--disable-syntax-highlighting[disable syntax highlighting]'
        '--gpu-acceleration=[GPU acceleration mode]:mode:(auto off on)'
        '--log-file=[write logs to this file]:file:_files'
        '--log-filter=[log filter regex]:regex:'
        '--checkhealth[run health check + exit]'
        '--list-displays[list connected displays + exit]'
        '--list-extensions[list installed extensions + exit]'
        '--install-extension=[install extension (path or name)]:ext:'
        '--query-extension=[query catalog for an extension]:ext:'
        '--uninstall-extension=[uninstall an extension]:ext:'
        '--proxy-server=[proxy server URL]:url:'
        '--working-directory=[chdir before opening files]:dir:_files -/'
        '--extensions-dir=[custom extensions directory]:dir:_files -/'
        '--force-device-scale-factor=[force display scale factor]:scale:'
        '--window-position=[window position x\,y]:pos:'
        '*:file:_files'
    )
    _arguments -s $args
}

_oni2 "$@"
