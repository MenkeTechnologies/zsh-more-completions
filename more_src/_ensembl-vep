#compdef ensembl-vep
# Documentation: https://man.archlinux.org/search?q=ensembl-vep
# Reference accessed: 2026-05-16

# ensembl-vep: alternative name for Ensembl Variant Effect Predictor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(--help -h)'{--help,-h}'[show help]' \
  '-i[input file]:file:_files' \
  '-o[output file]:file:_files' \
  '--format=[input format]:fmt:(vcf id ensembl hgvs region spdi)' \
  '--vcf[output VCF]' \
  '--tab[tab-separated output]' \
  '--json[JSON output]' \
  '--fasta=[reference FASTA]:file:_files' \
  '--species=[species]:species:' \
  '--assembly=[genome assembly]:assembly:(GRCh37 GRCh38 GRCm38 GRCm39)' \
  '--cache[use cache]' \
  '--offline[offline mode]' \
  '--database[REST API mode]' \
  '--refseq[RefSeq transcripts]' \
  '--symbol[gene symbols]' \
  '--canonical[mark canonical transcripts]' \
  '--mane[MANE transcripts]' \
  '--af[output AF]' \
  '--max_af[output max AF]' \
  '--sift=[SIFT level]:level:(b s p)' \
  '--polyphen=[PolyPhen level]:level:(b s p)' \
  '--plugin=[plugin]:plugin:' \
  '--custom=[custom annotation]:source:' \
  '--fork=[parallel processes]:n:' \
  '*:VCF input file:_files' && ret=0
return ret
