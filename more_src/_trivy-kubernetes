#compdef trivy-kubernetes trivy-k8s
# _trivy-kubernetes — Aqua Trivy Kubernetes cluster scanner subcommand alias (Aqua Security, Go); spf13/cobra
# upstream: https://github.com/aquasecurity/trivy

_trivy-kubernetes() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--timeout=+[timeout]:dur:' \
        '--format=+[format]:fmt:(table json sarif cyclonedx spdx-json)' \
        '-f+[format]:fmt:(table json sarif cyclonedx spdx-json)' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--severity=+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '-s+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '--ignore-unfixed[ignore unfixed]' \
        '--exit-code=+[exit code]:n:' \
        '--ignorefile=+[ignorefile]:file:_files' \
        '--report=+[report mode]:r:(all summary)' \
        '--scanners=+[scanners]:list:(vuln secret misconfig license rbac)' \
        '--security-checks=+[security checks (deprecated)]:list:' \
        '--namespaces=+[namespaces]:list:' \
        '-n+[namespaces]:list:' \
        '--include-namespaces=+[include namespaces]:list:' \
        '--exclude-namespaces=+[exclude namespaces]:list:' \
        '--kubeconfig=+[kubeconfig]:file:_files' \
        '--context=+[kube context]:ctx:' \
        '--burst=+[burst]:n:' \
        '--components=+[components]:list:(workload infra)' \
        '--qps=+[qps]:f:' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '--kind=+[resource kind]:list:' \
        '-k+[resource kind]:list:' \
        '--list-all-pkgs[list all packages]' \
        '--no-progress[no progress]' \
        '--skip-db-update[skip db update]' \
        '--db-repository=+[db repo]:str:' \
        '--skip-java-db-update[skip java db update]' \
        '--skip-images[skip image scanning]' \
        '--include-kinds=+[include kinds]:list:' \
        '--exclude-kinds=+[exclude kinds]:list:' \
        '--exclude-resources=+[exclude resources]:list:' \
        '--include-resources=+[include resources]:list:' \
        '--compliance=+[compliance spec]:spec:(k8s-cis-1.23 k8s-cis-1.24 k8s-cis-1.7 k8s-pss-baseline-0.1 k8s-pss-restricted-0.1 k8s-nsa-1.0)' \
        '*:target:(cluster)'
}

_trivy-kubernetes "$@"
