#compdef libvirt-cli libvirt
# _libvirt-cli — libvirt project virtualization toolkit CLI alias (Red Hat / libvirt team, C); custom argparse
# upstream: https://github.com/libvirt/libvirt

_libvirt-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[connect URI]:str:' \
        '--connect=+[connect URI]:str:' \
        '-r[readonly]' \
        '--readonly[readonly]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[debug level]:n:(0 1 2 3 4)' \
        '--debug=+[debug level]:n:(0 1 2 3 4)' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '*:arg:'
}

_libvirt-cli "$@"
