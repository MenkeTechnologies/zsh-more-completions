#compdef btrfs-find-root
# _btrfs-find-root — btrfs-progs btrfs-find-root (search a btrfs block device for valid root tree blocks; -a print all even if invalid, -g generation filter, -l level filter, -o objectid filter; positional argument is the device; useful for forensic recovery)
# upstream: https://github.com/kdave/btrfs-progs
# Flags from btrfs-progs btrfs-find-root.c on tip.

_btrfs-find-root() {
    _arguments \
        '-a[print all root blocks]' \
        '-g+[generation filter]:gen:' \
        '-l+[level filter]:level:' \
        '-o+[objectid filter]:objectid:' \
        '1:device:_files -g "/dev/*"'
}

_btrfs-find-root "$@"
