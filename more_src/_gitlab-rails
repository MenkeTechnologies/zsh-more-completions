#compdef gitlab-rails
# _gitlab-rails — GitLab Inc gitlab-rails wrapper that runs Rails commands in the context of the omnibus GitLab installation (gitlab team, Ruby); rails CLI
# upstream: https://gitlab.com/gitlab-org/gitlab

_gitlab-rails() {
    local -a sub=(
        'console:open Rails console'
        'c:open Rails console'
        'dbconsole:open DB console'
        'db:database tasks'
        'runner:run a snippet of Ruby code'
        'r:run a snippet of Ruby code'
        'server:start Rails server'
        's:start Rails server'
        'generate:generate code from templates'
        'g:generate code from templates'
        'destroy:revert a generator'
        'd:revert a generator'
        'test:run tests'
        't:run tests'
        'about:show framework info'
        'routes:show routes'
        'middleware:show middleware'
        'tmp:clear tmp directories'
        'restart:restart app'
        'version:show Rails version'
        'webpacker:webpacker tasks'
        'assets:asset pipeline tasks'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-e+[environment]:e:(development test production staging)' \
        '--environment=+[environment]:e:(development test production staging)' \
        '-b+[bind ip]:host:_hosts' \
        '--binding=+[bind ip]:host:_hosts' \
        '-p+[port]:port:_ports' \
        '--port=+[port]:port:_ports' \
        '-P+[pid file]:file:_files' \
        '--pid=+[pid file]:file:_files' \
        '-d[run in background]' \
        '--daemon[run in background]' \
        '--sandbox[sandbox]' \
        '--no-prompt[no prompt]' \
        '-r+[require file]:file:_files' \
        '--require=+[require file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--config=+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gitlab-rails subcommand' sub ;;
        args)
            case $words[1] in
                runner|r) _arguments '*:ruby code or file:_files -g "*.rb"' ;;
                console|c) _arguments '--sandbox[sandbox]' ;;
                db) _arguments '1:db cmd:(create migrate rollback seed schema:load schema:dump structure:load structure:dump version reset drop fixtures:load)' ;;
                generate|g) _arguments '*:generator:(controller model migration scaffold mailer job)' ;;
            esac
            ;;
    esac
}

_gitlab-rails "$@"
