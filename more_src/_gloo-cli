#compdef gloo-cli glooctl
# _gloo-cli — Solo.io Gloo gloo-cli CLI command-line frontend wrapping the Gloo Mesh formerly Gloo Enterprise and Gloo Edge cloud-native Layer 7 Envoy-based proxy and gateway open-source written in Go runs on Kubernetes the cli for the Gloo Edge API gateway api routing-tools traffic-management observability auth security gateway vs virtualservice upstream route-table secret federation install uninstall check edge mesh gateway-api Federation discovery proxy debug-pprof debug-yaml debug-logs cluster register init-plugin-manager generate create delete edit (Solo.io Gloo team Idit Levine Marco Palladino, Go); cobra
# upstream: https://docs.solo.io/

_gloo-cli() {
    local -a sub=(
        'add:add resource fields'
        'check:check installation health'
        'cluster:cluster operations'
        'completion:generate shell completion'
        'create:create resources'
        'debug:debug operations'
        'delete:delete resources'
        'demo:run demos'
        'edit:edit resources'
        'federation:federation operations'
        'gateway:gateway operations'
        'gateway-api:gateway API operations'
        'get:get resources'
        'init-plugin-manager:install plugin manager'
        'install:install Gloo Edge'
        'license:license operations'
        'observability:observability operations'
        'plugin:plugin operations'
        'proxy:proxy operations'
        'remove:remove resource fields'
        'route-table:route table operations'
        'secret:secret operations'
        'uninstall:uninstall Gloo'
        'upgrade:upgrade Gloo'
        'upstream:upstream operations'
        'virtualservice:virtual service operations'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config dir]:dir:_files -/' \
        '--config=+[file]:file:_files' \
        '--consul-allow-stale-reads[consul allow stale]' \
        '--consul-datacenter=+[name]:str:' \
        '--consul-root-key=+[key]:str:' \
        '--consul-scheme=+[s]:s:(http https)' \
        '--consul-server-address=+[host:port]:_hosts' \
        '--consul-token=+[token]:str:' \
        '--dry-run[dry run]' \
        '-i[interactive mode]' \
        '--interactive[interactive]' \
        '--kubeconfig=+[file]:file:_files -g "kubeconfig *.yaml *.yml"' \
        '-n+[namespace]:str:' \
        '--namespace=+[ns]:str:' \
        '-o+[output format]:f:(table yaml json kube-yaml wide)' \
        '--output=+[fmt]:f:(table yaml json kube-yaml wide)' \
        '--use-cache[use cache]' \
        '--vault-address=+[url]:str:' \
        '--vault-ca-cert=+[file]:file:_files' \
        '--vault-ca-path=+[path]:str:' \
        '--vault-client-cert=+[file]:file:_files' \
        '--vault-client-key=+[file]:file:_files' \
        '--vault-root-key=+[key]:str:' \
        '--vault-tls-insecure[skip TLS]' \
        '--vault-tls-server-name=+[name]:str:' \
        '--vault-token=+[token]:str:' \
        '--gloo-version=+[v]:str:' \
        '--license-key=+[key]:str:' \
        '--with-gloo-fed[with Gloo Fed]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'glooctl subcommand' sub ;;
        args)
            case $words[1] in
                get|delete|edit|create) _arguments '1:type:(upstream virtualservice route-table secret proxy gateway settings authconfig ratelimitconfig)' '*:name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                install|uninstall) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_gloo-cli "$@"
