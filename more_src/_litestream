#compdef litestream
# _litestream — SQLite streaming replication tool (benbjohnson/litestream)
# upstream: https://github.com/benbjohnson/litestream

_litestream() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1: :_litestream_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                replicate)
                    _arguments \
                        '-config=[config file]:file:_files' \
                        '-exec=[exec child process]:command:' \
                        '--help[show help]' \
                        '1:database path:_files -g "*.db"' \
                        '2:replica URL:' && ret=0 ;;
                restore)
                    _arguments \
                        '-config=[config file]:file:_files' \
                        '(-o -output)'{-o,-output}'=[output path]:file:_files' \
                        '-if-replica-exists[only restore if replica exists]' \
                        '-if-db-not-exists[only restore if database does not exist]' \
                        '-parallelism=[download parallelism]:count:' \
                        '-replica=[replica name or URL]:replica:' \
                        '-generation=[generation to restore]:generation:' \
                        '-index=[WAL index to restore]:index:' \
                        '-timestamp=[point-in-time to restore]:timestamp:' \
                        '--help[show help]' \
                        '1:database path:_files -g "*.db"' && ret=0 ;;
                snapshots|wal|generations)
                    _arguments \
                        '-config=[config file]:file:_files' \
                        '-replica=[replica name]:replica:' \
                        '--help[show help]' \
                        '1:database path:_files -g "*.db"' && ret=0 ;;
                databases)
                    _arguments \
                        '-config=[config file]:file:_files' \
                        '--help[show help]' && ret=0 ;;
                version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_litestream_commands] )) ||
_litestream_commands() {
    local -a commands
    commands=(
        'databases:list managed databases'
        'generations:list backup generations'
        'replicate:continuously replicate databases'
        'restore:restore a database from backup'
        'snapshots:list snapshots for a database'
        'version:show version'
        'wal:list WAL files for a database'
    )
    _describe -t commands 'litestream command' commands
}

_litestream "$@"
