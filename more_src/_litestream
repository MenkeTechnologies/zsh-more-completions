#compdef litestream
# Documentation: https://litestream.io/reference/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for litestream - SQLite replication tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'replicate:Run a server to replicate databases'
      'restore:Recover database backup from a replica'
      'databases:List databases specified in config file'
      'ltx:List available LTX files for a database'
      'mcp:MCP server for AI assistant integration'
      'sync:Force immediate WAL-to-LTX sync for a database'
      'wal:List available WAL files for a database (deprecated)'
      'version:Print binary version'
    )
    _describe -t commands 'litestream commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      replicate)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' \
          '-exec[Execute a subprocess]:command:' \
          '-no-expand-env[Disable environment variable expansion]' \
          '1:database path:_files -g "*.db"' \
          '2:replica URL:' && ret=0
        ;;
      restore)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' \
          '-o[Output file path]:file:_files' \
          '-if-db-not-exists[Exit 0 if database already exists]' \
          '-if-replica-exists[Exit 0 if no backups found]' \
          '-timestamp[Restore to a point in time]:timestamp:' \
          '-txid[Restore up to a hex-encoded transaction ID]:txid:' \
          '-f[Continuously restore new data]' \
          '-follow-interval[Polling interval]:duration:' \
          '-parallelism[Number of parallel WAL downloads]:count:' \
          '-no-expand-env[Disable environment variable expansion]' \
          '1:database path or replica URL:_files' && ret=0
        ;;
      databases)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' \
          '-no-expand-env[Disable environment variable expansion]' && ret=0
        ;;
      ltx|wal)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' \
          '-no-expand-env[Disable environment variable expansion]' \
          '1:database path:_files -g "*.db"' && ret=0
        ;;
      sync)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' \
          '-no-expand-env[Disable environment variable expansion]' \
          '1:database path:_files -g "*.db"' && ret=0
        ;;
      mcp)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' && ret=0
        ;;
      version)
        ;;
    esac
    ;;
esac

return ret
