#compdef litestream

# Zsh completion for litestream - SQLite replication tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'generations:List available generations for a database'
      'replicate:Replicate a SQLite database'
      'restore:Restore a SQLite database from a replica'
      'snapshots:List available snapshots for a database'
      'wal:List available WAL files for a database'
      'databases:List databases managed by the configuration file'
      'version:Print version information'
    )
    _describe -t commands 'litestream commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      replicate)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' \
          '-exec[Execute a subprocess]:command:' \
          '1:database path:_files -g "*.db"' \
          '2:replica URL:' && ret=0
        ;;
      restore)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' \
          '-replica[Replica name]:replica:' \
          '-o[Output file path]:file:_files' \
          '-if-db-not-exists[Only restore if database does not exist]' \
          '-if-replica-exists[Only restore if replica exists]' \
          '-parallelism[Number of parallel downloads]:count:' \
          '1:database path or replica URL:_files' && ret=0
        ;;
      generations)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' \
          '-replica[Replica name]:replica:' \
          '1:database path:_files -g "*.db"' && ret=0
        ;;
      snapshots)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' \
          '-replica[Replica name]:replica:' \
          '1:database path:_files -g "*.db"' && ret=0
        ;;
      wal)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' \
          '-replica[Replica name]:replica:' \
          '1:database path:_files -g "*.db"' && ret=0
        ;;
      databases)
        _arguments -s -S \
          '-config[Configuration file path]:file:_files' && ret=0
        ;;
      version)
        ;;
    esac
    ;;
esac

return ret
