#compdef repmgr

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-f+[configuration file]:config file:_files' \
  '--config-file=[configuration file]:config file:_files' \
  '-b+[pg_bindir]:directory:_directories' \
  '--pg_bindir=[pg_bindir]:directory:_directories' \
  '-d+[database name]:database:' \
  '--dbname=[database name]:database:' \
  '-h+[host]:host:_hosts' \
  '--host=[host]:host:_hosts' \
  '-p+[port]:port:' \
  '--port=[port]:port:' \
  '-U+[user]:user:' \
  '--username=[user]:user:' \
  '-S+[superuser]:superuser:' \
  '-F+[output format]:format:(text csv)' \
  '--csv[CSV output]' \
  '-t[terse output]' \
  '--terse[terse output]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-L+[log level]:level:(DEBUG INFO NOTICE WARNING ERR ALERT CRIT EMERG)' \
  '--log-level=[log level]:level:(DEBUG INFO NOTICE WARNING ERR ALERT CRIT EMERG)' \
  '--log-to-file[log to file]' \
  '-n+[node ID]:node id:' \
  '--node-id=[node ID]:node id:' \
  '--dry-run[show what would be done]' \
  '--force[force operation]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'primary:manage primary server'
      'standby:manage standby server'
      'node:manage node'
      'cluster:manage cluster'
      'witness:manage witness server'
      'service:manage repmgr service'
      'daemon:manage repmgrd'
    )
    _describe -t commands 'repmgr command' commands && ret=0
    ;;
  args)
    case $line[1] in
      primary)
        local -a primary_commands=(
          'register:register the primary'
          'unregister:unregister the primary'
        )
        _describe -t commands 'primary command' primary_commands && ret=0
        ;;
      standby)
        local -a standby_commands=(
          'clone:clone a standby from the primary'
          'register:register a standby'
          'unregister:unregister a standby'
          'promote:promote a standby to primary'
          'follow:follow a new primary'
          'switchover:promote standby and demote primary'
        )
        _describe -t commands 'standby command' standby_commands && ret=0
        ;;
      node)
        local -a node_commands=(
          'status:show node status'
          'check:run checks on a node'
          'rejoin:rejoin a failed node'
          'service:manage node service'
        )
        _describe -t commands 'node command' node_commands && ret=0
        ;;
      cluster)
        local -a cluster_commands=(
          'show:show cluster info'
          'event:show cluster events'
          'matrix:show cluster connection matrix'
          'crosscheck:cross-check cluster connections'
          'cleanup:clean up cluster metadata'
        )
        _describe -t commands 'cluster command' cluster_commands && ret=0
        ;;
      witness)
        local -a witness_commands=(
          'register:register a witness server'
          'unregister:unregister a witness server'
        )
        _describe -t commands 'witness command' witness_commands && ret=0
        ;;
      daemon)
        local -a daemon_commands=(
          'start:start repmgrd'
          'stop:stop repmgrd'
          'status:show repmgrd status'
        )
        _describe -t commands 'daemon command' daemon_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
