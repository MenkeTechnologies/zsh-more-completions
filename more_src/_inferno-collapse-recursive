#compdef inferno-collapse-recursive
# Documentation: https://github.com/jonhoo/inferno
# Collapse direct recursive calls in folded stacks

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-n --nthreads)'{-n,--nthreads}'=[number of threads to use]:uint' \
  '*:folded stacks:_files' && ret=0

return ret
