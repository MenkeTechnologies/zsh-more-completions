#compdef baseten
# Documentation: https://github.com/basetenlabs/truss
# Reference accessed: 2026-05-23
# Verified: baseten/cli.py Click commands (baseten PyPI).

# Zsh completion for baseten - Baseten model deployment CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'baseten command' \
      'configure[configure Baseten server URL]' \
      'login[authenticate with Baseten API key]' \
      'models[list Baseten models]' && ret=0
    ;;
  args)
    case $line[1] in
      configure)
        _arguments '--server_url[Baseten server URL]:url:' && ret=0
        ;;
      login)
        _arguments '--api_key[Baseten API key]:key:' && ret=0
        ;;
    esac
    ;;
esac

return ret
