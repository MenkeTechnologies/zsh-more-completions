#compdef huey_consumer huey_consumer.py

# Completion for huey_consumer - Huey task queue consumer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-w,--workers}'=[number of worker threads/processes]:workers' \
  {-k,--worker-type}'=[worker type]:worker type:(thread process greenlet)' \
  {-n,--no-periodic}'[disable periodic task scheduler]' \
  {-d,--delay}'=[polling interval in seconds]:delay' \
  {-m,--max-delay}'=[maximum polling interval in seconds]:max delay' \
  {-b,--backoff}'=[backoff multiplier]:backoff' \
  {-c,--health-check-interval}'=[health check interval in seconds]:interval' \
  {-C,--disable-health-check}'[disable health checks]' \
  {-s,--scheduler-interval}'=[scheduler interval in seconds]:interval' \
  {-l,--logfile}'=[log file path]:log file:_files' \
  {-v,--verbose}'[verbose logging]' \
  {-q,--quiet}'[quiet logging]' \
  {-S,--simple}'[use simple log format]' \
  '1:huey instance (module.huey_instance)' && ret=0

return ret
