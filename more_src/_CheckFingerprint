#compdef CheckFingerprint
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CheckFingerprint
# Picard: check the sample identity of a SAM/BAM/VCF against known genotypes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM or BAM file]:bam:_files -g "*.(bam|sam|vcf|vcf.gz)"' \
  {-O=,--OUTPUT=}'[base name of output files to write]:basename:' \
  {-S=,--SUMMARY_OUTPUT=}'[text file to write summary metrics to]:file:_files' \
  {-D=,--DETAIL_OUTPUT=}'[text file to write detail metrics to]:file:_files' \
  {-G=,--GENOTYPES=}'[file of genotypes (VCF or GELI) for comparison]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  '--SAMPLE_ALIAS=[which sample genotypes to use from the VCF]:sample:' \
  {-H=,--HAPLOTYPE_MAP=}'[haplotype information file]:file:_files' \
  {-LOD=,--GENOTYPE_LOD_THRESHOLD=}'[minimum LOD to count a haplotype]:float:' \
  {-IGNORE_RG=,--IGNORE_READ_GROUPS=}'[treat the entire BAM as one read group]:bool:(true false)' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:input file:_files -g "*.(bam|sam|vcf|vcf.gz)"' && ret=0

return ret
