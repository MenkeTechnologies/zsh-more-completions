#compdef storj

_storj_commands() {
  local -a commands=(
    'access:Manage accesses'
    'share:Share access to objects'
    'cp:Copy files and objects'
    'ls:List objects and prefixes'
    'mb:Make a new bucket'
    'mv:Move objects'
    'rb:Remove a bucket'
    'rm:Remove an object'
    'meta:Manage object metadata'
    'version:Print version'
    'setup:Setup uplink'
  )
  _describe 'command' commands
}

_storj() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--config-dir[Configuration directory]:dir:_directories' \
    '--interactive[Enable interactive mode]' \
    '--verbose[Verbose output]' \
    '1:command:_storj_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        cp)
          _arguments \
            '--recursive[Copy recursively]' \
            '--parallelism[Number of parallel transfers]:num:' \
            '--progress[Show progress]' \
            '--range[Download a specific range]:range:' \
            '--expires[Set expiration time]:time:' \
            '--metadata[Metadata in JSON format]:json:' \
            '*:source or destination:_files'
          ;;
        ls)
          _arguments \
            '--recursive[List recursively]' \
            '--encrypted[List encrypted paths]' \
            '--pending[List pending objects]' \
            '*:path:'
          ;;
        rm)
          _arguments \
            '--recursive[Remove recursively]' \
            '--encrypted[Remove encrypted paths]' \
            '--pending[Remove pending objects]' \
            '*:path:'
          ;;
        mb|rb)
          _arguments '*:bucket:'
          ;;
        access)
          local -a subcmds=(
            'create:Create an access'
            'export:Export an access'
            'import:Import an access'
            'inspect:Inspect an access'
            'list:List saved accesses'
            'register:Register an access'
            'restrict:Restrict an access'
            'revoke:Revoke an access'
            'use:Set default access'
          )
          _describe 'access command' subcmds
          ;;
        share)
          _arguments \
            '--url[Generate a sharing URL]' \
            '--dns[Specify a DNS name]:dns:' \
            '--auth-service[Auth service address]:url:' \
            '--public[Make access public]' \
            '--readonly[Restrict to read-only]' \
            '--writeonly[Restrict to write-only]' \
            '--not-after[Disallow access after]:time:' \
            '--not-before[Disallow access before]:time:' \
            '*:path:'
          ;;
      esac
      ;;
  esac
}

_storj "$@"
