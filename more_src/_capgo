#compdef capgo
# Documentation: https://capgo.app/docs/cli/commands/
# Live updates for Capacitor apps (@capgo/cli)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'init:onboard step-by-step (add app, build, upload)'
      'login:store API key for authentication'
      'doctor:check package updates and system status'
      'app:manage apps (add set list delete debug setting)'
      'bundle:manage bundles (upload list delete cleanup encrypt decrypt zip)'
      'channel:manage channels (add delete list set)'
      'key:manage encryption keys (create save)'
      'account:account information'
    )
    _describe -t commands 'capgo command' cmds && ret=0
    ;;
esac

return ret
