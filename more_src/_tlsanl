#compdef tlsanl
# CCP4: analyse TLS group parameters and derive anisotropic tensors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZOUT[output coordinates with anisotropic tensors]:output:_files' \
  'TLSIN[input TLS group/tensor file]:tls:_files' \
  'AXES[output axes file]:axes:_files' \
  'SKTOUT[output SKTTLS test results file]:output:_files' \
  '*:file:_files' && ret=0

return ret
