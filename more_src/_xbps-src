#compdef xbps-src

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-a[cross compile to target]:target' \
  '-C[do not clean after build]' \
  '-f[force build]' \
  '-G[enable git revisions]' \
  '-g[enable debug packages]' \
  '-H[use specified hostdir]:directory:_directories' \
  '-j[number of parallel jobs]:jobs' \
  '-L[disable the use of remote repositories]' \
  '-m[use specified masterdir]:directory:_directories' \
  '-N[disable use of remote repositories for dependencies]' \
  '-o[set build option]:option' \
  '-Q[enable quiet operation]' \
  '-t[create a temporary masterdir]' \
  '1:command:(binary-bootstrap bootstrap bootstrap-update build build-environment bump-pkgver chroot clean configure consistency-check edit extract fetch install list patch pkg purge-distfiles remove remove-autodeps show show-avail show-build-deps show-deps show-files show-options show-shlib-provides show-shlib-requires show-var sort-dependencies update-bulk update-check update-sys zap)' \
  '2:package' && ret=0

return ret
