#compdef txt2tags
# Documentation: https://man.archlinux.org/search?q=txt2tags
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --config-file)'{-C,--config-file}'+[config file]:file:_files' \
  '(-H --no-headers)'{-H,--no-headers}'[no headers in output]' \
  '(-i --infile)'{-i,--infile}'+[input file]:file:_files' \
  '(-n --enum-title)'{-n,--enum-title}'[enumerate titles]' \
  '(-o --outfile)'{-o,--outfile}'+[output file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-t --target)'{-t,--target}'+[target format]:format:(adoc art bbcode creole dbk doku gwiki html htmltable lout man mgp moin pm6 pmw pmwiki sgml tex txt2t txwiki wiki xhtml dotclear)' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(--art-chars)--art-chars=+[ASCII art chars]:chars:' \
  '(--mask-email)--mask-email[mask emails]' \
  '(--no-mask-email)--no-mask-email[do not mask emails]' \
  '(--no-toc)--no-toc[do not include TOC]' \
  '(--toc)--toc[include TOC]' \
  '(--toc-only)--toc-only[output only TOC]' \
  '(--toc-level)--toc-level=+[TOC depth]:n:' \
  '(--rc)--rc[use ~/.txt2tagsrc]' \
  '(--no-rc)--no-rc[do not use rc file]' \
  '(--no-encoding)--no-encoding[do not set encoding]' \
  '(--encoding)--encoding=+[set encoding]:enc:' \
  '(--style)--style=+[stylesheet]:file:_files' \
  '(--css-sugar)--css-sugar[generate CSS-friendly markup]' \
  '(--css-inside)--css-inside[include stylesheet inline]' \
  '(--no-css-inside)--no-css-inside[link stylesheet]' \
  '(--gui)--gui[run GUI]' \
  '(--strict)--strict[strict mode]' \
  '*:file:_files -g "*.t2t"' && ret=0

return ret
