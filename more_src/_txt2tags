#compdef txt2tags
# Documentation: https://txt2tags.org/manpage.html
# Reference accessed: 2026-05-21
# Verified: txt2tags upstream manpage.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --config-file)'{-C,--config-file}'+[config file]:file:_files' \
  '(-H --no-headers)'{-H,--no-headers}'[no headers in output]' \
  '(-i --infile)'{-i,--infile}'+[input file]:file:_files' \
  '(-n --enum-title)'{-n,--enum-title}'[enumerate titles]' \
  '(-o --outfile)'{-o,--outfile}'+[output file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-t --target)'{-t,--target}'+[target format]:format:(adoc asciidoc creole doku dokuwiki dbk docbook gwiki html html5 latex lout man mgp moin pm6 pmwiki sgml tex txt wiki xhtml)' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '--art-chars=[ASCII art chars]:chars:' \
  '--mask-email[mask emails]' \
  '--no-mask-email[do not mask emails]' \
  '--no-toc[do not include TOC]' \
  '--toc[include TOC]' \
  '--toc-only[output only TOC]' \
  '--toc-level=[TOC depth]:n:' \
  '--rc[use ~/.txt2tagsrc]' \
  '--no-rc[do not use rc file]' \
  '--no-encoding[do not set encoding]' \
  '--encoding=[set encoding]:enc:' \
  '--style=[stylesheet]:file:_files' \
  '--css-sugar[generate CSS-friendly markup]' \
  '--css-inside[include stylesheet inline]' \
  '--gui[run GUI]' \
  '--slides[enable slides]' \
  '--no-slides[disable slides]' \
  '--targets[list targets]' \
  '--no-targets[do not list targets]' \
  '--dump-config[dump config]' \
  '--dump-source[dump source]' \
  '--width=[output width]:n:' \
  '--height=[output height]:n:' \
  '*:file:_files -g "*.t2t"' && ret=0

return ret
