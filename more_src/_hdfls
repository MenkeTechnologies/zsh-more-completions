#compdef hdfls
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hdfls.1.en.html
# List the contents (tags and reference numbers) of an HDF file

local ret=1

_arguments -s \
  '-o[display reference numbers in ascending order]' \
  '-l[long format, display more information]' \
  '-d[display offset and length for each element]' \
  '-v[verbose, display annotation and label text]' \
  '-g[group, list items by group]' \
  '-s[display detailed info about special elements]' \
  '-h[dump DD block information]' \
  '-t+[only list information about the specified tag number]:tag number' \
  '1:hdf file:_files -g "*.(hdf|h4)"' && ret=0

return ret
