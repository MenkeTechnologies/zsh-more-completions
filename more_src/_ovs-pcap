#compdef ovs-pcap ovs-tcpundump
# Documentation: https://man.archlinux.org/search?q=ovs-pcap
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*: :_files -g "*.pcap *.cap"' && ret=0

return ret
