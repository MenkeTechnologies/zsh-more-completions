#compdef js jsshell
# _spidermonkey-cli — SpiderMonkey JavaScript engine shell (Mozilla); REPL+scriptable shell for Mozilla's JS engine
# upstream: https://spidermonkey.dev

_spidermonkey-cli() {
    _arguments \
        '-h[show help]' \
        '-v+[ECMAScript version]:ver:(170 180 185)' \
        '-V[print version]' \
        '-e+[expression]:expr:' \
        '-f+[script file]:file:_files -g "*.js"' \
        '-c[only compile, do not run]' \
        '-i[interactive shell]' \
        '-w[warnings on]' \
        '-W[disable warnings]' \
        '-s[strict mode]' \
        '-S+[stack size]:n:' \
        '-x[XML extensions on]' \
        '-X[XML extensions off]' \
        '-d[debug]' \
        '-D[print info on diagnostic switches]' \
        '-z[set zeal level]' \
        '--no-jit[disable JIT]' \
        '--no-baseline[disable Baseline JIT]' \
        '--no-ion[disable IonMonkey]' \
        '--enable-cse[enable CSE]' \
        '--ion-warmup-threshold=+[ion warmup threshold]:n:' \
        '--baseline-warmup-threshold=+[baseline warmup threshold]:n:' \
        '*:script:_files -g "*.js"'
}

_spidermonkey-cli "$@"
