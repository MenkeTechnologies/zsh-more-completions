#compdef abinit anaddb mrgddb mrggkk mrgscr fold2Bloch atdep optic
# _abinit — ABINIT collaboration abinit DFT plane-wave pseudopotentials and projector augmented wave PAW electronic structure code (abinit team, Fortran); custom argparse
# upstream: https://github.com/abinit/abinit

_abinit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i+[input file]:file:_files -g "*.in *.abi"' \
        '--input=+[input file]:file:_files -g "*.in *.abi"' \
        '-o+[output file]:file:_files -g "*.out *.abo"' \
        '--output=+[output file]:file:_files -g "*.out *.abo"' \
        '-l+[log file]:file:_files -g "*.log"' \
        '--log=+[log file]:file:_files -g "*.log"' \
        '--longoutput[long output]' \
        '-t[test mode]' \
        '--timelimit=+[seconds]:n:' \
        '-d[debug]' \
        '--dry-run[dry run]' \
        '--enable-gpu[enable GPU]' \
        '--gpu-id=+[gpu id]:n:' \
        '--mpi-time=+[time]:str:' \
        '--abimem-level=+[level]:l:(0 1 2 3 4)' \
        '--profile=+[profile]:str:' \
        '--xc=+[functional]:f:(LDA PBE PBEsol HSE06 B3LYP HSE03 vdW-DF-cx SCAN rev-SCAN r2SCAN)' \
        '--basis=+[basis]:b:(planewave wavelet localized)' \
        '--paw=+[bool]:b:(true false)' \
        '--vdw=+[bool]:b:(true false)' \
        '--spin=+[bool]:b:(true false)' \
        '--noncoll[non-collinear]' \
        '--mpi-nproc=+[N]:n:' \
        '--omp-nthreads=+[N]:n:' \
        '-F+[files file]:file:_files' \
        '--files=+[files file]:file:_files' \
        '*:input file:_files -g "*.in *.abi *.files"'
}

_abinit "$@"
