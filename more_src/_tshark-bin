#compdef tshark
# _tshark-bin — Wireshark CLI packet analyzer (Wireshark Foundation); capture and dump packet traces
# upstream: https://gitlab.com/wireshark/wireshark

_tshark-bin() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-i+[interface]:iface:_net_interfaces' \
        '-D[list interfaces]' \
        '-L[list link layer types]' \
        '--list-time-stamp-types[list time stamp types]' \
        '--time-stamp-type+[time stamp type]:type:' \
        '-f+[capture filter]:filter:' \
        '-s+[snaplen bytes]:n:' \
        '-p[no promiscuous]' \
        '-I[monitor mode]' \
        '-B+[buffer size MiB]:n:' \
        '-y+[link layer type]:type:' \
        '-c+[stop after N packets]:n:' \
        '-a+[autostop condition]:cond:' \
        '-b+[ring buffer option]:opt:' \
        '-w+[write to file]:file:_files' \
        '-r+[read from file]:file:_files' \
        '-2[two-pass analysis]' \
        '-Y+[display filter]:filter:' \
        '-T+[output format]:fmt:(ek fields json jsonraw pdml ps psml tabs text)' \
        '-e+[field]:field:' \
        '-E+[option=value]:str:' \
        '-V[verbose dissect]' \
        '-O+[protocols to expand]:protos:' \
        '-x[print hex dump]' \
        '-q[quiet]' \
        '-Q[really quiet]' \
        '-X+[extension option]:str:' \
        '-z+[stat]:stat:' \
        '-d+[decode as]:str:' \
        '-K+[Kerberos keytab]:file:_files' \
        '-n[disable name resolution]' \
        '-N+[name resolution flags]:flags:' \
        '-G[print available glossaries]' \
        '*:capture filter:'
}

_tshark-bin "$@"
