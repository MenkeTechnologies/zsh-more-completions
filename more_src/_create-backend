#compdef create-backend
# Documentation: https://www.npmjs.com/package/create-backend
# Reference accessed: 2026-05-24
# Verified: npm view create-backend bin; npm readme Advanced Usage table.

# Zsh completion for create-backend - Node.js REST/socket backend scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--name=[project name]:name:' \
  '--db=[database engine]:database:(mysql mariadb mssql postgres mysql_ns)' \
  '--example=[example endpoint preset]:example:(none)' \
  '--aliases=[use module require aliases]:aliases:(none)' \
  '--license=[project license id]:license:' \
  '--port=[HTTP listen port]:port:' \
  ':project name:' && ret=0

return ret
