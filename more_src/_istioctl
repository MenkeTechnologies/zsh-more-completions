#compdef istioctl
# Documentation: https://github.com/istio/istio (istioctl/cmd/root.go cobra rootCmd)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'kube-inject:inject sidecar proxies into Kubernetes manifests'
  'experimental:container for experimental/unstable commands'
  'proxy-config:retrieve proxy configuration from Envoy sidecars'
  'admin:access administrative functions'
  'mesh:manage Istio mesh installation'
  'waypoint:manage waypoint proxies (ambient mode)'
  'ztunnel-config:view ztunnel configuration (ambient mode)'
  'analyze:validate Istio configuration for potential issues'
  'dashboard:open Istio dashboards in a browser'
  'manifest:generate or manage installation manifests'
  'install:deploy Istio to a cluster'
  'upgrade:update an existing Istio installation'
  'bug-report:collect diagnostic information for troubleshooting'
  'tag:manage revision tags for canary deployments'
  'create-remote-secret:create credentials for multi-cluster access'
  'clusters:display connected cluster information'
  'docs:generate documentation'
  'validate:validate Kubernetes manifests against Istio schemas'
  'options:display all available CLI flags and options'
  'version:show version information'
  'completion:generate shell completion'
  'help:show help for a subcommand'
)

local -a _root_flags
_root_flags=(
  '(-c --context)'{-c,--context=}'[name of kubeconfig context to use]:context:'
  '--kubeconfig=[path to kubeconfig file]:file:_files'
  '(-n --namespace)'{-n,--namespace=}'[Kubernetes namespace]:namespace:'
  '(-i --istioNamespace)'{-i,--istioNamespace=}'[Istio system namespace]:namespace:'
  '--as=[user to impersonate]:user:'
  '--as-uid=[UID for impersonation]:uid:'
  '*--as-group=[groups to impersonate]:group:'
  '--kube-api-timeout=[Kubernetes client timeout]:duration:'
  '--vklog=[number for V logs level]:level:'
  '--log_output_level=[log scope:level]:scope\:level:'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -C \
  $_root_flags \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'istioctl subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _proxy_config _admin _waypoint _experimental _mesh
    _proxy_config=(
      'all:retrieve all configuration from Envoy'
      'bootstrap:retrieve bootstrap configuration'
      'cluster:retrieve cluster configuration'
      'ecds:retrieve ECDS configuration'
      'endpoint:retrieve endpoint configuration'
      'listener:retrieve listener configuration'
      'log:manage proxy log levels'
      'route:retrieve route configuration'
      'rootca-compare:compare root CAs of two pods'
      'secret:retrieve secret configuration'
    )
    _admin=(
      'log:manage log levels of istiod loggers'
    )
    _waypoint=(
      'apply:apply a waypoint'
      'delete:delete a waypoint'
      'generate:generate a waypoint config'
      'list:list waypoints'
      'status:show waypoint status'
    )
    _experimental=(
      'authz:authorization policy commands'
      'check-inject:check whether sidecar injection will be applied'
      'create-remote-secret:create remote-secret for multi-cluster'
      'describe:describe pod/service'
      'envoy-stats:retrieve Envoy stats'
      'injector:list/manage injector webhooks'
      'metrics:metrics for workload'
      'precheck:precheck cluster for Istio install'
      'proxystatus:proxy status'
      'remote-clusters:list registered remote clusters'
      'wait:wait for resources to be ready'
      'workload:workload management'
    )
    _mesh=(
      'uninstall:uninstall Istio from a cluster'
    )
    case $line[1] in
      proxy-config) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'proxy-config' _proxy_config && ret=0 ;;
      admin) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'admin' _admin && ret=0 ;;
      waypoint) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'waypoint' _waypoint && ret=0 ;;
      experimental|x) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'experimental' _experimental && ret=0 ;;
      mesh) _arguments $_root_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'mesh' _mesh && ret=0 ;;
      completion) _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac
    ;;
esac

return ret
