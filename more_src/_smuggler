#compdef smuggler
# _smuggler — Defparam smuggler CLI HTTP request smuggling vulnerability scanner for HTTP/1.1 backend-frontend desync attack pattern probing TE.CL CL.TE TE.TE chunk-extension obfuscation header-folding leading-zero invalid-chunk-length probe variants for proxy CDN load-balancer mismatch detection (Defparam team, Python); argparse
# upstream: https://github.com/defparam/smuggler

_smuggler() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-u+[url]:str:' \
        '--url=+[url]:str:' \
        '-v+[verbosity]:l:(0 1 2 3)' \
        '--verbosity=+[level]:l:(0 1 2 3)' \
        '-l+[input file]:file:_files' \
        '--list=+[file]:file:_files' \
        '-x+[proxy]:str:' \
        '--proxy=+[url]:str:' \
        '-c+[config]:file:_files -g "*.json"' \
        '--config=+[file]:file:_files -g "*.json"' \
        '-m+[method]:m:(GET POST PUT DELETE PATCH OPTIONS HEAD CONNECT TRACE)' \
        '--method=+[m]:m:(GET POST PUT DELETE PATCH OPTIONS HEAD CONNECT TRACE)' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-t+[test type]:t:(default exhaustive minimal)' \
        '--test=+[t]:t:(default exhaustive minimal)' \
        '--no-color[disable color output]' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '*:url:'
}

_smuggler "$@"
