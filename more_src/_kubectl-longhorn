#compdef kubectl-longhorn
# Documentation: https://github.com/longhorn/cli/blob/master/docs/longhornctl.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--namespace=[Kubernetes namespace]:namespace:' \
  '--kubeconfig=[Kubernetes config path]:file:_files' \
  '--image=[image containing longhornctl-local]:image:' \
  '--image-pull-secret=[image pull secret]:secret:' \
  '--image-registry=[image registry]:registry:' \
  '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(trace debug info warn error fatal panic)' \
  '--node-selector=[node selector]:selector:' \
  '--tolerations=[pod tolerations]:tolerations:' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'check:Longhorn checking operations'
      'checksum:snapshot checksum operations'
      'doc:generate markdown documentation for the CLI'
      'export:export Longhorn resources'
      'get:Longhorn information gathering operations'
      'global-options:display global options inherited by all subcommands'
      'install:Longhorn installation operations'
      'trim:Longhorn trimming operations'
      'version:print longhornctl version'
    )
    _describe -t commands 'kubectl-longhorn command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
