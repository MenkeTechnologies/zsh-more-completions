_bittorrent-tracker() {
    _arguments -s -S \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[print the current version]' \
        '(-p --port)'{-p,--port=}'[change the port (default 8000)]:port:' \
        '--http-hostname=[change the HTTP server hostname (default ::)]:hostname:' \
        '--udp-hostname=[change the UDP hostname (default 0.0.0.0)]:hostname:' \
        '--udp6-hostname=[change the UDP6 hostname (default ::)]:hostname:' \
        "--trust-proxy[trust 'x-forwarded-for' header from reverse proxy]" \
        '--interval=[client announce interval in ms (default 600000)]:milliseconds:' \
        '--http[enable HTTP tracker (BEP 0003 standard tracker protocol)]' \
        '--udp[enable UDP tracker (BEP 0015 UDP tracker protocol)]' \
        '--ws[enable WebSocket tracker for browser WebRTC peers]' \
        '--stats[enable web-based statistics at /stats and /stats.json (default true)]' \
        '--no-stats[disable web-based statistics]' \
        '(-q --quiet)'{-q,--quiet}'[only show error output]' \
        '(-s --silent)'{-s,--silent}'[show no output]'
}

_bittorrent-tracker "$@"
