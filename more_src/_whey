#compdef whey
# Documentation: https://pypi.org/project/whey/
# simple Python wheel/sdist builder for simple projects

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show the version and exit]' \
  '(-s --sdist)'{-s,--sdist}'[build a source distribution]' \
  '(-w --wheel)'{-w,--wheel}'[build a wheel]' \
  '(-b --binary)'{-b,--binary}'[build a binary distribution]' \
  '(-B --builder)'{-B,--builder}'+[the builder to build with]:builder' \
  '--build-dir=[the temporary build directory]:dir:_files -/' \
  '(-o --out-dir)'{-o,--out-dir}'+[the output directory]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-S --show-builders)'{-S,--show-builders}'[show the builders which will be used, and exit]' \
  '(--colour --no-colour)--colour[use coloured output]' \
  '(--colour --no-colour)--no-colour[disable coloured output]' \
  '(-T --traceback)'{-T,--traceback}'[show the complete traceback on error]' \
  '*:project:_files -/' && ret=0

return ret
