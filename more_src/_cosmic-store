#compdef cosmic-store
# _cosmic-store — COSMIC desktop application store (pop-os/cosmic-store)
# upstream: https://github.com/pop-os/cosmic-store
# Flags from src/main.rs (clap derive Cli).

_cosmic-store() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--transient-for=[X11/Wayland window-id to be transient for]:wid:' \
        '--interaction=[gst-install-plugins-helper interaction mode]:mode:' \
        '--desktop-id=[XDG desktop ID]:id:' \
        '--startup-notification-id=[startup notification ID]:id:' \
        '1:subcommand or package id:'
}

_cosmic-store "$@"
