#compdef delv-tool
# _delv-tool — delv wrapper helper (small wrapper around delv(1) that pre-loads the standard managed trust-anchors file and forces +rtrace +mtrace +vtrace by default; -a anchor file, -p port, -t qtype, -c qclass, -4/-6 family, -x reverse, -i insecure mode, -b source addr; positional QNAME [QTYPE] [@SERVER])
# upstream: https://github.com/isc-projects/bind9 (delv)
# Flags from isc-projects/bind9 bin/delv on tip.

_delv-tool() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-a+[anchor file]:file:_files' \
        '-p+[port]:port:' \
        '-t+[qtype]:type:(A AAAA NS MX TXT CNAME PTR SOA DS DNSKEY RRSIG NSEC NSEC3 CAA TLSA SVCB HTTPS SRV ANY)' \
        '-c+[qclass]:class:(IN CH HS)' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-x[reverse lookup]' \
        '-i[insecure mode]' \
        '-b+[source address]:addr:' \
        '1:qname:' \
        '2::qtype:(A AAAA NS MX TXT CNAME PTR SOA DS DNSKEY RRSIG NSEC NSEC3 CAA TLSA SVCB HTTPS SRV ANY)' \
        '3::server:_hosts'
}

_delv-tool "$@"
