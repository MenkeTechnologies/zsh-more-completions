#compdef kubectl-envsubst
# Documentation: https://github.com/hashmap-kz/kubectl-envsubst
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--envsubst-allowed-vars=[comma-separated list of variable names allowed for substitution]:vars:' \
  '--envsubst-allowed-prefixes=[comma-separated list of variable name prefixes to allow]:prefixes:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace (passed to kubectl apply)]:namespace:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context to use]:context:' \
  '*:kubectl apply arguments:_default'
