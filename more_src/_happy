#compdef happy

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-o --outfile)'{-o+,--outfile=}'[output file (- for stdout)]:file:_files' \
  '(-i --info)'{-i+,--info=}'[write info/debug report to file]:file:_files' \
  '(-p --pretty)'{-p+,--pretty=}'[pretty-print to file]:file:_files' \
  '(-t --template)'{-t+,--template=}'[parser template directory]:dir:_files -/' \
  '(-m --magic-name)'{-m+,--magic-name=}'[internal symbol prefix]:prefix:' \
  '(-a --array)'{-a,--array}'[array-based shift-reduce parser]' \
  '(-g --ghc)'{-g,--ghc}'[use GHC extensions for speed]' \
  '(-c --coerce)'{-c,--coerce}'[use unsafeCoerce# (requires --ghc)]' \
  '(-d --debug)'{-d,--debug}'[generate a debugging parser]' \
  '(-l --glr)'{-l,--glr}'[generate a GLR parser]' \
  '(-k --decode)'{-k,--decode}'[GLR: emit decode helpers]' \
  '(-f --filter)'{-f,--filter}'[GLR: prune unused forest nodes]' \
  '--strict[generate a strict parser]' \
  '*:happy_file:_files -g "*.{y,ly}"' && ret=0

return ret
