#compdef nest
# _nestjs-cli — NestJS Node.js TypeScript framework CLI (Kamil Mysliwiec); Angular-inspired modular server framework
# upstream: https://github.com/nestjs/nest-cli

_nestjs-cli() {
    local -a sub=(
        'new:create new project'
        'n:alias for new'
        'add:add a Nest library'
        'build:build the project'
        'generate:generate code from blueprint'
        'g:alias for generate'
        'info:print env info'
        'i:alias for info'
        'start:run the app'
        's:alias for start'
        'update:update Nest deps'
        'u:alias for update'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nest subcommand' sub ;;
        args)
            case $words[1] in
                new|n) _arguments \
                    '(-d --dry-run)'{-d,--dry-run}'[dry run]' \
                    '(-g --skip-git)'{-g,--skip-git}'[skip git init]' \
                    '(-s --skip-install)'{-s,--skip-install}'[skip install]' \
                    '(-p --package-manager)'{-p,--package-manager}'+[package manager]:pm:(npm yarn pnpm bun)' \
                    '(-l --language)'{-l,--language}'+[language]:lang:(ts js)' \
                    '(-c --collection)'{-c,--collection}'+[schematics collection]:name:' \
                    '--strict[strict mode]' \
                    '1:project name:' ;;
                generate|g) _arguments \
                    '(-d --dry-run)'{-d,--dry-run}'[dry run]' \
                    '(-p --project)'{-p,--project}'+[project]:project:' \
                    '(-c --collection)'{-c,--collection}'+[collection]:name:' \
                    '--no-spec[skip spec file]' \
                    '--no-flat[generate in own dir]' \
                    '--flat[flat file]' \
                    '--spec[generate spec file]' \
                    '1:schematic:(application class configuration controller decorator filter gateway guard interceptor interface library middleware module pipe provider resolver resource service sub-app)' \
                    '*:name:' ;;
                build) _arguments \
                    '(-c --config)'{-c,--config}'+[nest config]:file:_files' \
                    '(-w --watch)'{-w,--watch}'[watch]' \
                    '(--webpack)--webpack[use webpack]' \
                    '(--webpackPath)--webpackPath+[webpack config]:file:_files' \
                    '(-p --path)'{-p,--path}'+[tsconfig path]:file:_files' \
                    '--watchAssets[watch assets]' \
                    '--builder+[builder]:builder:(tsc webpack swc)' \
                    '--tsc[force tsc]' ;;
                start|s) _arguments \
                    '(-c --config)'{-c,--config}'+[nest config]:file:_files' \
                    '(-w --watch)'{-w,--watch}'[watch and restart]' \
                    '(-b --builder)'{-b,--builder}'+[builder]:builder:(tsc webpack swc)' \
                    '(-d --debug)'{-d,--debug}'[node --inspect]' \
                    '(-e --exec)'{-e,--exec}'+[exec runner]:cmd:_command_names -e' \
                    '(-p --path)'{-p,--path}'+[tsconfig path]:file:_files' \
                    '--preserveWatchOutput[preserve watch output]' \
                    '--type-check[do type-check]' \
                    '--watchAssets[watch assets]' \
                    '*:entry:_files' ;;
                add|i|info|update|u) _arguments '*:lib:' ;;
            esac
            ;;
    esac
}

_nestjs-cli "$@"
