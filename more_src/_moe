#compdef moe
# _moe — Vim-inspired terminal editor written in Nim (fox0430/moe)
# upstream: https://github.com/fox0430/moe

_moe() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help and exit]'
        '(- *)'{-v,--version}'[show version and exit]'
        '--read-only[open files read-only]'
        '--config=[path to moerc configuration file]:file:_files -g "*.toml"'
        '--debug[enable debug output]'
        '*:file to edit:_files'
    )
    _arguments -s -S $args
}

_moe "$@"
