#compdef clippy-driver
# Documentation: clippy-driver --help
# Source: Rust Clippy — Rust linter (rustc replacement that runs Clippy lints).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--rustc[pass all arguments to rustc unchanged]' \
    '*-W+[warn-by-default lint]:lint:' \
    '*-A+[allow lint]:lint:' \
    '*-D+[deny lint]:lint:' \
    '*-F+[forbid lint]:lint:' \
    '*--edition=[Rust edition]:edition:(2015 2018 2021 2024)' \
    '*--cfg=[cfg flag]:cfg:' \
    '*--target=[target triple]:triple:' \
    '*-L+[add directory to library search path]:dir:_files -/' \
    '*--extern=[extern crate]:name[=path]:' \
    '*-C+[codegen option]:opt[=value]:' \
    '*-Z+[nightly options]:flag:' \
    '*:Rust source:_files -g "*.rs"' \
    && ret=0

return ret
