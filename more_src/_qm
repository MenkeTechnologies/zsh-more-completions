#compdef qm

# Zsh completion for qm - Proxmox VE VM management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list VMs'
  'create:create or restore a VM'
  'destroy:destroy a VM'
  'start:start a VM'
  'stop:stop a VM'
  'shutdown:shutdown a VM'
  'reboot:reboot a VM'
  'suspend:suspend a VM'
  'resume:resume a suspended VM'
  'reset:reset a VM'
  'status:show VM status'
  'config:show VM configuration'
  'set:set VM options'
  'clone:clone a VM'
  'migrate:migrate a VM to another node'
  'move-disk:move a VM disk to different storage'
  'resize:extend a VM disk'
  'template:create a template'
  'snapshot:manage VM snapshots'
  'rollback:rollback a VM to a snapshot'
  'delsnapshot:delete a snapshot'
  'listsnapshot:list snapshots'
  'monitor:connect to VM monitor'
  'terminal:open a terminal to VM serial device'
  'vncproxy:start VNC proxy'
  'importdisk:import an external disk image'
  'importovf:import a VM from an OVF file'
  'cloudinit:manage cloud-init'
  'guest:manage QEMU guest agent'
  'pending:show pending configuration changes'
  'agent:execute agent commands'
  'cleanup:clean up resources'
  'nbdstop:stop NBD server'
  'remote-migrate:remote migrate a VM'
  'unlock:unlock a VM'
  'wait:wait for VM to reach a state'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'qm command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (create)
        _arguments -s -S \
          '1:VMID' \
          '--name=[VM name]:name' \
          '--memory=[memory in MB]:MB' \
          '--sockets=[number of CPU sockets]:count' \
          '--cores=[number of CPU cores per socket]:count' \
          '--cpu=[CPU type]:type:(host kvm64 qemu64)' \
          '--ostype=[OS type]:type:(l24 l26 win7 win8 win10 win11 wvista wxp other)' \
          '--cdrom=[ISO image]:file' \
          '--ide*=[IDE device]:config' \
          '--scsi*=[SCSI device]:config' \
          '--sata*=[SATA device]:config' \
          '--virtio*=[VirtIO device]:config' \
          '--net*=[network device]:config' \
          '--serial*=[serial device]:config' \
          '--boot=[boot order]:order' \
          '--bios=[BIOS type]:type:(seabios ovmf)' \
          '--machine=[machine type]:type:(pc q35)' \
          '--scsihw=[SCSI hardware type]:type:(lsi virtio-scsi-pci virtio-scsi-single megasas pvscsi)' \
          '--onboot=[start on boot]:enable:(0 1)' \
          '--agent=[QEMU agent]:enable:(0 1)' \
          '--vga=[VGA type]:type:(std cirrus vmware qxl serial0 serial1 serial2 serial3 virtio virtio-gl none)' \
          '--storage=[default storage]:storage' \
          '--pool=[resource pool]:pool' \
          '--start=[start after creation]:enable:(0 1)' && ret=0
        ;;
      (start|stop|shutdown|reboot|suspend|resume|reset|destroy|status|config|pending|unlock)
        _arguments -s -S \
          '1:VMID' && ret=0
        ;;
      (set)
        _arguments -s -S \
          '1:VMID' \
          '--name=[VM name]:name' \
          '--memory=[memory in MB]:MB' \
          '--sockets=[number of CPU sockets]:count' \
          '--cores=[number of CPU cores per socket]:count' \
          '--cpu=[CPU type]:type:(host kvm64 qemu64)' \
          '--onboot=[start on boot]:enable:(0 1)' \
          '--agent=[QEMU agent]:enable:(0 1)' \
          '--description=[description]:text' \
          '--tags=[tags]:tags' \
          '--delete=[delete specified settings]:settings' && ret=0
        ;;
      (clone)
        _arguments -s -S \
          '1:source VMID' \
          '2:new VMID' \
          '--name=[new VM name]:name' \
          '--full[create a full copy]' \
          '--target=[target node]:node' \
          '--storage=[target storage]:storage' \
          '--pool=[resource pool]:pool' \
          '--snapname=[snapshot to clone from]:snapshot' \
          '--format=[disk format]:format:(raw qcow2 vmdk)' && ret=0
        ;;
      (migrate)
        _arguments -s -S \
          '1:VMID' \
          '2:target node' \
          '--online[use online migration]' \
          '--force[allow migration with local devices]' \
          '--with-local-disks[migrate local disks]' \
          '--targetstorage=[target storage]:storage' && ret=0
        ;;
      (move-disk)
        _arguments -s -S \
          '1:VMID' \
          '2:disk:' \
          '--storage=[target storage]:storage' \
          '--format=[disk format]:format:(raw qcow2 vmdk)' \
          '--delete=[delete original disk]:enable:(0 1)' && ret=0
        ;;
      (resize)
        _arguments -s -S \
          '1:VMID' \
          '2:disk:' \
          '3:size:' && ret=0
        ;;
      (template)
        _arguments -s -S \
          '1:VMID' \
          '--disk=[disk to convert]:disk' && ret=0
        ;;
      (snapshot)
        _arguments -s -S \
          '1:subcommand:(create delete list rollback)' \
          '2:VMID' \
          '3:snapname' && ret=0
        ;;
      (importdisk)
        _arguments -s -S \
          '1:VMID' \
          '2:disk image:_files' \
          '3:storage' \
          '--format=[disk format]:format:(raw qcow2 vmdk)' && ret=0
        ;;
      (importovf)
        _arguments -s -S \
          '1:VMID' \
          '2:OVF file:_files -g "*.ovf"' \
          '3:storage' \
          '--format=[disk format]:format:(raw qcow2 vmdk)' && ret=0
        ;;
      (monitor|terminal)
        _arguments -s -S \
          '1:VMID' && ret=0
        ;;
      (wait)
        _arguments -s -S \
          '1:VMID' \
          '--timeout=[timeout in seconds]:seconds' && ret=0
        ;;
      (guest)
        _arguments -s -S \
          '1:subcommand:(cmd exec passwd)' \
          '2:VMID' && ret=0
        ;;
    esac
    ;;
esac

return ret
