#compdef medaka

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'compress_bam:compress a BAM file'
  'features:create features for prediction'
  'inference:run neural network inference'
  'sequence:create consensus sequence'
  'snp:call SNPs'
  'variant:call variants'
  'stitch:stitch predictions'
  'smolecule:single molecule consensus'
  'methylation:call base modifications'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'medaka command' commands && ret=0
    ;;
  args)
    case $line[1] in
      variant|snp)
        _arguments -s -S \
          '-i[input BAM]:file:_files -g "*.bam"' \
          '-f[reference FASTA]:file:_files -g "*.fa(|sta)(|.gz)"' \
          '-o[output directory]:directory:_directories' \
          '-m[model]:model:' \
          '-t[threads]:threads:' \
          '-b[batch size]:size:' \
          '--regions[regions to process]:regions:' \
          '--help[show help]' && ret=0
        ;;
      inference|features)
        _arguments -s -S \
          '-i[input BAM]:file:_files -g "*.bam"' \
          '-o[output file]:file:_files' \
          '-m[model]:model:' \
          '-t[threads]:threads:' \
          '-b[batch size]:size:' \
          '--regions[regions]:regions:' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
