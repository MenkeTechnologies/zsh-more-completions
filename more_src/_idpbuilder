#compdef idpbuilder
# Documentation: upstream pkg/cmd/{create,get,delete}/root.go at github.com/cnoe-io/idpbuilder
# Reference accessed: 2026-05-30
# CNOE idpbuilder R50 — single-binary launcher for a complete internal
# developer platform on top of Kubernetes/Argo/Backstage. Docker is the
# only required dependency.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'create:spin up CNOE IDP cluster'
  'get:fetch cluster/secrets/packages info'
  'delete:tear down the local Kind cluster'
  'version:show version'
)

local -a _get_subs
_get_subs=(
  'clusters:list managed clusters'
  'secrets:list secrets'
  'packages:list installed packages'
)

_arguments -C -s -S \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'idpbuilder subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      create)
        _arguments \
          '--recreate[recreate the cluster]' \
          '--name=[cluster name]:name:' \
          '--build-name=[cluster name (DEPRECATED — use --name)]:name:' \
          '--dev-password[generate a dev password]' \
          '--kube-version=[Kubernetes version]:version:' \
          '--extra-ports=[extra port mappings]:ports:' \
          '--kind-config=[Kind config file]:file:_files' \
          '*--registry-config=[registry config]:config:' \
          '*--registry-mirrors=[registry mirrors]:mirrors:' \
          '--insecure-registry-mirrors[allow insecure registry mirrors]' \
          '--host=[host address]:host:' \
          '--ingress-host-name=[ingress host name]:hostname:' \
          '--protocol=[protocol (http/https)]:protocol:(http https)' \
          '--port=[port]:port:' \
          '--use-path-routing[use path-based routing instead of host-based]' \
          '(-p --package)*-p+[extra packages]:package:' \
          '(-p --package)*--package=[extra packages]:package:' \
          '(-c --package-custom-file)*-c+[package customization files]:file:_files' \
          '(-c --package-custom-file)*--package-custom-file=[package customization files]:file:_files' \
          '(-n --no-exit)-n[do not exit after creation]' \
          '(-n --no-exit)--no-exit[do not exit after creation]' && ret=0
        ;;
      get)
        _arguments -C \
          '(-): :->getcmd' \
          '(-)*:: :->getcmd_args' \
          '(-p --packages)*-p+[package names]:package:' \
          '(-p --packages)*--packages=[package names]:package:' \
          '(-o --output)-o+[output format (default table)]:format:(table json yaml)' \
          '(-o --output)--output=[output format (default table)]:format:(table json yaml)' \
          '--kubeconfig=[kubeconfig file path]:file:_files' && ret=0
        case $state in
          getcmd)
            _describe -t commands 'idpbuilder get subcommand' _get_subs && ret=0
            ;;
        esac
        ;;
      delete)
        _arguments \
          '--name=[Kind cluster name (default localdev)]:name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
