#compdef meterbridge

# meterbridge: JACK metering applications (VU, PPM, DPM, JF, SCO, etc.)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-t[meter type]:type:(vu ppm dpm jf sco)' \
  '-r[refresh rate (Hz)]:hz:' \
  '-n[JACK client name]:name:' \
  '-c[colour scheme]:scheme:(0 1 2)' \
  '-f[font]:font:' \
  '-d[delay between updates]:ms:' \
  '-i[input mode]:mode:' \
  '-w[window size hint]:WxH:' \
  '*:JACK ports:' && ret=0
return ret
