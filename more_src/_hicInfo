#compdef hicInfo
# UCSC kent: retrieve and display header information for a .hic file

local ret=1

_arguments -s -S \
  '-attrs[write out the attribute dictionary for the file]' \
  '-udcDir=[place to put cache for remote bigBed/bigWigs]:dir:_files -/' \
  '1:hic file:_files -g "*.hic"' && ret=0

return ret
