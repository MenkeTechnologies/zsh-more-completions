#compdef gotools
# _gotools — Go x/tools meta dispatcher; runs goimports, gopls, godoc, stringer, etc.
# upstream: https://github.com/golang/tools

_gotools() {
    local -a sub=(
        'godoc:run documentation server'
        'goimports:format + manage imports'
        'gopls:Go language server'
        'gorename:rename identifiers'
        'guru:answer questions about Go source'
        'stringer:generate String() methods'
        'present:Go presentations server'
        'fix:apply automated rewrites'
        'eg:example-based refactoring'
        'callgraph:print call graph'
        'digraph:directed-graph commands'
        'fieldalignment:struct field alignment'
        'getgo:install latest Go'
        'help:show help'
    )
    _arguments -C \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gotools subcommand' sub ;;
    esac
}

_gotools "$@"
