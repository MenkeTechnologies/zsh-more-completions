#compdef bash-language-server

# Zsh completion for bash-language-server

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start the language server'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' && ret=0

case "$state" in
  command)
    _describe -t commands 'bash-language-server command' commands && ret=0
    ;;
esac

return ret
