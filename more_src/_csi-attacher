#compdef csi-attacher external-attacher
# _csi-attacher — Kubernetes CSI external-attacher sidecar (kubernetes-csi/external-attacher)
# upstream: https://github.com/kubernetes-csi/external-attacher
# Flags from cmd/csi-attacher/main.go + csi-lib-utils/standardflags/flags.go on tip.

_csi-attacher() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--kubeconfig=[kubeconfig file (out-of-cluster only)]:file:_files' \
        '--csi-address=[CSI driver UDS path]:path:_files' \
        '--resync=[informer resync interval]:dur:' \
        '--timeout=[per-attach/detach timeout]:dur:' \
        '--retry-interval-start=[initial retry interval]:dur:' \
        '--retry-interval-max=[max retry interval]:dur:' \
        '--worker-threads=[concurrent attacher workers]:n:' \
        '--max-entries=[max entries per ListVolumes page (0 = unlimited)]:n:' \
        '--default-fstype=[default filesystem type]:fs:' \
        '--reconcile-sync=[VolumeAttachment reconciler resync interval]:dur:' \
        '--max-grpc-log-length=[max chars of gRPC response logged (-1 = unlimited)]:n:' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '--leader-election=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--http-endpoint=[diagnostics HTTP host\:port]:host\:port:' \
        '--metrics-path=[Prometheus metrics HTTP path]:path:' \
        '-v[klog verbosity level]:n:'
}

_csi-attacher "$@"
