#compdef func

# Zsh completion for Azure Functions Core Tools

local curcontext="$curcontext" state line ret=1

local -a func_commands
func_commands=(
  'init:create a new Function App'
  'new:create a new function from a template'
  'start:launch the Functions runtime host locally'
  'host:launch the Functions runtime host locally'
  'azure:manage Azure resources'
  'azurecontainerregistry:manage Azure Container Registry'
  'durable:manage Durable Functions'
  'extensions:manage extensions'
  'kubernetes:manage Kubernetes'
  'settings:manage environment settings for the local Functions host'
  'templates:list available templates'
  'logs:gets logs of Functions running on custom backends'
)

local -a func_global_flags
func_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version]'
)

_arguments -s -S \
  $func_global_flags \
  '1:command:_describe -t commands command func_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      init)
        _arguments -s -S \
          $func_global_flags \
          '--worker-runtime=[choose runtime]:runtime:(dotnet dotnet-isolated node python java powershell typescript custom)' \
          '--language=[choose language]:language:(c# f# javascript typescript python powershell java custom)' \
          '-n=[function app name]:name:' \
          '--name=[function app name]:name:' \
          '--docker[generate Dockerfile]' \
          '--docker-only[only generate Dockerfile]' \
          '--no-source-control[skip creating .gitignore]' \
          '--source-control[create .gitignore]' \
          '--csx[use csx dotnet functions]' \
          '--managed-dependencies[install managed dependencies]' \
          '--target-framework=[target framework]:framework:(net6.0 net7.0 net8.0)' \
          '--model=[programming model]:model:(V1 V2 V3 V4)' \
          '1:path:_directories' && ret=0
        ;;
      new)
        _arguments -s -S \
          $func_global_flags \
          '-t=[template name]:template:(HttpTrigger TimerTrigger QueueTrigger ServiceBusQueueTrigger ServiceBusTopicTrigger BlobTrigger CosmosDBTrigger EventGridTrigger EventHubTrigger IoTHubTrigger SendGrid SignalRTrigger DurableFunctionsOrchestrator DurableFunctionsActivity DurableFunctionsEntityHTTP)' \
          '--template=[template name]:template:' \
          '-n=[function name]:name:' \
          '--name=[function name]:name:' \
          '-l=[choose language]:language:(c# f# javascript typescript python powershell java custom)' \
          '--language=[choose language]:language:' \
          '-a=[authorization level]:level:(anonymous function admin)' \
          '--authlevel=[authorization level]:level:(anonymous function admin)' \
          '--csx[use csx template]' \
          '--model=[programming model]:model:(V1 V2 V3 V4)' && ret=0
        ;;
      start|host)
        _arguments -s -S \
          $func_global_flags \
          '-p=[port for the host to listen on]:port:' \
          '--port=[port for the host to listen on]:port:' \
          '--cors=[CORS origins]:origins:' \
          '--cors-credentials[allow cross-origin authenticated requests]' \
          '--timeout=[timeout in seconds]:seconds:' \
          '--useHttps[use HTTPS]' \
          '--cert=[path to certificate]:cert file:_files' \
          '--password=[password for the certificate]:password:' \
          '--language-worker=[language worker arguments]:args:' \
          '--no-build[do not build project before running]' \
          '--build[build the project before running]' \
          '--enableAuth[enable full authentication handling pipeline]' \
          '--functions=[space-separated list of functions to load]:functions:' \
          '--verbose[enable verbose output]' \
          '--dotnet-isolated-debug[wait for debugger to attach]' \
          '--pause-on-error[pause for additional input before exiting on error]' && ret=0
        ;;
      azure)
        local -a azure_commands
        azure_commands=(
          'functionapp:manage function apps'
          'storage:manage storage'
        )
        _arguments -s -S \
          $func_global_flags \
          '1:azure command:_describe -t commands command azure_commands' \
          '*::azure args:->azure_args' && ret=0
        case "$state" in
          azure_args)
            case "${line[1]}" in
              functionapp)
                local -a functionapp_commands
                functionapp_commands=(
                  'fetch-app-settings:download remote settings locally'
                  'list-functions:list functions in a function app'
                  'logstream:stream logs'
                  'publish:publish the current directory to Azure'
                )
                _arguments -s -S \
                  $func_global_flags \
                  '1:functionapp command:_describe -t commands command functionapp_commands' \
                  '*::functionapp args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      extensions)
        local -a extensions_commands
        extensions_commands=(
          'install:install an extension'
          'sync:sync extensions to local'
        )
        _arguments -s -S \
          $func_global_flags \
          '1:extensions command:_describe -t commands command extensions_commands' \
          '*::extensions args:' && ret=0
        ;;
      settings)
        local -a settings_commands
        settings_commands=(
          'add:add a new local setting'
          'decrypt:decrypt local settings'
          'delete:remove a local setting'
          'encrypt:encrypt local settings'
          'list:list local settings'
        )
        _arguments -s -S \
          $func_global_flags \
          '1:settings command:_describe -t commands command settings_commands' \
          '*::settings args:' && ret=0
        ;;
      kubernetes)
        local -a kubernetes_commands
        kubernetes_commands=(
          'deploy:deploy a function app to Kubernetes via KEDA'
          'install:install KEDA in a Kubernetes cluster'
          'remove:uninstall KEDA from a Kubernetes cluster'
        )
        _arguments -s -S \
          $func_global_flags \
          '1:kubernetes command:_describe -t commands command kubernetes_commands' \
          '*::kubernetes args:' && ret=0
        ;;
      durable)
        local -a durable_commands
        durable_commands=(
          'delete-task-hub:delete the task hub'
          'get-history:get the history of an orchestration instance'
          'get-instances:get all orchestration instances'
          'get-runtime-status:get the runtime status of an instance'
          'purge-history:purge orchestration history'
          'raise-event:raise an event to an orchestration'
          'rewind:rewind an orchestration'
          'start-new:start a new orchestration instance'
          'terminate:terminate an orchestration'
        )
        _arguments -s -S \
          $func_global_flags \
          '1:durable command:_describe -t commands command durable_commands' \
          '*::durable args:' && ret=0
        ;;
      templates)
        _arguments -s -S \
          $func_global_flags \
          'list[list available templates]' && ret=0
        ;;
      *)
        _arguments -s -S $func_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
