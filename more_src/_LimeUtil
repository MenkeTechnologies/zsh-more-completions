#compdef LimeUtil

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--info[show device info]' \
  '--find=+[find devices matching]:args:' \
  '--make=+[make device with args]:args:' \
  '--fw=+[upload firmware]:file:_files' \
  '--fpga=+[upload FPGA bitstream]:file:_files' \
  '--update[update firmware and gateware]' \
  '--force[force operations]' \
  '--reset[reset device]' \
  '--calibrate=+[calibrate]:opt:(rx tx)' \
  '--list[list devices]' && ret=0

return ret
