#compdef bareos-bscan
# Documentation: https://docs.bareos.org/Appendix/BareosPrograms.html
# Reference accessed: 2026-05-16
# Verified: Bareos docs Appendix - bscan program reference.
# Removed from prior file: bogus man.archlinux.org search URL.

# bareos-bscan: rescan volumes to recreate catalog database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '(-b --parse-bootstrap)'{-b+,--parse-bootstrap=}'[bootstrap file]:file:_files' \
  '(-c --config)'{-c+,--config=}'[configuration file or directory]:path:_files' \
  '(-D --director)'{-D+,--director=}'[specify director]:director:' \
  '(-d --debug-level)'{-d+,--debug-level=}'[debug level]:level:' \
  '(--dt --debug-timestamps)'{--dt,--debug-timestamps}'[print timestamps in debug output]' \
  '(-n --dbname)'{-n+,--dbname=}'[database name (default bareos)]:dbname:' \
  '(-o --dbhost)'{-o+,--dbhost=}'[database host]:host:_hosts' \
  '(-P --dbpassword)'{-P+,--dbpassword=}'[database password]:password:' \
  '(-t --dbport)'{-t+,--dbport=}'[database port]:port:' \
  '(-u --dbuser)'{-u+,--dbuser=}'[database user]:user:' \
  '(-m --update-volume-info)'{-m,--update-volume-info}'[update media info in database]' \
  '(-p --proceed-io)'{-p,--proceed-io}'[proceed despite IO errors]' \
  '(-r --list-records)'{-r,--list-records}'[list records]' \
  '(-S --show-progress)'{-S,--show-progress}'[show progress]' \
  '(-s --update-db)'{-s,--update-db}'[update database]' \
  '(-V --volumes)'{-V+,--volumes=}'[volumes (vol1|vol2|...)]:volumes:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-w --working-directory)'{-w+,--working-directory=}'[working directory]:dir:_files -/' && ret=0
return ret
