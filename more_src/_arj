#compdef arj
# Documentation: https://manpages.debian.org/bookworm/arj/arj.1.en.html
# Reference accessed: 2026-05-30
# arj — Robert K Jung's ARJ Archiver (now maintained as open-source by the
# arj-software team). Single binary, command-letter dispatch (a/x/e/l/t/etc),
# with a notorious 100+ switch tail organized in `-h*`/`-j*`/`-2*` prefix
# blocks. This completion seeds the 25-command verb table + the most-used
# basic switches; arj power-users can still type the obscure -hf4/-j#3 form
# manually.

local curcontext="$curcontext" state line ret=1

local -a _commands
_commands=(
  'a:add files to archive'
  'x:extract files preserving paths'
  'e:extract files (strip paths)'
  'l:list archive contents'
  'v:verbose list contents'
  't:test archive integrity'
  'p:print files to stdout'
  's:sample files to screen (paged)'
  'd:delete files from archive'
  'f:freshen files in archive'
  'u:update files (newer-than)'
  'm:move files into archive (delete originals)'
  'n:rename files inside archive'
  'o:order files inside archive'
  'r:remove paths from filenames'
  'g:garble (encrypt) files in archive'
  'i:check ARJ program integrity'
  'j:join archives into one'
  'k:remove obsolete backup files'
  'c:comment archive files'
  'b:execute batch/dos command'
  'q:recover damaged ARJ file'
  'w:search for text strings in archive'
  'y:copy archive applying new options'
  'ac:add chapter to chapter-mode archive'
  'cc:convert archive to chapter-mode archive'
  'dc:delete last chapter from archive'
)

_arguments -s -S \
  '(- *)-help[show short help (also `arj h`)]' \
  '-c[skip time-stamp check]' \
  '*-e[exclude paths from names]' \
  '-f[freshen existing files]' \
  '*-g+[set garble password]:password:' \
  '-i[hide progress indicator]' \
  '-m+[compression method (0..4)]:method:(0 1 2 3 4)' \
  '-n[only add files that do not exist in archive]' \
  '-r[recurse into subdirectories]' \
  '-u[update files (new + newer)]' \
  '-v+[multi-volume size]:size-spec:' \
  '-w+[work directory]:dir:_files -/' \
  '*-x+[exclude files matching pattern]:pattern:' \
  '-y[assume yes on all queries]' \
  '-hk[enable ARJ-PROTECT damage protection]' \
  '-hz[create ARJ-SECURITY envelope]' \
  '-jm[maximum compression]' \
  '-jp[pause after each screenful]' \
  '-ji[create index file]' \
  '-je[create self-extracting archive]' \
  '-jf[store full specified path]' \
  '-jt[test temporary archive after operation]' \
  '*-jy[suppress queries (assume yes everywhere)]' \
  '-2d[arj/DOS compatibility mode]' \
  '-2s[preserve symlink properties (UNIX)]' \
  '*-2o[store/restore file ownership (UNIX)]' \
  '1:arj command:->cmd' \
  '2:archive file:_files -g "*.arj"' \
  '*:file:_files' \
  && ret=0

case $state in
  cmd)
    _describe -t commands 'arj command' _commands && ret=0
    ;;
esac

return ret
