#compdef seextrct
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/seextrct.txt
# Create a light curve and/or spectrum from XTE Science Event (SE) data

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input FITS file(s) or @ASCII file]:input file:_files' \
  'gtiorfile=[GTI file for individual input files]:gti file:_files' \
  'gtiandfile=[GTI file applied to all input files]:gti file:_files' \
  'outroot=[root name for output files]:root:' \
  'extenpha=[suffix for spectrum output file]:suffix:' \
  'extenlc=[suffix for light curve output file]:suffix:' \
  'phasefile=[ASCII phase information file]:phase file:_files' \
  'bitfile=[ASCII bitmask expression file for filtering]:bit file:_files' \
  'timecol=[column containing timing data]:column:' \
  'columns=[vector column to bin]:columns:' \
  'binsz=[binning size in seconds]:seconds:' \
  'timezero=[time offset handling]:value:' \
  'printmode=[output type]:mode:(LIGHTCURVE SPECTRUM BOTH)' \
  'lcmode=[light curve binning type]:mode:(SUM RATE MEAN EVENT_SUM EVENT_RATE)' \
  'spmode=[spectrum binning type]:mode:(SUM RATE MEAN EVENT_SUM EVENT_RATE)' \
  'timeint=[time intervals or @file]:intervals:' \
  'gticols=[GTI start/stop column names]:columns:' \
  'chmin=[minimum energy channel]:channel:' \
  'chmax=[maximum energy channel]:channel:' \
  'chint=[channel ranges or @file]:channels:' \
  'clobber=[overwrite existing output files]:flag:(yes no)' \
  'negative=[handle negative values]:mode:(IGNORE SUM)' \
  '*:file:_files' && ret=0

return ret
