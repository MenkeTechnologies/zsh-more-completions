#compdef chpl-shim
# Documentation: https://chapel-lang.org/docs/tools/chpl-language-server/chpl-language-server.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

# chpl-shim wraps a build command to collect Chapel build information into
# a .cls-commands.json file consumed by chpl-language-server. Usage:
#   chpl-shim [--vscode] <build command> [args...]
_arguments -s \
  '--vscode[generate tasks.json for VS Code integration]' \
  '*::build command and args:_command_names -e' && ret=0

return ret
