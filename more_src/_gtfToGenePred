#compdef gtfToGenePred
# UCSC kent: convert a GTF file to a genePred file

local ret=1

_arguments -s -S \
  '-genePredExt[create an extended genePred file including score, alt name, CDS status, exon frames]' \
  '-allErrors[skip groups with errors rather than aborting]' \
  '-ignoreGroupsWithoutExons[skip groups containing no exons rather than error]' \
  '-infoOut=[write a file with information on each transcript]:file:_files' \
  '*-sourcePrefix=[only process entries whose source name has this prefix]:prefix' \
  '-impliedStopAfterCds[implied stop codon after CDS]' \
  '-simple[only check column validity, not hierarchy]' \
  '-geneNameAsName2[use gene_name for the name2 field instead of gene_id]' \
  '1:input gtf:_files' \
  '2:output genePred:_files' && ret=0

return ret
