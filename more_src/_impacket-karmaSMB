#compdef impacket-karmaSMB
# Documentation: https://github.com/fortra/impacket/blob/master/examples/karmaSMB.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-karmaSMB: SMB server that delivers a default file for any client request.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-config[config file mapping extensions to files]:file:_files' \
  '-smb2support[enable SMB2 support (experimental)]' \
  ':default file to serve:_files' && ret=0
return ret
