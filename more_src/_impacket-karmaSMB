#compdef impacket-karmaSMB

# Impacket karmaSMB.py: KARMA-style SMB server (responds to any name)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-ip[server IP]:ip:' \
  '-port[server port]:port:' \
  '-fakeName[fake hostname to advertise]:name:' \
  '-share[share name]:share:' \
  '-smb2support[advertise SMB2 support]' \
  '-comment[share comment]:text:' \
  '-output[log to file]:file:_files' \
  '*:config file:_files' && ret=0
return ret
