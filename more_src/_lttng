#compdef lttng

# Zsh completion for lttng - Linux Trace Toolkit next generation

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add-context:add context fields to a channel'
  'add-trigger:add a trigger'
  'clear:clear a tracing session'
  'create:create a tracing session'
  'destroy:destroy a tracing session'
  'disable-channel:disable a tracing channel'
  'disable-event:disable event rules'
  'disable-rotation:unset a rotation schedule'
  'enable-channel:enable a tracing channel'
  'enable-event:enable event rules'
  'enable-rotation:set a rotation schedule'
  'help:display help for a command'
  'list:list tracing sessions and instrumentation points'
  'list-triggers:list triggers'
  'load:load tracing session configurations'
  'metadata:regenerate tracing session metadata'
  'regenerate:regenerate specific data for a session'
  'remove-trigger:remove a trigger'
  'rotate:archive the current trace chunk'
  'save:save tracing session configurations'
  'set-session:set the current tracing session'
  'snapshot:snapshot a tracing session'
  'start:start tracing'
  'status:get the status of the session daemon'
  'stop:stop tracing'
  'track:track specific system resources'
  'untrack:untrack specific system resources'
  'version:show version information'
  'view:start a trace viewer'
)

_arguments -s -S \
  '1:command:->command' \
  '--group=[set tracing group]:group:_groups' \
  '(-n --no-sessiond)'{-n,--no-sessiond}'[do not spawn a session daemon]' \
  '--sessiond-path=[set session daemon binary path]:path:_files' \
  '--relayd-path=[set relay daemon binary path]:path:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--debug[enable debug output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--list-options[list available options]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'lttng command' commands && ret=0
    ;;
  (args)
    local -a sessions=("${(@f)$(lttng list 2>/dev/null | grep '^ ' | awk '{print $1}')}")
    case $words[1] in
      (create)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'[trace output path]:directory:_files -/' \
          '--no-output[no trace output]' \
          '--snapshot[snapshot mode]' \
          '--live=[live mode with specified timer]:microseconds' \
          '--shm-path=[shared memory path]:path:_files -/' \
          '1:session name' && ret=0
        ;;
      (destroy)
        _arguments -s -S \
          '--no-wait[do not wait for data availability]' \
          '(-a --all)'{-a,--all}'[destroy all sessions]' \
          '1:session name:compadd -a sessions' && ret=0
        ;;
      (start|stop|clear|rotate)
        _arguments '1:session name:compadd -a sessions' && ret=0
        ;;
      (enable-event)
        _arguments -s -S \
          '(-s --session)'{-s,--session}'[session name]:session:compadd -a sessions' \
          '(-c --channel)'{-c,--channel}'[channel name]:channel' \
          '(-k --kernel)'{-k,--kernel}'[kernel tracing]' \
          '(-u --userspace)'{-u,--userspace}'[user-space tracing]' \
          '(-j --jul)'{-j,--jul}'[JUL tracing]' \
          '(-l --log4j)'{-l,--log4j}'[Log4j tracing]' \
          '(-p --python)'{-p,--python}'[Python tracing]' \
          '(-a --all)'{-a,--all}'[all events/tracepoints]' \
          '--tracepoint[tracepoint event rule]' \
          '--syscall[system call event rule]' \
          '--probe=[dynamic probe]:location' \
          '--userspace-probe=[user-space probe]:location' \
          '--function=[dynamic function entry/return probe]:location' \
          '(-x --exclude)'{-x,--exclude}'[exclude events]:events' \
          '--loglevel=[log level]:level' \
          '--loglevel-only=[specific log level]:level' \
          '--filter=[event filter expression]:expression' \
          '*:event name' && ret=0
        ;;
      (disable-event)
        _arguments -s -S \
          '(-s --session)'{-s,--session}'[session name]:session:compadd -a sessions' \
          '(-c --channel)'{-c,--channel}'[channel name]:channel' \
          '(-k --kernel)'{-k,--kernel}'[kernel domain]' \
          '(-u --userspace)'{-u,--userspace}'[user-space domain]' \
          '(-a --all)'{-a,--all}'[all events]' \
          '*:event name' && ret=0
        ;;
      (enable-channel)
        _arguments -s -S \
          '(-s --session)'{-s,--session}'[session name]:session:compadd -a sessions' \
          '(-k --kernel)'{-k,--kernel}'[kernel domain]' \
          '(-u --userspace)'{-u,--userspace}'[user-space domain]' \
          '--overwrite[overwrite mode (flight recorder)]' \
          '--discard[discard mode]' \
          '--subbuf-size=[sub-buffer size]:size' \
          '--num-subbuf=[number of sub-buffers]:count' \
          '--switch-timer=[switch timer interval]:microseconds' \
          '--read-timer=[read timer interval]:microseconds' \
          '--output=[channel output]:output:(mmap splice)' \
          '--tracefile-size=[trace file size]:bytes' \
          '--tracefile-count=[trace file count]:count' \
          '1:channel name' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '(-k --kernel)'{-k,--kernel}'[list kernel events]' \
          '(-u --userspace)'{-u,--userspace}'[list user-space events]' \
          '(-j --jul)'{-j,--jul}'[list JUL events]' \
          '(-l --log4j)'{-l,--log4j}'[list Log4j events]' \
          '(-p --python)'{-p,--python}'[list Python events]' \
          '(-c --channel)'{-c,--channel}'[channel name]:channel' \
          '1:session name:compadd -a sessions' && ret=0
        ;;
      (snapshot)
        local -a snapshot_commands=(
          'add-output:add a snapshot output'
          'del-output:delete a snapshot output'
          'list-output:list snapshot outputs'
          'record:record a snapshot'
        )
        _arguments '1:snapshot command:->snap_cmd' && ret=0
        if [[ $state == snap_cmd ]]; then
          _describe -t commands 'snapshot command' snapshot_commands && ret=0
        fi
        ;;
      (set-session)
        _arguments '1:session name:compadd -a sessions' && ret=0
        ;;
      (save)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[overwrite existing configuration]' \
          '(-o --output-path)'{-o,--output-path}'[output path]:path:_files' \
          '(-a --all)'{-a,--all}'[save all sessions]' \
          '1:session name:compadd -a sessions' && ret=0
        ;;
      (load)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[force load even with errors]' \
          '(-i --input-path)'{-i,--input-path}'[input path]:path:_files' \
          '(-a --all)'{-a,--all}'[load all sessions]' \
          '1:session name' && ret=0
        ;;
    esac
    ;;
esac

return ret
