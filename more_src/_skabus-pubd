#compdef skabus-pubd
# _skabus-pubd — skabus publish-subscribe bus daemon (clients PUBLISH bytes to topics and SUBSCRIBE to matching topics; persistent per-topic msgfs directory backs durable subscriptions)
# upstream: https://github.com/skarnet/skabus
# Flags from src/pub/skabus-pubd.c on tip.

_skabus-pubd() {
    _arguments \
        '-v+[verbosity]:n:' \
        '-1[print socket info on fd 1 when ready]' \
        '-c+[max simultaneous clients]:n:' \
        '-t+[per-request timeout (ms)]:ms:' \
        '-T+[lame-duck timeout (ms)]:ms:' \
        '(-i -x)-i+[accessrules directory]:dir:_files -/' \
        '(-i -x)-x+[accessrules cdb file]:file:_files' \
        '(-S -s)-S[skip cleanup on lame-duck]' \
        '(-S -s)-s[clean up on lame-duck (default)]' \
        '-k+[control-topic regex (administrative pub/sub control plane)]:regex:' \
        '-m+[max persistent fds (msgfs cache)]:n:' \
        '1:msgfsdir:_files -/'
}

_skabus-pubd "$@"
