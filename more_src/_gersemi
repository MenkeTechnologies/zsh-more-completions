#compdef gersemi

# https://github.com/BlankSpruce/gersemi — argparse (gersemi/__main__.py)
_arguments -s -S   '(-h --help)'{-h,--help}'[help]'   '--version[show versions]'   '(-c --check)'{-c,--check}'[check formatting]'   '(-i --in-place)'{-i,--in-place}'[format in place]'   '--diff[show diff on stdout]'   '--print-config=-[print resolved config]:kind:(default minimal verbose)'   '(-l --line-length)'{-l,--line-length}'=-[max line length]:integer:'   '--indent=-[spaces or tabs]:indent:'   '--safe[enable sanity checks]'   '--unsafe[disable sanity checks]'   '--definitions=-[custom command definitions]:paths:_files'   '--list-expansion=-[list formatting]:mode:(favour-inlining favour-expansion)'   '--warn-about-unknown-commands[warn on unknown commands]'   '--no-warn-about-unknown-commands[disable unknown-command warnings]'   '--disable-formatting[disable formatting]'   '--enable-formatting[enable formatting]'   '--extensions=-[extension modules/paths]'   '--sort-order=-[argument sort order]:order:(case-sensitive case-insensitive)'   '(-q --quiet)'{-q,--quiet}'[quiet non-errors]'   '--no-quiet[show non-error messages]'   '--color[colorize diff]'   '--no-color[plain diff]'   '(-w --workers)'{-w,--workers}'=-[parallel workers or max]:workers:'   '--cache[enable cache]'   '--no-cache[disable cache]'   '--cache-dir=-[cache directory]:dir:_files -/'   '--config=-[gersemi config path]:file:_files'   '--warnings-as-errors[treat warnings as errors]'   '*--line-ranges=-[format only line ranges]:range:'   '--respect-ignore-files[honour ignore files]'   '--no-respect-ignore-files[ignore ignore rules]'   '*:cmake sources:_files'
