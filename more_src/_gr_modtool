#compdef gr_modtool

local -a subcommands
subcommands=(
  'newmod:Create a new out-of-tree module'
  'add:Add a new block to the module'
  'rm:Remove a block from the module'
  'rename:Rename a block in the module'
  'disable:Disable a block in the module'
  'update:Update a block in the module'
  'info:Show information about the module'
  'makeyaml:Generate YAML file for GRC from block header'
  'help:Show help'
)

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --directory)'{-d,--directory}'[specify module directory]:directory:_directories' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      newmod)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-n --module-name)'{-n,--module-name}'[name of the new module]:name' \
          '(-d --directory)'{-d,--directory}'[directory to create module in]:directory:_directories' \
          '--skip-cmakefiles[do not create CMakeLists.txt]' \
          '--skip-python[do not create Python bindings]' \
          '--skip-grc[do not create GRC XML/YAML files]'
        ;;
      add)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --block-type)'{-t,--block-type}'[type of block]:block type:(sink source sync decimator interpolator general tagged_stream hier noblock)' \
          '(-l --lang)'{-l,--lang}'[language]:language:(python cpp)' \
          '(-d --directory)'{-d,--directory}'[module directory]:directory:_directories' \
          '--license-file=[license file to use]:file:_files' \
          '--copyright=[copyright holder name]:copyright' \
          '--argument-list=[argument list for block constructor]:arguments' \
          '--add-python-qa[add Python QA code]' \
          '--add-cpp-qa[add C++ QA code]' \
          '--skip-cmakefiles[do not modify CMakeLists.txt]' \
          '--skip-lib[do not create C++ files]' \
          '--skip-swig[do not create SWIG interface files]' \
          '--skip-python[do not create Python files]' \
          '--skip-grc[do not create GRC XML/YAML files]' \
          '1:block name'
        ;;
      rm)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --directory)'{-d,--directory}'[module directory]:directory:_directories' \
          '1:block name'
        ;;
      rename)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --directory)'{-d,--directory}'[module directory]:directory:_directories' \
          '1:old block name' \
          '2:new block name'
        ;;
      disable)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --directory)'{-d,--directory}'[module directory]:directory:_directories' \
          '1:block name'
        ;;
      update)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --directory)'{-d,--directory}'[module directory]:directory:_directories'
        ;;
      info)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --directory)'{-d,--directory}'[module directory]:directory:_directories'
        ;;
      makeyaml)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --directory)'{-d,--directory}'[module directory]:directory:_directories' \
          '1:block name'
        ;;
      help)
        _arguments '1:command:(newmod add rm rename disable update info makeyaml)'
        ;;
    esac
    ;;
esac
