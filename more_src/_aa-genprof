#compdef aa-genprof aa-logprof
# _aa-genprof — AppArmor profile-learning helpers (aa-genprof and aa-logprof drive interactive profile generation/refinement based on AppArmor learning logs in audit.log; -d profile dir, -f logfile, --json output, --no-reload skip kernel reload, --help, --version; positional argument is the path to the program / profile being learned)
# upstream: https://gitlab.com/apparmor/apparmor
# Flags from apparmor/apparmor utils/aa-genprof on tip.

_aa-genprof() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-d+[profile dir]:dir:_files -/' \
        '-f+[audit log]:file:_files' \
        '--json[json output]' \
        '--no-reload[skip kernel reload]' \
        '1:program path:_files'
}

_aa-genprof "$@"
