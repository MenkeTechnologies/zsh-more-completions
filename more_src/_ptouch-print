#compdef ptouch-print
# Documentation: https://github.com/philenotfound/ptouch-print
# Print labels on Brother P-touch label printers

local ret=1

_arguments -s -S \
  '--font[font file or font name to use for text rendering]:font:_files' \
  '--fontsize[font size in points]:size' \
  '--writepng[write output to a PNG file instead of printing]:file:_files' \
  '--version[display the program version]' \
  '--image[print a 2-color black/white PNG image]:file:_files' \
  '*--text[print 1-4 lines of text]:text' \
  '--cutmark[print a mark indicating where the tape should be cut]' \
  '--info[display maximum printing width for the current tape]' && ret=0

return ret
