#compdef tere

# Zsh completion for tere (terminal file explorer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--filter-search[Start in filter search mode]' \
  '--files-only[Only show files]' \
  '--folders-only[Only show folders]' \
  '--gap-search[Enable gap search (default)]' \
  '--no-gap-search[Disable gap search]' \
  '--autocd-timeout=[Timeout for autocd in ms]:milliseconds' \
  '--history-file=[Path to history file]:file:_files' \
  '--mouse=[Enable or disable mouse support]:mode:(on off)' \
  '--smart-case[Use smart case matching]' \
  '--ignore-case[Use case-insensitive matching]' \
  '--case-sensitive[Use case-sensitive matching]' \
  '--map=[Set a custom key mapping]:mapping' \
  '--sort=[Sort files by]:sort:(name created modified size)' \
  '--reverse-sort[Reverse sort order]' \
  '--dirs-first[Show directories before files]' \
  '--no-dirs-first[Do not show directories before files]' \
  '--hidden=[Show hidden files]:mode:(on off)' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-V --version)'{-V,--version}'[Print version]' \
  ':starting directory:_files -/' && ret=0

return ret
