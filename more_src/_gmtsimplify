#compdef gmtsimplify
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtsimplify.html
# Source: GenericMappingTools/gmt classic-mode gmtsimplify — Douglas-Peucker line simplification.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-T+[max mismatch tolerance (user units)]:tolerance:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-q+[row selection]:opts:_default' \
    '-:[swap first two columns]' \
    '(- *)-\?[show help]' \
    '*:input table:_files' \
    && ret=0

return ret
