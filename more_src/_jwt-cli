#compdef jwt

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'encode:encode a JWT'
  'decode:decode a JWT'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'jwt command' commands && ret=0
    ;;
  args)
    case $line[1] in
      encode)
        _arguments -s -S \
          '(-A --algorithm)'{-A,--algorithm}'[signing algorithm]:algorithm:(HS256 HS384 HS512 RS256 RS384 RS512 ES256 ES384 PS256 PS384 PS512 EdDSA)' \
          '(-S --secret)'{-S,--secret}'[signing secret]:secret:' \
          '(-P --payload)'{-P,--payload}'[payload claim]:claim:' \
          '--exp[expiration time]:time:' \
          '--iss[issuer]:issuer:' \
          '--sub[subject]:subject:' \
          '--aud[audience]:audience:' \
          '--nbf[not before]:time:' \
          '--iat[issued at]:time:' \
          '--jti[JWT ID]:id:' \
          '--no-iat[do not add iat claim]' \
          '--help[show help]' && ret=0
        ;;
      decode)
        _arguments -s -S \
          '(-A --algorithm)'{-A,--algorithm}'[expected algorithm]:algorithm:(HS256 HS384 HS512 RS256 RS384 RS512 ES256 ES384 PS256 PS384 PS512 EdDSA)' \
          '(-S --secret)'{-S,--secret}'[verification secret]:secret:' \
          '--iso8601[display dates in ISO 8601 format]' \
          '--json[JSON output]' \
          '--no-verify[skip signature verification]' \
          '1:token:' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
