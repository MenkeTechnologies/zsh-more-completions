#compdef MFEKmetadata
# Documentation: https://github.com/MFEK/metadata
# MFEK font metadata fetcher/updater for UFO fonts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '1:path:_files' \
  '2:subcommand:(arbitrary glyph glyphpathlen glyphs glyphslen write_metainfo help)' \
  '*::args:_files' && ret=0

return ret
