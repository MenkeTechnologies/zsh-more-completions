#compdef livenessprobe csi-livenessprobe
# _livenessprobe — Kubernetes CSI livenessprobe sidecar (kubernetes-csi/livenessprobe)
# upstream: https://github.com/kubernetes-csi/livenessprobe
# Flags from cmd/livenessprobe/main.go on tip.

_livenessprobe() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--csi-address=[CSI driver UDS path]:path:_files' \
        '--probe-timeout=[CSI probe timeout]:dur:' \
        '--health-port=[(deprecated) healthz TCP port]:port:' \
        '--metrics-address=[(deprecated) Prometheus metrics bind host\:port]:host\:port:' \
        '--http-endpoint=[diagnostics HTTP host\:port]:host\:port:' \
        '--metrics-path=[Prometheus metrics HTTP path]:path:' \
        '-v[klog verbosity level]:n:'
}

_livenessprobe "$@"
