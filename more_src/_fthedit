#compdef fthedit
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/fthedit.html
# fthedit - edit (add, delete, or update) a FITS header keyword

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'keyword=[keyword name to add/delete, or @editfile]:keyword' \
  'operation=[edit operation: add delete deleteall replace]:operation:(add a delete d deleteall replace r)' \
  'value=[keyword value and optional comment]:value' \
  'unit=[physical units of the value]:unit' \
  'comment=[comment string for the keyword]:comment' \
  'insert=[keyword after which to insert the new keyword]:insert' \
  'protect=[protect structural keywords]:protect:(YES NO yes no)' \
  'longstring=[use long string keyword convention]:longstring:(YES NO yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords recording parameters]:history:(YES NO yes no)' \
  '*:fits file:_files' && ret=0

return ret
