(( $+functions[_renri_commands] )) ||
_renri_commands() {
    local commands; commands=(
'add:Create a new worktree (git) or workspace (jj)' \
'list:List existing worktrees / workspaces' \
'remove:Remove a worktree / forget a workspace' \
'cd:Print the absolute path of a worktree (designed to be used from a shell function\: \`cd "\$(renri cd foo)"\`)' \
'exec:Run a command inside a worktree' \
'prune:Garbage-collect worktrees / stale jj workspaces' \
'init:Write a starter \`renri.toml\` in the current directory' \
'shell-init:Print (or install) a shell snippet that makes \`renri cd\` actually \`cd\` the parent shell instead of spawning a subshell' \
'config:Manage configuration' \
'sync:Run \`git fetch origin\` / \`jj git fetch\` in the current repo so all worktrees see the latest remote refs' \
'completions:Print a shell-completion script for the given shell. Pipe into your shell'\''s completion-loader, e.g. \`renri completions bash > ~/.local/share/bash-completion/completions/renri\`' \
'gh-repo:Print \`<owner>/<repo>\` for the current repo'\''s \`origin\` remote, or nothing when the cwd is not in a repo or has no parseable origin' \
'self-update:Update the renri binary itself to the latest GitHub release' \
'pr:Open the GitHub PR for a worktree in the browser' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'renri commands' commands "$@"
}
