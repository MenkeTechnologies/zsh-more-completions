#compdef opensearch-plugin

# opensearch-plugin: install/remove OpenSearch plugins
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'list:list installed plugins'
  'install:install a plugin'
  'remove:remove an installed plugin'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '-v[verbose]' \
  '-b[batch]' \
  '--batch[batch]' \
  '-E[config setting key=value]:kv:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'opensearch-plugin command' commands && ret=0 ;;
esac
return ret
