#compdef gobgpd
# Documentation: https://man.archlinux.org/search?q=gobgpd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --config-file)'{-f,--config-file}'+[config file]:file:_files -g "*.{toml,yaml,json}"' \
  '(-t --config-type)'{-t,--config-type}'+[config format]:fmt:(toml yaml json)' \
  '(-l --log-level)'{-l,--log-level}'+[log level]:level:(debug info warn error fatal panic)' \
  '(-j --log-as-json)'{-j,--log-as-json}'[log in JSON]' \
  '(--log-plain)--log-plain[plain text logs]' \
  '(-p --pprof-disable)'{-p,--pprof-disable}'[disable pprof]' \
  '(--metrics-path)--metrics-path=+[Prometheus metrics path]:path:' \
  '(--gops-port)--gops-port=+[gops agent port]:port:' \
  '(--api-hosts)--api-hosts=+[API hosts]:hosts:' \
  '(--cpus)--cpus=+[max CPUs]:n:' \
  '(--collector-prefix)--collector-prefix=+[InfluxDB prefix]:prefix:' \
  '(--graceful-restart)--graceful-restart[enable graceful restart]' \
  '(--syslog-network)--syslog-network=+[syslog network]:net:(tcp udp)' \
  '(--syslog-host)--syslog-host=+[syslog host]:host:_hosts' \
  '(--useSdNotify)--useSdNotify[use systemd notify]' \
  '(--disable-stdlog)--disable-stdlog[disable stdlog]' \
  '(--dry-run)--dry-run[validate config only]' && ret=0

return ret
