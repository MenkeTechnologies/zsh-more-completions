#compdef phenix.reciprocal_space_arrays
# Phenix: compute reciprocal-space arrays (FOBS, FMODEL, FCALC, FMASK, FBULK, HL) to MTZ

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'f_obs_label=[reflection data array to use]:label:' \
  'r_free_flags_label=[R-free flags column]:label:' \
  '*:model or data file:_files -g "*.(pdb|cif|mtz|hkl)"' && ret=0

return ret
