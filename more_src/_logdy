#compdef logdy
# Documentation: https://logdy.dev/docs/reference/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for logdy - Log viewer and parser

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[verbose logging output]' \
  '--no-analytics[opt-out from sending anonymous analytical data]' \
  '(-u --no-updates)'{-u,--no-updates}'[disable version update checks]' \
  '--port=[web UI port]:port:' \
  '--ui-ip=[web UI bind IP]:ip:' \
  '--ui-pass=[password prompted on UI access]:password:' \
  '--config=[path to JSON layout settings file]:file:_files' \
  '--api-key=[API key for REST API communication]:key:' \
  '(-t --fallthrough)'{-t,--fallthrough}'[print what is forwarded or consumed by logdy]' \
  '--append-to-file=[store messages to a file as JSON lines]:file:_files' \
  '--append-to-file-raw[store raw messages without metadata]' \
  '--rotate-file-size=[max file size before rotation (K/M/G)]:size:' \
  '--max-message-count=[maximum messages in the fixed-size buffer]:count:' \
  '--bulk-window=[milliseconds to batch messages]:ms:' \
  '--full-read[read entire file before following new lines]' \
  '--ip=[IP address to listen to (forward/socket modes)]:ip:' \
  '--disable-ansi-code-stripping[preserve ANSI terminal formatting codes]' \
  '--sample-text[use raw text instead of JSON in demo mode]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'stdin:Read logs from stdin'
      'forward:Forward logs to another destination'
      'demo:Run demo mode'
      'utils:Utility commands'
      'socket:Listen on a socket port'
      'follow:Follow files'
    )
    _describe -t commands 'logdy command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      forward)
        _arguments -s -S \
          '--port=[forward port]:port:' && ret=0
        ;;
      utils)
        local -a subcmds=(
          'sample:Generate sample log data'
        )
        _describe -t subcmds 'utils subcommand' subcmds && ret=0
        ;;
      socket)
        _arguments '1:port' && ret=0
        ;;
    esac
    ;;
esac

return ret
