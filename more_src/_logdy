#compdef logdy

# Zsh completion for logdy - Log viewer and parser

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-c --config)'{-c,--config}'[config file path]:config file:_files' \
  '(-p --port)'{-p,--port}'[web UI port]:port' \
  '--ui-ip=[web UI bind IP]:ip address' \
  '--no-analytics[disable analytics]' \
  '--append-to-file=[append logs to file]:file:_files' \
  '--bulk-window=[bulk window duration]:duration' \
  '--max-message-count=[maximum message count]:count' \
  '--sample-rate=[sample rate]:rate' \
  '--pass-through[pass through logs to stdout]' \
  '--fallback-column=[fallback column name]:column' \
  '--no-auto-date[disable automatic date detection]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'stdin:Read logs from stdin'
      'forward:Forward logs to another destination'
      'demo:Run demo mode'
      'utils:Utility commands'
      'socket:Listen on a socket port'
    )
    _describe -t commands 'logdy command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      forward)
        _arguments -s -S \
          '--port=[forward port]:port' && ret=0
        ;;
      utils)
        local -a subcmds=(
          'sample:Generate sample log data'
        )
        _describe -t subcmds 'utils subcommand' subcmds && ret=0
        ;;
      socket)
        _arguments '1:port' && ret=0
        ;;
    esac
    ;;
esac

return ret
