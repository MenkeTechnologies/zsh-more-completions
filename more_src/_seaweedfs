#compdef weed

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v+[log level]:level:(0 1 2 3 4)' \
  '-logdir=[log directory]:directory:_directories' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'master:start master server'
      'volume:start volume server'
      'filer:start filer server'
      'server:start combined server'
      's3:start S3 gateway'
      'mount:mount as FUSE filesystem'
      'upload:upload files'
      'download:download files'
      'benchmark:run benchmark'
      'backup:backup volume data'
      'compact:compact volume data'
      'fix:fix volume index'
      'export:export volume data'
      'scaffold:generate config scaffolding'
      'shell:start interactive shell'
      'version:print version'
    )
    _describe -t commands 'weed command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      server)
        _arguments -s -S \
          '-master.port=[master port]:port' \
          '-volume.port=[volume port]:port' \
          '-filer[start filer too]' \
          '-filer.port=[filer port]:port' \
          '-s3[start S3 gateway too]' \
          '-s3.port=[S3 port]:port' \
          '-dir=[data directory]:directory:_directories' \
          '-ip=[listen IP]:ip' \
          '-ip.bind=[bind IP]:ip' && ret=0
        ;;
      mount)
        _arguments -s -S \
          '-dir=[mount point]:directory:_directories' \
          '-filer=[filer address]:address' \
          '-filer.path=[filer remote path]:path' \
          '-cacheDir=[cache directory]:directory:_directories' \
          '-cacheSizeMB=[cache size in MB]:size' && ret=0
        ;;
      upload)
        _arguments -s -S \
          '-master=[master server address]:address' \
          '-dir=[directory to upload]:directory:_directories' \
          '-include=[include pattern]:pattern' \
          '-ttl=[time to live]:ttl' \
          '-maxMB=[max file size in MB]:size' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
