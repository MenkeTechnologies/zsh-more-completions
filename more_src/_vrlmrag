#compdef vrlmrag
# Source: https://github.com/nbiish/mai-vl-rag-graph-rlm/blob/91e84e1dbb77f412e1c7e6ceed8824049cb26b9d/scripts/vrlmrag-completion.zsh
# Repository: nbiish/mai-vl-rag-graph-rlm (scripts/vrlmrag-completion.zsh)
# vrlmrag zsh completion script
# Install: copy to a directory in $fpath (e.g., /usr/local/share/zsh/site-functions/)

_vrlmrag() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(--query -q)'{-q,--query}'[Custom query]:query:' \
        '(--output -o)'{-o,--output}'[Output markdown report path]:file:_files' \
        '--format[Output format]:format:(markdown json)' \
        '(--provider -p)'{-p,--provider}'[API provider]:provider:(openrouter zenmux zai openai anthropic gemini litellm sambanova nebius modalresearch ollama)' \
        '(--model -m)'{-m,--model}'[Override default model]:model:' \
        '--profile[Analysis depth]:profile:(fast thorough comprehensive)' \
        '--comprehensive[Explicitly enable comprehensive mode]' \
        '(--verbose -v)'{-v,--verbose}'[Enable verbose output]' \
        '(--quiet -Q)'{-Q,--quiet}'[Suppress all non-error output]' \
        '--text-only[Use lightweight text-only embeddings]' \
        '--no-embed[Skip embedding entirely]' \
        '--cache[Use existing cached embeddings]' \
        '--dry-run[Show what would be processed without running]' \
        '--local[Use local Qwen3-VL model]' \
        '--offline[Force offline mode]' \
        '--max-depth[Maximum RLM recursion depth]:depth:' \
        '--max-iterations[Maximum RLM iterations]:iterations:' \
        '(--interactive -i)'{-i,--interactive}'[Start interactive session]' \
        '--store-dir[Directory for embeddings/KG]:dir:_directories' \
        '--chunk-size[Characters per chunk]:size:' \
        '--chunk-overlap[Character overlap between chunks]:overlap:' \
        '--use-sqlite[Use SQLite backend]' \
        '--rrf-dense-weight[Weight for dense results]:weight:' \
        '--rrf-keyword-weight[Weight for keyword results]:weight:' \
        '--multi-query[Multi-query retrieval]' \
        '--reindex[Force re-embedding all documents]' \
        '--rebuild-kg[Regenerate knowledge graph]' \
        '--model-compare[Compare embeddings between models]:old_model:' \
        '--check-model[Check collection compatibility]:model_name:' \
        '--quality-check[RLM-powered quality assessment]' \
        '--export-graph[Export knowledge graph]:file:_files' \
        '--graph-format[Graph export format]:format:(mermaid graphviz networkx)' \
        '--graph-stats[Show KG statistics]' \
        '--deduplicate-kg[Deduplicate entities]' \
        '--dedup-threshold[Similarity threshold]:threshold:' \
        '--dedup-report[Show deduplication report]' \
        '--graph-augmented[Enable graph-augmented retrieval]' \
        '--graph-hops[Maximum graph traversal hops]:hops:' \
        '(--collection -c)'{-c,--collection}'[Named collection]:collection:_vrlmrag_collections' \
        '--add[Add documents to collection]:path:_files' \
        '--collection-list[List all collections]' \
        '--collection-info[Show collection info]' \
        '--collection-delete[Delete collection]' \
        '--collection-export[Export collection]:path:_files' \
        '--collection-import[Import collection]:path:_files' \
        '--import-rename[Rename imported collection]:name:' \
        '--collection-merge[Merge collections]:source:_vrlmrag_collections' \
        '--collection-description[Collection description]:text:' \
        '--collection-tag[Add tag to collection]:tag:' \
        '--collection-untag[Remove tag from collection]:tag:' \
        '--collection-search[Search collections]:query:' \
        '--collection-search-tags[Filter by tags]:tags:' \
        '--collection-stats[Show collection statistics]' \
        '--global-stats[Show global statistics]' \
        '--list-providers[List available providers]' \
        '--show-hierarchy[Show provider hierarchy]' \
        '--lock-status[Show local model lock status]' \
        '*:file:_files'
}

_vrlmrag_collections() {
    local -a collections
    collections=(${(f)"$(vrlmrag --collection-list 2>/dev/null | grep "^  -" | sed 's/^  - //')"})
    _describe -t collections 'collections' collections
}

