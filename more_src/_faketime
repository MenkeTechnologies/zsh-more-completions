#compdef faketime
# Documentation: https://github.com/wolfcw/libfaketime/blob/master/src/faketime.c
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for faketime - manipulate system time for a given command

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-m[multi-threaded version of libfaketime]' \
  '-f[advanced timestamp specification format]' \
  '--exclude-monotonic[prevent monotonic clock from drifting]' \
  '-p+[pretend program PID is this]:pid:' \
  '--disable-shm[disable shared memory]' \
  '--date-prog=[GNU-compatible date program]:program:_command_names -e' \
  '1:fake time:' \
  '*::command:_command_names -e'
