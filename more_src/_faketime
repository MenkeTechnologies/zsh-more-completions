#compdef faketime
# Documentation: https://man.archlinux.org/search?q=faketime
# Reference accessed: 2026-05-16

# Zsh completion for faketime - manipulate system time for a given command

_arguments -s -S \
  '(-f --faking-time)'{-f,--faking-time}'[use the next argument as the faked time]' \
  '*:command:_command_names -e'
