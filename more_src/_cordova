#compdef cordova

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a new cordova project'
  'platform:manage project platforms'
  'plugin:manage project plugins'
  'prepare:copy files into platform for building'
  'compile:compile platform project'
  'build:shortcut for prepare then compile'
  'run:run project on device or emulator'
  'emulate:run project on emulator'
  'serve:run a local web server for www/ assets'
  'clean:clean build artifacts'
  'requirements:check and print platform requirements'
  'info:print project information'
  'telemetry:turn telemetry on or off'
  'help:show help for a command'
)

local -a platforms=(
  'android' 'ios' 'browser' 'electron'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d[verbose logging]' \
  '--verbose[verbose logging]' \
  '--no-update-notifier[disable update check]' \
  '--nohooks[suppress hook execution]' \
  '--no-telemetry[disable telemetry]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cordova command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (platform)
        local -a platform_cmds=(
          'add:add a platform'
          'remove:remove a platform'
          'rm:remove a platform'
          'update:update a platform'
          'list:list installed and available platforms'
          'ls:list installed and available platforms'
          'check:check platforms for updates'
          'save:save platform versions to config.xml'
        )
        _arguments \
          '1:platform command:_describe -t platform-cmds "platform command" platform_cmds' \
          '*:platform:($platforms)' && ret=0
        ;;
      (plugin)
        local -a plugin_cmds=(
          'add:add a plugin'
          'remove:remove a plugin'
          'rm:remove a plugin'
          'list:list installed plugins'
          'ls:list installed plugins'
          'search:search for plugins'
          'save:save plugin versions to config.xml'
        )
        _arguments \
          '1:plugin command:_describe -t plugin-cmds "plugin command" plugin_cmds' \
          '--save[save to config.xml]' \
          '--nosave[do not save to config.xml]' \
          '--link[symlink instead of copy]' \
          '--force[force add even if already installed]' \
          '--searchpath=[additional plugin search path]:path:_directories' \
          '--variable=[CLI variable]:variable (NAME=VALUE)' \
          '*:plugin' && ret=0
        ;;
      (build|compile|run|emulate)
        _arguments \
          '--debug[build debug version]' \
          '--release[build release version]' \
          '--device[deploy to device]' \
          '--emulator[deploy to emulator]' \
          '--target=[target device]:target' \
          '--nobuild[skip building]' \
          '--list[list available targets]' \
          '--buildConfig=[build configuration file]:file:_files' \
          '*:platform:($platforms)' && ret=0
        ;;
      (create)
        _arguments \
          '1:directory:_directories' \
          '2:package name' \
          '3:project name' \
          '--template=[template to use]:template' \
          '--copy-from=[directory to copy from]:directory:_directories' \
          '--link-to=[directory to link to]:directory:_directories' && ret=0
        ;;
      (serve)
        _arguments \
          '--port=[local port]:port' \
          '--target=[platform to serve]:platform:($platforms)' \
          '--browser=[browser to launch]:browser' && ret=0
        ;;
      (requirements|info|clean)
        _arguments '*:platform:($platforms)' && ret=0
        ;;
      (telemetry)
        _arguments '1:state:(on off)' && ret=0
        ;;
    esac
    ;;
esac

return ret
