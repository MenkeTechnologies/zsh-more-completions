#compdef capacitor cap
# _capacitor-bin — Capacitor cross-platform native runtime CLI (Ionic Team); Cordova successor for adding iOS/Android shells
# upstream: https://github.com/ionic-team/capacitor

_capacitor-bin() {
    local -a sub=(
        'add:add a native platform'
        'build:build native projects'
        'config:print config'
        'copy:copy web assets to native'
        'create:create new project (deprecated)'
        'doctor:run env doctor'
        'init:initialize Capacitor in current project'
        'ls:list installed plugins per platform'
        'migrate:migrate to a newer version'
        'open:open native IDE'
        'plugin:plugin commands'
        'run:run on device/emulator'
        'serve:serve web assets'
        'sync:copy + update'
        'telemetry:telemetry opt-in/out'
        'update:update native deps'
        'live-reload:enable live reload'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cap subcommand' sub ;;
        args)
            case $words[1] in
                add|open|copy|sync|update|build) _arguments '1:platform:(android ios)' ;;
                run) _arguments \
                    '1:platform:(android ios)' \
                    '(-l --live-reload)'{-l,--live-reload}'[live reload]' \
                    '--port+[live reload port]:port:' \
                    '--host+[live reload host]:host:_hosts' \
                    '--external[external host]' \
                    '--list[list devices]' \
                    '--target+[device target]:device:' \
                    '--scheme+[iOS scheme]:scheme:' \
                    '--no-sync[skip sync]' ;;
                init) _arguments '1:appName:' '2:appId:' \
                    '--web-dir+[web dir]:dir:_files -/' ;;
                plugin) _arguments '1:plugin cmd:(generate add remove ls)' '*:args:' ;;
                migrate) _arguments '--noprompt[no prompt]' '--packagemanager+[package manager]:pm:(npm yarn pnpm)' ;;
            esac
            ;;
    esac
}

_capacitor-bin "$@"
