#compdef messagebird-cli messagebird mb-cli
# _messagebird-cli — Bird MessageBird messagebird-cli CLI command-line frontend wrapping the Bird formerly MessageBird Omnichannel Communications API managing messages voice calls conversations flows numbers verify HLR-lookup contacts groups balances Voice-XML Notifications MMS WhatsApp Telegram channels (Bird team, Go); cobra
# upstream: https://bird.com/

_messagebird-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'message:message operations'
        'voice:voice call operations'
        'conversation:conversation operations'
        'flow:flow operations'
        'number:number operations'
        'verify:verify operations'
        'hlr:HLR lookup'
        'contact:contact operations'
        'group:group operations'
        'balance:balance operations'
        'notification:notification operations'
        'mms:MMS operations'
        'whatsapp:WhatsApp operations'
        'telegram:Telegram operations'
        'channel:channel operations'
        'webhook:webhook operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--access-key=+[key]:str:' \
        '--access-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--workspace-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'messagebird-cli subcommand' sub ;;
        args)
            case $words[1] in
                message|voice|conversation|flow|number|verify|hlr|contact|group|notification|mms|whatsapp|telegram|channel|webhook) _arguments '1:op:(list get create update delete send hangup transfer)' '*:id:' ;;
            esac
            ;;
    esac
}

_messagebird-cli "$@"
