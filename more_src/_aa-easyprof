#compdef aa-easyprof
# _aa-easyprof — AppArmor aa-easyprof (template-driven AppArmor profile generator; --policy-groups groups csv, --abstractions abstractions csv, --read-path/--write-path/--no-abstractions, --binary path to executable, --name profile name, --template-var KEY=VAL, --template TEMPLATE, --policy-version, --list-templates, --list-policy-groups, --check, --output dir; positional argument is the executable to profile)
# upstream: https://gitlab.com/apparmor/apparmor
# Flags from apparmor/apparmor utils/aa-easyprof on tip.

_aa-easyprof() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--policy-groups+[groups csv]:groups:' \
        '--abstractions+[abstractions csv]:abstractions:' \
        '*--read-path+[path]:path:_files' \
        '*--write-path+[path]:path:_files' \
        '--no-abstractions[no abstractions]' \
        '--binary+[binary]:binary:_command_names -e' \
        '--name+[profile name]:name:' \
        '*--template-var+[KEY=VAL]:var:' \
        '--template+[template]:template:' \
        '--policy-version+[policy version]:version:' \
        '--list-templates[list templates]' \
        '--list-policy-groups[list policy groups]' \
        '--check[check]' \
        '--output+[output dir]:dir:_files -/' \
        '1::executable:_command_names -e'
}

_aa-easyprof "$@"
