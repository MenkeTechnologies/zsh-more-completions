#compdef helgrind
# _helgrind — Valgrind Helgrind data race detector (Julian Seward, C); detect POSIX pthreads errors and races
# upstream: https://valgrind.org

_helgrind() {
    _arguments \
        '--free-is-write+[free is write]:bool:(yes no)' \
        '--track-lockorders+[lock order check]:bool:(yes no)' \
        '--history-level+[history level]:level:(full approx none)' \
        '--conflict-cache-size+[conflict cache size]:n:' \
        '--check-stack-refs+[check stack refs]:bool:(yes no)' \
        '--ignore-thread-creation+[ignore thread creation]:bool:(yes no)' \
        '--fair-sched+[fair scheduling]:bool:(yes no)' \
        '--cmd-line-only+[cmd-line only]:bool:(yes no)' \
        '*::command:_command_names -e'
}

_helgrind "$@"
