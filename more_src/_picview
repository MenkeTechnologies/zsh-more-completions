#compdef picview

# picview: image viewer (commonly the package alt name for gpicview)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '*:image file(s):_files -g "*.(jpg|jpeg|png|gif|bmp|tiff|tif|webp|svg|xpm|pbm|pgm|ppm)"' && ret=0
return ret
