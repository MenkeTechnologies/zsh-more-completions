#compdef picview
# Documentation: https://man.archlinux.org/search?q=picview
# Reference accessed: 2026-05-16

# picview: image viewer (KDE / Qt)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--fullscreen[start in fullscreen mode]' \
  '*:images:_files -g "*.(jpg|jpeg|png|gif|bmp|tif|tiff|webp|avif|heic|heif|svg)"' && ret=0
return ret
