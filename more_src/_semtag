#compdef semtag
# Documentation: https://github.com/nico2sh/semtag
# Reference accessed: 2026-05-21
# Verified: upstream README usage section.

local curcontext="$curcontext" ret=1 state line
local -a commands=(
  'getfinal:return the current final version'
  'getlast:return the last tagged version'
  'getcurrent:return current version with dev info if uncommitted'
  'get:return both last tagged and current final versions'
  'final:bump to a final version'
  'alpha:bump to an alpha version'
  'beta:bump to a beta version'
  'candidate:bump to a release candidate version'
)
_arguments -C \
  '-o[display output only without tagging]' \
  '-s+[bump scope]:scope:(major minor patch auto)' \
  '-v+[manually set a version]:version:' \
  '-f[force tagging despite no new commits or unstaged changes]' \
  '-p[plain mode (no v prefix)]' \
  '-P+[custom tag prefix]:prefix:' \
  '1:command:->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'semtag command' commands && ret=0 ;;
esac
return ret
