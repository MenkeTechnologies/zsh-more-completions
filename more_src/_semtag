#compdef semtag

# Zsh completion for semtag semver git tag helper

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-p+[stable prefix string]:prefix' \
  '-u+[unstable prefix string]:prefix' \
  '-v+[force bump kind]:kind:(major minor patch none)' \
  '*::args:{ _message "semtag refs" }' && ret=0

return ret
