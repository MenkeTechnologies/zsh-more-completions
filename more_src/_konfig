#compdef konfig
# Documentation: https://github.com/corneliusweig/konfig
# Reference accessed: 2026-05-19
# Verified: upstream corneliusweig/konfig README (kubeconfig merger,
# also a kubectl krew plugin).

# Zsh completion for konfig (Kubernetes kubeconfig merger)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'import:import a config file into the default kubeconfig'
      'merge:combine multiple kubeconfig files'
      'export:extract a minimal kubeconfig for one or several contexts'
    )
    _describe -t commands 'konfig subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      import)
        _arguments -s -S \
          '--save[persist changes to your kubeconfig]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:kubeconfig file:_files' && ret=0
        ;;
      merge)
        _arguments -s -S \
          '--preserve-structure[preserve structure and keep credentials separate]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:kubeconfig file:_files' && ret=0
        ;;
      export)
        _arguments -s -S \
          '-k+[comma separated kubeconfig file paths]:paths:' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:context name:_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
