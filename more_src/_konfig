#compdef konfig

# Zsh completion for konfig (Kubernetes config merger, kubectl plugin)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'import:import a kubeconfig file'
      'export:export a context to a file'
      'delete:delete a context'
      'merge:merge multiple kubeconfig files'
      'split:split kubeconfig into separate files'
      'help:show help for a subcommand'
    )
    _describe -t commands 'konfig subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      import|merge)
        _files && ret=0
        ;;
      export)
        _arguments \
          '1:context name' \
          '2:output file:_files' && ret=0
        ;;
      delete)
        _message 'context name' && ret=0
        ;;
      split)
        _arguments \
          '--dir[output directory]:directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
