#compdef pbrd ripngd
# Documentation:
#   https://docs.frrouting.org/en/latest/pbr.html
#   https://docs.frrouting.org/en/latest/ripngd.html
#   https://docs.frrouting.org/en/latest/basic.html (common invocation opts)
# Reference accessed: 2026-05-30
# pbrd   — FRR's Policy-Based Routing daemon (per-source/per-app routing).
# ripngd — FRR's RIPng (RIP for IPv6) routing daemon — IPv6 sibling of ripd.
# Both use the FRR-common command-line flag set; this multi-stem file covers
# them with one dispatcher, consistent with the existing _ripd / _ospfd / etc.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '(-f --config_file)'{-f,--config_file=}'[config file]:file:_files' \
  '(-i --pid_file)'{-i,--pid_file=}'[pid file]:file:_files' \
  '(-z --socket)'{-z,--socket=}'[zebra socket]:file:_files' \
  '(-A --vty_addr)'{-A,--vty_addr=}'[VTY bind address]:addr:' \
  '(-P --vty_port)'{-P,--vty_port=}'[VTY TCP port]:port:' \
  '(-u --user)'{-u,--user=}'[run as USER:GROUP]:user:_users' \
  '(-g --group)'{-g,--group=}'[run as group]:group:_groups' \
  '(-N --pathspace)'{-N,--pathspace=}'[namespace]:ns:' \
  '(-M --module)'{-M,--module=}'[load module[:opts]]:module:' \
  '(-w --vrfwnetns)'{-w,--vrfwnetns}'[discover VRFs via Linux netns]' \
  '(-o --vrfdefaultname)'{-o,--vrfdefaultname=}'[name for Default VRF in CLI]:name:' \
  '--command-log-always[permanently enable command logging]' \
  '--log=[initial log destination]:dest:->log' \
  '--log-level=[default log level]:level:(emergencies alerts critical errors warnings notifications informational debugging)' \
  '--tcli[enable transactional CLI mode]' \
  '--limit-fds=[max file descriptors used internally]:N:' \
  && ret=0

case $state in
  log)
    _alternative \
      'special:special destination:(stdout syslog)' \
      'files:log file (file:/path):_files' \
      && ret=0
    ;;
esac

return ret
