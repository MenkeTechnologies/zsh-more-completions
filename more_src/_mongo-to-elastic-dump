#compdef mongo-to-elastic-dump
# ============================================================================
# _mongo-to-elastic-dump — zsh completion for Sameer Deshmukh's
#                           mongo-to-elastic-dump, a Node.js MongoDB →
#                           Elasticsearch bulk pump (@elastic/
#                           elasticsearch ^8.7.0)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/sameer17cs/mongo-to-elastic-dump
#   Author     : Sameer Deshmukh
#   License    : ISC
#   Language   : JavaScript (Node)
#   Package    : mongo-to-elastic-dump v2.0.7
#   Binary     : mongo-to-elastic-dump  (package.json bin:
#                bin/command.js)
#   Last push  : 2023-07-03
#
# WHAT IT IS
#   mongo-to-elastic-dump is "a tool for dumping records from
#   MongoDB to Elasticsearch" — Sameer Deshmukh's batched bulk-
#   loader.  It connects to a source MongoDB collection, paginates
#   through documents by `_id` order (resumable via `--m_skip_id`),
#   optionally projects a subset of fields, optionally applies a
#   user-provided `transform.js` to each document, then `bulk`-
#   indexes the result into an Elasticsearch index.  Both the
#   read batch size and the per-batch retry budget are
#   configurable, with retries kicking in on every transient
#   error.
#
# CLI ARGUMENT GRAMMAR  (verbatim from index.js `Flags.define*`
#                       block — the `flags` npm package uses the
#                       single `--name=value` syntax with no short
#                       alternatives)
#   mongo-to-elastic-dump --m_db <DB> --m_collection <NAME> \
#                          --e_index <INDEX> --e_doc_id <FIELD> \
#                          [OPTIONS]
#
#   MongoDB-source options (`m_*`):
#     --m_host <URI>          MongoDB host URI
#                             (e.g. `mongodb://localhost:27017`)
#                             [default: localhost:27017]
#     --m_db <NAME>           Database to dump from        [REQUIRED]
#     --m_collection <NAME>   Collection to dump from      [REQUIRED]
#     --m_limit <N>           Per-batch limit for the MongoDB query
#                             [default: 500]
#     --m_fields <CSV>        Comma-separated list of fields to
#                             include in the dump
#     --m_query <JSON>        MongoDB filter expression
#                             [default: `{}`]
#     --m_skip_id <OID>       Resume from this `_id` (paginated by
#                             `_id > skip_id`)
#     --m_transform <PATH>    Path to a `transform.js` module that
#                             exports a function applied to each
#                             document before indexing
#
#   Elasticsearch-target options (`e_*`):
#     --e_host <URI>          Elasticsearch endpoint URL
#                             [default: localhost:9200]
#     --e_auth <CREDS>        Auth credentials passed to the client
#                             (e.g. `user:pass`)
#     --e_index <NAME>        Target index               [REQUIRED]
#     --e_doc_id <FIELD>      Field name whose value becomes the
#                             ES primary `_id`
#     --e_update_key <FIELD>  Field name used to match documents
#                             for update
#     --e_action <ACTION>     Bulk-API action               [default:
#                             index;  also: `create`]
#     --e_attempts <N>        Retry budget on transient failures
#                             [default: -1 = infinite]
#
#   Behavior note:
#     The `flags` package supports only `--name=value` and
#     `--name value`;  there are no short flags or auto-help
#     bundled with the package.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `@elastic/elasticsearch ^8.7.0` declared
#   in package.json — the canonical Node.js Elasticsearch client
#   maintained by Elastic NV (elastic/elasticsearch-js, npm
#   `@elastic/elasticsearch`).  The 8.x line is the official
#   client for ES 8.x and 9.x;  it exposes a typed `Client`
#   constructor with API-key / basic / cloud-id authentication,
#   every REST endpoint as a typed method (`client.bulk`,
#   `client.search`, `client.indices.create`, `client.cat.*`,
#   `client.cluster.*`, `client.snapshot.*`), connection-pool
#   topology with sniffing, BWC for ES 7.17 / 8.x / 9.x, and
#   transport-level retry hooks.  mongo-to-elastic-dump's
#   `index.js` constructs `new Client({node, auth})`, calls
#   `client.info()` for the up-front version check, then loops
#   `client.bulk({body})` with the per-batch document array.
#   Verified via:
#     gh api repos/sameer17cs/mongo-to-elastic-dump/contents/package.json
#       → "@elastic/elasticsearch": "^8.7.0"
#       → "bin": {"mongo-to-elastic-dump": "bin/command.js"}
#     gh api repos/sameer17cs/mongo-to-elastic-dump/contents/index.js
#       → const { Client } = require('@elastic/elasticsearch')
#         this.es_client.bulk({ body: body });
#   This entry is the TS-Node=137 leader bump that CLOSES Axis 82
#   (Elasticsearch Client Library) at 1/1/1 three-language
#   symmetry — pairing Rust=`elasticsearch` (R917 _escli),
#   Go=`go-elasticsearch/v7` v7.16.0 (R918 _elasticcopy), and
#   TS-Node=`@elastic/elasticsearch` ^8.7.0 (this entry).
#   Triple-137 landmark on commit.
#
#   No completion for `mongo-to-elastic-dump` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_mongo-to-elastic-dump() {
    _arguments -s \
        '--m_host=[MongoDB host URI (default localhost\:27017)]:URI:' \
        '--m_db=[database to dump from (required)]:database:' \
        '--m_collection=[collection to dump from (required)]:collection:' \
        '--m_limit=[per-batch limit (default 500)]:n:' \
        '--m_fields=[CSV list of fields to dump]:fields:' \
        '--m_query=[MongoDB filter JSON (default {})]:JSON:' \
        '--m_skip_id=[resume from this _id]:object id:' \
        '--m_transform=[path to transform.js module]:transform.js:_files -g "*.js"' \
        '--e_host=[Elasticsearch endpoint (default localhost\:9200)]:URI:' \
        '--e_auth=[ES auth credentials (user\:pass)]:credentials:' \
        '--e_index=[target ES index (required)]:index:' \
        '--e_doc_id=[field whose value becomes ES _id]:field:' \
        '--e_update_key=[field used to match documents for update]:field:' \
        '--e_action=[bulk action (default index)]:action:(index create)' \
        '--e_attempts=[retry budget (-1 = infinite)]:n:'
}

_mongo-to-elastic-dump "$@"
