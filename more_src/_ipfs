#compdef ipfs

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add:add a file or directory to IPFS'
  'cat:show IPFS object data'
  'get:download IPFS objects'
  'ls:list directory contents for unixfs objects'
  'refs:list links from an object'
  'dag:operations on the DAG'
  'files:interact with unixfs files'
  'block:interact with raw blocks'
  'cid:CID conversion utilities'
  'multibase:multibase encode/decode'
  'daemon:start a long-running daemon process'
  'shutdown:shut down the daemon'
  'resolve:resolve names to peer/DNS/IPFS paths'
  'name:publish/resolve IPNS names'
  'key:create and list IPNS name keypairs'
  'pin:pin objects to local storage'
  'repo:manipulate the local IPFS repo'
  'stats:query stats and metrics'
  'p2p:libp2p stream mounting (experimental)'
  'filestore:filestore operations (experimental)'
  'mount:mount the IPFS namespace (experimental)'
  'provide:provide a CID to the network'
  'id:show IPFS node id info'
  'bootstrap:show or edit the bootstrap list'
  'swarm:swarm operations'
  'dht:DHT commands (deprecated, use routing)'
  'routing:routing operations'
  'ping:send echo requests to peers'
  'bitswap:bitswap operations'
  'pubsub:pubsub operations'
  'config:get/set local IPFS config'
  'version:show IPFS version'
  'diag:diagnostic operations'
  'update:update IPFS itself'
  'commands:list all available commands'
  'log:manage the daemon log'
  'init:initializes the IPFS repo'
  'object:legacy object commands (deprecated)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--repo-dir=[repository directory]:dir:_files -/' \
  '--config-file=[config file]:file:_files' \
  '(-c --config)'{-c,--config=}'[deprecated config file]:file:_files' \
  '(-D --debug)'{-D,--debug}'[debug mode]' \
  '--offline[run command offline]' \
  '--api=[API multiaddr]:multiaddr:' \
  '--api-auth=[API auth secret]:secret:' \
  '--cid-base=[CID multibase encoding]:enc:' \
  '(--enc --encoding)'{--enc=,--encoding=}'[output encoding]:fmt:(json xml text)' \
  '--timeout=[global timeout]:duration:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ipfs subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (pin)
        _values 'pin action' 'add' 'ls' 'rm' 'update' 'verify' 'remote' && ret=0
        ;;
      (swarm)
        _values 'swarm action' \
          'peers' 'connect' 'disconnect' 'addrs' 'filters' 'peering' 'limit' && ret=0
        ;;
      (repo)
        _values 'repo action' \
          'gc' 'stat' 'fsck' 'verify' 'version' 'migrate' 'ls' && ret=0
        ;;
      (key)
        _values 'key action' \
          'gen' 'list' 'rm' 'rename' 'rotate' 'export' 'import' && ret=0
        ;;
      (name)
        _values 'name action' 'publish' 'resolve' 'pubsub' && ret=0
        ;;
      (files)
        _values 'files action' \
          'cp' 'flush' 'ls' 'mkdir' 'mv' 'read' 'rm' 'stat' 'write' 'chcid' && ret=0
        ;;
      (block)
        _values 'block action' 'get' 'put' 'rm' 'stat' && ret=0
        ;;
      (dag)
        _values 'dag action' \
          'get' 'put' 'resolve' 'export' 'import' 'stat' && ret=0
        ;;
      (bootstrap)
        _values 'bootstrap action' 'list' 'add' 'rm' && ret=0
        ;;
      (config)
        _values 'config action' 'show' 'edit' 'replace' 'profile' && ret=0
        ;;
      (stats)
        _values 'stats target' \
          'bw' 'bitswap' 'repo' 'dht' 'provide' 'pin' && ret=0
        ;;
      (log)
        _values 'log action' 'level' 'ls' 'tail' && ret=0
        ;;
      (object)
        _values 'object action' \
          'data' 'links' 'get' 'put' 'stat' 'new' 'patch' 'diff' && ret=0
        ;;
      (routing)
        _values 'routing action' \
          'findpeer' 'findprovs' 'get' 'put' 'provide' && ret=0
        ;;
      (bitswap)
        _values 'bitswap action' 'ledger' 'reprovide' 'stat' 'wantlist' && ret=0
        ;;
      (pubsub)
        _values 'pubsub action' 'pub' 'sub' 'ls' 'peers' && ret=0
        ;;
      (cid)
        _values 'cid action' 'base32' 'bases' 'codecs' 'format' 'hashes' && ret=0
        ;;
      (multibase)
        _values 'multibase action' 'decode' 'encode' 'list' 'transcode' && ret=0
        ;;
      (filestore)
        _values 'filestore action' 'dups' 'ls' 'verify' && ret=0
        ;;
      (p2p)
        _values 'p2p action' \
          'forward' 'listen' 'close' 'ls' 'stream' && ret=0
        ;;
      (diag)
        _values 'diag action' \
          'cmds' 'sys' 'profile' && ret=0
        ;;
      (add|cat|get|ls|refs|provide)
        _files
        ret=0
        ;;
    esac
    ;;
esac

return ret
