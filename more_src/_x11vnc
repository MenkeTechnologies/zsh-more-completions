#compdef x11vnc
# _x11vnc — x11vnc (export a real X display over the VNC RFB protocol; -display selects the X display, -auth points at Xauthority for headless screens, -forever stays running across clients, -shared multi-viewer, -passwd inline auth, -httpdir serves Java applet)
# upstream: https://github.com/LibVNC/x11vnc
# Flags from x11vnc/x11vnc.c on tip.

_x11vnc() {
    _arguments \
        '-display+[X display]:display:' \
        '-auth+[xauthority file]:file:_files' \
        '-rfbport+[RFB listen port]:port:' \
        '-passwd+[plaintext password]:password:' \
        '-passwdfile+[password file]:file:_files' \
        '-allow+[allow client IPs]:cidrs:' \
        '-localhost[listen on loopback only]' \
        '-forever[keep running across clients]' \
        '-shared[allow multiple simultaneous clients]' \
        '-viewonly[clients cannot send input]' \
        '-quiet[silent]' \
        '-once[exit after first client]' \
        '-httpdir+[Java viewer dir]:dir:_files -/' \
        '-ssl+[SSL cert]:file:_files' \
        '-rmflag+[file to remove on exit]:file:_files' \
        '-noxdamage[disable XDAMAGE polling]' \
        '-cursor+[cursor mode]:mode:(none arrow X most some plus)' \
        '-scale+[scaling factor]:factor:' \
        '-tile+[tile size]:size:' \
        '-create[create Xvfb if no display]' \
        '-listen+[listen address]:addr:'
}

_x11vnc "$@"
