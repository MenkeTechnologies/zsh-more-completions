#compdef dropanalysis DropAnalysis
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/StreamDropAnalysis.html
# TauDEM: stream drop analysis to select a stream threshold

local ret=1

_arguments -s -S \
  '-fel[input hydrologically correct elevation grid]:felfile:_files' \
  '-p[input D8 flow directions grid]:pfile:_files' \
  '-ad8[input D8 contributing area grid]:ad8file:_files' \
  '-ssa[input accumulated stream source grid]:ssafile:_files' \
  '-drp[output stream drop analysis text file]:drpfile:_files' \
  '-o[input outlets file (OGR readable dataset)]:outletfile:_files' \
  '-par[threshmin threshmax nthresh steptype (default 5 500 10 0)]:threshmin:' \
  '(-lyrno)-lyrname[OGR layer name for outlets]:layer name:' \
  '(-lyrname)-lyrno[OGR layer number for outlets]:layer number:' \
  '*:file:_files' && ret=0

return ret
