#compdef sheets
# Documentation: https://github.com/maaslalani/sheets
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: terminal CSV spreadsheet; takes a file argument plus optional cell
# read/write expressions (e.g., 'B9', 'B1:B3', 'B7=10'); no documented flags.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:file:_files -g "*.csv"' && ret=0
return ret
