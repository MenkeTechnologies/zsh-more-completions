#compdef iostat-cli
# _iostat-cli — sysstat iostat report CPU and I/O statistics CLI alias (sysstat team, C); custom argparse
# upstream: https://github.com/sysstat/sysstat

_iostat-cli() {
    _arguments \
        '--help[show help]' \
        '-h[human readable output]' \
        '--human[human readable output]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[CPU report only]' \
        '-d[device report only]' \
        '-N[show device-mapper names]' \
        '-H[show only LVM2 devices]' \
        '-j+[id mode]:m:(LABEL UUID PATH ID)' \
        '-k[kilobytes]' \
        '-m[megabytes]' \
        '-o+[output format]:f:(JSON)' \
        '-p+[device]:str:' \
        '-r[serial-style report]' \
        '-s[show short device names]' \
        '-t[show time stamps]' \
        '-T[show short report]' \
        '-x[extended stats]' \
        '-y[skip first report]' \
        '-z[hide zero activity]' \
        '*:interval count device:'
}

_iostat-cli "$@"
