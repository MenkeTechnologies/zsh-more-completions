#compdef cert_req
# Documentation: https://github.com/Mbed-TLS/mbedtls/blob/development/programs/x509/cert_req.c
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above (Mbed TLS X.509 CSR sample program).

# cert_req: Mbed TLS X.509 certificate signing request generator
local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'filename=:input key file (default keyfile.key)'
  'password=:private key password'
  'debug_level=:debug level (default 0)'
  'output_file=:output CSR file (default cert.req)'
  'subject_name=:subject DN (default CN=Cert,O=mbed TLS,C=UK)'
  'san=:Subject Alt Name (semicolon-separated DNS:/URI:/RFC822:/IP:/DN:)'
  'key_usage=:comma-separated key usage'
  'force_key_usage=:force KeyUsage flag (0 or 1)'
  'ns_cert_type=:Netscape cert type'
  'force_ns_cert_type=:force NsCertType (0 or 1)'
  'md=:hash algorithm (default SHA256)'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    if compset -P 'filename='; then
      _files && ret=0
    elif compset -P 'output_file='; then
      _files && ret=0
    elif compset -P 'force_key_usage='; then
      _values flag 0 1 && ret=0
    elif compset -P 'force_ns_cert_type='; then
      _values flag 0 1 && ret=0
    elif compset -P 'md='; then
      _values 'hash' MD5 RIPEMD160 SHA1 SHA224 SHA256 SHA384 SHA512 && ret=0
    elif compset -P 'ns_cert_type='; then
      _values -s , 'cert type' ssl_client ssl_server email object_signing ssl_ca email_ca object_signing_ca && ret=0
    elif compset -P 'key_usage='; then
      _values -s , 'usage' digital_signature non_repudiation key_encipherment data_encipherment key_agreement key_cert_sign crl_sign && ret=0
    else
      _describe -t params 'param' params -S '' && ret=0
    fi
    ;;
esac

return ret
