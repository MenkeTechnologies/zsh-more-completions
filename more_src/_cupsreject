#compdef cupsreject cupsdisable
# Documentation: https://manpages.debian.org/cupsreject
# Source: OpenPrinting/cups systemv/cupsaccept.c — reject/disable CUPS print queues (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[use encryption]' \
    '-U+[username for authentication]:user:_users' \
    '-c[cancel pending jobs (cupsdisable only)]' \
    '-h+[connect to CUPS server[:port]]:host:_hosts' \
    '-r+[reason text]:reason:_default' \
    '*:printer or class:_default' \
    && ret=0

return ret
