#compdef velacc gmx-velacc
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-velacc.html
# gmx velacc: calculate velocity autocorrelation functions

local ret=1

_arguments -s \
  '-f[full precision trajectory]:file:_files' \
  '-s[structure+mass(db)]:file:_files' \
  '-n[index file]:file:_files' \
  '-o[xvgr/xmgr file]:file:_files' \
  '-os[xvgr/xmgr file (spectrum)]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-m[calculate momentum autocorrelation function]' \
  '-recip[use cm-1 on X-axis instead of 1/ps]' \
  '-mol[calculate velocity acf of molecules]' \
  '-acflen[length of ACF]:int:' \
  '-normalize[normalize ACF]' \
  '-P[order of Legendre polynomial]:order:(0 1 2 3)' \
  '-fitfn[fit function]:fn:(none exp aexp exp_exp exp5 exp7 exp9)' \
  '-beginfit[time to begin exponential fit]:real:' \
  '-endfit[time to end exponential fit]:real:' && ret=0

return ret
