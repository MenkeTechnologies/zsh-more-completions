#compdef crate
# Documentation: https://man.archlinux.org/search?q=crate
# Reference accessed: 2026-05-16

# crate: CrateDB SQL database CLI launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-C[Crate config key=value]:setting:' \
  '-E[environment variable]:env=value:' \
  '-d[daemonize]' \
  '-p[PID file]:file:_files' \
  '-s[silent]' \
  '-q[quiet]' \
  '*::crate args:_files' && ret=0
return ret
