#compdef crate
# Documentation: https://cratedb.com/docs/crate/reference/en/latest/cli-tools.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bin/crate: CrateDB server launcher (Elasticsearch-derived flags)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[Print usage information]' \
  '(- *)-v[Print version information]' \
  '*-C-[Set a CrateDB configuration value (overrides config file)]:setting:' \
  '*-D-[Set a Java system property value]:property:' \
  '*-X-[Set a nonstandard Java option]:option:' \
  '-p[Write PID to file]:pidfile:_files' \
  '*::crate args:_files' && ret=0
return ret
