#compdef vipsedit
# Documentation: https://man.archlinux.org/man/extra/libvips/vipsedit.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# vipsedit: edit fields/metadata of a libvips .v image header in place
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)-h[show help]' \
  '--version[show version]' \
  '--xoffset=[set Xoffset header field]:n:' \
  '--yoffset=[set Yoffset header field]:n:' \
  '--xres=[set Xres header field]:n:' \
  '--yres=[set Yres header field]:n:' \
  '--coding=[set coding]:coding:(none labq rad)' \
  '--type=[set interpretation type]:type:(multiband b-w histogram xyz lab cmyk labq rgb cmc lch labs srgb yxy fourier rgb16 grey16 matrix scrgb hsv)' \
  '--format=[set band format]:format:(uchar char ushort short uint int float double complex dpcomplex)' \
  '--endian=[set byte order]:endian:(little big)' \
  '--setext=[set EXIF/XMP extension]:file:_files' \
  '*:vips images:_files -g "*.(v|vips)"' && ret=0
return ret
