#compdef zigbee2mqtt
# Documentation: https://man.archlinux.org/search?q=zigbee2mqtt
# Reference accessed: 2026-05-16

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c=[path to configuration file]:file:_files -g "*.{yml,yaml,json}"' \
  '--config=[path to configuration file]:file:_files -g "*.{yml,yaml,json}"' \
  '-d=[data directory]:dir:_directories' \
  '--data-dir=[data directory]:dir:_directories' \
  '-l=[log level]:level:(debug info warn error)' \
  '--log-level=[log level]:level:(debug info warn error)'
