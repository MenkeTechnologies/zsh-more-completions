#compdef emmake
# Documentation: https://emscripten.org/docs/compiling/Building-Projects.html
# Reference accessed: 2026-06-10

# Zsh completion for emmake - Emscripten make wrapper
# emmake wraps make (or cmake --build, etc.) setting the Emscripten toolchain environment.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:build command:(make cmake ninja)' \
  '*::build args:_normal' && ret=0

return ret
