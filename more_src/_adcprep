#compdef adcprep
# Documentation: https://adcirc.github.io/adcirc/user_guide/running_adcirc/command_line_options.html
# ADCIRC domain decomposition preprocessor.

local ret=1

_arguments -s -S \
  '--np[decompose domain into NUM_SUBDOMAINS subdomains]:num_subdomains:' \
  '--partmesh[partition mesh only; writes partmesh.txt]' \
  '--prepall[decompose all input files into PE* subdirectories]' \
  '--prep13[redecompose nodal attributes file only]' \
  '--prep15[redecompose control/boundary conditions file]' \
  '--prep20[redecompose normal flux boundary condition file]' \
  '--prep88[redecompose upland river initialization file]' && ret=0

return ret
