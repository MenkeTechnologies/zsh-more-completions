#compdef derper
# Documentation: https://pkg.go.dev/tailscale.com/cmd/derper

_arguments -s -S \
  '--addr=[server listen address]:address:' \
  '--http-port=[HTTP port for non-TLS traffic (use -1 to disable)]:port:' \
  '--stun-port=[UDP port for STUN]:port:' \
  '--stun[run a STUN server]' \
  '--certmode=[certificate mode]:mode:(manual letsencrypt)' \
  '--certdir=[directory to store LetsEncrypt certs]:dir:_files -/' \
  '--hostname=[LetsEncrypt hostname]:hostname:_hosts' \
  '--verify-clients[verify clients are authenticated Tailscale nodes]' \
  '--mesh-with=[comma-separated list of DERP servers to mesh with]:url:' \
  '--mesh-psk-file=[file containing pre-shared key for mesh peering]:file:_files' \
  '--bootstrap-dns-names=[comma-separated DNS names to resolve for bootstrapping]:names:' \
  '--unpublished-bootstrap-dns-names=[unpublished bootstrap DNS names]:names:' \
  '--dev[run in dev mode]' \
  '--accept-connection-burst=[burst rate for connection acceptance]:n:' \
  '--accept-connection-limit=[per-second rate limit for connections]:n:' \
  '--logcollection=[log collection endpoint]:url:' \
  && return 0
