#compdef scheme chezscheme
# Documentation: https://github.com/cisco/ChezScheme/blob/main/scheme.1.in
# Reference accessed: 2026-05-17
# Verified: upstream scheme.1.in man page at the URL above.

# Chez Scheme — the binary is typically installed as `scheme` (manpage `chezscheme`).
_arguments \
  '--help[show help and exit]' \
  '--version[show version and exit]' \
  '(-q --quiet)'{-q,--quiet}'[suppress greeting and prompts]' \
  '--script[run file as a shell script]:file:_files' \
  '--program[run RNRS program file as a shell script]:file:_files' \
  '--libdirs[library directories]:dirs:' \
  '--libexts[library extensions]:exts:' \
  '--compile-imported-libraries[compile libraries before loading]' \
  '--import-notify[enable import search messages]' \
  '--optimize-level=[optimization level]:level:(0 1 2 3)' \
  '--debug-on-exception[enter debugger on uncaught exception]' \
  '--eedisable[disable expression editor]' \
  '--eehistory=[history file or off]:value:' \
  '--enable-object-counts[maintain object counts in collector]' \
  '--retain-static-relocation[keep relocation information]' \
  '(-b --boot)'{-b,--boot}'+[boot file]:file:_files' \
  '--verbose[trace boot file search]' \
  '*:files:_files' && return 0
