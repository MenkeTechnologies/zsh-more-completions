#compdef chezscheme

_arguments \
  '-h[Show help]' \
  '-V[Show version]' \
  '-q[Quiet mode, suppress greeting and prompt]' \
  '-b[Boot file]:file:_files' \
  '--eedisable[Disable expression editor]' \
  '--verbose[Verbose boot messages]' \
  '--version[Show version]' \
  '--help[Show help]' \
  '--script[Run as script]:file:_files' \
  '--program[Run as R6RS program]:file:_files' \
  '--libdirs[Library directories]:dirs:' \
  '--libexts[Library extensions]:exts:' \
  '--compile-imported-libraries[Compile imported libraries]' \
  '--import-notify[Notify on library import]' \
  '--optimize-level=[Optimization level]:level:(0 1 2 3)' \
  '--debug-on-exception[Enter debugger on exception]' \
  '--eehistory=[History file]:file:_files' \
  '--save-profile=[Save profile to file]:file:_files' \
  '--profile-clear[Clear profile data]' \
  '--suppress-greeting[Suppress greeting]' \
  '*:files:_files' && return 0
