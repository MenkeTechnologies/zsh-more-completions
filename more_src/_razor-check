#compdef razor-check
# Documentation: https://linux.die.net/man/1/razor-check
# Razor filtering agent: check a mail against the Razor catalogue

local ret=1

_arguments -s -S \
  '-h[print usage message]' \
  '-v[print version number]' \
  '(-d --verbose)'{-d,--verbose}'[print debugging information]' \
  '-debuglevel=[set debug level]:level' \
  '-dl=[set debug level]:level' \
  '-whitelist=[whitelist file]:file:_files' \
  '-s[simulate a check without contacting the server]' \
  '-conf=[alternate configuration file]:file:_files' \
  '-home=[razorhome directory]:dir:_files -/' \
  '-logfile=[log file]:file:_files' \
  '-rs=[use a specific Razor server]:server' \
  '-H[compute and print mail signature, then exit]' \
  '-S=[accept pre-computed signatures]:string' \
  '-e=[signature engine (1-4)]:engine:(1 2 3 4)' \
  '-ep4=[engine 4 signature string]:string' \
  '*:mail file:_files' && ret=0

return ret
