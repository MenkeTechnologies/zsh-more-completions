#compdef eimagecombine
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/eimagecombine/node7.html
# Combine EPIC vignetting-corrected background-subtracted images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--prefix=[file name prefix for the output files]:prefix' \
  '--withcheckinput=[check individual input images for consistency]:bool:(yes no)' \
  '--maskindividual=[mask images of individual exposures]:bool:(yes no)' \
  '--withaddimages=[add the images of individual exposures]:bool:(yes no)' \
  '--withcombineimages=[combine the individual EPIC instruments]:bool:(yes no)' \
  '--ecut=[exposure cut in seconds, less is masked]:seconds' \
  '--exposureband=[energy band of the exposure map for the mask]:band' \
  '--epn_weight=[exposure weight per energy band of EPIC-pn]:weight' \
  '--em1_weight=[exposure weight per energy band of EPIC-MOS1]:weight' \
  '--em2_weight=[exposure weight per energy band of EPIC-MOS2]:weight' \
  '--withasmooth=[create smoothed and corrected images]:bool:(yes no)' \
  '--smoothstyle=[type of smoothing]:style:(simple adaptive)' \
  '--convolverstyle=[convolver shape for simple smoothing]:style:(gaussian tophat squarebox)' \
  '--width=[width of the convolver for simple smoothing]:value' \
  '--withuserwidths=[read a list of gaussian-convolver sigma values]:bool:(yes no)' \
  '--userwidths=[gaussian-convolver sigma values for adaptive smoothing]:values' \
  '--minwidth=[minimum sigma value for adaptive gaussian convolvers]:value' \
  '--maxwidth=[maximum sigma value for adaptive gaussian convolvers]:value' \
  '--desiredsnr=[desired signal-to-noise ratio in smoothed image]:value' \
  '--nconvolvers=[number of gaussian convolvers for adaptive smoothing]:n' \
  '--templatebands=[energy bands to estimate smoothing template statistics]:bands' \
  '--keepinterstage=[keep intermediate products]:bool:(yes no)' \
  '--n_parallel=[max number of parallelly executed processes]:n' \
  '*:param=value:_default' && ret=0

return ret
