#compdef graphmod
# Documentation: https://hackage.haskell.org/package/graphmod
# Render the module dependency graph of a Haskell program as a Graphviz dot graph

local ret=1

_arguments -s -S \
  '(-q --quiet)'{-q,--quiet}'[do not show warnings]' \
  '*-i+[add a search directory]:dir:_files -/' \
  '(-a --all)'{-a,--all}'[add nodes for missing modules]' \
  '--no-cluster[do not cluster directories]' \
  '--no-module-in-cluster[do not place modules matching a cluster name inside it]' \
  '*'{-r,--remove-module}'=[do not display module NAME]:name' \
  '*'{-R,--remove-qual}'=[do not display modules NAME.*]:name' \
  '*'{-c,--collapse}'=[display modules NAME.* as one node]:name' \
  '*'{-C,--collapse-module}'=[display modules NAME and NAME.* as one node]:name' \
  '(-p --prune-edges)'{-p,--prune-edges}'[remove imports if module is imported by another imported module]' \
  '(-d --graph-dim)'{-d,--graph-dim}'=[set dimensions of the graph (SIZE,SIZE)]:size' \
  '(-s --colors)'{-s,--colors}'=[choose a color scheme number (0-5)]:num' \
  '--no-cabal[do not use Cabal for paths and modules]' \
  '--single-main[do not try to disambiguate multiple main modules]' \
  '(-v --version)'{-v,--version}'[show the current version]' \
  '*:file:_files' && ret=0

return ret
