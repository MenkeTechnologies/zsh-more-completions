#compdef ecsta
# _ecsta — fujiwara/ecsta (AWS ECS task helper: list/describe/stop/exec/portforward tasks, push/pull task definitions, trace task lifecycle events; --cluster + --service scope queries, --task-id targets a task)
# upstream: https://github.com/fujiwara/ecsta
# Subcommands from ecsta cmd on tip.

_ecsta() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--cluster+[cluster]:cluster:' \
        '--region+[AWS region]:region:' \
        '--config+[config file]:file:_files' \
        '--output+[output format]:format:(table tsv json)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'ecsta command' '(list describe stop exec portforward trace cp logs configure)' ;;
        args) _arguments '--service+[service]:service:' '--task-id+[task ID]:taskid:' '--container+[container]:name:' '*::arg:_files' ;;
    esac
}

_ecsta "$@"
