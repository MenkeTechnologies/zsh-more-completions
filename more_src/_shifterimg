#compdef shifterimg
# Documentation: https://docs.nersc.gov/development/containers/shifter/how-to-use/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# shifterimg: manage images in Shifter image gateway
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'login:login to a registry'
  'logout:logout'
  'pull:pull an image'
  'images:list images'
  'lookup:look up image id'
  'expire:expire image'
  'export:export image'
  'import:import image'
  'rmi:remove image'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--verbose[verbose]' \
  '--user=[user]:user:_users' \
  '--password[ask password]' \
  '--type=[image type]:type:(docker custom local)' \
  '--insecure[insecure (skip TLS verify)]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'shifterimg command' commands && ret=0 ;;
esac
return ret
