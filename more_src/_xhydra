#compdef xhydra
# _xhydra — Marc van Hauser THC xhydra CLI GTK graphical frontend to the THC-Hydra parallel network login cracker presenting target service password list user list timing module-specific options as forms launching hydra processes with the chosen brute-force configuration for SSH FTP HTTP MySQL VNC Telnet protocols (THC team, GTK); custom argparse
# upstream: https://github.com/vanhauser-thc/thc-hydra

_xhydra() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--display=+[X display]:str:' \
        '--screen=+[N]:n:' \
        '--name=+[name]:str:' \
        '--class=+[class]:str:' \
        '--no-xshm[no shared memory]' \
        '--sync[X sync]' \
        '*::'
}

_xhydra "$@"
