#compdef upsmon

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-c+[command for running daemon]:cmd:(fsd stop reload)' \
  '-P+[pid file]:file:_files' \
  '-D[debug, do not fork]' \
  '-K[check shutdown flag and exit]' \
  '-F[run in foreground]' \
  '-B[run in background]' \
  '-u+[switch to user]:user:_users' \
  '-p[run as root - no setuid]' && ret=0

return ret
