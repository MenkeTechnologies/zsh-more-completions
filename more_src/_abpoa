#compdef abpoa

# ABPOA — https://github.com/yangao07/ABPOA — options from `abpoa --help` (adaptive banded POA).

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-i,--in}"=[input FASTA/FASTQ]:file:_files" \
  {-o,--out}"=[output consensus]:file:_files" \
  {-c,--cons}"=[homopolymer compression threshold]: " \
  '(-d --amb)'{-d,--amb}'[mark heterozygous columns in consensus]' \
  {-r,--revsg}'[include reverse complement of each sequence]' \
  {-M,--max-matrix}"=[adaptive band width]: " \
  '(-f --gap-freq)'{-f,--gap-freq}"=[gap frequency factor]: " \
  {-p,--progress}'[print progress to stderr]' \
  '(-t --threads)'{-t,--threads}"=[worker threads]: " \
  '-->[read sequences from stdin instead of -i]' \
  '*:sequence file:_files' && ret=0

return ret
