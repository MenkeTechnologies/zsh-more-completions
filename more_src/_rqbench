#compdef rqbench
# Documentation: https://github.com/rqlite/rqlite/blob/master/cmd/rqbench/main.go
# rqbench - rqlite write-performance benchmarking tool

local ret=1

_arguments -s \
  '-a[node address]:address' \
  '-n[number of requests]:count' \
  '-b[statements per request]:batch size' \
  '-m[print progress every m requests]:m' \
  '-x[use explicit transaction per request]' \
  '-q[use queued writes]' \
  '-t[transport to use]:transport' \
  '-p[endpoint to use]:path' \
  '-o[one-shot execute statement to preload]:statement' \
  '*:statement' && ret=0

return ret
