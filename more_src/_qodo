#compdef qodo
# Documentation: https://github.com/qodo-ai/command
# Reference accessed: 2026-05-22
# Verified: docs.qodo.ai CLI commands and flags reference.

# Zsh completion for qodo - Qodo Command AI agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--agent-file[agent TOML file or URL]:file:_files' \
  '--chat[keep interacting after run]' \
  '--ui[open web interface]' \
  '--model[custom model]:model:' \
  '--ci[CI mode]' \
  '--mcp[run agents as MCP server on port 3000]' \
  '--webhook[run agents as HTTP webhook tools]' \
  '--resume[resume session]:session-id:' \
  '--sandbox[sandbox mode macOS]:mode:(off permissive restrictive)' \
  '--tool[tool to use]:tool:' \
  '(-t --tools)'{-t,--tools}'[comma-separated tools]:tools:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'qodo command' \
      'login[authenticate and receive API key]' \
      'chat[interactive chat mode]' \
      'list-mcp[list MCP tools]' \
      'models[list available models]' \
      'key[manage API keys]' && ret=0
    ;;
  args)
    case $line[1] in
      key)
        _values 'key action' list create revoke && ret=0
        case $line[2] in
          create|revoke)
            _arguments '1:key name:' && ret=0
            ;;
        esac
        ;;
      chat)
        _arguments '*:prompt:' && ret=0
        ;;
    esac
    ;;
esac

return ret
