#compdef mcp-inspector

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cli[enable CLI mode (no UI)]' \
  '--config=[configuration file path]:file:_files -g "*.json"' \
  '--server=[server name from config]:server:' \
  '--method=[operation to run]:method:(tools/list tools/call resources/list resources/read prompts/list prompts/get logging/setLevel completion/complete ping)' \
  '--tool-name=[tool to invoke]:tool:' \
  '*--tool-arg=[tool argument key=value (repeatable)]:arg:' \
  '--resource-uri=[resource URI to access]:uri:' \
  '--prompt-name=[prompt name]:prompt:' \
  '*--prompt-arg=[prompt argument key=value (repeatable)]:arg:' \
  '--transport=[transport type]:transport:(stdio sse http streamable-http)' \
  '*--header=[custom HTTP header (repeatable)]:header (key\:value):' \
  '*-e+[env var key=value (repeatable)]:env:' \
  '--port=[UI port]:port:' \
  '--server-port=[proxy port]:port:' \
  '--auto-open[auto-open browser]' \
  '--no-auth[disable proxy auth (dangerous)]' \
  '*::server_command:_files' && ret=0

return ret
