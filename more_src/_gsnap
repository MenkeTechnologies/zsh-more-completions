#compdef gsnap gsnapl
# Documentation: https://manpages.debian.org/testing/gmap/gsnap.1.en.html
# Genomic short-read nucleotide alignment program

local ret=1

_arguments -s -S \
  '(-D --dir)'{-D,--dir=}'[genome directory]:dir:_files -/' \
  '(-d --db)'{-d,--db=}'[genome database]:db:' \
  '--two-pass[two-pass mode to identify splice sites and introns, then align]' \
  '--use-localdb=[whether to use the local suffix arrays]:int:' \
  '(-C --transcriptdir)'{-C,--transcriptdir=}'[transcriptome directory]:dir:_files -/' \
  '(-c --transcriptdb)'{-c,--transcriptdb=}'[transcriptome database]:db:' \
  '--transcriptome-mode=[transcriptome mode]:mode:(assist only annotate)' \
  '(-k --kmer)'{-k,--kmer=}'[kmer size to use in genome database]:int:' \
  '--sampling=[sampling to use in genome database]:int:' \
  '--align-fraction=[process only the given fraction of reads, selected at random]:float:' \
  '(-q --part)'{-q,--part=}'[process only the i-th out of every n sequences]:part:' \
  '--input-buffer-size=[size of input buffer]:int:' \
  '--barcode-length=[amount of barcode to remove from start of every read]:int:' \
  '--endtrim-length=[amount of trim to remove from the end of every read]:int:' \
  '--orientation=[orientation of paired-end reads]:orientation:(FR RF FF 10X)' \
  '--10x-whitelist=[whitelist of 10X Genomics GEM bead barcodes]:file:_files' \
  '--10x-well-position=[position of well information in the accession]:int:' \
  '--fastq-id-start=[starting position of identifier in FASTQ header]:int:' \
  '--fastq-id-end=[ending position of identifier in FASTQ header]:int:' \
  '--force-single-end[treat each file as single-end when multiple FASTQ files are provided]' \
  '--filter-chastity=[skip reads marked by the Illumina chastity program]:value:(off either both)' \
  '--allow-pe-name-mismatch[allow accession names of reads to mismatch in paired-end files]' \
  '--interleaved[input is in interleaved format]' \
  '--gunzip[uncompress gzipped input files]' \
  '--bunzip2[uncompress bzip2-compressed input files]' \
  '(-B --batch)'{-B,--batch=}'[batch mode]:int:' \
  '--use-shared-memory=[if 1, allocated memory is shared among all processes on this node]:int:' \
  '--preload-shared-memory[load files indicated by --batch mode into shared memory]' \
  '--unload-shared-memory[unload files from shared memory]' \
  '(-m --max-mismatches)'{-m,--max-mismatches=}'[maximum number of mismatches allowed]:float:' \
  '--query-unk-mismatch=[whether to count N characters in the query as a mismatch]:int:' \
  '--genome-unk-mismatch=[whether to count N characters in the genome as a mismatch]:int:' \
  '--maxsearch=[maximum number of alignments to find]:int:' \
  '--indel-endlength=[minimum length at end required for indel alignments]:int:' \
  '--max-insertions=[maximum number of insertions allowed]:int:' \
  '--max-deletions=[maximum number of deletions allowed]:int:' \
  '(-M --suboptimal-levels)'{-M,--suboptimal-levels=}'[report suboptimal hits beyond best hit]:int:' \
  '(-a --adapter-strip)'{-a,--adapter-strip=}'[method for removing adapters from reads]:method:' \
  '(-e --use-mask)'{-e,--use-mask=}'[use genome containing masks for scoring preference]:mask:' \
  '(-V --snpsdir)'{-V,--snpsdir=}'[directory for SNPs index files]:dir:_files -/' \
  '(-v --use-snps)'{-v,--use-snps=}'[use database containing known SNPs]:db:' \
  '--cmetdir=[directory for methylcytosine index files]:dir:_files -/' \
  '--atoidir=[directory for A-to-I RNA editing index files]:dir:_files -/' \
  '--mode=[alignment mode]:mode:(standard cmet-stranded cmet-nonstranded atoi-stranded atoi-nonstranded ttoc-stranded ttoc-nonstranded)' \
  '(-t --nthreads)'{-t,--nthreads=}'[number of worker threads]:int:' \
  '--find-dna-chimeras=[look for distant splicing involving poor splice sites]:int:' \
  '(-N --novelsplicing)'{-N,--novelsplicing=}'[look for novel splicing]:int:' \
  '--splicingdir=[directory for splicing involving known sites or known introns]:dir:_files -/' \
  '(-s --use-splicing)'{-s,--use-splicing=}'[look for splicing involving known sites or known introns]:value:' \
  '--splices-noeval[do not evaluate splices for probability or intron length]' \
  '--splices-dump=[write splice junction information to FILE]:file:_files' \
  '--splices-exclude-known[in the file for --splices-dump, exclude all known introns]' \
  '(-w --localsplicedist)'{-w,--localsplicedist=}'[definition of local novel splicing event]:int:' \
  '--merge-distant-samechr[report distant splices on the same chromosome as a single splice]' \
  '--pairmax-dna=[max total genomic length for DNA-Seq paired reads]:int:' \
  '--pairmax-rna=[max total genomic length for RNA-Seq paired reads]:int:' \
  '--resolve-inner=[whether to resolve soft-clipping on the insides of paired-end reads]:int:' \
  '--pairexpect=[expected paired-end length]:int:' \
  '--pairdev=[allowable deviation from expected paired-end length]:int:' \
  '--pass1-min-support=[threshold read support for learning an intron during pass 1]:int:' \
  '--quality-protocol=[protocol for input quality scores]:protocol:(illumina sanger)' \
  '(-J --quality-zero-score)'{-J,--quality-zero-score=}'[FASTQ quality scores are zero at this ASCII value]:int:' \
  '(-j --quality-print-shift)'{-j,--quality-print-shift=}'[shift FASTQ quality scores by this amount in output]:int:' \
  '(-n --npaths)'{-n,--npaths=}'[maximum number of paths to print]:int:' \
  '(-Q --quiet-if-excessive)'{-Q,--quiet-if-excessive}'[if more than max paths are found, print nothing]' \
  '(-O --ordered)'{-O,--ordered}'[print output in same order as input]' \
  '--show-refdiff[show all differences relative to the reference genome as lower case]' \
  '--clip-overlap[for paired-end reads whose alignments overlap, clip the overlapping region]' \
  '--merge-overlap[for paired-end reads whose alignments overlap, merge the two ends]' \
  '--print-snps[print detailed information about SNPs in reads]' \
  '--failsonly[print only failed alignments]' \
  '--nofails[exclude printing of failed alignments]' \
  '--only-concordant[print only concordant alignments]' \
  '--omit-concordant-uniq[do not print any concordant_uniq alignments]' \
  '--omit-concordant-mult[do not print any concordant_mult alignments]' \
  '--omit-softclipped[do not allow any alignments with soft clips]' \
  '--only-tr-consistent[print only alignments with consistent transcripts]' \
  '(-A --format)'{-A,--format=}'[another format type]:format:(sam m8)' \
  '--split-output=[basename for multiple-file output]:basename:' \
  '(-o --output-file)'{-o,--output-file=}'[file name for a single stream of output results]:file:_files' \
  '--failed-input=[print completely failed alignments as input FASTA or FASTQ]:basename:' \
  '--append-output[append output to existing files]' \
  '--order-among-best=[order alignments tied with the best score]:order:(genomic random)' \
  '--output-buffer-size=[buffer size, in queries, for output thread]:int:' \
  '--no-sam-headers[do not print headers beginning with @]' \
  '--add-paired-nomappers[add nomapper lines to make all paired-end results alternate]' \
  '--paired-flag-means-concordant=[whether the paired bit in SAM flags means concordant only]:int:' \
  '--sam-headers-batch=[print headers only for this batch]:int:' \
  '--sam-hardclip-use-S[use S instead of H for hardclips]' \
  '--sam-use-0M=[insert 0M in CIGAR between adjacent indels and introns]:int:' \
  '--sam-extended-cigar[use extended CIGAR format (X and = instead of M)]' \
  '--sam-multiple-primaries[allow multiple alignments to be marked as primary if equally good]' \
  '--sam-sparse-secondaries[for secondary alignments, use * for SEQ and QUAL fields]' \
  '--force-xs-dir[disallow XS:A:? and replace with XS:A:+]' \
  '--md-report-snps[in MD string, when known SNPs are given, print difference nucleotides]' \
  '--no-soft-clips[do not allow soft clips at ends]' \
  '--extend-soft-clips[extend alignments through soft clipped regions]' \
  '--action-if-cigar-error[action if CIGAR length disagrees with sequence length]:action:' \
  '--read-group-id=[value to put into read-group id (RG-ID) field]:id:' \
  '--read-group-name=[value to put into read-group name (RG-SM) field]:name:' \
  '--read-group-library=[value to put into read-group library (RG-LB) field]:lib:' \
  '--read-group-platform=[value to put into read-group platform (RG-PL) field]:platform:' \
  '--check[check compiler assumptions]' \
  '--version[show version]' \
  '--help[show this help message]' \
  '*:fastq read file:_files' && ret=0

return ret
