#compdef iotbx.mtz.dump
# Documentation: https://cci.lbl.gov/docs/cctbx/
# iotbx.mtz.dump - print information about an MTZ reflection file (cctbx/iotbx)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[show more details]' \
  '(-c --show_column_data)'{-c,--show_column_data}'[show column data]' \
  '(-f --column_data_format)'{-f,--column_data_format=}'[format for column data]:format:(human spreadsheet)' \
  '(-b --show_batches)'{-b,--show_batches}'[show batch information]' \
  '--walk[recursively process directories]' \
  '*:mtz file:_files -g "*.mtz"' && ret=0

return ret
