#compdef airlift

# jl178/airlift — local Airflow via kind/helm (README.md). Subcommands: start, check, pause,
# unpause, remove, status, import_variables, run_dag.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'start:start local Airflow cluster'
  'check:verify docker/helm/kind installed'
  'pause:pause Airflow deployment'
  'unpause:resume Airflow deployment'
  'remove:delete kind cluster and containers'
  'status:report whether UI is reachable'
  'import_variables:upload variables.json to running instance'
  'run_dag:trigger DAG by id'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'airlift subcommand' subcmds && ret=0
    ;;
  rest)
    _arguments -s -S \
      '-d+[path to DAGs]:directory:_files -/' \
      '-p+[path to plugins]:directory:_files -/' \
      '-r+[requirements.txt]:file:_files' \
      '-c+[airlift YAML config]:file:_files' \
      '-P+[Airflow UI port]:port' \
      '-V+[variables.json path]:file:_files' \
      '-D+[DAG id to run]:dag' && ret=0
    ;;
esac

return ret
