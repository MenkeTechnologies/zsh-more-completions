#compdef capacitor cap
# Documentation: https://man.archlinux.org/search?q=capacitor
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new Capacitor project'
  'add:add a native platform (ios|android)'
  'sync:copy + update web code into native projects'
  'copy:copy web assets into native projects'
  'update:update native deps and Capacitor plugins'
  'open:open the native IDE for the project'
  'run:build and run on a device/emulator'
  'build:build a native binary'
  'serve:serve web assets via local server'
  'doctor:diagnose problems with the project'
  'ls:list installed Capacitor plugins'
  'config:get a value from capacitor.config'
  'plugin:plugin scaffolding utilities'
  'migrate:migrate Capacitor projects to a new version'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--verbose[verbose output]' \
  '--no-color[disable color output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cap command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '--web-dir=[directory containing web assets]:dir:_files -/' \
          '*::app_name_id:' && ret=0 ;;
      (add)
        _arguments \
          '--packagemanager=[package manager]:pm:(npm yarn pnpm bun)' \
          '*::platform:(ios android web electron)' && ret=0 ;;
      (sync|copy|update|open)
        _arguments \
          '--inline[use inline source maps]' \
          '--deployment[use --deployment for cocoapods (sync/copy)]' \
          '*::platform:(ios android web electron)' && ret=0 ;;
      (run)
        _arguments \
          '--list[list available targets]' \
          '--target=[target by id]:id:' \
          '--target-name=[target by name]:name:' \
          '--target-name-sdk-version=[target name + sdk version]:name_sdk:' \
          '--no-sync[skip sync before run]' \
          '--scheme=[iOS scheme]:scheme:' \
          '--config=[Android build configuration]:config:' \
          '--flavor=[Android product flavor]:flavor:' \
          '--forwardPorts=[ports to adb reverse]:ports:' \
          '--live-reload[enable live reload]' \
          '--host=[live-reload host]:host:' \
          '--port=[live-reload port]:port:' \
          '--external[bind dev server to all interfaces]' \
          '*::platform:(ios android)' && ret=0 ;;
      (build)
        _arguments \
          '--scheme=[iOS scheme]:scheme:' \
          '--flavor=[Android flavor]:flavor:' \
          '--configuration=[build configuration]:config:(Debug Release)' \
          '--keystorepath=[path to Android keystore]:file:_files' \
          '--keystorepass=[Android keystore password]:pwd:' \
          '--keystorealias=[keystore alias]:alias:' \
          '--keystorealiaspass=[keystore alias password]:pwd:' \
          '--androidreleasetype=[Android release type]:type:(APK AAB)' \
          '--signing-type=[iOS signing type]:type:(jarsigner apksigner)' \
          '*::platform:(ios android)' && ret=0 ;;
      (config)
        _arguments \
          '--json[output JSON]' \
          '*::key:' && ret=0 ;;
      (migrate)
        _arguments \
          '--noprompt[do not prompt]' \
          '--packagemanager=[package manager]:pm:(npm yarn pnpm bun)' && ret=0 ;;
      (plugin)
        _arguments '*::sub:(generate)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
