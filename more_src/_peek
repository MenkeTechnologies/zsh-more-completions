#compdef peek
# Documentation: https://manpages.debian.org/bookworm/peek/peek.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-gapplication[show GApplication options]' \
  '(- *)--help-gtk[show GTK options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --backend)'{-b,--backend}'[recording backend]:backend:(ffmpeg gnome-shell)' \
  '--display=[X11 display]:display:' \
  '--no-headerbar[disable header bar]' \
  '(-s --start)'{-s,--start}'[start recording immediately]' \
  '(-p --stop)'{-p,--stop}'[stop active recording]' \
  '(-t --toggle)'{-t,--toggle}'[toggle recording]' && ret=0
return ret
