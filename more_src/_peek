#compdef peek
# Documentation: https://man.archlinux.org/search?q=peek
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-b --backend)'{-b,--backend}'[recording backend]:backend:(ffmpeg gnome-shell)' \
  '--display[X11 display]:display' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--no-headerbar[disable header bar]' \
  '(-s --start)'{-s,--start}'[start recording immediately]' \
  '(-t --toggle)'{-t,--toggle}'[toggle recording]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0
return ret
