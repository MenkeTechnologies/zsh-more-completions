#compdef mangal

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'update:update mangal'
  'search:search for manga'
  'inline:search and download in non-interactive mode'
  'sources:manage manga sources'
  'config:manage configuration'
  'where:show config/cache/download path'
  'clear:clear cache and temp files'
  'doctor:check for problems'
  'version:show version'
  'completion:generate shell completions'
  'env:show environment variables'
  'gen:generate a source template'
  'integration:manage integrations (Anilist)'
  'web:start the web interface'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mangal command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (inline)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-s[source name]:source:' \
          '-q[search query]:query:' \
          '-m[manga index]:index:' \
          '-c[chapter index or range]:range:' \
          '-f[output format]:format:(pdf cbz zip plain epub)' \
          '-d[download directory]:dir:_files -/' \
          '-j[JSON output]' && ret=0
        ;;
      (sources)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--install[install a source]:source:' \
          '--remove[remove a source]:source:' \
          '--raw[print raw list]' && ret=0
        ;;
      (config)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--set[set a config value]:key value:' \
          '--get[get a config value]:key:' \
          '--env[show as environment variable]:key:' \
          '--info[show config info]' && ret=0
        ;;
      (where)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--config[show config path]' \
          '--cache[show cache path]' \
          '--downloads[show downloads path]' \
          '--sources[show sources path]' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
