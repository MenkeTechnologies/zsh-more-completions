#compdef mangal
# Documentation: https://github.com/metafates/mangal
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'mini:launch mini mode'
  'inline:search and download in non-interactive mode'
  'sources:manage sources/scrapers'
  'config:manage configuration'
  'where:show config/cache/download/sources path'
  'run:test a custom scraper'
  'env:show available environment variables'
  'help:show help'
  'version:show version'
  'completion:generate shell completion'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mangal command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (inline)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (sources)
        local -a sources_subs=(
          'install:browse and install a scraper'
          'gen:generate a new scraper template'
        )
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:->sub' && ret=0
        case $state in
          (sub) _describe -t sources_subs 'sources subcommand' sources_subs && ret=0 ;;
        esac
        ;;
      (config)
        local -a config_subs=(
          'get:get a config value'
          'set:set a config value'
          'reset:reset config to defaults'
          'info:list config fields with descriptions'
          'write:write current config to file'
        )
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:->sub' && ret=0
        case $state in
          (sub) _describe -t config_subs 'config subcommand' config_subs && ret=0 ;;
        esac
        ;;
      (where)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--config[show config path]' \
          '--cache[show cache path]' \
          '--downloads[show downloads path]' \
          '--sources[show sources path]' && ret=0
        ;;
      (run)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:scraper file:_files' && ret=0
        ;;
      (completion)
        _arguments \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
