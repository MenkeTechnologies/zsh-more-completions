#compdef zfs-rename
# _zfs-rename — OpenZFS zfs rename rename dataset CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-rename() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-f[force unmount]' \
        '-p[create parent datasets if needed]' \
        '-r[recursive rename]' \
        '-u[do not mount]' \
        '*:source dataset target:'
}

_zfs-rename "$@"
