#compdef gfal-copy
# Documentation: https://man.archlinux.org/search?q=gfal-copy
# Reference accessed: 2026-05-16

# gfal-copy: copy files via Grid File Access Library
local curcontext="$curcontext" ret=1
_arguments -C \
'(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '-r[recursive]' \
  '--recursive[recursive]' \
  '-f[force overwrite]' \
  '--force[force overwrite]' \
  '-K[checksum algorithm]:algo:(MD5 ADLER32 SHA1 SHA256)' \
  '--checksum=[checksum algorithm]:algo:(MD5 ADLER32 SHA1 SHA256)' \
  '-p[create parent dirs]' \
  '--parent[create parent dirs]' \
  '-n[parallel transfers]:n:' \
  '--nstreams=[parallel transfers]:n:' \
  '-T[timeout (s)]:s:' \
  '--timeout=[timeout (s)]:s:' \
  '--from-file=[source list file]:file:_files' \
  '--src-spacetoken=[source space token]:token:' \
  '--dst-spacetoken=[dest space token]:token:' \
  '--just-copy[skip checksum/staging]' \
  '--cancel=[seconds before cancel]:s:' \
  '--ipv4[force IPv4]' \
  '--ipv6[force IPv6]' \
  '*:src dst:_files' && ret=0
return ret
