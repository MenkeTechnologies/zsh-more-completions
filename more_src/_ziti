#compdef ziti
# _ziti — OpenZiti CLI for zero-trust networking (openziti/ziti)
# upstream: https://github.com/openziti/ziti
# Subcommands from ziti/cmd/cmd.go (cobra).

_ziti() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'edge:edge management commands'
                'fabric:fabric management commands'
                'router:run a Ziti router'
                'controller:run a Ziti controller'
                'pki:Ziti PKI operations'
                'create:create configs / PKI artifacts'
                'agent:control a running agent process'
                'database:database operations'
                'login:login to the Ziti edge'
                'logout:log out of the Ziti edge'
                'demo:run demos'
                'tunnel:run a Ziti tunneler'
                'ops:operational utilities'
                'cluster:cluster management'
                'export:export controller data'
                'import:import controller data'
                'art:show Ziti ASCII art'
                'enroll:enroll an identity / router'
                'version:show version'
                'completion:generate shell completions'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_ziti "$@"
