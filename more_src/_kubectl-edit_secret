#compdef kubectl-edit_secret
# Documentation: https://man.archlinux.org/search?q=kubectl-edit_secret
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '*:secret name:_default'
