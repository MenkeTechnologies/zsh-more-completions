#compdef kubectl-edit_secret
# Documentation: https://github.com/BardiaYaghmaie/kubectl-edit-secret
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. krew replaces `-` with `_`
# in the binary name; invoked as `kubectl edit-secret` via krew.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-e --editor)'{-e+,--editor=}'[editor to use for editing]:editor:_command_names' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:' \
  '--context=[Kubernetes context]:context:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '*:secret name:_default'
