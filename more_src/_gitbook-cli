#compdef gitbook-cli
# Documentation: https://github.com/GitbookIO/gitbook-cli
# GitBook CLI version manager and builder

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--gitbook=[gitbook version to use]:version:' \
  '--log=[logging level]:level:' \
  '--format=[output format]:format:' \
  '--output=[output directory]:dir:_files -/' \
  '--port=[server port]:port:' \
  '--watch[watch for file changes]' \
  '--live[enable live reload]' \
  '--open[open in browser]' \
  '--browser=[browser to use]:browser:' \
  '1:command:(build serve install pdf epub mobi init ls ls-remote fetch alias uninstall update current help)' \
  '*::arg:_files' && ret=0

return ret
