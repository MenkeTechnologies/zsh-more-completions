#compdef rust-parallel
# Documentation: https://github.com/aaronriekenberg/rust-parallel/wiki/Manual
# rust-parallel - run commands in parallel, similar interface to GNU parallel or xargs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-d --discard-output)'{-d,--discard-output}'=[redirect command output to /dev/null]:target:(stdout stderr all)' \
  '(-i --input-file)'{-i,--input-file}'=[input file or - for stdin]:input file:_files' \
  '(-j --jobs)'{-j,--jobs}'=[maximum number of commands to run in parallel]:jobs:' \
  '(-0 --null-separator)'{-0,--null-separator}'[use null separator for reading input files]' \
  '(-p --progress-bar)'{-p,--progress-bar}'[display progress bar]' \
  '--progress-bar-style=[progress bar style]:style:' \
  '(-r --regex)'{-r,--regex}'=[apply regex pattern to inputs]:regex:' \
  '(-s --shell)'{-s,--shell}'[use shell mode for running commands]' \
  '(-t --timeout-seconds)'{-t,--timeout-seconds}'=[timeout seconds for running commands]:seconds:' \
  '--channel-capacity=[input and output channel capacity]:capacity:' \
  '--disable-path-cache[disable command path cache]' \
  '--dry-run[do not actually run commands just log]' \
  '--exit-on-error[exit immediately when a command fails]' \
  '--no-run-if-empty[do not run commands for empty buffered input lines]' \
  '(-k --keep-order)'{-k,--keep-order}'[keep output in the same order as input]' \
  '--pipe[use pipe input mode]' \
  '--block-size=[block size for pipe input mode]:size:' \
  '--shell-path=[path to shell to use for shell mode]:shell:_files' \
  '--shell-argument=[argument to shell for shell mode]:argument:' \
  '*:command and arguments:_command_names' && ret=0

return ret
