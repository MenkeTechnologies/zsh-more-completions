#compdef lshw-gtk
# Documentation: https://man.archlinux.org/search?q=lshw-gtk
# Reference accessed: 2026-05-16

# lshw-gtk: GTK frontend to lshw hardware lister
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*::lshw-gtk args:_files' && ret=0
return ret
