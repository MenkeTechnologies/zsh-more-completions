#compdef mail.maildir
# _mail.maildir — OpenSMTPD mail.maildir delivery helper (reads stdin and stores it as one new file in a Maildir; called by smtpd(8) for maildir destinations)
# upstream: https://github.com/OpenSMTPD/OpenSMTPD
# Flags from usr.sbin/smtpd/mail.maildir.8 on tip.

_mail.maildir() {
    _arguments \
        '-j[scan for X-Spam header; route positive matches to the Junk folder]' \
        '1:pathname:_files -/'
}

_mail.maildir "$@"
