#compdef pesign
# Documentation: https://manpages.debian.org/bookworm/pesign/pesign.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm pesign(1) manpage OPTIONS.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# pesign: sign PE-format binaries (e.g. UEFI Secure Boot)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-i --in)'{-i+,--in=}'[input binary]:file:_files' \
  '(-o --out)'{-o+,--out=}'[output binary]:file:_files' \
  '(-n --certdir)'{-n+,--certdir=}'[NSS certificate database directory]:dir:_files -/' \
  '(-t --nss-token)'{-t+,--nss-token=}'[NSS token]:token:' \
  '(-c --certificate)'{-c+,--certificate=}'[certificate nickname for signing]:nickname:' \
  '(-f --force)'{-f,--force}'[overwrite output files]' \
  '(-s --sign)'{-s,--sign}'[sign input binary with certificate]' \
  '(-h --hash)'{-h,--hash}'[print cryptographic digest of input]' \
  '(-d --digest_type)'{-d+,--digest_type=}'[digest algorithm]:digest:(sha1 sha224 sha256 sha384 sha512)' \
  '(-S --show-signature)'{-S,--show-signature}'[show signature info]' \
  '(-r --remove-signature)'{-r,--remove-signature}'[remove signature section]' \
  '(-u --signature-number)'{-u+,--signature-number=}'[signature index (zero-based)]:n:' \
  '(-K --export-pubkey)'{-K+,--export-pubkey=}'[export public key]:outfile:_files' \
  '(-C --export-cert)'{-C+,--export-cert=}'[export certificate]:outfile:_files' \
  '(-a --ascii-armor)'{-a,--ascii-armor}'[ascii-armor exported certificates]' \
  '(-D --daemonize)'{-D,--daemonize}'[spawn daemon for pesign-client]' \
  '(-N --nofork)'{-N,--nofork}'[do not fork when daemonized]' && ret=0
return ret
