#compdef csvtk
# Documentation: https://bioinf.shenwei.me/csvtk/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# csvtk: cross-platform CSV/TSV toolkit by shenwei356.

local curcontext="$curcontext" state line ret=1

_csvtk_global_flags() {
  _arguments -s \
    '(-t --tabs)'{-t,--tabs}'[input is tab-delimited]' \
    '(-d --delimiter)'{-d,--delimiter}'[field delimiter]:char' \
    '(-D --out-delimiter)'{-D,--out-delimiter}'[output field delimiter]:char' \
    '(-T --out-tabs)'{-T,--out-tabs}'[use tab as output delimiter]' \
    '(-E --ignore-empty-row)'{-E,--ignore-empty-row}'[ignore empty rows]' \
    '(-H --no-header-row)'{-H,--no-header-row}'[input has no header row]' \
    '(-j --num-cpus)'{-j,--num-cpus}'[number of CPUs to use]:number' \
    '(-l --lazy-quotes)'{-l,--lazy-quotes}'[allow lazy quotes]' \
    '(-C --comment-char)'{-C,--comment-char}'[comment character]:char' \
    '(-U --delete-header)'{-U,--delete-header}'[delete header row from output]' \
    '(-I --ignore-illegal-row)'{-I,--ignore-illegal-row}'[ignore illegal rows]' \
    '--infile-list=[file containing list of input files]:file:_files' \
    '(-n --buf-rows)'{-n,--buf-rows}'[number of buffered rows]:number' \
    '(- *)'{-h,--help}'[show help]' \
    '*:input files:_files'
}

_csvtk() {
  local -a commands=(
    'headers:print header row'
    'dim:show dimensions'
    'nrow:print number of rows'
    'ncol:print number of columns'
    'summary:summary statistics'
    'watch:online statistics monitor'
    'corr:Pearson correlation between columns'
    'pretty:convert to aligned table'
    'csv2tab:convert CSV to tab-delimited'
    'tab2csv:convert tab-delimited to CSV'
    'space2tab:convert space-delimited to tab-delimited'
    'csv2md:convert CSV to markdown table'
    'csv2rst:convert CSV to reStructuredText table'
    'csv2json:convert CSV to JSON'
    'csv2xlsx:convert CSV to XLSX'
    'xlsx2csv:convert XLSX to CSV'
    'head:print first N rows'
    'concat:concatenate CSV/TSV files'
    'sample:sampling by proportion'
    'cut:select columns'
    'grep:grep rows by column value'
    'uniq:unique rows'
    'freq:frequency of fields'
    'inter:intersection of files'
    'filter:filter rows by values'
    'filter2:filter rows by awk-like expressions'
    'join:join files by selected fields'
    'split:split CSV/TSV into multiple files'
    'splitxlsx:split XLSX sheet into sheets'
    'comb:compute combinations'
    'fix:fix CSV with different column counts'
    'fix-quotes:fix malformed CSV quoting'
    'del-quotes:remove quotes'
    'add-header:add header row'
    'del-header:delete header row'
    'rename:rename column names'
    'rename2:rename column names by regex'
    'replace:replace data by regex'
    'round:round float to n decimal places'
    'comma:add thousand separator'
    'mutate:create new column from fields'
    'mutate2:create new column by awk-like expressions'
    'mutate3:create new column from regexes'
    'fmtdate:format dates'
    'transpose:transpose CSV data'
    'sep:separate column into columns'
    'gather:gather columns into key-value pairs'
    'spread:spread key-value pair across columns'
    'unfold:unfold field with multiple values'
    'fold:fold values into single field'
    'sort:sort by selected fields'
    'shuf:shuffle rows'
    'plot:plot data (hist/box/line/bar)'
    'cat:concatenate (alias of concat)'
    'collapse:collapse fields using selected as keys'
    'version:print version'
    'genautocomplete:generate shell autocompletion script'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::args:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'csvtk command' commands && ret=0
      ;;
    args)
      _csvtk_global_flags && ret=0
      ;;
  esac

  return ret
}

_csvtk "$@"
