#compdef classad_eval
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/classad_eval.html
# evaluate ClassAd expressions on the command line

local ret=1

_arguments -s -S \
  '-help[display help information]' \
  '(-ad-file -file)'{-ad-file,-file}'[supply a ClassAd via a file as context for evaluation]:file:_files' \
  '-target-file[evaluate an expression to check a match against a ClassAd]:file:_files' \
  '-quiet[suppress printing the ClassAd context before expressions]' \
  '*:expression' && ret=0

return ret
