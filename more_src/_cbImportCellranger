#compdef cbImportCellranger
# Documentation: https://cellbrowser.readthedocs.io/en/master/cellranger.html
# UCSC Cell Browser - convert Cell Ranger output to cellbrowser format

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[show debug messages]' \
  '(-i --inDir)'{-i,--inDir=}'[input folder with the cellranger analysis output]:dir:_files -/' \
  '(-o --outDir)'{-o,--outDir=}'[output directory]:dir:_files -/' \
  '(-n --name)'{-n,--name=}'[name of the dataset (no spaces or special chars)]:name' \
  '(-m --noMat)'{-m,--noMat}'[do not export the matrix again]' && ret=0

return ret
