#compdef bigwigCompare
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/bigwigCompare.html
# deepTools: compare two bigWig files into a single output track

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b1 --bigwig1)'{-b1,--bigwig1}'[bigWig file 1 (treatment)]:bw:_files -g "*.bw"' \
  '(-b2 --bigwig2)'{-b2,--bigwig2}'[bigWig file 2 (control)]:bw:_files -g "*.bw"' \
  '--scaleFactors[multiply bigwig values by constants (a:b)]:factors:' \
  '--pseudocount[pseudocount to avoid division by zero]:n:' \
  '--skipZeroOverZero[skip bins lacking coverage in both files]' \
  '--operation[comparison operation]:op:(log2 ratio subtract add mean reciprocal_ratio first second)' \
  '(--skipNonCoveredRegions --skipNAs)'{--skipNonCoveredRegions,--skipNAs}'[skip non-covered regions]' \
  '--fixedStep[write all bins instead of merging equal-value neighbors]' \
  '--version[show version]' \
  '(-bs --binSize)'{-bs,--binSize}'[bin size in bases]:size:' \
  '(-r --region)'{-r,--region}'[genome region to analyze]:region:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[BED/GTF file of excluded regions]:file:_files' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-o --outFileName)'{-o,--outFileName}'[output file name]:file:_files' \
  '(-of --outFileFormat)'{-of,--outFileFormat}'[output format]:format:(bigwig bedgraph)' && ret=0

return ret
