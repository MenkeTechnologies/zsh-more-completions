#compdef asttable
# asttable — manipulate table columns

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra information]' \
  '--log[store program activity in a log file]' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads]:number' \
  '--minmapsize[minimum bytes to use memory-mapped files]:size' \
  '--quietmmap[do not report memory-mapped file creation]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[output data type]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--tableformat[output table format]:format:(txt fits-ascii fits-binary)' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input]:HDU' \
  '(-I --ignorecase)'{-I,--ignorecase}'[ignore case in matching column names]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and exit]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for current directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for current user]' \
  '--cite[show BibTeX citation for this program]' \
  '--config[configuration file to use]:file:_files' \
  '--checkconfig[print all config files and variables]' \
  '--onlyversion[only run if program version matches]:version' \
  '--searchin[search column metadata]:where:(name unit comment)' \
  '*'{-c,--column}'[column number or search string]:column' \
  '(-w --wcsfile)'{-w,--wcsfile}'[file with WCS for coordinate conversion]:file:_files' \
  '(-W --wcshdu)'{-W,--wcshdu}'[HDU in WCS file]:HDU' \
  '*'{-L,--catcolumnfile}'[file to concatenate by column]:file:_files' \
  '*'{-u,--catcolumnhdu}'[HDU in catcolumnfile]:HDU' \
  '*'{-C,--catcolumns}'[columns to use in catcolumnfile]:columns' \
  '*'{-R,--catrowfile}'[file to concatenate by row]:file:_files' \
  '*'{-X,--catrowhdu}'[HDU in catrowfile]:HDU' \
  '--catcolumnrawname[do not touch column names of catcolumnfile]' \
  '(-i --information)'{-i,--information}'[only print input table information]' \
  '--info-num-rows[only print number of rows]' \
  '--info-num-cols[only print number of columns]' \
  '(-O --colinfoinstdout)'{-O,--colinfoinstdout}'[column info/metadata when printing to stdout]' \
  '(-Y --txteasy)'{-Y,--txteasy}'[short for -Afixed -B6 -ffixed -p3]' \
  '(-f --txtf32format)'{-f,--txtf32format}'[text output float32 format]:format:(fixed exp)' \
  '(-A --txtf64format)'{-A,--txtf64format}'[text output float64 format]:format:(fixed exp)' \
  '(-p --txtf32precision)'{-p,--txtf32precision}'[text output float32 precision]:digits' \
  '(-B --txtf64precision)'{-B,--txtf64precision}'[text output float64 precision]:digits' \
  '*'{-m,--colmetadata}'[column metadata (name, unit, comments)]:id,name,unit,comment' \
  '--tovector[merge columns into a vector column]:columns' \
  '--fromvector[extract columns from a vector column]:column,indices' \
  '(-k --keepvectfin)'{-k,--keepvectfin}'[keep inputs of --tovector and --fromvector]' \
  '--transpose[transpose table (vector columns only)]' \
  '--rowfirst[apply row-based operations first]' \
  '*'{-r,--range}'[column and range to limit output]:column,min:max' \
  '--polygon[polygon vertices or DS9 region file]:vertices' \
  '--inpolygon[coordinate columns inside polygon]:col1,col2' \
  '--outpolygon[coordinate columns outside polygon]:col1,col2' \
  '*'{-e,--equal}'[column and values to keep]:column,values' \
  '*'{-n,--notequal}'[column and values to remove]:column,values' \
  '*'{-b,--noblank}'[remove rows with blank in given columns]:column' \
  '*'{-E,--noblankend}'[similar to --noblank, applied at end]:column' \
  '(-s --sort)'{-s,--sort}'[column name or number for sorting]:column' \
  '(-d --descending)'{-d,--descending}'[sort in descending order]' \
  '(-H --head)'{-H,--head}'[only return given number of top rows]:count' \
  '(-t --tail)'{-t,--tail}'[only return given number of bottom rows]:count' \
  '--rowrange[only rows in this row-counter range]:start,end' \
  '--rowrandom[number of rows to select randomly]:count' \
  '--envseed[use GSL_RNG_SEED environment variable for randomization]' \
  '*:input table:_files'
