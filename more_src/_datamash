#compdef datamash
# Documentation: https://www.gnu.org/software/datamash/manual/datamash.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-f --full)'{-f,--full}'[print full input lines]' \
  '(-g --group)'{-g,--group=}'[group by fields]:fields:' \
  '--header-in[first line is header]' \
  '--header-out[print operation names as header line]' \
  '(-H --headers)'{-H,--headers}'[use first input line as header and print operation header]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive grouping/sorting]' \
  '(-s --sort)'{-s,--sort}'[sort input before grouping]' \
  '(-R --round)'{-R,--round=}'[round numeric output to N decimal places]:digits:' \
  '(-t --field-separator)'{-t,--field-separator=}'[input/output field separator]:separator:' \
  '--output-delimiter=[output field separator]:delimiter:' \
  '(-c --collapse-delimiter)'{-c,--collapse-delimiter=}'[delimiter for collapse/unique]:delimiter:' \
  '--no-strict[allow lines with varying field counts]' \
  '--narm[skip NA/NaN values]' \
  '(-W --whitespace)'{-W,--whitespace}'[use whitespace as input/output delimiter]' \
  '(-z --zero-terminated)'{-z,--zero-terminated}'[use NUL as line delimiter]' \
  '--filler=[fill missing values with TEXT]:text:' \
  '(-C --skip-comments)'{-C,--skip-comments}'[skip lines starting with # or ;]' \
  '(-S --seed)'{-S,--seed=}'[set random number generator seed]:n:' \
  '--format=[printf-style format for numeric output]:fmt:' \
  '--sort-cmd=[path to external sort command]:path:_files' \
  '--vnlog[enable vnlog format support]' \
  '*:operation:(groupby crosstab transpose reverse check count first last min max absmin absmax range sum mean median q1 q3 iqr perc mode antimode pstdev sstdev pvar svar mad madraw pskew sskew pkurt skurt jarque countunique collapse unique md5 sha1 sha224 sha256 sha384 sha512 base64 debase64 abs ceil floor trunc frac log log2 log10 round rmdup rand bin strbin getnum basename dirname extname barename cut)' && ret=0

return ret
