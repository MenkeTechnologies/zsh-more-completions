#compdef datamash

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-f --full)'{-f,--full}'[print full input lines]' \
  '(-g --group)'{-g,--group}'[group by fields]:fields' \
  '--header-in[first line is header]' \
  '--header-out[print header line]' \
  '-H[use header lines]' \
  '--headers[use header lines]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[ignore case for grouping]' \
  '(-s --sort)'{-s,--sort}'[sort input]' \
  '(-R --round)'{-R,--round}'[round numeric output]:digits' \
  '(-t --field-separator)'{-t,--field-separator}'[field separator]:separator' \
  '--output-delimiter=[output delimiter]:delimiter' \
  '--no-strict[allow missing fields]' \
  '--narm[skip NA values]' \
  '-W[use whitespace as delimiter]' \
  '--whitespace[use whitespace as delimiter]' \
  '-z[use NUL as line delimiter]' \
  '--zero-terminated[use NUL as line delimiter]' \
  '--filler=[filler for missing values]:filler' \
  '(-C --skip-comments)'{-C,--skip-comments}'[skip comment lines]' \
  '*:operation:(count first last min max sum mean median q1 q3 iqr perc mode antimode pstdev sstdev pvar svar mad madraw pskew sskew pkurt skurt jarque range countunique collapse unique sha1 sha256 sha512 md5 base64 debase64 reverse abs ceil floor trunc frac log log2 log10 round rmdup rand)' && ret=0

return ret
