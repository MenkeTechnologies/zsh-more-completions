#compdef lxmenu-data

# lxmenu-data is a data-only package providing XDG menu .directory/.menu
# files; it ships no executable. Completion kept as a no-op stub so the
# corresponding test entry continues to match the more_src/ inventory.
local curcontext="$curcontext" ret=1

_arguments -C '*:file:_files' && ret=0

return ret
