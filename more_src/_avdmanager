#compdef avdmanager
# Documentation: https://developer.android.com/tools/avdmanager
# Source: Android SDK — Android Virtual Device manager.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(-s --silent)'{-s,--silent}'[silent mode (errors only)]' \
    '(-h --help)'{-h,--help}'[usage help]' \
    '(-v --verbose)'{-v,--verbose}'[verbose (errors + warnings + info)]' \
    '--clear[clear the SDK Manager repository manifest cache]:what:(cache)' \
    '1: :->verb' \
    '2: :->object' \
    '*:: :->args' \
    && ret=0

case $state in
    verb)
        local -a verbs=(
            'create:create a new AVD'
            'delete:delete an AVD'
            'move:move or rename an AVD'
            'list:list targets / device defs / AVDs'
        )
        _describe -t verbs 'verb' verbs && ret=0
        ;;
    object)
        local -a objs=(
            'avd:AVD object'
            'target:target object (list only)'
            'device:device-definition object (list only)'
        )
        _describe -t objs 'object' objs && ret=0
        ;;
    args)
        _arguments \
            '-n[AVD name]:name:' \
            '-k[SDK id (e.g. "system-images;android-34;google_apis;x86_64")]:sdk_id:' \
            '-c[SD card image path OR size with K/M suffix]:sdcard:' \
            '-f[force creation (overwrite existing AVD)]' \
            '-p[AVD files directory location]:path:_directories' \
            '-r[new AVD name for move/rename]:new name:' \
            '-c[compact output (with list)]' \
            && ret=0
        ;;
esac

return ret
