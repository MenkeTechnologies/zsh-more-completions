#compdef hopt
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Histogram optimisation (equalisation) of an image

local ret=1

_arguments -s -S \
  'IMAGE=[image to be processed]:image:_files' \
  'MINVAL=[minimum data value for histogram]:minval:' \
  'MAXVAL=[maximum data value for histogram]:maxval:' \
  'EQUALISE=[perform equalisation]:equalise:(TRUE FALSE)' \
  'OUTPUT=[resulting processed image]:output:_files' \
  '*:NDF data file:_files' && ret=0

return ret
