#compdef ascii2der
# Documentation: https://man.archlinux.org/search?q=ascii2der
# Reference accessed: 2026-05-16

# Zsh completion for ascii2der (RFC7468 PEM → DER)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:ascii input:_files' && ret=0

return ret
