#compdef ascii2der
# Documentation: https://github.com/google/der-ascii
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for ascii2der (RFC7468 PEM → DER)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:ascii input:_files' && ret=0

return ret
