#compdef smaflux
# Documentation: https://lweb.cfa.harvard.edu/sma/miriad/manuals/SMAuguide/smauserhtml/smaflux.html
# Set the flux scale of a vis dataset given a planet observation

local ret=1

_arguments -s \
  'vis=[input visibility datasets with planetary observations]:dataset:_files' \
  'select=[standard uv-selection to filter data by source]:select' \
  'mirhome=[location of MIRIAD home directory (default $MIR)]:dir:_files -/' \
  'options=[vector,noapply,nofqav]:options' \
  '*:dataset:_files' && ret=0

return ret
