#compdef bottle-cli bottle.py
# _bottle-cli — Bottle micro web framework CLI alias (Marcel Hellkamp, Python); argparse
# upstream: https://github.com/bottlepy/bottle

_bottle-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--bind=+[bind addr]:str:' \
        '-b+[bind addr]:str:' \
        '--server=+[server adapter]:s:(auto wsgiref cherrypy paste cheroot gevent eventlet rocket waitress gunicorn meinheld)' \
        '-s+[server adapter]:s:(auto wsgiref cherrypy paste cheroot gevent eventlet rocket waitress gunicorn meinheld)' \
        '--debug[debug mode]' \
        '-d[debug mode]' \
        '--reload[auto reload]' \
        '-r[auto reload]' \
        '--plugin=+[plugin]:list:' \
        '-p+[plugin]:list:' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '*:module-or-script:'
}

_bottle-cli "$@"
