#compdef amber

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-e --regex)'{-e,--regex}'[use regex pattern]' \
  '(-r --replacement)'{-r,--replacement}'[replacement string]:replacement' \
  '(-f --file)'{-f,--file}'[file filter pattern]:pattern' \
  '--include[include files matching pattern]:pattern' \
  '--exclude[exclude files matching pattern]:pattern' \
  '--just-files[only print file names]' \
  '--no-regex[treat pattern as literal string]' \
  '--dry-run[show what would be changed without modifying files]' \
  '(-w --word-regexp)'{-w,--word-regexp}'[match whole words only]' \
  '1:search pattern' \
  '2:replacement' \
  '3:path:_files -/' && ret=0
return ret
