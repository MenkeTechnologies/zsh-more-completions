#compdef chainToPsl
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# convert chain file to psl format

local ret=1

_arguments -s -S \
  '1:in chain:_files -g "*.chain"' \
  '2:target sizes:_files' \
  '3:query sizes:_files' \
  '4:target list:_files' \
  '5:query list:_files' \
  '6:out psl:_files' && ret=0

return ret
