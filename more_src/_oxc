#compdef oxc

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'lint:lint JavaScript/TypeScript files'
  'format:format JavaScript/TypeScript files'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'oxc command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (lint)
        _arguments \
          '--fix[apply automatic fixes]' \
          '--fix-suggestions[apply suggested fixes]' \
          '--quiet[suppress warnings]' \
          '--deny=[deny rule]:rule' \
          '--warn=[warn on rule]:rule' \
          '--allow=[allow rule]:rule' \
          '-D+[deny rule category]:category:(correctness suspicious pedantic perf style nursery restriction)' \
          '-W+[warn on rule category]:category:(correctness suspicious pedantic perf style nursery restriction)' \
          '-A+[allow rule category]:category:(correctness suspicious pedantic perf style nursery restriction)' \
          '--config=[config file]:file:_files' \
          '--tsconfig=[tsconfig.json path]:file:_files' \
          '--ignore-path=[ignore file path]:file:_files' \
          '--ignore-pattern=[ignore glob pattern]:pattern' \
          '--no-ignore[disable ignore files]' \
          '--max-warnings=[max warnings before error]:count' \
          '--threads=[number of threads]:count' \
          '--format=[output format]:format:(default json unix github)' \
          '*:files or directories:_files' && ret=0
        ;;
      (format)
        _arguments \
          '--check[check if files are formatted]' \
          '--stdin-filename=[filename for stdin]:filename' \
          '--indent-style=[indentation style]:style:(tab space)' \
          '--indent-width=[indentation width]:width' \
          '--line-width=[line width]:width' \
          '--quote-style=[quote style]:style:(double single)' \
          '--trailing-comma=[trailing comma style]:style:(all es5 none)' \
          '--semicolons=[semicolons]:style:(always as-needed)' \
          '*:files or directories:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
