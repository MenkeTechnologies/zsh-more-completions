#compdef filter_vep
# Documentation: https://www.ensembl.org/info/docs/tools/vep/script/vep_filter.html
# Filter Ensembl VEP results files on a variety of attributes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage message and exit]' \
  '(-i --input_file)'{-i,--input_file}'[specify the input VEP results file]:input file:_files' \
  '--format[input file format]:format:(vcf tab)' \
  '(-o --output_file)'{-o,--output_file}'[specify the output file to write to]:output file:_files' \
  '--force_overwrite[overwrite existing output files]' \
  '*'{-f,--filter}'[add filter (multiple are logical AND)]:filter string' \
  '(-l --list)'{-l,--list}'[list allowed fields from the input file]' \
  '(-c --count)'{-c,--count}'[print only a count of matched lines]' \
  '--only_matched[output only matching consequence blocks in VCF files]' \
  '(-y --ontology)'{-y,--ontology}'[use Sequence Ontology to match consequence terms]' \
  '--vcf_info_field[alternative INFO key for VEP annotations]:field' \
  '*:input file:_files' && ret=0

return ret
