#compdef ftlist
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/ftlist.html
# List the contents of a FITS file (HDUs, keywords, columns, images, table data)

local ret=1

_arguments -s -S \
  'infile=[input file with optional extension in brackets]:infile:_files' \
  'option=[output type chars H C K I T]:option:' \
  'outfile=[output listing destination, - for stdout]:outfile:_files' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'include=[keywords to display for option=K]:include:' \
  'exclude=[keywords to suppress]:exclude:' \
  'section=[image row/column range for option=I]:section:' \
  'columns=[columns to display for option=T]:columns:' \
  'rows=[rows or ranges to display for option=T]:rows:' \
  'vector=[vector element range to display]:vector:' \
  'separator=[string between columns]:separator:' \
  'rownum=[show row numbers]:rownum:(yes no)' \
  'colheader=[show column headers]:colheader:(yes no)' \
  '*:file:_files' && ret=0

return ret
