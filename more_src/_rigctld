#compdef rigctld
# Documentation: source-direct extraction from upstream
# Hamlib/Hamlib tests/rigctld.c `static struct option
# long_options[]` table + SHORT_OPTIONS string
# "m:r:p:d:P:D:s:S:c:T:t:C:W:w:x:lLuovhVZRA:b" + the source
# self-imposed maintenance contract "keep up to date
# SHORT_OPTIONS, usage()'s output and man page. thanks."
# preserved verbatim. The 26 options are decoded long-form
# from the long_options[] table aligned with the SHORT_OPTIONS
# argstring's `:` arg-required markers.
# Reference accessed: 2026-05-30 via gh api.
# Hamlib rigctld R154a — TCP network daemon for controlling ham
# radios via the Hamlib backend library. Sister daemon to the
# already-covered `rigctl` (the equivalent local-only client)
# from the same upstream + `fldigi`/`flrig`/`wsjtx`/`direwolf`
# /`gpredict` ham radio family.

_arguments -s -S \
  '(-m --model)'{-m+,--model=}'[Hamlib rig model number (use --list to enumerate)]:model:' \
  '(-r --rig-file)'{-r+,--rig-file=}'[serial/network device for rig communication]:file:_files -g "/dev/tty*"' \
  '(-p --ptt-file)'{-p+,--ptt-file=}'[PTT device path or hardware line]:file:_files' \
  '(-d --dcd-file)'{-d+,--dcd-file=}'[DCD device path or hardware line]:file:_files' \
  '(-P --ptt-type)'{-P+,--ptt-type=}'[PTT type override]:type:(RIG DTR RTS PARALLEL CM108 GPIO GPION NONE)' \
  '(-D --dcd-type)'{-D+,--dcd-type=}'[DCD type override]:type:(RIG DSR CTS CD PARALLEL CM108 GPIO GPION NONE)' \
  '(-s --serial-speed)'{-s+,--serial-speed=}'[serial port baud rate]:baud:(1200 2400 4800 9600 19200 38400 57600 115200)' \
  '(-S --separator)'{-S+,--separator=}'[record-separator string between rigctl-protocol records]:separator:' \
  '(-c --civaddr)'{-c+,--civaddr=}'[Icom CI-V address (model-specific override)]:addr:' \
  '(-T --listen-addr)'{-T+,--listen-addr=}'[TCP listen address]:host:_hosts' \
  '(-t --port)'{-t+,--port=}'[TCP listen port (default 4532)]:port:' \
  '(-C --set-conf)'{-C+,--set-conf=}'[per-rig conf pair PARAM=VAL (repeatable)]:PARAM=VAL:' \
  '(-l --list)'{-l,--list}'[list supported rig models and exit]' \
  '(-L --show-conf)'{-L,--show-conf}'[show available conf params for the rig and exit]' \
  '(-u --dump-caps)'{-u,--dump-caps}'[dump rig capabilities and exit]' \
  '(-o --vfo)'{-o,--vfo}'[enable VFO mode (per-VFO command targeting)]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output (stackable; use multiple times)]' \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-W --twiddle_timeout)'{-W+,--twiddle_timeout=}'[twiddle (knob-spin) detection timeout in seconds]:sec:' \
  '(-w --twiddle_rit)'{-w+,--twiddle_rit=}'[twiddle RIT range]:hz:' \
  '(-x --uplink)'{-x+,--uplink=}'[uplink/downlink linkage mode for satellite ops]:mode:(0 1 2)' \
  '(-Z --debug-time-stamps)'{-Z,--debug-time-stamps}'[prefix debug lines with timestamps]' \
  '(-A --password)'{-A+,--password=}'[require this password on connecting clients]:password:' \
  '(-R --rigctld-idle)'{-R,--rigctld-idle}'[allow idle (no-rig) startup; for testing]' \
  '(-b --bind-all)'{-b,--bind-all}'[bind to all interfaces (default localhost only)]'
