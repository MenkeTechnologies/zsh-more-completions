#compdef rbw

# Zsh completion for rbw - unofficial Bitwarden CLI

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'config:Get or set configuration options'
  'login:Authenticate with the Bitwarden server'
  'unlock:Unlock the password manager'
  'unlocked:Check if the password manager is unlocked'
  'sync:Sync the local database with the Bitwarden server'
  'list:List names of secrets stored in the database'
  'get:Get the password for a secret'
  'code:Get the TOTP code for a secret'
  'add:Add a new secret'
  'generate:Generate a new password'
  'edit:Update an existing secret'
  'remove:Remove a secret'
  'restore:Restore a removed secret'
  'history:View the password history for a secret'
  'lock:Lock the password manager'
  'purge:Remove the local database'
  'stop-agent:Stop the background agent'
  'agent:Run the background agent'
  'completions:Generate shell completions'
  'version:Print version info'
  'help:Print help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      get|code|edit|remove|restore|history)
        _arguments \
          '--folder[restrict results to folder]:folder:' \
          '*:secret name:' && ret=0
        ;;
      generate)
        _arguments \
          '(-l --len)'{-l,--len}'[length of password to generate]:length:' \
          '--no-symbols[only use letters and numbers]' \
          '--only-numbers[only use numbers]' \
          '--nonconfusables[avoid ambiguous characters]' \
          '--diceware[generate passphrase using diceware]' \
          ':secret name:' && ret=0
        ;;
      config)
        _arguments \
          ':key:(email base_url identity_url lock_timeout sync_interval pinentry)' \
          ':value:' && ret=0
        ;;
      completions)
        _arguments ':shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
