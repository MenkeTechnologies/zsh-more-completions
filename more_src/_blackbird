#compdef blackbird
# Documentation: https://github.com/p1ngul1n0/blackbird
# OSINT: search accounts by username and email across sites.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-u,--username}'[one or more usernames to search]:username:' \
  '(-uf --username-file)'{-uf+,--username-file=}'[file of usernames to be searched]:file:_files' \
  '--permute[permute usernames, ignoring single elements]' \
  '--permuteall[permute usernames, all elements]' \
  '*'{-e,--email}'[one or more emails to search]:email:' \
  '(-ef --email-file)'{-ef+,--email-file=}'[file of emails to be searched]:file:_files' \
  '--csv[generate a CSV with the results]' \
  '--pdf[generate a PDF with the results]' \
  '--json[generate a JSON with the results]' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '(-ai --ai)'{-ai,--ai}'[use AI features]' \
  '--setup-ai[configure the API key required for AI features]' \
  '--filter=[filter sites by list property value (e.g. cat=social)]:filter:' \
  '--no-nsfw[remove NSFW sites from the search]' \
  '--dump[dump HTML content for found accounts]' \
  '--proxy=[proxy to send HTTP requests through]:proxy:' \
  '--timeout=[timeout in seconds for each HTTP request (default 30)]:seconds:' \
  '--max-concurrent-requests=[max number of concurrent requests (default 30)]:n:' \
  '--no-update[do not update sites lists]' \
  '--about[show about information and exit]' && ret=0

return ret
