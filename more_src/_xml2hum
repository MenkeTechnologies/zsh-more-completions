#compdef xml2hum
# Documentation: https://extras.humdrum.org/man/xml2hum/
# Convert MusicXML data into Humdrum **kern data

local ret=1

_arguments -s -S \
  '-s[convert only the specified staff]:staff:' \
  '-i[display MusicXML information (debugging)]' \
  '-x[fix note spellings of data originating from MIDI files]' \
  '-S[do not print stem information in output kern data]' \
  '-B[do not print beaming information in output kern data]' \
  '-D[do not print dynamics information in output kern data]' \
  '-N[do not print notation information (equivalent to -SB)]' \
  '-T[do not convert any text from lyrics]' \
  '-M[do not auto-fix measure numbers in MusicXML input]' \
  '*:MusicXML file:_files -g "*.(xml|musicxml|mxl)"' && ret=0

return ret
