#compdef ncmpc

# Zsh completion for ncmpc - ncurses MPD client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-h --host)'{-h,--host}'[connect to host]:host:_hosts' \
  '(-p --port)'{-p,--port}'[connect to port]:port:' \
  '(-P --password)'{-P,--password}'[connect with password]:password:' \
  '(-f --config)'{-f,--config}'[specify config file]:config file:_files' \
  '(-k --key-file)'{-k,--key-file}'[specify key bindings file]:key file:_files' \
  '--colors[enable colors]' \
  '--no-colors[disable colors]' \
  '(-m --mouse)'{-m,--mouse}'[enable mouse support]' \
  '--no-mouse[disable mouse support]' \
  && ret=0

return ret
