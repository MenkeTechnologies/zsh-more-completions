#compdef ncmpc
# Documentation: https://ncmpc.readthedocs.io/en/latest/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for ncmpc - ncurses MPD client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--host=[connect to host]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[connect to port]:port:' \
  '(-P --password)'{-P+,--password=}'[connect with password]:password:' \
  '(-f --config)'{-f+,--config=}'[specify config file]:config file:_files' \
  '(-k --key-file)'{-k+,--key-file=}'[specify key bindings file]:key file:_files' \
  '(-c --colors)'{-c,--colors}'[enable colors]' \
  '(-C --no-colors)'{-C,--no-colors}'[disable colors]' \
  '(-m --mouse)'{-m,--mouse}'[enable mouse support]' \
  && ret=0

return ret
