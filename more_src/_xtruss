#compdef xtruss
# Documentation: https://manpages.debian.org/unstable/xtruss/xtruss.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (xtruss(1)).
# Removed: -h/--help, -V/--version (not in man OPTIONS), -x (fake; raw hex is
# -R), -I (real -I is "include init message", not "interactive prompt").
# Fixed: -p takes resource-id (not pid), -P sets up proxy (no arg), -I shows
# the X server initialization message, -R does raw hex dumps, added -C.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-s+[limit output line length (0/unlimited = unrestricted)]:length:' \
  '-o+[output file (- for stdout)]:file:_files' \
  '-e+[filter requests/events]:filter spec:' \
  '-I[include X server initialization message]' \
  '-p+[attach via RECORD to X client resource id]:resource id:' \
  '-P[set up proxy server without spawning subprocess]' \
  '-R[show raw hexadecimal dumps alongside protocol translation]' \
  '-C[prefix output lines with X client id]' \
  '*:command:_command_names' && ret=0

return ret
