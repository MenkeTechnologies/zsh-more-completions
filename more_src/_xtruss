#compdef xtruss

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-s+[max string size]:n:' \
  '-o+[output file]:file:_files' \
  '-e+[trace selected events]:events:' \
  '-I[interactive prompt]' \
  '-p+[pid to attach]:pid:_pids' \
  '-P+[X11 display proxy]:display:' \
  '-x[hex output]' \
  '-R[show responses]' \
  '*:command:_command_names' && ret=0

return ret
