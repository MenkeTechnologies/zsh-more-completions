#compdef mage
# Zsh completion for Mage
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-l --list)'{-l,--list}'[list available targets]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '-d[run in specified directory]:dir:_directories' \
  '-f[force rebuild]' \
  '(- *)'{-h,--help}'[show help message]' \
  '-w[working directory]:dir:_directories' \
  '--debug[enable debug output]' \
  '-t[timeout for targets]:timeout:' \
  '-keep[keep intermediate files]' \
  '-gocmd[path to go binary]:path:_files' \
  '-compile[compile a static binary to the given path]:output:_files' \
  '-clean[clean the cache]' \
  '-goos[set GOOS]:os:' \
  '-goarch[set GOARCH]:arch:' \
  '(- *)-version[show version]' \
  '*:target:' && ret=0
return ret
