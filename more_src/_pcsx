#compdef pcsx pcsxr pcsx-redux
# Documentation: https://manpages.debian.org/testing/pcsxr/pcsxr.1
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '-runcd[run CD-ROM from drive]' \
  '-cdfile+[run a CD image file]:file:_files -g "*.bin *.iso *.cue *.img *.mds *.mdf"' \
  '-nogui[do not load the GUI]' \
  '-cfg+[specify a config file]:file:_files' \
  '-psxout[enable PSX output]' \
  '-slowboot[enable BIOS logo]' \
  '-load+[load savestate slot]:state-num:' \
  '*: :_files -g "*.bin *.iso *.cue *.img *.mds *.mdf *.pbp *.ecm"' && ret=0

return ret
