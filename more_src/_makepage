#compdef makepage
# Documentation: https://github.com/Orc/discount/blob/master/makepage.1
# makepage - convert markdown text into a complete XHTML page (discount)

local ret=1

_arguments -s -S \
  '-V[show version]' \
  '-F+[set or clear named feature bits]:bitmap:' \
  '-f+[set or clear markdown flags]:flags:' \
  '*:file:_files' && ret=0

return ret
