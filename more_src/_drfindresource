#compdef drfindresource
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/drfindresource.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS drfindresource: find DRCAT data resources by EDAM type
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-query=[EDAM data keywords]:query' \
  '-outfile=[output file]:file:_files' \
  '-sensitive[also search EDAM term definitions]' \
  '-subclasses[include sub-class terms]' \
  '-nosubclasses[disable sub-class inclusion]' \
  '-oformat2=[output format]:format:(drcat basic wsbasic list)' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '*:EDAM resource id:' && ret=0
return ret
