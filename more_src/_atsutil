#compdef atsutil

local curcontext="$curcontext" state line ret=1
local -a verbs

verbs=(
  'fonts:font cache management'
  'databases:font database management'
  'help:show help'
)

_arguments -C \
  '1: :->verb' \
  '*::arg:->args' && ret=0

case $state in
  (verb)
    _describe -t verbs 'atsutil verb' verbs && ret=0
    ;;
  (args)
    _files && ret=0
    ;;
esac

return ret
