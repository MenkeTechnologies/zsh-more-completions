#compdef dbui

# Zsh completion for dbui (standalone database TUI)

_arguments \
  '(-c --config)'{-c,--config}'[path to the configuration file]:file:_files' \
  '(-d --dsn)'{-d,--dsn}'[Data Source Name (connection string)]:dsn' \
  '(-t --type)'{-t,--type}'[database type]:type:(mysql postgres sqlite3)' \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-v --version)'{-v,--version}'[show version]' && return 0
