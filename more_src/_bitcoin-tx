#compdef bitcoin-tx
# Documentation: https://github.com/bitcoin/bitcoin (src/bitcoin-tx.cpp SetupBitcoinTxArgs)
# Reference accessed: 2026-05-29
# Stand-alone Bitcoin transaction tool. Commands are positional name=value args.

local curcontext="$curcontext" state line ret=1

local -a _commands
_commands=(
  'nversion\=:set TX version to N'
  'locktime\=:set TX lock time to N'
  'replaceable:set Replace-By-Fee opt-in sequence number'
  'delin\=:delete input N from TX'
  'in\=:add input (TXID:VOUT[:SEQUENCE_NUMBER])'
  'delout\=:delete output N from TX'
  'outaddr\=:add address-based output (VALUE:ADDRESS)'
  'outdata\=:add data-based output ([VALUE:]DATA)'
  'outpubkey\=:add pay-to-pubkey output (VALUE:PUBKEY[:FLAGS])'
  'outmultisig\=:add Pay-To n-of-m Multi-sig output'
  'outscript\=:add raw script output (VALUE:SCRIPT[:FLAGS])'
  'sign\=:add signatures (SIGHASH-FLAGS)'
  'load\=:load JSON file into register NAME:FILENAME'
  'set\=:set register NAME:JSON-STRING'
)

_arguments -s -S \
  '(- *)-version[print version and exit]' \
  '(- *)-help[show help]' \
  '(- *)-?[show help]' \
  '-create[create new, empty TX]' \
  '-json[select JSON output]' \
  '-txid[output only the hex-encoded transaction ID]' \
  '-regtest[run on regtest]' \
  '-testnet[run on testnet]' \
  '-testnet4[run on testnet4]' \
  '-signet[run on signet]' \
  '-chain=-[chain name]:chain:(main test testnet4 signet regtest)' \
  '*: :->cmd' && ret=0

case $state in
  cmd)
    _describe -t commands 'bitcoin-tx command' _commands && ret=0
    ;;
esac

return ret
