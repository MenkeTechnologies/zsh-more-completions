#compdef create-heroku-app
# Documentation: https://www.npmjs.com/package/create-heroku-app
# Reference accessed: 2026-05-24
# Verified: npx create-heroku-app --help.

# Zsh completion for create-heroku-app - Heroku app scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-n --name)'{-n,--name=}'[project name]:name:' \
  '(-t --type)'{-t,--type=}'[app type]:type:' && ret=0

return ret
