#compdef j2

# Zsh completion for j2 - jinja2 command-line template renderer

_arguments -s -S \
  '(-f --format)'{-f,--format}'[input data format]:format:(env json yaml ini querystring)' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-e --import-env)'{-e,--import-env}'[import environment variables under given key]:key:' \
  '--undefined[allow undefined variables]' \
  '--filters[load custom filter modules]:modules:' \
  '--tests[load custom test modules]:modules:' \
  '--customize[load customization module]:module:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:template:_files -g "*.(j2|jinja|jinja2|tmpl)"' \
  '2:data file:_files'
