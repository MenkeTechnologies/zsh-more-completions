#compdef j2
# Documentation: https://github.com/kolypto/j2cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for j2 - jinja2 command-line template renderer

_arguments -s -S \
  '(-f --format)'{-f,--format}'[input data format]:format:(? env ini json yaml)' \
  '-o+[output file]:file:_files' \
  '(-e --import-env)'{-e,--import-env}'+[import environment variables under given key]:key:' \
  '--undefined[allow undefined variables in templates]' \
  '*--filters[load custom Jinja2 filters from a Python file]:filters:_files -g "*.py"' \
  '--tests[load custom Jinja2 tests from a Python file]:tests:_files -g "*.py"' \
  '--customize[load Python file with hooks to customize j2cli]:module:_files -g "*.py"' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:template:_files -g "*.(j2|jinja|jinja2|tmpl)"' \
  '2:data file:_files'
