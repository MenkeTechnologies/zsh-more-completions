#compdef ouch

# Zsh completion for ouch - painless CLI compression/decompression

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'compress:Compress one or more files into one output file'
  'decompress:Decompress one or more files, each one gets its own folder'
  'list:List the contents of archive(s)'
  'help:Print help for the given command'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--yes[skip confirmation prompts, always Yes]' \
  '--no[skip confirmation prompts, always No]' \
  '--quiet[inhibit informational messages]' \
  '--accessible[activate accessibility mode (removes most visual decorations)]' \
  ':subcommand:->subcommand' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
esac

return ret
