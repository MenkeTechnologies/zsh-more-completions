#compdef ipa-winsync-migrate
# Documentation: https://github.com/freeipa/freeipa/blob/master/install/tools/man/ipa-winsync-migrate.1
# Reference accessed: 2026-05-16
# Verified: upstream install/tools/man/ipa-winsync-migrate.1.

# ipa-winsync-migrate: migrate winsync users to AD trust users
local curcontext="$curcontext" ret=1
_arguments -C \
  '--realm=[Active Directory realm]:realm:' \
  '--server=[Active Directory DC hostname]:host:_hosts' \
  '(-U --unattended)'{-U,--unattended}'[unattended installation]' && ret=0
return ret
