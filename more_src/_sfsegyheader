#compdef sfsegyheader
# Documentation: http://www.ahay.org/RSF/sfsegyheader.html
# Madagascar: create a trace header file for sfsegywrite

local ret=1

_arguments -s \
  'n1=[number of samples in a trace]:n1' \
  'd1=[trace sampling]:d1' \
  'o1=[trace origin]:o1' \
  'tfile=[auxiliary input file name]:file:_files' \
  '*:rsf file:_files' && ret=0

return ret
