#compdef esl-shuffle
# Documentation: https://man.archlinux.org/search?q=esl-shuffle
# Reference accessed: 2026-05-16

# Easel esl-shuffle: shuffle a sequence preserving composition or structure
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-o[output file]:file:_files' \
  '-N[number of shuffles per sequence]:n:' \
  '-d[shuffle preserving dinucleotide composition]' \
  '-k[shuffle preserving k-let composition]:k:' \
  '-0[treat sequence as a 0-th order Markov chain]' \
  '-w[shuffle within fixed-size window]:size:' \
  '-r[reverse the sequence]' \
  '-G[generate random sequence from given probabilities]' \
  '-L[length of random sequences]:n:' \
  '--seed[random seed]:n:' \
  '--amino[assume protein]' \
  '--dna[assume DNA]' \
  '--rna[assume RNA]' \
  '--informat[input format]:fmt:(fasta embl genbank uniprot)' \
  '--mono[preserve mono-nt composition]' \
  '--di[preserve di-nt composition]' \
  '--markov0[0-th order Markov]' \
  '--markov1[1st order Markov]' \
  '--reverse[reverse sequence]' \
  '--iid[generate iid random sequence]' \
  '--rna[output as RNA]' \
  '*:sequence file:_files' && ret=0
return ret
