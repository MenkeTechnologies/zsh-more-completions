#compdef kubectl-kueue
# Documentation: https://kueue.sigs.k8s.io/docs/reference/kubectl-kueue/commands/kueuectl/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--context=[kube context]:context:' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '--user=[kubeconfig user name]:user:' \
  '(-s --server)'{-s+,--server=}'[Kubernetes API server address]:server:' \
  '--token=[bearer token]:token:' \
  '--certificate-authority=[CA certificate file]:file:_files' \
  '--client-certificate=[client cert file]:file:_files' \
  '--client-key=[client key file]:file:_files' \
  '--insecure-skip-tls-verify[skip TLS verification]' \
  '--request-timeout=[request timeout]:duration:' \
  '--cache-dir=[default cache directory]:dir:_files -/' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'create:create a resource'
      'delete:delete a resource'
      'describe:show details of a resource'
      'edit:edit a resource on the server'
      'get:display a resource'
      'list:display resources'
      'patch:update fields of a resource'
      'resume:resume the resource'
      'stop:stop the resource'
      'version:print client version and controller image'
    )
    _describe -t commands 'kubectl-kueue command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
