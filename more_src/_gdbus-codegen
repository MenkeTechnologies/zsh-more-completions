#compdef gdbus-codegen
# Documentation: gdbus-codegen --help (GLib)
# Source: generate C code / documentation from D-Bus introspection XML.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '--interface-prefix=[strip prefix from D-Bus names]:prefix:' \
    '--c-namespace=[namespace for generated C code]:namespace:' \
    '--c-generate-object-manager[generate GDBusObjectManagerClient subclass]' \
    '--c-generate-autocleanup=[autocleanup support]:mode:(none objects all)' \
    '--generate-docbook=[generate Docbook to OUTFILES]:outfiles:' \
    '--generate-md=[generate Markdown to OUTFILES]:outfiles:' \
    '--generate-rst=[generate reStructuredText to OUTFILES]:outfiles:' \
    '--pragma-once[use #pragma once instead of guards]' \
    '*--annotate[annotation WHAT KEY VALUE]:annotation:' \
    '--glib-min-required=[minimum GLib version required]:version:' \
    '--glib-max-allowed=[maximum GLib version allowed]:version:' \
    '--symbol-decorator=[symbol decorator]:decorator:' \
    '--symbol-decorator-header=[decorator header]:header:' \
    '--symbol-decorator-define=[decorator define]:define:' \
    '--extension-path=[extension path]:path:_files -/' \
    '(--generate-c-code --header --body --interface-info-header --interface-info-body)--generate-c-code=[generate C code OUTFILES]:outfiles:' \
    '(--generate-c-code --header --body --interface-info-header --interface-info-body)--header[generate header only]' \
    '(--generate-c-code --header --body --interface-info-header --interface-info-body)--body[generate body only]' \
    '(--generate-c-code --header --body --interface-info-header --interface-info-body)--interface-info-header[interface info header]' \
    '(--generate-c-code --header --body --interface-info-header --interface-info-body)--interface-info-body[interface info body]' \
    '(--output --output-directory)--output=[output file]:file:_files' \
    '(--output --output-directory)--output-directory=[output directory]:dir:_files -/' \
    '*:D-Bus XML file:_files -g "*.xml"' \
    && ret=0

return ret
