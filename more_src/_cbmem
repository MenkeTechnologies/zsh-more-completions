#compdef cbmem
# _cbmem — coreboot cbmem dump coreboot memory log timestamps and coreboot table from /sys/firmware/coreboot (coreboot team, C); custom argparse
# upstream: https://github.com/coreboot/coreboot/tree/main/util/cbmem

_cbmem() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c[print cbmem console]' \
        '--console[print cbmem console]' \
        '-1[trim repeat console]' \
        '--oneboot[trim repeat console]' \
        '-2[show only previous boot]' \
        '--2ndtolast[show only previous boot]' \
        '-B+[boot]:n:' \
        '--last-boot=+[boot]:n:' \
        '-l[list cbmem table sections]' \
        '--list[list cbmem table sections]' \
        '-t[show timestamps]' \
        '--timestamps[show timestamps]' \
        '-T[show timestamps with stage info]' \
        '--parseable-timestamps[show parseable timestamps]' \
        '-S[trim repeats from cbmem console]' \
        '--stages[trim repeats]' \
        '-r[raw output]' \
        '--rawdump[raw output]' \
        '-x[hexdump]' \
        '--hexdump[hexdump]' \
        '-N[show flat memory]' \
        '--no-cap-time[no cap time]' \
        '-v[verbose]' \
        '--verbose[verbose]'
}

_cbmem "$@"
