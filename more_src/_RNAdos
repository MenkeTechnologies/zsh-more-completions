#compdef RNAdos
# ============================================================================
#  _RNAdos — RNAdos: RNA density-of-states calculator from the ViennaRNA
#            Package (Vienna Theoretical Biochemistry Group, Univ. Vienna)
#
#  Source-direct extraction from
#    https://github.com/ViennaRNA/ViennaRNA/blob/master/src/bin/RNAdos.ggo
#    https://www.gnu.org/software/gengetopt/gengetopt.html (the
#    GNU gengetopt code generator)
#
#  Maintained by the Vienna Theoretical Biochemistry Group at the
#  University of Vienna (ViennaRNA/ViennaRNA).  408 GH stars.  The
#  ViennaRNA Package is THE canonical RNA secondary structure
#  prediction and analysis toolkit in computational biology —
#  developed since 1994 by Peter F. Stadler, Ivo L. Hofacker, et al.
#  RNAdos computes the DENSITY OF STATES for each energy band of an
#  RNA — used by structural bioinformaticians to understand
#  thermodynamic ensemble properties of RNA molecules.  Sister
#  ViennaRNA tools: RNAfold (MFE structure prediction, IN CORPUS),
#  RNAduplex (RNA-RNA interaction), RNAcofold (cofolding), RNAaliduplex
#  (conserved RNA-RNA interactions), RNAalifold (alignment-based
#  folding), RNAheat (specific heat curve, IN CORPUS via _RNAheat),
#  RNAplex (RNA-RNA target prediction), RNAinverse (sequence design,
#  IN CORPUS via _RNAinverse), RNAsubopt (suboptimal structures, IN
#  CORPUS), RNApdist (probability distance), RNAplot (structure
#  visualization, IN CORPUS via _RNAplot).
#
#  CLI library taxonomy update: 4th C CLI library — GNU **gengetopt**
#  (gnu.org/software/gengetopt).  C ecosystem now has 4 documented
#  CLI libraries (R272 POSIX getopt + R382 GNU argp + R394 cargs +
#  R397 gengetopt) — joining the multi-library tier behind Java/
#  Crystal/OCaml/Python/Scala/TypeScript-Node (all 5-6).
#
#  GNU gengetopt is a CODE GENERATOR (similar in concept to R387
#  Argbash for Bash but for C) — reads `.ggo` (gengetopt source)
#  declarative spec files and EMITS PORTABLE C SOURCE CODE that
#  parses command-line arguments using POSIX getopt_long internally.
#  Distinct from R272 C POSIX getopt (LOW-LEVEL char-by-char
#  iteration with caller-written switch), R382 GNU argp (struct
#  argp_option + parser callback model, GNU/Linux-glibc-specific),
#  R394 cargs (cross-platform single-header library with declarative
#  struct cag_option array) by being a BUILD-TIME CODE GENERATOR
#  that produces standalone .c/.h files with NO RUNTIME LIBRARY
#  DEPENDENCY in the output.  Used by ViennaRNA Package (RNAfold +
#  ~25 sister RNA tools — `RNAdos`/`RNAaliduplex`/`RNAcofold`/
#  `RNAplex`/`RNApdist`/`RNAheat`/`RNAplot` etc.), RTK (Reconstruction
#  Toolkit for medical imaging, 289 stars), OpenMD (Molecular
#  Dynamics, 91 stars), AwaLWM2M (Connectivity Foundry's
#  LightweightM2M IoT protocol implementation, 110 stars), GNU
#  gsasl (SASL library), libgcrypt-tests, gnubg utility tools,
#  rdsmsg (FM RDS message generator), twstools (Interactive Brokers
#  TWS API), and many academic/scientific C/C++ codes that want a
#  high-level declarative syntax for their getopt_long parsing.
#
#  GNU gengetopt API:
#    # mytool.ggo - gengetopt source file
#    package "mytool"
#    purpose "Do useful things"
#    usage "mytool [OPTIONS] file..."
#    version "1.0"
#
#    args "--file-name=cmdline --include-getopt --default-optional \
#          --unamed-opts --func-name=cmdline_parser \
#          --arg-struct-name=args_info"
#
#    description "Long-form description of what this tool does..."
#
#    option "verbose" v
#    "Be verbose"
#    details="Lower the log level threshold so all INFO messages pass."
#    flag off
#
#    option "output" o
#    "Output file path"
#    string
#    typestr="FILE"
#    default="out.txt"
#    optional
#
#    option "count" n
#    "Number of iterations"
#    int
#    typestr="N"
#    default="10"
#    optional
#
#    option "rate" r
#    "Sample rate"
#    double
#    default="1.0"
#    optional
#
#    section "Algorithm Options"
#    sectiondesc="Configure the algorithm"
#
#    option "method" m
#    "Algorithm method"
#    string
#    values="fast","slow","accurate"
#    default="fast"
#    optional
#
#    text "\nReport bugs to <bug@example.com>\n"
#
#    # ---- BUILD ----
#    # $ gengetopt -i mytool.ggo
#    # ... generates cmdline.c and cmdline.h
#    # $ gcc -o mytool main.c cmdline.c
#
#    # ---- USE FROM C ----
#    # #include "cmdline.h"
#    # int main(int argc, char **argv) {
#    #   struct args_info args_info;
#    #   if (cmdline_parser(argc, argv, &args_info) != 0)
#    #     exit(EXIT_FAILURE);
#    #   if (args_info.verbose_given) { ... }
#    #   const char *out = args_info.output_arg;  /* default fallback */
#    #   int n = args_info.count_arg;
#    #   cmdline_parser_free(&args_info);
#    # }
#
#  GNU gengetopt distinctive features:
#    - BUILD-TIME CODE GENERATOR — `.ggo` files are processed by
#      `gengetopt` binary at BUILD TIME to emit portable C source
#      (typically `cmdline.c` + `cmdline.h`)
#    - NO RUNTIME LIBRARY DEPENDENCY — generated code uses ONLY POSIX
#      getopt_long from libc (system stdlib); no gengetopt runtime
#      needed at execution
#    - `.ggo` DECLARATIVE SYNTAX — package/purpose/usage/version/
#      description/option/section/text directives
#    - `package "name"` — sets the package name (vs `--package=NAME`
#      gengetopt arg)
#    - `purpose "string"` — short purpose summary
#    - `usage "string"` — usage line template
#    - `version "string"` — version string (omit when using automake
#      AC_INIT)
#    - `description "long string"` — long-form description
#    - `args "..."` — gengetopt INVOCATION ARGS embedded in the
#      `.ggo` file (specifies output file name, function name,
#      arg-struct name, --include-getopt for inline getopt code, etc.)
#    - `option "name" SHORT_CHAR "description"` — main option
#      definition (SHORT_CHAR is 'X' character or `-` for none)
#    - `details="..."` — extended help details
#    - TYPE DIRECTIVES (immediately follow option declaration):
#      * `flag` — boolean flag (no value)
#      * `string` — string value
#      * `int` — integer value
#      * `long` — long integer value
#      * `float` — float value
#      * `double` — double-precision value
#      * `enum values="A","B","C"` — restricted choices
#    - `typestr="name"` — value-name placeholder for help (e.g.
#      "FILE", "N", "LEVEL")
#    - `default="X"` — default value (string-quoted for all types)
#    - `optional` / `required` — required-or-optional flag
#    - `argoptional` — value is optional (e.g. `-o` vs `-o file`)
#    - `multiple` / `multiple(MIN-MAX)` — repeatable flag (returns
#      array in args_info)
#    - `hidden` — exclude from --help output
#    - `section "title"` — start a new section group
#    - `sectiondesc="..."` — section description
#    - `text "..."` — free-form text (typically appended after
#      options in --help)
#    - `mode "name"` — modal subcommand declaration (groups options
#      under a particular mode)
#    - `modedesc="..."` — mode description
#    - `dependon="other-option"` — option depends on another
#    - `defgroup "X"` — define option group (for help organization)
#    - GENERATED ARTIFACTS:
#      * `cmdline.h` — header with args_info struct definition
#      * `cmdline.c` — parser implementation (`cmdline_parser`,
#        `cmdline_parser_init`, `cmdline_parser_free`, etc.)
#    - GENERATED `args_info` STRUCT — each option becomes
#      `NAME_arg` (value), `NAME_given` (presence flag), `NAME_arg_count`
#      (for multiple), `NAME_orig` (raw string)
#    - GENERATED `cmdline_parser(argc, argv, &args_info)` — entry
#      point returning 0 on success
#    - GENERATED `cmdline_parser_print_help()` — auto-formatted help
#    - GENERATED `cmdline_parser_print_version()` — version output
#    - GENERATED `cmdline_parser_free(&args_info)` — release allocated
#      memory
#    - GENERATED `cmdline_parser_dump(FILE*, &args_info)` — dump
#      current args to file (config-file feature)
#    - GENERATED `cmdline_parser_file_save(filename, &args_info)` —
#      save to config file
#    - GENERATED `cmdline_parser_configfile(filename, &args_info,
#      override, init, check_required)` — load from config file
#    - AUTO-INJECTED `--help`/`-h`/`--detailed-help`/`--full-help`
#      flags
#    - AUTO-INJECTED `--version`/`-V` flag (when version specified)
#  Distinct from R272 C POSIX getopt (LOW-LEVEL char-by-char with
#  caller-written switch loop; no help generation; no grouping;
#  no nested parsers), R382 GNU argp (struct argp_option array +
#  parser callback model + special keys for positional/lifecycle
#  hooks + nested children parsers + auto-help; GNU/Linux-glibc-
#  specific), R394 likle/cargs (cross-platform single-header
#  declarative struct cag_option array; runtime library), R387
#  Bash Argbash (CLOSEST concept analog — both are build-time code
#  generators using declarative spec files; Argbash uses M4 macros
#  in bash comments to emit bash code, while gengetopt uses .ggo
#  files to emit C code; both produce NO-RUNTIME-DEP output but
#  Argbash targets Bash and gengetopt targets C).  gengetopt's
#  approach: BUILD-TIME CODE GENERATOR + `.ggo` DECLARATIVE SYNTAX
#  with package/purpose/usage/version/description/option/section/
#  text directives + TYPE DIRECTIVES (flag/string/int/long/float/
#  double/enum) + `typestr=`/`default=`/`optional`/`required`/
#  `argoptional`/`multiple`/`hidden` modifiers + SECTION grouping +
#  MODAL SUBCOMMAND support via `mode` directive + GENERATED .c/.h
#  WITH NO RUNTIME LIBRARY DEPENDENCY (uses libc getopt_long
#  internally) + `args_info` struct with `NAME_arg`/`NAME_given`/
#  `NAME_arg_count` fields + AUTO-INJECTED --help/--detailed-help/
#  --full-help/--version flags + CONFIG FILE SUPPORT via
#  `cmdline_parser_configfile`/`cmdline_parser_file_save`/
#  `cmdline_parser_dump` — corpus's **first documented build-time-
#  code-generator-targeting-C CLI library** (cf. R387 Argbash which
#  targets Bash).  Brings cross-language CLI library taxonomy
#  variant count to 136; C ecosystem now has 4 documented CLI
#  libraries.
#
#  Surface (verbatim from `src/bin/RNAdos.ggo`):
#
#  Options:
#    -v, --verbose                  Be verbose (lower log level)
#
#  I/O Options:
#    -s, --sequence STRING          The RNA sequence (ACGU)
#    -j, --numThreads N             Number of OpenMP threads
#        --log-level LEVEL          Log level threshold (default 2)
#                                   (hidden in --help)
#        --log-file FILE            Log file path (default RNAdos.log)
#                                   (hidden, argoptional)
#        --log-time                 Include time stamp in log
#                                   (hidden flag)
#        --log-call                 Include file/line of caller
#                                   (hidden flag)
#
#  Algorithm Options:
#    -e, --max-energy N             Energy threshold in kcal/mol
#                                   (default 0)
#    -b, --hashtable-bits N         DP-matrix hash table bit size
#                                   (default 20; hidden)
#
#  Energy Parameter Options:
#    -T, --temp DEGREES_C           Temperature in Celsius (default 37.0)
#    -P, --paramFile FILE           Energy parameter file (or 'DNA'
#                                   placeholder for DNA parameters)
#        --salt MOLAR               Salt concentration in molar
#                                   (default 1.021M)
#
#  Model Details:
#    -d, --dangles 0|1|2|3          Dangling-end treatment (default 2)
#        --helical-rise FLOAT       Helix rise in Angstrom (default 2.8;
#                                   hidden)
#        --backbone-length FLOAT    Backbone length in Angstrom
#                                   (default 6.0; hidden)
#
#  Auto-injected by gengetopt:
#    -h, --help                     Print help
#        --detailed-help            Print full help with details
#        --full-help                Print full help including hidden
#        --version, -V              Print version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also gengetopt users):
#    - RNAfold / RNAcofold / RNAheat / RNAinverse / RNALfold / RNAplot
#      / RNAsubopt / rnafold / rnaalifold / rnaduplex / rnaeval (ALL
#      ViennaRNA sister tools IN CORPUS via _RNAfold/_RNAcofold/etc.;
#      all use gengetopt with similar .ggo specs)
#    - RTK (RTKConsortium/RTK 289 stars — Reconstruction Toolkit
#      medical imaging; uses gengetopt heavily, FUTURE candidate
#      for medical imaging scope)
#    - OpenMD (91 stars — Molecular Dynamics; uses gengetopt for
#      every utility binary)
#    - AwaLWM2M (Connectivity Foundry 110 stars — LightweightM2M
#      IoT protocol; uses gengetopt for awa-client-*/awa-server-*
#      tools)
#    - PIntron (AlgoLab 5 stars — gene-structure prediction, niche)
#    - twstools (Interactive Brokers TWS API tools, niche)
#    - rdsmsg / f32c (FM RDS message generator, embedded scope)
#    - chef-symbex-lua (chef symbolic execution example, academic)
# ============================================================================

_RNAdos() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-v --verbose)'{-v,--verbose}'[be verbose]' \
    '(-s --sequence)'{-s,--sequence}'=[RNA sequence (ACGU)]:sequence' \
    '(-j --numThreads)'{-j,--numThreads}'=[number of OpenMP threads]:n' \
    '--log-level=[log level threshold (default 2)]:level' \
    '--log-file=[log file path (default RNAdos.log)]:file:_files' \
    '--log-time[include time stamp in log]' \
    '--log-call[include file/line of caller]' \
    '(-e --max-energy)'{-e,--max-energy}'=[energy threshold in kcal/mol (default 0)]:n' \
    '(-b --hashtable-bits)'{-b,--hashtable-bits}'=[DP hash table bits (default 20)]:n' \
    '(-T --temp)'{-T,--temp}'=[temperature in Celsius (default 37.0)]:degrees' \
    '(-P --paramFile)'{-P,--paramFile}'=[energy parameter file]:file:_files' \
    '--salt=[salt concentration in molar (default 1.021M)]:concentration' \
    '(-d --dangles)'{-d,--dangles}'=[dangling-end treatment]:mode:(0 1 2 3)' \
    '--helical-rise=[helix rise in Angstrom (default 2.8)]:rise' \
    '--backbone-length=[backbone length in Angstrom (default 6.0)]:length' \
    '(-h --help)'{-h,--help}'[print help]' \
    '--detailed-help[print full help with details]' \
    '--full-help[print full help including hidden]' \
    '(-V --version)'{-V,--version}'[print version]'
}

_RNAdos "$@"
