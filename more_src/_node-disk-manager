#compdef ndm node-disk-manager
# _node-disk-manager — OpenEBS Node Disk Manager DaemonSet (discovers + tracks block devices as BlockDevice CRs)
# upstream: https://github.com/openebs/node-disk-manager
# Subcommands + flags from cmd/ndm_daemonset/app/command on tip (cobra).

_node-disk-manager() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[NDM config file]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                start:'start the node-disk controller'
                device:'get/list block devices managed by NDM'
            )
            _describe -t commands 'node-disk-manager subcommand' subs
            ;;
        args)
            case $line[1] in
                device)
                    _arguments \
                        '1: :(get list)' \
                        '--api-service-address=[gRPC address of the NDM API service]:addr:'
                    ;;
            esac
            ;;
    esac
}

_node-disk-manager "$@"
