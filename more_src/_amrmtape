#compdef amrmtape
# _amrmtape — Zmanda Amanda amrmtape CLI for removing a specific tape label from the Amanda tape catalog dropping associated dumps from the index keeping or erasing the tape header with cleanup commit (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amrmtape() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-n[no commit dry-run]' \
        '--dry-run[no commit dry-run]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-x[do not remove tape entry]' \
        '--no-erase-info[do not remove tape entry]' \
        '-c[cleanup index files]' \
        '--cleanup[cleanup index files]' \
        '-e[erase tape]' \
        '--erase[erase tape]' \
        '-r[reuse storage]' \
        '--reuse[reuse storage]' \
        '--changer-name=+[name]:str:' \
        '--storage=+[name]:str:' \
        '*:config label:'
}

_amrmtape "$@"
