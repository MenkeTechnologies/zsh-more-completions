#compdef sfboxsmooth
# Documentation: https://ahay.org/RSF/sfboxsmooth.html
# Madagascar: multi-dimensional box smoothing

local ret=1

_arguments -s \
  'repeat=[repeat filtering several times]:int:' \
  'rect1=[smoothing radius on 1st axis]:int:' \
  'rect2=[smoothing radius on 2nd axis]:int:' \
  'rect3=[smoothing radius on 3rd axis]:int:' \
  '*:rsf file:_files' && ret=0

return ret
