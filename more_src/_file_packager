#compdef file_packager
# Documentation: https://emscripten.org/docs/porting/files/packaging_files.html
# file_packager - package files into a .data bundle for Emscripten virtual FS

local ret=1

_arguments -s -S \
  '--preload[preload files into a separate .data bundle]:file:_files' \
  '--exclude[exclude files matching fnmatch patterns]:pattern:' \
  '--js-output=[output filename for the generated JavaScript file]:file:_files' \
  '*:target:_files' && ret=0

return ret
