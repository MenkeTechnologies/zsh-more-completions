#compdef xrdmapc
# Documentation: https://man.archlinux.org/search?q=xrdmapc
# Reference accessed: 2026-05-16

# xrdmapc: query CMS manager to map xrootd resources
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[debug]' \
  '--host=[xrootd host]:host:_hosts' \
  '-l[redirector list]:hosts:' \
  '*:path:_files' && ret=0
return ret
