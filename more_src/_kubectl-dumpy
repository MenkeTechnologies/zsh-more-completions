#compdef kubectl-dumpy
# Documentation: https://github.com/larryTheSlap/dumpy
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'capture:deploy sniffers to capture network traffic'
      'get:display capture details'
      'export:extract PCAP files from sniffers'
      'delete:remove captures and related sniffers'
      'restart:redeploy sniffers with new filters'
      'stop:terminate tcpdump processes on sniffers'
    )
    _describe -t commands 'kubectl-dumpy command' commands && ret=0
    ;;
  args)
    case $line[1] in
      capture)
        _arguments -s -S \
          '-n+[namespace for dumpy sniffer deployment]:namespace:' \
          '-t+[target resource namespace]:namespace:' \
          '-f+[custom tcpdump filters]:filters:' \
          '-c+[container name for multi-container pods]:container:' \
          '-v+[PVC name for storing captures]:pvc:' \
          '-i+[dumpy image for private clusters]:image:' \
          '-s+[image pull secret for private registries]:secret:' \
          '--name=[custom capture identifier]:name:' \
          '*:resource:_default' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-n+[capture namespace]:namespace:' \
          '-f+[tcpdump filters]:filters:' \
          '*:: :_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
