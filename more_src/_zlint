#compdef zlint

_arguments -s \
  '-format=[input format]:format:(pem der base64)' \
  '-includeSources=[only run from sources]:sources:' \
  '-excludeSources=[exclude sources]:sources:' \
  '-includeNames=[only run lints]:names:' \
  '-excludeNames=[exclude lints]:names:' \
  '-nameFilter=[regex name filter]:regex:' \
  '-list-lints-json[list lints as JSON]' \
  '-list-lints-source[list lints with source]' \
  '-list-profiles[list profiles]' \
  '-summary[short summary]' \
  '-longSummary[long summary]' \
  '-pretty[pretty print JSON]' \
  '-profile=[profile name]:profile:' \
  '-config=[config file]:file:_files' \
  '-exampleConfig[print example config]' \
  '(- *)-version[show version]' \
  '*:cert: _files'
