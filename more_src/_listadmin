#compdef listadmin

# listadmin: command-line moderator for Mailman 2 / 3 admin queues
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-f[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-l[log file]:file:_files' \
  '--log=[log file]:file:_files' \
  '-a[user supplied admin URL/etc]:value:' \
  '-t[mail-thread option]:val:' \
  '--threading=[mail-thread option]:val:' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '*:list name:' && ret=0
return ret
