#compdef listadmin
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/listadmin.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# listadmin: process messages held by Mailman for approval
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-?[display help]' \
  '(- *)--help[display help]' \
  '(- *)-V[output version]' \
  '(- *)--version[output version]' \
  '-f[config file]:file:_files' \
  '-t[stop processing after minutes]:minutes:' \
  '--mail[added subscribers have nomail off]' \
  '--nomail[added subscribers have nomail on]' \
  '-a[add e-mail addresses listed in file]:file:_files' \
  '--add-member=[add a single address]:address:' \
  '-r[remove e-mail addresses listed in file]:file:_files' \
  '--remove-member=[remove a single address]:address:' \
  '-l[display the subscriber list]' \
  '*:list name:' && ret=0
return ret
