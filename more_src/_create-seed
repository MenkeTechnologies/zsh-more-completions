#compdef create-seed
# Documentation: https://create-seed.xyz
# Reference accessed: 2026-05-24
# Verified: npm view create-seed bin; npm readme Options section at the URL above.

# Zsh completion for create-seed - template-based project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-V --version)'{-V,--version}'[output the version number]' \
  '(-t --template)'{-t,--template=}'[template name, gh: URL, or local path]:template:' \
  '--pm=[package manager]:manager:(npm pnpm bun)' \
  '--allow-missing-tools[continue when create-seed.tools commands are not installed]' \
  '--skip-git[skip git initialization]' \
  '--skip-install[skip installing dependencies]' \
  '(-l --list)'{-l,--list}'[list available templates]' \
  '--templates-url=[URL or path to templates.json]:url:' \
  '(-d --dry-run)'{-d,--dry-run}'[dry run without writing files]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[display help for command]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' registry template tools && ret=0
    ;;
  args)
  _arguments -C \
    '(-t --template)'{-t,--template=}'[template]:template:' \
    '--pm=[package manager]:manager:(npm pnpm bun)' \
    '--skip-git[skip git initialization]' \
    '--skip-install[skip installing dependencies]' \
    ':project name:' && ret=0
    ;;
esac

return ret
