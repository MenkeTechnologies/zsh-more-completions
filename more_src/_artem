#compdef artem

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --characters)'{-c,--characters}'+[custom character set (dark to bright)]:characters:' \
  '--color[use truecolor ANSI output]' \
  '(-b --border)'{-b,--border}'[add a border around the output]' \
  '(-C --center-x)'{-C,--center-x}'[center the output horizontally]' \
  '--center-y[center the output vertically]' \
  '-f[flip the image horizontally]' \
  '--height+[set output height in characters]:height:' \
  '--width+[set output width in characters]:width:' \
  '(-H --hysteresis)'{-H,--hysteresis}'[use edge detection (outline mode)]' \
  '--invert[invert the image luminance]' \
  '--no-color[disable color output]' \
  '--outline[use edge detection]' \
  '(-t --target)'{-t,--target}'+[output target]:target:(ansi html)' \
  '--background+[background color]:color:' \
  '*:image file:_files -g "*.{png,jpg,jpeg,gif,bmp,tiff,webp,ico,pnm}(-.)"' && ret=0

return ret
