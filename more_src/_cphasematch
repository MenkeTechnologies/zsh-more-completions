#compdef cphasematch
# Documentation: https://www.ccp4.ac.uk/html/cphasematch.html
# cphasematch — compare two sets of phases / phase agreement (CCP4)

local ret=1

_arguments -s -S \
  '-mtzin[input MTZ]:file:_files -g "*.mtz"' \
  '-mtzout[output MTZ]:file:_files -g "*.mtz"' \
  '-colin-fo[column path for F amplitudes]:path:' \
  '-colin-hl-1[HL coefficients, first set]:path:' \
  '-colin-phifom-1[phase/FOM, first set]:path:' \
  '-colin-fc-1[calculated F, first set]:path:' \
  '-colin-hl-2[HL coefficients, second set]:path:' \
  '-colin-phifom-2[phase/FOM, second set]:path:' \
  '-colin-fc-2[calculated F, second set]:path:' \
  '-colout[output column path]:path:' \
  '-resolution-bins[number of resolution bins]:n:' \
  '-no-origin-hand[disable origin shift checking]' \
  '-stdin[read keywords from standard input]' \
  '*:argument:_files' && ret=0

return ret
