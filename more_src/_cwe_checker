#compdef cwe_checker
# Documentation: https://deepwiki.com/fkie-cad/cwe_checker/1.2-command-line-usage
# cwe_checker - find vulnerable patterns in binary executables

local ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'=[use a custom configuration file]:config:_files' \
  '(-o --out)'{-o,--out}'=[write results to a file]:out:_files' \
  '(-p --partial)'{-p,--partial}'=[run only a comma-separated list of checks]:checks' \
  '(-j --json)'{-j,--json}'[generate JSON output]' \
  '(-q --quiet)'{-q,--quiet}'[do not print log messages]' \
  '(-v --verbose)'{-v,--verbose}'[print additional debug log messages]' \
  '--statistics[include analysis statistics in log messages]' \
  '--bare-metal-config=[config file for bare-metal binaries]:config:_files' \
  '--module-versions[print module version numbers and exit]' \
  '--cfg-stats[print control flow graph statistics and exit]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:binary:_files' && ret=0

return ret
