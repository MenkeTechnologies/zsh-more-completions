#compdef wing

# Zsh completion for Wing CLI
# https://github.com/winglang/wing

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:Start local simulator (alias: it)'
  'it:Start local simulator (alias: run)'
  'compile:Compile Wing file'
  'test:Run tests'
  'doctor:Check environment'
  'help:Show help'
)

_arguments -s -S \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'wing command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (run|it)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[port for Wing Console]:port:' \
          '--no-open[prevent browser from opening]' \
          '1:file:_files -g "*.w"' && ret=0
        ;;
      (compile)
        _arguments -s -S \
          '(-t --target)'{-t,--target}'[deployment target]:target:(sim tf-aws tf-azure tf-gcp awscdk)' \
          '(-o --output)'{-o,--output}'[output directory]:dir:_directories' \
          '--platform=[custom platform provider]:platform:' \
          '1:file:_files -g "*.w"' && ret=0
        ;;
      (test)
        _arguments -s -S \
          '(-t --target)'{-t,--target}'[target to run tests against]:target:(sim)' \
          '(-w --watch)'{-w,--watch}'[re-run tests automatically]' \
          '(-v --verbose)'{-v,--verbose}'[show detailed output]' \
          '*:file:_files -g "*.w"' && ret=0
        ;;
    esac
    ;;
esac

return ret
