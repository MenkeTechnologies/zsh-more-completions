#compdef fzinformer
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/gsfml — plot statistical information from fracture zone analysis

local ret=1

_arguments -s \
  '-D[use filtered fzblender output instead of raw analysis]' \
  '-F+[max F-statistic amplitude for plot]:value:_default' \
  '-I+[select single cross-profile by number]:n:_default' \
  '-N+[max range of VGG amplitudes in Eotvos]:value:_default' \
  '-S+[max half-range of FZ offsets in km]:value:_default' \
  '-T+[file name prefix]:prefix:_default' \
  '-W+[max range of FZ widths in km]:value:_default' \
  '-Z+[quality index thresholds amp/var/F/width]:opts:_default' \
  '*-V[verbose (stackable)]' \
  '-bo+[binary output format]:format:_default' \
  '-do+[replace NaN output with nodata]:nodata:_default' \
  '-i+[input column selection]:cols:_default' \
  '-o+[output column selection]:cols:_default' \
  '-q+[row/data limits]:limits:_default' \
  '*:input file:_files' \
  && ret=0

return ret
