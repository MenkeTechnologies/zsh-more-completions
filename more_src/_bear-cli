#compdef bear-cli
# _bear-cli — rizsotto Bear build EAR compile_commands.json generator CLI alias (László Nagy / rizsotto, C++); custom argparse
# upstream: https://github.com/rizsotto/Bear

_bear-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--output=+[output file]:file:_files -g "compile_commands.json"' \
        '-o+[output file]:file:_files -g "compile_commands.json"' \
        '--config=+[config file]:file:_files' \
        '--append[append to existing output]' \
        '--use-cc=+[C compiler list]:list:' \
        '--use-c++=+[C++ compiler list]:list:' \
        '--use=+[generic compiler list]:list:' \
        '--force-preload[force preload mode]' \
        '--force-wrapper[force wrapper mode]' \
        '--field-output=+[field output]:str:' \
        '--bear-path=+[bear path]:file:_files' \
        '--libear=+[libear path]:file:_files' \
        '--wrapper=+[wrapper path]:file:_files' \
        '--cc-compilers=+[cc compilers]:list:' \
        '--cxx-compilers=+[cxx compilers]:list:' \
        '--match=+[match regex]:str:' \
        '--filter=+[filter regex]:str:' \
        '--no-filter[no filter]' \
        '--include-paths=+[include paths]:list:_files -/' \
        '--exclude-paths=+[exclude paths]:list:_files -/' \
        '--socket=+[ipc socket]:file:_files' \
        '*:cmd:_command_names -e'
}

_bear-cli "$@"
