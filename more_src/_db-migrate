#compdef db-migrate
# Documentation: https://db-migrate.readthedocs.io/en/latest/Getting%20Started/commands/
# db-migrate Node.js database migration framework

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e --env)'{-e,--env}'=[environment to run the migrations under]:env' \
  '--config=[location of the database.json file]:file:_files' \
  '(-m --migrations-dir)'{-m,--migrations-dir}'=[directory containing migration files]:dir:_files -/' \
  '(-c --count)'{-c,--count}'=[max number of migrations to run]:count' \
  '--dry-run[print the SQL but do not run it]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '--sql-file[create SQL file based migration template]' \
  '--coffee-file[create CoffeeScript migration template]' \
  '1:command:(up down reset create db:create db:drop)' \
  '*::arg:_default' && ret=0

return ret
