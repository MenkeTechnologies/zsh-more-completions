#compdef udocker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '-D[debug mode]' \
  '--debug[debug mode]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'search:search Docker Hub'
      'pull:pull image from registry'
      'create:create container from image'
      'run:run container'
      'ps:list containers'
      'images:list local images'
      'rm:remove container'
      'rmi:remove image'
      'name:set container name'
      'rename:rename container'
      'inspect:inspect container or image'
      'verify:verify image integrity'
      'save:save image to file'
      'load:load image from file'
      'import:import tar file as image'
      'export:export container to tar'
      'clone:clone container'
      'login:login to registry'
      'logout:logout from registry'
      'setup:setup execution engine'
      'install:install tools'
      'mkrepo:create local repository'
      'tag:tag image'
    )
    _describe -t commands 'udocker command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      run)
        _arguments -s -S \
          '--rm[remove after execution]' \
          '-d[daemon mode]' \
          '-e+[environment variable]:name=value' \
          '--env=[environment variable]:name=value' \
          '-v+[bind mount volume]:host_path:container_path' \
          '--volume=[bind mount volume]:host_path:container_path' \
          '-w+[working directory]:directory' \
          '--workdir=[working directory]:directory' \
          '-u+[run as user]:user' \
          '--user=[run as user]:user' \
          '-p+[port mapping]:port' \
          '--publish=[port mapping]:port' \
          '--name=[container name]:name' \
          '--hostname=[set hostname]:hostname' \
          '--hostauth[use host authentication]' \
          '--nosysdirs[do not map system directories]' \
          '--novol=[exclude volume]:volume' \
          '*::command:_command_names -e' && ret=0
        ;;
      pull)
        _arguments -s -S \
          '--registry=[registry]:url' \
          '1:image:' && ret=0
        ;;
    esac
    ;;
esac

return ret
