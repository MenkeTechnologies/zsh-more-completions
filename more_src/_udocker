#compdef udocker
# Documentation: https://github.com/indigo-dc/udocker
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '-D[debug mode]' \
  '--debug[debug mode]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'search:search Docker Hub'
      'pull:pull image from registry'
      'create:create container from image'
      'run:run container'
      'ps:list containers'
      'images:list local images'
      'rm:remove container'
      'rmi:remove image'
      'name:apply name to container'
      'rmname:remove name from container'
      'rename:rename container'
      'inspect:inspect container or image'
      'verify:verify image integrity'
      'save:save image to file'
      'load:load image from file'
      'import:import tar file as image'
      'export:export container to tar'
      'clone:clone container'
      'login:login to registry'
      'logout:logout from registry'
      'setup:setup execution engine'
      'install:install tools'
      'mkrepo:create local repository'
      'tag:tag image'
    )
    _describe -t commands 'udocker command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      run)
        _arguments -s -S \
          '--rm[remove container after execution]' \
          '-e+[environment variable]:name=value:' \
          '--env=[environment variable]:name=value:' \
          '--env-file=[read environment from file]:file:_files' \
          '-v+[bind mount volume HOST:CONT]:host_path\:container_path:' \
          '--volume=[bind mount volume HOST:CONT]:host_path\:container_path:' \
          '-w+[working directory]:directory:_directories' \
          '--workdir=[working directory]:directory:_directories' \
          '--user=[run as user (name or uid:gid)]:user:_users' \
          '--publish=[map container port to host]:host_port\:container_port:' \
          '--publish-all[map all container ports]' \
          '--name=[set container name]:name:' \
          '--bindhome[bind user home into container]' \
          '--hostauth[obtain user account from host]' \
          '--containerauth[use container passwd/group]' \
          '--hostenv[pass host environment to container]' \
          '--nosysdirs[do not map /proc /sys /run /dev]' \
          '--nometa[ignore container metadata]' \
          '--novol=[exclude volume from mapping]:dir:_directories' \
          '*::command:_command_names -e' && ret=0
        ;;
      pull)
        _arguments -s -S \
          '--registry=[registry URL]:url:_urls' \
          '1:image:' && ret=0
        ;;
    esac
    ;;
esac

return ret
