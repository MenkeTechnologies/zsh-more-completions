#compdef sfhilbert
# Documentation: https://github.com/ahay/src/blob/master/user/chenyk/Mhilbert.c
# Madagascar: compute Hilbert transform using different methods

local ret=1

_arguments -s -S \
  'type=[method: t time domain, f frequency domain, m robust]:type:(t f m)' \
  'order=[Hilbert transformer order if type=m]:order' \
  'ref=[Hilbert transformer reference (0.5 < ref <= 1) if type=m]:ref' \
  'phase=[phase shift in degrees]:phase' \
  '*:RSF file:_files' && ret=0

return ret
