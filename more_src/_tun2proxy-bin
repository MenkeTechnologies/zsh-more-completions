#compdef tun2proxy-bin

# Zsh completion for tun2proxy TUN → SOCKS/HTTP proxy (tun2proxy/tun2proxy)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --proxy)'{-p,--proxy}'[proxy URL socks4|socks5|http]:url' \
  '(-t --tun)'{-t,--tun}'[utun/tun interface name]:if' \
  '--tun-fd[existing tun file descriptor]:fd' \
  '--close-fd-on-drop[tun FD lifetime]:bool:(true false)' \
  '--ipv6-enabled[enable IPv6 path]' \
  '(-s --setup)'{-s,--setup}'[install split routes / firewall]' \
  '(-d --dns)'{-d,--dns}'[DNS strategy]:strategy:(virtual over-tcp direct)' \
  '--dns-addr[resolver IP]:ip' \
  '--virtual-dns-pool[fake-IP CIDR]:cidr' \
  '*(-b --bypass)'{-b,--bypass}'[hosts bypassing tunnel]:cidr' \
  '--tcp-timeout[TCP session timeout seconds]:sec' \
  '--udp-timeout[UDP mapping timeout seconds]:sec' \
  '(-v --verbosity)'{-v,--verbosity}'[log verbosity]:level:(off error warn info debug trace)' \
  '--daemonize[background on unix / service on Windows]' \
  '--exit-on-fatal-error[quit immediately on hard failure]' \
  '--max-sessions[concurrent flows limit]:n' \
  '--udpgw-server[UDP over TCP helper host:port]:endpoint' \
  '--udpgw-connections[max parallel udpgw sockets]:n' \
  '--udpgw-keepalive[udpgw keepalive seconds]:sec' \
  '*::args:{ _message "linux: --unshare options; see tun2proxy-bin --help" }' && ret=0

return ret
