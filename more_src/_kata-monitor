#compdef kata-monitor

# kata-monitor: Kata Containers monitor (sandbox metrics)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '--listen-address=[listen address]:addr:' \
  '--log-level=[log level]:level:(trace debug info warn error)' \
  '--runtime-endpoint=[runtime endpoint]:endpoint:' \
  '*::kata-monitor args:_files' && ret=0
return ret
