#compdef superpose
# CCP4: superpose macromolecular structures by secondary-structure matching

local ret=1

_arguments -s -S \
  '*-s+[selection string (MMDB convention)]:selection:' \
  '-o+[output PDB file with transformation applied]:output:_files' \
  '*:structure:_files -g "*.(pdb|cif|ent|brk)"' && ret=0

return ret
