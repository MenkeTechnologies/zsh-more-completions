#compdef muzak
# Documentation: https://github.com/muzak-project/muzak/blob/master/COMMANDS.md
# Reference accessed: 2026-05-19
# Verified: upstream COMMANDS.md at the URL above. Muzak is a Ruby
# metamusic player driven by a command name as the first argument
# (no traditional -h/--V flags); commands include play, pause, toggle,
# next, previous, now-playing, enqueue-*, list-*, playlist-*, ping, quit.

local -a commands
commands=(
  'play:start playback'
  'pause:pause the player'
  'toggle:toggle play/pause'
  'next:skip to next song'
  'previous:play previous song'
  'now-playing:show currently playing track'
  'list-queue:display playback queue'
  'clear-queue:empty the queue'
  'shuffle-queue:randomize queue order'
  'jukebox:add N random songs to the queue'
  'list-artists:show all artists'
  'list-albums:show all albums'
  'albums-by-artist:list albums by an artist'
  'songs-by-artist:list songs by an artist'
  'enqueue-artist:enqueue an artist'
  'enqueue-album:enqueue an album'
  'enqueue-playlist:enqueue a playlist'
  'list-playlists:show available playlists'
  'playlist-add-album:add album to playlist'
  'playlist-add-artist:add artist to playlist'
  'playlist-add-current:save the now-playing song'
  'playlist-del-current:remove the now-playing song'
  'playlist-delete:delete a playlist'
  'playlist-shuffle:randomize a playlist'
  'player-activate:start player instance'
  'player-deactivate:stop player instance'
  'reload-index:refresh music library'
  'dump-index:export current index state'
  'config-get:retrieve a config value'
  'list-plugins:show available plugins'
  'ping:verify instance is running'
  'help:list all commands'
  'quit:terminate muzak'
)

if (( CURRENT == 2 )); then
  _describe -t commands 'muzak command' commands
else
  _files
fi
