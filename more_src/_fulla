#compdef fulla
# Documentation: https://man.archlinux.org/search?q=fulla
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-g+[blue-yellow,green-magenta TCA params]:abc_d:' \
  '-b+[red-cyan TCA params]:abc_d:' \
  '-r+[image rotation 0/90/180/270]:rot:(0 90 180 270)' \
  '-d[distortion correction params (a,b,c)]' \
  '-m+[manufacturer]:mfr:' \
  '-o+[output file]:file:_files' \
  '-p[print correction parameters]' \
  '-s+[scale]:val:' \
  '-c+[crop image after correction]:crop:' \
  '-i+[input image]:file:_files' \
  '-v[verbose]' \
  '*:image:_files' && ret=0

return ret
