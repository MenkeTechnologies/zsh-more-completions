#compdef dmd
# Documentation: dmd --help (DMD64 D Compiler 2.112)
# Source: D Language Foundation DMD — reference D compiler.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*@-[read arguments from command file]:cmdfile:_files' \
    '-allinst[generate code for all template instantiations]' \
    '-betterC[omit some runtime info / helpers]' \
    '-boundscheck=[bounds checks]:mode:(on safeonly off)' \
    '(-c -run)-c[compile only, no link]' \
    '(-c -run)-run[compile and run]' \
    '*-check=[enable/disable specific check]:check[=on|off]:(assert bounds in invariant out switch)' \
    '-checkaction=[behavior on check failure]:action:(D C halt context)' \
    '(--color -color)'{--color,-color=-}'[colored output]::when:(on off auto)' \
    '-conf=[config file]:file:_files' \
    '-cov[code coverage analysis]' \
    '-cov=[require coverage percent]:nn:' \
    '-cpp=[C preprocessor for ImportC]:filename:_command_names -e' \
    '-D[generate documentation]' \
    '-Dd-[doc output directory]:dir:_files -/' \
    '-Df-[doc output filename]:file:_files' \
    '(-d -de -dw)-d[silently allow deprecated]' \
    '(-d -de -dw)-de[error on deprecated]' \
    '(-d -de -dw)-dw[warn on deprecated (default)]' \
    '-debug[compile in debug code]' \
    '*-debug=-[debug code <= level or identifier]:level-or-ident:' \
    '-debuglib=[debug library]:name:' \
    '-defaultlib=[default library]:name:' \
    '-deps[print module dependencies]' \
    '-deps=-[write dependencies to file]:file:_files' \
    '-dllimport=[Windows dllimport scope]:scope:(none defaultLibsOnly externalOnly all)' \
    '-edition=[set language edition]:year[G[FILE]]:' \
    '-extern-std=[C++ name mangling standard]:standard:' \
    '-fIBT[Indirect Branch Tracking code]' \
    '-ftime-trace[turn on compile-time profiler]' \
    '-ftime-trace-granularity=[profiler granularity (us)]:us:' \
    '-ftime-trace-file=[profiler output file]:file:_files' \
    '-fPIC[position independent code]' \
    '-fPIE[position independent executable]' \
    '-fno-druntime[exclude druntime]' \
    '-g[debug info]' \
    '-gdwarf=[DWARF version]:n:(2 3 4 5)' \
    '-gf[extra debug info]' \
    '-gs[no stack frame omission]' \
    '*-H[generate D interface file]' \
    '-Hd-[interface output dir]:dir:_files -/' \
    '-Hf-[interface output file]:file:_files' \
    '*-I-[include search path]:dir:_files -/' \
    '-i=-[automatically include matching modules]:patterns:' \
    '*-J-[string-import search path]:dir:_files -/' \
    '*-L-[linker option]:opt:' \
    '*-Xcc=-[pass option to C compiler]:opt:' \
    '*-Xlinker=-[pass option to linker]:opt:' \
    '-lib[generate library]' \
    '-lowmem[reduce memory at compile time]' \
    '-m32[generate 32-bit code]' \
    '-m64[generate 64-bit code]' \
    '-makedeps[print module dependencies (make rule)]' \
    '-makedeps=-[write dependencies to file]:file:_files' \
    '-man[show man page]' \
    '-mcpu=[target CPU]:cpu:(baseline avx avx2 native)' \
    '-mscrtlib=[Windows C runtime library]:lib:' \
    '-mv=-[remap package/module to path]:package=path:' \
    '-noboundscheck[disable bounds checking]' \
    '-nofloat[do not emit reference to floating point]' \
    '-O[optimize]' \
    '-o-[do not write object file]' \
    '-od-[output object directory]:dir:_files -/' \
    '-of-[output object file]:file:_files' \
    '-op[preserve source path in output]' \
    '-os=[target OS]:os:' \
    '-P=-[preprocessor option for ImportC]:opt:' \
    '*-preview=-[enable preview feature]:feature:' \
    '*-revert=-[revert change]:feature:' \
    '-profile[CPU profiling]' \
    '-profile=gc[GC profiling]' \
    '-quiet[suppress warnings]' \
    '-release[release build (no asserts/contracts/etc)]' \
    '-shared[shared library]' \
    '-target=[target triple]:triple:' \
    '-transition=-[enable transition feature]:feature:' \
    '*-unittest[compile in unit tests]' \
    '(- *)'{-v,-vasm,-version,-vcg-ast,-vgc,-vtemplates,-vtemplates-list-instances,-verror-style=,-vtls}'-v[verbose compiler output]' \
    '-vcolumns[print column numbers in errors]' \
    '-verrors=[max errors before exit]:n:' \
    '*-version=-[compile with version identifier/level]:ident-or-level:' \
    '-w[warnings as errors]' \
    '-wi[warnings (info)]' \
    '-X[output JSON file with description]' \
    '-Xf-[JSON output file]:file:_files' \
    '*:D source file or args (after -run):_files -g "*.{d,di,o,a,lib}"' \
    && ret=0

return ret
