#compdef spotify_player
# Documentation: https://man.archlinux.org/search?q=spotify_player
# Reference accessed: 2026-05-16

# Zsh completion for spotify_player IPC/CLI (aome510/spotify-player). Top-level args from cli/mod.rs; use spotify_player generate <shell> for full scripts.

local -a sub
sub=(
  'get:fetch Spotify data'
  'playback:control playback'
  'connect:select playback device'
  'like:like or unlike current track'
  'authenticate:OAuth login flow'
  'playlist:manage playlists'
  'generate:emit shell completions'
  'search:search catalogue'
  'features:print compile-time features'
  'lyrics:show lyrics for a track'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-t --theme)'{-t,--theme=}'[UI theme name]:theme:' \
  '(-c --config-folder)'{-c,--config-folder=}'[config directory]:dir:_directories' \
  '(-C --cache-folder)'{-C,--cache-folder=}'[cache directory]:dir:_directories' \
  '*'{-o,--config-override}'+[override config KEY=value]:override:' \
  '1: :{_describe '\''spotify_player command'\'' sub}' \
  '*::arguments:_default'
