#compdef spotify_player
# Documentation: https://github.com/aome510/spotify-player (spotify_player/src/cli/mod.rs)
# Reference accessed: 2026-05-21
# Verified: upstream cli/mod.rs clap definitions.

# Zsh completion for spotify_player IPC/CLI (aome510/spotify-player). Use
# `spotify_player generate <shell>` for full upstream-generated scripts.

local -a sub
sub=(
  'get:retrieve Spotify data (keys, items)'
  'playback:control music playback'
  'connect:connect to a device'
  'like:mark tracks as liked/unliked'
  'authenticate:handle Spotify authentication'
  'playlist:manage playlists'
  'generate:generate shell completions'
  'search:search Spotify'
  'print-features:display compile-time features'
  'lyrics:retrieve song lyrics'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-t --theme)'{-t,--theme=}'[application theme]:theme:' \
  '(-c --config-folder)'{-c,--config-folder=}'[path to config folder]:dir:_directories' \
  '(-C --cache-folder)'{-C,--cache-folder=}'[path to cache folder]:dir:_directories' \
  '*'{-o,--config-override=}'[override a config option KEY=VALUE]:override:' \
  '(-d --daemon)'{-d,--daemon}'[run as a daemon]' \
  '1: :{_describe '\''spotify_player command'\'' sub}' \
  '*::arguments:_default'
