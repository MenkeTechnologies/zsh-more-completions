#compdef jack-stdin
# _jack-stdin — read raw audio data from stdin into a JACK port (x42/jack-stdin)
# upstream: https://github.com/x42/jack-stdin
# Flags from jack-stdin(1) man page.

_jack-stdin() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-b --bitdepth)'{-b+,--bitdepth=}'[sample bit depth (16 or 24)]:bits:(16 24)' \
        '(-d --duration)'{-d+,--duration=}'[run duration in seconds (<1 = until EOF)]:sec:' \
        '(-e --encoding)'{-e+,--encoding=}'[input encoding]:format:(signed-integer unsigned-integer floating-point)' \
        '(-f --file)'{-f+,--file=}'[read data from file instead of stdin]:file:_files' \
        '(-p --prebuffer)'{-p+,--prebuffer=}'[pre-fill percent before output (default 50)]:percent:' \
        '(-L --little-endian -B --big-endian)'{-L,--little-endian}'[input is little-endian / native float]' \
        '(-L --little-endian -B --big-endian)'{-B,--big-endian}'[input is big-endian / byte-swapped float]' \
        '(-q --quiet)'{-q,--quiet}'[suppress info / overflow warnings]' \
        '(-S --bufsize)'{-S+,--bufsize=}'[internal ring-buffer size in samples]:samples:' \
        '*:JACK port:'
}

_jack-stdin "$@"
