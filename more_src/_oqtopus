}

cmd_completion() {
  if [[ "${1:-}" == "help" || "${1:-}" == "--help" ]]; then
    usage_completion
    return
  fi
  [[ $# -eq 1 ]] || { usage_completion; exit 1; }
  case "$1" in
    bash) completion_bash ;;
    zsh) completion_zsh ;;
    fish) completion_fish ;;
    *) die "unsupported shell: $1" ;;
  esac
}

# -----------------------------------------------------------------------------
# Top-level command dispatcher
# -----------------------------------------------------------------------------

main() {
  case "${1:-}" in
    help|--help|"")
      usage_top
      ;;
    version|--version)
      local version
      version=$(cli_version)
      printf 'oqtopus %s\n' "$version"
      ;;
    init)
      shift
      cmd_init "$@"
      ;;
    backend)
      shift
      cmd_backend "$@"
      ;;
    completion)
      shift
      cmd_completion "$@"
      ;;
    *)
      die "unknown command: $1"
      ;;
  esac
}

main "$@"
