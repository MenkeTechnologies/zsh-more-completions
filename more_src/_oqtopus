#compdef oqtopus
# Documentation: https://github.com/oqtopus-team/oqtopus-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# oqtopus: CLI for preparing and operating a local OQTOPUS backend environment.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a top_commands=(
  'init:create an OQTOPUS environment'
  'backend:manage local backend components and services'
  'completion:print shell completion scripts'
  'version:print the installed CLI version'
  'help:show help'
)

local -a backend_commands=(
  'install:install backend component releases'
  'versions:list available component versions'
  'uninstall:remove an installed release'
  'update:install the latest release of a component'
  'start:start a managed service'
  'stop:stop a managed service'
  'restart:restart a managed service'
  'status:show process status'
  'device-status:show or update gateway device status'
  'info:show backend environment information'
  'help:show help'
)

local -a backend_components=(engine tranqu gateway)
local -a backend_services=(core sse_engine mitigator estimator combiner tranqu gateway)
local -a shell_choices=(bash zsh fish powershell)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'oqtopus command' top_commands && ret=0 ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--template=[environment template]:template:(backend)' \
          '1:env name:' && ret=0
        ;;
      backend)
        _arguments -C \
          '1: :->bcmd' \
          '*::barg:->bargs' && ret=0
        case $state in
          bcmd) _describe -t commands 'oqtopus backend command' backend_commands && ret=0 ;;
          bargs)
            case $line[1] in
              install|versions|uninstall|update)
                _arguments '1:component:($backend_components)' && ret=0
                ;;
              start|stop|restart|status)
                _arguments '1:service:($backend_services)' && ret=0
                ;;
              device-status|info|help)
                _arguments '*:arg:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      completion)
        _arguments '1:shell:($shell_choices)' && ret=0
        ;;
    esac
    ;;
esac
return ret
