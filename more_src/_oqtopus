ENV_ROOT=""
INSTALL_ROOT=""
ACTIVE_SERVICE_LOCK=""

# -----------------------------------------------------------------------------
# Common output and command helpers
# -----------------------------------------------------------------------------

log() {
  printf '%s\n' "$*"
}

warn() {
  printf 'Warning: %s\n' "$*" >&2
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

need_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    die "'$1' is required but was not found on PATH."
  fi
}

