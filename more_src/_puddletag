#compdef puddletag
# Documentation: https://github.com/puddletag/puddletag
# Reference accessed: 2026-05-16
# Verified: upstream puddletag - Qt audio tag editor. GUI-only; no
# documented CLI options beyond optional file/directory arg.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# puddletag: Qt audio metadata editor (GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:audio file or directory:_files' && ret=0
return ret
