#compdef mFitExec
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mFitExec.html
# Run mFitplane on all difference images listed in a table

local ret=1

_arguments -s -S \
  '-d[enable debugging]' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '1:diffs table:_files -g "*.tbl"' \
  '2:fits table:_files -g "*.tbl"' \
  '3:diff directory:_files -/' && ret=0

return ret
