#compdef quickget

# Zsh completion for quickget - download and prepare VM images for quickemu

local curcontext="$curcontext" state line ret=1

local -a operating_systems=(
  'alma' 'alpine' 'android' 'antix' 'archlinux' 'arcolinux'
  'batocera' 'blendos' 'bodhi' 'bunsenlabs'
  'cachyos' 'centos-stream' 'chimeralinux'
  'debian' 'deepin' 'devuan' 'dragonflybsd'
  'elementary' 'endeavouros'
  'fedora' 'freebsd' 'freedos'
  'garuda' 'gentoo' 'ghostbsd' 'gnomeos' 'guix'
  'haiku' 'holoiso'
  'kali' 'kde-neon' 'kolibrios' 'kubuntu'
  'linuxlite' 'linuxmint' 'lmde' 'lubuntu'
  'macos' 'mageia' 'manjaro' 'mxlinux'
  'netboot' 'netbsd' 'nixos' 'nwg-shell'
  'openbsd' 'openindiana' 'opensuse' 'oraclelinux'
  'parrotsec' 'peppermint' 'popos' 'porteus' 'pureos'
  'reactos' 'rebornos' 'rockylinux'
  'slackware' 'slax' 'slitaz' 'solus' 'sparkylinux'
  'tails' 'tinycore' 'trisquel' 'truenas'
  'ubuntu' 'ubuntu-budgie' 'ubuntu-mate' 'ubuntu-server' 'ubuntu-unity'
  'vanillaos' 'void' 'vxlinux'
  'windows' 'xubuntu'
  'zorin'
)

_arguments -s -S \
  '--list[list available operating systems]' \
  '--list-csv[list available operating systems in CSV format]' \
  '--list-json[list available operating systems in JSON format]' \
  '--show-iso-url[show the ISO download URL]' \
  '--download-only[only download the ISO, do not create VM]' \
  '--open-homepage[open the OS homepage in a browser]' \
  '--url-only[only display the URL, do not download]' \
  '--check-hash[check the hash of the downloaded file]' \
  '--create-config[create VM configuration only]' \
  '--version[display version information]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '1:operating system:compadd -a operating_systems' \
  '2:release' \
  '3:edition' && ret=0

return ret
