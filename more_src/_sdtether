#compdef sdtether
# Documentation: https://rdock.github.io/documentation/html_docs/reference-guide/programs.html
# sdtether - rDock annotate ligands with tethered substructure atoms.

local ret=1

_arguments -s \
  '1:reference SD file:_files' \
  '2:input SD file:_files' \
  '3:output SD file:_files' \
  '4:SMARTS query string:' && ret=0

return ret
