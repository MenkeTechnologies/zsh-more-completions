#compdef xcode-project
# Documentation: https://github.com/codemagic-ci-cd/cli-tools/tree/master/docs/xcode-project
# Codemagic CLI tools - utility to work with Xcode projects

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-s --silent)'{-s,--silent}'[suppress log output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--no-color[disable colored output]' \
  '--log-stream=[log output destination]:stream:(stderr stdout)' \
  '1:command:(build-ipa clean junit-test-results detect-bundle-id default-test-destination ipa-info pkg-info test-destinations run-tests show-build-settings test-summary use-profiles)' \
  '*::args:->args' && ret=0

return ret
