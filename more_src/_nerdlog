#compdef nerdlog
# Documentation: https://github.com/dimonomid/nerdlog
# Reference accessed: 2026-05-19
# Verified: upstream README documents the flags below.

# Zsh completion for nerdlog - remote-first TUI log viewer

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--lstreams=[logstreams to query]:logstreams' \
  '--time=[time range]:range' \
  '--pattern=[filter pattern]:pattern' \
  '--lstreams-config=[path to lstreams config]:file:_files' \
  '--cmdhistory-file=[path to command history file]:file:_files' \
  '--queryhistory-file=[path to query history file]:file:_files' \
  '*:log:_files' && ret=0

return ret
