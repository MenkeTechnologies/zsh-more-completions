#compdef geda gattrib gnetlist gschlas
# Documentation: http://wiki.geda-project.org/geda:documentation
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

case $service in
  (gnetlist)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-g --backend)'{-g,--backend}'+[netlist backend]:backend:(spice spice-sdb verilog vhdl bae geda DRC DRC2 PCB pads protelII)' \
      '(-L --library)'{-L,--library}'+[Scheme library dir]:dir:_files -/' \
      '(-l --pre-load)'{-l,--pre-load}'+[load Scheme file before netlist]:file:_files' \
      '(-m --post-load)'{-m,--post-load}'+[load Scheme file after netlist]:file:_files' \
      '(-o --output)'{-o,--output}'+[output netlist file]:file:_files' \
      '(-O --backend-option)'{-O,--backend-option}'+[backend option]:opt:' \
      '(-c --eval-code)'{-c,--eval-code}'+[evaluate Scheme code]:code:' \
      '(-q --quiet)'{-q,--quiet}'[quiet]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '*:schematic:_files -g "*.sch"' && ret=0 ;;
  (gattrib)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-q --quiet)'{-q,--quiet}'[quiet]' \
      '*:schematic:_files -g "*.sch"' && ret=0 ;;
  (gschlas)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-e --embed)'{-e,--embed}'[embed all components]' \
      '(-u --unembed)'{-u,--unembed}'[unembed all components]' \
      '*:schematic:_files -g "*.sch"' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' && ret=0 ;;
esac

return ret
