#compdef cargo-generate-rpm
# Documentation: https://github.com/cat-in-136/cargo-generate-rpm
# Cargo helper command to generate a binary RPM package

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --package)'{-p,--package}'=[package directory for workspace builds]:dir:_files -/' \
  '(-a --auto-req)'{-a,--auto-req}'=[automatic dependency discovery mode]:mode:(auto disabled no builtin find-requires)' \
  '--variant=[select metadata variant]:variant' \
  '--metadata-overwrite=[override config with TOML file or path]:file:_files' \
  '(-s --set-metadata)'{-s,--set-metadata}'=[override config with inline TOML text]:toml' \
  '(-o --output)'{-o,--output}'=[RPM output file location]:file:_files' \
  '--payload-compress=[compression type]:type:(none gzip zstd)' \
  '--signing-key=[PGP key file path for signing]:file:_files' \
  '--target=[target triple for cross-compilation]:target' \
  '--target-dir=[custom build target directory]:dir:_files -/' \
  '(-b --build)'{-b,--build}'[build before generating RPM]' \
  '--profile=[custom build profile]:profile' && ret=0

return ret
