#compdef dovecot
# _dovecot — Dovecot IMAP/POP3/Submission/LMTP/managesieve server master process (the daemon entrypoint that forks individual login + service processes)
# upstream: https://github.com/dovecot/core
# Flags from src/master/main.c print_help on tip; reload/stop are positional control commands.

_dovecot() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version and exit]' \
        '(- *)--build-options[print configured build options and exit]' \
        '(- *)--hostdomain[print FQDN as detected at startup and exit]' \
        '-F[run in foreground]' \
        '-c+[config file]:file:_files' \
        '-p[ask for SSL key passphrase at startup]' \
        '-n[print non-default config + values]' \
        '-a[print all config + values]' \
        '1: :->cmd'
    case $state in
        cmd) _describe -t commands 'control command' '(reload:SIGHUP reload of config stop:stop the master)' ;;
    esac
}

_dovecot "$@"
