#compdef jaeger-collector jaeger-query jaeger-agent jaeger-ingester jaeger-all-in-one
# Documentation: https://www.jaegertracing.io/docs/1.62/cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Jaeger v1 components. Replaced placeholder MenkeTechnologies repo URL
# with the real CLI reference. Removed bogus repeatable `*` prefixes,
# fabricated --reporter.tchannel.*/--reporter.grpc.retry.max, expvar
# metrics value (v1 = prometheus|none), and --collector.queue-size-memory.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config-file=[configuration file]:file:_files -g "*.(yml|yaml|json|toml)(-.)"' \
  '--log-level=[minimal allowed log level]:level:(debug info warn error fatal panic)' \
  '--metrics-backend=[metrics backend]:backend:(prometheus none)' \
  '--admin.http.host-port=[admin HTTP host:port]:addr:' \
  '--span-storage.type=[span storage backend (deprecated)]:type:(cassandra elasticsearch memory badger grpc)' \
  '--collector.grpc-server.host-port=[collector gRPC host:port]:addr:' \
  '--collector.http-server.host-port=[collector HTTP host:port]:addr:' \
  '--collector.zipkin.host-port=[Zipkin collector host:port]:addr:' \
  '--collector.queue-size=[collector queue size]:n:' \
  '--collector.num-workers=[collector workers]:n:' \
  '--collector.grpc.tls.enabled=[enable collector gRPC TLS]:b:(true false)' \
  '--collector.grpc.tls.cert=[collector gRPC TLS cert]:file:_files' \
  '--collector.grpc.tls.key=[collector gRPC TLS key]:file:_files' \
  '--collector.grpc.tls.client-ca=[collector gRPC client CA]:file:_files' \
  '--query.http-server.host-port=[query HTTP host:port]:addr:' \
  '--query.grpc-server.host-port=[query gRPC host:port]:addr:' \
  '--query.base-path=[query UI base path]:path:' \
  '--query.static-files=[query static UI files dir]:dir:_files -/' \
  '--query.ui-config=[query UI config file]:file:_files' \
  '--reporter.grpc.host-port=[agent: collector gRPC host:port]:addr:' \
  '--processor.jaeger-compact.server-host-port=[agent compact Thrift host:port]:addr:' \
  '--processor.jaeger-binary.server-host-port=[agent binary Thrift host:port]:addr:' \
  '--processor.zipkin-compact.server-host-port=[agent Zipkin Thrift host:port]:addr:' \
  '--es.server-urls=[Elasticsearch server URLs]:urls:' \
  '--es.username=[Elasticsearch username]:user:' \
  '--es.password=[Elasticsearch password]:pass:' \
  '--es.index-prefix=[Elasticsearch index prefix]:prefix:' \
  '--cassandra.servers=[Cassandra servers]:list:' \
  '--cassandra.keyspace=[Cassandra keyspace]:keyspace:' \
  '--cassandra.username=[Cassandra username]:user:' \
  '--cassandra.password=[Cassandra password]:pass:' \
  '--kafka.producer.brokers=[Kafka producer brokers]:list:' \
  '--kafka.consumer.brokers=[Kafka consumer brokers]:list:' \
  '--kafka.producer.topic=[Kafka producer topic]:topic:' \
  '--kafka.consumer.topic=[Kafka consumer topic]:topic:' \
  '*: :_files' && ret=0
return ret
