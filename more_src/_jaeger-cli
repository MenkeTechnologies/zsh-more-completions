#compdef jaeger-collector jaeger-query jaeger-agent jaeger-ingester jaeger-all-in-one
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*--config-file=[config file]:file:_files -g "*.yml *.yaml"' \
  '*--admin.http.host-port=[admin HTTP listen]:addr:' \
  '*--collector.grpc-server.host-port=[collector gRPC listen]:addr:' \
  '*--collector.grpc.tls.enabled=[gRPC TLS]:b:(true false)' \
  '*--collector.grpc.tls.cert=[TLS cert]:file:_files' \
  '*--collector.grpc.tls.key=[TLS key]:file:_files' \
  '*--collector.grpc.tls.client-ca=[client CA]:file:_files' \
  '*--collector.http-server.host-port=[collector HTTP listen]:addr:' \
  '*--collector.queue-size=[queue size]:n:' \
  '*--collector.queue-size-memory=[queue memory MB]:mb:' \
  '*--collector.num-workers=[workers]:n:' \
  '*--collector.tags=[tags]:tags:' \
  '*--query.host-port=[query HTTP listen]:addr:' \
  '*--query.grpc-server.host-port=[query gRPC]:addr:' \
  '*--query.base-path=[base path]:path:' \
  '*--query.static-files=[static files dir]:dir:_files -/' \
  '*--query.ui-config=[UI config file]:file:_files' \
  '*--reporter.grpc.host-port=[gRPC reporter]:addr:' \
  '*--reporter.grpc.retry.max=[grpc retry]:n:' \
  '*--reporter.tchannel.host-port=[tchannel reporter]:addr:' \
  '*--processor.zipkin-compact.server-host-port=[zipkin compact]:addr:' \
  '*--processor.jaeger-compact.server-host-port=[jaeger compact]:addr:' \
  '*--processor.jaeger-binary.server-host-port=[jaeger binary]:addr:' \
  '*--span-storage.type=[storage type]:t:(memory cassandra elasticsearch kafka grpc-plugin badger blackhole)' \
  '*--cassandra.servers=[cassandra servers csv]:list:' \
  '*--cassandra.keyspace=[cassandra keyspace]:k:' \
  '*--cassandra.username=[cassandra user]:user:' \
  '*--cassandra.password=[cassandra pass]:pass:' \
  '*--es.server-urls=[ES servers csv]:list:' \
  '*--es.username=[ES user]:user:_users' \
  '*--es.password=[ES pass]:pass:' \
  '*--es.index-prefix=[ES index prefix]:p:' \
  '*--kafka.producer.brokers=[kafka brokers]:list:' \
  '*--kafka.consumer.brokers=[kafka brokers]:list:' \
  '*--kafka.consumer.topic=[kafka topic]:topic:' \
  '*--kafka.producer.topic=[kafka topic]:topic:' \
  '*--log-level=[log level]:l:(debug info warn error fatal panic)' \
  '*--metrics-backend=[metrics backend]:b:(prometheus expvar none)' \
  '*--metrics-http-route=[metrics HTTP route]:p:' \
  '*--health-check-http-port=[health check port]:n:' \
  '*: :_files' && ret=0

return ret
