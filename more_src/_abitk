#compdef abitk
# Documentation: https://docs.abinit.org/guide/abitk/
# abitk - ABINIT Tool Kit for inspecting netcdf output files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--version[show version number and exit]' \
  '--prtvol=-[verbosity level]:level:' \
  '--enforce-fortran-io[use Fortran-IO instead of MPI-IO]' \
  '--abimem-level=-[set memory profiling level]:level:(0 1 2 3 4)' \
  '--abimem-limit-mb=-[log malloc/free only above limit in MB]:mb:' \
  '--kptopt=-[k-point generation option]:n:' \
  '--ngkpt=-[Monkhorst-Pack grid divisions]:n:' \
  '--kptrlatt=-[k-point lattice]:vals:' \
  '--shiftk=-[k-point shifts]:vals:' \
  '--chksymbreak=-[check symmetry breaking]:n:(0 1)' \
  '--intmeth=-[integration method]:n:' \
  '--ltetra=-[tetrahedron variant]:n:' \
  '--step=-[energy step]:val:' \
  '--broad=-[broadening]:val:' \
  '--extrael=-[extra electrons]:val:' \
  '--doping=-[doping level]:val:' \
  '--spinmagntarget=-[target spin magnetization]:val:' \
  '--tmesh=-[temperature mesh (start step num)]:vals:' \
  '--is-metal[treat system as metal]' \
  '--ndivsm=-[number of divisions for smallest segment]:n:' \
  '--prtebands=-[print band structure format]:n:' \
  '--ptgroup=-[point group]:str:' \
  '--ngqpt=-[q-point grid divisions]:n:' \
  '--use-symmetries=-[use symmetries]:bool:(0 1)' \
  '--lpratio=-[Lebedev-Petersen ratio]:val:' \
  '--rcut=-[cutoff radius]:val:' \
  '--rsigma=-[sigma radius]:val:' \
  '1:command:(from_poscar hdr_print ibz crystal_print crystal_abivars ebands_print ebands_xmgrace ebands_gnuplot ebands_gaps ebands_edos ebands_jdos ebands_bxsf ebands_mu_T skw_kpath skw_compare find_ewin tetra_unit_tests tetra_zinv_convergence kptrank_unit_tests)' \
  '*:file:_files' && ret=0

return ret
