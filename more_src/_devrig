_devrig_commands() {
    local commands; commands=(
'start:Start all services' \
'stop:Stop all services' \
'delete:Stop and remove all resources' \
'ps:Show service status' \
'init:Generate a starter devrig.toml' \
'doctor:Check that dependencies are installed' \
'env:Show resolved environment variables for a service' \
'exec:Execute a command in a docker container' \
'reset:Reset init-completed flag for a docker service' \
'validate:Validate the configuration file' \
'logs:Show and filter service logs' \
'completions:Generate shell completions' \
'cluster:Manage the k3d cluster' \
'kubectl:Proxy to kubectl with devrig'\''s isolated kubeconfig' \
'query:Query telemetry data from the OTel collector' \
'update:Update devrig to the latest version' \
'skill:Manage the devrig Claude Code skill' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'devrig commands' commands "$@"
}
