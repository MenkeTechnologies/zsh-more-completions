#compdef cellranger
# Documentation: https://www.10xgenomics.com/support/software/cell-ranger/latest/resources/cr-command-line-arguments
# Reference accessed: 2026-05-27
# Verified: upstream 10x Genomics Cell Ranger command-line argument reference.

# cellranger - 10x Genomics single-cell sequencing analysis pipeline

local curcontext="$curcontext" state line ret=1

local -a _cr_subcommands
_cr_subcommands=(
  'count:gene expression / Feature Barcode / fixed RNA profiling on a single library'
  'multi:run analysis on multiplexed (or combined GEX+VDJ) libraries'
  'multi-template:emit a multi config template'
  'vdj:single-cell V(D)J immune profiling'
  'aggr:aggregate multiple count/multi/vdj runs'
  'annotate:cell-type annotation on a count/multi run'
  'reanalyze:rerun secondary analysis on an existing matrix'
  'mkref:build a custom reference genome'
  'mkvdjref:build a custom VDJ reference'
  'mkgtf:filter a GTF gene annotation file'
  'mkfastq:demultiplex Illumina BCL data into FASTQ files'
  'testrun:end-to-end pipeline sanity test'
  'sitecheck:run system diagnostics for installation'
  'upload:upload pipeline output to 10x cloud'
  'cloud:txg cloud helpers (login/list/upload)'
  'telemetry:opt-in usage telemetry controls'
  'mat2csv:export feature-barcode matrix to CSV'
)

# Common martian-pipeline runtime flags shared by count/multi/vdj/aggr/...
_cr_common_runtime() {
  _arguments -s -S \
    '--id=[unique pipeline run id]:id:' \
    '--description=[free-form run description]:text:' \
    '--dry[show what would be run without executing]' \
    '--jobmode=[martian job manager]:mode:(local sge lsf slurm pbs torque)' \
    '--localcores=[max CPU cores in local mode]:n:' \
    '--localmem=[max GB RAM in local mode]:gb:' \
    '--localvmem=[max GB virtual mem in local mode]:gb:' \
    '--mempercore=[GB RAM per allocated core in cluster mode]:gb:' \
    '--maxjobs=[max concurrent jobs in cluster mode]:n:' \
    '--jobinterval=[ms between cluster job submissions]:ms:' \
    '--overrides=[per-stage runtime overrides]:file:_files -g "*.json"' \
    '--output-dir=[output directory]:dir:_directories' \
    '--uiport=[port for pipeline web UI]:port:' \
    '--disable-ui[disable pipeline web UI]' \
    '--noexit[keep UI running after pipeline completion]' \
    '--nopreflight[skip preflight checks]' \
    '(-h --help)'{-h,--help}'[show help]' && ret=0
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'cellranger subcommand' _cr_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      count)
        _cr_common_runtime
        _arguments \
          '--transcriptome=[reference transcriptome path]:dir:_directories' \
          '--fastqs=[FASTQ directory (comma-separated)]:dir:_directories' \
          '--project=[project name (FASTQ subdirectory)]:name:' \
          '--sample=[sample prefix (comma-separated)]:names:' \
          '--lanes=[comma-separated lanes to use]:lanes:' \
          '--libraries=[libraries CSV path]:file:_files -g "*.csv"' \
          '--feature-ref=[Feature Reference CSV path]:file:_files -g "*.csv"' \
          '--expect-cells=[expected number of recovered cells]:n:' \
          '--force-cells=[force pipeline to use this many cells]:n:' \
          '--create-bam=[emit BAM output]:bool:(true false)' \
          '--nosecondary[skip secondary analysis (clustering, t-SNE, etc.)]' \
          '--r1-length=[hard-trim R1 length]:n:' \
          '--r2-length=[hard-trim R2 length]:n:' \
          '--include-introns=[count intronic reads]:bool:(true false)' \
          '--chemistry=[assay chemistry]:chem:(auto threeprime fiveprime SC3Pv1 SC3Pv2 SC3Pv3 SC3Pv4 SC3Pv5 SC5P-PE SC5P-R2 SC-FB ARC-v1)' \
          '--no-libraries[ignore --libraries CSV]' \
          '--check-library-compatibility=[check library compatibility]:bool:(true false)' \
          '--tenx-cloud-token-path=[path to 10x Cloud token]:file:_files' \
          '--cell-annotation-model=[cell-type annotation model name]:model:' \
          '--min-crispr-umi=[minimum CRISPR UMI threshold]:n:' && ret=0
        ;;
      multi|multi-template)
        _cr_common_runtime
        _arguments \
          '--csv=[multi config CSV path]:file:_files -g "*.csv"' \
          '(-o --output)'{-o+,--output=}'[output path]:file:_files' \
          '(-p --parameters)'{-p+,--parameters=}'[parameter set]:set:' && ret=0
        ;;
      vdj)
        _cr_common_runtime
        _arguments \
          '--reference=[VDJ reference path]:dir:_directories' \
          '--fastqs=[FASTQ directory (comma-separated)]:dir:_directories' \
          '--project=[project name (FASTQ subdirectory)]:name:' \
          '--sample=[sample prefix (comma-separated)]:names:' \
          '--lanes=[comma-separated lanes to use]:lanes:' \
          '--denovo[de novo assembly without reference]' \
          '--chain=[VDJ chain type]:chain:(auto TR IG)' \
          '--inner-enrichment-primers=[custom enrichment primers FASTA]:file:_files' && ret=0
        ;;
      aggr)
        _cr_common_runtime
        _arguments \
          '--csv=[aggregation CSV path]:file:_files -g "*.csv"' \
          '--normalize=[normalization mode]:mode:(mapped none)' \
          '--nosecondary[skip secondary analysis]' \
          '--min-crispr-umi=[minimum CRISPR UMI threshold]:n:' \
          '--enable-tsne[enable t-SNE projection]' && ret=0
        ;;
      annotate)
        _cr_common_runtime
        _arguments \
          '--tenx-cloud-token-path=[path to 10x Cloud token]:file:_files' \
          '--cell-annotation-model=[cell-type annotation model name]:model:' \
          '--cloupe=[input .cloupe file]:file:_files -g "*.cloupe"' \
          '--cloupe-group-name=[grouping for cloupe annotation]:name:' \
          '--matrix=[input matrix file]:file:_files' && ret=0
        ;;
      reanalyze)
        _cr_common_runtime
        _arguments \
          '--matrix=[filtered feature-barcode matrix HDF5]:file:_files -g "*.h5"' \
          '--params=[parameters CSV]:file:_files -g "*.csv"' \
          '--barcodes=[barcodes CSV to keep]:file:_files -g "*.csv"' \
          '--genes=[genes CSV to keep]:file:_files -g "*.csv"' \
          '--exclude-genes=[genes CSV to exclude]:file:_files -g "*.csv"' \
          '--agg=[aggregation CSV]:file:_files -g "*.csv"' \
          '--force-cells=[force pipeline to use this many cells]:n:' && ret=0
        ;;
      mkref)
        _cr_common_runtime
        _arguments \
          '--genome=[genome name]:name:' \
          '--fasta=[reference FASTA path]:file:_files -g "*.{fa,fasta,fa.gz,fasta.gz}"' \
          '--genes=[gene annotation GTF path]:file:_files -g "*.{gtf,gtf.gz}"' \
          '--nthreads=[parallel threads]:n:' \
          '--memgb=[memory budget in GB]:gb:' \
          '--ref-version=[reference version string]:version:' && ret=0
        ;;
      mkvdjref)
        _cr_common_runtime
        _arguments \
          '--genome=[genome name]:name:' \
          '--fasta=[reference FASTA path]:file:_files' \
          '--genes=[gene annotation GTF path]:file:_files' \
          '--seqs=[VDJ FASTA path]:file:_files' \
          '--rm-transcripts=[transcripts to drop]:file:_files' \
          '--memgb=[memory budget in GB]:gb:' \
          '--ref-version=[reference version string]:version:' && ret=0
        ;;
      mkgtf)
        _arguments \
          '*--attribute=[attribute filter (key:value, repeatable)]:filter:' \
          '(- *)'{-h,--help}'[show help]' \
          '(- *)--version[show version]' \
          '1:input_gtf:_files -g "*.{gtf,gtf.gz}"' \
          '2:output_gtf:_files' && ret=0
        ;;
      mkfastq)
        _cr_common_runtime
        _arguments \
          '--run=[Illumina BCL run path]:dir:_directories' \
          '--samplesheet=[Illumina samplesheet CSV]:file:_files -g "*.csv"' \
          '--csv=[10x simple samplesheet CSV]:file:_files -g "*.csv"' \
          '--lanes=[comma-separated lanes to demux]:lanes:' \
          '--use-bases-mask=[bcl2fastq base mask]:mask:' \
          '--delete-undetermined[delete undetermined FASTQs]' \
          '--qc[run BCL QC]' && ret=0
        ;;
      testrun)
        _cr_common_runtime
        ;;
      cloud)
        _arguments \
          '--access-token=[10x Cloud access token]:token:' \
          '(-y --assumeyes)'{-y,--assumeyes}'[assume yes for prompts]' \
          '*'{-H,--header=}'[HTTP header]:header:' \
          '(-q --quiet)'{-q,--quiet}'[suppress non-essential output]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(- *)'{-h,--help}'[show help]' \
          '--version[show version]' && ret=0
        ;;
      telemetry)
        local -a _telem
        _telem=(collect check disable enable list show)
        _describe -t commands 'telemetry subcommand' _telem && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
