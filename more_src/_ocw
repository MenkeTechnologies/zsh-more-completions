}

bridge_runtime_dir() {
  local configured="${OCW_BRIDGE_RUNTIME_DIR:-}"
  local project_dir

  if [[ -n "$configured" ]]; then
    printf '%s\n' "$configured"
    return
  fi

  project_dir="$(bridge_project_dir)"
  if [[ -f "$project_dir/bridge.py" ]]; then
    printf '%s\n' "$project_dir"
  else
    bridge_vendor_dir
  fi
}

bridge_default_key() {
  local stored=""

  if [[ -z "${OCW_BRIDGE_KEY:-${PROXY_API_KEY:-${LITELLM_MASTER_KEY:-}}}" ]]; then
    stored="$(bridge_proxy_key_read 2>/dev/null || true)"
  fi
  printf '%s\n' "${OCW_BRIDGE_KEY:-${PROXY_API_KEY:-${LITELLM_MASTER_KEY:-${stored:-sk-local-codex-bridge}}}}"
}

bridge_loopback_host_ok() {
  local host="$1"
  case "$host" in
    127.*|localhost|::1) return 0 ;;
    *) return 1 ;;
  esac
}

bridge_url_host() {
  local host="$1"

  case "$host" in
    *:*) printf '[%s]\n' "$host" ;;
    *) printf '%s\n' "$host" ;;
  esac
}

bridge_validate_port() {
  local port="$1"

  [[ "$port" =~ ^[0-9]+$ ]] || die "invalid bridge port: $port (must be 1-65535)"
  (( 10#$port >= 1 && 10#$port <= 65535 )) || die "invalid bridge port: $port (must be 1-65535)"
}

bridge_load_env_file() {
  local env_file="$1"
  local line key value

  [[ -f "$env_file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="$(trim "$line")"
    [[ -z "$line" || "$line" == \#* ]] && continue
    case "$line" in
      export\ *) line="${line#export }" ;;
    esac
    [[ "$line" == *=* ]] || die "invalid bridge env line in $env_file: $line"
    key="$(trim "${line%%=*}")"
    value="$(unquote "$(trim "${line#*=}")")"
    [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || die "invalid bridge env key in $env_file: $key"
    case "$key" in
      OPENCODE_GO_API_KEY|OCW_BRIDGE_KEY|PROXY_API_KEY|LITELLM_MASTER_KEY|UPSTREAM_BASE|UPSTREAM_TIMEOUT_SECONDS|UPSTREAM_RETRIES|MODEL_MAP_JSON|FALLBACK_MODEL_MAP_JSON|PROXY_STATE_DB|PROXY_STATE_TTL_SECONDS|PROXY_STATE_MAX_RESPONSES|PROXY_LOG_PATH|FORCE_SINGLE_TOOL_INSTRUCTIONS|STRIP_TOOLS|SSE_CHUNK_SIZE|SSE_UPSTREAM_HEARTBEAT_SECONDS|EXPOSE_EMPTY_REASONING_ITEM)
        export "$key=$value"
        ;;
      *)
        die "unsupported bridge env key in $env_file: $key"
        ;;
    esac
  done < "$env_file"
}

bridge_expand_user_path() {
  local path="$1"

  case "$path" in
    \~)
      printf '%s\n' "$HOME"
      ;;
    \~/*)
      printf '%s/%s\n' "$HOME" "${path#\~/}"
      ;;
    *)
      printf '%s\n' "$path"
      ;;
  esac
}

bridge_global_config_dir() {
