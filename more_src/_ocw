}

bridge_service_stderr_log() {
  bridge_expand_user_path "${OCW_BRIDGE_STDERR_LOG:-$(bridge_global_log_dir)/bridge.err.log}"
}

bridge_install_global_runtime() {
  local force="$1"
  local quiet="${2:-0}"
  local source_dir target_dir runner

  source_dir="$(bridge_vendor_dir)"
  target_dir="$(bridge_global_runtime_dir)"
  runner="$(bridge_service_runner_path)"
  [[ -f "$source_dir/bridge.py" ]] || die "bridge runtime not found: $source_dir"
  mkdir -p "$target_dir"
  if [[ "$force" -eq 1 || ! -f "$target_dir/bridge.py" ]]; then
    cp -R "$source_dir/." "$target_dir/"
    [[ "$quiet" -eq 1 ]] || printf 'Installed global bridge runtime: %s\n' "$target_dir"
  else
    cp -R "$source_dir/." "$target_dir/"
    [[ "$quiet" -eq 1 ]] || printf 'Refreshed global bridge runtime: %s\n' "$target_dir"
  fi
  chmod +x "$target_dir/bridge.py" "$target_dir/bin/start-proxy" "$target_dir/bin/oss-scout" "$target_dir/bin/oss-review" "$target_dir/bin/oss-docs" "$target_dir/bin/oss-patch" 2>/dev/null || true
  mkdir -p "$(dirname "$runner")"
  cp "$(bridge_self_abs)" "$runner"
  chmod +x "$runner"
  [[ "$quiet" -eq 1 ]] || printf 'Installed bridge service runner: %s\n' "$runner"
}

bridge_write_posix_service_launcher() {
  local launcher="$1"
  local host="$2"
  local port="$3"
  local runtime_dir="$4"
  local ocw_abs

  ocw_abs="$(bridge_service_runner_path)"
  mkdir -p "$(dirname "$launcher")"
  {
    printf '#!/usr/bin/env sh\n'
    printf 'exec %s bridge run-service --host %s --port %s --runtime-dir %s\n' \
      "$(shell_single_quote "$ocw_abs")" \
      "$(shell_single_quote "$host")" \
      "$(shell_single_quote "$port")" \
      "$(shell_single_quote "$runtime_dir")"
  } > "$launcher"
  chmod +x "$launcher"
}

bridge_to_windows_path() {
  local path="$1"

  if have_command cygpath; then
    cygpath -w "$path"
  else
    printf '%s\n' "$path"
  fi
}

bridge_write_windows_service_launcher() {
  local launcher="$1"
  local host="$2"
  local port="$3"
  local runtime_dir="$4"
  local ocw_abs bash_exe="bash.exe"

  ocw_abs="$(bridge_service_runner_path)"
  if have_command bash && have_command cygpath; then
    bash_exe="$(bridge_to_windows_path "$(command -v bash)")"
  fi
  mkdir -p "$(dirname "$launcher")"
  {
    printf '@echo off\r\n'
    printf '"%s" -lc "exec %s bridge run-service --host %s --port %s --runtime-dir %s"\r\n' \
      "$bash_exe" \
      "$(shell_single_quote "$ocw_abs")" \
      "$(shell_single_quote "$host")" \
      "$(shell_single_quote "$port")" \
      "$(shell_single_quote "$runtime_dir")"
  } > "$launcher"
}

bridge_write_launchd_plist() {
