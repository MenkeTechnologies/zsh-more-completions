known_commands() {
  printf '%s\n' "cheap explore scan review patch init uninstall config keys last show manifest audit apply clean delegate verdict savings backend stats serve doctor quickstart setup bridge models route tournament hooks memory dashboard copilot agent-pack agents bench batch eval pr report policy gh-extension homebrew security support trace explain mcp-config completions mcp help version"
}

suggest_command_name() {
  local input="$1"
  awk -v input="$input" -v commands="$(known_commands)" '
    function min(a, b, c) {
      m = a
      if (b < m) m = b
      if (c < m) m = c
      return m
    }
    function lev(a, b, i, j, cost, la, lb) {
      la = length(a)
      lb = length(b)
      for (i = 0; i <= la; i++) d[i,0] = i
      for (j = 0; j <= lb; j++) d[0,j] = j
      for (i = 1; i <= la; i++) {
        for (j = 1; j <= lb; j++) {
          cost = (substr(a, i, 1) == substr(b, j, 1)) ? 0 : 1
          d[i,j] = min(d[i-1,j] + 1, d[i,j-1] + 1, d[i-1,j-1] + cost)
        }
      }
      return d[la,lb]
    }
    BEGIN {
      split(commands, list, " ")
      best = 999
      bestcmd = ""
      for (i in list) {
        score = lev(input, list[i])
        if (score < best) {
          best = score
          bestcmd = list[i]
        }
      }
      if (best <= 3) print bestcmd
    }
  '
}

unknown_command() {
  local command="$1"
  local suggestion

  suggestion="$(suggest_command_name "$command")"
  printf 'ocw: unknown command: %s\n' "$command" >&2
  if [[ -n "$suggestion" ]]; then
    printf 'Did you mean: ocw %s\n' "$suggestion" >&2
  fi
  printf "Run \`ocw help\` for available commands.\n" >&2
  exit 2
}

help_command() {
  local topic="${1:-}"

  if [[ -z "$topic" ]]; then
    usage
    return
  fi

  case "$topic" in
    cheap|explore|scan|review|patch)
      usage
      ;;
    help)
      printf 'Usage: ocw help [command]\n'
      ;;
    version)
      printf 'Usage: ocw version\n'
      ;;
    init|uninstall|config|keys|last|show|manifest|audit|apply|clean|delegate|verdict|savings|backend|stats|serve|doctor|quickstart|setup|bridge|models|route|tournament|hooks|memory|dashboard|copilot|agent-pack|agents|bench|batch|eval|pr|report|policy|gh-extension|homebrew|security|support|trace|explain|mcp-config|completions|mcp)
      "$OCW_SELF" "$topic" --help
      ;;
    *)
      unknown_command "$topic"
      ;;
  esac
}

die() {
  printf 'ocw: %s\n' "$*" >&2
  exit 2
}

die_code() {
  local code="$1"
  shift
  printf 'ocw: [%s] %s\n' "$code" "$*" >&2
  exit 2
}

have_command() {
  command -v "$1" >/dev/null 2>&1
}

require_command() {
  have_command "$1" || die "required command not found: $1"
}

require_command_code() {
  local command_name="$1"
  local error_code="$2"
  have_command "$command_name" || die_code "$error_code" "required command not found: $command_name"
}

trim() {
  printf '%s' "$1" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

csv_to_lines() {
  local input="$1"
  local item

  while [[ "$input" == *,* ]]; do
    item="${input%%,*}"
    item="$(trim "$item")"
    [[ -n "$item" ]] && printf '%s\n' "$item"
    input="${input#*,}"
  done

  item="$(trim "$input")"
  [[ -n "$item" ]] && printf '%s\n' "$item"
}

safe_name() {
  printf '%s' "$1" | sed 's/[^A-Za-z0-9_.-]/-/g'
}

opencode_config_home() {
  if [[ -n "${OPENCODE_CONFIG_HOME:-}" ]]; then
    printf '%s\n' "$OPENCODE_CONFIG_HOME"
  else
    printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}/opencode"
  fi
}

unquote() {
  local value="$1"
  if [[ "$value" == \"*\" && "$value" == *\" ]]; then
    value="${value#\"}"
    value="${value%\"}"
  elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
    value="${value#\'}"
    value="${value%\'}"
  fi
  printf '%s\n' "$value"
}

normalize_bool() {
  local key="$1"
  local value
  value="$(printf '%s' "$2" | tr '[:upper:]' '[:lower:]')"

  case "$value" in
    1|true|yes|on)
      printf '1\n'
      ;;
    0|false|no|off)
      printf '0\n'
      ;;
    *)
      die "invalid boolean for $key: $2"
      ;;
  esac
}

git_is_repo() {
  "$GIT_BIN" -C "$1" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

git_root() {
  "$GIT_BIN" -C "$1" rev-parse --show-toplevel 2>/dev/null || true
}

git_is_clean() {
  [[ -z "$("$GIT_BIN" -C "$1" status --porcelain --untracked-files=normal)" ]]
}

git_is_clean_for_apply() {
  local dir="$1"
  local output_root="$2"
  local repo_root output_abs output_rel status line path

  status="$("$GIT_BIN" -C "$dir" status --porcelain --untracked-files=normal)"
  [[ -n "$status" ]] || return 0

  repo_root="$(abs_existing_dir "$(git_root "$dir")")"
  output_abs="$(abs_existing_dir "$output_root")"
  output_rel=""
  if [[ "$output_abs" == "$repo_root/"* ]]; then
    output_rel="${output_abs#"$repo_root"/}"
  fi

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    path="${line:3}"
    case "$path" in
      .codex|.codex/|.codex/*)
        continue
        ;;
    esac
    if [[ -n "$output_rel" ]]; then
      case "$path" in
        "$output_rel"|"$output_rel"/|"$output_rel"/*)
          continue
          ;;
      esac
    fi
    return 1
  done <<EOF
$status
EOF

  return 0
}

set_config_value() {
  local section="$1"
  local key="$2"
  local value="$3"

  case "$section:$key" in
    models:cheap) OCW_CONFIG_CHEAP_MODEL="$value" ;;
    models:explore) OCW_CONFIG_EXPLORE_MODEL="$value" ;;
    models:review) OCW_CONFIG_REVIEW_MODEL="$value" ;;
    models:patch) OCW_CONFIG_PATCH_MODEL="$value" ;;
    models:scan) OCW_CONFIG_SCAN_MODEL="$value" ;;
    agents:cheap) OCW_CONFIG_CHEAP_AGENT="$value" ;;
    agents:explore) OCW_CONFIG_EXPLORE_AGENT="$value" ;;
    agents:review) OCW_CONFIG_REVIEW_AGENT="$value" ;;
    agents:patch) OCW_CONFIG_PATCH_AGENT="$value" ;;
    agents:scan) OCW_CONFIG_SCAN_AGENT="$value" ;;
    defaults:output_root) OCW_CONFIG_OUTPUT_ROOT="$value" ;;
    defaults:variant) OCW_CONFIG_VARIANT="$value" ;;
    defaults:attach) OCW_CONFIG_ATTACH="$value" ;;
    defaults:worktree) OCW_CONFIG_WORKTREE="$(normalize_bool "$key" "$value")" ;;
    defaults:rm_worktree) OCW_CONFIG_RM_WORKTREE="$(normalize_bool "$key" "$value")" ;;
    defaults:require_clean) OCW_CONFIG_REQUIRE_CLEAN="$(normalize_bool "$key" "$value")" ;;
    defaults:auto_approve) OCW_CONFIG_AUTO_APPROVE="$(normalize_bool "$key" "$value")" ;;
    auth:key_env|auth:env) OCW_CONFIG_API_KEY_ENV="$value" ;;
    auth:keys_file) OCW_CONFIG_KEYS_FILE="$value" ;;
    auth:auto_rotate|auth:rotate_on_failure) OCW_CONFIG_KEY_ROTATION="$(normalize_bool "$key" "$value")" ;;
    *)
      ;;
  esac
}

find_config_file() {
  local root

  if [[ -n "${OCW_CONFIG:-}" ]]; then
    [[ -f "$OCW_CONFIG" ]] || die "config file not found: $OCW_CONFIG"
    printf '%s\n' "$OCW_CONFIG"
    return
  fi

  if have_command "$GIT_BIN"; then
    root="$(git_root "$PWD")"
    if [[ -n "$root" && -f "$root/.ocw.toml" ]]; then
      printf '%s\n' "$root/.ocw.toml"
      return
    fi
  fi

  if [[ -f ".ocw.toml" ]]; then
    printf '%s\n' ".ocw.toml"
  fi

  return 0
}

load_config() {
  local config_file section line key value

  config_file="$(find_config_file || true)"
  if [[ -z "$config_file" ]]; then
    return 0
  fi
  OCW_CONFIG_FILE="$config_file"
  section=""

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="$(trim "$line")"
    [[ -z "$line" ]] && continue

    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      section="${BASH_REMATCH[1]}"
      continue
    fi

    [[ "$line" == *=* ]] || continue
    key="$(trim "${line%%=*}")"
    value="$(trim "${line#*=}")"
    value="$(unquote "$value")"
    set_config_value "$section" "$key" "$value"
  done < "$config_file"
}

prepare_output_root() {
  local root="$1"
  mkdir -p "$root"
  (cd "$root" && pwd -P)
}

abs_existing_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || die "directory not found: $dir"
  (cd "$dir" && pwd -P)
}

allocate_output_dir() {
  local root="$1"
  local mode="$2"
  local stamp="${OCW_TEST_STAMP:-$(date +%Y%m%d-%H%M%S)}"
  local base="$root/$stamp-$mode"
  local dir="$base"
  local counter=0

  while ! mkdir "$dir" 2>/dev/null; do
    counter=$((counter + 1))
    dir="$base-$counter"
  done

  printf '%s\n' "$dir"
}

write_diff_snapshot() {
  local dir="$1"
  local output="$2"

  if git_is_repo "$dir"; then
    "$GIT_BIN" -C "$dir" diff --binary > "$output" || true
  else
    : > "$output"
  fi
}

write_diff_stat() {
  local dir="$1"
  local output="$2"

  if git_is_repo "$dir"; then
    "$GIT_BIN" -C "$dir" diff --stat > "$output" || true
  else
    : > "$output"
  fi
}

write_status_snapshot() {
  local dir="$1"
  local output="$2"

  if git_is_repo "$dir"; then
    "$GIT_BIN" -C "$dir" status --short > "$output" || true
  else
    : > "$output"
  fi
}

extract_summary() {
  local result_jsonl="$1"
  local summary="$2"

  if have_command jq; then
    jq -r '
      if type == "object" then
        .part.text? // .message? // .text? // .content? // .delta? // empty
      else
        empty
      end
    ' "$result_jsonl" > "$summary" 2>/dev/null || cp "$result_jsonl" "$summary"
  else
    cp "$result_jsonl" "$summary"
  fi
}

metadata_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 0
  awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print }' "$file" | tail -n 1
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\t'/\\t}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\n'/\\n}"
  printf '%s' "$value"
}

json_string() {
  printf '"%s"' "$(json_escape "$1")"
}

html_escape() {
  printf '%s' "$1" | sed \
    -e 's/&/\&amp;/g' \
    -e 's/</\&lt;/g' \
    -e 's/>/\&gt;/g' \
    -e 's/"/\&quot;/g' \
    -e "s/'/\&#39;/g"
}

xml_escape() {
  html_escape "$1"
}

file_size_bytes() {
  local file="$1"
  local size

  size="$(stat -f '%z' "$file" 2>/dev/null || true)"
  if [[ "$size" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$size"
    return
  fi

  size="$(stat -c '%s' "$file" 2>/dev/null || true)"
  if [[ "$size" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$size"
    return
  fi

  wc -c < "$file" | tr -d ' '
}

file_sha256() {
  local file="$1"

  if have_command shasum; then
    shasum -a 256 "$file" | awk '{ print $1 }'
  elif have_command sha256sum; then
    sha256sum "$file" | awk '{ print $1 }'
  else
    printf ''
  fi
}

validate_env_name() {
  [[ "$1" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || die "invalid environment variable name: $1"
}

validate_key_name() {
  local name="$1"

  [[ -n "$name" ]] || die "key name is required"
  [[ "$name" != *$'\t'* && "$name" != *$'\n'* && "$name" != *$'\r'* ]] || die "key name cannot contain tabs or newlines"
}

validate_key_value() {
  local value="$1"

  [[ -n "$value" ]] || die "API key is empty"
  [[ "$value" != *$'\t'* && "$value" != *$'\n'* && "$value" != *$'\r'* ]] || die "API key cannot contain tabs or newlines"
}

sanitize_tsv_field() {
  local value="$1"
  value="${value//$'\t'/ }"
  value="${value//$'\r'/ }"
  value="${value//$'\n'/ }"
  printf '%s' "$value"
}

redact_exact_stream() {
  local secret="$1"

  if [[ -z "$secret" ]]; then
    cat
    return
  fi

  awk -v secret="$secret" '
    {
      line = $0
      output = ""
      while ((pos = index(line, secret)) > 0) {
        output = output substr(line, 1, pos - 1) "<redacted>"
        line = substr(line, pos + length(secret))
      }
      print output line
    }
  '
}

auth_key_fingerprint() {
  local key="$1"
  local hash tail

  hash="$(printf '%s' "$key" | file_sha256 /dev/stdin 2>/dev/null || true)"
  if [[ -z "$hash" ]]; then
    hash="$(printf '%s' "$key" | cksum | awk '{ print $1 }')"
  fi
  if [[ ${#key} -gt 4 ]]; then
    tail="${key: -4}"
  else
    tail="$key"
  fi
  printf '%s...%s\n' "${hash:0:12}" "$tail"
}

auth_read_secret() {
  local value

  if [[ -t 0 ]]; then
    printf 'API key: ' >&2
    stty -echo
    IFS= read -r value
    stty echo
    printf '\n' >&2
  else
    IFS= read -r value
  fi
  printf '%s\n' "$value"
}

auth_read_records() {
  local file="${1:-$(auth_keys_file_path)}"

  [[ -f "$file" ]] || return 0
  awk -F '\t' 'NF >= 3 && $1 != "name" { print }' "$file"
}

auth_runtime_key_records() {
  local file env_name item index=0
  local file_env name key _note _created_at

  env_name="$(auth_key_env_name)"
  validate_env_name "$env_name"

  if [[ -n "${OCW_API_KEYS:-}" ]]; then
    while IFS= read -r item; do
      [[ -n "$item" ]] || continue
      index=$((index + 1))
      printf 'env-%s\t%s\t%s\tenv\n' "$index" "$env_name" "$item"
    done <<EOF
$(csv_to_lines "$OCW_API_KEYS")
EOF
  fi

  file="$(auth_keys_file_path)"
  while IFS=$'\t' read -r name file_env key _note _created_at; do
    [[ -n "$name" && -n "$key" ]] || continue
    [[ -n "$file_env" ]] || file_env="$env_name"
    validate_env_name "$file_env"
    printf '%s\t%s\t%s\tfile\n' "$name" "$file_env" "$key"
  done <<EOF
$(auth_read_records "$file")
EOF
}

auth_failure_detected() {
  local status="$1"
  local stdout_file="$2"
  local stderr_file="$3"
  local pattern

  [[ "$status" -ne 0 ]] || return 1
  pattern='(auth|unauthori[sz]ed|forbidden|invalid[ _-]?(api[ _-]?)?key|api[ _-]?key|quota|balance|billing|credit|usage limit|rate limit|rate_limit|insufficient|payment required|402|429)'
  grep -Eiq "$pattern" "$stdout_file" "$stderr_file" 2>/dev/null
}

opencode_run_with_key_rotation() {
  local workdir="$1"
  local out_dir="$2"
  local result_file="$3"
  shift 3
  local records record_count rotate=0 attempt=0 status=0 final_status=0
  local key_name key_env key_value key_source fingerprint stdout_file stderr_file attempts_file key_run_file
  local should_rotate=false reason="none"
  local max_attempts="${OCW_KEY_MAX_ATTEMPTS:-0}"
  local default_env default_key=""

  records="$(auth_runtime_key_records)"
  if [[ -z "$records" ]]; then
    default_env="$(auth_key_env_name)"
    validate_env_name "$default_env"
    default_key="${!default_env:-}"
    set +e
    if [[ -n "$default_key" ]]; then
      (
        cd "$workdir" || exit 2
        "$OPENCODE_BIN" "$@"
      ) > >(redact_exact_stream "$default_key" | tee "$result_file") 2> >(redact_exact_stream "$default_key" >&2)
      status=$?
    else
      (
        cd "$workdir" || exit 2
        "$OPENCODE_BIN" "$@"
      ) | tee "$result_file"
      status=${PIPESTATUS[0]}
    fi
    return "$status"
  fi

  if auth_rotation_enabled; then
    rotate=1
  fi
  [[ "$max_attempts" =~ ^[0-9]+$ ]] || die "OCW_KEY_MAX_ATTEMPTS must be a non-negative integer"
  record_count="$(printf '%s\n' "$records" | awk 'NF { count++ } END { print count + 0 }')"
  if [[ "$max_attempts" -gt 0 && "$record_count" -gt "$max_attempts" ]]; then
    record_count="$max_attempts"
  fi

  attempts_file="${result_file%.jsonl}.key-attempts.tsv"
  key_run_file="${result_file%.jsonl}.key-run.txt"
  printf 'attempt\tkey_name\tsource\tenv\tfingerprint\tstatus\trotated\treason\tstdout\tstderr\n' > "$attempts_file"

  while IFS=$'\t' read -r key_name key_env key_value key_source; do
    [[ -n "$key_name" && -n "$key_value" ]] || continue
    attempt=$((attempt + 1))
    if [[ "$max_attempts" -gt 0 && "$attempt" -gt "$max_attempts" ]]; then
      break
    fi

    validate_env_name "$key_env"
    fingerprint="$(auth_key_fingerprint "$key_value")"
    stdout_file="$out_dir/result.attempt-$attempt.jsonl"
    stderr_file="$out_dir/stderr.attempt-$attempt.txt"

    set +e
    (
      cd "$workdir" || exit 2
      env "$key_env=$key_value" "$OPENCODE_BIN" "$@"
    ) > >(redact_exact_stream "$key_value" | tee "$stdout_file") 2> >(redact_exact_stream "$key_value" | tee "$stderr_file" >&2)
    status=$?

    cp "$stdout_file" "$result_file"
    final_status="$status"
    should_rotate=false
    reason="none"
    if [[ "$status" -ne 0 ]] && auth_failure_detected "$status" "$stdout_file" "$stderr_file"; then
      reason="auth_or_quota"
      if [[ "$rotate" -eq 1 && "$attempt" -lt "$record_count" ]]; then
        should_rotate=true
      fi
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$attempt" "$key_name" "$key_source" "$key_env" "$fingerprint" "$status" "$should_rotate" "$reason" "$stdout_file" "$stderr_file" >> "$attempts_file"

    {
      printf 'key_name=%s\n' "$key_name"
      printf 'key_source=%s\n' "$key_source"
      printf 'key_env=%s\n' "$key_env"
      printf 'key_fingerprint=%s\n' "$fingerprint"
      printf 'key_attempts=%s\n' "$attempt"
      printf 'key_rotation=%s\n' "$rotate"
    } > "$key_run_file"

    if [[ "$status" -eq 0 || "$should_rotate" != true ]]; then
      break
    fi
    printf 'ocw: key %s failed with auth/quota signal; trying next key\n' "$key_name" >&2
  done <<EOF
$records
EOF

  return "$final_status"
}

