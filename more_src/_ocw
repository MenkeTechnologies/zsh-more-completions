}

bridge_service_manager() {
  local requested="${1:-${OCW_BRIDGE_SERVICE_MANAGER:-auto}}"
  local platform

  case "$requested" in
    auto)
      platform="$(bridge_platform_id)"
      case "$platform" in
        macos) printf 'launchd\n' ;;
        linux) printf 'systemd\n' ;;
        windows) printf 'windows\n' ;;
        *) die "unsupported platform for OCW bridge service: $(uname -s 2>/dev/null || printf unknown)" ;;
      esac
      ;;
    launchd|systemd|windows)
      printf '%s\n' "$requested"
      ;;
    *)
      die "invalid bridge service manager: $requested (expected auto, launchd, systemd, or windows)"
      ;;
  esac
}

