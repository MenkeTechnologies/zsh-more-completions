Creates a sanitized diagnostic tarball for bug reports. It excludes diffs, JSONL,
and worker summaries unless --include-summary is explicitly provided.
EOF
      return
      ;;
    *)
      die "unknown support command: $subcommand"
      ;;
  esac

  while [[ $# -gt 0 ]]; do
    case "$1" in
