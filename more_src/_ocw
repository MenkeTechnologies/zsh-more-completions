  done

  if have_command "$NODE_BIN"; then
    node_path="$(command -v "$NODE_BIN" 2>/dev/null || printf '%s' "$NODE_BIN")"
    "$NODE_BIN" --check "$server" >/dev/null 2>&1 || status=1
  else
    status=1
  fi

  if [[ "$json" -eq 1 ]]; then
