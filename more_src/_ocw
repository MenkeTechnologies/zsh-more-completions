}

bridge_global_env_file() {
  bridge_expand_user_path "${OCW_BRIDGE_GLOBAL_ENV_FILE:-$(bridge_global_config_dir)/opencode-go.env}"
}

bridge_platform_id() {
  local uname_s

  uname_s="$(uname -s 2>/dev/null || true)"
  case "$uname_s" in
    Darwin) printf 'macos\n' ;;
    Linux) printf 'linux\n' ;;
    MINGW*|MSYS*|CYGWIN*) printf 'windows\n' ;;
    *)
      if [[ "${OS:-}" == "Windows_NT" ]]; then
        printf 'windows\n'
      else
        printf 'unknown\n'
      fi
      ;;
  esac
}

bridge_global_data_dir() {
  local platform

  platform="$(bridge_platform_id)"
  if [[ -n "${OCW_GLOBAL_DATA_DIR:-}" ]]; then
    bridge_expand_user_path "$OCW_GLOBAL_DATA_DIR"
  elif [[ "$platform" == "macos" ]]; then
    printf '%s\n' "$HOME/Library/Application Support/ocw"
  elif [[ "$platform" == "windows" ]]; then
    bridge_expand_user_path "${LOCALAPPDATA:-$HOME/AppData/Local}/ocw"
  else
    bridge_expand_user_path "${XDG_DATA_HOME:-$HOME/.local/share}/ocw"
  fi
}

bridge_global_state_dir() {
