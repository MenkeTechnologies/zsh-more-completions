  if [[ "$fix" -eq 1 ]]; then
    prepare_output_root "${out_base:-$DEFAULT_OUTPUT_ROOT}" >/dev/null
    install_agent_skill "Codex" "$codex_skills_dir" >/dev/null
    install_agent_skill "Claude Code" "$claude_skills_dir" >/dev/null
    install_agent_skill "OpenCode" "$opencode_skills_dir" >/dev/null
    install_agent_skill "Agents" "$agents_skills_dir" >/dev/null
  fi

  printf 'ok\tversion\tocw %s\n' "$VERSION" >> "$check_file"

  if [[ -n "${OCW_CONFIG_FILE:-}" ]]; then
    printf 'ok\tconfig\t%s\n' "$OCW_CONFIG_FILE" >> "$check_file"
  else
    printf 'ok\tconfig\tno project config loaded\n' >> "$check_file"
  fi

  keys_file="$(auth_keys_file_path)"
  key_env="$(auth_key_env_name)"
  key_count="$(auth_read_records "$keys_file" | awk 'NF { count++ } END { print count + 0 }')"
  if [[ -f "$keys_file" ]]; then
    key_perm="$(stat -f '%Lp' "$keys_file" 2>/dev/null || stat -c '%a' "$keys_file" 2>/dev/null || printf unknown)"
    if [[ "$key_perm" == "600" || "$key_perm" == "400" ]]; then
      printf 'ok\tkeys\t%s keys in %s using %s\n' "$key_count" "$keys_file" "$key_env" >> "$check_file"
    else
      printf 'warn\tkeys\t%s should be chmod 600\n' "$keys_file" >> "$check_file"
    fi
  elif [[ -n "${OCW_API_KEYS:-}" ]]; then
    key_count="$(csv_to_lines "$OCW_API_KEYS" | awk 'NF { count++ } END { print count + 0 }')"
    printf 'ok\tkeys\t%s keys from OCW_API_KEYS using %s\n' "$key_count" "$key_env" >> "$check_file"
  else
    printf 'warn\tkeys\tno OCW key registry found; opencode auth storage or existing environment will be used\n' >> "$check_file"
  fi

  if have_command "$OPENCODE_BIN"; then
    opencode_version="$("$OPENCODE_BIN" --version 2>/dev/null || "$OPENCODE_BIN" version 2>/dev/null || true)"
    printf 'ok\topencode\t%s\n' "$(command -v "$OPENCODE_BIN" 2>/dev/null || printf '%s' "$OPENCODE_BIN")" >> "$check_file"
    [[ -n "$opencode_version" ]] && printf 'ok\topencode_version\t%s\n' "$opencode_version" >> "$check_file"
  else
    printf 'fail\topencode\tmissing\n' >> "$check_file"
    health=1
  fi

  if have_command "$GIT_BIN"; then
    printf 'ok\tgit\t%s\n' "$(command -v "$GIT_BIN" 2>/dev/null || printf '%s' "$GIT_BIN")" >> "$check_file"
  else
    printf 'warn\tgit\tmissing\n' >> "$check_file"
  fi

  if have_command jq; then
    printf 'ok\tjq\t%s\n' "$(command -v jq)" >> "$check_file"
  else
    printf 'warn\tjq\tmissing; summaries will fall back to raw JSONL\n' >> "$check_file"
  fi

  if have_command "$OPENCODE_BIN"; then
    if "$OPENCODE_BIN" models opencode-go >/dev/null 2>&1; then
      printf 'ok\topencode_go_models\treachable\n' >> "$check_file"
    else
      printf 'fail\topencode_go_models\tnot reachable\n' >> "$check_file"
      health=1
    fi
  fi

  if [[ "$deep" -eq 1 ]]; then
    output_abs="$(prepare_output_root "${out_base:-$DEFAULT_OUTPUT_ROOT}")"
    if [[ -w "$output_abs" ]]; then
      printf 'ok\toutput_root\t%s\n' "$output_abs" >> "$check_file"
    else
      printf 'fail\toutput_root\tnot writable: %s\n' "$output_abs" >> "$check_file"
      health=1
    fi

    if have_command "$GIT_BIN"; then
      root="$(git_root "$PWD")"
      if [[ -n "$root" ]]; then
        printf 'ok\tgit_root\t%s\n' "$root" >> "$check_file"
        if git_is_clean "$PWD"; then
          printf 'ok\tgit_state\tclean\n' >> "$check_file"
        else
          printf 'warn\tgit_state\tdirty\n' >> "$check_file"
        fi
      else
        printf 'warn\tgit_root\tnone\n' >> "$check_file"
      fi
    fi

    if have_command "$OPENCODE_BIN"; then
      models_file="$(mktemp "${TMPDIR:-/tmp}/ocw-models.XXXXXX")"
      if "$OPENCODE_BIN" models opencode-go > "$models_file" 2>/dev/null; then
        model_count="$(grep -c . "$models_file" || true)"
        printf 'ok\topencode_go_model_count\t%s\n' "$model_count" >> "$check_file"
      else
        printf 'fail\topencode_go_model_list\tfailed\n' >> "$check_file"
        health=1
      fi
    fi
  fi

  if [[ -f "$codex_skills_dir/$SKILL_NAME/SKILL.md" ]]; then
    printf 'ok\tskill_codex\t%s\n' "$codex_skills_dir/$SKILL_NAME/SKILL.md" >> "$check_file"
  else
    printf 'warn\tskill_codex\tnot installed: %s\n' "$codex_skills_dir/$SKILL_NAME/SKILL.md" >> "$check_file"
  fi
  if [[ -f "$claude_skills_dir/$SKILL_NAME/SKILL.md" ]]; then
    printf 'ok\tskill_claude\t%s\n' "$claude_skills_dir/$SKILL_NAME/SKILL.md" >> "$check_file"
  else
    printf 'warn\tskill_claude\tnot installed: %s\n' "$claude_skills_dir/$SKILL_NAME/SKILL.md" >> "$check_file"
  fi
  if [[ -f "$opencode_skills_dir/$SKILL_NAME/SKILL.md" ]]; then
    printf 'ok\tskill_opencode\t%s\n' "$opencode_skills_dir/$SKILL_NAME/SKILL.md" >> "$check_file"
  else
    printf 'warn\tskill_opencode\tnot installed: %s\n' "$opencode_skills_dir/$SKILL_NAME/SKILL.md" >> "$check_file"
  fi
  if [[ -f "$agents_skills_dir/$SKILL_NAME/SKILL.md" ]]; then
    printf 'ok\tskill_agents\t%s\n' "$agents_skills_dir/$SKILL_NAME/SKILL.md" >> "$check_file"
  else
    printf 'warn\tskill_agents\tnot installed: %s\n' "$agents_skills_dir/$SKILL_NAME/SKILL.md" >> "$check_file"
  fi

  overall="ok"
  if awk -F '\t' '$1 == "fail" { found = 1 } END { exit(found ? 0 : 1) }' "$check_file"; then
    overall="fail"
  elif awk -F '\t' '$1 == "warn" { found = 1 } END { exit(found ? 0 : 1) }' "$check_file"; then
    overall="warn"
  fi

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.doctor.v1",\n'
    printf '  "version": '
    json_string "$VERSION"
    printf ',\n'
    printf '  "overall": '
    json_string "$overall"
    printf ',\n'
    printf '  "fixed": %s,\n' "$fix"
    printf '  "checks": [\n'
    first=1
    while IFS=$'\t' read -r severity id message; do
      [[ -n "$severity" ]] || continue
      if [[ "$first" -eq 0 ]]; then
        printf ',\n'
      fi
      printf '    { "severity": '
      json_string "$severity"
      printf ', "id": '
      json_string "$id"
      printf ', "message": '
      json_string "$message"
      printf ' }'
      first=0
    done < "$check_file"
    printf '\n  ]\n'
    printf '}\n'
  else
    printf 'ocw %s\n' "$VERSION"
    if [[ -n "${OCW_CONFIG_FILE:-}" ]]; then
      printf 'config: %s\n' "$OCW_CONFIG_FILE"
    else
      printf 'config: none\n'
    fi
    if have_command "$OPENCODE_BIN"; then
      printf 'opencode: %s\n' "$(command -v "$OPENCODE_BIN" 2>/dev/null || printf '%s' "$OPENCODE_BIN")"
      [[ -n "${opencode_version:-}" ]] && printf 'opencode version: %s\n' "$opencode_version"
    else
      printf 'opencode: missing\n'
    fi
    if have_command "$GIT_BIN"; then
      printf 'git: %s\n' "$(command -v "$GIT_BIN" 2>/dev/null || printf '%s' "$GIT_BIN")"
    else
      printf 'git: missing\n'
    fi
    if have_command jq; then
      printf 'jq: %s\n' "$(command -v jq)"
    else
      printf 'jq: missing; summaries will fall back to raw JSONL\n'
    fi
    if have_command "$OPENCODE_BIN"; then
      if "$OPENCODE_BIN" models opencode-go >/dev/null 2>&1; then
        printf 'opencode-go models: reachable\n'
      else
        printf 'opencode-go models: not reachable\n'
      fi
    fi
    if [[ "$deep" -eq 1 ]]; then
      printf 'output root: %s\n' "$output_abs"
      if have_command "$GIT_BIN"; then
        root="$(git_root "$PWD")"
        if [[ -n "$root" ]]; then
          printf 'git root: %s\n' "$root"
          if git_is_clean "$PWD"; then
            printf 'git state: clean\n'
          else
            printf 'git state: dirty\n'
          fi
        else
          printf 'git root: none\n'
        fi
      fi
      if [[ -n "$models_file" && -f "$models_file" ]]; then
        printf 'opencode-go model count: %s\n' "$model_count"
        while IFS= read -r message; do
          [[ -n "$message" ]] || continue
          printf '  - %s\n' "$message"
        done < "$models_file"
      fi
    fi
    printf 'skill Codex: %s\n' "$codex_skills_dir/$SKILL_NAME/SKILL.md"
    [[ -f "$codex_skills_dir/$SKILL_NAME/SKILL.md" ]] || printf 'skill Codex status: not installed\n'
    printf 'skill Claude Code: %s\n' "$claude_skills_dir/$SKILL_NAME/SKILL.md"
    [[ -f "$claude_skills_dir/$SKILL_NAME/SKILL.md" ]] || printf 'skill Claude Code status: not installed\n'
    printf 'skill OpenCode: %s\n' "$opencode_skills_dir/$SKILL_NAME/SKILL.md"
    [[ -f "$opencode_skills_dir/$SKILL_NAME/SKILL.md" ]] || printf 'skill OpenCode status: not installed\n'
    printf 'skill Agents: %s\n' "$agents_skills_dir/$SKILL_NAME/SKILL.md"
    [[ -f "$agents_skills_dir/$SKILL_NAME/SKILL.md" ]] || printf 'skill Agents status: not installed\n'
    if [[ "$deep" -eq 1 ]]; then
      if [[ "$health" -eq 0 ]]; then
        printf 'doctor deep: ok\n'
      else
        printf 'doctor deep: issues found\n'
      fi
    else
      printf 'doctor: %s\n' "$overall"
    fi
  fi

  rm -f "$check_file"
  [[ -n "$models_file" ]] && rm -f "$models_file"
  return "$health"
}

copy_if_needed() {
  local source="$1"
  local target="$2"
  local label="$3"
  local force="$4"

  [[ -f "$source" ]] || die "template not found: $source"
  mkdir -p "$(dirname "$target")"

  if [[ -e "$target" && "$force" -ne 1 ]]; then
    printf 'Kept existing %s: %s\n' "$label" "$target"
    return
  fi

  cp "$source" "$target"
  printf 'Installed %s: %s\n' "$label" "$target"
}

ensure_gitignore_entry() {
  local gitignore="$1"
  local entry="$2"

  touch "$gitignore"
  if grep -Fxq "$entry" "$gitignore"; then
    return
  fi

  if [[ -s "$gitignore" ]]; then
    printf '\n' >> "$gitignore"
  fi
  printf '%s\n' "$entry" >> "$gitignore"
}

ensure_ocw_gitignore_entries() {
  local gitignore="$1"

  ensure_gitignore_entry "$gitignore" ".codex/opencode-workers/"
  ensure_gitignore_entry "$gitignore" ".codex/opencode-worktrees/"
  ensure_gitignore_entry "$gitignore" ".codex/ocw-keys.tsv"
  ensure_gitignore_entry "$gitignore" ".codex/ocw-bridge/"
  ensure_gitignore_entry "$gitignore" ".codex/ocw-bridge-results/"
  ensure_gitignore_entry "$gitignore" ".codex/ocw-bridge-worktrees/"
}

ensure_sensitive_project_file_ignored() {
  local file="$1"
  local prefix="$PWD/.codex/"
  local suffix

  if [[ "$file" == .codex/* ]]; then
    ensure_gitignore_entry ".gitignore" "$file"
  elif [[ "$file" == "$prefix"* ]]; then
    suffix="${file:${#prefix}}"
    ensure_gitignore_entry ".gitignore" ".codex/$suffix"
  fi
}

