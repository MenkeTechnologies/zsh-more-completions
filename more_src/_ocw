route_file_record() {
  local mode="$1"
  local route_file="${2:-$(routes_file_path)}"

  [[ -f "$route_file" ]] || return 0
  awk -F '\t' -v mode="$mode" '$1 == mode { model = $2; reason = $3 } END { if (model != "") print model "\t" reason }' "$route_file"
}

route_file_model() {
  route_file_record "$1" | awk -F '\t' '{ print $1 }'
}

route_file_reason() {
  route_file_record "$1" | awk -F '\t' '{ print $2 }'
}

route_effective_model() {
  local mode="$1"
  local value

  validate_worker_mode "$mode"
  value="$(route_env_model "$mode")"
  if [[ -n "$value" ]]; then
    printf '%s\t%s\t%s\n' "$value" "env" ""
    return
  fi

  value="$(route_file_model "$mode")"
  if [[ -n "$value" ]]; then
    printf '%s\t%s\t%s\n' "$value" "route" "$(route_file_reason "$mode")"
    return
  fi

  value="$(route_config_model "$mode")"
  if [[ -n "$value" ]]; then
    printf '%s\t%s\t%s\n' "$value" "config" "${OCW_CONFIG_FILE:-}"
    return
  fi

  printf '%s\t%s\t%s\n' "$(route_builtin_model "$mode")" "default" ""
}

is_batch_worker_run() {
  local root="$1"
  local dir="$2"
  local base prefix mode

  base="$(basename "$dir")"
  case "$base" in
    *-batch-[0-9]*-cheap|*-batch-[0-9]*-explore|*-batch-[0-9]*-scan|*-batch-[0-9]*-review|*-batch-[0-9]*-patch)
      ;;
    *)
      return 1
      ;;
  esac

  mode="${base##*-}"
  prefix="${base%-[0-9]*-"$mode"}"
  [[ -d "$root/$prefix" && "$(metadata_value "$root/$prefix/metadata.txt" "mode")" == "batch" ]]
}

natural_sort_key() {
  awk '
    {
      value = $0
      key = ""
      while (match(value, /[0-9]+/)) {
        key = key substr(value, 1, RSTART - 1) sprintf("%020d", substr(value, RSTART, RLENGTH) + 0)
        value = substr(value, RSTART + RLENGTH)
      }
      print key value
    }
  ' <<EOF
$1
EOF
}

run_sort_line() {
  local dir="$1"
  local created base key

  created="$(metadata_value "$dir/metadata.txt" "created_at")"
  [[ -n "$created" ]] || created="0000-00-00T00:00:00Z"
  base="$(basename "$dir")"
  key="$(natural_sort_key "$base")"
  printf '%s\t%s\t%s\n' "$created" "$key" "$dir"
}

latest_run_dir() {
  local root="$1"
  local mode="${2:-}"
  local latest
  local candidate candidate_mode lines

  [[ -d "$root" ]] || die "output root not found: $root"

  lines=""
  if [[ -n "$mode" ]]; then
    while IFS= read -r candidate || [[ -n "$candidate" ]]; do
      [[ -n "$candidate" ]] || continue
      candidate_mode="$(metadata_value "$candidate/metadata.txt" "mode")"
      if [[ -n "$candidate_mode" ]]; then
        [[ "$candidate_mode" == "$mode" ]] || continue
      else
        case "$(basename "$candidate")" in
          *-"$mode"|*-"$mode"-[0-9]*)
            ;;
          *)
            continue
            ;;
        esac
      fi
      lines="${lines}$(run_sort_line "$candidate")
"
    done <<EOF
$(find "$root" -mindepth 1 -maxdepth 1 -type d -print)
EOF
  else
    while IFS= read -r candidate || [[ -n "$candidate" ]]; do
      [[ -n "$candidate" ]] || continue
      if is_batch_worker_run "$root" "$candidate"; then
        continue
      fi
      lines="${lines}$(run_sort_line "$candidate")
"
    done <<EOF
$(find "$root" -mindepth 1 -maxdepth 1 -type d -print)
EOF
  fi

  latest="$(printf '%s' "$lines" | sort | tail -n 1 | cut -f3-)"
  [[ -n "$latest" ]] || die "no OCW runs found in $root"
  abs_existing_dir "$latest"
}

resolve_run_dir() {
  local root="$1"
  local ref="${2:-latest}"
  local mode_filter="${3:-}"

  if [[ -z "$ref" || "$ref" == "latest" ]]; then
    latest_run_dir "$root" "$mode_filter"
    return
  fi

  if [[ -d "$ref" ]]; then
    abs_existing_dir "$ref"
    return
  fi

  if [[ -d "$root/$ref" ]]; then
    abs_existing_dir "$root/$ref"
    return
  fi

  die "OCW run not found: $ref"
}

