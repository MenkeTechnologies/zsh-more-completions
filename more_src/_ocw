memory_add_record() {
  local key="$1"
  local value="$2"
  local tags="${3:-}"
  local memory_file="${4:-$(memory_file_path)}"

  [[ -n "$key" ]] || die "memory key is required"
  [[ -n "$value" ]] || die "memory value is required"
  ensure_parent_dir "$memory_file"
  if [[ ! -f "$memory_file" ]]; then
    printf 'created_at\tkey\ttags\tvalue\n' > "$memory_file"
  fi
  printf '%s\t%s\t%s\t%s\n' "$(now_utc)" "$key" "$tags" "$value" >> "$memory_file"
}

memory_export_json() {
  local memory_file="${1:-$(memory_file_path)}"
  local first=1 created_at key tags value

  printf '{\n'
  printf '  "schema_version": "ocw.memory.v1",\n'
  printf '  "memory_file": '
  json_string "$memory_file"
  printf ',\n  "items": [\n'
  if [[ -f "$memory_file" ]]; then
    while IFS=$'\t' read -r created_at key tags value; do
      [[ "$created_at" == "created_at" ]] && continue
      [[ -n "$created_at" ]] || continue
      if [[ "$first" -eq 0 ]]; then
        printf ',\n'
      fi
      printf '    { "created_at": '
      json_string "$created_at"
      printf ', "key": '
      json_string "$key"
      printf ', "tags": '
      json_string "$tags"
      printf ', "value": '
      json_string "$value"
      printf ' }'
      first=0
    done < "$memory_file"
  fi
  printf '\n  ]\n}\n'
}

memory_search_text() {
  local query="$1"
  local limit="${2:-5}"
  local memory_file="${3:-$(memory_file_path)}"

  [[ -f "$memory_file" ]] || return 0
  awk -F '\t' -v q="$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')" -v limit="$limit" '
    NR == 1 { next }
    {
      line = tolower($2 " " $3 " " $4)
      if (q == "" || index(line, q) > 0) {
        print "- " $2 " [" $3 "]: " $4
        count++
        if (count >= limit) exit
      }
    }
  ' "$memory_file"
}

memory_command() {
  local subcommand="${1:-search}"
  shift || true
  local key="" value="" tags="" query="" json=0 memory_file
  local tmp

  case "$subcommand" in
    add)
      [[ $# -ge 2 ]] || die "Usage: ocw memory add KEY VALUE [--tags TAGS]"
      key="$1"
      value="$2"
      shift 2
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --tags)
            [[ $# -ge 2 ]] || die "--tags requires a value"
            tags="$2"
            shift 2
            ;;
          *)
            die "unknown memory add option: $1"
            ;;
        esac
      done
      memory_add_record "$key" "$value" "$tags"
      printf 'OCW memory added: %s\n' "$key"
      ;;
    search)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json) json=1; shift ;;
          -h|--help)
            printf 'Usage: ocw memory search QUERY [--json]\n'
            return
            ;;
          *)
            query="${query:+$query }$1"
            shift
            ;;
        esac
      done
      if [[ "$json" -eq 1 ]]; then
        memory_file="$(memory_file_path)"
        if [[ -n "$query" && -f "$memory_file" ]]; then
          tmp="$(mktemp "${TMPDIR:-/tmp}/ocw-memory.XXXXXX")"
          {
            printf 'created_at\tkey\ttags\tvalue\n'
            awk -F '\t' -v q="$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')" 'NR > 1 { line = tolower($2 " " $3 " " $4); if (index(line, q) > 0) print }' "$memory_file"
          } > "$tmp"
          memory_export_json "$tmp"
          rm -f "$tmp"
        else
          memory_export_json "$memory_file"
        fi
      else
        memory_search_text "$query" 100
      fi
      ;;
    update)
      if have_command "$GIT_BIN" && git_is_repo "$PWD"; then
        value="$(git_root "$PWD")"
        [[ -n "$value" ]] && memory_add_record "git_root" "$value" "project"
      fi
      if [[ -n "${OCW_CONFIG_FILE:-}" ]]; then
        memory_add_record "config_file" "$OCW_CONFIG_FILE" "project"
      fi
      if [[ -f Makefile ]]; then
        memory_add_record "test_command" "make test" "tests"
      elif [[ -f package.json ]]; then
        memory_add_record "test_command" "npm test" "tests"
      fi
      if [[ -f README.md ]]; then
        memory_add_record "docs" "README.md is the primary project README" "docs"
      fi
      printf 'OCW memory updated: %s\n' "$(memory_file_path)"
      ;;
    export)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json) json=1; shift ;;
          -h|--help)
            printf 'Usage: ocw memory export [--json]\n'
            return
            ;;
          *)
            die "unknown memory export option: $1"
            ;;
        esac
      done
      memory_file="$(memory_file_path)"
      if [[ "$json" -eq 1 ]]; then
        memory_export_json "$memory_file"
      elif [[ -f "$memory_file" ]]; then
        cat "$memory_file"
      else
        printf 'created_at\tkey\ttags\tvalue\n'
      fi
      ;;
    -h|--help|help)
      cat <<'EOF'
Usage:
  ocw memory add KEY VALUE [--tags TAGS]
  ocw memory search QUERY [--json]
  ocw memory update
  ocw memory export [--json]
EOF
      ;;
    *)
      die "unknown memory command: $subcommand"
      ;;
  esac
}

dashboard_command() {
  local root="$1"
  shift
  local out_file=".codex/ocw-dashboard.html"
  local json=0
  local root_abs dir metadata mode status model created_at base first route_count memory_count

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --out)
        [[ $# -ge 2 ]] || die "--out requires a value"
        out_file="$2"
        shift 2
        ;;
      --json)
        json=1
        shift
        ;;
      -h|--help)
        printf 'Usage: ocw dashboard [--out FILE] [--json]\n'
        return
        ;;
      *)
        die "unknown dashboard option: $1"
        ;;
    esac
  done

  root_abs="$(prepare_output_root "$root")"
  route_count=0
  [[ -f "$(routes_file_path)" ]] && route_count="$(awk 'NR > 1 { count++ } END { print count + 0 }' "$(routes_file_path)")"
  memory_count=0
  [[ -f "$(memory_file_path)" ]] && memory_count="$(awk 'NR > 1 { count++ } END { print count + 0 }' "$(memory_file_path)")"

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.dashboard.v1",\n'
    printf '  "output_root": '
    json_string "$root_abs"
    printf ',\n  "route_count": %s,\n  "memory_count": %s,\n  "runs": [\n' "$route_count" "$memory_count"
    first=1
    while IFS= read -r dir; do
      [[ -n "$dir" ]] || continue
      metadata="$dir/metadata.txt"
      [[ -f "$metadata" ]] || continue
      if [[ "$first" -eq 0 ]]; then
        printf ',\n'
      fi
      printf '    { "run": '
      json_string "$(basename "$dir")"
      printf ', "mode": '
      json_string "$(metadata_value "$metadata" "mode")"
      printf ', "status": '
      json_string "$(metadata_value "$metadata" "status")"
      printf ', "model": '
      json_string "$(metadata_value "$metadata" "model")"
      printf ', "created_at": '
      json_string "$(metadata_value "$metadata" "created_at")"
      printf ' }'
      first=0
    done <<EOF
$(find "$root_abs" -mindepth 1 -maxdepth 1 -type d -print | sort | tail -n 50)
EOF
    printf '\n  ]\n}\n'
    return
  fi

  ensure_parent_dir "$out_file"
  {
    printf '<!doctype html><html><head><meta charset="utf-8"><title>OCW Dashboard</title>'
    printf '<style>body{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif;max-width:1120px;margin:32px auto;padding:0 20px;color:#1f2328}table{border-collapse:collapse;width:100%%}th,td{border-bottom:1px solid #d0d7de;padding:8px;text-align:left}th{background:#f6f8fa}.stat{display:inline-block;margin:0 16px 16px 0;padding:8px 10px;border:1px solid #d0d7de;border-radius:6px}</style>'
    printf '</head><body><h1>OCW Dashboard</h1>'
    printf '<p class="stat">Output root: <code>%s</code></p>' "$(html_escape "$root_abs")"
    printf '<p class="stat">Routes: <strong>%s</strong></p>' "$route_count"
    printf '<p class="stat">Memory: <strong>%s</strong></p>' "$memory_count"
    printf '<h2>Recent Runs</h2><table><thead><tr><th>Run</th><th>Mode</th><th>Status</th><th>Model</th><th>Created</th></tr></thead><tbody>'
    while IFS= read -r dir; do
      [[ -n "$dir" ]] || continue
      metadata="$dir/metadata.txt"
      [[ -f "$metadata" ]] || continue
      base="$(basename "$dir")"
      mode="$(metadata_value "$metadata" "mode")"
      status="$(metadata_value "$metadata" "status")"
      model="$(metadata_value "$metadata" "model")"
      created_at="$(metadata_value "$metadata" "created_at")"
      printf '<tr><td><code>%s</code></td><td>%s</td><td>%s</td><td><code>%s</code></td><td>%s</td></tr>' \
        "$(html_escape "$base")" "$(html_escape "$mode")" "$(html_escape "$status")" "$(html_escape "$model")" "$(html_escape "$created_at")"
    done <<EOF
$(find "$root_abs" -mindepth 1 -maxdepth 1 -type d -print | sort | tail -n 50)
EOF
    printf '</tbody></table></body></html>\n'
  } > "$out_file"
  printf 'OCW dashboard written: %s\n' "$out_file"
}

quickstart_command() {
  local json=0
  local node_ok opencode_ok git_ok gh_ok

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help)
        printf 'Usage: ocw quickstart [--json]\n'
        return
        ;;
      *)
        die "unknown quickstart option: $1"
        ;;
    esac
  done

  if have_command "$OPENCODE_BIN"; then opencode_ok=true; else opencode_ok=false; fi
  if have_command "$GIT_BIN"; then git_ok=true; else git_ok=false; fi
  if have_command "$GH_BIN"; then gh_ok=true; else gh_ok=false; fi
  if have_command "$NODE_BIN"; then node_ok=true; else node_ok=false; fi

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.quickstart.v1",\n'
    printf '  "checks": { "opencode": %s, "git": %s, "gh": %s, "node": %s },\n' "$opencode_ok" "$git_ok" "$gh_ok" "$node_ok"
    printf '  "commands": [\n'
    printf '    "ocw doctor --deep",\n'
    printf '    "ocw setup all",\n'
    printf '    "ocw bridge setup --force",\n'
    printf '    "ocw bridge doctor",\n'
    printf '    "ocw bridge workers doctor",\n'
    printf '    "ocw models sync",\n'
    printf '    "ocw models configure balanced",\n'
    printf '    "ocw route doctor",\n'
    printf '    "ocw keys doctor",\n'
    printf '    "ocw delegate \\"Summarize this repository\\"",\n'
    printf '    "ocw verdict latest",\n'
    printf '    "ocw savings"\n'
    printf '  ]\n'
    printf '}\n'
    return
  fi

  cat <<'EOF'
OCW quickstart

1. Check setup:
   ocw doctor --deep

2. Install project integrations:
   ocw setup all

3. Set up Codex-native OpenCode Go workers:
   ocw bridge setup --force

4. Sync OpenCode Go model catalog:
   ocw models sync

5. Configure project model routes:
   ocw models configure balanced
   ocw route doctor

6. Check API key rotation:
   ocw keys doctor

7. Delegate a bounded worker task:
   ocw delegate "Summarize this repository"

8. Check the handoff:
   ocw verdict latest
   ocw savings

Useful next commands:
   ocw route explain
   ocw keys list
   ocw backend doctor
   ocw bridge setup --force
   ocw bridge doctor
   ocw bridge workers doctor
   ocw mcp audit
   ocw policy init strict
EOF
}

setup_command() {
  local target="${1:-all}"
  local force=0
  local project_skills=0
  local json=0
  local log_file=""
  local codex_skills_dir="${OCW_CODEX_SKILLS_DIR:-${CODEX_HOME:-$HOME/.codex}/skills}"
  local claude_skills_dir="${OCW_CLAUDE_SKILLS_DIR:-${CLAUDE_HOME:-$HOME/.claude}/skills}"
  local opencode_home_dir opencode_skills_dir
  opencode_home_dir="$(opencode_config_home)"
  opencode_skills_dir="${OCW_OPENCODE_SKILLS_DIR:-$opencode_home_dir/skills}"

  if [[ "$target" == "--"* || "$target" == "-h" ]]; then
    target="all"
  else
    shift || true
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=1; shift ;;
      --project-skills) project_skills=1; shift ;;
      --json) json=1; shift ;;
      -h|--help)
        cat <<'EOF'
Usage: ocw setup [codex|claude|opencode|copilot|all] [--force] [--project-skills] [--json]

Installs project-local instructions and client helpers for the selected agent.
Existing files are kept unless --force is passed.
EOF
        return
        ;;
      *)
        die "unknown setup option: $1"
        ;;
    esac
  done

  case "$target" in
    codex|claude|opencode|copilot|all) ;;
    *) die "unknown setup target: $target" ;;
  esac

  if [[ "$json" -eq 1 ]]; then
    log_file="$(mktemp "${TMPDIR:-/tmp}/ocw-setup.XXXXXX")"
    exec 3>&1
    exec > "$log_file"
  fi

  case "$target" in
    codex)
      ensure_ocw_gitignore_entries ".gitignore"
      write_default_config ".ocw.toml" "$force"
      copy_if_needed "$OCW_HOME/examples/codex/AGENTS.md" "AGENTS.md" "Codex instructions" "$force"
      install_agent_skill "Codex" "$codex_skills_dir"
      install_ocw_post_task_hook "$force"
      install_project_mcp_config "$force"
      if [[ "$force" -eq 1 ]]; then
        bridge_install_command --force
        bridge_agents_command sync --force
        bridge_workers_command sync --force
        bridge_orchestration_command sync --force
        bridge_codex_config_command --write --project --force
      else
        bridge_install_command
        bridge_agents_command sync
        bridge_workers_command sync
        bridge_orchestration_command sync
        bridge_codex_config_command --write --project
      fi
      ;;
    claude)
      ensure_ocw_gitignore_entries ".gitignore"
      write_default_config ".ocw.toml" "$force"
      copy_if_needed "$OCW_HOME/examples/claude/CLAUDE.md" "CLAUDE.md" "Claude Code instructions" "$force"
      install_agent_skill "Claude Code" "$claude_skills_dir"
      if [[ "$project_skills" -eq 1 ]]; then
        install_agent_skill "project Claude Code" ".claude/skills"
      fi
      install_project_mcp_config "$force"
      install_claude_ocw_subagent "$force"
      if [[ "$force" -eq 1 ]]; then
        hooks_command install claude --force
      else
        hooks_command install claude
      fi
      ;;
    opencode)
      ensure_ocw_gitignore_entries ".gitignore"
      write_default_config ".ocw.toml" "$force"
      install_agent_skill "OpenCode" "$opencode_skills_dir"
      if [[ "$project_skills" -eq 1 ]]; then
        install_agent_skill "project OpenCode" ".opencode/skills"
      fi
      if [[ "$force" -eq 1 ]]; then
        hooks_command install opencode --force
      else
        hooks_command install opencode
      fi
      ;;
    copilot)
      if [[ "$force" -eq 1 ]]; then
        copilot_command install --force
      else
        copilot_command install
      fi
      ;;
    all)
      if [[ "$project_skills" -eq 1 ]]; then
        if [[ "$force" -eq 1 ]]; then
          init_project --project-skills --force
        else
          init_project --project-skills
        fi
      else
        if [[ "$force" -eq 1 ]]; then
          init_project --force
        else
          init_project
        fi
      fi
      if [[ "$force" -eq 1 ]]; then
        hooks_command install all --force
      else
        hooks_command install all
      fi
      install_project_mcp_config "$force"
      install_claude_ocw_subagent "$force"
      if [[ "$force" -eq 1 ]]; then
        bridge_install_command --force
        bridge_agents_command sync --force
        bridge_workers_command sync --force
        bridge_orchestration_command sync --force
        bridge_codex_config_command --write --project --force
      else
        bridge_install_command
        bridge_agents_command sync
        bridge_workers_command sync
        bridge_orchestration_command sync
        bridge_codex_config_command --write --project
      fi
      ;;
  esac

  if [[ "$json" -eq 1 ]]; then
    exec 1>&3
    exec 3>&-
    printf '{\n'
    printf '  "schema_version": "ocw.setup.v1",\n'
    printf '  "target": '
    json_string "$target"
    printf ',\n  "force": %s,\n  "project_skills": %s,\n  "log": ' "$force" "$project_skills"
    json_string "$(cat "$log_file")"
    printf '\n}\n'
    rm -f "$log_file"
  else
    printf 'OCW setup complete: %s\n' "$target"
  fi
}

bridge_vendor_dir() {
