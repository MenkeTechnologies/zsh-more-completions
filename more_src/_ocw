  else
    bridge_expand_user_path "${XDG_STATE_HOME:-$HOME/.local/state}/ocw/logs"
  fi
}

bridge_global_runtime_dir() {
  bridge_expand_user_path "${OCW_BRIDGE_GLOBAL_RUNTIME_DIR:-$(bridge_global_data_dir)/bridge-runtime}"
}

bridge_proxy_key_file() {
  bridge_expand_user_path "${OCW_BRIDGE_PROXY_KEY_FILE:-$(bridge_global_config_dir)/bridge-proxy-key}"
}

bridge_proxy_key_read() {
  local file key

  file="$(bridge_proxy_key_file)"
  [[ -f "$file" ]] || return 1
  IFS= read -r key < "$file"
  [[ -n "${key:-}" ]] || return 1
  printf '%s\n' "$key"
}

bridge_generate_proxy_key() {
  if have_command "$PYTHON_BIN"; then
    "$PYTHON_BIN" -c 'import secrets; print("sk-ocw-" + secrets.token_urlsafe(32))'
  elif [[ -r /dev/urandom ]] && have_command od; then
    printf 'sk-ocw-'
    od -An -N32 -tx1 /dev/urandom | tr -d ' \n'
    printf '\n'
  else
    printf 'sk-ocw-%s-%s\n' "$(date +%s)" "$$"
  fi
}

bridge_proxy_key_get_or_create() {
  local file key tmp lock_dir attempts=0

  key="$(bridge_proxy_key_read 2>/dev/null || true)"
  if [[ -n "$key" ]]; then
    printf '%s\n' "$key"
    return
  fi

  file="$(bridge_proxy_key_file)"
  mkdir -p "$(dirname "$file")"
  lock_dir="$file.lock"
  while ! mkdir "$lock_dir" 2>/dev/null; do
    key="$(bridge_proxy_key_read 2>/dev/null || true)"
    if [[ -n "$key" ]]; then
      printf '%s\n' "$key"
      return
    fi
    attempts=$((attempts + 1))
    (( attempts <= 100 )) || die "timed out waiting for bridge proxy key lock: $lock_dir"
    sleep 0.1
  done

  key="$(bridge_proxy_key_read 2>/dev/null || true)"
  if [[ -n "$key" ]]; then
    rmdir "$lock_dir" 2>/dev/null || true
    printf '%s\n' "$key"
    return
  fi

  tmp="$(mktemp "$(dirname "$file")/.bridge-proxy-key.XXXXXX")"
  chmod 600 "$tmp"
  if ! bridge_generate_proxy_key > "$tmp"; then
    rm -f "$tmp"
    rmdir "$lock_dir" 2>/dev/null || true
    die "failed to generate bridge proxy key"
  fi
  mv "$tmp" "$file"
  chmod 600 "$file" 2>/dev/null || true
  rmdir "$lock_dir" 2>/dev/null || true
  bridge_proxy_key_read
}

bridge_keychain_service() {
  printf '%s\n' "${OCW_BRIDGE_KEYCHAIN_SERVICE:-dev.ocw.opencodgo.api-key}"
}

bridge_keychain_account() {
  printf '%s\n' "${OCW_BRIDGE_KEYCHAIN_ACCOUNT:-default}"
}

bridge_keychain_available() {
  [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]] && have_command security
}

bridge_key_store_backend() {
  local requested="${1:-${OCW_BRIDGE_KEY_STORE:-auto}}"

  case "$requested" in
    auto)
      if bridge_keychain_available; then
        printf 'keychain\n'
      else
        printf 'file\n'
      fi
      ;;
    keychain|file)
      printf '%s\n' "$requested"
      ;;
    *)
      die "invalid bridge key store: $requested (expected auto, keychain, or file)"
      ;;
  esac
}

bridge_env_file_get_key() {
  local env_file="$1"
  local wanted="${2:-OPENCODE_GO_API_KEY}"
  local line key value

  [[ -f "$env_file" ]] || return 1
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="$(trim "$line")"
    [[ -z "$line" || "$line" == \#* ]] && continue
    case "$line" in
      export\ *) line="${line#export }" ;;
    esac
    [[ "$line" == *=* ]] || continue
    key="$(trim "${line%%=*}")"
    value="$(unquote "$(trim "${line#*=}")")"
    if [[ "$key" == "$wanted" && -n "$value" ]]; then
      printf '%s\n' "$value"
      return 0
    fi
  done < "$env_file"
  return 1
}

bridge_keychain_read() {
  bridge_keychain_available || return 1
  security find-generic-password \
    -a "$(bridge_keychain_account)" \
    -s "$(bridge_keychain_service)" \
    -w 2>/dev/null
}

bridge_keychain_write() {
  local value="$1"

  bridge_keychain_available || return 1
  security add-generic-password \
    -a "$(bridge_keychain_account)" \
    -s "$(bridge_keychain_service)" \
    -w "$value" \
    -U >/dev/null
}

bridge_keychain_delete() {
  bridge_keychain_available || return 1
  security delete-generic-password \
    -a "$(bridge_keychain_account)" \
    -s "$(bridge_keychain_service)" >/dev/null 2>&1 || true
}

bridge_global_file_read() {
  bridge_env_file_get_key "$(bridge_global_env_file)" OPENCODE_GO_API_KEY
}

bridge_global_file_write() {
  local value="$1"
  local file tmp

  file="$(bridge_global_env_file)"
  mkdir -p "$(dirname "$file")"
  tmp="$(mktemp "${TMPDIR:-/tmp}/ocw-bridge-key.XXXXXX")"
  chmod 600 "$tmp"
  printf 'OPENCODE_GO_API_KEY=%s\n' "$value" > "$tmp"
  mv "$tmp" "$file"
  chmod 600 "$file" 2>/dev/null || true
}

bridge_global_key_record() {
  local requested="${1:-${OCW_BRIDGE_KEY_STORE:-auto}}"
  local value

  case "$requested" in
    auto)
      value="$(bridge_keychain_read 2>/dev/null || true)"
      if [[ -n "$value" ]]; then
        printf 'keychain\t%s\n' "$value"
        return 0
      fi
      value="$(bridge_global_file_read 2>/dev/null || true)"
      if [[ -n "$value" ]]; then
        printf 'file\t%s\n' "$value"
        return 0
      fi
      ;;
    keychain)
      value="$(bridge_keychain_read 2>/dev/null || true)"
      if [[ -n "$value" ]]; then
        printf 'keychain\t%s\n' "$value"
        return 0
      fi
      ;;
    file)
      value="$(bridge_global_file_read 2>/dev/null || true)"
      if [[ -n "$value" ]]; then
        printf 'file\t%s\n' "$value"
        return 0
      fi
      ;;
    *)
      die "invalid bridge key store: $requested (expected auto, keychain, or file)"
      ;;
  esac
  return 1
}

bridge_global_key_write() {
  local value="$1"
  local requested="${2:-${OCW_BRIDGE_KEY_STORE:-auto}}"
  local backend

  backend="$(bridge_key_store_backend "$requested")"
  case "$backend" in
    keychain)
      if bridge_keychain_write "$value"; then
        printf 'keychain\n'
        return 0
      fi
      if [[ "$requested" == "auto" ]]; then
        bridge_global_file_write "$value"
        printf 'file\n'
        return 0
      fi
      die "failed to write bridge key to macOS Keychain"
      ;;
    file)
      bridge_global_file_write "$value"
      printf 'file\n'
      ;;
  esac
}

bridge_global_key_delete() {
  local requested="${1:-all}"
  local file deleted=0

  case "$requested" in
    all|auto|keychain)
      if bridge_keychain_available; then
        bridge_keychain_delete || true
        deleted=1
      fi
      ;;
    file) ;;
    *)
      die "invalid bridge key remove store: $requested (expected all, auto, keychain, or file)"
      ;;
  esac

  case "$requested" in
    all|auto|file)
      file="$(bridge_global_env_file)"
      if [[ -f "$file" ]]; then
        rm -f "$file"
        deleted=1
      fi
      ;;
    keychain) ;;
  esac

  [[ "$deleted" -eq 1 ]]
}

bridge_load_credentials() {
  local env_file="$1"
  local env_before="${OPENCODE_GO_API_KEY:-}"
  local project_key=""
  local record source="missing" store value

  project_key="$(bridge_env_file_get_key "$env_file" OPENCODE_GO_API_KEY 2>/dev/null || true)"
  bridge_load_env_file "$env_file"
  if [[ -n "$project_key" ]]; then
    source="project-env"
  elif [[ -n "$env_before" || -n "${OPENCODE_GO_API_KEY:-}" ]]; then
    source="environment"
  fi

  if [[ -z "${OPENCODE_GO_API_KEY:-}" ]]; then
    record="$(bridge_global_key_record "${OCW_BRIDGE_KEY_STORE:-auto}" 2>/dev/null || true)"
    if [[ -n "$record" ]]; then
      store="${record%%$'\t'*}"
      value="${record#*$'\t'}"
      export OPENCODE_GO_API_KEY="$value"
      case "$store" in
        keychain) source="keychain" ;;
        file) source="global-file" ;;
        *) source="$store" ;;
      esac
    fi
  fi

  export OCW_BRIDGE_UPSTREAM_KEY_SOURCE="$source"
}

shell_single_quote() {
  local value="$1"

  value="${value//\'/\'\\\'\'}"
  printf "'%s'" "$value"
}

bridge_self_abs() {
  local self="${OCW_SELF:-$0}"
  local dir base

  case "$self" in
    /*)
      printf '%s\n' "$self"
      ;;
    */*)
      dir="$(dirname "$self")"
      base="$(basename "$self")"
      printf '%s/%s\n' "$(cd "$dir" >/dev/null 2>&1 && pwd -P)" "$base"
      ;;
    *)
      if command -v "$self" >/dev/null 2>&1; then
        command -v "$self"
      else
        printf '%s\n' "$self"
      fi
      ;;
  esac
}

bridge_service_name() {
  printf '%s\n' "${OCW_BRIDGE_SERVICE_NAME:-ocw-bridge}"
}

bridge_service_label() {
  printf '%s\n' "${OCW_BRIDGE_SERVICE_LABEL:-dev.ocw.bridge}"
}

bridge_windows_task_name() {
