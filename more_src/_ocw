  local force=0
  local file target base
  local status=0
  local worker explorer overall provider_ok=false model_ok=false worker_ok=false explorer_ok=false

  shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dir) target_dir="$2"; shift 2 ;;
      --force) force=1; shift ;;
      -h|--help)
        cat <<'EOF'
Usage:
  ocw bridge workers sync [--dir DIR] [--force]
  ocw bridge workers diff [--dir DIR]
  ocw bridge workers doctor [--dir DIR]
EOF
        return
        ;;
      *) die "unknown bridge workers option: $1" ;;
    esac
