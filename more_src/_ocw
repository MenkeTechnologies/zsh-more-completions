resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  local dir target

  while [[ -L "$source" ]]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    target="$(readlink "$source")"
    if [[ "$target" == /* ]]; then
      source="$target"
    else
      source="$dir/$target"
    fi
  done

  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
OCW_HOME="${OCW_HOME:-$(cd "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd -P)}"

