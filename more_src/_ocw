bridge_key_command() {
  local subcommand="${1:-status}"
  shift || true
  local key_value="" source_env="" store="${OCW_BRIDGE_KEY_STORE:-auto}" backend
  local project_env global_record global_store global_key configured=false source="missing" fingerprint="" json=0
  local global_available=false global_fingerprint="" mode="missing" message="bridge key not configured" severity="warn"

  project_env="$(bridge_project_dir)/opencode-go.env"

  case "$subcommand" in
    set)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --stdin)
            key_value="$(auth_read_secret)"
            shift
            ;;
          --value)
            [[ $# -ge 2 ]] || die "--value requires a value"
            key_value="$2"
            shift 2
            ;;
          --from-env)
            [[ $# -ge 2 ]] || die "--from-env requires a variable name"
            source_env="$2"
            validate_env_name "$source_env"
            key_value="${!source_env:-}"
            [[ -n "$key_value" ]] || die "environment variable is empty or unset: $source_env"
            shift 2
            ;;
          --from-project)
            key_value="$(bridge_env_file_get_key "$project_env" OPENCODE_GO_API_KEY 2>/dev/null || true)"
            [[ -n "$key_value" ]] || die "project bridge key not found in $project_env"
            shift
            ;;
          --store)
            [[ $# -ge 2 ]] || die "--store requires a value"
            store="$2"
            shift 2
            ;;
          -h|--help)
            cat <<'EOF'
Usage: ocw bridge key set (--stdin|--value KEY|--from-env ENV|--from-project) [--store auto|keychain|file]

Stores the OpenCode Go API key globally so every project can use OCW Bridge
without asking for the key again. Use --stdin or --from-env to avoid putting
secrets in shell history.
EOF
            return
            ;;
          *)
            die "unknown bridge key set option: $1"
            ;;
        esac
      done
      validate_key_value "${key_value:-}"
      backend="$(bridge_global_key_write "$key_value" "$store")"
      fingerprint="$(auth_key_fingerprint "$key_value")"
      printf 'OCW bridge key stored: %s\n' "$backend"
      printf 'fingerprint: %s\n' "$fingerprint"
      if [[ "$backend" == "file" ]]; then
        printf 'file: %s\n' "$(bridge_global_env_file)"
      elif [[ "$backend" == "keychain" ]]; then
        printf 'keychain service: %s\n' "$(bridge_keychain_service)"
      fi
      ;;
    status|list|doctor)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json) json=1; shift ;;
          -h|--help)
            printf 'Usage: ocw bridge key status [--json]\n'
            return
            ;;
          *)
            die "unknown bridge key status option: $1"
            ;;
        esac
      done
      bridge_load_credentials "$project_env"
      if [[ -n "${OPENCODE_GO_API_KEY:-}" ]]; then
        configured=true
        source="${OCW_BRIDGE_UPSTREAM_KEY_SOURCE:-unknown}"
        fingerprint="$(auth_key_fingerprint "$OPENCODE_GO_API_KEY")"
        severity="ok"
        message="bridge key is configured"
      fi
      global_record="$(bridge_global_key_record "$store" 2>/dev/null || true)"
      if [[ -n "$global_record" ]]; then
        global_available=true
        global_store="${global_record%%$'\t'*}"
        global_key="${global_record#*$'\t'}"
        global_fingerprint="$(auth_key_fingerprint "$global_key")"
      else
        global_store="$(bridge_key_store_backend "$store")"
      fi
      if [[ -f "$(bridge_global_env_file)" ]]; then
        mode="$(stat -f '%Lp' "$(bridge_global_env_file)" 2>/dev/null || stat -c '%a' "$(bridge_global_env_file)" 2>/dev/null || printf unknown)"
        if [[ "$mode" != "600" && "$mode" != "400" ]]; then
          severity="warn"
          message="global bridge key file should be chmod 600"
        fi
      fi

      if [[ "$json" -eq 1 ]]; then
        printf '{\n'
        printf '  "schema_version": "ocw.bridge.key.v1",\n'
        printf '  "configured": %s,\n' "$configured"
        printf '  "source": '
        json_string "$source"
        printf ',\n  "fingerprint": '
        json_string "$fingerprint"
        printf ',\n  "global_available": %s,\n' "$global_available"
        printf '  "global_store": '
        json_string "$global_store"
        printf ',\n  "global_fingerprint": '
        json_string "$global_fingerprint"
        printf ',\n  "global_file": '
        json_string "$(bridge_global_env_file)"
        printf ',\n  "project_env": '
        json_string "$project_env"
        printf ',\n  "severity": '
        json_string "$severity"
        printf ',\n  "message": '
        json_string "$message"
        printf '\n}\n'
      else
        printf 'OCW bridge key: %s\n' "$severity"
        printf 'configured: %s\n' "$configured"
        printf 'source: %s\n' "$source"
        [[ -n "$fingerprint" ]] && printf 'fingerprint: %s\n' "$fingerprint"
        printf 'global store: %s\n' "$global_store"
        printf 'global available: %s\n' "$global_available"
        [[ -n "$global_fingerprint" ]] && printf 'global fingerprint: %s\n' "$global_fingerprint"
        printf 'global file: %s\n' "$(bridge_global_env_file)"
        printf 'project env: %s\n' "$project_env"
        printf '[%s] %s\n' "$severity" "$message"
      fi
      [[ "$severity" != "fail" ]]
      ;;
    remove|rm|clear)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --store)
            [[ $# -ge 2 ]] || die "--store requires a value"
            store="$2"
            shift 2
            ;;
          -h|--help)
            printf 'Usage: ocw bridge key remove [--store all|auto|keychain|file]\n'
            return
            ;;
          *)
            die "unknown bridge key remove option: $1"
            ;;
        esac
      done
      bridge_global_key_delete "$store" || true
      printf 'OCW bridge key removed from: %s\n' "$store"
      ;;
    path)
      printf '%s\n' "$(bridge_global_env_file)"
      ;;
    -h|--help|help)
      cat <<'EOF'
Usage:
  ocw bridge key set (--stdin|--value KEY|--from-env ENV|--from-project) [--store auto|keychain|file]
  ocw bridge key status [--json]
  ocw bridge key list [--json]
  ocw bridge key doctor [--json]
  ocw bridge key remove [--store all|auto|keychain|file]
  ocw bridge key path

OCW Bridge reads keys in this order:
1. Project env file: .codex/ocw-bridge/opencode-go.env
2. Shell environment: OPENCODE_GO_API_KEY
3. Global store: macOS Keychain when available, otherwise a chmod-600 file

Use `ocw bridge key set --stdin` once, then every project can run
`ocw bridge setup --force --start --live` without asking for the key again.
EOF
      ;;
    *)
      die "unknown bridge key command: $subcommand"
      ;;
  esac
}

bridge_proxy_key_command() {
  local subcommand="${1:-status}"
  shift || true
  local key fingerprint file tmp json=0

  file="$(bridge_proxy_key_file)"
  case "$subcommand" in
    print)
      bridge_proxy_key_get_or_create
      ;;
    status|doctor)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json) json=1; shift ;;
          -h|--help)
            printf 'Usage: ocw bridge proxy-key status [--json]\n'
            return
            ;;
          *) die "unknown bridge proxy-key status option: $1" ;;
        esac
      done
      key="$(bridge_proxy_key_read 2>/dev/null || true)"
      if [[ -n "$key" ]]; then
        fingerprint="$(auth_key_fingerprint "$key")"
      else
        fingerprint=""
      fi
      if [[ "$json" -eq 1 ]]; then
        printf '{\n'
        printf '  "schema_version": "ocw.bridge.proxy_key.v1",\n'
        printf '  "exists": %s,\n' "$([[ -n "$key" ]] && printf true || printf false)"
        printf '  "file": '
        json_string "$file"
        printf ',\n  "fingerprint": '
        json_string "$fingerprint"
        printf '\n}\n'
      else
        printf 'OCW bridge proxy key: %s\n' "$([[ -n "$key" ]] && printf configured || printf missing)"
        printf 'file: %s\n' "$file"
        [[ -n "$fingerprint" ]] && printf 'fingerprint: %s\n' "$fingerprint"
      fi
      ;;
    rotate)
      mkdir -p "$(dirname "$file")"
      tmp="$(mktemp "${TMPDIR:-/tmp}/ocw-bridge-proxy-key.XXXXXX")"
      chmod 600 "$tmp"
      bridge_generate_proxy_key > "$tmp"
      mv "$tmp" "$file"
      chmod 600 "$file" 2>/dev/null || true
      printf 'OCW bridge proxy key rotated: %s\n' "$file"
      printf 'Restart the bridge service so the new proxy key is used.\n'
      ;;
    path)
      printf '%s\n' "$file"
      ;;
    -h|--help|help)
      cat <<'EOF'
Usage:
  ocw bridge proxy-key print
  ocw bridge proxy-key status [--json]
  ocw bridge proxy-key rotate
  ocw bridge proxy-key path

This key protects the localhost bridge itself. It is not your OpenCode Go
upstream key. Codex reads it through the generated auth command.
EOF
      ;;
    *)
      die "unknown bridge proxy-key command: $subcommand"
      ;;
  esac
}

bridge_service_command() {
  local subcommand="${1:-status}"
  shift || true
  local manager_input="${OCW_BRIDGE_SERVICE_MANAGER:-auto}" manager
  local host="${OCW_BRIDGE_HOST:-127.0.0.1}"
  local port="${OCW_BRIDGE_PORT:-4000}"
  local timeout="${OCW_BRIDGE_START_TIMEOUT:-60}"
  local force=0 start=0 live=0 dry_run=0 json=0 lines=120 all=0
  local runtime_dir service_file launcher runner stdout_log stderr_log key active=false health=false installed=false
  local wait_status=0

  case "$subcommand" in
    install)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --manager) manager_input="$2"; shift 2 ;;
          --host) host="$2"; shift 2 ;;
          --port) port="$2"; shift 2 ;;
          --timeout) timeout="$2"; shift 2 ;;
          --force) force=1; shift ;;
          --start) start=1; shift ;;
          --live) live=1; start=1; shift ;;
          --dry-run) dry_run=1; shift ;;
          --json) json=1; shift ;;
          -h|--help)
            cat <<'EOF'
Usage: ocw bridge service install [--manager auto|launchd|systemd|windows] [--host HOST] [--port PORT] [--start] [--live] [--force] [--dry-run] [--json]
EOF
            return
            ;;
          *) die "unknown bridge service install option: $1" ;;
        esac
      done
      manager="$(bridge_service_manager "$manager_input")"
      bridge_validate_port "$port"
      [[ "$timeout" =~ ^[0-9]+$ ]] || die "invalid bridge service timeout: $timeout"
      if ! bridge_loopback_host_ok "$host" && [[ "${OCW_BRIDGE_ALLOW_NON_LOOPBACK:-0}" != "1" ]]; then
        die "refusing to bind bridge service to non-loopback host '$host' (set OCW_BRIDGE_ALLOW_NON_LOOPBACK=1 to override)"
      fi
      runtime_dir="$(bridge_global_runtime_dir)"
      bridge_install_global_runtime "$force" "$json"
      bridge_proxy_key_get_or_create >/dev/null
      bridge_service_write_files "$manager" "$host" "$port" "$runtime_dir" "$json"
      bridge_service_install_manager "$manager" "$start" "$dry_run" "$json"
      key="$(bridge_default_key)"
      if [[ "$start" -eq 1 && "$dry_run" -ne 1 ]]; then
        bridge_wait_for_health "$host" "$port" "$key" "" "$timeout" || wait_status=$?
        if [[ "$wait_status" -ne 0 ]]; then
          die "OCW bridge service did not pass health within ${timeout}s; inspect $(bridge_service_stderr_log)"
        fi
      fi
      if [[ "$live" -eq 1 && "$dry_run" -ne 1 ]]; then
        if [[ "$json" -eq 1 ]]; then
          bridge_test_command --live --host "$host" --port "$port" --json >/dev/null
        else
          bridge_test_command --live --host "$host" --port "$port"
        fi
      fi
      if [[ "$json" -eq 1 ]]; then
        printf '{\n'
        printf '  "schema_version": "ocw.bridge.service.install.v1",\n'
        printf '  "manager": '
        json_string "$manager"
        printf ',\n  "host": '
        json_string "$host"
        printf ',\n  "port": %s,\n  "dry_run": %s,\n  "started": %s' "$port" "$([[ "$dry_run" -eq 1 ]] && printf true || printf false)" "$([[ "$start" -eq 1 && "$dry_run" -ne 1 ]] && printf true || printf false)"
        printf ',\n  "runtime": '
        json_string "$runtime_dir"
        printf ',\n  "service_file": '
        json_string "$(bridge_service_definition_path "$manager")"
        printf ',\n  "launcher": '
        json_string "$(bridge_service_launcher_path "$manager")"
        printf ',\n  "runner": '
        json_string "$(bridge_service_runner_path)"
        printf '\n}\n'
      else
        printf 'OCW bridge service installed: %s\n' "$manager"
        printf 'runtime: %s\n' "$runtime_dir"
        printf 'service file: %s\n' "$(bridge_service_definition_path "$manager")"
        printf 'launcher: %s\n' "$(bridge_service_launcher_path "$manager")"
        printf 'runner: %s\n' "$(bridge_service_runner_path)"
      fi
      ;;
    start)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --manager) manager_input="$2"; shift 2 ;;
          --host) host="$2"; shift 2 ;;
          --port) port="$2"; shift 2 ;;
          --timeout) timeout="$2"; shift 2 ;;
          -h|--help)
            printf 'Usage: ocw bridge service start [--manager auto|launchd|systemd|windows] [--host HOST] [--port PORT] [--timeout SECONDS]\n'
            return
            ;;
          *) die "unknown bridge service start option: $1" ;;
        esac
      done
      manager="$(bridge_service_manager "$manager_input")"
      bridge_validate_port "$port"
      bridge_service_start_manager "$manager"
      key="$(bridge_default_key)"
      bridge_wait_for_health "$host" "$port" "$key" "" "$timeout" || die "OCW bridge service did not pass health within ${timeout}s; inspect $(bridge_service_stderr_log)"
      printf 'OCW bridge service started: %s\n' "$manager"
      ;;
    stop)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --manager) manager_input="$2"; shift 2 ;;
          -h|--help)
            printf 'Usage: ocw bridge service stop [--manager auto|launchd|systemd|windows]\n'
            return
            ;;
          *) die "unknown bridge service stop option: $1" ;;
        esac
      done
      manager="$(bridge_service_manager "$manager_input")"
      bridge_service_stop_manager "$manager"
      printf 'OCW bridge service stopped: %s\n' "$manager"
      ;;
    status|doctor)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --manager) manager_input="$2"; shift 2 ;;
          --host) host="$2"; shift 2 ;;
          --port) port="$2"; shift 2 ;;
          --json) json=1; shift ;;
          -h|--help)
            printf 'Usage: ocw bridge service status [--manager auto|launchd|systemd|windows] [--host HOST] [--port PORT] [--json]\n'
            return
            ;;
          *) die "unknown bridge service status option: $1" ;;
        esac
      done
      manager="$(bridge_service_manager "$manager_input")"
      service_file="$(bridge_service_definition_path "$manager")"
      launcher="$(bridge_service_launcher_path "$manager")"
      runner="$(bridge_service_runner_path)"
      runtime_dir="$(bridge_global_runtime_dir)"
      stdout_log="$(bridge_service_stdout_log)"
      stderr_log="$(bridge_service_stderr_log)"
      [[ -f "$service_file" ]] && installed=true
      bridge_service_active "$manager" && active=true
      key="$(bridge_default_key)"
      bridge_health_check "$host" "$port" "$key" && health=true
      if [[ "$json" -eq 1 ]]; then
        printf '{\n'
        printf '  "schema_version": "ocw.bridge.service.status.v1",\n'
        printf '  "manager": '
        json_string "$manager"
        printf ',\n  "installed": %s,\n  "active": %s,\n  "health": %s,\n' "$installed" "$active" "$health"
        printf '  "service_file": '
        json_string "$service_file"
        printf ',\n  "launcher": '
        json_string "$launcher"
        printf ',\n  "runner": '
        json_string "$runner"
        printf ',\n  "runtime": '
        json_string "$runtime_dir"
        printf ',\n  "stdout_log": '
        json_string "$stdout_log"
        printf ',\n  "stderr_log": '
        json_string "$stderr_log"
        printf '\n}\n'
      else
        printf 'OCW bridge service: %s\n' "$manager"
        printf 'installed: %s\n' "$installed"
        printf 'active: %s\n' "$active"
        printf 'health: %s\n' "$health"
        printf 'service file: %s\n' "$service_file"
        printf 'launcher: %s\n' "$launcher"
        printf 'runner: %s\n' "$runner"
        printf 'runtime: %s\n' "$runtime_dir"
        printf 'stdout log: %s\n' "$stdout_log"
        printf 'stderr log: %s\n' "$stderr_log"
      fi
      ;;
    logs)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --lines) lines="$2"; shift 2 ;;
          -n) lines="$2"; shift 2 ;;
          -h|--help)
            printf 'Usage: ocw bridge service logs [--lines N]\n'
            return
            ;;
          *) die "unknown bridge service logs option: $1" ;;
        esac
      done
      [[ "$lines" =~ ^[0-9]+$ ]] || die "invalid log line count: $lines"
      stdout_log="$(bridge_service_stdout_log)"
      stderr_log="$(bridge_service_stderr_log)"
      printf '==> %s <==\n' "$stdout_log"
      if [[ -f "$stdout_log" ]]; then
        tail -n "$lines" "$stdout_log" || true
      fi
      printf '==> %s <==\n' "$stderr_log"
      if [[ -f "$stderr_log" ]]; then
        tail -n "$lines" "$stderr_log" || true
      fi
      ;;
    uninstall|remove|rm)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --manager) manager_input="$2"; shift 2 ;;
          --dry-run) dry_run=1; shift ;;
          --all) all=1; shift ;;
          -h|--help)
            printf 'Usage: ocw bridge service uninstall [--manager auto|launchd|systemd|windows] [--all] [--dry-run]\n'
            return
            ;;
          *) die "unknown bridge service uninstall option: $1" ;;
        esac
      done
      manager="$(bridge_service_manager "$manager_input")"
      bridge_service_uninstall_manager "$manager" "$dry_run"
      if [[ "$dry_run" -ne 1 ]]; then
        rm -f "$(bridge_service_definition_path "$manager")" "$(bridge_service_launcher_path "$manager")"
        if [[ "$all" -eq 1 ]]; then
          rm -rf "$(bridge_global_runtime_dir)"
        fi
      fi
      printf 'OCW bridge service uninstalled: %s\n' "$manager"
      ;;
    -h|--help|help)
      cat <<'EOF'
Usage:
  ocw bridge service install [--manager auto|launchd|systemd|windows] [--start] [--live] [--force] [--dry-run]
  ocw bridge service start [--manager auto|launchd|systemd|windows]
  ocw bridge service stop [--manager auto|launchd|systemd|windows]
  ocw bridge service status [--manager auto|launchd|systemd|windows] [--json]
  ocw bridge service logs [--lines N]
  ocw bridge service uninstall [--manager auto|launchd|systemd|windows] [--all] [--dry-run]

Managers:
- macOS: launchd user LaunchAgent with RunAtLoad and KeepAlive
- Linux: systemd --user service with Restart=always
- Windows: Task Scheduler logon task with RestartOnFailure
EOF
      ;;
    *)
      die "unknown bridge service command: $subcommand"
      ;;
  esac
}

bridge_bootstrap_command() {
  local manager_input="${OCW_BRIDGE_SERVICE_MANAGER:-auto}"
  local host="${OCW_BRIDGE_HOST:-127.0.0.1}"
  local port="${OCW_BRIDGE_PORT:-4000}"
  local timeout="${OCW_BRIDGE_START_TIMEOUT:-60}"
  local force=0 live=0 dry_run=0
  local -a install_args

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --manager) manager_input="$2"; shift 2 ;;
      --host) host="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      --timeout) timeout="$2"; shift 2 ;;
      --force) force=1; shift ;;
      --live) live=1; shift ;;
      --dry-run) dry_run=1; shift ;;
      -h|--help)
        cat <<'EOF'
Usage: ocw bridge bootstrap [--manager auto|launchd|systemd|windows] [--host HOST] [--port PORT] [--timeout SECONDS] [--force] [--live] [--dry-run]

Installs the global always-on OCW Bridge service and starts it. Run this once
per machine, then run `ocw bridge setup --force` inside each project.
EOF
        return
        ;;
      *) die "unknown bridge bootstrap option: $1" ;;
    esac
  done

  install_args=(install --manager "$manager_input" --host "$host" --port "$port" --timeout "$timeout" --start)
  [[ "$force" -eq 1 ]] && install_args+=(--force)
  [[ "$live" -eq 1 ]] && install_args+=(--live)
  [[ "$dry_run" -eq 1 ]] && install_args+=(--dry-run)
  bridge_service_command "${install_args[@]}"
  if [[ "$dry_run" -ne 1 ]]; then
    bridge_service_command status --manager "$manager_input" --host "$host" --port "$port"
  fi
}

bridge_codex_config_command() {
  local write=0
  local force=0
  local target=".codex/config.toml"
  local host="${OCW_BRIDGE_HOST:-127.0.0.1}"
  local port="${OCW_BRIDGE_PORT:-4000}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --write) write=1; shift ;;
      --force) force=1; shift ;;
      --project) target=".codex/config.toml"; shift ;;
      --global) target="${CODEX_HOME:-$HOME/.codex}/config.toml"; shift ;;
      --file) target="$2"; shift 2 ;;
      --host) host="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      --key) printf 'warning: --key is ignored by codex-config; set OCW_BRIDGE_KEY for persistent Codex auth\n' >&2; shift 2 ;;
      -h|--help)
        printf 'Usage: ocw bridge codex-config [--write] [--project|--global|--file FILE] [--force] [--host HOST] [--port PORT] [--key KEY]\n'
        return
        ;;
      *) die "unknown bridge codex-config option: $1" ;;
    esac
  done

  bridge_validate_port "$port"
  if ! bridge_loopback_host_ok "$host" && [[ "${OCW_BRIDGE_ALLOW_NON_LOOPBACK:-0}" != "1" ]]; then
    die "refusing to write bridge config for non-loopback host '$host' (set OCW_BRIDGE_ALLOW_NON_LOOPBACK=1 to override)"
  fi
  if [[ "$write" -eq 1 ]]; then
    bridge_write_codex_config "$target" "$force" "$port" "$host"
  else
    bridge_print_codex_config "$port" "$host"
  fi
}

bridge_setup_command() {
  local force=0
  local start=0
  local live=0
  local host="${OCW_BRIDGE_HOST:-127.0.0.1}"
  local port="${OCW_BRIDGE_PORT:-4000}"
  local timeout="${OCW_BRIDGE_START_TIMEOUT:-60}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=1; shift ;;
      --start) start=1; shift ;;
      --live) live=1; start=1; shift ;;
      --host) host="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      --timeout) timeout="$2"; shift 2 ;;
      -h|--help)
        cat <<'EOF'
Usage: ocw bridge setup [--force] [--start] [--live] [--host HOST] [--port PORT] [--timeout SECONDS]

Sets up the core Codex integration in the current project:
- bridge runtime and env template
- Codex model provider config
- bridge-native agent templates
- built-in worker/explorer overrides
- orchestration routing docs

Use `ocw bridge key set --stdin` once to save the OpenCode Go key globally.
Use `ocw bridge bootstrap --live` once per machine for the always-on bridge
service. --start is kept for foreground-style local testing.
EOF
        return
        ;;
      *) die "unknown bridge setup option: $1" ;;
    esac
  done

  bridge_validate_port "$port"
  ensure_ocw_gitignore_entries ".gitignore"

  if [[ "$force" -eq 1 ]]; then
    bridge_install_command --force
    bridge_agents_command sync --force
    bridge_workers_command sync --force
    bridge_orchestration_command sync --force
    bridge_codex_config_command --write --project --force --host "$host" --port "$port"
  else
    bridge_install_command
    bridge_agents_command sync
    bridge_workers_command sync
    bridge_orchestration_command sync
    bridge_codex_config_command --write --project --host "$host" --port "$port"
  fi

  bridge_workers_command doctor
  bridge_doctor_command --host "$host" --port "$port"

  if [[ "$start" -eq 1 ]]; then
    bridge_start_command --host "$host" --port "$port" --timeout "$timeout"
    if [[ "$live" -eq 1 ]]; then
      bridge_test_command --live --host "$host" --port "$port"
    fi
  fi

  if [[ "$start" -eq 1 ]]; then
    cat <<EOF
OCW bridge setup complete.

Next steps:
1. Start a new Codex session in this project so .codex/config.toml and .codex/agents/*.toml are loaded.
2. Ask Codex to spawn an explorer or worker for bounded tasks.
3. Re-run ocw bridge test --live any time you want to verify live model reachability.
EOF
  else
    cat <<EOF
OCW bridge setup complete.

Next steps:
1. Save your OpenCode Go key once for all projects:
   ocw bridge key set --stdin
2. Install and start the always-on bridge service once on this machine:
   ocw bridge bootstrap --live --timeout $timeout
3. Verify the service any time:
   ocw bridge service status
   ocw bridge test --live
4. Start a new Codex session in this project so .codex/config.toml and .codex/agents/*.toml are loaded.
5. Ask Codex to spawn an explorer or worker for bounded tasks.
EOF
  fi
}

