bridge_status_command() {
  local host="${OCW_BRIDGE_HOST:-127.0.0.1}"
  local port="${OCW_BRIDGE_PORT:-4000}"
  local key
  local key_arg=0
  local json=0
  local state_dir env_file pid_file log_file runtime_dir running=false health_ok=false pid="" tracked_pid_running=false

  key="$(bridge_default_key)"
  state_dir="$(bridge_project_dir)"
  env_file="$state_dir/opencode-go.env"
  pid_file="$state_dir/bridge.pid"
  log_file="$state_dir/bridge.log"
  runtime_dir="$(bridge_runtime_dir)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --host) host="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      --key) key="$2"; key_arg=1; shift 2 ;;
      --json) json=1; shift ;;
      -h|--help)
        printf 'Usage: ocw bridge status [--host HOST] [--port PORT] [--key KEY] [--json]\n'
        return
        ;;
      *) die "unknown bridge status option: $1" ;;
    esac
  done

  bridge_validate_port "$port"
  bridge_load_credentials "$env_file"
  if [[ "$key_arg" -ne 1 ]]; then
    key="$(bridge_default_key)"
  fi

  if bridge_health_check "$host" "$port" "$key"; then
    health_ok=true
    running=true
  elif bridge_pid_running "$pid_file"; then
    tracked_pid_running=true
    running=true
  fi
  [[ -f "$pid_file" ]] && pid="$(cat "$pid_file" 2>/dev/null || true)"

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.bridge.status.v1",\n'
    printf '  "running": %s,\n' "$running"
    printf '  "health": %s,\n' "$health_ok"
    printf '  "tracked_pid_running": %s,\n' "$tracked_pid_running"
    printf '  "url": '
    json_string "http://$host:$port/v1"
    printf ',\n  "pid": '
    json_string "$pid"
    printf ',\n  "runtime": '
    json_string "$runtime_dir/bridge.py"
    printf ',\n  "log": '
    json_string "$log_file"
    printf '\n}\n'
    return
  fi

  printf 'OCW bridge: %s\n' "$([[ "$running" == true ]] && printf 'running' || printf 'stopped')"
  printf 'health: %s\n' "$health_ok"
  printf 'tracked pid running: %s\n' "$tracked_pid_running"
  printf 'url: http://%s:%s/v1\n' "$host" "$port"
  [[ -n "$pid" ]] && printf 'pid: %s\n' "$pid"
  printf 'runtime: %s\n' "$runtime_dir/bridge.py"
  printf 'log: %s\n' "$log_file"
}

bridge_start_command() {
  local host="${OCW_BRIDGE_HOST:-127.0.0.1}"
  local port="${OCW_BRIDGE_PORT:-4000}"
  local key
  local key_arg=0
  local foreground=0
  local timeout="${OCW_BRIDGE_START_TIMEOUT:-15}"
  local state_dir runtime_dir env_file pid_file log_file pid health_status wait_status

  key="$(bridge_default_key)"
  state_dir="$(bridge_project_dir)"
  runtime_dir="$(bridge_runtime_dir)"
  env_file="$state_dir/opencode-go.env"
  pid_file="$state_dir/bridge.pid"
  log_file="$state_dir/bridge.log"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --host) host="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      --key) key="$2"; key_arg=1; shift 2 ;;
      --timeout) timeout="$2"; shift 2 ;;
      --foreground) foreground=1; shift ;;
      -h|--help)
        printf 'Usage: ocw bridge start [--host HOST] [--port PORT] [--key KEY] [--timeout SECONDS] [--foreground]\n'
        return
        ;;
      *) die "unknown bridge start option: $1" ;;
    esac
  done

  bridge_validate_port "$port"
  [[ "$timeout" =~ ^[0-9]+$ ]] || die "invalid bridge start timeout: $timeout"
  (( 10#$timeout >= 1 && 10#$timeout <= 300 )) || die "invalid bridge start timeout: $timeout (must be 1-300)"
  [[ -f "$runtime_dir/bridge.py" ]] || die "bridge runtime not found: $runtime_dir/bridge.py"
  require_command "$PYTHON_BIN"
  if ! bridge_loopback_host_ok "$host" && [[ "${OCW_BRIDGE_ALLOW_NON_LOOPBACK:-0}" != "1" ]]; then
    die "refusing to bind bridge to non-loopback host '$host' (set OCW_BRIDGE_ALLOW_NON_LOOPBACK=1 to override)"
  fi

  mkdir -p "$state_dir"
  bridge_load_credentials "$env_file"
  if [[ "$key_arg" -ne 1 ]]; then
    if [[ -z "${OCW_BRIDGE_KEY:-${PROXY_API_KEY:-${LITELLM_MASTER_KEY:-}}}" ]]; then
      key="$(bridge_proxy_key_get_or_create)"
    else
      key="$(bridge_default_key)"
    fi
  fi

  if bridge_health_check "$host" "$port" "$key"; then
    printf 'OCW bridge already running: http://%s:%s/v1\n' "$host" "$port"
    return
  fi

  health_status="$(bridge_health_status "$host" "$port" "$key")"
  if [[ "$health_status" == "401" || "$health_status" == "403" ]]; then
    die "bridge is reachable on http://$host:$port/health but the proxy key was rejected; pass --key, set OCW_BRIDGE_KEY, or stop the existing bridge"
  fi
  if bridge_pid_running "$pid_file"; then
    die "tracked bridge process is already running but health did not pass; inspect $(bridge_project_dir)/bridge.log or run 'ocw bridge stop'"
  fi
  if [[ -f "$pid_file" ]]; then
    rm -f "$pid_file"
  fi

  export LITELLM_MASTER_KEY="$key"
  export PROXY_API_KEY="$key"
  export PROXY_HOST="$host"
  export PROXY_PORT="$port"
  export PROXY_STATE_DB="${PROXY_STATE_DB:-$state_dir/state.sqlite3}"
  export FORCE_SINGLE_TOOL_INSTRUCTIONS="${FORCE_SINGLE_TOOL_INSTRUCTIONS:-1}"
  export FALLBACK_MODEL_MAP_JSON="${FALLBACK_MODEL_MAP_JSON:-{\"deepseek-v4-pro\":[\"kimi-k2.6\",\"deepseek-v4-flash\"],\"kimi-k2.6\":[\"deepseek-v4-pro\"],\"deepseek-v4-flash\":[\"kimi-k2.6\"]}}"

  if [[ -z "${OPENCODE_GO_API_KEY:-}" ]]; then
    printf 'warning: OPENCODE_GO_API_KEY is not set; health works, live model calls will fail until configured\n' >&2
  fi

  if [[ "$foreground" -eq 1 ]]; then
    exec "$PYTHON_BIN" "$runtime_dir/bridge.py" --host "$host" --port "$port"
  fi

  nohup "$PYTHON_BIN" "$runtime_dir/bridge.py" --host "$host" --port "$port" > "$log_file" 2>&1 &
  pid=$!
  printf '%s\n' "$pid" > "$pid_file"
  wait_status=0
  bridge_wait_for_health "$host" "$port" "$key" "$pid" "$timeout" || wait_status=$?
  if [[ "$wait_status" -eq 0 ]]; then
    printf 'OCW bridge started: http://%s:%s/v1\n' "$host" "$port"
    printf 'pid: %s\n' "$pid"
    printf 'log: %s\n' "$log_file"
  elif [[ "$wait_status" -eq 2 ]]; then
    rm -f "$pid_file"
    die "OCW bridge exited before health check passed; see log: $log_file"
  else
    die "OCW bridge did not pass health within ${timeout}s; see log: $log_file"
  fi
}

bridge_stop_command() {
  local state_dir pid_file pid

  state_dir="$(bridge_project_dir)"
  pid_file="$state_dir/bridge.pid"
  [[ -f "$pid_file" ]] || {
    printf 'OCW bridge is not tracked as running\n'
    return
  }
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" >/dev/null 2>&1; then
    kill "$pid" >/dev/null 2>&1 || true
    sleep 1
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill -KILL "$pid" >/dev/null 2>&1 || true
    fi
    printf 'OCW bridge stopped: %s\n' "$pid"
  else
    printf 'OCW bridge pid is not running: %s\n' "$pid"
  fi
  rm -f "$pid_file"
}

