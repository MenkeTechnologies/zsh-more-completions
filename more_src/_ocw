        die "unknown support bundle option: $1"
        ;;
    esac
  done

  stamp="${OCW_TEST_STAMP:-$(date +%Y%m%d-%H%M%S)}"
  bundle_dir="$(mktemp -d "${TMPDIR:-/tmp}/ocw-support.XXXXXX")"
  mkdir -p "$bundle_dir/support"

  {
    printf 'OCW support bundle\n'
    printf 'created_at=%s\n' "${OCW_TEST_CREATED_AT:-$(date -u +%Y-%m-%dT%H:%M:%SZ)}"
    printf 'cwd=%s\n' "$PWD"
    printf 'version=%s\n' "$VERSION"
    printf 'include_summary=%s\n' "$include_summary"
  } > "$bundle_dir/support/README.txt"

  {
    printf 'ocw: %s\n' "$VERSION"
    if have_command "$OPENCODE_BIN"; then
      printf 'opencode: %s\n' "$("$OPENCODE_BIN" --version 2>/dev/null || "$OPENCODE_BIN" version 2>/dev/null || true)"
    else
      printf 'opencode: missing\n'
    fi
    if have_command "$GIT_BIN"; then
      printf 'git: %s\n' "$("$GIT_BIN" --version 2>/dev/null || true)"
    else
      printf 'git: missing\n'
    fi
    if have_command "$GH_BIN"; then
      printf 'gh: %s\n' "$("$GH_BIN" --version 2>/dev/null | head -n 1 || true)"
    else
      printf 'gh: missing\n'
    fi
    if have_command "$NODE_BIN"; then
      printf 'node: %s\n' "$("$NODE_BIN" --version 2>/dev/null || true)"
    else
      printf 'node: missing\n'
    fi
  } > "$bundle_dir/support/versions.txt"

  set +e
  "$OCW_SELF" doctor --deep --json > "$bundle_dir/support/doctor.json" 2> "$bundle_dir/support/doctor.stderr"
  set -e

  config_source="${OCW_CONFIG_FILE:-}"
  [[ -n "$config_source" ]] || config_source="$(default_project_config_path)"
  sanitize_support_file "$config_source" "$bundle_dir/support/config.sanitized.toml"

  if have_command "$GIT_BIN" && git_is_repo "$PWD"; then
    "$GIT_BIN" status --short > "$bundle_dir/support/git-status.txt" || true
    "$GIT_BIN" rev-parse --show-toplevel > "$bundle_dir/support/git-root.txt" 2>/dev/null || true
    "$GIT_BIN" rev-parse HEAD > "$bundle_dir/support/git-head.txt" 2>/dev/null || true
  fi

  if [[ "$include_latest" -eq 1 ]]; then
    root_abs="$(prepare_output_root "$out_base")"
    set +e
    run_dir="$(resolve_run_dir "$root_abs" "latest" 2>/dev/null)"
    set -e
    if [[ -n "${run_dir:-}" ]]; then
      latest_dir="$bundle_dir/support/latest"
      mkdir -p "$latest_dir"
      cp "$run_dir/metadata.txt" "$latest_dir/metadata.txt" 2>/dev/null || true
      set +e
      "$OCW_SELF" manifest "$run_dir" --json > "$latest_dir/manifest.json" 2> "$latest_dir/manifest.stderr"
      "$OCW_SELF" audit "$run_dir" --json > "$latest_dir/audit.json" 2> "$latest_dir/audit.stderr"
      set -e
      if [[ "$include_summary" -eq 1 && -f "$run_dir/summary.md" ]]; then
        cp "$run_dir/summary.md" "$latest_dir/summary.md"
      fi
    else
      printf 'No latest run found under %s\n' "$root_abs" > "$bundle_dir/support/latest.txt"
    fi
  fi

  if [[ -z "$out_file" ]]; then
    out_file="$PWD/ocw-support-$stamp.tar.gz"
  fi
  mkdir -p "$(dirname "$out_file")"
  archive="$(cd "$bundle_dir" && tar -czf "$out_file" support && printf '%s\n' "$out_file")"
  rm -rf "$bundle_dir"
  printf 'OCW support bundle: %s\n' "$archive"
}

mcp_audit_command() {
  local json=0
  local baseline=""
  local write_baseline=""
  local server="$OCW_HOME/mcp/ocw-mcp.js"
  local checks_file sha overall exit_code=0 first severity id message tool pattern
  local -a required_tools=(
    ocw_run ocw_last ocw_show ocw_manifest ocw_audit ocw_report ocw_eval
    ocw_doctor ocw_apply_check ocw_apply ocw_stats ocw_models ocw_keys ocw_route
    ocw_tournament ocw_memory ocw_dashboard ocw_delegate ocw_verdict
    ocw_savings ocw_backend ocw_bridge ocw_mcp_audit
  )

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        json=1
        shift
        ;;
      --baseline)
        [[ $# -ge 2 ]] || die "--baseline requires a file"
        baseline="$2"
        shift 2
        ;;
      --write-baseline)
        [[ $# -ge 2 ]] || die "--write-baseline requires a file"
        write_baseline="$2"
        shift 2
        ;;
      -h|--help)
        printf 'Usage: ocw mcp audit [--json] [--baseline FILE] [--write-baseline FILE]\n'
        return
        ;;
      *)
        die "unknown mcp audit option: $1"
        ;;
    esac
  done

  checks_file="$(mktemp "${TMPDIR:-/tmp}/ocw-mcp-audit.XXXXXX")"
  if [[ -f "$server" ]]; then
    printf 'ok\tserver\t%s exists\n' "$server" >> "$checks_file"
  else
    printf 'fail\tserver\t%s is missing\n' "$server" >> "$checks_file"
  fi

  if have_command "$NODE_BIN" && [[ -f "$server" ]]; then
    if "$NODE_BIN" --check "$server" >/dev/null 2>&1; then
      printf 'ok\tnode_check\tserver parses with node --check\n' >> "$checks_file"
    else
      printf 'fail\tnode_check\tserver failed node --check\n' >> "$checks_file"
    fi
  else
    printf 'fail\tnode_check\tnode is missing or server is unavailable\n' >> "$checks_file"
  fi

  sha=""
  if [[ -f "$server" ]]; then
    sha="$(file_sha256 "$server")"
    printf 'ok\tsha256\t%s\n' "$sha" >> "$checks_file"
  fi

  for tool in "${required_tools[@]}"; do
    if [[ -f "$server" ]] && grep -Fq "name: '$tool'" "$server"; then
      printf 'ok\ttool_%s\ttool is declared\n' "$tool" >> "$checks_file"
    else
      printf 'fail\ttool_%s\ttool is missing\n' "$tool" >> "$checks_file"
    fi
  done

  if [[ -f "$server" ]]; then
    for pattern in 'ignore (all )?(previous|prior) instructions' 'exfiltrat' 'secret token' 'api[_ -]?key'; do
      if grep -Eiq "$pattern" "$server"; then
        printf 'warn\tsuspicious_source\tpattern matched: %s\n' "$pattern" >> "$checks_file"
      fi
    done
  fi

  if [[ -n "$baseline" ]]; then
    if [[ -f "$baseline" ]]; then
      if grep -Fxq "$sha" "$baseline"; then
        printf 'ok\tbaseline\tserver sha matches %s\n' "$baseline" >> "$checks_file"
      else
        printf 'fail\tbaseline\tserver sha does not match %s\n' "$baseline" >> "$checks_file"
      fi
    else
      printf 'fail\tbaseline\tbaseline not found: %s\n' "$baseline" >> "$checks_file"
    fi
  fi

  if [[ -n "$write_baseline" ]]; then
    [[ -n "$sha" ]] || die "cannot write baseline without server sha"
    ensure_parent_dir "$write_baseline"
    printf '%s\n' "$sha" > "$write_baseline"
    printf 'ok\twrite_baseline\twrote %s\n' "$write_baseline" >> "$checks_file"
  fi

  overall="ok"
  if awk -F '\t' '$1 == "fail" { found = 1 } END { exit(found ? 0 : 1) }' "$checks_file"; then
    overall="fail"
    exit_code=1
  elif awk -F '\t' '$1 == "warn" { found = 1 } END { exit(found ? 0 : 1) }' "$checks_file"; then
    overall="warn"
  fi

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.mcp.audit.v1",\n'
    printf '  "server": '
    json_string "$server"
    printf ',\n  "sha256": '
    json_string "$sha"
    printf ',\n  "overall": '
    json_string "$overall"
    printf ',\n  "checks": [\n'
    first=1
    while IFS=$'\t' read -r severity id message; do
      [[ -n "$severity" ]] || continue
      if [[ "$first" -eq 0 ]]; then
        printf ',\n'
      fi
      printf '    { "severity": '
      json_string "$severity"
      printf ', "id": '
      json_string "$id"
      printf ', "message": '
      json_string "$message"
      printf ' }'
      first=0
    done < "$checks_file"
    printf '\n  ]\n}\n'
  else
    printf 'OCW MCP audit: %s\n' "$server"
    printf 'overall: %s\n\n' "$overall"
    while IFS=$'\t' read -r severity id message; do
      [[ -n "$severity" ]] || continue
      printf '[%s] %s: %s\n' "$severity" "$id" "$message"
    done < "$checks_file"
  fi

  rm -f "$checks_file"
  return "$exit_code"
}

mcp_doctor_command() {
  local json=0
