route_set_record() {
  local mode="$1"
  local model="$2"
  local reason="${3:-manual}"
  local route_file="${4:-$(routes_file_path)}"

  validate_worker_mode "$mode"
  [[ -n "$model" ]] || die "route model is required"
  ensure_parent_dir "$route_file"
  if [[ ! -f "$route_file" ]]; then
    printf 'mode\tmodel\treason\tcreated_at\n' > "$route_file"
  fi
  printf '%s\t%s\t%s\t%s\n' "$mode" "$model" "$reason" "$(now_utc)" >> "$route_file"
}

route_command() {
  local subcommand="${1:-explain}"
  shift || true
  local mode=""
  local model=""
  local reason="manual"
  local json=0
  local record route_model source detail first route_file candidate cache strict=0 status=0 cache_exists=false ok

  case "$subcommand" in
    explain)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json) json=1; shift ;;
          -h|--help)
            printf 'Usage: ocw route explain [MODE] [--json]\n'
            return
            ;;
          -*)
            die "unknown route explain option: $1"
            ;;
          *)
            [[ -z "$mode" ]] || die "route explain accepts one mode"
            mode="$1"
            shift
            ;;
        esac
      done

      if [[ -n "$mode" ]]; then
        validate_worker_mode "$mode"
      fi

      if [[ "$json" -eq 1 ]]; then
        printf '{\n'
        printf '  "schema_version": "ocw.route.v1",\n'
        printf '  "routes_file": '
        json_string "$(routes_file_path)"
        printf ',\n  "routes": [\n'
        first=1
        for candidate in cheap explore scan review patch; do
          [[ -z "$mode" || "$candidate" == "$mode" ]] || continue
          record="$(route_effective_model "$candidate")"
          route_model="$(printf '%s\n' "$record" | awk -F '\t' '{ print $1 }')"
          source="$(printf '%s\n' "$record" | awk -F '\t' '{ print $2 }')"
          detail="$(printf '%s\n' "$record" | awk -F '\t' '{ print $3 }')"
          if [[ "$first" -eq 0 ]]; then
            printf ',\n'
          fi
          printf '    { "mode": '
          json_string "$candidate"
          printf ', "model": '
          json_string "$route_model"
          printf ', "source": '
          json_string "$source"
          printf ', "detail": '
          json_string "$detail"
          printf ' }'
          first=0
        done
        printf '\n  ]\n}\n'
      else
        route_file="$(routes_file_path)"
        printf 'OCW route file: %s\n' "$route_file"
        for candidate in cheap explore scan review patch; do
          [[ -z "$mode" || "$candidate" == "$mode" ]] || continue
          record="$(route_effective_model "$candidate")"
          route_model="$(printf '%s\n' "$record" | awk -F '\t' '{ print $1 }')"
          source="$(printf '%s\n' "$record" | awk -F '\t' '{ print $2 }')"
          detail="$(printf '%s\n' "$record" | awk -F '\t' '{ print $3 }')"
          if [[ -n "$detail" ]]; then
            printf '%-7s %s (%s: %s)\n' "$candidate" "$route_model" "$source" "$detail"
          else
            printf '%-7s %s (%s)\n' "$candidate" "$route_model" "$source"
          fi
        done
      fi
      ;;
    set)
      [[ $# -ge 2 ]] || die "Usage: ocw route set MODE MODEL [--reason TEXT]"
      mode="$1"
      model="$2"
      shift 2
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --reason)
            [[ $# -ge 2 ]] || die "--reason requires a value"
            reason="$2"
            shift 2
            ;;
          -h|--help)
            printf 'Usage: ocw route set MODE MODEL [--reason TEXT]\n'
            return
            ;;
          *)
            die "unknown route set option: $1"
            ;;
        esac
      done
      route_set_record "$mode" "$model" "$reason"
      printf 'OCW route set: %s -> %s\n' "$mode" "$model"
      ;;
    doctor)
      cache="$(models_cache_path)"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --cache)
            [[ $# -ge 2 ]] || die "--cache requires a value"
            cache="$2"
            shift 2
            ;;
          --json)
            json=1
            shift
            ;;
          --strict)
            strict=1
            shift
            ;;
          -h|--help)
            printf 'Usage: ocw route doctor [--cache FILE] [--json] [--strict]\n'
            return
            ;;
          *)
            die "unknown route doctor option: $1"
            ;;
        esac
      done

      [[ -f "$cache" ]] && cache_exists=true
      if [[ "$strict" -eq 1 && "$cache_exists" != true ]]; then
        status=1
      fi

      if [[ "$json" -eq 1 ]]; then
        printf '{\n'
        printf '  "schema_version": "ocw.route.doctor.v1",\n'
        printf '  "cache": '
        json_string "$cache"
        printf ',\n  "cache_exists": %s,\n  "strict": %s,\n  "checks": [\n' "$cache_exists" "$([[ "$strict" -eq 1 ]] && printf true || printf false)"
      else
        printf 'OCW route doctor\n'
        printf 'cache: %s (%s)\n' "$cache" "$([[ "$cache_exists" == true ]] && printf synced || printf "using built-in fallback catalog")"
      fi

      first=1
      for candidate in cheap explore scan review patch; do
        record="$(route_effective_model "$candidate")"
        route_model="$(printf '%s\n' "$record" | awk -F '\t' '{ print $1 }')"
        source="$(printf '%s\n' "$record" | awk -F '\t' '{ print $2 }')"
        detail="$(printf '%s\n' "$record" | awk -F '\t' '{ print $3 }')"
        if model_in_catalog "$cache" "$route_model"; then
          ok=true
        else
          ok=false
          status=1
        fi
        if [[ "$json" -eq 1 ]]; then
          if [[ "$first" -eq 0 ]]; then
            printf ',\n'
          fi
          printf '    { "mode": '
          json_string "$candidate"
          printf ', "model": '
          json_string "$route_model"
          printf ', "source": '
          json_string "$source"
          printf ', "detail": '
          json_string "$detail"
          printf ', "known": %s }' "$ok"
          first=0
        else
          printf '[%s] %-7s %s (%s)\n' "$([[ "$ok" == true ]] && printf ok || printf missing)" "$candidate" "$route_model" "$source"
        fi
      done

      if [[ "$json" -eq 1 ]]; then
        printf '\n  ],\n  "ok": %s\n}\n' "$([[ "$status" -eq 0 ]] && printf true || printf false)"
      fi
      return "$status"
      ;;
    path)
      printf '%s\n' "$(routes_file_path)"
      ;;
    -h|--help|help)
      cat <<'EOF'
Usage:
  ocw route explain [MODE] [--json]
  ocw route set MODE MODEL [--reason TEXT]
  ocw route doctor [--cache FILE] [--json] [--strict]
  ocw route path
EOF
      ;;
    *)
      die "unknown route command: $subcommand"
      ;;
  esac
}

