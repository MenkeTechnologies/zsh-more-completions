models_json_ids() {
  local file="$1"

  have_command "$NODE_BIN" || return 1
  "$NODE_BIN" - "$file" <<'NODE'
const fs = require('node:fs');
const file = process.argv[2];
const input = JSON.parse(fs.readFileSync(file, 'utf8'));
const ids = [];
const seen = new Set();

function add(value, forceGoProvider = false) {
  if (typeof value !== 'string') return;
  const trimmed = value.trim();
  if (!trimmed) return;
  const id = trimmed.startsWith('opencode-go/') ? trimmed : (forceGoProvider && !trimmed.includes('/') ? `opencode-go/${trimmed}` : '');
  if (!id) return;
  if (seen.has(id)) return;
  seen.add(id);
  ids.push(id);
}

function walk(value) {
  if (typeof value === 'string') {
    add(value);
    return;
  }
  if (Array.isArray(value)) {
    value.forEach(walk);
    return;
  }
  if (!value || typeof value !== 'object') return;
  const ownedBy = typeof value.owned_by === 'string' ? value.owned_by.toLowerCase() : '';
  const provider = typeof value.provider === 'string' ? value.provider.toLowerCase() : '';
  const forceGoProvider = ownedBy === 'opencode' || ownedBy === 'opencode-go' || provider === 'opencode' || provider === 'opencode-go';
  for (const key of ['id', 'model', 'name', 'slug']) {
    add(value[key], forceGoProvider);
  }
  for (const nested of ['models', 'data', 'items', 'results']) {
    if (value[nested] !== undefined) walk(value[nested]);
  }
  if (value['opencode-go'] !== undefined) walk(value['opencode-go']);
}

walk(input);
for (const id of ids) console.log(id);
NODE
}

