    printf ',\n  "ok": %s,\n' "$([[ "$status" -eq 0 ]] && printf true || printf false)"
    printf '  "capabilities": ["tools", "resources", "prompts"],\n'
    printf '  "tools": ["ocw_run", "ocw_last", "ocw_show", "ocw_manifest", "ocw_audit", "ocw_report", "ocw_eval", "ocw_doctor", "ocw_apply_check", "ocw_apply", "ocw_stats", "ocw_models", "ocw_keys", "ocw_route", "ocw_tournament", "ocw_memory", "ocw_dashboard", "ocw_delegate", "ocw_verdict", "ocw_savings", "ocw_backend", "ocw_bridge", "ocw_mcp_audit"]\n'
    printf '}\n'
  else
    printf 'OCW MCP server: %s\n' "$server"
    if [[ -n "$node_path" ]]; then
      printf 'node: %s\n' "$node_path"
    else
      printf 'node: missing\n'
    fi
    if [[ "$status" -eq 0 ]]; then
      printf 'mcp: ok\n'
      printf 'capabilities: tools, resources, prompts\n'
    else
      printf 'mcp: failed\n'
    fi
  fi

  return "$status"
}

