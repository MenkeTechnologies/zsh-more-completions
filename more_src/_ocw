  platform="$(bridge_platform_id)"
  if [[ -n "${OCW_GLOBAL_STATE_DIR:-}" ]]; then
    bridge_expand_user_path "$OCW_GLOBAL_STATE_DIR"
  elif [[ "$platform" == "macos" ]]; then
    printf '%s\n' "$HOME/Library/Application Support/ocw/state"
  elif [[ "$platform" == "windows" ]]; then
    bridge_expand_user_path "${LOCALAPPDATA:-$HOME/AppData/Local}/ocw/state"
  else
    bridge_expand_user_path "${XDG_STATE_HOME:-$HOME/.local/state}/ocw"
  fi
}

bridge_global_log_dir() {
  local platform

  platform="$(bridge_platform_id)"
  if [[ -n "${OCW_BRIDGE_LOG_DIR:-}" ]]; then
    bridge_expand_user_path "$OCW_BRIDGE_LOG_DIR"
  elif [[ "$platform" == "macos" ]]; then
    printf '%s\n' "$HOME/Library/Logs/ocw"
  elif [[ "$platform" == "windows" ]]; then
