  ocw bridge workers diff [--dir DIR]
  ocw bridge workers doctor [--dir DIR]
EOF
      return
      ;;
    *) die "unknown bridge workers command: $subcommand" ;;
  esac

  source_dir="$(bridge_runtime_dir)"
  if [[ ! -d "$source_dir/workers" && -d "$(bridge_vendor_dir)/workers" ]]; then
    source_dir="$(bridge_vendor_dir)"
  fi
  [[ -d "$source_dir/workers" ]] || die "bridge worker overrides not found: $source_dir/workers"

  case "$subcommand" in
    sync)
      mkdir -p "$target_dir"
      for file in "$source_dir"/workers/*.toml; do
        [[ -f "$file" ]] || die "no bridge worker override templates found: $source_dir/workers"
        copy_if_needed "$file" "$target_dir/$(basename "$file")" "Codex built-in worker override" "$force"
      done
      printf 'OCW bridge worker overrides synced: %s\n' "$target_dir"
      ;;
    diff)
      for file in "$source_dir"/workers/*.toml; do
        [[ -f "$file" ]] || die "no bridge worker override templates found: $source_dir/workers"
        base="$(basename "$file")"
        target="$target_dir/$base"
        if [[ ! -f "$target" ]]; then
          printf 'missing: %s\n' "$target"
          status=1
        elif cmp -s "$file" "$target"; then
          printf 'ok: %s\n' "$target"
        else
          printf 'changed: %s\n' "$target"
          status=1
        fi
      done
      return "$status"
      ;;
    doctor)
      worker="$target_dir/worker.toml"
      explorer="$target_dir/explorer.toml"
      if [[ -f "$worker" ]] \
        && grep -Fq 'name = "worker"' "$worker" \
        && grep -Fq 'sandbox_mode = "workspace-write"' "$worker"; then
        worker_ok=true
      fi
      if [[ -f "$explorer" ]] \
        && grep -Fq 'name = "explorer"' "$explorer" \
        && grep -Fq 'sandbox_mode = "read-only"' "$explorer"; then
        explorer_ok=true
      fi
      if [[ -f "$worker" && -f "$explorer" ]] \
        && grep -Fq 'model_provider = "opencode_bridge"' "$worker" \
        && grep -Fq 'model_provider = "opencode_bridge"' "$explorer"; then
        provider_ok=true
      fi
      if [[ -f "$worker" && -f "$explorer" ]] \
        && grep -Eq 'model = "ocg-[^"]+"' "$worker" \
        && grep -Eq 'model = "ocg-[^"]+"' "$explorer"; then
        model_ok=true
      fi
      overall="ok"
      if [[ "$worker_ok" != true || "$explorer_ok" != true || "$provider_ok" != true || "$model_ok" != true ]]; then
        overall="fail"
        status=1
      fi
      printf 'OCW bridge workers doctor: %s\n' "$overall"
      printf 'agent dir: %s\n' "$target_dir"
      printf 'source dir: %s\n' "$source_dir/workers"
      printf 'worker override: %s\n' "$worker_ok"
      printf 'explorer override: %s\n' "$explorer_ok"
      printf 'opencode bridge provider: %s\n' "$provider_ok"
      printf 'ocg models: %s\n' "$model_ok"
      return "$status"
      ;;
  esac
}

