    <string>$(xml_escape "$launcher")</string>
  </array>
  <key>WorkingDirectory</key>
  <string>$(xml_escape "$runtime_dir")</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$(xml_escape "$stdout_log")</string>
  <key>StandardErrorPath</key>
