write_default_config() {
  local target="$1"
  local force="$2"

  if [[ -e "$target" && "$force" -ne 1 ]]; then
    printf 'Kept existing config: %s\n' "$target"
    return
  fi

  print_default_config > "$target"

  printf 'Installed config: %s\n' "$target"
}

install_agent_skill() {
  local label="$1"
  local skills_dir="$2"
  local source="$OCW_HOME/skills/$SKILL_NAME/SKILL.md"
  local target="$skills_dir/$SKILL_NAME"

  [[ -f "$source" ]] || die "skill source not found: $source"
  mkdir -p "$target"
  cp "$source" "$target/SKILL.md"
  printf 'Installed %s skill: %s\n' "$label" "$target"
}

resolved_symlink_target() {
  local link="$1"
  local target dir

  target="$(readlink "$link" 2>/dev/null || true)"
  [[ -n "$target" ]] || return 1
  case "$target" in
    /*)
      printf '%s\n' "$target"
      ;;
    *)
      dir="$(cd "$(dirname "$link")" >/dev/null 2>&1 && pwd -P)"
      printf '%s/%s\n' "$dir" "$target"
      ;;
  esac
}

uninstall_remove_path() {
  local label="$1"
  local target="$2"
  local yes="$3"

  if [[ ! -e "$target" && ! -L "$target" ]]; then
    printf 'Not installed %s: %s\n' "$label" "$target"
    return
  fi

  if [[ "$yes" -eq 1 ]]; then
    rm -rf "$target"
    printf 'Removed %s: %s\n' "$label" "$target"
  else
    printf 'Would remove %s: %s\n' "$label" "$target"
  fi
}

uninstall_remove_file_if_matching() {
  local label="$1"
  local target="$2"
  local template="$3"
  local force="$4"
  local yes="$5"

  if [[ ! -e "$target" ]]; then
    printf 'Not installed %s: %s\n' "$label" "$target"
    return
  fi

  if [[ "$force" -ne 1 && ! -f "$template" ]]; then
    printf 'Kept %s: template missing for comparison: %s\n' "$label" "$target"
    return
  fi

  if [[ "$force" -ne 1 ]] && ! cmp -s "$target" "$template"; then
    printf 'Kept modified %s: %s (pass --force to remove)\n' "$label" "$target"
    return
  fi

  uninstall_remove_path "$label" "$target" "$yes"
}

uninstall_remove_gitignore_entries() {
  local yes="$1"
  local gitignore=".gitignore"
  local tmp

  [[ -f "$gitignore" ]] || {
    printf 'Not installed gitignore entries: %s\n' "$gitignore"
    return
  }

  if ! grep -Fxq ".codex/opencode-workers/" "$gitignore" && \
    ! grep -Fxq ".codex/opencode-worktrees/" "$gitignore" && \
    ! grep -Fxq ".codex/ocw-keys.tsv" "$gitignore" && \
    ! grep -Fxq ".codex/ocw-bridge/" "$gitignore" && \
    ! grep -Fxq ".codex/ocw-bridge-results/" "$gitignore" && \
    ! grep -Fxq ".codex/ocw-bridge-worktrees/" "$gitignore"; then
    printf 'Not installed gitignore entries: %s\n' "$gitignore"
    return
  fi

  if [[ "$yes" -ne 1 ]]; then
    printf 'Would remove OCW gitignore entries: %s\n' "$gitignore"
    return
  fi

  tmp="$(mktemp "${TMPDIR:-/tmp}/ocw-gitignore.XXXXXX")"
  awk '$0 != ".codex/opencode-workers/" && $0 != ".codex/opencode-worktrees/" && $0 != ".codex/ocw-keys.tsv" && $0 != ".codex/ocw-bridge/" && $0 != ".codex/ocw-bridge-results/" && $0 != ".codex/ocw-bridge-worktrees/" { print }' "$gitignore" > "$tmp"
  mv "$tmp" "$gitignore"
  printf 'Removed OCW gitignore entries: %s\n' "$gitignore"
}

uninstall_command() {
  local remove_bin=1
  local remove_skills=1
  local remove_project=0
  local scope_set=0
  local yes=0
  local force=0
  local install_dir="${OCW_INSTALL_DIR:-$HOME/.local/bin}"
  local bin_path
  local bin_source="$OCW_HOME/bin/ocw"
  local bin_target
  local codex_skills_dir claude_skills_dir opencode_home_dir opencode_skills_dir agents_skills_dir
  local config_template

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --bin)
        if [[ "$scope_set" -eq 0 ]]; then
          remove_bin=0
          remove_skills=0
          remove_project=0
          scope_set=1
        fi
        remove_bin=1
        shift
        ;;
      --skills)
        if [[ "$scope_set" -eq 0 ]]; then
          remove_bin=0
          remove_skills=0
          remove_project=0
          scope_set=1
        fi
        remove_skills=1
        shift
        ;;
      --project)
        if [[ "$scope_set" -eq 0 ]]; then
          remove_bin=0
          remove_skills=0
          remove_project=0
          scope_set=1
        fi
        remove_project=1
        shift
        ;;
      --all)
        remove_bin=1
        remove_skills=1
        remove_project=1
        scope_set=1
        shift
        ;;
      --install-dir)
        [[ $# -ge 2 ]] || die "--install-dir requires a value"
        install_dir="$2"
        shift 2
        ;;
      --dry-run)
        yes=0
        shift
        ;;
      --yes)
        yes=1
        shift
        ;;
      --force)
        force=1
        shift
        ;;
      -h|--help)
        cat <<'EOF'
Usage: ocw uninstall [--bin] [--skills] [--project] [--all] [--dry-run] [--yes] [--force]

Default scope is --bin --skills. Without --yes, uninstall prints what it would remove.

Scopes:
  --bin          Remove the installed ocw launcher from ~/.local/bin or --install-dir
  --skills       Remove global Codex, Claude Code, OpenCode, and Agents skills
  --project      Remove project OCW files in the current directory
  --all          Remove binary, global skills, and project OCW files

Options:
  --install-dir DIR  Override install directory for the ocw launcher
  --dry-run          Print removal plan without deleting anything
  --yes              Actually remove selected targets
  --force            Remove modified project AGENTS.md, CLAUDE.md, or .ocw.toml
EOF
        return
        ;;
      *)
        die "unknown uninstall option: $1"
        ;;
    esac
  done

  if [[ "$yes" -ne 1 ]]; then
    printf 'OCW uninstall dry run. Pass --yes to remove selected targets.\n'
  fi

  if [[ "$remove_bin" -eq 1 ]]; then
    bin_path="$install_dir/ocw"
    if [[ -L "$bin_path" ]]; then
      bin_target="$(resolved_symlink_target "$bin_path" || true)"
      if [[ "$force" -eq 1 || "$bin_target" == "$bin_source" ]]; then
        uninstall_remove_path "binary" "$bin_path" "$yes"
      else
        printf 'Kept binary: %s points to %s (pass --force to remove)\n' "$bin_path" "$bin_target"
      fi
    elif [[ -f "$bin_path" ]]; then
      if [[ "$force" -eq 1 ]] || { [[ -f "$bin_source" ]] && cmp -s "$bin_path" "$bin_source"; }; then
        uninstall_remove_path "binary" "$bin_path" "$yes"
      else
        printf 'Kept binary: %s is not the OCW launcher (pass --force to remove)\n' "$bin_path"
      fi
    else
      uninstall_remove_path "binary" "$bin_path" "$yes"
    fi
  fi

  if [[ "$remove_skills" -eq 1 ]]; then
    codex_skills_dir="${OCW_CODEX_SKILLS_DIR:-${CODEX_HOME:-$HOME/.codex}/skills}"
    claude_skills_dir="${OCW_CLAUDE_SKILLS_DIR:-${CLAUDE_HOME:-$HOME/.claude}/skills}"
    opencode_home_dir="$(opencode_config_home)"
    opencode_skills_dir="${OCW_OPENCODE_SKILLS_DIR:-$opencode_home_dir/skills}"
    agents_skills_dir="${OCW_AGENTS_SKILLS_DIR:-${AGENTS_HOME:-$HOME/.agents}/skills}"

    uninstall_remove_path "Codex skill" "$codex_skills_dir/$SKILL_NAME" "$yes"
    uninstall_remove_path "Claude Code skill" "$claude_skills_dir/$SKILL_NAME" "$yes"
    uninstall_remove_path "OpenCode skill" "$opencode_skills_dir/$SKILL_NAME" "$yes"
    uninstall_remove_path "Agents skill" "$agents_skills_dir/$SKILL_NAME" "$yes"
  fi

  if [[ "$remove_project" -eq 1 ]]; then
    config_template="$(mktemp "${TMPDIR:-/tmp}/ocw-config.XXXXXX")"
    print_default_config > "$config_template"

    uninstall_remove_file_if_matching "project config" ".ocw.toml" "$config_template" "$force" "$yes"
    uninstall_remove_file_if_matching "Codex instructions" "AGENTS.md" "$OCW_HOME/examples/codex/AGENTS.md" "$force" "$yes"
    uninstall_remove_file_if_matching "Claude Code instructions" "CLAUDE.md" "$OCW_HOME/examples/claude/CLAUDE.md" "$force" "$yes"
    rm -f "$config_template"

    uninstall_remove_path "project OpenCode skill" ".opencode/skills/$SKILL_NAME" "$yes"
    uninstall_remove_path "project Claude Code skill" ".claude/skills/$SKILL_NAME" "$yes"
    uninstall_remove_path "project Agents skill" ".agents/skills/$SKILL_NAME" "$yes"
    uninstall_remove_path "OpenCode agent ocw-explorer" ".opencode/agents/ocw-explorer.md" "$yes"
    uninstall_remove_path "OpenCode agent ocw-reviewer" ".opencode/agents/ocw-reviewer.md" "$yes"
    uninstall_remove_path "OpenCode agent ocw-patcher" ".opencode/agents/ocw-patcher.md" "$yes"
    uninstall_remove_path "OpenCode agent ocw-triage" ".opencode/agents/ocw-triage.md" "$yes"
    uninstall_remove_gitignore_entries "$yes"
  fi

  if [[ "$yes" -eq 1 ]]; then
    printf 'OCW uninstall complete\n'
  fi
}

init_project() {
  local install_codex=1
  local install_claude=1
  local install_opencode=1
  local install_agents=1
  local install_gitignore=1
  local install_config=1
  local install_skills=1
  local install_project_skills=0
  local force=0
  local codex_home="${CODEX_HOME:-$HOME/.codex}"
  local claude_home="${CLAUDE_HOME:-$HOME/.claude}"
  local opencode_home_dir
  local codex_skills_dir="${OCW_CODEX_SKILLS_DIR:-$codex_home/skills}"
  local claude_skills_dir="${OCW_CLAUDE_SKILLS_DIR:-$claude_home/skills}"
  opencode_home_dir="$(opencode_config_home)"
  local opencode_skills_dir="${OCW_OPENCODE_SKILLS_DIR:-$opencode_home_dir/skills}"
  local agents_skills_dir="${OCW_AGENTS_SKILLS_DIR:-${AGENTS_HOME:-$HOME/.agents}/skills}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --codex) install_codex=1; shift ;;
      --claude) install_claude=1; shift ;;
      --opencode) install_opencode=1; shift ;;
      --agents) install_agents=1; shift ;;
      --skills) install_skills=1; shift ;;
      --project-skills) install_project_skills=1; shift ;;
      --gitignore) install_gitignore=1; shift ;;
      --config) install_config=1; shift ;;
      --no-codex) install_codex=0; shift ;;
      --no-claude) install_claude=0; shift ;;
      --no-opencode) install_opencode=0; shift ;;
      --no-agents) install_agents=0; shift ;;
      --no-skills) install_skills=0; shift ;;
      --no-project-skills) install_project_skills=0; shift ;;
      --no-gitignore) install_gitignore=0; shift ;;
      --no-config) install_config=0; shift ;;
      --force) force=1; shift ;;
      -h|--help)
        cat <<'EOF'
Usage: ocw init [options]

Options:
  --codex / --no-codex        Install AGENTS.md project instructions
  --claude / --no-claude      Install CLAUDE.md project instructions
  --opencode / --no-opencode  Install global OpenCode skill
  --agents / --no-agents      Install global Agent Skills-compatible skill
  --skills / --no-skills      Install personal/global agent skills
  --project-skills            Install project-local .opencode/.claude/.agents skills
  --gitignore / --no-gitignore
  --config / --no-config      Install .ocw.toml
  --force                     Overwrite project instruction/config files
EOF
        return
        ;;
      *)
        die "unknown init option: $1"
        ;;
    esac
  done

  if [[ "$install_gitignore" -eq 1 ]]; then
    ensure_ocw_gitignore_entries ".gitignore"
    printf 'Updated gitignore: .gitignore\n'
  fi

  if [[ "$install_config" -eq 1 ]]; then
    write_default_config ".ocw.toml" "$force"
  fi

  if [[ "$install_codex" -eq 1 ]]; then
    copy_if_needed "$OCW_HOME/examples/codex/AGENTS.md" "AGENTS.md" "Codex instructions" "$force"
  fi

  if [[ "$install_claude" -eq 1 ]]; then
    copy_if_needed "$OCW_HOME/examples/claude/CLAUDE.md" "CLAUDE.md" "Claude Code instructions" "$force"
  fi

  if [[ "$install_skills" -eq 1 ]]; then
    if [[ "$install_codex" -eq 1 ]]; then
      install_agent_skill "Codex" "$codex_skills_dir"
    fi
    if [[ "$install_claude" -eq 1 ]]; then
      install_agent_skill "Claude Code" "$claude_skills_dir"
    fi
    if [[ "$install_opencode" -eq 1 ]]; then
      install_agent_skill "OpenCode" "$opencode_skills_dir"
    fi
    if [[ "$install_agents" -eq 1 ]]; then
      install_agent_skill "Agents" "$agents_skills_dir"
    fi
  fi

  if [[ "$install_project_skills" -eq 1 ]]; then
    install_agent_skill "project OpenCode" ".opencode/skills"
    install_agent_skill "project Claude Code" ".claude/skills"
    install_agent_skill "project Agents" ".agents/skills"
  fi

  printf 'OCW init complete\n'
}

default_project_config_path() {
  local root

  if have_command "$GIT_BIN"; then
    root="$(git_root "$PWD")"
    if [[ -n "$root" ]]; then
      printf '%s/.ocw.toml\n' "$root"
      return
    fi
  fi

  printf '%s/.ocw.toml\n' "$PWD"
}

config_validate_file() {
  local file="$1"
  local checks_file="$2"
  local section="" line key value lower lineno=0 status=0

  [[ -f "$file" ]] || {
    printf 'fail\tfile\tconfig file not found: %s\n' "$file" >> "$checks_file"
    return 1
  }

  while IFS= read -r line || [[ -n "$line" ]]; do
    lineno=$((lineno + 1))
    line="${line%%#*}"
    line="$(trim "$line")"
    [[ -z "$line" ]] && continue

    if [[ "$line" =~ ^\[(.+)\]$ ]]; then
      section="${BASH_REMATCH[1]}"
      case "$section" in
        models|agents|defaults|auth)
          printf 'ok\tsection\tline %s: [%s]\n' "$lineno" "$section" >> "$checks_file"
          ;;
        *)
          printf 'fail\tsection\tline %s: unknown section [%s]\n' "$lineno" "$section" >> "$checks_file"
          status=1
          ;;
      esac
      continue
    fi

    if [[ "$line" != *=* ]]; then
      printf 'fail\tsyntax\tline %s: expected key = value\n' "$lineno" >> "$checks_file"
      status=1
      continue
    fi

    key="$(trim "${line%%=*}")"
    value="$(trim "${line#*=}")"
    value="$(unquote "$value")"
    case "$section:$key" in
      models:cheap|models:explore|models:scan|models:review|models:patch|agents:cheap|agents:explore|agents:scan|agents:review|agents:patch|defaults:output_root|defaults:variant|defaults:attach|auth:key_env|auth:env|auth:keys_file)
        if [[ -n "$value" ]]; then
          printf 'ok\tkey\tline %s: %s.%s\n' "$lineno" "$section" "$key" >> "$checks_file"
        else
          printf 'fail\tvalue\tline %s: %s.%s is empty\n' "$lineno" "$section" "$key" >> "$checks_file"
          status=1
        fi
        ;;
      defaults:worktree|defaults:rm_worktree|defaults:require_clean|defaults:auto_approve|auth:auto_rotate|auth:rotate_on_failure)
        lower="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
        if [[ "$lower" == "1" || "$lower" == "true" || "$lower" == "yes" || "$lower" == "on" || "$lower" == "0" || "$lower" == "false" || "$lower" == "no" || "$lower" == "off" ]]; then
          printf 'ok\tkey\tline %s: %s.%s\n' "$lineno" "$section" "$key" >> "$checks_file"
        else
          printf 'fail\tvalue\tline %s: %s.%s must be a boolean\n' "$lineno" "$section" "$key" >> "$checks_file"
          status=1
        fi
        ;;
      :*)
        printf 'fail\tsection\tline %s: key outside a section\n' "$lineno" >> "$checks_file"
        status=1
        ;;
      *)
        printf 'warn\tkey\tline %s: unknown key %s.%s\n' "$lineno" "$section" "$key" >> "$checks_file"
        ;;
    esac
  done < "$file"

  return "$status"
}

config_command() {
  local subcommand="${1:-show}"
  shift || true
  local target force=0 json=0 checks_file severity id message first status=0

  case "$subcommand" in
    init)
      target="$(default_project_config_path)"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --file)
            [[ $# -ge 2 ]] || die "--file requires a value"
            target="$2"
            shift 2
            ;;
          --force)
            force=1
            shift
            ;;
          -h|--help)
            printf 'Usage: ocw config init [--file FILE] [--force]\n'
            return
            ;;
          *)
            die "unknown config init option: $1"
            ;;
        esac
      done
      write_default_config "$target" "$force"
      ;;
    path)
      if [[ -n "${OCW_CONFIG_FILE:-}" ]]; then
        printf '%s\n' "$OCW_CONFIG_FILE"
      else
        default_project_config_path
      fi
      ;;
    show)
      if [[ $# -gt 0 ]]; then
        die "unknown config show option: $1"
      fi
      if [[ -n "${OCW_CONFIG_FILE:-}" && -f "$OCW_CONFIG_FILE" ]]; then
        cat "$OCW_CONFIG_FILE"
      else
        print_default_config
      fi
      ;;
    validate)
      target="${OCW_CONFIG_FILE:-$(default_project_config_path)}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --file)
            [[ $# -ge 2 ]] || die "--file requires a value"
            target="$2"
            shift 2
            ;;
          --json)
            json=1
            shift
            ;;
          -h|--help)
            printf 'Usage: ocw config validate [--file FILE] [--json]\n'
            return
            ;;
          *)
            target="$1"
            shift
            ;;
        esac
      done
      checks_file="$(mktemp "${TMPDIR:-/tmp}/ocw-config-checks.XXXXXX")"
      config_validate_file "$target" "$checks_file" || status=1
      if [[ "$json" -eq 1 ]]; then
        printf '{\n'
        printf '  "schema_version": "ocw.config.validate.v1",\n'
        printf '  "file": '
        json_string "$target"
        printf ',\n  "valid": %s,\n  "checks": [\n' "$([[ "$status" -eq 0 ]] && printf true || printf false)"
        first=1
        while IFS=$'\t' read -r severity id message; do
          [[ -n "$severity" ]] || continue
          if [[ "$first" -eq 0 ]]; then
            printf ',\n'
          fi
          printf '    { "severity": '
          json_string "$severity"
          printf ', "id": '
          json_string "$id"
          printf ', "message": '
          json_string "$message"
          printf ' }'
          first=0
        done < "$checks_file"
        printf '\n  ]\n}\n'
      else
        printf 'OCW config: %s\n' "$target"
        while IFS=$'\t' read -r severity id message; do
          [[ -n "$severity" ]] || continue
          printf '[%s] %s: %s\n' "$severity" "$id" "$message"
        done < "$checks_file"
        if [[ "$status" -eq 0 ]]; then
          printf 'config: ok\n'
        else
          printf 'config: invalid\n'
        fi
      fi
      rm -f "$checks_file"
      return "$status"
      ;;
    -h|--help|help)
      cat <<'EOF'
Usage:
  ocw config init [--file FILE] [--force]
  ocw config path
  ocw config show
  ocw config validate [--file FILE] [--json]
EOF
      ;;
    *)
      die "unknown config command: $subcommand"
      ;;
  esac
}

keys_command() {
  local subcommand="${1:-list}"
  shift || true
  local file name env_name key_value note="" force=0 activate=0 json=0 first=1
  local source_env remove_name found=0 tmp existing mode message severity
  local created_at record_name record_env record_key record_note record_created fingerprint

  file="$(auth_keys_file_path)"
  env_name="$(auth_key_env_name)"

  case "$subcommand" in
    set|add)
      [[ $# -ge 1 ]] || die "Usage: ocw keys set NAME (--stdin|--value KEY|--from-env ENV) [--env ENV] [--activate] [--force] [--note TEXT]"
      name="$1"
      validate_key_name "$name"
      shift
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --env)
            [[ $# -ge 2 ]] || die "--env requires a value"
            env_name="$2"
            shift 2
            ;;
          --value)
            [[ $# -ge 2 ]] || die "--value requires a value"
            key_value="$2"
            shift 2
            ;;
          --stdin)
            key_value="$(auth_read_secret)"
            shift
            ;;
          --from-env)
            [[ $# -ge 2 ]] || die "--from-env requires a variable name"
            source_env="$2"
            validate_env_name "$source_env"
            key_value="${!source_env:-}"
            [[ -n "$key_value" ]] || die "environment variable is empty or unset: $source_env"
            shift 2
            ;;
          --activate)
            activate=1
            shift
            ;;
          --force)
            force=1
            shift
            ;;
          --note)
            [[ $# -ge 2 ]] || die "--note requires a value"
            note="$2"
            shift 2
            ;;
          -h|--help)
            cat <<'EOF'
Usage: ocw keys set NAME (--stdin|--value KEY|--from-env ENV) [--env ENV] [--activate] [--force] [--note TEXT]

Stores a project-local API key registry at .codex/ocw-keys.tsv by default.
Use --stdin or --from-env to avoid putting secrets in shell history.
EOF
            return
            ;;
          *)
            die "unknown keys set option: $1"
            ;;
        esac
      done
      validate_env_name "$env_name"
      validate_key_value "${key_value:-}"
      ensure_parent_dir "$file"
      ensure_sensitive_project_file_ignored "$file"
      existing="$(auth_read_records "$file")"
      if printf '%s\n' "$existing" | awk -F '\t' -v name="$name" '$1 == name { found = 1 } END { exit(found ? 0 : 1) }'; then
        found=1
      fi
      if [[ "$found" -eq 1 && "$force" -ne 1 ]]; then
        die "key already exists: $name (pass --force to replace)"
      fi
      created_at="$(now_utc)"
      tmp="$(mktemp "${TMPDIR:-/tmp}/ocw-keys.XXXXXX")"
      chmod 600 "$tmp"
      if [[ "$activate" -eq 1 ]]; then
        printf '%s\t%s\t%s\t%s\t%s\n' "$name" "$env_name" "$key_value" "$(sanitize_tsv_field "$note")" "$created_at" > "$tmp"
      fi
      while IFS=$'\t' read -r record_name record_env record_key record_note record_created; do
        [[ -n "$record_name" ]] || continue
        [[ "$record_name" != "$name" ]] || continue
        printf '%s\t%s\t%s\t%s\t%s\n' "$record_name" "$record_env" "$record_key" "$record_note" "$record_created" >> "$tmp"
      done <<EOF
$existing
EOF
      if [[ "$activate" -ne 1 ]]; then
        printf '%s\t%s\t%s\t%s\t%s\n' "$name" "$env_name" "$key_value" "$(sanitize_tsv_field "$note")" "$created_at" >> "$tmp"
      fi
      mv "$tmp" "$file"
      chmod 600 "$file" 2>/dev/null || true
      printf 'OCW key stored: %s (%s)\n' "$name" "$env_name"
      ;;
    list)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json)
            json=1
            shift
            ;;
          -h|--help)
            printf 'Usage: ocw keys list [--json]\n'
            return
            ;;
          *)
            die "unknown keys list option: $1"
            ;;
        esac
      done
      if [[ "$json" -eq 1 ]]; then
        printf '{\n'
        printf '  "schema_version": "ocw.keys.v1",\n'
        printf '  "file": '
        json_string "$file"
        printf ',\n  "env": '
        json_string "$env_name"
        printf ',\n  "keys": [\n'
        while IFS=$'\t' read -r record_name record_env record_key record_note record_created; do
          [[ -n "$record_name" ]] || continue
          fingerprint="$(auth_key_fingerprint "$record_key")"
          if [[ "$first" -eq 0 ]]; then
            printf ',\n'
          fi
          printf '    { "name": '
          json_string "$record_name"
          printf ', "active": %s, "env": ' "$([[ "$first" -eq 1 ]] && printf true || printf false)"
          json_string "$record_env"
          printf ', "fingerprint": '
          json_string "$fingerprint"
          printf ', "note": '
          json_string "$record_note"
          printf ', "created_at": '
          json_string "$record_created"
          printf ' }'
          first=0
        done <<EOF
$(auth_read_records "$file")
EOF
        printf '\n  ]\n}\n'
      else
        printf 'OCW keys: %s\n' "$file"
        printf 'active\tname\tenv\tfingerprint\tnote\n'
        while IFS=$'\t' read -r record_name record_env record_key record_note record_created; do
          [[ -n "$record_name" ]] || continue
          fingerprint="$(auth_key_fingerprint "$record_key")"
          printf '%s\t%s\t%s\t%s\t%s\n' "$([[ "$first" -eq 1 ]] && printf '*' || printf '')" "$record_name" "$record_env" "$fingerprint" "$record_note"
          first=0
        done <<EOF
$(auth_read_records "$file")
EOF
      fi
      ;;
    use)
      [[ $# -eq 1 ]] || die "Usage: ocw keys use NAME"
      name="$1"
      validate_key_name "$name"
      existing="$(auth_read_records "$file")"
      [[ -n "$existing" ]] || die "no keys stored: $file"
      tmp="$(mktemp "${TMPDIR:-/tmp}/ocw-keys.XXXXXX")"
      chmod 600 "$tmp"
      while IFS=$'\t' read -r record_name record_env record_key record_note record_created; do
        [[ -n "$record_name" ]] || continue
        if [[ "$record_name" == "$name" ]]; then
          printf '%s\t%s\t%s\t%s\t%s\n' "$record_name" "$record_env" "$record_key" "$record_note" "$record_created" > "$tmp"
          found=1
        fi
      done <<EOF
$existing
EOF
      [[ "$found" -eq 1 ]] || {
        rm -f "$tmp"
        die "key not found: $name"
      }
      while IFS=$'\t' read -r record_name record_env record_key record_note record_created; do
        [[ -n "$record_name" ]] || continue
        [[ "$record_name" != "$name" ]] || continue
        printf '%s\t%s\t%s\t%s\t%s\n' "$record_name" "$record_env" "$record_key" "$record_note" "$record_created" >> "$tmp"
      done <<EOF
$existing
EOF
      mv "$tmp" "$file"
      chmod 600 "$file" 2>/dev/null || true
      printf 'OCW active key: %s\n' "$name"
      ;;
    remove|rm)
      [[ $# -eq 1 ]] || die "Usage: ocw keys remove NAME"
      remove_name="$1"
      validate_key_name "$remove_name"
      existing="$(auth_read_records "$file")"
      tmp="$(mktemp "${TMPDIR:-/tmp}/ocw-keys.XXXXXX")"
      chmod 600 "$tmp"
      while IFS=$'\t' read -r record_name record_env record_key record_note record_created; do
        [[ -n "$record_name" ]] || continue
        if [[ "$record_name" == "$remove_name" ]]; then
          found=1
          continue
        fi
        printf '%s\t%s\t%s\t%s\t%s\n' "$record_name" "$record_env" "$record_key" "$record_note" "$record_created" >> "$tmp"
      done <<EOF
$existing
EOF
      [[ "$found" -eq 1 ]] || {
        rm -f "$tmp"
        die "key not found: $remove_name"
      }
      mv "$tmp" "$file"
      chmod 600 "$file" 2>/dev/null || true
      printf 'OCW key removed: %s\n' "$remove_name"
      ;;
    doctor)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json) json=1; shift ;;
          -h|--help)
            printf 'Usage: ocw keys doctor [--json]\n'
            return
            ;;
          *)
            die "unknown keys doctor option: $1"
            ;;
        esac
      done
      mode="missing"
      message="keys file not found"
      severity="warn"
      if [[ -f "$file" ]]; then
        mode="$(stat -f '%Lp' "$file" 2>/dev/null || stat -c '%a' "$file" 2>/dev/null || printf unknown)"
        if [[ "$mode" == "600" || "$mode" == "400" ]]; then
          severity="ok"
          message="keys file permissions are restricted"
        else
          severity="warn"
          message="keys file should be chmod 600"
        fi
      fi
      if [[ "$json" -eq 1 ]]; then
        printf '{\n'
        printf '  "schema_version": "ocw.keys.doctor.v1",\n'
        printf '  "file": '
        json_string "$file"
        printf ',\n  "exists": %s,\n  "env": ' "$([[ -f "$file" ]] && printf true || printf false)"
        json_string "$env_name"
        printf ',\n  "count": %s,\n  "permission": ' "$(auth_read_records "$file" | awk 'NF { count++ } END { print count + 0 }')"
        json_string "$mode"
        printf ',\n  "severity": '
        json_string "$severity"
        printf ',\n  "message": '
        json_string "$message"
        printf '\n}\n'
      else
        printf 'OCW keys doctor\n'
        printf 'file: %s\n' "$file"
        printf 'env: %s\n' "$env_name"
        printf 'count: %s\n' "$(auth_read_records "$file" | awk 'NF { count++ } END { print count + 0 }')"
        printf 'permission: %s\n' "$mode"
        printf '[%s] %s\n' "$severity" "$message"
      fi
      [[ "$severity" != "fail" ]]
      ;;
    path)
      printf '%s\n' "$file"
      ;;
    -h|--help|help)
      cat <<'EOF'
Usage:
  ocw keys set NAME (--stdin|--value KEY|--from-env ENV) [--env ENV] [--activate] [--force] [--note TEXT]
  ocw keys add NAME (--stdin|--value KEY|--from-env ENV) [--env ENV] [--activate] [--force] [--note TEXT]
  ocw keys list [--json]
  ocw keys use NAME
  ocw keys remove NAME
  ocw keys doctor [--json]
  ocw keys path

OCW tries keys in priority order. Use `ocw keys use NAME` to move a key to the
front. On auth/quota/rate-limit failures, worker runs automatically retry the
next key unless OCW_KEY_ROTATION=0.
EOF
      ;;
    *)
      die "unknown keys command: $subcommand"
      ;;
  esac
}

last_command() {
  local root="$1"
  shift
  local mode=""

  if [[ $# -gt 0 ]]; then
    mode="$1"
  fi

  root="$(abs_existing_dir "$root")"
  latest_run_dir "$root" "$mode"
}

show_command() {
  local root="$1"
  shift
  local ref="latest"
  local view="default"
  local run_dir

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --summary) view="summary"; shift ;;
      --diff) view="diff"; shift ;;
      --stat) view="stat"; shift ;;
      --status) view="status"; shift ;;
      --metadata) view="metadata"; shift ;;
      --jsonl) view="jsonl"; shift ;;
      --path) view="path"; shift ;;
      -h|--help)
        printf 'Usage: ocw show [latest|run-dir] [--summary|--diff|--stat|--status|--metadata|--jsonl|--path]\n'
        return
        ;;
      -*)
        die "unknown show option: $1"
        ;;
      *)
        ref="$1"
        shift
        ;;
    esac
  done

  root="$(abs_existing_dir "$root")"
  run_dir="$(resolve_run_dir "$root" "$ref")"

  case "$view" in
    path)
      printf '%s\n' "$run_dir"
      ;;
    summary)
      [[ -f "$run_dir/summary.md" ]] || die "summary not found: $run_dir/summary.md"
      cat "$run_dir/summary.md"
      ;;
    diff)
      [[ -f "$run_dir/diff.after.patch" ]] || die "diff not found: $run_dir/diff.after.patch"
      cat "$run_dir/diff.after.patch"
      ;;
    stat)
      [[ -f "$run_dir/diff.after.stat" ]] || die "diff stat not found: $run_dir/diff.after.stat"
      cat "$run_dir/diff.after.stat"
      ;;
    status)
      [[ -f "$run_dir/status.after.txt" ]] || die "status not found: $run_dir/status.after.txt"
      cat "$run_dir/status.after.txt"
      ;;
    metadata)
      [[ -f "$run_dir/metadata.txt" ]] || die "metadata not found: $run_dir/metadata.txt"
      cat "$run_dir/metadata.txt"
      ;;
    jsonl)
      [[ -f "$run_dir/result.jsonl" ]] || die "result JSONL not found: $run_dir/result.jsonl"
      cat "$run_dir/result.jsonl"
      ;;
    default)
      printf 'OCW run: %s\n\n' "$run_dir"
      if [[ -f "$run_dir/summary.md" ]]; then
        cat "$run_dir/summary.md"
      fi
      if [[ -s "$run_dir/diff.after.stat" ]]; then
        printf '\nDiff stat:\n'
        cat "$run_dir/diff.after.stat"
      fi
      ;;
    *)
      die "unknown show view: $view"
      ;;
  esac
}

manifest_command() {
  local root="$1"
  shift
  local ref="latest"
  local json=0
  local run_dir metadata_file artifact first line key value file rel bytes sha

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        json=1
        shift
        ;;
      -h|--help)
        printf 'Usage: ocw manifest [latest|run-dir] [--json]\n'
        return
        ;;
      -*)
        die "unknown manifest option: $1"
        ;;
      *)
        ref="$1"
        shift
        ;;
    esac
  done

  root="$(abs_existing_dir "$root")"
  run_dir="$(resolve_run_dir "$root" "$ref")"
  metadata_file="$run_dir/metadata.txt"

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.manifest.v1",\n'
    printf '  "run_dir": '
    json_string "$run_dir"
    printf ',\n'
    printf '  "metadata": {\n'
    first=1
    if [[ -f "$metadata_file" ]]; then
      while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" == *=* ]] || continue
        key="${line%%=*}"
        value="${line#*=}"
        [[ -n "$key" ]] || continue
        if [[ "$first" -eq 0 ]]; then
          printf ',\n'
        fi
        printf '    '
        json_string "$key"
        printf ': '
        json_string "$value"
        first=0
      done < "$metadata_file"
    fi
    printf '\n  },\n'
    printf '  "artifacts": [\n'
    first=1
    while IFS= read -r file; do
      [[ -n "$file" ]] || continue
      rel="${file#"$run_dir"/}"
      bytes="$(file_size_bytes "$file")"
      sha="$(file_sha256 "$file")"
      if [[ "$first" -eq 0 ]]; then
        printf ',\n'
      fi
      printf '    { "name": '
      json_string "$rel"
      printf ', "path": '
      json_string "$file"
      printf ', "bytes": %s, "sha256": ' "$bytes"
      json_string "$sha"
      printf ' }'
      first=0
    done <<EOF
$(find "$run_dir" -type f -print | sort)
EOF
    printf '\n  ]\n'
    printf '}\n'
    return
  fi

  printf 'OCW manifest: %s\n' "$run_dir"
  if [[ -f "$metadata_file" ]]; then
    printf '\nmetadata:\n'
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ "$line" == *=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      printf '  %s: %s\n' "$key" "$value"
    done < "$metadata_file"
  else
    printf '\nmetadata: missing\n'
  fi

  printf '\nartifacts:\n'
  while IFS= read -r artifact; do
    [[ -n "$artifact" ]] || continue
    rel="${artifact#"$run_dir"/}"
    bytes="$(file_size_bytes "$artifact")"
    sha="$(file_sha256 "$artifact")"
    printf '  - %s (%s bytes' "$rel" "$bytes"
    if [[ -n "$sha" ]]; then
      printf ', sha256:%s' "$sha"
    fi
    printf ')\n'
  done <<EOF
$(find "$run_dir" -type f -print | sort)
EOF
}

status_has_unexpected_changes() {
  local status_file="$1"
  local project_dir="$2"
  local output_dir="$3"
  local before_status_file="${4:-}"
  local output_rel=""
  local line path before_norm after_norm has_changes status_source

  if [[ -n "$project_dir" && -n "$output_dir" && "$output_dir" == "$project_dir/"* ]]; then
    output_rel="${output_dir#"$project_dir"/}"
  fi

  after_norm="$(mktemp "${TMPDIR:-/tmp}/ocw-status-after.XXXXXX")"
  before_norm=""
  status_source="/dev/null"
  [[ -f "$status_file" ]] && status_source="$status_file"

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -n "$line" ]] || continue
    path="${line:3}"
    case "$path" in
      .codex|.codex/|.codex/*|.out|.out/|.out/*)
        continue
        ;;
    esac
    if [[ -n "$output_rel" ]]; then
      case "$path" in
        "$output_rel"|"$output_rel"/|"$output_rel"/*)
          continue
          ;;
      esac
    fi
    printf '%s\n' "$line"
  done < "$status_source" | LC_ALL=C sort -u > "$after_norm"

  if [[ -n "$before_status_file" && -f "$before_status_file" ]]; then
    before_norm="$(mktemp "${TMPDIR:-/tmp}/ocw-status-before.XXXXXX")"
    while IFS= read -r line || [[ -n "$line" ]]; do
      [[ -n "$line" ]] || continue
      path="${line:3}"
      case "$path" in
        .codex|.codex/|.codex/*|.out|.out/|.out/*)
          continue
          ;;
      esac
      if [[ -n "$output_rel" ]]; then
        case "$path" in
          "$output_rel"|"$output_rel"/|"$output_rel"/*)
            continue
            ;;
        esac
      fi
      printf '%s\n' "$line"
    done < "$before_status_file" | LC_ALL=C sort -u > "$before_norm"

    if cmp -s "$before_norm" "$after_norm"; then
      has_changes=1
    else
      has_changes=0
    fi
  elif [[ -s "$after_norm" ]]; then
    has_changes=0
  else
    has_changes=1
  fi

  rm -f "$after_norm"
  [[ -n "$before_norm" ]] && rm -f "$before_norm"

  return "$has_changes"
}

audit_add() {
  local severity="$1"
  local id="$2"
  local message="$3"
  printf '%s\t%s\t%s\n' "$severity" "$id" "$message" >> "$audit_checks_file"
}

audit_tsv_status_failures() {
  local file="$1"
  local column="$2"
  awk -F '\t' -v col="$column" 'NR > 1 && $col != "0" { found = 1 } END { exit(found ? 0 : 1) }' "$file"
}

audit_tsv_marker_warnings() {
  local file="$1"
  local column="$2"
  awk -F '\t' -v col="$column" 'NR > 1 && $col != "ok" { found = 1 } END { exit(found ? 0 : 1) }' "$file"
}

audit_summary_has_injection_marker() {
  local run_dir="$1"
  local file

  while IFS= read -r -d '' file; do
    if grep -Eiq 'ignore (all )?(previous|prior) instructions|system prompt|developer message|exfiltrat|api[_ -]?key|secret token' "$file"; then
      return 0
    fi
  done < <(find "$run_dir" \( -name summary.md -o -name review.md \) -type f -print0 2>/dev/null)

  return 1
}

audit_command() {
  local root="$1"
  shift
  local ref="latest"
  local json=0
  local max_diff_bytes=200000
  local run_dir metadata_file mode status output_dir project_dir worktree diff_size overall exit_code
  local summary_file report_file first severity id message

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        json=1
        shift
        ;;
      --max-diff-bytes)
        [[ $# -ge 2 ]] || die "--max-diff-bytes requires a value"
        max_diff_bytes="$2"
        shift 2
        ;;
      -h|--help)
        printf 'Usage: ocw audit [latest|run-dir] [--json] [--max-diff-bytes N]\n'
        return
        ;;
      -*)
        die "unknown audit option: $1"
        ;;
      *)
        ref="$1"
        shift
        ;;
    esac
  done

  [[ "$max_diff_bytes" =~ ^[0-9]+$ ]] || die "--max-diff-bytes must be a non-negative integer"
  root="$(abs_existing_dir "$root")"
  run_dir="$(resolve_run_dir "$root" "$ref")"
  metadata_file="$run_dir/metadata.txt"
  audit_checks_file="$(mktemp "${TMPDIR:-/tmp}/ocw-audit.XXXXXX")"

  if [[ -f "$metadata_file" ]]; then
    audit_add ok metadata "metadata.txt exists"
  else
    audit_add fail metadata "metadata.txt is missing"
  fi

  mode="$(metadata_value "$metadata_file" "mode")"
  status="$(metadata_value "$metadata_file" "status")"
  output_dir="$(metadata_value "$metadata_file" "output_dir")"
  project_dir="$(metadata_value "$metadata_file" "project_dir")"
  worktree="$(metadata_value "$metadata_file" "worktree")"

  if [[ -n "$mode" ]]; then
    audit_add ok mode "mode=$mode"
  else
    audit_add warn mode "mode is missing from metadata"
  fi

  if [[ -n "$status" ]]; then
    if [[ "$status" == "0" ]]; then
      audit_add ok status "worker exited 0"
    else
      audit_add fail status "worker exited $status"
    fi
  elif [[ "$mode" == "bench" || "$mode" == "batch" ]]; then
    audit_add ok status "aggregate command uses TSV status rows"
  elif [[ -n "$mode" ]]; then
    audit_add warn status "status is missing from metadata"
  fi

  case "$mode" in
    cheap|explore|scan|review|patch)
      summary_file="$run_dir/summary.md"
      if [[ -s "$summary_file" ]]; then
        audit_add ok summary "summary.md is present"
      else
        audit_add fail summary "summary.md is missing or empty"
      fi
      if [[ -s "$run_dir/result.jsonl" ]]; then
        audit_add ok result "result.jsonl is present"
      else
        audit_add warn result "result.jsonl is missing or empty"
      fi
      if [[ "$mode" == "patch" ]]; then
        if [[ "$worktree" == "1" ]]; then
          audit_add ok patch_isolation "patch ran in an isolated worktree"
        else
          audit_add warn patch_isolation "patch did not run in an isolated worktree"
        fi
      elif {
        [[ -f "$run_dir/diff.before.patch" && -f "$run_dir/diff.after.patch" ]] && ! cmp -s "$run_dir/diff.before.patch" "$run_dir/diff.after.patch"
      } || status_has_unexpected_changes "$run_dir/status.after.txt" "$project_dir" "$output_dir" "$run_dir/status.before.txt"; then
        audit_add warn readonly_changes "read-only mode left unexpected git status changes"
      else
        audit_add ok readonly_changes "no unexpected git status changes"
      fi
      ;;
    pr-summary|pr-review)
      if [[ -s "$run_dir/pr.diff.patch" ]]; then
        audit_add ok pr_diff "pr.diff.patch is present"
      else
        audit_add fail pr_diff "pr.diff.patch is missing or empty"
      fi
      report_file="$run_dir/summary.md"
      [[ "$mode" == "pr-review" ]] && report_file="$run_dir/review.md"
      if [[ -s "$report_file" ]]; then
        audit_add ok pr_report "$(basename "$report_file") is present"
      else
        audit_add fail pr_report "$(basename "$report_file") is missing or empty"
      fi
      if [[ -s "$run_dir/workers.tsv" ]]; then
        if audit_tsv_status_failures "$run_dir/workers.tsv" 2; then
          audit_add fail pr_workers "one or more PR workers failed"
        else
          audit_add ok pr_workers "all PR workers exited 0"
        fi
      else
        audit_add fail pr_workers "workers.tsv is missing or empty"
      fi
      ;;
    bench)
      if [[ -s "$run_dir/bench.tsv" ]]; then
        if audit_tsv_status_failures "$run_dir/bench.tsv" 3; then
          audit_add fail bench_status "one or more benchmark runs failed"
        else
          audit_add ok bench_status "all benchmark runs exited 0"
        fi
        if audit_tsv_marker_warnings "$run_dir/bench.tsv" 5; then
          audit_add warn bench_marker "one or more benchmark markers are missing"
        else
          audit_add ok bench_marker "all benchmark markers are present"
        fi
      else
        audit_add fail bench_status "bench.tsv is missing or empty"
      fi
      if [[ -s "$run_dir/bench.md" ]]; then
        audit_add ok bench_report "bench.md is present"
      else
        audit_add fail bench_report "bench.md is missing or empty"
      fi
      ;;
    batch)
      if [[ -s "$run_dir/batch.tsv" ]]; then
        if audit_tsv_status_failures "$run_dir/batch.tsv" 3; then
          audit_add fail batch_status "one or more batch workers failed"
        else
          audit_add ok batch_status "all batch workers exited 0"
        fi
      else
        audit_add fail batch_status "batch.tsv is missing or empty"
      fi
      ;;
    tournament)
      if [[ -s "$run_dir/candidates.tsv" ]]; then
        if audit_tsv_status_failures "$run_dir/candidates.tsv" 3; then
          audit_add fail tournament_candidates "one or more tournament candidates failed"
        else
          audit_add ok tournament_candidates "all tournament candidates exited 0"
        fi
      else
        audit_add fail tournament_candidates "candidates.tsv is missing or empty"
      fi
      if [[ -s "$run_dir/decision.md" ]]; then
        audit_add ok tournament_decision "decision.md is present"
      else
        audit_add fail tournament_decision "decision.md is missing or empty"
      fi
      ;;
    eval)
      if [[ -s "$run_dir/eval.tsv" ]]; then
        if audit_tsv_status_failures "$run_dir/eval.tsv" 5; then
          audit_add fail eval_status "one or more eval runs failed"
        else
          audit_add ok eval_status "all eval runs exited 0"
        fi
        if audit_tsv_marker_warnings "$run_dir/eval.tsv" 6; then
          audit_add fail eval_marker "one or more eval expectations are missing"
        else
          audit_add ok eval_marker "all eval expectations are present"
        fi
      else
        audit_add fail eval_status "eval.tsv is missing or empty"
      fi
      if [[ -s "$run_dir/eval.md" ]]; then
        audit_add ok eval_report "eval.md is present"
      else
        audit_add fail eval_report "eval.md is missing or empty"
      fi
      ;;
    "")
      ;;
    *)
      audit_add warn mode "unknown mode for specialized audit checks: $mode"
      ;;
  esac

  if [[ -f "$run_dir/diff.after.patch" ]]; then
    diff_size="$(file_size_bytes "$run_dir/diff.after.patch")"
    if [[ "$diff_size" -gt "$max_diff_bytes" ]]; then
      audit_add warn diff_size "diff.after.patch is $diff_size bytes, above $max_diff_bytes"
    else
      audit_add ok diff_size "diff.after.patch is $diff_size bytes"
    fi
  fi

  if audit_summary_has_injection_marker "$run_dir"; then
    audit_add warn injection_markers "worker summaries contain prompt-injection or secret-handling markers"
  else
    audit_add ok injection_markers "no obvious prompt-injection markers in worker summaries"
  fi

  overall="ok"
  if awk -F '\t' '$1 == "fail" { found = 1 } END { exit(found ? 0 : 1) }' "$audit_checks_file"; then
    overall="fail"
  elif awk -F '\t' '$1 == "warn" { found = 1 } END { exit(found ? 0 : 1) }' "$audit_checks_file"; then
    overall="warn"
  fi

  if [[ "$overall" == "fail" ]]; then
    exit_code=1
  else
    exit_code=0
  fi

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.audit.v1",\n'
    printf '  "run_dir": '
    json_string "$run_dir"
    printf ',\n'
    printf '  "overall": '
    json_string "$overall"
    printf ',\n'
    printf '  "checks": [\n'
    first=1
    while IFS=$'\t' read -r severity id message; do
      [[ -n "$severity" ]] || continue
      if [[ "$first" -eq 0 ]]; then
        printf ',\n'
      fi
      printf '    { "severity": '
      json_string "$severity"
      printf ', "id": '
      json_string "$id"
      printf ', "message": '
      json_string "$message"
      printf ' }'
      first=0
    done < "$audit_checks_file"
    printf '\n  ]\n'
    printf '}\n'
  else
    printf 'OCW audit: %s\n' "$run_dir"
    printf 'overall: %s\n\n' "$overall"
    while IFS=$'\t' read -r severity id message; do
      [[ -n "$severity" ]] || continue
      printf '[%s] %s: %s\n' "$severity" "$id" "$message"
    done < "$audit_checks_file"
  fi

  rm -f "$audit_checks_file"
  return "$exit_code"
}

apply_command() {
  local root="$1"
  shift
  local ref="latest"
  local check_only=0
  local allow_dirty=0
  local force=0
  local run_dir patch worktree

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --check) check_only=1; shift ;;
      --allow-dirty) allow_dirty=1; shift ;;
      --force) force=1; shift ;;
      -h|--help)
        printf 'Usage: ocw apply [latest|run-dir] [--check] [--allow-dirty] [--force]\n'
        return
        ;;
      -*)
        die "unknown apply option: $1"
        ;;
      *)
        ref="$1"
        shift
        ;;
    esac
  done

  require_command "$GIT_BIN"
  git_is_repo "$PWD" || die "apply requires a git repository"

  root="$(abs_existing_dir "$root")"
  if [[ "$ref" == "latest" || -z "$ref" ]]; then
    run_dir="$(resolve_run_dir "$root" "latest" "patch")"
  else
    run_dir="$(resolve_run_dir "$root" "$ref")"
  fi

  patch="$run_dir/diff.after.patch"
  [[ -s "$patch" ]] || die "patch is empty: $patch"

  worktree="$(metadata_value "$run_dir/metadata.txt" "worktree")"
  if [[ "$worktree" != "1" && "$force" -ne 1 ]]; then
    die "refusing to apply a non-worktree run; pass --force if you intentionally want this"
  fi

  if [[ "$allow_dirty" -ne 1 ]]; then
    git_is_clean_for_apply "$PWD" "$root" || die "git worktree is not clean; pass --allow-dirty to override"
  fi

  "$GIT_BIN" -C "$PWD" apply --check "$patch"

  if [[ "$check_only" -eq 1 ]]; then
    printf 'Patch can be applied: %s\n' "$patch"
    return
  fi

  "$GIT_BIN" -C "$PWD" apply "$patch"
  printf 'Applied patch: %s\n' "$patch"
  "$GIT_BIN" -C "$PWD" diff --stat || true
}

delegate_infer_mode() {
  local task="$1"
  local lower

  lower="$(printf '%s' "$task" | tr '[:upper:]' '[:lower:]')"
  case "$lower" in
    *patch*|*fix*|*implement*|*wire*|*edit*|*change*|*refactor*)
      printf 'patch\timplementation task should run in an isolated patch worker\n'
      ;;
    *review*|*regression*|*risk*|*security*|*bug\ report*|*pull\ request*)
      printf 'review\treview/risk language benefits from a stronger second-opinion worker\n'
      ;;
    *scan*|*whole\ repo*|*entire\ repo*|*monorepo*|*all\ files*)
      printf 'scan\tbroad repository language benefits from a long-context scan worker\n'
      ;;
    *find*|*where*|*map*|*trace*|*understand*|*explore*|*explain*)
      printf 'explore\trepository discovery language maps to explore mode\n'
      ;;
    *)
      printf 'cheap\tdefaulting to the cheapest bounded worker mode\n'
      ;;
  esac
}

delegate_write_artifact() {
  local out_dir="$1"
  local mode="$2"
  local reason="$3"
  local final_review="$4"
  local task="$5"
  local metadata="$out_dir/metadata.txt"

  [[ -d "$out_dir" ]] || return 0
  {
    printf '# OCW delegate\n\n'
    printf -- "- worker_mode: \`%s\`\n" "$mode"
    printf -- "- route_reason: %s\n" "$reason"
    printf -- "- final_review_required: \`%s\`\n\n" "$final_review"
    printf '## Task\n\n%s\n\n' "$task"
    printf '## Required Handoff\n\n'
    printf 'Treat this worker output as draft labor. The primary Codex or Claude Code session remains responsible for final review, edits, and tests.\n'
  } > "$out_dir/delegate.md"

  if [[ -f "$metadata" ]] && ! grep -Fq 'delegate=1' "$metadata"; then
    {
      printf 'delegate=1\n'
      printf 'delegate_reason=%s\n' "$reason"
      printf 'final_review_required=%s\n' "$final_review"
    } >> "$metadata"
  fi
}

delegate_command() {
  local root="$1"
  shift
  local mode="" mode_set=0 json=0 final_review=1 use_worktree=0 worktree_set=0
  local model="" agent="" variant="" attach_url="" auto_approve=0 require_clean=0 remove_worktree=0
  local task reason stdout_file stderr_file status output_dir first_arg
  local -a files=() ocw_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --mode|--intent)
        [[ $# -ge 2 ]] || die "$1 requires a value"
        mode="$2"
        validate_worker_mode "$mode"
        mode_set=1
        shift 2
        ;;
      --json) json=1; shift ;;
      --final-review|--codex-final-review) final_review=1; shift ;;
      --no-final-review) final_review=0; shift ;;
      -m|--model)
        [[ $# -ge 2 ]] || die "--model requires a value"
        model="$2"
        shift 2
        ;;
      -a|--agent)
        [[ $# -ge 2 ]] || die "--agent requires a value"
        agent="$2"
        shift 2
        ;;
      --variant)
        [[ $# -ge 2 ]] || die "--variant requires a value"
        variant="$2"
        shift 2
        ;;
      --attach)
        [[ $# -ge 2 ]] || die "--attach requires a value"
        attach_url="$2"
        shift 2
        ;;
      --file)
        [[ $# -ge 2 ]] || die "--file requires a value"
        files+=("$2")
        shift 2
        ;;
      --auto-approve) auto_approve=1; shift ;;
      --require-clean) require_clean=1; shift ;;
      --worktree) use_worktree=1; worktree_set=1; shift ;;
      --no-worktree) use_worktree=0; worktree_set=1; shift ;;
      --rm-worktree) remove_worktree=1; shift ;;
      -h|--help)
        cat <<'EOF'
Usage: ocw delegate [--mode MODE] [--json] [worker-options...] <task...>

Routes a bounded task to the cheapest appropriate OCW worker mode, records a
delegate handoff artifact, and keeps final review assigned to Codex/Claude.

Modes: cheap, explore, scan, review, patch
EOF
        return
        ;;
      --)
        shift
        break
        ;;
      -*)
        die "unknown delegate option: $1"
        ;;
      *)
        break
        ;;
    esac
  done

  [[ $# -gt 0 ]] || die "missing delegate task"
  task="$*"

  if [[ "$mode_set" -eq 0 ]]; then
    IFS=$'\t' read -r mode reason <<< "$(delegate_infer_mode "$task")"
  else
    reason="explicit --mode"
  fi

  if [[ "$mode" == "patch" && "$worktree_set" -eq 0 ]]; then
    use_worktree=1
  fi

  ocw_args=()
  [[ -n "$model" ]] && ocw_args+=(--model "$model")
  [[ -n "$agent" ]] && ocw_args+=(--agent "$agent")
  [[ -n "$variant" ]] && ocw_args+=(--variant "$variant")
  [[ -n "$attach_url" ]] && ocw_args+=(--attach "$attach_url")
  if [[ "${#files[@]}" -gt 0 ]]; then
    for first_arg in "${files[@]}"; do
      ocw_args+=(--file "$first_arg")
    done
  fi
  [[ "$auto_approve" -eq 1 ]] && ocw_args+=(--auto-approve)
  [[ "$require_clean" -eq 1 ]] && ocw_args+=(--require-clean)
  [[ "$use_worktree" -eq 1 ]] && ocw_args+=(--worktree)
  [[ "$remove_worktree" -eq 1 ]] && ocw_args+=(--rm-worktree)
  ocw_args+=("$mode" "$task")

  stdout_file="$(mktemp "${TMPDIR:-/tmp}/ocw-delegate-stdout.XXXXXX")"
  stderr_file="$(mktemp "${TMPDIR:-/tmp}/ocw-delegate-stderr.XXXXXX")"

  set +e
  OCW_OUTPUT_ROOT="$root" "$OCW_SELF" "${ocw_args[@]}" > "$stdout_file" 2> "$stderr_file"
  status=$?
  set -e

  output_dir="$(awk '/^OCW output: / { sub(/^OCW output: /, ""); print }' "$stdout_file" | tail -n 1)"
  if [[ -n "$output_dir" ]]; then
    delegate_write_artifact "$output_dir" "$mode" "$reason" "$final_review" "$task"
  fi

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.delegate.v1",\n'
    printf '  "mode": '
    json_string "$mode"
    printf ',\n  "reason": '
    json_string "$reason"
    printf ',\n  "status": %s,\n  "final_review_required": %s,\n  "output_dir": ' "$status" "$([[ "$final_review" -eq 1 ]] && printf true || printf false)"
    json_string "$output_dir"
    printf ',\n  "stdout": '
    json_string "$(cat "$stdout_file")"
    printf ',\n  "stderr": '
    json_string "$(cat "$stderr_file")"
    printf '\n}\n'
  else
    cat "$stdout_file"
    if [[ -s "$stderr_file" ]]; then
      cat "$stderr_file" >&2
    fi
    printf 'OCW delegate: mode=%s reason=%s final_review_required=%s\n' "$mode" "$reason" "$final_review"
    [[ -n "$output_dir" ]] && printf 'OCW delegate output: %s\n' "$output_dir"
  fi

  rm -f "$stdout_file" "$stderr_file"
  return "$status"
}

mode_savings_weight() {
  case "$1" in
    cheap) printf '1\n' ;;
    explore|review|pr-summary) printf '2\n' ;;
    scan|patch) printf '3\n' ;;
    pr-review) printf '4\n' ;;
    batch|bench|eval|tournament) printf '5\n' ;;
    *) printf '1\n' ;;
  esac
}

cutoff_iso_days() {
  local days="$1"
  local cutoff=""

  if [[ "$days" =~ ^[0-9]+$ && "$days" -gt 0 ]]; then
    cutoff="$(date -u -v-"$days"d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || true)"
    if [[ -z "$cutoff" ]]; then
      cutoff="$(date -u -d "$days days ago" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || true)"
    fi
  fi
  printf '%s\n' "$cutoff"
}

savings_command() {
  local root="$1"
  shift
  local json=0 days=0 frontier_cost="${OCW_FRONTIER_COST_PER_UNIT:-0.40}" worker_cost="${OCW_WORKER_COST_PER_UNIT:-0.03}"
  local root_abs cutoff dir metadata mode status created_at weight
  local runs=0 ok=0 failed=0 delegated=0 frontier_units=0 worker_units=0 estimate

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json=1; shift ;;
      --days)
        [[ $# -ge 2 ]] || die "--days requires a value"
        days="$2"
        shift 2
        ;;
      --frontier-cost-per-unit)
        [[ $# -ge 2 ]] || die "--frontier-cost-per-unit requires a value"
        frontier_cost="$2"
        shift 2
        ;;
      --worker-cost-per-unit)
        [[ $# -ge 2 ]] || die "--worker-cost-per-unit requires a value"
        worker_cost="$2"
        shift 2
        ;;
      -h|--help)
        printf 'Usage: ocw savings [--json] [--days N] [--frontier-cost-per-unit N] [--worker-cost-per-unit N]\n'
        return
        ;;
      *)
        die "unknown savings option: $1"
        ;;
    esac
  done

  [[ "$days" =~ ^[0-9]+$ ]] || die "--days must be a non-negative integer"
  root_abs="$(prepare_output_root "$root")"
  cutoff="$(cutoff_iso_days "$days")"

  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    metadata="$dir/metadata.txt"
    [[ -f "$metadata" ]] || continue
    created_at="$(metadata_value "$metadata" "created_at")"
    if [[ -n "$cutoff" && -n "$created_at" && "$created_at" < "$cutoff" ]]; then
      continue
    fi
    mode="$(metadata_value "$metadata" "mode")"
    status="$(metadata_value "$metadata" "status")"
    weight="$(mode_savings_weight "$mode")"
    runs=$((runs + 1))
    frontier_units=$((frontier_units + weight))
    worker_units=$((worker_units + 1))
    if [[ "$status" == "0" ]]; then
      ok=$((ok + 1))
    else
      failed=$((failed + 1))
    fi
    if [[ "$(metadata_value "$metadata" "delegate")" == "1" ]]; then
      delegated=$((delegated + 1))
    fi
  done <<EOF
$(find "$root_abs" -mindepth 1 -maxdepth 1 -type d -print | sort)
EOF

  estimate="$(awk -v units="$frontier_units" -v workers="$worker_units" -v frontier="$frontier_cost" -v worker="$worker_cost" 'BEGIN { printf "%.4f", (units * frontier) - (workers * worker) }')"

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.savings.v1",\n'
    printf '  "output_root": '
    json_string "$root_abs"
    printf ',\n  "days": %s,\n  "runs": %s,\n  "successful_runs": %s,\n  "failed_runs": %s,\n  "delegated_runs": %s,\n' "$days" "$runs" "$ok" "$failed" "$delegated"
    printf '  "frontier_equivalent_units": %s,\n  "worker_units": %s,\n' "$frontier_units" "$worker_units"
    printf '  "frontier_cost_per_unit": %s,\n  "worker_cost_per_unit": %s,\n  "estimated_savings": %s\n' "$frontier_cost" "$worker_cost" "$estimate"
    printf '}\n'
    return
  fi

  printf 'OCW savings estimate\n'
  printf 'output_root: %s\n' "$root_abs"
  printf 'runs: %s (%s ok, %s failed, %s delegated)\n' "$runs" "$ok" "$failed" "$delegated"
  printf 'frontier_equivalent_units: %s\n' "$frontier_units"
  printf 'worker_units: %s\n' "$worker_units"
  printf 'estimated_savings: %s\n' "$estimate"
  printf 'note: cost units are configurable estimates, not provider billing records\n'
}

verdict_command() {
  local root="$1"
  shift
  local ref="latest" json=0 root_abs run_dir metadata mode status worktree diff_bytes audit_json audit_status audit_overall
  local overall="pass" safe_to_apply=false needs_final_review=true reason="worker output requires primary-agent review"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help)
        printf 'Usage: ocw verdict [latest|run-dir] [--json]\n'
        return
        ;;
      -*)
        die "unknown verdict option: $1"
        ;;
      *)
        ref="$1"
        shift
        ;;
    esac
  done

  root_abs="$(abs_existing_dir "$root")"
  run_dir="$(resolve_run_dir "$root_abs" "$ref")"
  metadata="$run_dir/metadata.txt"
  mode="$(metadata_value "$metadata" "mode")"
  status="$(metadata_value "$metadata" "status")"
  worktree="$(metadata_value "$metadata" "worktree")"
  diff_bytes=0
  [[ -f "$run_dir/diff.after.patch" ]] && diff_bytes="$(file_size_bytes "$run_dir/diff.after.patch")"

  set +e
  audit_json="$(audit_command "$root_abs" "$run_dir" --json)"
  audit_status=$?
  set -e
  audit_overall="$(printf '%s\n' "$audit_json" | awk -F'"' '/"overall":/ { print $4; exit }')"

  if [[ "$status" != "0" || "$audit_status" -ne 0 || "$audit_overall" == "fail" ]]; then
    overall="fail"
    reason="worker failed or audit found blocking issues"
  elif [[ "$audit_overall" == "warn" ]]; then
    overall="warn"
    reason="worker completed but audit warnings need review"
  fi

  if [[ "$mode" == "patch" && "$status" == "0" && "$audit_overall" == "ok" && "$worktree" == "1" && "$diff_bytes" -gt 0 ]]; then
    safe_to_apply=true
  fi

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.verdict.v1",\n'
    printf '  "run_dir": '
    json_string "$run_dir"
    printf ',\n  "overall": '
    json_string "$overall"
    printf ',\n  "mode": '
    json_string "$mode"
    printf ',\n  "status": '
    json_string "$status"
    printf ',\n  "audit_overall": '
    json_string "$audit_overall"
    printf ',\n  "diff_bytes": %s,\n  "needs_final_review": %s,\n  "safe_to_apply_after_review": %s,\n  "reason": ' "$diff_bytes" "$needs_final_review" "$safe_to_apply"
    json_string "$reason"
    printf '\n}\n'
    [[ "$overall" != "fail" ]]
    return
  fi

  printf 'OCW verdict: %s\n' "$overall"
  printf 'run: %s\n' "$run_dir"
  printf 'mode: %s\n' "${mode:-unknown}"
  printf 'status: %s\n' "${status:-unknown}"
  printf 'audit: %s\n' "${audit_overall:-unknown}"
  printf 'needs_final_review: %s\n' "$needs_final_review"
  printf 'safe_to_apply_after_review: %s\n' "$safe_to_apply"
  printf 'reason: %s\n' "$reason"
  [[ "$overall" != "fail" ]]
}

backend_registry_path() {
  printf '%s\n' "${OCW_BACKENDS_FILE:-$(ocw_state_dir)/ocw-backends.tsv}"
}

backend_builtin_rows() {
  cat <<'EOF'
opencode-go	provider	opencode	https://opencode.ai	OpenCode Go provider through OpenCode CLI
opencode-local	agent	opencode	https://opencode.ai	Local OpenCode models or configured providers
aider	agent	aider	https://aider.chat	Aider CLI adapter candidate
openhands	agent	openhands	https://docs.all-hands.dev	OpenHands agent runtime candidate
swe-agent	agent	sweagent	https://swe-agent.com	SWE-agent runtime candidate
goose	agent	goose	https://block.github.io/goose	Goose local agent candidate
ollama	provider	ollama	https://ollama.com	Local Ollama model provider candidate
litellm	gateway	litellm	https://docs.litellm.ai	LiteLLM proxy/gateway candidate
openrouter	gateway	curl	https://openrouter.ai	OpenRouter API gateway candidate
bifrost	gateway	bifrost	https://docs.getbifrost.ai	Bifrost AI gateway candidate
EOF
}

backend_command_available() {
  local command_name="$1"
  if [[ "$command_name" == "opencode" ]]; then
    have_command "$OPENCODE_BIN"
  else
    have_command "$command_name"
  fi
}

backend_custom_rows() {
  local file
  file="$(backend_registry_path)"
  [[ -f "$file" ]] || return 0
  awk -F '\t' 'BEGIN { OFS = "\t" } NR > 1 { print $2, $3, $4, $5, $6 }' "$file"
}

backend_row_for() {
  local name="$1"
  local custom
  custom="$(backend_custom_rows | awk -F '\t' -v name="$name" '$1 == name { print }' | tail -n 1)"
  if [[ -n "$custom" ]]; then
    printf '%s\n' "$custom"
    return
  fi
  backend_builtin_rows | awk -F '\t' -v name="$name" '$1 == name { print }'
}

backend_list_json() {
  local first=1 name kind command url note available
  printf '{\n'
  printf '  "schema_version": "ocw.backend.v1",\n'
  printf '  "registry": '
  json_string "$(backend_registry_path)"
  printf ',\n  "backends": [\n'
  while IFS=$'\t' read -r name kind command url note; do
    [[ -n "$name" ]] || continue
    if backend_command_available "$command"; then available=true; else available=false; fi
    if [[ "$first" -eq 0 ]]; then
      printf ',\n'
    fi
    printf '    { "name": '
    json_string "$name"
    printf ', "kind": '
    json_string "$kind"
    printf ', "command": '
    json_string "$command"
    printf ', "url": '
    json_string "$url"
    printf ', "available": %s, "note": ' "$available"
    json_string "$note"
    printf ' }'
    first=0
  done <<EOF
$(backend_builtin_rows)
$(backend_custom_rows)
EOF
  printf '\n  ]\n}\n'
}

backend_command() {
  local subcommand="${1:-list}"
  shift || true
  local json=0 force=0 name="" kind="" command_name="" url="" note="" registry
  local row available status=0 first=1 created_at

  registry="$(backend_registry_path)"

  case "$subcommand" in
    list|doctor|path|add|remove) ;;
    -h|--help|help)
      cat <<'EOF'
Usage:
  ocw backend list [--json]
  ocw backend doctor [--json]
  ocw backend add NAME [--kind KIND] [--command CMD] [--url URL] [--note TEXT] [--force]
  ocw backend remove NAME
  ocw backend path
EOF
      return
      ;;
    *) die "unknown backend command: $subcommand" ;;
  esac

  if [[ "$subcommand" == "path" ]]; then
    printf '%s\n' "$registry"
    return
  fi

  if [[ "$subcommand" == "add" ]]; then
    [[ $# -ge 1 ]] || die "Usage: ocw backend add NAME [--kind KIND] [--command CMD] [--url URL] [--note TEXT] [--force]"
    name="$1"
    shift
    row="$(backend_row_for "$name")"
    if [[ -n "$row" ]]; then
      IFS=$'\t' read -r name kind command_name url note <<< "$row"
    fi
    kind="${kind:-agent}"
    command_name="${command_name:-$name}"
    url="${url:-}"
    note="${note:-custom backend}"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --kind)
          [[ $# -ge 2 ]] || die "--kind requires a value"
          kind="$2"
          shift 2
          ;;
        --command)
          [[ $# -ge 2 ]] || die "--command requires a value"
          command_name="$2"
          shift 2
          ;;
        --url)
          [[ $# -ge 2 ]] || die "--url requires a value"
          url="$2"
          shift 2
          ;;
        --note)
          [[ $# -ge 2 ]] || die "--note requires a value"
          note="$2"
          shift 2
          ;;
        --force) force=1; shift ;;
        --json) json=1; shift ;;
        *) die "unknown backend add option: $1" ;;
      esac
    done
    ensure_parent_dir "$registry"
    if [[ ! -f "$registry" ]]; then
      printf 'created_at\tname\tkind\tcommand\turl\tnote\n' > "$registry"
    fi
    if [[ "$force" -eq 1 ]]; then
      awk -F '\t' -v name="$name" 'NR == 1 || $2 != name { print }' "$registry" > "$registry.tmp"
      mv "$registry.tmp" "$registry"
    elif awk -F '\t' -v name="$name" 'NR > 1 && $2 == name { found = 1 } END { exit(found ? 0 : 1) }' "$registry"; then
      die "backend already exists: $name (pass --force to replace)"
    fi
    created_at="$(now_utc)"
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$created_at" "$name" "$kind" "$command_name" "$url" "$note" >> "$registry"
    if [[ "$json" -eq 1 ]]; then
      printf '{ "schema_version": "ocw.backend.add.v1", "name": '
      json_string "$name"
      printf ', "registry": '
      json_string "$registry"
      printf ' }\n'
    else
      printf 'OCW backend added: %s\n' "$name"
      printf 'registry: %s\n' "$registry"
    fi
    return
  fi

  if [[ "$subcommand" == "remove" ]]; then
    [[ $# -eq 1 ]] || die "Usage: ocw backend remove NAME"
    name="$1"
    [[ -f "$registry" ]] || die "backend registry not found: $registry"
    awk -F '\t' -v name="$name" 'NR == 1 || $2 != name { print }' "$registry" > "$registry.tmp"
    mv "$registry.tmp" "$registry"
    printf 'OCW backend removed: %s\n' "$name"
    return
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help)
        printf 'Usage: ocw backend %s [--json]\n' "$subcommand"
        return
        ;;
      *) die "unknown backend option: $1" ;;
    esac
  done

  if [[ "$subcommand" == "list" ]]; then
    if [[ "$json" -eq 1 ]]; then
      backend_list_json
    else
      printf 'name\tkind\tcommand\tavailable\tnote\n'
      while IFS=$'\t' read -r name kind command_name url note; do
        [[ -n "$name" ]] || continue
        if backend_command_available "$command_name"; then available=yes; else available=no; fi
        printf '%s\t%s\t%s\t%s\t%s\n' "$name" "$kind" "$command_name" "$available" "$note"
      done <<EOF
$(backend_builtin_rows)
$(backend_custom_rows)
EOF
    fi
    return
  fi

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.backend.doctor.v1",\n'
    printf '  "registry": '
    json_string "$registry"
    printf ',\n  "checks": [\n'
  else
    printf 'OCW backend doctor\n'
  fi

  while IFS=$'\t' read -r name kind command_name url note; do
    [[ -n "$name" ]] || continue
    if backend_command_available "$command_name"; then
      available=true
    else
      available=false
      case "$name" in
        opencode-go|opencode-local) status=1 ;;
      esac
    fi
    if [[ "$json" -eq 1 ]]; then
      if [[ "$first" -eq 0 ]]; then
        printf ',\n'
      fi
      printf '    { "name": '
      json_string "$name"
      printf ', "command": '
      json_string "$command_name"
      printf ', "available": %s }' "$available"
      first=0
    else
      printf '[%s] %s (%s)\n' "$([[ "$available" == true ]] && printf ok || printf missing)" "$name" "$command_name"
    fi
  done <<EOF
$(backend_builtin_rows)
$(backend_custom_rows)
EOF

  if [[ "$json" -eq 1 ]]; then
    printf '\n  ],\n  "ok": %s\n}\n' "$([[ "$status" -eq 0 ]] && printf true || printf false)"
  fi
  return "$status"
}

report_write() {
  local out_file="$1"
  local tmp_file="$2"

  if [[ -n "$out_file" ]]; then
    mkdir -p "$(dirname "$out_file")"
    mv "$tmp_file" "$out_file"
    printf 'OCW report written: %s\n' "$out_file"
  else
    cat "$tmp_file"
    rm -f "$tmp_file"
  fi
}

report_command() {
  local root="$1"
  shift
  local ref="latest"
  local format="markdown"
  local out_file=""
  local run_dir metadata_file mode status model agent created_at summary diff_stat audit_text audit_status tmp title

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --markdown) format="markdown"; shift ;;
      --html) format="html"; shift ;;
      --json) format="json"; shift ;;
      --junit) format="junit"; shift ;;
      --sarif) format="sarif"; shift ;;
      --out)
        [[ $# -ge 2 ]] || die "--out requires a value"
        out_file="$2"
        shift 2
        ;;
      -h|--help)
        printf 'Usage: ocw report [latest|run-dir] [--markdown|--html|--json|--junit|--sarif] [--out FILE]\n'
        return
        ;;
      -*)
        die "unknown report option: $1"
        ;;
      *)
        ref="$1"
        shift
        ;;
    esac
  done

  root="$(abs_existing_dir "$root")"
  run_dir="$(resolve_run_dir "$root" "$ref")"
  metadata_file="$run_dir/metadata.txt"
  mode="$(metadata_value "$metadata_file" "mode")"
  status="$(metadata_value "$metadata_file" "status")"
  model="$(metadata_value "$metadata_file" "model")"
  agent="$(metadata_value "$metadata_file" "agent")"
  created_at="$(metadata_value "$metadata_file" "created_at")"
  summary=""
  [[ -f "$run_dir/summary.md" ]] && summary="$(cat "$run_dir/summary.md")"
  diff_stat=""
  [[ -f "$run_dir/diff.after.stat" ]] && diff_stat="$(cat "$run_dir/diff.after.stat")"
  set +e
  audit_text="$(audit_command "$root" "$run_dir")"
  audit_status=$?
  set -e

  tmp="$(mktemp "${TMPDIR:-/tmp}/ocw-report.XXXXXX")"
  title="OCW report: $(basename "$run_dir")"

  case "$format" in
    markdown)
      {
        printf '# %s\n\n' "$title"
        printf -- "- run: \`%s\`\n" "$run_dir"
        printf -- "- mode: \`%s\`\n" "${mode:-unknown}"
        printf -- "- status: \`%s\`\n" "${status:-unknown}"
        printf -- "- model: \`%s\`\n" "${model:-}"
        printf -- "- agent: \`%s\`\n" "${agent:-}"
        printf -- "- created_at: \`%s\`\n\n" "${created_at:-}"
        printf '## Summary\n\n%s\n\n' "${summary:-No summary artifact found.}"
        printf "## Diff Stat\n\n\`\`\`text\n%s\n\`\`\`\n\n" "${diff_stat:-No diff stat artifact found.}"
        printf "## Audit\n\n\`\`\`text\n%s\n\`\`\`\n" "$audit_text"
      } > "$tmp"
      ;;
    html)
      {
        printf '<!doctype html>\n<html><head><meta charset="utf-8"><title>%s</title>' "$(html_escape "$title")"
        printf '<style>body{font-family:-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif;max-width:960px;margin:40px auto;padding:0 20px;line-height:1.5}pre{background:#f6f8fa;padding:12px;overflow:auto}code{background:#f6f8fa;padding:2px 4px}</style>'
        printf '</head><body><h1>%s</h1>' "$(html_escape "$title")"
        printf '<p><strong>run:</strong> <code>%s</code></p>' "$(html_escape "$run_dir")"
        printf '<p><strong>mode:</strong> <code>%s</code> <strong>status:</strong> <code>%s</code></p>' "$(html_escape "${mode:-unknown}")" "$(html_escape "${status:-unknown}")"
        printf '<h2>Summary</h2><pre>%s</pre>' "$(html_escape "${summary:-No summary artifact found.}")"
        printf '<h2>Diff Stat</h2><pre>%s</pre>' "$(html_escape "${diff_stat:-No diff stat artifact found.}")"
        printf '<h2>Audit</h2><pre>%s</pre></body></html>\n' "$(html_escape "$audit_text")"
      } > "$tmp"
      ;;
    json)
      {
        printf '{\n'
        printf '  "schema_version": "ocw.report.v1",\n'
        printf '  "run_dir": '
        json_string "$run_dir"
        printf ',\n  "mode": '
        json_string "${mode:-}"
        printf ',\n  "status": '
        json_string "${status:-}"
        printf ',\n  "model": '
        json_string "${model:-}"
        printf ',\n  "agent": '
        json_string "${agent:-}"
        printf ',\n  "created_at": '
        json_string "${created_at:-}"
        printf ',\n  "audit_status": %s,\n  "summary": ' "$audit_status"
        json_string "$summary"
        printf ',\n  "diff_stat": '
        json_string "$diff_stat"
        printf ',\n  "audit": '
        json_string "$audit_text"
        printf '\n}\n'
      } > "$tmp"
      ;;
    junit)
      {
        printf '<?xml version="1.0" encoding="UTF-8"?>\n'
        printf '<testsuite name="ocw" tests="1" failures="%s">\n' "$audit_status"
        printf '  <testcase classname="ocw.audit" name="%s">\n' "$(xml_escape "$(basename "$run_dir")")"
        if [[ "$audit_status" -ne 0 ]]; then
          printf '    <failure message="OCW audit failed"><![CDATA[%s]]></failure>\n' "$audit_text"
        fi
        printf '  </testcase>\n</testsuite>\n'
      } > "$tmp"
      ;;
    sarif)
      {
        printf '{\n'
        printf '  "version": "2.1.0",\n'
        printf "  \"\$schema\": \"https://json.schemastore.org/sarif-2.1.0.json\",\n"
        printf '  "runs": [{\n'
        printf '    "tool": { "driver": { "name": "ocw", "version": '
        json_string "$VERSION"
        printf ', "informationUri": "https://github.com/BenitoJD/OCW-CLI" } },\n'
        printf '    "results": [{ "ruleId": "ocw-audit", "level": '
        if [[ "$audit_status" -ne 0 ]]; then
          json_string "error"
        elif grep -Fq 'overall: warn' <<< "$audit_text"; then
          json_string "warning"
        else
          json_string "note"
        fi
        printf ', "message": { "text": '
        json_string "$audit_text"
        printf ' }, "locations": [{ "physicalLocation": { "artifactLocation": { "uri": '
        json_string "$run_dir"
        printf ' } } }] }]\n'
        printf '  }]\n}\n'
      } > "$tmp"
      ;;
    *)
      die "unknown report format: $format"
      ;;
  esac

  report_write "$out_file" "$tmp"
  return "$audit_status"
}

trace_command() {
  local root="$1"
  shift
  local ref="latest"
  local json=0
  local run_dir metadata_file mode status created_at first file rel bytes sha key value line resolve_status

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        json=1
        shift
        ;;
      -h|--help)
        printf 'Usage: ocw trace [latest|run-dir] [--json]\n'
        return
        ;;
      -*)
        die "unknown trace option: $1"
        ;;
      *)
        ref="$1"
        shift
      ;;
    esac
  done

  set +e
  run_dir="$(resolve_run_dir "$root" "$ref" 2>&1)"
  resolve_status=$?
  set -e
  if [[ "$resolve_status" -ne 0 ]]; then
    if [[ "$json" -eq 1 ]]; then
      printf '{\n'
      printf '  "schema_version": "ocw.trace.v1",\n'
      printf '  "ok": false,\n'
      printf '  "error_code": "not_found",\n'
      printf '  "error": '
      json_string "$run_dir"
      printf '\n}\n'
    else
      printf '%s\n' "$run_dir" >&2
    fi
    return "$resolve_status"
  fi
  metadata_file="$run_dir/metadata.txt"
  mode="$(metadata_value "$metadata_file" "mode")"
  status="$(metadata_value "$metadata_file" "status")"
  created_at="$(metadata_value "$metadata_file" "created_at")"

  if [[ "$json" -eq 1 ]]; then
    printf '{\n'
    printf '  "schema_version": "ocw.trace.v1",\n'
    printf '  "run_dir": '
    json_string "$run_dir"
    printf ',\n  "mode": '
    json_string "$mode"
    printf ',\n  "status": '
    json_string "$status"
    printf ',\n  "created_at": '
    json_string "$created_at"
    printf ',\n  "metadata": {\n'
    first=1
    if [[ -f "$metadata_file" ]]; then
      while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" == *=* ]] || continue
        key="${line%%=*}"
        value="${line#*=}"
        if [[ "$first" -eq 0 ]]; then
          printf ',\n'
        fi
        printf '    '
        json_string "$key"
        printf ': '
        json_string "$value"
        first=0
      done < "$metadata_file"
    fi
    printf '\n  },\n  "events": [\n'
    first=1
    while IFS= read -r file; do
      [[ -n "$file" ]] || continue
      rel="${file#"$run_dir"/}"
      bytes="$(file_size_bytes "$file")"
      sha="$(file_sha256 "$file")"
      if [[ "$first" -eq 0 ]]; then
        printf ',\n'
      fi
      printf '    { "type": "artifact", "name": '
      json_string "$rel"
      printf ', "bytes": %s, "sha256": ' "$bytes"
      json_string "$sha"
      printf ' }'
      first=0
    done <<EOF
$(find "$run_dir" -type f -print | sort)
EOF
    printf '\n  ]\n}\n'
    return
  fi

  printf 'OCW trace: %s\n' "$run_dir"
  printf 'mode: %s\n' "${mode:-unknown}"
  printf 'status: %s\n' "${status:-unknown}"
  printf 'created_at: %s\n\n' "${created_at:-unknown}"
  printf 'artifacts:\n'
  while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    rel="${file#"$run_dir"/}"
    bytes="$(file_size_bytes "$file")"
    printf '  - %s (%s bytes)\n' "$rel" "$bytes"
  done <<EOF
$(find "$run_dir" -type f -print | sort)
EOF
}

print_default_policy() {
  local profile="${1:-balanced}"
  cat <<EOF
profile = "$profile"
fail_on_audit_warn = $([[ "$profile" == "strict" ]] && printf 'true' || printf 'false')
require_patch_worktree = true
max_diff_bytes = 200000
EOF
}

policy_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 0
  awk -F= -v key="$key" '$1 ~ "^[[:space:]]*" key "[[:space:]]*$" { gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2); gsub(/^"|"$/, "", $2); print $2 }' "$file" | tail -n 1
}

policy_command() {
  local root="$1"
  shift
  local subcommand="${1:-check}"
  local profile="balanced"
  local force=0
  local ref="latest"
  local policy_file=".ocw-policy.toml"
  local audit_text audit_status run_dir metadata_file mode worktree fail_on_warn require_worktree max_diff_bytes

  shift || true
  case "$subcommand" in
    init)
      if [[ $# -gt 0 && "$1" != --* ]]; then
        profile="$1"
        shift
      fi
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --force) force=1; shift ;;
          -h|--help)
            printf 'Usage: ocw policy init [balanced|strict] [--force]\n'
            return
            ;;
          *) die "unknown policy init option: $1" ;;
        esac
      done
      case "$profile" in balanced|strict) ;; *) die "unknown policy profile: $profile" ;; esac
      if [[ -f "$policy_file" && "$force" -ne 1 ]]; then
        printf 'Kept existing policy: %s\n' "$policy_file"
      else
        print_default_policy "$profile" > "$policy_file"
        printf 'Installed policy: %s\n' "$policy_file"
      fi
      ;;
    show)
      if [[ -f "$policy_file" ]]; then
        cat "$policy_file"
      else
        print_default_policy balanced
      fi
      ;;
    check)
      if [[ $# -gt 0 ]]; then
        ref="$1"
        shift
      fi
      [[ $# -eq 0 ]] || die "unknown policy check option: $1"
      root="$(abs_existing_dir "$root")"
      run_dir="$(resolve_run_dir "$root" "$ref")"
      metadata_file="$run_dir/metadata.txt"
      fail_on_warn="$(policy_value "$policy_file" "fail_on_audit_warn")"
      require_worktree="$(policy_value "$policy_file" "require_patch_worktree")"
      max_diff_bytes="$(policy_value "$policy_file" "max_diff_bytes")"
      [[ -n "$fail_on_warn" ]] || fail_on_warn="false"
      [[ -n "$require_worktree" ]] || require_worktree="true"
      [[ -n "$max_diff_bytes" ]] || max_diff_bytes="200000"
      set +e
      audit_text="$(audit_command "$root" "$run_dir" --max-diff-bytes "$max_diff_bytes")"
      audit_status=$?
      set -e
      printf '%s\n' "$audit_text"
      if [[ "$audit_status" -ne 0 ]]; then
        return "$audit_status"
      fi
      if [[ "$fail_on_warn" == "true" && "$audit_text" == *"overall: warn"* ]]; then
        printf 'policy: failed because fail_on_audit_warn=true\n' >&2
        return 1
      fi
      mode="$(metadata_value "$metadata_file" "mode")"
      worktree="$(metadata_value "$metadata_file" "worktree")"
      if [[ "$require_worktree" == "true" && "$mode" == "patch" && "$worktree" != "1" ]]; then
        printf 'policy: failed because patch did not run in an isolated worktree\n' >&2
        return 1
      fi
      printf 'policy: ok\n'
      ;;
    -h|--help|help)
      cat <<'EOF'
Usage:
  ocw policy init [balanced|strict] [--force]
  ocw policy show
  ocw policy check [latest|run-dir]
EOF
      ;;
    *)
      die "unknown policy command: $subcommand"
      ;;
  esac
}

clean_command() {
  local root="$1"
  shift
  local days=""
  local all=0
  local dry_run=0
  local yes=0
  local targets_file dir count

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --days)
        [[ $# -ge 2 ]] || die "--days requires a value"
        days="$2"
        shift 2
        ;;
      --all)
        all=1
        shift
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --yes)
        yes=1
        shift
        ;;
      -h|--help)
        printf 'Usage: ocw clean (--days N|--all) [--dry-run] [--yes]\n'
        return
        ;;
      *)
        die "unknown clean option: $1"
        ;;
    esac
  done

  [[ "$all" -eq 1 || -n "$days" ]] || die "clean requires --days N or --all"
  if [[ -n "$days" && ! "$days" =~ ^[0-9]+$ ]]; then
    die "--days must be a non-negative integer"
  fi

  root="$(abs_existing_dir "$root")"
  if [[ "$root" == "/" || "$root" == "$HOME" || "$root" == "$PWD" ]]; then
    die "refusing unsafe clean root: $root"
  fi

  targets_file="$(mktemp "${TMPDIR:-/tmp}/ocw-clean.XXXXXX")"
  if [[ "$all" -eq 1 ]]; then
    find "$root" -mindepth 1 -maxdepth 1 -type d -print | sort > "$targets_file"
  else
    find "$root" -mindepth 1 -maxdepth 1 -type d -mtime +"$days" -print | sort > "$targets_file"
  fi

  if [[ ! -s "$targets_file" ]]; then
    rm -f "$targets_file"
    printf 'No OCW runs matched clean criteria\n'
    return
  fi

  count=0
  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    count=$((count + 1))
    if [[ "$dry_run" -eq 1 || "$yes" -ne 1 ]]; then
      printf '%s\n' "$dir"
    else
      rm -rf "$dir"
    fi
  done < "$targets_file"

  rm -f "$targets_file"

  if [[ "$dry_run" -eq 1 ]]; then
    printf 'Dry run: %s run(s) matched\n' "$count"
  elif [[ "$yes" -ne 1 ]]; then
    printf 'Pass --yes to remove %s run(s)\n' "$count"
  else
    printf 'Removed %s run(s)\n' "$count"
  fi
}

