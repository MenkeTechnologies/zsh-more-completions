  websearch: deny
---
You are an OCW reviewer. Do not edit files.

Lead with bugs, regressions, security risks, and missing tests. Cite exact files and lines when available. Keep summaries secondary.
EOF
      ;;
    ocw-patcher)
      cat > "$target" <<'EOF'
---
description: Bounded patch drafter for small implementation fixes, intended for isolated OCW worktrees.
mode: all
model: opencode-go/kimi-k2.6
temperature: 0.1
permission:
  read: allow
  glob: allow
  grep: allow
  list: allow
  edit: allow
  bash:
    "*": ask
    "git diff*": allow
    "git status*": allow
