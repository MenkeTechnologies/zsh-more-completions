bridge_service_write_files() {
  local manager="$1"
  local host="$2"
  local port="$3"
  local runtime_dir="$4"
  local quiet="${5:-0}"
  local service_file launcher stdout_log stderr_log

  service_file="$(bridge_service_definition_path "$manager")"
  launcher="$(bridge_service_launcher_path "$manager")"
  stdout_log="$(bridge_service_stdout_log)"
  stderr_log="$(bridge_service_stderr_log)"
  mkdir -p "$(dirname "$stdout_log")" "$(dirname "$stderr_log")"
  : > "$stdout_log"
  : > "$stderr_log"

  if [[ "$manager" == "windows" ]]; then
    bridge_write_windows_service_launcher "$launcher" "$host" "$port" "$runtime_dir"
    bridge_write_windows_task_xml "$service_file" "$launcher" "$stdout_log" "$stderr_log"
  else
    bridge_write_posix_service_launcher "$launcher" "$host" "$port" "$runtime_dir"
    if [[ "$manager" == "launchd" ]]; then
      bridge_write_launchd_plist "$service_file" "$launcher" "$runtime_dir" "$stdout_log" "$stderr_log"
    else
      bridge_write_systemd_unit "$service_file" "$launcher" "$runtime_dir" "$stdout_log" "$stderr_log"
    fi
  fi

  if [[ "$quiet" -ne 1 ]]; then
    printf 'Installed bridge service launcher: %s\n' "$launcher"
    printf 'Installed bridge service definition: %s\n' "$service_file"
  fi
}

bridge_service_install_manager() {
  local manager="$1"
  local start="$2"
  local dry_run="$3"
  local quiet="${4:-0}"
  local service_file label uid task_name

  service_file="$(bridge_service_definition_path "$manager")"
  label="$(bridge_service_label)"
  if [[ "$dry_run" -eq 1 ]]; then
    [[ "$quiet" -eq 1 ]] || printf 'OCW bridge service install dry-run: %s\n' "$manager"
    return
  fi

  case "$manager" in
    launchd)
      require_command launchctl
      uid="$(id -u)"
      if [[ "$start" -eq 1 ]]; then
        launchctl bootout "gui/$uid/$label" >/dev/null 2>&1 || true
        launchctl bootstrap "gui/$uid" "$service_file"
        launchctl enable "gui/$uid/$label" >/dev/null 2>&1 || true
        launchctl kickstart -k "gui/$uid/$label"
      fi
      ;;
    systemd)
      require_command systemctl
      systemctl --user daemon-reload
      systemctl --user enable "$(basename "$service_file")"
      if [[ "$start" -eq 1 ]]; then
        systemctl --user restart "$(basename "$service_file")"
      fi
      ;;
    windows)
      require_command schtasks.exe
      task_name="$(bridge_windows_task_name)"
      schtasks.exe /Create /TN "$task_name" /XML "$(bridge_to_windows_path "$service_file")" /F >/dev/null
      if [[ "$start" -eq 1 ]]; then
        schtasks.exe /Run /TN "$task_name" >/dev/null
      fi
      ;;
  esac
}

bridge_service_start_manager() {
  local manager="$1"
  local service_file label uid task_name

  service_file="$(bridge_service_definition_path "$manager")"
  label="$(bridge_service_label)"
  case "$manager" in
    launchd)
      require_command launchctl
      uid="$(id -u)"
      launchctl bootstrap "gui/$uid" "$service_file" >/dev/null 2>&1 || true
      launchctl kickstart -k "gui/$uid/$label"
      ;;
    systemd)
      require_command systemctl
      systemctl --user start "$(basename "$service_file")"
      ;;
    windows)
      require_command schtasks.exe
      task_name="$(bridge_windows_task_name)"
      schtasks.exe /Run /TN "$task_name" >/dev/null
      ;;
  esac
}

bridge_service_stop_manager() {
  local manager="$1"
  local service_file label uid task_name

  service_file="$(bridge_service_definition_path "$manager")"
  label="$(bridge_service_label)"
  case "$manager" in
    launchd)
      require_command launchctl
      uid="$(id -u)"
      launchctl bootout "gui/$uid/$label" >/dev/null 2>&1 || true
      ;;
    systemd)
      require_command systemctl
      systemctl --user stop "$(basename "$service_file")" >/dev/null 2>&1 || true
      ;;
    windows)
      require_command schtasks.exe
      task_name="$(bridge_windows_task_name)"
      schtasks.exe /End /TN "$task_name" >/dev/null 2>&1 || true
      ;;
  esac
}

bridge_service_uninstall_manager() {
  local manager="$1"
  local dry_run="$2"
  local service_file task_name

  service_file="$(bridge_service_definition_path "$manager")"
  if [[ "$dry_run" -eq 1 ]]; then
    printf 'OCW bridge service uninstall dry-run: %s\n' "$manager"
    return
  fi
  bridge_service_stop_manager "$manager" || true
  case "$manager" in
    systemd)
      systemctl --user disable "$(basename "$service_file")" >/dev/null 2>&1 || true
      systemctl --user daemon-reload >/dev/null 2>&1 || true
      ;;
    windows)
      require_command schtasks.exe
      task_name="$(bridge_windows_task_name)"
      schtasks.exe /Delete /TN "$task_name" /F >/dev/null 2>&1 || true
      ;;
    launchd) ;;
  esac
}

bridge_service_active() {
  local manager="$1"
  local service_file label uid task_name

  service_file="$(bridge_service_definition_path "$manager")"
  label="$(bridge_service_label)"
  case "$manager" in
    launchd)
      have_command launchctl || return 1
      uid="$(id -u)"
      launchctl print "gui/$uid/$label" >/dev/null 2>&1
      ;;
    systemd)
      have_command systemctl || return 1
      systemctl --user is-active --quiet "$(basename "$service_file")"
      ;;
    windows)
      have_command schtasks.exe || return 1
      task_name="$(bridge_windows_task_name)"
      schtasks.exe /Query /TN "$task_name" >/dev/null 2>&1
      ;;
  esac
}

bridge_run_service_command() {
  local host="${OCW_BRIDGE_HOST:-127.0.0.1}"
  local port="${OCW_BRIDGE_PORT:-4000}"
  local runtime_dir="${OCW_BRIDGE_SERVICE_RUNTIME_DIR:-$(bridge_global_runtime_dir)}"
  local key

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --host) host="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      --runtime-dir) runtime_dir="$2"; shift 2 ;;
      -h|--help)
        printf 'Usage: ocw bridge run-service [--host HOST] [--port PORT] [--runtime-dir DIR]\n'
        return
        ;;
      *) die "unknown bridge run-service option: $1" ;;
    esac
  done

  bridge_validate_port "$port"
  require_command "$PYTHON_BIN"
  [[ -f "$runtime_dir/bridge.py" ]] || die "bridge runtime not found: $runtime_dir/bridge.py"
  if ! bridge_loopback_host_ok "$host" && [[ "${OCW_BRIDGE_ALLOW_NON_LOOPBACK:-0}" != "1" ]]; then
    die "refusing to bind bridge to non-loopback host '$host' (set OCW_BRIDGE_ALLOW_NON_LOOPBACK=1 to override)"
  fi

  bridge_load_credentials "$(bridge_global_env_file)"
  key="$(bridge_proxy_key_get_or_create)"
  export LITELLM_MASTER_KEY="$key"
  export PROXY_API_KEY="$key"
  export PROXY_HOST="$host"
  export PROXY_PORT="$port"
  export PROXY_STATE_DB="${PROXY_STATE_DB:-$(bridge_global_state_dir)/bridge-state.sqlite3}"
  export FORCE_SINGLE_TOOL_INSTRUCTIONS="${FORCE_SINGLE_TOOL_INSTRUCTIONS:-1}"
  export FALLBACK_MODEL_MAP_JSON="${FALLBACK_MODEL_MAP_JSON:-{\"deepseek-v4-pro\":[\"kimi-k2.6\",\"deepseek-v4-flash\"],\"kimi-k2.6\":[\"deepseek-v4-pro\"],\"deepseek-v4-flash\":[\"kimi-k2.6\"]}}"
  mkdir -p "$(bridge_global_state_dir)"
  exec "$PYTHON_BIN" "$runtime_dir/bridge.py" --host "$host" --port "$port"
}

bridge_health_status() {
  local host="$1"
  local port="$2"
  local key="$3"
  local status

  have_command "$CURL_BIN" || {
    printf '000\n'
    return
  }
  status="$("$CURL_BIN" -sS -o /dev/null -w '%{http_code}' --max-time 2 "http://$host:$port/health" \
    -H "Authorization: Bearer $key" 2>/dev/null || true)"
  printf '%s\n' "${status:-000}"
}

bridge_health_check() {
  local host="$1"
  local port="$2"
  local key="$3"

  have_command "$CURL_BIN" || return 2
  "$CURL_BIN" -fsS --max-time 2 "http://$host:$port/health" \
    -H "Authorization: Bearer $key" >/dev/null 2>&1
}

bridge_wait_for_health() {
  local host="$1"
  local port="$2"
  local key="$3"
  local pid="$4"
  local timeout="$5"
  local attempt=0

  while (( attempt < timeout )); do
    if bridge_health_check "$host" "$port" "$key"; then
      return 0
    fi
    if [[ "$pid" =~ ^[0-9]+$ ]] && ! kill -0 "$pid" >/dev/null 2>&1; then
      return 2
    fi
    attempt=$((attempt + 1))
    sleep 1
  done
  return 1
}

bridge_pid_running() {
  local pid_file="$1"
  local pid

  [[ -f "$pid_file" ]] || return 1
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" >/dev/null 2>&1
}

bridge_print_codex_config() {
  local port="$1"
  local host="${2:-127.0.0.1}"
  local auth_cmd

  auth_cmd="if [ -n \"\${OCW_BRIDGE_KEY:-\${PROXY_API_KEY:-\${LITELLM_MASTER_KEY:-}}}\" ]; then printf %s \"\${OCW_BRIDGE_KEY:-\${PROXY_API_KEY:-\${LITELLM_MASTER_KEY:-}}}\"; else $(shell_single_quote "$(bridge_self_abs)") bridge proxy-key print; fi"
  cat <<EOF
[model_providers.opencode_bridge]
name = "OpenCode Bridge"
base_url = "http://$(bridge_url_host "$host"):$port/v1"
wire_api = "responses"
request_max_retries = 2
stream_max_retries = 2
stream_idle_timeout_ms = 900000

[model_providers.opencode_bridge.auth]
command = "sh"
args = ["-c", $(json_string "$auth_cmd")]
timeout_ms = 1000

[profiles.oss_native]
model_provider = "opencode_bridge"
web_search = "disabled"

[profiles.oss_native.features]
apps = false
EOF
}

bridge_write_codex_config() {
  local target="$1"
  local force="$2"
  local port="$3"
  local host="${4:-127.0.0.1}"
  local tmp snippet

  mkdir -p "$(dirname "$target")"
  snippet="$(bridge_print_codex_config "$port" "$host")"

  if [[ -f "$target" ]] && grep -Fq "[model_providers.opencode_bridge]" "$target"; then
    if [[ "$force" -ne 1 ]]; then
      printf 'Kept existing Codex bridge config: %s\n' "$target"
      return
    fi
    tmp="$(mktemp "${TMPDIR:-/tmp}/ocw-bridge-config.XXXXXX")"
    awk '
      /^\[[^]]+\]$/ {
        skip = ($0 == "[model_providers.opencode_bridge]" ||
          $0 == "[model_providers.opencode_bridge.auth]" ||
          $0 == "[profiles.oss_native]" ||
          $0 == "[profiles.oss_native.features]")
        if (!skip) print
        next
      }
      !skip { print }
    ' "$target" > "$tmp"
    mv "$tmp" "$target"
  fi

  if [[ -s "$target" ]]; then
    printf '\n' >> "$target"
  fi
  printf '%s\n' "$snippet" >> "$target"
  printf 'Installed Codex bridge config: %s\n' "$target"
}

bridge_install_command() {
  local target_dir
  local source_dir
  local force=0
  local json=0
  local log_file=""
  local installed_runtime=0
  local file

  target_dir="$(bridge_project_dir)"
  source_dir="$(bridge_vendor_dir)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dir) target_dir="$2"; shift 2 ;;
      --force) force=1; shift ;;
      --json) json=1; shift ;;
      -h|--help)
        printf 'Usage: ocw bridge install [--dir DIR] [--force] [--json]\n'
        return
        ;;
      *) die "unknown bridge install option: $1" ;;
    esac
  done

  if [[ "$json" -eq 1 ]]; then
    log_file="$(mktemp "${TMPDIR:-/tmp}/ocw-bridge-install.XXXXXX")"
    exec 3>&1
    exec > "$log_file"
  fi

  [[ -f "$source_dir/bridge.py" ]] || die "bridge runtime not found: $source_dir"
  if [[ -f "$target_dir/bridge.py" && "$force" -ne 1 ]]; then
    printf 'Kept existing bridge runtime: %s\n' "$target_dir"
  else
    mkdir -p "$target_dir"
    cp -R "$source_dir/." "$target_dir/"
    printf 'Installed bridge runtime: %s\n' "$target_dir"
    installed_runtime=1
  fi

  if [[ "$installed_runtime" -eq 0 ]]; then
    mkdir -p "$target_dir/bin" "$target_dir/orchestration" "$target_dir/workers"
    for file in start-proxy oss-lib oss-scout oss-review oss-docs oss-patch; do
      if [[ -f "$source_dir/bin/$file" ]]; then
        copy_if_needed "$source_dir/bin/$file" "$target_dir/bin/$file" "bridge helper" "$force"
      fi
    done
    for file in "$source_dir"/orchestration/*.md; do
      [[ -f "$file" ]] || continue
      copy_if_needed "$file" "$target_dir/orchestration/$(basename "$file")" "bridge orchestration doc" "$force"
    done
    for file in "$source_dir"/workers/*.toml; do
      [[ -f "$file" ]] || continue
      copy_if_needed "$file" "$target_dir/workers/$(basename "$file")" "bridge worker override" "$force"
    done
  fi

  chmod +x "$target_dir/bridge.py" "$target_dir/bin/start-proxy" "$target_dir/bin/oss-scout" "$target_dir/bin/oss-review" "$target_dir/bin/oss-docs" "$target_dir/bin/oss-patch" 2>/dev/null || true

  if [[ ! -f "$target_dir/opencode-go.env" ]]; then
    cp "$source_dir/opencode-go.env.example" "$target_dir/opencode-go.env"
    printf 'Installed bridge env template: %s\n' "$target_dir/opencode-go.env"
  fi

  ensure_gitignore_entry ".gitignore" "$target_dir/"
  ensure_gitignore_entry ".gitignore" ".codex/ocw-bridge-results/"
  ensure_gitignore_entry ".gitignore" ".codex/ocw-bridge-worktrees/"
  printf 'Updated gitignore: .gitignore\n'

  if [[ "$json" -eq 1 ]]; then
    exec 1>&3
    exec 3>&-
    printf '{\n'
    printf '  "schema_version": "ocw.bridge.install.v1",\n'
    printf '  "dir": '
    json_string "$target_dir"
    printf ',\n  "runtime": '
    json_string "$target_dir/bridge.py"
    printf ',\n  "log": '
    json_string "$(cat "$log_file")"
    printf '\n}\n'
    rm -f "$log_file"
  fi
}

bridge_agents_command() {
  local subcommand="${1:-sync}"
  local target_dir=".codex/agents"
  local source_dir
  local force=0
  local file

  shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dir) target_dir="$2"; shift 2 ;;
      --force) force=1; shift ;;
      -h|--help)
        printf 'Usage: ocw bridge agents sync [--dir DIR] [--force]\n'
        return
        ;;
      *) die "unknown bridge agents option: $1" ;;
    esac
  done

  case "$subcommand" in
    sync) ;;
    -h|--help|help)
      printf 'Usage: ocw bridge agents sync [--dir DIR] [--force]\n'
      return
      ;;
    *) die "unknown bridge agents command: $subcommand" ;;
  esac

  source_dir="$(bridge_runtime_dir)"
  if [[ ! -d "$source_dir/agents" && -d "$(bridge_vendor_dir)/agents" ]]; then
    source_dir="$(bridge_vendor_dir)"
  fi
  [[ -d "$source_dir/agents" ]] || die "bridge agents not found: $source_dir/agents"
  mkdir -p "$target_dir"
  for file in "$source_dir"/agents/*.toml; do
    [[ -f "$file" ]] || die "no bridge agent templates found: $source_dir/agents"
    copy_if_needed "$file" "$target_dir/$(basename "$file")" "Codex bridge agent" "$force"
  done
  printf 'OCW bridge agents synced: %s\n' "$target_dir"
}

bridge_workers_command() {
