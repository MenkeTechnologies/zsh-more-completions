#compdef coz
# _coz — Coz causal profiler (UMass, Curtsinger/Berger); causal profiling shows expected speedup per optimization
# upstream: https://github.com/plasma-umass/coz

_coz() {
    local -a sub=(
        'run:profile and run program'
        'plot:render profile to HTML'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coz subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--source-scope+[scope glob]:glob:' \
                    '--binary-scope+[binary glob]:glob:' \
                    '--progress+[progress point]:loc:' \
                    '--end-to-end[end-to-end mode]' \
                    '--output+[output profile]:file:_files' \
                    '--fixed-line+[fixed line loc]:loc:' \
                    '--fixed-speedup+[fixed speedup %]:n:' \
                    '---[separator]' \
                    '*::command:_command_names -e' ;;
                plot) _arguments \
                    '--output+[html output]:file:_files' \
                    '1:profile:_files' ;;
            esac
            ;;
    esac
}

_coz "$@"
