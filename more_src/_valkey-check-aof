#compdef valkey-check-aof
# Documentation: https://man.archlinux.org/search?q=valkey-check-aof
# Reference accessed: 2026-05-16

# valkey-check-aof: check/fix Valkey AOF
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--fix[truncate aof on first error]' \
  '*:AOF file:_files -g "*.aof"' && ret=0
return ret
