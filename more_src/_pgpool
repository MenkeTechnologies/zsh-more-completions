#compdef pgpool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-a+[pool_hba.conf file]:hba file:_files' \
  '--hba-file=[pool_hba.conf file]:hba file:_files' \
  '-f+[pgpool.conf file]:config file:_files' \
  '--config-file=[pgpool.conf file]:config file:_files' \
  '-F+[pcp.conf file]:pcp file:_files' \
  '--pcp-password-file=[pcp.conf file]:pcp file:_files' \
  '-k+[PCP password file]:password file:_files' \
  '-n[do not run in daemon mode]' \
  '--dont-detach[do not run in daemon mode]' \
  '-x[do not detach from parent process]' \
  '--no-daemon[do not detach from parent process]' \
  '-D[discard pgpool_status file at startup]' \
  '--discard-status[discard pgpool_status file at startup]' \
  '-C[clear query cache at startup]' \
  '--clear-cache[clear query cache at startup]' \
  '-d[debug mode]' \
  '--debug[debug mode]' \
  '-m+[shutdown mode]:mode:(smart fast immediate)' \
  '--mode=[shutdown mode]:mode:(smart fast immediate)' && ret=0

return ret
