#compdef tunalog
# ============================================================================
# tunalog - simple no-installation blogging
#            system written in Go
#            (Go, MIT)
#
# Author : caris-events / Yami Odymel
#           (Taiwanese open-source
#           developer; long-time
#           contributor to multiple Go
#           CLI + web tooling projects)
# Upstream: https://github.com/caris-events/tunalog
#
# `tunalog` 🐟 is a minimalist single-binary
# blogging system designed for no-installation
# deployment. Drop the binary on a server,
# run it, get a blog at http://localhost:8080
# - no database setup + no PHP/Node runtime +
# no PostgreSQL/MySQL required.
#
# Architecture:
#   - **Single binary** (Go cross-compiles
#     for Linux + macOS + Windows + ARM +
#     ARM64; ~15 MB executable contains
#     everything)
#   - **Embedded SQLite** (database is a
#     single file; no separate DB server
#     required)
#   - **Gin web framework** (high-
#     performance HTTP routing; Axis 288
#     Go slot canonical web framework)
#   - **Server-rendered templates** (no
#     SPA frontend; multitemplate-based
#     HTML rendering)
#   - **gomarkdown/markdown** (post
#     content stored as Markdown,
#     rendered to HTML on request)
#   - **bcrypt password storage**
#     (admin user passwords hashed with
#     golang.org/x/crypto/bcrypt)
#   - **Image conversion** (sunshineplan
#     /imgconv for uploaded image format
#     normalization)
#   - **i18n support** (teacat/i18n for
#     multi-language UI)
#   - **CSRF protection** (utrack/gin-
#     csrf middleware)
#
# Distinguishing features vs alternatives
# (WordPress + Ghost + Hexo + Hugo):
#   - **No installation required** (drop
#     binary + run; no LAMP stack + no
#     Node.js runtime)
#   - **Dynamic single-binary** (vs
#     Hugo/Hexo which require external
#     build step + separate web server)
#   - **Self-contained admin UI** (the
#     binary serves both public blog +
#     admin interface)
#   - **Bun-light footprint** (~50 MB
#     RAM at idle; runs comfortably on
#     Raspberry Pi)
#   - **Built-in TLS support** (--tls-
#     crt + --tls-key flags; no nginx/
#     Caddy proxy required)
#   - **Markdown-first** (posts authored
#     in Markdown; clean separation of
#     content from rendering)
#
# Use cases:
#   - Personal blog (no-setup deployment
#     for individual bloggers)
#   - Small team announcements (internal
#     team blogs without infrastructure
#     overhead)
#   - Self-hosted on Raspberry Pi + edge
#     compute (low-resource environments)
#   - Air-gapped deployments (single
#     binary works without internet
#     access)
#   - Quick prototypes + side projects
#     (rapid blog setup)
#
# Usage:
#   tunalog [global flags]
#   tunalog reset-password <email>
#
# Global flags (urfave/cli):
#   -p, --port <port>              - port to
#                                     listen
#                                     on
#                                     (default
#                                     ":8080")
#       --tls-key <file>           - path
#                                     to
#                                     TLS
#                                     key
#                                     file
#                                     (for
#                                     HTTPS)
#       --tls-crt <file>           - path
#                                     to
#                                     TLS
#                                     certificate
#                                     file
#                                     (for
#                                     HTTPS)
#
# Subcommands:
#   reset-password <email>         - reset
#                                     the
#                                     password
#                                     of a
#                                     user
#                                     by
#                                     email
#                                     address
#                                     (generates
#                                     new
#                                     random
#                                     password
#                                     + hashes
#                                     with
#                                     bcrypt
#                                     + stores
#                                     in DB)
#
# Standard:
#   -h, --help                     - show
#                                     help
#       --version                  - show
#                                     version
#
# Example invocations:
#   # Start with default port :8080
#   tunalog
#     # Visit http://localhost:8080
#
#   # Custom port
#   tunalog --port :9090
#
#   # HTTPS with TLS certificate
#   tunalog \
#     --port :443 \
#     --tls-crt /etc/letsencrypt/live/example.com/fullchain.pem \
#     --tls-key /etc/letsencrypt/live/example.com/privkey.pem
#
#   # Reset user password
#   tunalog reset-password admin@example.com
#     # Outputs new generated password
#     # User must change on first login
#
#   # Show version
#   tunalog --version
#
# Docker deployment:
#   ```bash
#   docker run -d \
#     --name tunalog \
#     -p 8080:8080 \
#     -v ./tunalog-data:/data \
#     tunalog/tunalog:latest
#   ```
#
# First-run setup:
#   1. Start tunalog (binary or Docker)
#   2. Visit http://localhost:8080/admin
#   3. Complete admin user registration
#      (bcrypt password set during this
#      step)
#   4. Configure site title + theme +
#      languages
#   5. Start blogging via the admin UI
#
# Built-in features:
#   - **Multi-user posts** (with role-
#     based access)
#   - **Tag system** (post tagging +
#     tag-based filtering)
#   - **Comments** (built-in; no
#     Disqus required)
#   - **RSS feed** (auto-generated
#     /feed.xml)
#   - **Custom theme** (template
#     customization via templates/
#     directory)
#   - **Multi-language** (i18n support
#     for UI translation)
#   - **Image uploads** (with automatic
#     format normalization via
#     imgconv)
#   - **Markdown editor** (with live
#     preview)
#
# The golang.org/x/crypto/bcrypt lane is
# built on `golang.org/x/crypto v0.26.0`
# (declared verbatim at upstream go.mod
# HEAD as a direct dep, the bcrypt
# subpackage is imported by `main.go`
# for the `reset-password` command to
# generate a new random password +
# bcrypt-hash it before storing in
# the users table), the canonical Go
# bcrypt library by the Go team -
# golang.org/x/crypto (officially
# stewarded by the Go team).
#
# golang.org/x/crypto/bcrypt is the
# de-facto canonical Go bcrypt library:
#   - **Official Go team library**
#     (part of golang.org/x/* - the
#     Go team's extended stdlib for
#     packages too volatile for stdlib
#     but officially blessed)
#   - **RFC 8018 compliant**
#     (canonical bcrypt spec; wire-
#     compatible with all major
#     bcrypt implementations)
#   - **Pure Go implementation** (no
#     CGO; no external crypto library
#     dependency)
#   - **Constant-time comparison**
#     (verify uses constant-time
#     comparison to prevent timing
#     attacks)
#   - **Configurable work factor**
#     (cost from 4 to 31; default
#     is 10)
#   - **Used by virtually every Go
#     project that handles
#     passwords** (Kubernetes
#     dashboard auth + Argo CD +
#     Grafana + Prometheus
#     alertmanager + many Go web
#     frameworks)
#
# Note on Go's x/crypto policy: the
# golang.org/x/* libraries are officially
# Go team maintained but NOT part of
# the Go stdlib. They follow looser API
# stability rules than stdlib (allowing
# breaking changes between versions
# rather than the strict Go 1
# compatibility promise for stdlib).
# However, x/crypto packages are
# considered *de facto* canonical
# extended stdlib for crypto
# primitives that aren't in stdlib
# (bcrypt + argon2 + ssh + acme +
# nacl + ocsp + etc.).
#
# golang.org/x/crypto/bcrypt's
# distinguishing position vs Go bcrypt
# alternatives:
#   - golang.org/x/crypto/bcrypt (Go
#     team): canonical; official
#     extended stdlib; THIS AXIS
#   - github.com/jmoiron/bcrypt: simple
#     wrapper; smaller scope
#   - There is essentially NO competing
#     Go bcrypt library because the
#     x/crypto one IS canonical + has
#     official Go team maintenance
#
# This *single canonical library
# without competitors* pattern is
# distinctive for golang.org/x/crypto/
# bcrypt. Most Go canonical libraries
# face some adoption competition from
# alternative implementations; bcrypt
# does not because the x/crypto
# version is so universally used.
#
# The Go team is one of the most
# influential Go ecosystem
# stewardship organizations:
#   - **stdlib** (the Go standard
#     library; the foundation of every
#     Go program)
#   - **golang.org/x/*** (extended
#     stdlib; bcrypt + ssh + acme +
#     net + sync + crypto + image +
#     mod + tools + ...)
#   - **golang/go** (the Go compiler
#     + runtime itself)
#   - **gopls** (the Go language
#     server)
#   - **godoc** (the canonical Go
#     documentation tool)
#   - **vet + race + cover**
#     (canonical Go diagnostics)
#
# The Go team's role in Go is
# *foundational language + standard
# library + extended infrastructure
# stewardship*. Their stdlib +
# x/crypto + x/* libraries form the
# de-facto canonical foundation for
# the entire Go ecosystem.
#
# Multi-axis canonical-Go author/org
# cohort extension (now spanning 34
# distinct individuals/orgs after R1581):
#   - + Go team + Google (golang.org/
#     x/crypto/bcrypt + golang.org/x/
#     * extended stdlib + golang.org/
#     x/tools + Go compiler + runtime;
#     THIS AXIS; canonical Go bcrypt +
#     foundational Go language +
#     stdlib + extended stdlib +
#     tooling stewardship)
#
# The Go team joining the canonical-
# Go cohort at the *language stewards
# canonical extended stdlib* level
# extends the pattern of *enterprise-
# backed canonical libraries* but with
# the unique characteristic of
# stewarding the language itself.
#
# Notable: Google's relationship to Go
# is similar to Microsoft's
# relationship to TypeScript + JetBrains'
# relationship to Kotlin - companies
# that simultaneously steward a
# programming language AND maintain
# canonical libraries for that language.
# This *language-creator-maintains-
# canonical-libraries* pattern produces
# the most cohesive language
# ecosystems but creates
# concentration of governance.
#
# tunalog uses golang.org/x/crypto/
# bcrypt for:
#   - Generating bcrypt hashes when
#     resetting user passwords via
#     `tunalog reset-password <email>`
#     command
#   - Comparing user-supplied passwords
#     against stored hashes during
#     login (via the auth handler)
#   - Default cost (10) is sufficient
#     for blog admin login frequency
#     (not high-frequency auth like
#     OAuth providers)
#
# This is the canonical use case for
# golang.org/x/crypto/bcrypt in
# production Go web applications:
# password storage where bcrypt's
# combination of industry-standard
# wire format + Go team stewardship +
# pure-Go implementation make it the
# unambiguous choice.
#
# ----------------------------------------------------------------------------
# AXIS 294 :: bcrypt password hashing
#              libraries
#              (RFC 8018 compliant
#              password hashing with
#              configurable work factor;
#              constant-time verification)
# Round 1581 :: Go slot 2 of 4 :: continues Axis 294
#
# Cross-language canonical library family
# for this axis:
#   Rust    : Keats/rust-bcrypt          [R1580 _rnacos]
#             (Vincent Prouillet;
#              canonical Rust bcrypt;
#              pure-Rust; part of
#              Prouillet's web security
#              stack)
#   Go      : golang.org/x/crypto/bcrypt [R1581 THIS FILE]
#             (Go team + Google;
#              canonical Go bcrypt in
#              extended stdlib;
#              official + foundational)
#   TS/Node : kelektiv/node.bcrypt.js    [R1582 closing]
#             (Nick Campbell + kelektiv
#              community; canonical Node
#              bcrypt; native bindings)
#
# Use-case spectrum across the lanes
# (so far):
#   - rnacos (Rust, Keats/rust-bcrypt):
#     Nacos Rust port using bcrypt for
#     admin user password storage
#   - tunalog (Go, x/crypto/bcrypt):
#     no-installation blogging system
#     using bcrypt for admin user
#     password reset + login
#
# Both use cases share the *admin user
# authentication for self-hosted
# services* pattern - the canonical
# bcrypt deployment pattern in
# production Rust + Go web
# applications. Single-binary self-
# hosted tools commonly use bcrypt for
# storing admin credentials because:
#   - bcrypt's industry-standard wire
#     format ensures cross-language
#     compatibility (rnacos can
#     accept Java Nacos bcrypt hashes;
#     tunalog can be migrated to/from
#     other bcrypt-using systems)
#   - The libraries are highly mature
#     + well-audited
#   - The work factor parameter allows
#     tuning for the deployment's
#     security/performance tradeoff
# ============================================================================

_tunalog() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-p --port)'{-p+,--port=}'[port to listen on]:port:' \
        '--tls-key=[path to TLS key file]:file:_files -g "*.(key|pem)"' \
        '--tls-crt=[path to TLS certificate file]:file:_files -g "*.(crt|pem)"' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_tunalog_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                reset-password)
                    _arguments \
                        '*:user email:_email_addresses'
                    ;;
            esac
            ;;
    esac

    return ret
}

_tunalog_cmds() {
    local -a cmds
    cmds=(
        'reset-password:reset the password of a user by email address'
    )
    _describe -t commands 'tunalog command' cmds
}

_tunalog "$@"
