#compdef blast-radius
# Documentation: https://github.com/28mm/blast-radius
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--serve[start the web server]' \
  '--port[port for the web server]:port:' \
  '--json[output as JSON]' \
  '*:path:_files' \
  && ret=0

return ret
