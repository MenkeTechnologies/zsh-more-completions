#compdef zfs-inherit
# _zfs-inherit — OpenZFS zfs inherit clear property to inherit from parent CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-inherit() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-r[recursive]' \
        '-S[revert to received value]' \
        '*:property dataset:'
}

_zfs-inherit "$@"
