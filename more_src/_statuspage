#compdef statuspage
# _statuspage — Statuspage CLI (statuspage.io)
# upstream: https://developer.statuspage.io/

_statuspage() {
    _arguments -s -S \
        '--api-key=[Statuspage API key]:key:' \
        '--page-id=[page ID]:id:' \
        '--format=[output format]:format:(json text)' \
        '--help[show help]'
}

_statuspage "$@"
