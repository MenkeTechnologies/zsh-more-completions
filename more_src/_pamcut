#compdef pamcut
# Documentation: man pamcut (Netpbm)
# Source: Netpbm pamcut — select a rectangular region of a PAM, PBM, PGM, or PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-left=[left column number]:colnum:' \
    '-right=[right column number]:colnum:' \
    '-top=[top row number]:rownum:' \
    '-bottom=[bottom row number]:rownum:' \
    '-width=[width (columns)]:cols:' \
    '-height=[height (rows)]:rows:' \
    '-pad[pad with background if region extends past image]' \
    '-cropleft=[columns to crop off left]:numcols:' \
    '-cropright=[columns to crop off right]:numcols:' \
    '-croptop=[rows to crop off top]:numrows:' \
    '-cropbottom=[rows to crop off bottom]:numrows:' \
    '-reportonly[only report what would be cut]' \
    '-verbose[print progress messages]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:left+top+width+height + PNM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
