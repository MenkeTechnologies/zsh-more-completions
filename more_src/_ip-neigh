#compdef ip-neigh
# Documentation: https://man.archlinux.org/man/ip-neighbour.8.en
# ip neigh - neighbour/ARP table management

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip neigh command' \
      'add[create new neighbour entry]' 'del[remove neighbour entry]' \
      'change[modify existing entry]' 'replace[add or update entry]' \
      'show[list neighbour entries]' 'flush[clear neighbour entries]' \
      'get[lookup specific neighbour entry]' \
      'to[protocol address]' 'dev[interface name]' 'lladdr[link layer address]' \
      'nud[neighbour unreachability detection state]' 'proxy[proxy configuration]' \
      'router[neighbour is a router]' 'use[mark entry as in-use]' \
      'managed[mark as managed by controller]' 'extern_learn[externally learned]' \
      'extern_valid[externally validated]' 'vrf[VRF name]' \
      'nomaster[exclude entries with master]' 'unused[inactive entries only]' \
      'permanent[NUD permanent]' 'noarp[NUD noarp]' 'reachable[NUD reachable]' \
      'stale[NUD stale]' 'incomplete[NUD incomplete]' 'delay[NUD delay]' \
      'probe[NUD probe]' 'failed[NUD failed]' && ret=0
    ;;
esac

return ret
