#compdef ksystemlog
# Documentation: https://docs.kde.org/stable5/en/ksystemlog/ksystemlog/
# Reference accessed: 2026-05-16
# Verified: KDE ksystemlog handbook + manpage. Accepts only common
# KDE/Qt options; no app-specific options exist.
# Removed from prior file: bogus man.archlinux.org search URL.

# ksystemlog: KDE system log viewer (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' && ret=0
return ret
