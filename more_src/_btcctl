#compdef btcctl
# _btcctl — btcsuite btcctl JSON-RPC client CLI alias for the btcd Bitcoin full-node implementation issuing wallet getbalance sendtoaddress listunspent getnewaddress getblockchaininfo and node-control commands (btcsuite team, Go); flag
# upstream: https://github.com/btcsuite/btcd

_btcctl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c+[config file]:file:_files -g "*.conf btcctl.conf"' \
        '--configfile=+[config file]:file:_files -g "*.conf btcctl.conf"' \
        '-s+[rpc server host:port]:str:' \
        '--rpcserver=+[rpc server host:port]:str:' \
        '-u+[rpc user]:str:' \
        '--rpcuser=+[rpc user]:str:' \
        '-P+[rpc password]:str:' \
        '--rpcpass=+[rpc password]:str:' \
        '-C+[cookie file]:file:_files' \
        '--rpccookiefile=+[cookie file]:file:_files' \
        '--rpccert=+[ca cert file]:file:_files -g "*.cert *.pem"' \
        '--notls[no TLS]' \
        '--proxy=+[host:port]:str:' \
        '--proxyuser=+[user]:str:' \
        '--proxypass=+[password]:str:' \
        '--testnet[use testnet]' \
        '--simnet[use simnet]' \
        '--regtest[use regtest]' \
        '--signet[use signet]' \
        '--wallet[connect to wallet]' \
        '--skipverify[skip server cert verification]' \
        '-l[list available commands]' \
        '--listcommands[list available commands]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getbalance listunspent sendtoaddress sendmany getnewaddress validateaddress dumpprivkey importprivkey importwallet dumpwallet generate generatetoaddress addnode getpeerinfo setgenerate stop help)'
}

_btcctl "$@"
