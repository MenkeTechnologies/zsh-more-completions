#compdef gnome-screensaver

# gnome-screensaver: GNOME 2-era screensaver daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '(- *)--help-gnome[show GNOME options]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '--no-daemon[do not detach]' \
  '--debug[debug mode]' \
  '--replace[replace running daemon]' \
  '*::gnome-screensaver args:_files' && ret=0
return ret
