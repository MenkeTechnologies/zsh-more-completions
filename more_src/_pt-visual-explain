#compdef pt-visual-explain
# Documentation: https://docs.percona.com/percona-toolkit/pt-visual-explain.html
# Format EXPLAIN output as a tree

local ret=1

_arguments -s -S \
  '(--help)--help[show help and exit]' \
  '(--version)--version[show version and exit]' \
  '--ask-pass[prompt for password when connecting to MySQL]' \
  '--buffer-stdout[enable STDOUT buffering]' \
  '--no-buffer-stdout[disable STDOUT buffering]' \
  '(-A --charset)'{-A,--charset=}'[default character set]:charset' \
  '--clustered-pk[assume PRIMARY KEY index accesses do not require bookmark lookups]' \
  '--config=[read this comma-separated list of config files]:files:_files' \
  '(-c --connect)'{-c,--connect}'[treat input as a query and obtain EXPLAIN by connecting to MySQL]' \
  '(-D --database)'{-D,--database=}'[connect to this database]:database' \
  '(-F --defaults-file)'{-F,--defaults-file=}'[only read mysql options from the given file]:file:_files' \
  '--format=[set output format]:format:(tree dump)' \
  '(-h --host)'{-h,--host=}'[connect to host]:host:_hosts' \
  '(-s --mysql_ssl)'{-s,--mysql_ssl=}'[create SSL MySQL connection]:value' \
  '(-p --password)'{-p,--password=}'[password to use when connecting]:password' \
  '--pid=[create the given PID file]:file:_files' \
  '(-P --port)'{-P,--port=}'[port number to use for connection]:port' \
  '--set-vars=[set the MySQL variables in this comma-separated list]:vars' \
  '(-S --socket)'{-S,--socket=}'[socket file to use for connection]:socket:_files' \
  '(-u --user)'{-u,--user=}'[user for login if not current user]:user:_users' \
  '*:file:_files' && ret=0

return ret
