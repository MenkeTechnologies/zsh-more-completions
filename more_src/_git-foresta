#compdef git-foresta
# Documentation: https://github.com/takaaki-kasai/git-foresta
# Reference accessed: 2026-05-30
# git-foresta — git log graph renderer with ASCII-art "forest" output.
# Passes through to git log so it accepts arbitrary git log arguments
# beyond its own flag set.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help and exit]' \
  '(- *)--version[show version and exit]' \
  '--style=[visual style]:style:(1 2 10 15)' \
  '--svdepth=[max merge subvine depth (default 2)]:N:' \
  '--graph-margin-left=[left margin (default 2)]:N:' \
  '--graph-margin-right=[right margin (default 1)]:N:' \
  '--graph-symbol-commit=[commit marker (default ●)]:symbol:' \
  '--graph-symbol-merge=[merge marker (default ◎)]:symbol:' \
  '--graph-symbol-overpass=[overpass marker (default ═)]:symbol:' \
  '--graph-symbol-root=[root marker (default ■)]:symbol:' \
  '--graph-symbol-tip=[tip marker (default ○)]:symbol:' \
  '--no-status[suppress working-tree status near HEAD]' \
  '*:git log argument:' \
  && ret=0

return ret
