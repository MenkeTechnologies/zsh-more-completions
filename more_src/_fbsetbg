#compdef fbsetbg
# Documentation: https://manpages.debian.org/bookworm/fluxbox/fbsetbg.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm fbsetbg(1) manpage OPTIONS. Uppercase variants
# are no-remember twins of the lowercase forms.
# Removed from prior file: fabricated --help/--version flags and bogus
# man.archlinux.org search URL.

# fbsetbg: Fluxbox wallpaper setter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[display help]' \
  '(-F)-f[set fullscreen wallpaper (remember)]' \
  '(-f)-F[set fullscreen wallpaper (no remember)]' \
  '(-C)-c[set centered wallpaper (remember)]' \
  '(-c)-C[set centered wallpaper (no remember)]' \
  '(-T)-t[set tiled wallpaper (remember)]' \
  '(-t)-T[set tiled wallpaper (no remember)]' \
  '(-A)-a[set maximized wallpaper preserving aspect (remember)]' \
  '(-a)-A[set maximized wallpaper preserving aspect (no remember)]' \
  '(-U)-u[use specified wallpaper setter (remember)]:setter:' \
  '(-u)-U[use specified wallpaper setter (no remember)]:setter:' \
  '(-B)-b[forward options to fbsetroot (remember)]:option:' \
  '(-b)-B[forward options to fbsetroot (no remember)]:option:' \
  '(-R)-r[set random wallpaper from directory (remember)]:dir:_files -/' \
  '(-r)-R[set random wallpaper from directory (no remember)]:dir:_files -/' \
  '-l[set previous wallpaper]' \
  '-i[display info about wallpaper setter found]' \
  '-p[display useful tips]' \
  '*:image:_files -g "*.(png|jpg|jpeg|gif|bmp|xpm|tiff|webp)(-.)"' && ret=0
return ret
