#compdef CalculateMixingFractions
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/validation/CalculateMixingFractions.java
# GATK4: estimate mixing fractions of samples in a pooled VCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --variant)'{-V,--variant}'[input VCF of known variants]:file:_files -g "*.(vcf|vcf.gz)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to operate on]:intervals:_files' \
  '(-O --output)'{-O,--output}'[output table of sample mixing fractions]:file:_files' \
  '*:options:_files' && ret=0

return ret
