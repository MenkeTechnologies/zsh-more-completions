#compdef iptables-translate ip6tables-translate iptables-restore-translate ip6tables-restore-translate
# _iptables-translate — netfilter iptables-translate (read an iptables-save line or a file of them and emit equivalent nftables nft commands without applying changes; -A/-I/-D/etc. accepted, -t TABLE limit translation, -f file input file, -V version, -h help; companion to iptables-restore-translate which converts entire snapshot)
# upstream: https://git.netfilter.org/iptables
# Flags from netfilter/iptables iptables/iptables-translate.c on tip.

_iptables-translate() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-t+[table]:table:(filter nat mangle raw security)' \
        '-f+[input file]:file:_files' \
        '*::rule:'
}

_iptables-translate "$@"
