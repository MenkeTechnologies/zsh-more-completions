#compdef committor
# Documentation: https://github.com/simonhdickson/committor
# Source: simonhdickson/committor — Rust CLI generating conventional commits via OpenAI / Ollama.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _co_cmds
_co_cmds=(
    'generate:create commit message options for staged changes'
    'commit:generate and create the commit in one step'
    'diff:show the current git diff'
    'models:list available models for the selected provider'
    'check-ollama:verify Ollama is reachable'
    'help:show help'
)

_arguments -C \
    '--provider=[AI provider]:provider:(openai ollama)' \
    '--api-key=[OpenAI API key]:key:_default' \
    '--ollama-url=[Ollama base URL]:url:_default' \
    '--model=[model to use]:model:_default' \
    '--count=[max commit message options to generate]:n:_default' \
    '(-y --auto-commit)'{-y,--auto-commit}'[use the first suggestion automatically]' \
    '--show-diff[print git diff before generating]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    && ret=0

case $state in
    command)
        _describe -t commands 'committor command' _co_cmds && ret=0
        ;;
esac

return ret
