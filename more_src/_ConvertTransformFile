#compdef ConvertTransformFile
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ConvertTransformFile.cxx — read/write ITK transform file formats (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '--matrix[output as raw matrix instead of legacy format]' \
    '--RAS[output in RAS coordinate system]' \
    '--LPS[output in LPS coordinate system]' \
    '--convertToAffineType[force conversion to AffineTransform]' \
    '1:dimensions:(2 3 4)' \
    '2:inputTransformFile.ext:_files -g "*.{txt,mat,h5,xfm,tfm}"' \
    '3:outputTransformFile.ext:_files' \
    && ret=0

return ret
