#compdef topgrade

# Zsh completion for topgrade - a command to upgrade all the things

_arguments -s -S \
  '(-n --dry-run)'{-n,--dry-run}'[print steps to be performed, without executing]' \
  '(-t --only)'{-t,--only}'[only perform specific steps (repeatable)]:step:' \
  '--skip[skip specific steps (repeatable)]:step:' \
  '--disable[disable specific steps]:step:' \
  '-y[do not ask for confirmations]' \
  '--yes[do not ask for confirmations]' \
  '--no-retry[do not retry failed steps]' \
  '--skip-notify[skip sending a notification at the end of a run]' \
  '-c[cleanup temporary or old files]' \
  '--cleanup[cleanup temporary or old files]' \
  '--config[path to configuration file]:file:_files' \
  '--config-reference[print the default configuration]' \
  '--help-steps[list all available steps]' \
  '--keep[keep the terminal window open at the end of the run]' \
  '--tmux[run updates with tmux]' \
  '--no-tmux[do not run with tmux]' \
  '--finish-with-config[if topgrade finishes, run an additional step]' \
  '--tracing[enable tracing]' \
  '--verbose[enable verbose output]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[print help]'
