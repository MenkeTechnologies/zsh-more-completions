#compdef minigraph
# _minigraph — Heng Li lh3 minigraph CLI sequence-to-graph mapper extending minimap2 to graph references constructing-incrementally aligning long reads/contigs to GFA pangenome augmenting graph variants from arbitrarily-large genome differences for human-pangenome graph build (Heng Li team, C); getopt
# upstream: https://github.com/lh3/minigraph

_minigraph() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-x+[preset]:p:(lr asm sr ggs)' \
        '-c[base alignment]' \
        '-S[print self-alignment]' \
        '-N+[N best chains]:n:' \
        '-j+[min chain coverage]:n:' \
        '-k+[kmer]:n:' \
        '-w+[window]:n:' \
        '-K+[batch]:n:' \
        '-r+[bandwidth]:n:' \
        '-n+[min minimizer count]:n:' \
        '-l+[min chain length]:n:' \
        '-d+[max gap]:n:' \
        '-q+[min mapping quality]:n:' \
        '-D+[max divergence]:n:' \
        '-t+[threads]:n:' \
        '-o+[output file]:file:_files' \
        '-a[output SAM]' \
        '--vc[variant call]' \
        '--call[call SVs from graph]' \
        '--show-unmap=+[y/n]:s:(yes no)' \
        '--gen-cs=+[y/n]:s:(yes no)' \
        '--cov[output coverage]' \
        '*:input:_files -g "*.fa *.fasta *.fq *.fastq *.gz *.gfa"'
}

_minigraph "$@"
