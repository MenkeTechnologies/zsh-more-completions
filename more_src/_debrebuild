#compdef debrebuild
# Documentation: https://manpages.debian.org/debrebuild
# Source: debian/devscripts scripts/debrebuild.pl — rebuild Debian binaries from a .buildinfo (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    '(--no-respect-build-path)--respect-build-path[set build path from .buildinfo]' \
    '--no-respect-build-path[do not set build path]' \
    '--buildresult=-[directory for build artifacts]:dir:_files -/' \
    '--cache=-[cache directory for .debs]:dir:_files -/' \
    '--builder=-[builder]:builder:(none dpkg sbuild sbuild+unshare mmdebstrap)' \
    '1:buildinfo file:_files -g "*.buildinfo"' \
    && ret=0

return ret
