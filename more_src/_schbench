#compdef schbench
# Scheduler benchmark tool

local ret=1

_arguments -s -S \
  '-m[number of message threads]:threads:' \
  '-t[number of worker threads per message thread]:threads:' \
  '-r[runtime in seconds]:seconds:' \
  '-s[sleep time in usec]:microseconds:' \
  '-c[number of operations per worker]:count:' \
  '-a[set auto mode]' \
  '-p[specify pipe file]:file:_files' \
  '-R[rps mode]:requests per second:' \
  '-h[show help]' && ret=0

return ret
