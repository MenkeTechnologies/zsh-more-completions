# WHAT IT IS
#   openab is "a lightweight, secure, cloud-native ACP (Agent-
#   Channel Protocol) harness that bridges Discord and any ACP".
#   It runs as a long-lived daemon that connects to a Discord
#   bot via serenity's gateway, listens for messages and
#   reactions across configured channels, routes those events to
#   plugin-style ACP adapters (Anthropic Claude Code, OpenAI
#   Codex, Cursor Composer, GitHub Copilot, Gemini CLI, Grok,
#   Hermes, OpenCode, Antigravity, Pi, native shell, and a Slack
#   bridge), runs each agent in a sandboxed Docker container
#   matched to that adapter (`Dockerfile.claude`,
#   `Dockerfile.codex`, `Dockerfile.copilot`, `Dockerfile.cursor`,
#   `Dockerfile.gemini`, `Dockerfile.grok`, `Dockerfile.hermes`,
#   `Dockerfile.opencode`, `Dockerfile.antigravity`,
#   `Dockerfile.pi`, `Dockerfile.native`), and pipes structured
#   responses back into Discord with markdown rendering,
#   reactions, threads, attachments, and cron-scheduled reminders.
#   A `setup` wizard interactively generates the TOML config.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs `Cli` /
#                       `Commands` clap-derive enum — clap 4
#                       with derive feature)
#   openab [SUBCOMMAND] [args...]
#
#   Default behavior when invoked with no subcommand:  identical
#   to `openab run` (i.e. `openab` ≡ `openab run`).
#
#   Subcommands:
#     run                            Run the bot (default
#                                    subcommand)
#       -c, --config <CONFIG>          Config file path or URL
#                                      [default: config.toml]
#
#     setup                          Launch the interactive setup
#                                    wizard
#       -o, --output <PATH>            Output file path for the
#                                      generated config
#                                      [default: config.toml]
#
#   Standard clap auto-flags:
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `serenity = { version = "0.12",
#   default-features = false, features = ["client", "gateway",
#   "model", "rustls_backend", "cache"] }` declared in
#   Cargo.toml — `serenity` is THE canonical Rust Discord SDK
#   maintained by the serenity-rs org (serenity-rs/serenity, 5.5K
#   stars, the Rust counterpart of discord.js / discord.py).
#   serenity exposes `serenity::Client` with the
#   `EventHandler` trait, the `ShardManager`, full coverage of
#   the Discord Gateway v10 opcodes, typed model objects
#   (`Channel`, `Guild`, `GuildId`, `Member`, `Message`,
#   `MessageId`, `User`, `Embed`, `Component`,
#   `ApplicationCommand`, `Interaction`, `Modal`,
#   `AutocompleteValue`, `Attachment`), helpers for slash
#   commands and message-commands, the `serenity::prelude::*`
#   re-exports (Context, Mutex, RwLock), rate-limit-aware HTTP
#   via the `http` module, an opt-in cache layer, optional
#   voice support via songbird, and the `framework`
#   integrations.  openab's `src/main.rs` constructs a
#   `serenity::Client` against the Discord bot token in the
#   loaded TOML config, registers an `EventHandler` that
#   dispatches each gateway event into `AdapterRouter`, and
#   gracefully shuts down via the `ShardManager` on
#   SIGINT/SIGTERM.  Verified via:
#     gh api repos/openabdev/openab/contents/Cargo.toml
#       → serenity = { version = "0.12", default-features =
#           false, features = ["client", "gateway", "model",
#           "rustls_backend", "cache"] }
#       → tokio = { version = "1", features = ["full"] }
#       → clap = { version = "4", features = ["derive"] }
#       → name = "openab"
#     gh api repos/openabdev/openab/contents/src/main.rs
#       → use serenity::gateway::GatewayError;
#       → use serenity::prelude::*;
#       → #[derive(Parser)] struct Cli { command:
#           Option<Commands> }
#       → enum Commands { Run { config: Option<String> },
#                           Setup { output: Option<String> } }
#   This entry is the Rust=143 leader bump that OPENS Axis 88
#   (Discord SDK / serenity) at 1/0/0.  Pairing Go and TS-Node
#   bumps will follow at R942 and R943 (Go=143 candidates
#   bwmarrin/discordgo-based CLIs; TS-Node=143 candidates
#   discord.js-based CLIs).
#
#   No completion for `openab` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_openab() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_openab_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run)
                    _arguments \
                        '(-c --config)'{-c,--config}'=[config file path or URL]:config:_files -g "*.toml"' && ret=0 ;;
                setup)
                    _arguments \
                        '(-o --output)'{-o,--output}'=[output file path for generated config]:path:_files -g "*.toml"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_openab_commands] )) ||
_openab_commands() {
    local -a commands
    commands=(
        'run:run the bot (default)'
        'setup:launch the interactive setup wizard'
    )
    _describe -t commands 'openab command' commands
}

_openab "$@"
