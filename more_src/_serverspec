#compdef serverspec-init
# _serverspec — Serverspec (Ruby DSL for asserting state on real servers via SSH or local exec; the CLI users see is serverspec-init which scaffolds a spec tree (asks OS family, backend, host pattern, ssh user))
# upstream: https://github.com/serverspec/serverspec
# Argument shape from serverspec bin/serverspec-init on tip.

_serverspec() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--vagrant[use Vagrant box backend]' \
        '--ssh[use SSH backend]' \
        '--cmd[use cmd backend]' \
        '--docker[use Docker backend]' \
        '--exec[use local exec backend]' \
        '--lxc[use LXC backend]' \
        '--telnet[use Telnet backend]' \
        '--winrm[use WinRM backend]'
}

_serverspec "$@"
