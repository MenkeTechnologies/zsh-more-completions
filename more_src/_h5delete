#compdef h5delete
# Documentation: https://github.com/HDFGroup/hdf5
# Source: HDFGroup/hdf5 tools/src/misc/h5delete.c — delete HDF5 file (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[force delete (no error if not HDF5)]' \
    '1:filename:_files -g "*.{h5,hdf5}"' \
    && ret=0

return ret
