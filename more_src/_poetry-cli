#compdef poetry-cli
# _poetry-cli — Poetry Python dependency manager CLI alias (python-poetry, Python); cleo
# upstream: https://github.com/python-poetry/poetry

_poetry-cli() {
    local -a sub=(
        'about:about poetry'
        'add:add packages'
        'build:build distribution'
        'check:check pyproject.toml'
        'config:manage config'
        'completions:print shell completions'
        'env:manage environments'
        'export:export requirements file'
        'help:show help'
        'init:scaffold pyproject.toml'
        'install:install dependencies'
        'list:list available commands'
        'lock:update lockfile'
        'new:create a new project'
        'publish:publish distribution'
        'remove:remove packages'
        'run:run script'
        'search:search packages'
        'self:manage poetry itself'
        'shell:spawn venv shell'
        'show:show package info'
        'update:update packages'
        'version:show/bump version'
        'source:manage sources'
        'cache:manage cache'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-vvv[debug]' \
        '--ansi[force ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--no-plugins[no plugins]' \
        '--no-cache[no cache]' \
        '--directory=+[change directory]:dir:_files -/' \
        '-C+[change directory]:dir:_files -/' \
        '--project=+[project name]:str:' \
        '-P+[project name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'poetry subcommand' sub ;;
        args)
            case $words[1] in
                add|remove|update|install) _arguments \
                    '--dev[dev dep (deprecated)]' \
                    '--group=+[group]:str:' \
                    '-G+[group]:str:' \
                    '--editable[editable]' \
                    '-e[editable]' \
                    '--extras=+[extras]:list:' \
                    '-E+[extras]:list:' \
                    '--optional[optional]' \
                    '--platform=+[platform]:str:' \
                    '--source=+[source]:str:' \
                    '--allow-prereleases[allow prereleases]' \
                    '--dry-run[dry run]' \
                    '--lock[lock only]' \
                    '--no-update[no update]' \
                    '--no-cache[no cache]' \
                    '--with=+[with group]:list:' \
                    '--without=+[without group]:list:' \
                    '--only=+[only group]:list:' \
                    '--sync[sync env]' \
                    '*:package:' ;;
                run) _arguments '*:cmd:_command_names -e' ;;
                config) _arguments \
                    '1:key:' \
                    '2:value:' \
                    '--unset[unset key]' \
                    '--list[list values]' \
                    '--local[local config]' ;;
                env) _arguments \
                    '1:cmd:(activate info list remove use)' \
                    '*:arg:' ;;
                show) _arguments \
                    '--without=+[without group]:list:' \
                    '--with=+[with group]:list:' \
                    '--only=+[only group]:list:' \
                    '--no-dev[no dev]' \
                    '--tree[tree]' \
                    '-t[tree]' \
                    '--latest[latest]' \
                    '-l[latest]' \
                    '--outdated[outdated]' \
                    '-o[outdated]' \
                    '--all[all]' \
                    '-a[all]' \
                    '*:package:' ;;
                publish) _arguments \
                    '--repository=+[repository]:r:' \
                    '-r+[repository]:r:' \
                    '--username=+[username]:str:_users' \
                    '-u+[username]:str:_users' \
                    '--password=+[password]:str:' \
                    '-p+[password]:str:' \
                    '--cert=+[cert]:file:_files' \
                    '--client-cert=+[client cert]:file:_files' \
                    '--dry-run[dry run]' \
                    '--skip-existing[skip existing]' \
                    '--build[build first]' ;;
                version) _arguments \
                    '1:bump:(major minor patch premajor preminor prepatch prerelease)' \
                    '--short[short]' \
                    '-s[short]' \
                    '--next-phase[next phase]' \
                    '--dry-run[dry run]' ;;
                completions) _arguments \
                    '1:shell:(bash zsh fish)' ;;
                self) _arguments \
                    '1:cmd:(add lock plugin remove show sync update install)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_poetry-cli "$@"
