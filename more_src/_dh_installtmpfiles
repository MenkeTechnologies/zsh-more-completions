#compdef dh_installtmpfiles
# _dh_installtmpfiles — install tmpfiles.d snippets (Debian/debhelper)
# upstream: https://salsa.debian.org/debian/debhelper
# Flags from dh_installtmpfiles script.

_dh_installtmpfiles() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '--name=[tmpfiles.d basename / lookup prefix]:name:' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-a[arch-dep packages only]' \
        '-i[arch-indep packages only]' \
        '-O+[option passed to the helper]:opt:'
}

_dh_installtmpfiles "$@"
