#compdef mikro-orm
# Documentation: https://mikro-orm.io/docs/quick-start
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'cache:clear:remove the metadata cache'
  'cache:generate:build the metadata cache'
  'generate-entities:generate entities from current schema'
  'database:create:create the database if absent'
  'database:import:import a SQL file into the database'
  'schema:create:create database schema from current metadata'
  'schema:drop:drop database schema'
  'schema:update:update database schema to current metadata'
  'schema:fresh:drop and recreate database schema'
  'migration:create:create a new migration from current schema diff'
  'migration:up:apply pending migrations'
  'migration:down:rollback by one step'
  'migration:list:list executed migrations'
  'migration:check:check if migrations are necessary'
  'migration:pending:list pending migrations'
  'migration:fresh:drop everything and rerun all migrations'
  'seeder:create:create a new seeder class'
  'seeder:run:run a seeder class'
  'debug:debug CLI configuration'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[CLI config path]:file:_files' \
  '--contextName=[context name to use]:name:' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mikro-orm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (schema:create|schema:update|schema:drop|schema:fresh)
        _arguments \
          '(-r --run)'{-r,--run}'[execute generated SQL]' \
          '(-d --dump)'{-d,--dump}'[dump SQL only]' \
          '--drop-db[drop the whole database instead of tables]' \
          '--no-drop[do not drop tables before recreating]' \
          '--no-fk-checks[disable foreign key checks]' \
          '--seed=[run a seeder after fresh]:seeder:' \
          '--schema=[target schema]:schema:' && ret=0 ;;
      (migration:up)
        _arguments \
          '(-t --to)'{-t+,--to=}'[migrate to a specific version]:version:' \
          '(-f --from)'{-f+,--from=}'[migrate from a specific version]:version:' \
          '(-o --only)'{-o+,--only=}'[only run specified migrations]:list:' \
          '--seed[seed after migrating]' && ret=0 ;;
      (migration:down)
        _arguments \
          '(-t --to)'{-t+,--to=}'[migrate down to version]:version:' \
          '(-f --from)'{-f+,--from=}'[start from version]:version:' \
          '(-o --only)'{-o+,--only=}'[only specified versions]:list:' && ret=0 ;;
      (migration:create)
        _arguments \
          '--blank[create blank migration]' \
          '--initial[create initial migration]' \
          '--name=[migration class name]:name:' \
          '--dump[dump SQL only]' && ret=0 ;;
      (migration:fresh)
        _arguments \
          '--seed=[seed after running]:seeder:' \
          '--drop-db[drop the whole database]' && ret=0 ;;
      (seeder:run)
        _arguments \
          '(-c --class)'{-c+,--class=}'[seeder class to run]:class:' && ret=0 ;;
      (seeder:create)
        _arguments '*::seeder_name:' && ret=0 ;;
      (database:import)
        _arguments '*::file:_files -g "*.sql"' && ret=0 ;;
    esac ;;
esac

return ret
