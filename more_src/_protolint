#compdef protolint
# Documentation: https://github.com/yoheimuta/protolint
# Reference accessed: 2026-05-17
# Verified: yoheimuta/protolint upstream — Protocol Buffers linter
# with auto-fix. Subcommands: lint, list, version. Real flags use
# Go-style single-dash long form: -config_path, -config_dir_path,
# -fix, -auto_disable next|this, -v, -no-error-on-unmatched-pattern,
# -reporter plain|junit|json|sarif|sonar|unix|tsc, -output_file,
# -plugin, --mcp, --version.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'lint:lint .proto files (default)'
  'list:list rules'
  'version:show version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-config_path=[config file]:file:_files' \
  '-config_dir_path=[config search directory]:dir:_files -/' \
  '-reporter=[reporter format]:fmt:(plain junit json sarif sonar unix tsc)' \
  '-output_file=[output file]:file:_files' \
  '*-add-reporter=[additional reporter name:path]:reporter:' \
  '-fix[auto-correct violations]' \
  '-auto_disable=[insert disable comments]:where:(next this)' \
  '-no-error-on-unmatched-pattern[ignore unmatched patterns]' \
  '*-plugin=[load custom plugin]:file:_files' \
  '-v[verbose]' \
  '--mcp[run as MCP server]' \
  '1: :->subcommand' \
  '*::arg:_files -g "*.proto"' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'protolint subcommand' subcommands && ret=0
    ;;
esac

return ret
