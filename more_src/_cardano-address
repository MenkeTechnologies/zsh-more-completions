#compdef cardano-address
# _cardano-address — IOG cardano-address CLI for Cardano address derivation Byron Shelley script and stake key key-from-mnemonic key-derivation address-payment address-delegation script-hash (cardano-foundation team, Haskell); optparse-applicative
# upstream: https://github.com/IntersectMBO/cardano-addresses

_cardano-address() {
    local -a sub=(
        'recovery-phrase:work with BIP39 recovery phrase'
        'key:work with extended keys'
        'address:work with addresses'
        'script:work with multisig scripts'
        'script-hash:hash a script'
        'inspect:inspect data'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cardano-address subcommand' sub ;;
        args)
            case $words[1] in
                recovery-phrase) _arguments \
                    '1:action:(generate)' \
                    '--size=+[N words]:n:(9 12 15 18 21 24)' ;;
                key) _arguments \
                    '1:action:(from-recovery-phrase child public hash inspect walletid)' \
                    '--chain-code[chain code]' \
                    '--without-chain-code[without chain code]' ;;
                address) _arguments \
                    '1:action:(payment delegation stake bootstrap pointer inspect)' \
                    '--network-tag=+[tag]:t:(mainnet testnet 0 1)' \
                    '--from-script[from script]' ;;
                script|script-hash) _arguments \
                    '*:script:' ;;
                inspect) _arguments \
                    '*:address:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_cardano-address "$@"
