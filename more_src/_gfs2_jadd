#compdef gfs2_jadd
# Documentation: https://manpages.ubuntu.com/manpages/questing/man8/gfs2_jadd.8.html
# Add journals to a GFS2 filesystem

local ret=1

_arguments -s -S \
  '-c[initial size of each journal quota change file in MB]:megabytes:' \
  '-D[print debugging information about filesystem layout]' \
  '-h[show usage message]' \
  '-J[size of new journals in MB]:megabytes:' \
  '-j[number of new journals to add]:count:' \
  '-q[quiet; do not print anything]' \
  '-V[print version information]' \
  '*:mountpoint or device:_files' && ret=0

return ret
