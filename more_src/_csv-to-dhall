#compdef csv-to-dhall
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-csv
# Source: dhall-lang/dhall-haskell dhall-csv/csv-to-dhall/Main.hs — convert CSV to Dhall.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _ctd_cmds
_ctd_cmds=(
    'type:output the inferred Dhall type from a CSV value (not implemented)'
)

_arguments -C \
    '--records-strict[fail if any CSV fields are missing from the expected Dhall type]' \
    '--records-loose[tolerate CSV fields not present in the expected Dhall type]' \
    '--unions-first[accept the first matching union value (default)]' \
    '--unions-none[disallow unions]' \
    '--unions-strict[error if more than one union value matches]' \
    '--file=[read CSV from FILE instead of stdin]:file:_files' \
    '--output=[write Dhall expression to FILE instead of stdout]:file:_files' \
    '--ascii[format code using only ASCII syntax]' \
    '--plain[disable syntax highlighting]' \
    '--no-header[convert CSV with no header]' \
    '(- *)'{-V,--version}'[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'csv-to-dhall command' _ctd_cmds && ret=0
        _arguments '1:SCHEMA:_default' && ret=0
        ;;
esac

return ret
