#compdef rrdcached
# Documentation: https://man.archlinux.org/search?q=rrdcached
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-l+[listen address]:addr:' \
  '-L[listen on all interfaces]' \
  '-P+[allowed command]:cmd:(FLUSH STATS UPDATE WROTE FORGET HELP QUIT FLUSHALL PENDING FETCH FETCHBIN BATCH FIRST LAST INFO LIST QUEUE)' \
  '-w+[write timeout sec]:sec:' \
  '-z+[delay random sec]:sec:' \
  '-f+[flush timeout sec]:sec:' \
  '-p+[pid file]:file:_files' \
  '-t+[worker threads]:n:' \
  '-j+[journal directory]:dir:_files -/' \
  '-F[flush journal on shutdown]' \
  '-g[run in foreground]' \
  '-G+[group name]:group:_groups' \
  '-U+[user name]:user:_users' \
  '-b+[base dir]:dir:_files -/' \
  '-B[restrict update to base dir]' \
  '-s+[socket group permissions]:perm:' \
  '-m+[socket file mode]:mode:' \
  '-O[avoid overwriting pidfile]' \
  '-V+[log level]:level:(LOG_EMERG LOG_ALERT LOG_CRIT LOG_ERR LOG_WARNING LOG_NOTICE LOG_INFO LOG_DEBUG)' \
  '-o+[log file]:file:_files' && ret=0

return ret
