#compdef rrdcached
# Documentation: https://oss.oetiker.ch/rrdtool/doc/rrdcached.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a+[allocation chunk size]:n:' \
  '-l+[listen address (host:port or path)]:addr:' \
  '-L[bind to default TCP port on all interfaces]' \
  '-P+[allowed commands per socket]:cmd:(FLUSH STATS UPDATE WROTE FORGET HELP QUIT FLUSHALL PENDING FETCH FETCHBIN BATCH FIRST LAST INFO LIST QUEUE)' \
  '-w+[write timeout sec]:sec:' \
  '-z+[delay random sec]:sec:' \
  '-f+[flush timeout sec]:sec:' \
  '-p+[pid file]:file:_files' \
  '-t+[worker threads]:n:' \
  '-j+[journal directory]:dir:_files -/' \
  '-F[flush journal on shutdown]' \
  '-g[run in foreground (no fork)]' \
  '-G+[group name]:group:_groups' \
  '-U+[user name]:user:_users' \
  '-b+[base dir]:dir:_files -/' \
  '-B[restrict updates to base dir]' \
  '-R[allow recursive subdirectory creation]' \
  '-s+[socket group permissions]:perm:' \
  '-m+[socket file mode]:mode:' \
  '-O[avoid overwriting pidfile / CREATE not allowed to overwrite]' \
  '-V+[log level]:level:(LOG_EMERG LOG_ALERT LOG_CRIT LOG_ERR LOG_WARNING LOG_NOTICE LOG_INFO LOG_DEBUG)' \
  '-o+[log file (instead of syslog)]:file:_files' && ret=0

return ret
