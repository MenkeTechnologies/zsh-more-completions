#compdef ssh-mitm
# Documentation: https://github.com/ssh-mitm/ssh-mitm/blob/master/sshmitm/cli.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
#
# Global flags verified against sshmitm/cli.py create_parser().
# Subcommand list verified against pyproject.toml [project.entry-points."sshmitm.SubCommand"].
# Per-subcommand flags are dynamically registered by plugins and not enumerated here.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'server:run SSH MITM server'
  'audit:audit SSH implementations'
  'check-publickey:check public key auth'
  'mosh:MOSH client'
)

_arguments -C \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '--paramiko-log-level=[paramiko log level]:level:(warning info debug)' \
  '--disable-workarounds[disable paramiko workarounds]' \
  '--log-format=[log output format]:format:(text json)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'ssh-mitm subcommand' subcommands && ret=0 ;;
  (args) _files && ret=0 ;;
esac

return ret
