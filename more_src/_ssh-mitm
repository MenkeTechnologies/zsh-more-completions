#compdef ssh-mitm

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'server:run SSH MITM server'
  'audit:audit SSH implementations'
  'check-publickey:check public key auth'
  'mosh:MOSH client'
)

_arguments -C \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '--paramiko-log-level=[level]:level:(warning info debug)' \
  '--disable-workarounds[disable workarounds]' \
  '--log-format=[format]:fmt:(text json)' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'ssh-mitm subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (server)
        _arguments -s \
          '--netconf-interface=[plugin]:plugin:' \
          '--ssh-interface=[plugin]:plugin:' \
          '--scp-interface=[plugin]:plugin:' \
          '--sftp-interface=[plugin]:plugin:' \
          '--sftp-handler=[handler]:handler:' \
          '--remote-port-forwarder=[plugin]:plugin:' \
          '--local-port-forwarder=[plugin]:plugin:' \
          '--auth-interface=[plugin]:plugin:' \
          '--authenticator=[authenticator]:auth:(passthrough remoteauth)' \
          '--session-class=[class]:class:' \
          '--agent-forwarder=[plugin]:plugin:' \
          '--listen-address=[ip]:ip:' \
          '--listen-port=[port]:port:' \
          '--transparent[transparent mode]' \
          '--host-key=[host key]:file:_files' \
          '--host-key-algorithm=[algo]:algo:(dss rsa ecdsa ed25519)' \
          '--host-key-length=[bits]:n:' \
          '--banner-name=[banner]:name:' \
          '--plugins[plugin browser]' && ret=0 ;;
      (audit)
        local -a audit_subs
        audit_subs=('CVE-2023-25136:Terrapin attack')
        _arguments '1: :->audit_sub' '*:arg:' && ret=0
        if [[ $state == audit_sub ]]; then
          _describe -t subs 'audit subcommand' audit_subs && ret=0
        fi ;;
      (check-publickey)
        _arguments -s \
          '--host=[host]:host:_hosts' \
          '--port=[port]:port:' \
          '--username=[user]:user:' \
          '*--public-keys=[key file]:file:_files' && ret=0 ;;
      (mosh)
        _arguments \
          '1:subcommand:(client)' \
          '2:host:_hosts' \
          '3:port:' && ret=0 ;;
    esac
    ;;
esac

return ret
