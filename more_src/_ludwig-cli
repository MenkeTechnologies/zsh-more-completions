#compdef ludwig-cli ludwig2
# _ludwig-cli — Uber Predibase Ludwig ludwig-cli CLI command-line frontend wrapping the Ludwig declarative deep-learning framework providing train evaluate predict experiment hyperopt serve preprocess visualize collect_weights export_neuropod export_torchscript export_carton export_mlflow synthesize_dataset upload init_config (Uber team, Python); click
# upstream: https://ludwig.ai/

_ludwig-cli() {
    local -a sub=(
        'train:train a model'
        'evaluate:evaluate a model'
        'predict:run predictions'
        'experiment:run an experiment'
        'hyperopt:run hyperparameter optimization'
        'serve:serve a model'
        'preprocess:preprocess data'
        'visualize:run visualizations'
        'collect-weights:collect model weights'
        'collect-activations:collect activations'
        'export-torchscript:export to TorchScript'
        'export-neuropod:export to Neuropod'
        'export-mlflow:export to MLflow'
        'synthesize-dataset:synthesize dataset'
        'upload:upload to Hub'
        'init-config:init config from data'
        'render-config:render config'
        'check-install:check installation'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '-c+[config]:file:_files -g "*.yaml *.yml"' \
        '--dataset=+[file]:file:_files' \
        '--training-set=+[file]:file:_files' \
        '--validation-set=+[file]:file:_files' \
        '--test-set=+[file]:file:_files' \
        '--data-format=+[f]:f:(csv tsv json jsonl parquet hdf5 feather html numpy pickle excel)' \
        '--output-directory=+[dir]:dir:_files -/' \
        '--model-path=+[dir]:dir:_files -/' \
        '--model-load-path=+[dir]:dir:_files -/' \
        '--model-resume-path=+[dir]:dir:_files -/' \
        '--experiment-name=+[name]:str:' \
        '--model-name=+[name]:str:' \
        '--skip-save-training-description[skip save desc]' \
        '--skip-save-training-statistics[skip save stats]' \
        '--skip-save-model[skip save model]' \
        '--skip-save-progress[skip save progress]' \
        '--skip-save-log[skip save log]' \
        '--skip-save-processed-input[skip save processed input]' \
        '--skip-save-unprocessed-output[skip save unprocessed output]' \
        '--skip-save-predictions[skip save predictions]' \
        '--skip-save-eval-stats[skip save eval stats]' \
        '--backend=+[b]:b:(local ray horovod)' \
        '--random-seed=+[N]:n:' \
        '--gpus=+[ids]:str:' \
        '-f+[format]:f:(json yaml)' \
        '--format=+[format]:f:(json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ludwig-cli subcommand' sub ;;
    esac
}

_ludwig-cli "$@"
