#compdef fcrondyn
# Documentation: https://man.archlinux.org/man/fcrondyn.1.en
# fcron: interact with a running fcron daemon

local ret=1

_arguments -s \
  '-i[run in interactive mode]' \
  '-x[run command and return immediately]:command:' \
  '-c[use alternate config file]:file:_files' \
  '-d[run in debug mode]' \
  '-h[display a brief description of the options]' \
  '-V[display version information]' && ret=0

return ret
