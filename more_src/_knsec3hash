#compdef knsec3hash
# Documentation: https://www.knot-dns.cz/docs/latest/html/man_knsec3hash.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# knsec3hash: compute NSEC3 hash (Knot DNS)
# Synopsis: knsec3hash salt algorithm iterations name
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[print program help]' \
  '(-V --version)'{-V,--version}'[print program version]' \
  '1:salt (hex string):' \
  '2:algorithm number:(1)' \
  '3:iterations:' \
  '4:domain name:' && ret=0
return ret
