#compdef knsec3hash
# Documentation: https://manpages.debian.org/trixie/knot-dnssecutils/knsec3hash.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian trixie knsec3hash(1) manpage.

# knsec3hash: compute NSEC3 hash (Knot DNS)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:salt:' \
  '2:algorithm:(SHA-1)' \
  '3:iterations:' \
  '4:name:' && ret=0
return ret
