#compdef cfm-annotate
# Documentation: https://hub.docker.com/r/wishartlab/cfmid
# cfm-annotate: annotate spectrum peaks with predicted fragments (CFM-ID)

local ret=1

_arguments -s \
  '1:smiles or inchi:_files' \
  '2:spectrum_file:_files' \
  '3:id (molecule identifier):' \
  '4:ppm_mass_tol:' \
  '5:abs_mass_tol:' \
  '6:param_file (trained model parameters):_files' \
  '7:config_file (model configuration):_files' \
  '8:output_file:_files' && ret=0

return ret
