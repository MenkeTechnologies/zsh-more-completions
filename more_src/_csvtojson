#compdef csvtojson
# Documentation: https://github.com/Keyang/node-csvtojson
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# csvtojson CLI accepts the same parameters as the library API, passed as
# --key=value pairs (e.g. --noheader=true, --delimiter=";"). The complete
# parameter list is in the README; only common ones are completed here.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--delimiter=[field delimiter (default: ",", "auto" for autodetect)]:delimiter' \
  '--quote=[quoting character]:char' \
  '--trim=[trim leading/trailing whitespace]:bool:(true false)' \
  '--checkType=[infer cell types]:bool:(true false)' \
  '--ignoreEmpty=[ignore empty fields and rows]:bool:(true false)' \
  '--noheader=[treat first row as data]:bool:(true false)' \
  '--headers=[explicit header array (JSON)]:headers' \
  '--flatKeys=[do not split keys by dot]:bool:(true false)' \
  '--output=[output format]:fmt:(json csv line)' \
  '--downstreamFormat=[downstream format]:fmt:(array line)' \
  '--colParser=[per-column parser map (JSON)]:parser' \
  '--alwaysSplitAtEOL=[always split at EOL]:bool:(true false)' \
  '*:csv file:_files -g "*.{csv,tsv,txt}"' && ret=0

return ret
