#compdef arend
# _arend — JetBrains Arend HoTT-friendly dependent-type-theory proof assistant (jetbrains team, Java/Kotlin); custom argparse
# upstream: https://github.com/JetBrains/Arend

_arend() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--module=+[module name]:str:' \
        '-m+[module name]:str:' \
        '--library=+[library yaml]:file:_files -g "arend.yaml"' \
        '-L+[library yaml]:file:_files -g "arend.yaml"' \
        '--source=+[source dir]:dir:_files -/' \
        '-s+[source dir]:dir:_files -/' \
        '--binary=+[binary dir]:dir:_files -/' \
        '-b+[binary dir]:dir:_files -/' \
        '--libraries=+[libraries dir]:dir:_files -/' \
        '-l+[libraries dir]:dir:_files -/' \
        '--recompile[force recompile]' \
        '-r[force recompile]' \
        '--cache[enable cache]' \
        '-c[enable cache]' \
        '--background-typechecker[bg typechecker]' \
        '--print-options[print options]' \
        '--ext-main=+[extension main class]:str:' \
        '*:file:_files -g "*.ard"'
}

_arend "$@"
