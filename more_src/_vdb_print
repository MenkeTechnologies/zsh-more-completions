#compdef vdb_print
# Documentation: https://github.com/AcademySoftwareFoundation/openvdb/blob/master/openvdb_cmd/vdb_print/main.cc
# OpenVDB: print info about .vdb files

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '(-version --version)'{-version,--version}'[print version information]' \
  '(-l -stats)'{-l,-stats}'[long printout including grid statistics]' \
  '(-m -metadata)'{-m,-metadata}'[print per-file and per-grid metadata]' \
  '*:vdb file:_files -g "*.vdb"' && ret=0

return ret
