#compdef gotestsum-bin
# _gotestsum-bin — gotestsum (Daniel Nephin); same flags as gotestsum, alias for users with bin suffix
# upstream: https://github.com/gotestyourself/gotestsum

_gotestsum-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-f+[format]:fmt:(dots dots-v2 pkgname pkgname-and-test-fails standard-quiet standard-verbose testname testdox github-actions)' \
        '--format=+[format]:fmt:' \
        '--no-color[disable color]' \
        '--debug[debug log]' \
        '--junitfile+[junit output]:file:_files' \
        '--jsonfile+[jsonl output]:file:_files' \
        '--rerun-fails+[max reruns]:n:' \
        '--packages+[packages glob]:pkgs:' \
        '--watch[watch and re-run]' \
        '--raw-command[treat positional as raw cmd]' \
        '*::go test args:'
}

_gotestsum-bin "$@"
