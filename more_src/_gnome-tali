#compdef gnome-tali tali

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--delay=+[computer delay]:ms:' \
  '--scores[show scores]' \
  '--human-players=+[number of human players]:n:' \
  '--computer-players=+[number of computer players]:n:' \
  '--display=+[X display]:disp:' && ret=0

return ret
