#compdef kubebuilder

_kubebuilder_commands() {
  local -a commands=(
    'init:Initialize a new project'
    'create:Scaffold a Kubernetes API or webhook'
    'edit:Update the project configuration'
    'version:Print the kubebuilder version'
    'completion:Generate shell completion scripts'
    'help:Help about any command'
  )
  _describe 'command' commands
}

_kubebuilder_create_commands() {
  local -a commands=(
    'api:Scaffold a Kubernetes API'
    'webhook:Scaffold a webhook for an API resource'
  )
  _describe 'command' commands
}

_kubebuilder() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--plugins=[plugin keys to be used for this subcommand execution]:plugins' \
    '--project-version=[project version]:version' \
    '(-h --help)'{-h,--help}'[help for kubebuilder]' \
    '1:command:_kubebuilder_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        init)
          _arguments \
            '--domain=[domain for groups]:domain' \
            '--repo=[name to use for go module]:repo' \
            '--skip-go-version-check[skip Go version check]' \
            '--project-version=[project version]:version' \
            '--plugins=[plugin keys]:plugins' \
            '(-h --help)'{-h,--help}'[help for init]'
          ;;
        create)
          _arguments -C \
            '1:command:_kubebuilder_create_commands' \
            '*::arg:->create_args'
          case $state in
            create_args)
              case $line[1] in
                api)
                  _arguments \
                    '--group=[resource group]:group' \
                    '--version=[resource version]:version' \
                    '--kind=[resource kind]:kind' \
                    '--resource[if set, generate the resource]:' \
                    '--controller[if set, generate the controller]:' \
                    '--namespaced[resource is namespaced]' \
                    '--make[run make after generating]' \
                    '(-h --help)'{-h,--help}'[help for api]'
                  ;;
                webhook)
                  _arguments \
                    '--group=[resource group]:group' \
                    '--version=[resource version]:version' \
                    '--kind=[resource kind]:kind' \
                    '--defaulting[scaffold defaulting webhook]' \
                    '--validation[scaffold validation webhook]' \
                    '--conversion[scaffold conversion webhook]' \
                    '--programmatic-validation[scaffold programmatic validation webhook]' \
                    '(-h --help)'{-h,--help}'[help for webhook]'
                  ;;
              esac
              ;;
          esac
          ;;
        edit)
          _arguments \
            '--multigroup[enable multi-group layout]' \
            '(-h --help)'{-h,--help}'[help for edit]'
          ;;
        completion)
          _arguments \
            '1:shell:(bash zsh fish powershell)' \
            '(-h --help)'{-h,--help}'[help for completion]'
          ;;
      esac
      ;;
  esac
}

_kubebuilder "$@"
