#compdef ocaml-mdx
# Documentation: https://github.com/realworldocaml/mdx
# Execute code blocks inside markdown and OCaml documentation files

local ret=1
local -a subcmds

subcmds=(
  'test:execute and validate code blocks, writing .corrected files on mismatch'
  'pp:preprocess code blocks, replacing them by their toplevel evaluation'
  'deps:print the dependencies of a markdown file'
  'dune-gen:generate dune rules to test code blocks'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-n --non-deterministic)'{-n,--non-deterministic}'[run non-deterministic blocks]' \
  '--syntax=[syntax of the input file]:syntax:(markdown cram mli)' \
  '(-s --section)'{-s,--section}'=[select a section matching a pattern]:pattern' \
  '--silent[do not print errors]' \
  '--silent-eval[do not print evaluation errors]' \
  '--record-backtrace[record backtraces during evaluation]' \
  '--verbose-findlib[print findlib loading messages]' \
  '*--prelude=[load a prelude file before evaluation]:prelude:_files' \
  '*--prelude-str=[load a prelude string before evaluation]:string' \
  '*--directory=[add a directory to the load path]:directory:_files -/' \
  '--root=[root directory for relative paths]:dir:_files -/' \
  '--force-output[generate corrected file even on success]' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'ocaml-mdx command' subcmds && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
