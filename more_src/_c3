#compdef c3
# _c3 — Cloudflare create-cloudflare CLI for scaffolding projects
# upstream: https://github.com/cloudflare/workers-sdk/tree/main/packages/create-cloudflare

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--type=[type of application to create]:type:(hello-world common webFramework chatbot pre-existing)' \
  '--framework=[web framework to use]:framework:(angular astro docusaurus gatsby hono next nuxt qwik react remix solid svelte vue)' \
  '--deploy[deploy after creation]' \
  '--no-deploy[skip deployment after creation]' \
  '--git[initialize a git repository]' \
  '--no-git[do not initialize git repository]' \
  '--open[open in browser after deploy]' \
  '--no-open[do not open in browser after deploy]' \
  '--existing-script=[name of existing worker script]:name' \
  '--template=[URL of a git repo to use as template]:url' \
  '--accept-defaults[use default values for all prompts]' \
  '-y[use default values for all prompts]' \
  '--auto-update[auto-update c3]' \
  '--no-auto-update[do not auto-update c3]' \
  '--wrangler-defaults[use wrangler defaults]' \
  '1:directory:_directories' && ret=0

return ret
