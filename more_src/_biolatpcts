#compdef biolatpcts biolatpcts-bpfcc
# _biolatpcts — block I/O latency percentiles via BCC/eBPF (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/biolatpcts.py (argparse).

_biolatpcts() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-i --interval)'{-i+,--interval=}'[report interval seconds (0=once, -1=infinite)]:seconds:'
        '(-w --which)'{-w+,--which=}'[latency phase to measure]:phase:(from-rq-alloc after-rq-alloc on-device)'
        '(-p --pcts)'{-p+,--pcts=}'[comma-separated percentiles]:pcts:'
        '(-j --json)'{-j,--json}'[output in JSON]'
        '*'{-v,--verbose}'[increase verbosity]'
        '1:device (/dev/NAME, NAME, or MAJ\:MIN):_files -W /dev/'
    )
    _arguments $args
}

_biolatpcts "$@"
