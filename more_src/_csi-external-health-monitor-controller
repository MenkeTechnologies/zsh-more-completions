#compdef csi-external-health-monitor-controller external-health-monitor
# _csi-external-health-monitor-controller — CSI volume-health monitor (kubernetes-csi/external-health-monitor)
# upstream: https://github.com/kubernetes-csi/external-health-monitor
# Flags from cmd/csi-external-health-monitor-controller/main.go + csi-lib-utils/standardflags/flags.go on tip.

_csi-external-health-monitor-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--kubeconfig=[kubeconfig file (out-of-cluster only)]:file:_files' \
        '--csi-address=[CSI driver UDS path]:path:_files' \
        '--monitor-interval=[health-check loop interval]:dur:' \
        '--resync=[informer resync interval]:dur:' \
        '--timeout=[per-attach/detach CSI RPC timeout]:dur:' \
        '--list-volumes-interval=[ListVolumes poll interval]:dur:' \
        '--volume-list-add-interval=[PV enqueue interval]:dur:' \
        '--node-list-add-interval=[Node enqueue interval]:dur:' \
        '--worker-threads=[concurrent PV monitor workers]:n:' \
        '--enable-node-watcher=[enable node watcher]:bool:(true false)' \
        '--leader-election=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--http-endpoint=[diagnostics HTTP host\:port]:host\:port:' \
        '--metrics-path=[Prometheus metrics HTTP path]:path:' \
        '-v[klog verbosity level]:n:'
}

_csi-external-health-monitor-controller "$@"
