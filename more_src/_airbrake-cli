#compdef airbrake-cli airbrake
# _airbrake-cli — Airbrake airbrake-cli CLI command-line frontend wrapping the Airbrake error monitoring application performance monitoring crash reporting platform CLI providing login deploy notify source-map upload-source-map proguard-mapping symbols-upload project group notice user team backtrace-context language-server breakdown apdex throughput error-occurrences first-seen-last-seen (Airbrake team, Go); cobra
# upstream: https://airbrake.io/

_airbrake-cli() {
    local -a sub=(
        'login:authenticate'
        'whoami:show identity'
        'deploy:report a deployment'
        'notify:notify an event'
        'project:project operations'
        'group:group operations'
        'notice:notice operations'
        'user:user operations'
        'team:team operations'
        'source-map:source map operations'
        'upload-source-map:upload source map'
        'proguard-mapping:ProGuard mapping operations'
        'symbols-upload:upload debug symbols'
        'apdex:apdex operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--project-key=+[key]:str:' \
        '--project-id=+[id]:str:' \
        '--user-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--environment=+[env]:str:' \
        '-e+[env]:str:' \
        '--username=+[name]:str:' \
        '--repository=+[url]:str:' \
        '--revision=+[sha]:str:' \
        '--version=+[v]:str:' \
        '--app-version=+[v]:str:' \
        '--bundle-id=+[id]:str:' \
        '--platform=+[p]:p:(ios android browser node ruby python java elixir php go dotnet)' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'airbrake subcommand' sub ;;
        args)
            case $words[1] in
                source-map|upload-source-map|proguard-mapping|symbols-upload) _arguments '*:file:_files' ;;
                project|group|notice|user|team|apdex) _arguments '1:op:(list get create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_airbrake-cli "$@"
