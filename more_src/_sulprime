#compdef sulprime
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/well_logs/sulprime.c
# find Backus average length for a log suite

local ret=1

_arguments -s -S \
  'b=[target value of Backus number]:b' \
  'dz=[input depth sample interval (ft)]:dz' \
  'f=[frequency (Hz)]:f' \
  'nmax=[maximum averaging length (samples)]:nmax' \
  'verbose=[print intermediate results]:verbose' \
  '*:file:_files' && ret=0


return ret
