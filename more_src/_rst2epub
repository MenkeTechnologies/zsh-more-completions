#compdef rst2epub rst2epub3
# Documentation: https://man.archlinux.org/search?q=rst2epub
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--title=[document title]:title:' \
  '--generator=[generator string]:str:' \
  '--no-generator[suppress generator]' \
  '--datestamp=[datestamp format]:fmt:' \
  '--source-link[insert source link]' \
  '--source-url=[source URL]:url:' \
  '--toc-entry-backlinks[backlinks via TOC]' \
  '--toc-top-backlinks[top backlinks]' \
  '--no-toc-backlinks[no TOC backlinks]' \
  '--no-section-numbering[no section numbering]' \
  '--strip-comments[strip comment elements]' \
  '--leave-comments[keep comment elements]' \
  '--strip-elements-with-class=[strip elements with class]:cls:' \
  '--strict[strict mode]' \
  '--report=[report level]:lvl:(1 2 3 4 5)' \
  '--halt=[halt level]:lvl:(1 2 3 4 5)' \
  '--exit-status=[exit status level]:lvl:' \
  '--debug[verbose debug]' \
  '--no-debug[no debug]' \
  '--warnings=[warnings stream]:file:_files' \
  '--traceback[show full traceback]' \
  '--no-traceback[suppress traceback]' \
  '--input-encoding=[input encoding]:enc:' \
  '--output-encoding=[output encoding]:enc:' \
  '--language=[language code]:lang:' \
  '--config=[config file]:file:_files' \
  '*:file:_files -g "*.{rst,txt}"' && ret=0

return ret
