#compdef kwt kwt-cli
# _kwt — Carvel kwt Kubernetes workstation toolkit CLI (Carvel team / VMware Tanzu, Go); spf13/cobra
# upstream: https://github.com/vmware-tanzu/carvel-kwt

_kwt() {
    local -a sub=(
        'net:network namespace tools'
        'workspace:workspace commands'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--kubeconfig=+[kubeconfig]:file:_files' \
        '--namespace=+[namespace]:str:' \
        '-n+[namespace]:str:' \
        '--context=+[context]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kwt subcommand' sub ;;
        args)
            case $words[1] in
                net) _arguments \
                    '1:cmd:(start clean dump-iptables fetch-domain-ip listen forward proxy)' \
                    '--dns-recursor=+[recursor]:str:' \
                    '--dns-map=+[dns map]:str:' \
                    '--namespace=+[namespace]:str:' \
                    '-n+[namespace]:str:' \
                    '--name=+[name]:str:' \
                    '*:arg:' ;;
                workspace) _arguments \
                    '1:cmd:(install delete enter list)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kwt "$@"
