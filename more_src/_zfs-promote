#compdef zfs-promote
# _zfs-promote — OpenZFS zfs promote promote a cloned dataset to no longer depend on origin snapshot CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-promote() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '*:dataset:'
}

_zfs-promote "$@"
