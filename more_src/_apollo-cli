#compdef apollo-cli
# _apollo-cli — Apollo GraphQL Apollo CLI v2 (codegen/dev) alias (Apollo GraphQL, JavaScript); oclif
# upstream: https://github.com/apollographql/apollo-tooling

_apollo-cli() {
    local -a sub=(
        'client:client commands'
        'service:service commands'
        'help:show help'
        'version:show version'
        'plugins:plugin manager'
        'autocomplete:autocomplete'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "apollo.config.* package.json"' \
        '-c+[config file]:file:_files -g "apollo.config.* package.json"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'apollo subcommand' sub ;;
        args)
            case $words[1] in
                client) _arguments \
                    '1:cmd:(check codegen download-schema extract push)' \
                    '--key=+[apollo studio key]:str:' \
                    '--service=+[service name]:str:' \
                    '--variant=+[variant]:str:' \
                    '--clientName=+[client name]:str:' \
                    '--clientVersion=+[client version]:str:' \
                    '--clientReferenceId=+[client reference id]:str:' \
                    '--endpoint=+[endpoint]:url:_urls' \
                    '--header=+[header]:list:' \
                    '--target=+[target language]:t:(json typescript flow swift scala json-modern)' \
                    '--output=+[output file]:file:_files' \
                    '--queries=+[queries glob]:list:' \
                    '--config=+[config file]:file:_files' \
                    '*:arg:' ;;
                service) _arguments \
                    '1:cmd:(check delete download list push)' \
                    '--key=+[apollo studio key]:str:' \
                    '--service=+[service name]:str:' \
                    '--variant=+[variant]:str:' \
                    '--endpoint=+[endpoint]:url:_urls' \
                    '--header=+[header]:list:' \
                    '--localSchemaFile=+[local schema file]:file:_files' \
                    '--output=+[output file]:file:_files' \
                    '--config=+[config file]:file:_files' \
                    '*:arg:' ;;
                plugins) _arguments \
                    '1:cmd:(install link uninstall update)' \
                    '*:arg:' ;;
                autocomplete) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_apollo-cli "$@"
