#compdef pgcopydb
# Documentation: https://pgcopydb.readthedocs.io/en/latest/ref/pgcopydb.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pgcopydb: stream PostgreSQL databases from source to target
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'clone:copy a database from source to target'
  'fork:alias for clone'
  'follow:apply changes from source to target'
  'snapshot:export a snapshot'
  'compare:compare schemas/data between source and target'
  'copy:copy resource (schema/data/etc.)'
  'dump:dump database objects from a Postgres instance'
  'restore:restore database objects into target'
  'list:list database objects from a Postgres instance'
  'stream:stream changes from source database'
  'ping:test connectivity to source and target'
  'help:show help'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--debug[debug logging]' \
  '--trace[trace logging]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '--notice[notice level]' \
  '--source=[source database conninfo]:conninfo:' \
  '--target=[target database conninfo]:conninfo:' \
  '--dir=[work directory]:dir:_files -/' \
  '--table-jobs=[parallel table jobs]:n:' \
  '--index-jobs=[parallel index jobs]:n:' \
  '--restore-jobs=[parallel restore jobs]:n:' \
  '--large-objects-jobs=[parallel large objects jobs]:n:' \
  '--snapshot=[snapshot name]:name:' \
  '--filters=[filters file]:file:_files' \
  '--skip-extensions[skip extensions]' \
  '--skip-collations[skip collations]' \
  '--skip-large-objects[skip large objects]' \
  '--skip-vacuum[skip vacuum]' \
  '--skip-db-properties[skip db properties]' \
  '--no-role-passwords[no role passwords]' \
  '--no-owner[no owner]' \
  '--no-acl[no acl]' \
  '--no-comments[no comments]' \
  '--no-tablespaces[no tablespaces]' \
  '--drop-if-exists[drop if exists]' \
  '--resume[resume previous run]' \
  '--not-consistent[not consistent snapshot]' \
  '--follow[follow changes after clone]' \
  '--plugin=[logical decoding plugin]:plugin:(test_decoding wal2json pgoutput)' \
  '--slot-name=[logical replication slot]:name:' \
  '--create-slot[create slot]' \
  '--origin=[origin]:name:' \
  '--endpos=[end LSN]:lsn:' \
  '--startpos=[start LSN]:lsn:' \
  '--use-copy-binary[use COPY ... BINARY]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'pgcopydb command' commands && ret=0 ;;
esac
return ret
