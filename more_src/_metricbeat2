#compdef metricbeat2
# _metricbeat2 — Elastic metricbeat2 CLI command-line frontend wrapping the Metricbeat lightweight metric shipper from the Elastic Beats family providing run setup test export keystore modules version completion system-cpu-memory-disk-network-load-process aws-cloudwatch-sqs-rds-s3-lambda azure-monitor gcp-cloudbilling-cloudmonitoring-pubsub kubernetes-state-event-pod docker-container haproxy nginx mysql postgres redis elasticsearch logstash kibana mongodb (Elastic Beats team, Go); cobra
# upstream: https://www.elastic.co/beats/metricbeat

_metricbeat2() {
    local -a sub=(
        'run:run metricbeat'
        'setup:setup index pipelines templates'
        'test:test config or output'
        'export:export config or template'
        'keystore:keystore operations'
        'modules:modules management'
        'version:show version'
        'help:show help'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "metricbeat.yml *.yml *.yaml"' \
        '-d+[selectors]:str:' \
        '-e[log to stderr]' \
        '-E+[k=v]:str:' \
        '-M+[module setting]:str:' \
        '-N[disable publishing]' \
        '--path.home=+[dir]:dir:_files -/' \
        '--path.config=+[dir]:dir:_files -/' \
        '--path.data=+[dir]:dir:_files -/' \
        '--path.logs=+[dir]:dir:_files -/' \
        '--strict.perms[strict perms]' \
        '--system.hostfs=+[dir]:dir:_files -/' \
        '--once[run once]' \
        '--httpprof=+[host:port]:_hosts' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'metricbeat subcommand' sub ;;
        args)
            case $words[1] in
                setup) _arguments '1:target:(--index-management --pipelines --dashboards --machine-learning --policy)' '*:arg:' ;;
                test) _arguments '1:target:(config output modules)' ;;
                export) _arguments '1:target:(config ilm-policy index-pattern template dashboard)' ;;
                keystore) _arguments '1:op:(add create list remove)' '*:key:' ;;
                modules) _arguments '1:op:(enable disable list)' '*:module:(system aws azure gcp kubernetes docker haproxy nginx mysql postgresql redis elasticsearch logstash kibana mongodb prometheus rabbitmq ceph apache traefik tomcat ibmmq oracle)' ;;
            esac
            ;;
    esac
}

_metricbeat2 "$@"
