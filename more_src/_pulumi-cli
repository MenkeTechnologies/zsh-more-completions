#compdef pulumi

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'about:print info about Pulumi env'
  'cancel:cancel an update'
  'config:manage config'
  'console:open Pulumi console'
  'convert:convert IaC to Pulumi'
  'destroy:destroy stack resources'
  'env:Pulumi env'
  'gen-completion:generate shell completion'
  'help:show help'
  'import:import resources into a stack'
  'install:install plugins'
  'login:log in'
  'logout:log out'
  'logs:show logs'
  'new:create new project'
  'org:organization commands'
  'package:package commands'
  'plugin:plugin commands'
  'policy:policy commands'
  'preview:show update preview'
  'refresh:refresh stack state'
  'replay-events:replay events'
  'schema:schema commands'
  'stack:stack commands'
  'state:edit stack state'
  'up:update a stack'
  'update:update a stack'
  'version:show version'
  'watch:watch stack changes'
  'whoami:show current user'
  'completion:generate shell completion'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--color=[color]:c:(auto always never raw)' \
  '*--cwd=[cwd]:dir:_files -/' \
  '*-C+[cwd]:dir:_files -/' \
  '*--disable-integrity-checking[disable integrity check]' \
  '*--emoji[enable emoji]' \
  '*-e[emoji]' \
  '*--logflow[log flow]' \
  '*--logtostderr[log to stderr]' \
  '*--non-interactive[non-interactive]' \
  '*--profiling=[profile path]:p:' \
  '*--tracing=[tracing endpoint]:e:' \
  '*-v[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pulumi command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (up|update|preview|destroy|refresh|cancel)
        _arguments \
          '(-s --stack)'{-s+,--stack=}'[stack]:stack:' \
          '(-y --yes)'{-y,--yes}'[auto approve]' \
          '(-f --skip-preview)'{-f,--skip-preview}'[skip preview]' \
          '(-r --refresh)'{-r,--refresh}'[refresh first]' \
          '(--diff)--diff[diff]' \
          '(--target)*--target=[target URN]:t:' \
          '(--target-dependents)--target-dependents[target dependents]' \
          '(--exclude)*--exclude=[exclude URN]:e:' \
          '(--exclude-dependents)--exclude-dependents[exclude dependents]' \
          '(--show-config)--show-config[show config]' \
          '(--show-replacement-steps)--show-replacement-steps[show replacement]' \
          '(--show-sames)--show-sames[show sames]' \
          '(--parallel)--parallel=[parallel]:n:' \
          '(--message)'{-m+,--message=}'[message]:m:' \
          '(--config)--config=[config k=v]:c:' \
          '(--config-file)--config-file=[config file]:file:_files' \
          '*: :_files' && ret=0 ;;
      (stack)
        _arguments \
          '1:subcommand:(init select ls rm output history change-secrets-provider export import rename tag unselect graph)' \
          '*: :' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(env get set rm cp refresh)' \
          '*: :' && ret=0 ;;
      (state)
        _arguments \
          '1:subcommand:(delete rename unprotect upgrade move repair edit)' \
          '*: :' && ret=0 ;;
      (env)
        _arguments \
          '1:subcommand:(get set ls init rm)' \
          '*: :' && ret=0 ;;
      (plugin)
        _arguments \
          '1:subcommand:(install ls rm run)' \
          '*: :' && ret=0 ;;
      (completion|gen-completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
