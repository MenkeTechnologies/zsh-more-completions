#compdef wgu
# Documentation: https://github.com/emilibota/wireguard-util
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for wgu - WireGuard helper script

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-y[auto-install WireGuard without prompting]' \
  '(-c --conf-name)'{-c,--conf-name}'[interface/config name]:name' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a cmds
    cmds=(
      'set-server:initialize WireGuard server'
      'get-port:print server listen port'
      'get-ip:print server IP address'
      'create-client:add a client peer to server config'
      'remove-client:remove a client peer from server config'
      'setup-client:configure this machine as a WireGuard client'
      'client-disconnect:bring down WireGuard client interface'
      'client-status:show WireGuard interface status'
      'client-enable:enable WireGuard client on boot'
      'client-disable:disable WireGuard client on boot'
      'completions:output shell completion script'
    )
    _describe 'command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      set-server)
        _arguments \
          '(-p --port)'{-p,--port}'[listen port]:port' \
          '(-i --ip)'{-i,--ip}'[server IP without CIDR]:ip' \
          '(-pv --private-key)'{-pv,--private-key}'[private key file]:file:_files' \
          '(-pu --public-key)'{-pu,--public-key}'[public key file]:file:_files' \
          '(-d --directory)'{-d,--directory}'[config directory]:dir:_directories' && ret=0
        ;;
      get-port|get-ip)
        _arguments \
          '(-d --directory)'{-d,--directory}'[config directory]:dir:_directories' && ret=0
        ;;
      create-client)
        _arguments \
          '1:client name' \
          '(-i --ip)'{-i,--ip}'[client IP without CIDR]:ip' \
          '--dns[DNS server]:dns' \
          '(-d --directory)'{-d,--directory}'[config directory]:dir:_directories' && ret=0
        ;;
      remove-client)
        _arguments \
          '1:client name' \
          '(-d --directory)'{-d,--directory}'[config directory]:dir:_directories' && ret=0
        ;;
      setup-client)
        _arguments \
          '(-e --endpoint)'{-e,--endpoint}'[server endpoint IP:PORT]:endpoint' \
          '(-i --ip)'{-i,--ip}'[client IP without CIDR]:ip' \
          '(-s --server-pubkey)'{-s,--server-pubkey}'[server public key]:key' \
          '--dns[DNS server]:dns' \
          '--keepalive[PersistentKeepalive seconds]:seconds' \
          '--allowed-ips[AllowedIPs]:ips' \
          '(-d --directory)'{-d,--directory}'[config directory]:dir:_directories' && ret=0
        ;;
      client-disconnect|client-status|client-enable|client-disable)
        _arguments \
          '(-c --conf-name)'{-c,--conf-name}'[interface name]:name' && ret=0
        ;;
      completions)
        _arguments '1:shell:(bash zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
