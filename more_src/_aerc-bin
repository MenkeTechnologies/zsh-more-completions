#compdef aerc
# _aerc-bin — aerc terminal email client (Drew DeVault, ~sircmpwn, Go); modern TUI email client with vim-style keys + plugins
# upstream: https://git.sr.ht/~rjarry/aerc

_aerc-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-a --account)'{-a,--account}'+[account name]:account:' \
        '(-c --command)'{-c,--command}'+[command at start]:cmd:' \
        '*:mailto: URL:'
}

_aerc-bin "$@"
