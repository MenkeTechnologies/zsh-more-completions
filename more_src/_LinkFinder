#compdef LinkFinder
# Documentation: https://github.com/GerbenJavado/LinkFinder
# python script that finds endpoints and their parameters in JavaScript files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'+[input a URL, file or folder (wildcard allowed)]:input:_files' \
  '(-o --output)'{-o,--output}'+[cli to print to STDOUT, otherwise HTML file path]:output:_files' \
  '(-r --regex)'{-r,--regex}'+[RegEx for filtering found endpoints]:regex' \
  '(-d --domain)'{-d,--domain}'[analyze an entire domain, enumerating all found JS files]' \
  '(-b --burp)'{-b,--burp}'[input a Burp Save selected file with multiple JS files]' \
  '(-c --cookies)'{-c,--cookies}'+[add cookies to the request]:cookies' && ret=0

return ret
