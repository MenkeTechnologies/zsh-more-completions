#compdef csi-provisioner external-provisioner
# _csi-provisioner — Kubernetes CSI external-provisioner sidecar (kubernetes-csi/external-provisioner)
# upstream: https://github.com/kubernetes-csi/external-provisioner
# Flags from cmd/csi-provisioner/csi-provisioner.go + csi-lib-utils/standardflags/flags.go on tip.

_csi-provisioner() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--master=[apiserver URL override]:url:_urls' \
        '--kubeconfig=[kubeconfig file (out-of-cluster only)]:file:_files' \
        '--csi-address=[CSI driver UDS path]:path:_files' \
        '--volume-name-prefix=[provisioned PV name prefix]:prefix:' \
        '--volume-name-uuid-length=[truncate generated UUID to N chars]:n:' \
        '--retry-interval-start=[initial retry interval]:dur:' \
        '--retry-interval-max=[max retry interval]:dur:' \
        '--worker-threads=[concurrent CSI worker threads]:n:' \
        '--cloning-protection-threads=[clone finalizer worker threads]:n:' \
        '--snapshot-orphan-sweep-interval=[orphan snapshot-source sweep interval (0 disables)]:dur:' \
        '--capacity-threads=[CSIStorageCapacity worker threads]:n:' \
        '--timeout=[per-volume-operation timeout]:dur:' \
        '--strict-topology[late-binding only: pass selected node topology]' \
        '--immediate-topology=[immediate binding: pass aggregated topologies]:bool:(true false)' \
        '--extra-create-metadata[add PV/PVC metadata to CreateVolume parameters]' \
        '--enable-pprof[expose pprof on --http-endpoint]' \
        '--default-fstype=[default filesystem type]:fs:' \
        '--kube-api-capacity-qps=[capacity-update Kubernetes API QPS]:f:' \
        '--kube-api-capacity-burst=[capacity-update Kubernetes API burst]:n:' \
        '--enable-capacity[publish CSIStorageCapacity objects]' \
        '--capacity-for-immediate-binding[also produce capacity for immediate-binding classes]' \
        '--capacity-poll-interval=[capacity refresh interval]:dur:' \
        '--capacity-ownerref-level=[ownerref hops to owning object]:n:' \
        '--node-deployment[per-node deployment for node-local volumes]' \
        '--node-deployment-immediate-binding=[allow immediate binding in node-deployment mode]:bool:(true false)' \
        '--node-deployment-base-delay=[initial PVC ownership delay]:dur:' \
        '--node-deployment-max-delay=[max PVC ownership delay]:dur:' \
        '--controller-publish-readonly[mark PV readonly when PVC is ROX]' \
        '--prevent-volume-mode-conversion=[block volume-mode conversion via PVC]:bool:(true false)' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '--leader-election=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--http-endpoint=[diagnostics HTTP host\:port]:host\:port:' \
        '--metrics-path=[Prometheus metrics HTTP path]:path:' \
        '-v[klog verbosity level]:n:'
}

_csi-provisioner "$@"
