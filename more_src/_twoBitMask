#compdef twoBitMask
# UCSC kent: apply masking to a .2bit file, creating a new .2bit file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-add[don'\''t remove pre-existing masking before applying maskFile]' \
  '-type=[type of maskFile]:type:(.bed .bb .out)' \
  ':input 2bit:_files -g "*.2bit"' \
  ':maskFile:_files' \
  ':output 2bit:_files -g "*.2bit"' && ret=0

return ret
