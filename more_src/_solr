#compdef solr

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:launch a Solr instance'
  'stop:gracefully shut down Solr'
  'restart:restart a running Solr instance'
  'status:display JSON-formatted status of running servers'
  'version:print Solr version'
  'assert:verify installation issues and config states'
  'healthcheck:generate health report for SolrCloud collections'
  'create:create new collection or core'
  'delete:remove collection or core'
  'config:modify collection configuration properties'
  'auth:enable/disable Basic Authentication'
  'zk:ZooKeeper operations'
  'export:export collection documents to file'
  'api:send arbitrary HTTP request to Solr endpoint'
  'post:post documents to a collection'
  'snapshot-create:create snapshotted index view'
  'snapshot-list:list available snapshots'
  'snapshot-describe:display snapshot details'
  'snapshot-export:convert snapshot to backup'
  'snapshot-delete:remove snapshot'
  'package:manage installed Solr packages'
  'autoscaling:autoscaling commands (deprecated)'
  'help:show help'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'solr subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (start|restart)
        _arguments \
          '-p+[port]:port:' \
          '-m+[JVM heap size]:size:' \
          '-e+[example name]:name:(cloud techproducts schemaless films)' \
          '-z+[ZooKeeper host]:zkHost:' \
          '--user-managed[run standalone instead of SolrCloud]' \
          '-d+[server directory]:dir:_files -/' \
          '-s+[Solr home dir]:dir:_files -/' \
          '-h+[host name]:host:_hosts' \
          '-jvm-opts+[JVM options]:opts:' \
          '-q[quiet]' \
          '-V[verbose]' \
          '-f[run in foreground]' && ret=0
        ;;
      (stop)
        _arguments \
          '-p+[port]:port:' \
          '--all[stop all running instances]' && ret=0
        ;;
      (healthcheck)
        _arguments \
          '-c+[collection]:collection:' \
          '-z+[ZooKeeper host]:zkHost:' && ret=0
        ;;
      (create)
        _arguments \
          '-c+[collection/core name]:name:' \
          '-d+[config directory]:dir:_files -/' \
          '-sh+[number of shards]:n:' \
          '-rf+[replication factor]:n:' \
          '-n+[config name]:name:' && ret=0
        ;;
      (delete)
        _arguments \
          '-c+[name]:name:' \
          '--delete-config[also remove config from ZooKeeper]' && ret=0
        ;;
      (config)
        _arguments \
          '-c+[collection]:collection:' \
          '--action=[action]:action:(set-property unset-property set-user-property unset-user-property)' \
          '--property=[property name]:name:' \
          '--value=[new value]:value:' && ret=0
        ;;
      (auth)
        _arguments \
          '1:operation:(enable disable)' \
          '--credentials=[user:pass]:cred:' \
          '--prompt=[interactive prompt]:flag:(true false)' && ret=0
        ;;
      (zk)
        _arguments \
          '1:zk operation:(upconfig downconfig cp mv rm ls mkroot)' \
          '-d+[directory]:dir:_files -/' \
          '-n+[config name]:name:' \
          '-r[recursive]' \
          '-z+[ZooKeeper host]:zkHost:' \
          '*:path:' && ret=0
        ;;
      (export)
        _arguments \
          '-c+[collection]:collection:' \
          '--format=[output format]:format:(json jsonl javabin)' \
          '--limit=[document count]:n:' && ret=0
        ;;
      (api)
        _arguments \
          '-s+[endpoint URL]:url:' \
          '-X+[HTTP method]:method:(GET POST PUT DELETE PATCH)' \
          '-d+[request body]:body:' && ret=0
        ;;
      (post)
        _arguments \
          '-c+[collection]:collection:' \
          '--mode=[post mode]:mode:(args files web stdin)' \
          '--type=[content type]:type:(application/json application/xml text/csv)' \
          '--params=[query parameters]:params:' \
          '--filetypes=[file types]:types:' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
