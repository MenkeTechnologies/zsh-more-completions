#compdef kafka-run-class
# Documentation: https://github.com/apache/kafka/blob/4.2/bin/kafka-run-class.sh
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# USAGE: kafka-run-class [-daemon] [-name servicename] [-loggc] classname [opts]
# Options use a single dash, not a double dash.

local -a arguments

arguments=(
    '-daemon[Run as a daemon]'
    '-name[Service name]:name:'
    '-loggc[Enable GC logging]'
    '*:class name and arguments:'
)

_arguments -s -S $arguments
