#compdef kafka-run-class
# Documentation: https://man.archlinux.org/search?q=kafka-run-class
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '--daemon[Run as a daemon]'
    '--name[Daemon name]:name:'
    '--loggc[Enable GC logging]'
    '*:class name and arguments:'
)

_arguments -s -S $arguments
