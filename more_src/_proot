#compdef proot

# Zsh completion for proot - User-space chroot implementation

_arguments -s -S \
  '(-r --rootfs)'{-r,--rootfs}'=[guest root directory]:directory:_files -/' \
  '*'{-b,--bind}'=[bind mount path]:path (src\:dest):_files' \
  '(-q --qemu)'{-q,--qemu}'=[QEMU user-mode binary]:program:_files' \
  '(-w --pwd)'{-w,--pwd}'=[initial working directory]:directory:_files -/' \
  '(-v --verbose)'{-v,--verbose}'=[verbosity level (-1 to 3)]:level:' \
  '(-0 --root-id)'{-0,--root-id}'[pretend to be root (UID/GID 0)]' \
  '(-i --change-id)'{-i,--change-id}'=[change UID and GID]:UID\:GID:' \
  '(-k --kernel-release)'{-k,--kernel-release}'=[fake kernel release string]:release:' \
  '--kill-on-exit[kill all tracees on exit]' \
  '--link2symlink[translate hard links to symbolic links]' \
  '--no-seccomp[disable seccomp acceleration]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:command:_command_names -e'
