#compdef kdesrc-build
# _kdesrc-build — KDE kdesrc-build (Perl-based driver that builds the KDE Frameworks/Plasma/Applications stack from git: pulls per-module configs from kdesrc-buildrc, runs configure/build/install across modules with parallelism, log rotation, etc.)
# upstream: https://invent.kde.org/sdk/kdesrc-build
# Flags + subcommands from kdesrc-build kdesrc-build on tip.

_kdesrc-build() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--initial-setup[run first-time setup]' \
        '--rc-file+[config file]:file:_files' \
        '--build-system-only[only run cmake/configure]' \
        '--refresh-build[wipe build/ before building]' \
        '--no-src[skip source update step]' \
        '--no-build[skip build step]' \
        '--no-install[skip install step]' \
        '--no-tests[skip test step]' \
        '--run+[run an installed binary]:binary:_command_names -e' \
        '--prefix+[install prefix]:dir:_files -/' \
        '--cmake-options+[extra CMake args]:args:' \
        '--make-options+[extra make args]:args:' \
        '--num-cores+[parallel jobs]:n:' \
        '--include-dependencies[also build deps]' \
        '--no-include-dependencies[skip deps]' \
        '--rebuild-failures[retry only previously-failed]' \
        '--resume-from+[resume from module]:module:' \
        '--stop-on-failure[abort on first failure]' \
        '--dependency-tree[print dep tree]' \
        '*:module:'
}

_kdesrc-build "$@"
