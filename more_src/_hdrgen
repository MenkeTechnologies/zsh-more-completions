#compdef hdrgen
# Documentation: http://www.anyhere.com/gward/pickup/hdrgen.html
# create a high dynamic-range image from multiple exposures of a static scene

local ret=1

_arguments -s \
  '-o+[write HDR image to file (format from suffix)]:out file:_files' \
  '-F[toggle file overwrite protection]' \
  '-k+[write variance image to file]:var file:_files' \
  '-q+[set output quality (0-100)]:quality' \
  '-r+[use file for camera response curves]:cam.rsp:_files' \
  '-c+[output colour space]:space:(sRGB XYZ AdobeRGB P3)' \
  '-m+[cache size in megabytes (default 1000)]:size' \
  '-a[toggle automatic exposure alignment]' \
  '-e[toggle exposure adjustment fine-tuning]' \
  '-x[toggle removal of over/under-exposed images]' \
  '-f[toggle lens flare removal]' \
  '-g[toggle ghost removal for moving objects]' \
  '-s+[sample-to-nits conversion factor for next image]:stonits' \
  '*:exposure image:_files -g "*.(jpg|jpeg|tif|tiff|JPG|TIF)"' && ret=0

return ret
