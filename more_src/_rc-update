#compdef rc-update

# Zsh completion for rc-update - add and remove services to/from OpenRC runlevels

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add a service to a runlevel'
  'del:delete a service from a runlevel'
  'delete:delete a service from a runlevel'
  'show:show a service across runlevels'
)

_arguments -s -S \
  '1:command:->command' \
  '(-a --all)'{-a,--all}'[process all runlevels]' \
  '(-s --stack)'{-s,--stack}'[stack a runlevel instead of a service]' \
  '(-u --update)'{-u,--update}'[force an update of the dependency tree]' \
  '(-C --nocolor)'{-C,--nocolor}'[disable color output]' \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --version)'{-V,--version}'[show version information and exit]' \
  '(-v --verbose)'{-v,--verbose}'[run verbosely]' \
  '(-q --quiet)'{-q,--quiet}'[run quietly]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'rc-update command' commands && ret=0
    ;;
  (args)
    local -a services
    services=(${(f)"$(rc-service --list 2>/dev/null)"})
    _arguments \
      '1:service:compadd -a services' \
      '2:runlevel:(boot default nonetwork shutdown sysinit)' && ret=0
    ;;
esac

return ret
