#compdef bdep
# Documentation: https://build2.org/bdep/doc/bdep.xhtml
# build2 project dependency management tool

local ret=1

_arguments -s -S \
  '(-h --help)--help[print usage and exit]' \
  '--version[print version and exit]' \
  '(-v)-v[print essential underlying commands being executed]' \
  '(-V)-V[print all underlying commands being executed]' \
  '(-q --quiet)'{-q,--quiet}'[run quietly, only printing errors]' \
  '--verbose=[set diagnostics verbosity level (0-6)]:level:(0 1 2 3 4 5 6)' \
  '--stdout-format=[output format for standard output]:format:' \
  '(-j --jobs)'{-j,--jobs}'=[number of parallel jobs]:jobs:' \
  '--progress[display progress indicators]' \
  '--no-progress[suppress progress indicators]' \
  '--diag-color[use color in diagnostics]' \
  '--no-diag-color[do not use color in diagnostics]' \
  '--no-default-options[do not load default options files]' \
  '1:command:((
    help\:"show help for a command or topic"
    new\:"create and initialize new project"
    init\:"initialize project in build configurations"
    sync\:"synchronize project and build configurations"
    fetch\:"fetch list of available project dependencies"
    status\:"print status of project and/or its dependencies"
    ci\:"submit project test request to CI server"
    release\:"manage project version during release"
    publish\:"publish project to archive repository"
    deinit\:"deinitialize project in build configurations"
    config\:"manage project build configurations"
    test\:"test project in build configurations"
    update\:"update project in build configurations"
    clean\:"clean project in build configurations"
  ))' \
  '*::arg:->args' && ret=0

return ret
