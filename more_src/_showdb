#compdef showdb
# showdb - Display information on configured databases

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-database[single database name to display]:db:' \
  '-html[format output as HTML table]' \
  '-protein[display protein databases]' \
  '-nucleic[display nucleotide databases]' \
  '-sequence[display general sequence databases]' \
  '-feature[display feature annotation databases]' \
  '-text[display text databases]' \
  '-taxonomy[display taxonomy databases]' \
  '-resource[display resource databases]' \
  '-assembly[display sequence assembly databases]' \
  '-obo[display bio-ontology databases]' \
  '-xml[display XML databases]' \
  '-standard[display standard databases]' \
  '-user[display user-defined databases]' \
  '-include[display databases from included files]' \
  '-full[display all available columns]' \
  '-access[show access levels available]' \
  '-methods[show access methods available]' \
  '-taxscope[show taxonomic scope covered]' \
  '-fields[display searchable fields]' \
  '-numfields[show count of searchable fields]' \
  '-aliases[display alternative database names]' \
  '-numaliases[show count of aliases]' \
  '-examples[display example queries]' \
  '-numexamples[show count of example queries]' \
  '-defined[show database definition file location]' \
  '-release[display release information column]' \
  '-outfile[output file name]:file:_files' \
  '-only[display selected columns only]' \
  '-heading[toggle column headings display]' \
  '-type[toggle type column display]' \
  '-id[toggle ID access column display]' \
  '-query[toggle query access column display]' \
  '-all[toggle all access column display]' \
  '-comment[toggle comment column display]' \
  '-auto[turn off prompts]' \
  '-stdout[write to standard output]' \
  '-version[display version number]' && ret=0

return ret
