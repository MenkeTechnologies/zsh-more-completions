#compdef prusa-slicer-console
# Documentation: https://github.com/prusa3d/PrusaSlicer/wiki/Command-Line-Interface
# PrusaSlicer console-mode CLI (slice/export from the command line)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-fff[show FFF (FDM) config options]' \
  '--help-sla[show SLA config options]' \
  '(-g --export-gcode)'{-g,--export-gcode}'[slice and export G-code]' \
  '--export-sla[slice and export SLA archive]' \
  '--export-stl[export model as STL]' \
  '--export-3mf[export model as 3MF]' \
  '--export-obj[export model as OBJ]' \
  '--export-amf[export model as AMF]' \
  '--slice[slice the given model]' \
  '--info[output info about the model]' \
  '--repair[repair non-manifold mesh]' \
  '--merge[arrange and merge models into one]' \
  '--dont-arrange[do not arrange, use original coordinates]' \
  '--load=[load config from .ini file]:config:_files' \
  '(-o --output)'{-o,--output}'=[set output file path]:output:_files' \
  '--datadir=[set configuration directory]:dir:_files -/' \
  '--loglevel=[set log verbosity 0-5]:level:(0 1 2 3 4 5)' \
  '--center=[center model around X,Y]:point:' \
  '--align-xy=[align model to X,Y]:point:' \
  '--rotate=[rotate around Z by angle]:angle:' \
  '--rotate-x=[rotate around X by angle]:angle:' \
  '--rotate-y=[rotate around Y by angle]:angle:' \
  '--scale=[scale by factor or percentage]:factor:' \
  '--scale-to-fit=[scale to fit X,Y,Z]:size:' \
  '--duplicate=[number of copies]:count:' \
  '--duplicate-grid=[arrange copies in X,Y grid]:grid:' \
  '--split[split mesh into separate objects]' \
  '--save=[save config to file]:config:_files' \
  '*:model file:_files -g "*.(stl|STL|obj|OBJ|amf|AMF|3mf|3MF)"' && ret=0

return ret
