#compdef spkpredict
# Documentation: https://schnetpack.readthedocs.io/en/latest/userguide/configs.html
# SchNetPack: run predictions with a trained model via Hydra configuration

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config-dir=[add a config directory to the search path]:dir:_files -/' \
  '--config-name=[overrides the config name]:name' \
  '--config-path=[overrides the config path]:dir:_files -/' \
  '--cfg=[show config without running]:type:(job hydra all)' \
  '--multirun[run multiple jobs with sweeped parameters]' \
  '--info[print Hydra information]' \
  '*:override:_default' && ret=0

return ret
