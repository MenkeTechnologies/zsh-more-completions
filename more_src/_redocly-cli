#compdef redocly-cli
# _redocly-cli — Redocly OpenAPI tooling CLI alias (Redocly Inc., TypeScript); commander
# upstream: https://github.com/Redocly/redocly-cli

_redocly-cli() {
    local -a sub=(
        'lint:lint OpenAPI spec'
        'bundle:bundle multi-file spec into one'
        'build-docs:render Redocly Reference docs'
        'preview-docs:run dev preview server'
        'push:push to Redocly portal'
        'login:login to Redocly cloud'
        'logout:logout'
        'stats:print spec statistics'
        'split:split bundled spec into files'
        'join:join multiple specs into one'
        'completion:generate shell completion'
        'check-config:validate redocly.yaml'
        'translations:manage translations'
        'eject:eject docs theme'
        'preview:run portal preview'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "redocly.yaml *.yml *.yaml"' \
        '-c+[config file]:file:_files -g "redocly.yaml *.yml *.yaml"' \
        '--no-color[no color]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'redocly subcommand' sub ;;
        args)
            case $words[1] in
                lint) _arguments \
                    '--format=+[format]:fmt:(stylish codeframe json checkstyle codeclimate junit summary github-actions)' \
                    '-f+[format]:fmt:(stylish codeframe json checkstyle codeclimate junit summary github-actions)' \
                    '--max-problems=+[max problems]:n:' \
                    '--skip-rule=+[skip rule]:list:' \
                    '--skip-preprocessor=+[skip preprocessor]:list:' \
                    '--extends=+[extends]:list:' \
                    '--generate-ignore-file[generate ignore file]' \
                    '--lint-config=+[lint config severity]:s:(error warn off)' \
                    '*:spec:_files' ;;
                bundle) _arguments \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--ext=+[output ext]:e:(json yaml yml)' \
                    '--dereferenced[fully dereference]' \
                    '-d[fully dereference]' \
                    '--force[force]' \
                    '--remove-unused-components[remove unused components]' \
                    '--keep-url-references[keep url references]' \
                    '-k[keep url references]' \
                    '*:spec:_files' ;;
                preview-docs|build-docs|preview) _arguments \
                    '--theme.openapi.htmlTemplate=+[html template]:file:_files' \
                    '--theme.openapi.nativeScrollbars[native scrollbars]' \
                    '-t+[template]:file:_files' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--title=+[title]:str:' \
                    '*:spec:_files' ;;
                push|pull) _arguments \
                    '--domain=+[domain]:str:' \
                    '--branch-name=+[branch name]:str:' \
                    '--mount-path=+[mount path]:str:' \
                    '--job-id=+[job id]:str:' \
                    '--organization=+[organization]:str:' \
                    '--namespace=+[namespace]:str:' \
                    '--repository=+[repository]:str:' \
                    '*:spec:_files' ;;
                stats) _arguments \
                    '--format=+[format]:fmt:(stylish json markdown)' \
                    '-f+[format]:fmt:(stylish json markdown)' \
                    '*:spec:_files' ;;
                split|join) _arguments \
                    '--outDir=+[output dir]:dir:_files -/' \
                    '*:spec:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_redocly-cli "$@"
