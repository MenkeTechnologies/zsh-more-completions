#compdef dmmakepar
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmmakepar.html
# Convert the header keywords of a file into a parameter file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'input=[input FITS file or stack]:input:_files' \
  'output=[output text par file]:output:_files -g "*.par"' \
  'template=[template parameter file]:template:_files -g "*.par"' \
  'case=[output keyword case]:case:(same upper lower)' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:argument:_files' && ret=0

return ret
