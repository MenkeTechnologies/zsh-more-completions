#compdef pslCheck
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: validate PSL files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-db=[get targetSizes from this database]:db:' \
  '-prot[confirm psls are protein psls]' \
  '-noCountCheck[don'\''t validate match/mismatch counts]' \
  '-pass=[write PSLs without errors to this file]:file:_files' \
  '-fail=[write PSLs with errors to this file]:file:_files' \
  '-filter[use as filter, don'\''t error exit on problems]' \
  '-targetSizes=[tab file of target and size]:file:_files' \
  '-querySizes=[file with query sizes]:file:_files' \
  '-skipInsertCounts[don'\''t validate insert counts]' \
  '-ignoreQUniq[ignore text after last dash in qName]' \
  '-quiet[no error message, just filter]' \
  '*:psl file or table:_files' && ret=0

return ret
