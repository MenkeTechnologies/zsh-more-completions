#compdef dipy_median_otsu
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_median_otsu.html
# DIPY: brain extraction via median Otsu thresholding

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--bvalues_files=[path to b-values files]:file:_files' \
  '--b0_threshold=[threshold for b0 volume consideration]:thr' \
  '--save_masked[save mask]' \
  '--median_radius=[median filter radius in voxels]:radius' \
  '--numpass=[number of median filter passes]:n' \
  '--autocrop[crop mask to bounding box (deprecated)]' \
  '--vol_idx=[axis indices for 4D volumes]:idx' \
  '--dilate=[binary dilation iterations]:n' \
  '--finalize_mask[remove holes or islands]' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_mask=[mask volume filename]:file:_files' \
  '--out_masked=[masked volume filename]:file:_files' \
  '*:input volumes:_files' && ret=0

return ret
