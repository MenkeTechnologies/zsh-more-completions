#compdef cain-ncnn-vulkan-extra
# Documentation: https://github.com/nihui/cain-ncnn-vulkan
# CAIN ncnn Vulkan video frame interpolation (extra-models fork)

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose output]' \
  '-0+[first input image path]:input0:_files' \
  '-1+[second input image path]:input1:_files' \
  '-i+[input directory]:input dir:_files -/' \
  '-o+[output image path or directory]:output:_files' \
  '-m+[cain model path]:model dir:_files -/' \
  '-g+[gpu device to use]:gpu id' \
  '-j+[thread count for load:proc:save]:threads' \
  '-x[enable tta mode]' \
  '-f+[output filename pattern format]:format' && ret=0

return ret
