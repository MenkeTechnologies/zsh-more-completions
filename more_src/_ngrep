#compdef ngrep
# _ngrep — Jordan Ritter's ngrep (network grep; libpcap-based packet sniffer that applies extended regex to TCP/UDP/ICMP payloads + supports BPF filter expression)
# upstream: https://github.com/jpr5/ngrep
# Flags from ngrep.8 + ngrep.c getopt on tip.

_ngrep() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-V[show version and exit]' \
        '-N[show sub-protocol number]' \
        '-X[treat match expression as hex string]' \
        '-i[case-insensitive regex]' \
        '-w[word-match regex]' \
        '-q[quiet (only headers + payloads)]' \
        '-p[do not put interface in promiscuous mode]' \
        '-e[show empty packets]' \
        '-v[invert match]' \
        '-x[dump as hex + ASCII]' \
        '-l[line-buffer stdout]' \
        '-C[colorize matches]' \
        '-u[show UTF-8 in payload output]' \
        '-D[replay pcap dumps at real rate]' \
        '-t[absolute timestamp on each match]' \
        '-T[delta timestamp]' \
        '-R[do not drop root privileges]' \
        '-r[resolve container IPs to Docker/Podman names]' \
        '-M[match across packets (multi-packet)]' \
        '-c+[console width override]:cols:' \
        '-F+[read BPF filter from file]:file:_files' \
        '-P+[non-printable substitution character]:char:' \
        '-K+[send N RST segments to matching TCP flows (kill)]:n:' \
        '-W+[payload display mode]:mode:(normal byline single none)' \
        '-s+[BPF caplen (snaplen)]:bytes:' \
        '-S+[max payload bytes to scan]:bytes:' \
        '-I+[input pcap dump file]:file:_files' \
        '-O+[output pcap dump file]:file:_files' \
        '-n+[stop after N matches]:n:' \
        '-d+[network interface]:iface:_net_interfaces' \
        '-A+[trailing context packets]:n:' \
        '*::regex-or-bpf:'
}

_ngrep "$@"
