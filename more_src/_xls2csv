#compdef xls2csv

# Zsh completion for xls2csv - MS Excel to CSV converter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[column separator (default comma)]:separator' \
  '-d+[destination charset]:charset' \
  '-q+[quote mode]:mode:((0\:"minimal" 1\:"all" 2\:"nonnumeric" 3\:"none"))' \
  '-s+[source charset]:charset' \
  '-b+[book/sheet selection]:book' \
  '-l[list available charsets]' \
  '-x[dump hex output]' \
  '1:file:_files -g "*.{xls,XLS}"'
