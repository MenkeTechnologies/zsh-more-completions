#compdef dvm

# howtowhale/dvm — `dvm-helper/dvm-helper.go` (codegangsta/cli)

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '--github-token=[GitHub personal token]:token:' \
  '--dvm-dir=[DVM state dir]:dir:_files -/' \
  '--shell=[env snippet format]:shell:(sh bash zsh powershell cmd)' \
  '--debug[verbose debug]' \
  '--silent[quiet operational output]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'dvm command' compadd -- detect install i uninstall use deactivate current which alias unalias list \
    list-remote list-alias upgrade
  ;;
rest)
  case $line[1] in
    install|i)
      _arguments '*--mirror-url=[binary mirror base]:url:' \
        '1:version or edge:' && ret=0
      ;;
    use)
      _arguments '*--mirror-url=[binary mirror base]:url:' \
        '--nocheck[skip version existence check]' \
        '1:version edge or system:' && ret=0
      ;;
    uninstall)
      _arguments '1:version:' && ret=0
      ;;
    list-remote)
      _arguments '--pre[list pre-release builds]' && ret=0
      ;;
    upgrade)
      _arguments '--check[only probe for newer dvm]' \
        '--version=[target dvm release]:version:' && ret=0
      ;;
    alias)
      _arguments '1:alias name: 2:target version:' && ret=0
      ;;
    unalias)
      _arguments '1:alias name:' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
