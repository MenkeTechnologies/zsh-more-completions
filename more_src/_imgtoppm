#compdef imgtoppm
# Documentation: man imgtoppm (Netpbm)
# Source: convert an Img-whatnot file to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:img file:_files -g "*.img"' \
    && ret=0

return ret
