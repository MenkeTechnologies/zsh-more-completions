#compdef cmdh
# Documentation: https://github.com/pgibler/cmdh
# Create Linux commands from natural language, in the shell

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '1:command:((configure\:"start the configuration wizard"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    if [[ $words[1] == configure ]]; then
      _values 'subcommand' 'show[display current configuration]'
    fi
    ;;
esac

return ret
