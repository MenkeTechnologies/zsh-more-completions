#compdef ksort
# Documentation: https://github.com/superbrothers/ksort
# Reference accessed: 2026-05-19
# Verified: upstream ksort.go cobra command definition at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[print the version and exit]' \
  '*'{-f,--filename}'=[resource file/dir to sort by Kind]:file:_files' \
  '(-R --recursive)'{-R,--recursive}'[process the directory recursively]' \
  '(-d --delete)'{-d,--delete}'[sort manifests in uninstall order]' \
  '*:manifest file:_files' && ret=0

return ret
