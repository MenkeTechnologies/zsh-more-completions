#compdef qmelt
# Documentation: https://www.mltframework.org/docs/melt/
# qmelt — Shotcut's Qt-based melt (MLT) command-line renderer; same option set as melt

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage information]' \
  '-version[display version information]' \
  '-attach[attach a filter to the output]:filter' \
  '-attach-cut[attach a filter to a cut]:filter' \
  '-attach-track[attach a filter to a track]:filter' \
  '-attach-clip[attach a filter to a producer]:filter' \
  '-audio-track[designate an audio-only track]' \
  '-hide-video[designate an audio-only track]' \
  '-video-track[designate a video-only track]' \
  '-hide-audio[designate a video-only track]' \
  '-blank[add blank silence to a track]:length' \
  '-chain[add a producer as a chain]:producer' \
  '-consumer[set the consumer (sink)]:consumer' \
  '-debug[set the logging level to debug]' \
  '-filter[add a filter to the current track]:filter' \
  '-getc[get keyboard input using getc]' \
  '-group[apply properties repeatedly]' \
  '-jack[enable JACK transport synchronization]' \
  '-join[join multiple clips into one cut]' \
  '-link[add a link to a chain]:link' \
  '-loglevel[configure logging verbosity]:level' \
  '-mix[add a mix between the last two cuts]:length' \
  '-mixer[add a transition to the mix]:transition' \
  '-null-track[add a hidden track]' \
  '-hide-track[add a hidden track]' \
  '-profile[set the processing settings]:profile' \
  '-progress[display progress along with the position]' \
  '-query[list all of the registered services]:service' \
  '-quiet[set the logging level to quiet]' \
  '-remove[remove the most recent cut]' \
  '-repeat[repeat the last cut]:count' \
  '-repository[set the directory of MLT modules]:dir:_files -/' \
  '-serialise[write the commands to a text file]:file:_files' \
  '-setlocale[make numeric strings locale-sensitive]' \
  '-silent[do not display position/transport help]' \
  '-split[split the last cut into two cuts]:frame' \
  '-swap[rearrange the last two cuts]' \
  '-track[add a track]' \
  '-transition[add a transition]:transition' \
  '-verbose[set the logging level to verbose]' \
  '*:file:_files' && ret=0

return ret
