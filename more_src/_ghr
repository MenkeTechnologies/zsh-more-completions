#compdef ghr
# Documentation: https://github.com/tcnksm/ghr
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local ret=1
_arguments -s -S \
  '-h[show help]' \
  '-v[show version]' \
  '-t+[GitHub API token]:token:' \
  '-u+[GitHub username]:user:' \
  '-r+[repository name]:repo:' \
  '-c+[target commitish, branch, or commit SHA]:commit:' \
  '-n+[release title]:title:' \
  '-b+[release body / notes]:body:' \
  '-p+[parallelism count]:n:' \
  '-delete[delete release and git tag if existing]' \
  '-replace[replace artifacts if already uploaded]' \
  '-draft[create as draft release]' \
  '-soft[stop uploading if tag already exists]' \
  '-prerelease[mark release as prerelease]' \
  '-recreate[delete and recreate release]' \
  '-generatenotes[generate release notes automatically]' \
  '1:tag:' \
  '2:artifact path:_files' && ret=0

return ret
