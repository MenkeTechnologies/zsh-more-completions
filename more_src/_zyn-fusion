#compdef zyn-fusion
# Documentation: https://man.archlinux.org/search?q=zyn-fusion
# Reference accessed: 2026-05-16

# Zyn-Fusion: modern Zyn frontend (drop-in zynaddsubfx replacement)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --load)'{-l,--load=}'[load XMZ]:file:_files -g "*.xmz"' \
  '(-L --load-instrument)'{-L,--load-instrument=}'[load XIZ]:file:_files -g "*.xiz"' \
  '(-r --sample-rate)'{-r,--sample-rate=}'[sample rate]:n:' \
  '(-b --buffer-size)'{-b,--buffer-size=}'[audio buffer size]:n:' \
  '(-I --audio)'{-I,--audio=}'[audio backend]:backend:(jack alsa portaudio oss null)' \
  '(-O --output)'{-O,--output=}'[MIDI backend]:backend:(jack alsa oss)' \
  '(-U --no-gui)'{-U,--no-gui}'[no GUI]' \
  '*::zyn-fusion args:_files' && ret=0
return ret
