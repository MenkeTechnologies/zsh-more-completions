#compdef runpodctl runpod
# Documentation: https://man.archlinux.org/search?q=runpodctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'pod:manage Pods (create, list, start, stop, delete)'
  'serverless:manage Serverless endpoints'
  'sls:alias for serverless'
  'template:manage templates'
  'tpl:alias for template'
  'hub:browse and deploy from Runpod Hub'
  'network-volume:manage network volumes'
  'nv:alias for network-volume'
  'registry:manage container registry authentications'
  'reg:alias for registry'
  'gpu:list available GPUs'
  'datacenter:list datacenters'
  'dc:alias for datacenter'
  'billing:view billing history'
  'user:view account information'
  'me:alias for user'
  'ssh:manage SSH keys and connection info'
  'send:transfer files to a pod (no API key needed)'
  'receive:transfer files from a pod (no API key needed)'
  'exec:execute a command on a pod'
  'create:create a resource'
  'get:get info about a resource'
  'start:start a resource'
  'stop:stop a resource'
  'remove:remove a resource'
  'update:update a resource'
  'config:configure API key'
  'doctor:diagnose and fix CLI issues'
  'completion:generate shell completion'
  'version:show version'
  'help:show help for any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--api-key=[Runpod API key]:key:' \
  '--output=[output format]:format:(table json yaml)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'runpodctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (pod)
        local -a pod_cmds=(
          'list:list pods'
          'get:get pod info'
          'create:create a pod'
          'update:update a pod'
          'start:start a pod'
          'stop:stop a pod'
          'delete:delete a pod'
          'exec:execute on a pod'
        )
        _describe -t pcmds 'pod command' pod_cmds && ret=0 ;;
      (serverless|sls)
        local -a sls_cmds=(
          'list:list endpoints'
          'get:get endpoint info'
          'create:create endpoint'
          'update:update endpoint'
          'delete:delete endpoint'
        )
        _describe -t scmds 'serverless command' sls_cmds && ret=0 ;;
      (ssh)
        local -a ssh_cmds=(
          'add-key:add SSH key to account'
          'list-keys:list SSH keys'
          'remove-key:remove SSH key'
          'connect:get SSH connection info'
        )
        _describe -t sshcmds 'ssh command' ssh_cmds && ret=0 ;;
      (send|receive)
        _arguments '*::file:_files' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
