#compdef sourcery-cli
# _sourcery-cli — Krzysztof Zabłocki Sourcery Swift meta-programming code generator CLI alias (Krzysztof Zabłocki / krzysztofzablocki, Swift); custom argparse
# upstream: https://github.com/krzysztofzablocki/Sourcery

_sourcery-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g ".sourcery.yml *.yml"' \
        '-c+[config file]:file:_files -g ".sourcery.yml *.yml"' \
        '--sources=+[source path]:list:_files' \
        '-s+[source path]:list:_files' \
        '--exclude-sources=+[exclude source path]:list:_files' \
        '--templates=+[template path]:list:_files' \
        '-t+[template path]:list:_files' \
        '--exclude-templates=+[exclude template path]:list:_files' \
        '--output=+[output path]:dir:_files -/' \
        '-o+[output path]:dir:_files -/' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '--prune[prune empty output files]' \
        '-p[prune empty output files]' \
        '--cache-base-path=+[cache base path]:dir:_files -/' \
        '--disable-cache[disable cache]' \
        '--no-cache[disable cache]' \
        '--watch[watch files]' \
        '-w[watch files]' \
        '--logging=+[log level]:level:(error warn info debug verbose)' \
        '--logAST[log AST]' \
        '--logBenchmarks[log benchmarks]' \
        '--xc-frameworks=+[xc frameworks]:list:_files' \
        '--args=+[args]:str:' \
        '--target=+[xcode target]:str:' \
        '--project=+[xcode project]:file:_files -g "*.xcodeproj"' \
        '--workspace=+[xcode workspace]:file:_files -g "*.xcworkspace"' \
        '--parse-documentation[parse documentation]' \
        '--build-path=+[build path]:dir:_files -/' \
        '*:file:_files'
}

_sourcery-cli "$@"
