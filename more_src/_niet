#compdef niet
# _niet — read JSON / YAML / TOML values by JMESPath (openuado/niet)
# upstream: https://github.com/openuado/niet
# Flags from niet/__init__.py (argparse).

_niet() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '*'{-a+,--additional-objects=}'[extra JMESPath expression to query (repeatable)]:expr:'
        '(-f --format)'{-f+,--format=}'[output format]:format:(json yaml toml eval newline ifs squote dquote comma)'
        '(-i --in-place)'{-i,--in-place}'[modify the input file in place (with --output)]'
        '(-o --output)'{-o+,--output=}'[write output to file instead of stdout]:file:_files'
        '(-s --silent)'{-s,--silent}'[silent mode (no message on missing element)]'
        '--debug[activate pdb-based debug mode]'
        '1:JMESPath expression:'
        '2:JSON/YAML/TOML file or URL:_files'
    )
    _arguments -s $args
}

_niet "$@"
