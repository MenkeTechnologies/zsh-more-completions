#compdef pattern_sim
# Documentation: https://www.desy.de/~twhite/crystfel/manual-pattern_sim.html
# Simulate serial crystallography diffraction patterns (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-p --pdb)'{-p+,--pdb=}'[unit cell file]:file:_files' \
  '(-g --geometry)'{-g+,--geometry=}'[detector geometry file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[write pattern to file]:file:_files' \
  '(-i --intensities)'{-i+,--intensities=}'[reflection intensities/phases file]:file:_files' \
  '(-y --symmetry)'{-y+,--symmetry=}'[symmetry of intensity list]:pointgroup:' \
  '(-t --gradients)'{-t+,--gradients=}'[molecular transform calc method]:method:' \
  '(-n --number)'{-n+,--number=}'[number of patterns to simulate]:n:' \
  '(-r --random-orientation)'{-r,--random-orientation}'[random orientation per pattern]' \
  '(-s --sample-spectrum)'{-s+,--sample-spectrum=}'[spectrum samples in calculation]:n:' \
  '(-x --spectrum)'{-x+,--spectrum=}'[spectrum type]:type:(tophat sase twocolour)' \
  '--gpu[use GPU via OpenCL]' \
  '--gpu-dev=[GPU device number]:n:' \
  '--no-images[do not save HDF5 images]' \
  '--powder=[write sum of all patterns to file]:file:_files' \
  '--really-random[seed RNG from /dev/urandom]' \
  '--min-size=[min random crystal size in nm]:min:' \
  '--max-size=[max random crystal size in nm]:max:' \
  '--no-noise[do not calculate Poisson noise]' \
  '--background=[add n photons of background]:n:' \
  '--no-fringes[suppress shape transform maxima]' \
  '--nphotons=[photons per X-ray pulse]:val:' \
  '--beam-radius=[X-ray beam radius in metres]:val:' && ret=0

return ret
