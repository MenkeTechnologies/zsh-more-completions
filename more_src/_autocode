#compdef autocode

# Zsh completion for autocode
# Upstream: Code automation for every language, library and framework
# Conservative fallback — run `autocode --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
