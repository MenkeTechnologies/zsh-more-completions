#compdef mast
# Documentation: https://meme-suite.org/meme/doc/mast.html
# MEME Suite: search sequences for matches to a group of motifs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output directory (default mast_out), fail if exists]:dir:_files -/' \
  '-oc[output directory (default mast_out), overwrite if exists]:dir:_files -/' \
  '-dblist[sequence file contains a list of FASTA filenames]' \
  '-hit_list[output machine-readable hit list to stdout only]' \
  '-best[include only the best motif hit (requires -hit_list)]' \
  '-nostatus[suppress progress reports to stderr]' \
  '-notext[do not output the plain text file]' \
  '-nohtml[do not output the HTML file]' \
  '-remcorr[remove highly correlated motifs]' \
  '*-m[use only the motif at the nth position]:n:' \
  '-c[use only the first count motifs]:count:' \
  '-mev[use only motifs with E-values <= threshold]:thresh:' \
  '-diag[nominal motif order and spacing diagram]:diagram:' \
  '-norc[do not score the reverse complement strand]' \
  '-sep[score the reverse complement as a separate sequence]' \
  '-dna[translate DNA sequences to protein]' \
  '-comp[adjust p-values for sequence composition]' \
  '-ev[output sequences with E-values below this]:evalue:' \
  '-mt[show motif matches with p-value below this]:mt:' \
  '-w[show weak matches in angle brackets]' \
  '-seqp[use sequence p-values for motif thresholds]' \
  '-mf[motif filename to use in results]:mf:' \
  '-df[database name to use in results]:df:' \
  '-dl[URL for linking sequences to annotation]:dl:' \
  '-bfile[background model file]:file:_files' \
  '-minseqs[lower bound on the number of sequences]:ms:' \
  '*:motif/sequence file:_files' && ret=0

return ret
