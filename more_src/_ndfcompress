#compdef ndfcompress
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss122.html
# KAPPA: compress an NDF so that it occupies less disk space

local ret=1

_arguments -s \
  'IN=[the input NDF]:NDF:_files' \
  'OUT=[the output NDF]:NDF:_files' \
  'METHOD=[compression method]:method:(BOTH SCALED DELTA)' \
  'DSCALE=[scale factor for the Data component]:dscale' \
  'DZERO=[zero offset for the Data component]:dzero' \
  'VSCALE=[scale factor for the VARIANCE component]:vscale' \
  'VZERO=[zero offset for the VARIANCE component]:vzero' \
  'SCALEDTYPE=[data type for scaled values]:scaledtype' \
  'ZAXIS=[pixel axis for DELTA differences]:zaxis' \
  'ZMINRATIO=[minimum compression ratio]:zminratio' \
  'ZTYPE=[data type for stored differences]:ztype' \
  '*:NDF:_files' && ret=0

return ret
