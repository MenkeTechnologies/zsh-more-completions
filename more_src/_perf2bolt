#compdef perf2bolt
# Documentation: https://github.com/llvm/llvm-project/blob/main/bolt/docs/OptimizingClang.md
# convert perf.data into BOLT profile format

local ret=1

_arguments -s \
  '(-help --help)'{-help,--help}'[show help]' \
  '-help-hidden[show hidden options]' \
  '--version[show version]' \
  '-p=[input perf.data file]:perf data:_files' \
  '-o=[output BOLT profile file]:output:_files' \
  '-perfdata=[input perf.data file]:perf data:_files' \
  '-ignore-build-id[ignore build-id mismatch between perf.data and binary]' \
  '-nl[no LBR aggregation mode]' \
  '-pa[input is pre-aggregated profile data]' \
  '-pid=[only use samples from this PID]:pid' \
  '-filter-mem-profile[filter out memory profile samples]' \
  '-max-samples=[maximum number of samples to process]:n' \
  '-perfdata-jobs=[number of parallel perf decode jobs]:n' \
  '-lite[lite mode aggregation]' \
  '*:input binary:_files' && ret=0

return ret
