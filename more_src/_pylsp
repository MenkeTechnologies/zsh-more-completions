#compdef pylsp

# Zsh completion for pylsp - Python Language Server Protocol

_arguments -s -S \
  '--tcp[use TCP server]' \
  '--ws[use WebSocket server]' \
  '--host=[host for TCP/WebSocket]:host:' \
  '--port=[port for TCP/WebSocket]:port:' \
  '--check-parent-process[check parent process is alive]' \
  '--log-config=[log config file]:file:_files' \
  '--log-file=[redirect logs to file]:file:_files' \
  '-v[increase verbosity]' \
  '-vv[more verbose]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]'
