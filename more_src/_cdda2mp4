#compdef cdda2mp4
# Documentation: https://man.archlinux.org/search?q=cdda2mp4
# Reference accessed: 2026-05-16

# cdda2mp4: rip a CD to MP4 (AAC) audio files
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-d[CD device]:device:_files' \
  '-o[output dir]:dir:_files -/' \
  '-q[quality]:n:' \
  '-b[bitrate (kbps)]:n:' \
  '-t[track number]:n:' \
  '*::cdda2mp4 args:_files' && ret=0
return ret
