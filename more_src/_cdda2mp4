#compdef cdda2mp4
# Documentation: https://cdrtools.sourceforge.net/private/man/cdda2wav.1.html
# Reference accessed: 2026-05-17
# Verified: cdrtools-distributed cdda2mp4 wrapper script (cdda2wav
# + faac). Passes all flags through to cdda2wav with defaults `-H
# -q`. Configuration via env vars: CDDA2WAV, CDDA2WAV_OPTS, AACENC,
# AACENC_OPTS, CDDA_DEVICE, OUTPUTDIR, FILEPREFIX.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h, -d, -o, -q, -b, -t (no flag surface of its own).

local ret=1
_arguments -s \
  '1:track range (e.g. 1+2-5):' \
  '*:device:_files -g "/dev/(cdrom|sr*|cd*|dvd*)(-.)"' && ret=0
return ret
