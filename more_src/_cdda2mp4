#compdef cdda2mp4

# cdda2mp4: rip a CD to MP4 (AAC) audio files
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-d[CD device]:device:_files' \
  '-o[output dir]:dir:_files -/' \
  '-q[quality]:n:' \
  '-b[bitrate (kbps)]:n:' \
  '-t[track number]:n:' \
  '*::cdda2mp4 args:_files' && ret=0
return ret
