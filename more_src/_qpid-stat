#compdef qpid-stat
# Documentation: https://manned.org/qpid-stat/e43ca557
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(-g --general)'{-g,--general}'[show general broker stats]' \
  '(-c --connections)'{-c,--connections}'[show connections]' \
  '(-e --exchanges)'{-e,--exchanges}'[show exchanges]' \
  '(-q --queues)'{-q,--queues}'[show queues]' \
  '(-u --subscriptions)'{-u,--subscriptions}'[show subscriptions]' \
  '(-m --memory)'{-m,--memory}'[show broker memory stats]' \
  '--acl[show access control list stats]' \
  '(-b --broker)'{-b,--broker=}'[broker URL]:url:' \
  '(-t --timeout)'{-t,--timeout=}'[broker connection timeout in seconds]:secs:' \
  '--sasl-mechanism=[SASL mechanism]:mech:(EXTERNAL ANONYMOUS PLAIN CRAM-MD5 DIGEST-MD5 GSSAPI)' \
  '--sasl-service-name=[SASL service name]:name:' \
  '--ssl-certificate=[client SSL certificate (PEM format)]:cert:_files' \
  '--ssl-key=[client SSL private key (PEM format)]:key:_files' \
  '--ha-admin[allow connection to a HA backup broker]' \
  '(-S --sort-by)'{-S,--sort-by=}'[sort by column name]:column:' \
  '(-I --increasing)'{-I,--increasing}'[sort by increasing value]' \
  '(-L --limit)'{-L,--limit=}'[limit output to n rows]:n:'
