#compdef qpid-stat
# Documentation: https://qpid.apache.org/releases/qpid-cpp-1.39.0/cpp-broker/book/ch02s02.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '-g[show general broker stats]' \
  '-c[show connections]' \
  '-e[show exchanges]' \
  '-q[show queues]' \
  '-u[show subscriptions]' \
  '-m[show broker memory stats]' \
  '--acl[show access control list info]' \
  '(-b --broker)'{-b,--broker=}'[broker address]:addr:'
