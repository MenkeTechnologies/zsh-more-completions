#compdef faTrans
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# translate DNA .fa file to peptide

local ret=1

_arguments -s -S \
  '-stop[stop at first stop codon]' \
  '-offset=[start at a particular offset]:n' \
  '-cdsUpper[cds is in upper case]' \
  '1:in fa:_files -g "*.(fa|fasta)"' \
  '2:out fa:_files' && ret=0

return ret
