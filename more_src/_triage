# Zsh completion for triage (AWS Triage CLI)

local -a commands
commands=(
  'init:Initialize a project directory'
  'deploy:Deploy Triage infrastructure to AWS'
  'destroy:Tear down AWS resources'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help message]' \
  '1: :_describe -t commands "command" commands'
