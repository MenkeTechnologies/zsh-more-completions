#compdef xenstore-watch xenstore-control xenstore-chmod
# Documentation: https://man.archlinux.org/search?q=xenstore-watch
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (xenstore-watch)
    _arguments -C \
      '-h[show help]' \
      '-s+[socket]:file:_files' \
      '*:path:' && ret=0 ;;
  (xenstore-control)
    _arguments -C \
      '-h[show help]' \
      '-s+[socket]:file:_files' \
      '1:command:(check log memreport monitor)' \
      '*: :' && ret=0 ;;
  (xenstore-chmod)
    _arguments -C \
      '-h[show help]' \
      '-s+[socket]:file:_files' \
      '-r[recursive]' \
      '-u[update only]' \
      '-d[delete]' \
      '*: :' && ret=0 ;;
esac

return ret
