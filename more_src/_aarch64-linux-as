#compdef aarch64-linux-as aarch64-linux-gnu-as
# _aarch64-linux-as — GNU binutils aarch64-linux-as CLI cross-arch GAS assembler for ARMv8 AArch64 little-endian Linux Cortex-A53 Cortex-A55 Cortex-A72 Apple M1 Marvell ThunderX producing ELF64 object files supporting A64 SVE SVE2 NEON BTI PAC mcpu march arch-extension syntax (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_aarch64-linux-as() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-J[no warnings about signed overflow]' \
        '-K[allow modify .word section]' \
        '-W[suppress warnings]' \
        '--no-warn[suppress warnings]' \
        '--fatal-warnings[treat warnings as errors]' \
        '--warn[issue warnings]' \
        '-Z[generate object file even after errors]' \
        '-I+[include path]:dir:_files -/' \
        '-L[keep local symbols]' \
        '--keep-locals[keep local symbols]' \
        '-o+[output object]:file:_files -g "*.o *.elf"' \
        '-R[fold data section into text section]' \
        '--statistics[print statistics]' \
        '-g[generate debug info]' \
        '--gen-debug[generate debug info]' \
        '--gstabs[generate stabs debug]' \
        '--gdwarf-2[generate DWARF2]' \
        '--gdwarf-3[generate DWARF3]' \
        '--gdwarf-4[generate DWARF4]' \
        '--gdwarf-5[generate DWARF5]' \
        '-mcpu=+[cpu]:c:(generic cortex-a35 cortex-a53 cortex-a55 cortex-a57 cortex-a65 cortex-a72 cortex-a73 cortex-a75 cortex-a76 cortex-a77 cortex-a78 cortex-a510 cortex-a710 cortex-a715 cortex-a720 cortex-x1 cortex-x2 cortex-x3 cortex-x4 neoverse-n1 neoverse-n2 neoverse-v1 neoverse-v2 thunderx thunderx2t99 apple-a14 apple-m1 apple-m2 native)' \
        '-mtune=+[tune]:str:' \
        '-march=+[arch]:a:(armv8-a armv8.1-a armv8.2-a armv8.3-a armv8.4-a armv8.5-a armv8.6-a armv8.7-a armv8.8-a armv9-a armv9.1-a armv9.2-a armv9.3-a armv9.4-a native)' \
        '-mabi=+[abi]:a:(lp64 ilp32)' \
        '-EL[little endian]' \
        '-EB[big endian]' \
        '-mbig-endian[big endian]' \
        '-mlittle-endian[little endian]' \
        '-mno-verbose-error[no verbose error]' \
        '-mverbose-error[verbose error messages]' \
        '*:assembly file:_files -g "*.s *.S *.asm"'
}

_aarch64-linux-as "$@"
