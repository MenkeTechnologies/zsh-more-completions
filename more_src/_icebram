#compdef icebram
# Documentation: https://man.archlinux.org/search?q=icebram
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-g[generate random BRAM content]' \
  '1:from_hex_or_asc:_files' \
  '2:to_hex_or_asc:_files' && ret=0

return ret
