#compdef icebram
# Documentation: https://manpages.debian.org/testing/fpga-icestorm/icebram.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-g[generate random BRAM content]' \
  '1:from_hex_or_asc:_files' \
  '2:to_hex_or_asc:_files' && ret=0

return ret
