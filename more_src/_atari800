#compdef atari800
# Documentation: https://manpages.debian.org/bookworm/atari800/atari800.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm atari800(1) manpage. Single-dash long flags
# throughout (BSD-style). Listing the commonly-used subset; full surface
# is enormous - see manpage for complete list.

# atari800: Atari 8-bit family emulator (400/800/XL/XE/5200)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-v[show version]' \
  '(- *)-verbose[show version verbose]' \
  '-atari[emulate Atari 800]' \
  '-1200[emulate Atari 1200XL]' \
  '-xl[emulate Atari 800XL]' \
  '-xe[emulate Atari 130XE]' \
  '-320xe[emulate Atari 320XE]' \
  '-rambo[emulate Atari 320XE RAMBO]' \
  '-576xe[emulate Atari 576XE]' \
  '-1088xe[emulate Atari 1088XE]' \
  '-xegs[emulate Atari XEGS]' \
  '-5200[emulate Atari 5200]' \
  '-config[config file]:file:_files' \
  '-osa_rom[Atari 800 OS-A ROM]:file:_files' \
  '-osb_rom[Atari 800 OS-B ROM]:file:_files' \
  '-xlxe_rom[XL/XE ROM]:file:_files' \
  '-5200_rom[5200 ROM]:file:_files' \
  '-basic_rom[BASIC ROM]:file:_files' \
  '-pal[use PAL]' \
  '-ntsc[use NTSC]' \
  '-nobasic[disable built-in BASIC]' \
  '-basic[enable built-in BASIC]' \
  '-cart[load cartridge]:file:_files -g "*.(rom|car|bin)"' \
  '-cart-type[cartridge type]:type:' \
  '-cart2[second cartridge]:file:_files' \
  '-cart2-type[second cartridge type]:type:' \
  '-run[run binary file]:file:_files' \
  '-state[load state file]:file:_files' \
  '-tape[mount cassette tape]:file:_files -g "*.cas"' \
  '-boottape[boot cassette tape]:file:_files -g "*.cas"' \
  '-fullscreen[fullscreen mode]' \
  '-windowed[windowed mode]' \
  '-bpp[bits per pixel]:n:' \
  '-sound[enable sound]' \
  '-nosound[disable sound]' \
  '-stereo[stereo audio]' \
  '-nostereo[mono audio]' \
  '-volume[audio volume]:n:' \
  '-mouse[mouse mode]:mode:(off pad touch koala pen gun amiga st trak joy)' \
  '-mouseport[mouse port]:port:' \
  '-mousespeed[mouse speed]:speed:' \
  '-record[record video]:file:_files' \
  '-playback[playback recording]:file:_files' \
  '*:Atari disk/cart/exe:_files -g "*.(atr|atz|atx|xfd|atx|car|rom|cas|com|exe|xex)"' && ret=0
return ret
