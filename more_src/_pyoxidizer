#compdef pyoxidizer

# Zsh completion for pyoxidizer - Python application packager

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--verbose[verbose output]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'analyze:analyze a built binary'
      'build:build a PyOxidizer project'
      'cache-clear:clear PyOxidizer caches'
      'find-resources:find Python resources in a directory'
      'generate-python-embedding-artifacts:generate artifacts for embedding Python'
      'init-config-file:create a new config file'
      'init-rust-project:create a new Rust project with PyOxidizer'
      'list-targets:list build targets'
      'run:run a target in a PyOxidizer project'
      'rust-project-licensing:show licensing info for Rust project'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (build|run|list-targets)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--path[directory of project]:dir:_directories' \
          '--target-triple[target triple]:triple:' \
          '--release[build in release mode]' \
          '*:target:' \
          && ret=0
        ;;
      (init-config-file|init-rust-project)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--python-code[default Python code to run]:code:' \
          '--pip-install[pip package to install]:package:' \
          '1:path:_directories' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
