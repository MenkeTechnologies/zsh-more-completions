#compdef pyoxidizer
# Documentation: https://github.com/indygreg/PyOxidizer/blob/main/pyoxidizer/src/cli.rs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pyoxidizer - Python application packager

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--verbose[verbose output]' \
  '--system-rust[use system rust toolchain]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'analyze:analyze a built binary'
      'build:build a PyOxidizer project'
      'cache-clear:clear PyOxidizer caches'
      'find-resources:find Python resources in a directory'
      'generate-python-embedding-artifacts:generate artifacts for embedding Python'
      'init-config-file:create a new config file'
      'init-rust-project:create a new Rust project with PyOxidizer'
      'list-targets:list build targets'
      'python-distribution-extract:extract a Python distribution archive'
      'python-distribution-info:show info on a Python distribution archive'
      'python-distribution-licenses:show licensing info for a Python distribution'
      'run:run a target in a PyOxidizer project'
      'run-build-script:run a build-script step'
      'rust-project-licensing:show licensing info for Rust project'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (analyze)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:path:_files' && ret=0
        ;;
      (build|run)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--path=[directory of project]:dir:_directories' \
          '--target-triple=[Rust target triple]:triple:' \
          '--release[build/run in release mode]' \
          '*--var=[define Starlark variable]:var:' \
          '*--var-env=[define Starlark variable from env]:var:' \
          '--target=[target to run]:target:' \
          '*:target:' && ret=0
        ;;
      (list-targets)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:path:_directories' && ret=0
        ;;
      (find-resources)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--distributions-dir=[directory for extracted distributions]:dir:_directories' \
          '--scan-distribution[scan a Python distribution instead]' \
          '--target-triple=[Rust target triple]:triple:' \
          '--no-classify-files[skip file classification]' \
          '--no-emit-files[skip emitting File resources]' \
          '1:path:_files' && ret=0
        ;;
      (generate-python-embedding-artifacts)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--target-triple=[Rust target triple]:triple:' \
          '--flavor=[Python distribution flavor]:flavor:(standalone)' \
          '--python-version=[Python version X.Y]:version:' \
          '1:dest path:_directories' && ret=0
        ;;
      (init-config-file)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--python-code=[default Python code to run]:code:' \
          '*--pip-install=[pip package to install]:package:' \
          '1:path:_directories' && ret=0
        ;;
      (init-rust-project)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:path:_directories' && ret=0
        ;;
      (python-distribution-extract)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--download-default[download default distribution]' \
          '--archive-path=[path to distribution archive]:file:_files' \
          '1:dest path:_directories' && ret=0
        ;;
      (python-distribution-info|python-distribution-licenses)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:path:_files' && ret=0
        ;;
      (rust-project-licensing)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--all-features[activate all crate features]' \
          '--target-triple=[Rust target triple]:triple:' \
          '--unified-license[print unified license document]' \
          '1:project path:_directories' && ret=0
        ;;
      (run-build-script)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--target=[config target to resolve]:target:' \
          '*--var=[define Starlark variable]:var:' \
          '*--var-env=[define Starlark variable from env]:var:' \
          '1:build-script-name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
