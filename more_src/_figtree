#compdef figtree FigTree
# FigTree: graphical phylogenetic tree viewer (with graphic export)

local ret=1

_arguments -s -S \
  '-help[print help message]' \
  '-graphic[produce a graphic with the given format]:format:(PDF SVG SWF PS EMF GIF PNG JPEG)' \
  '-width[width of the graphic in pixels]:pixels:' \
  '-height[height of the graphic in pixels]:pixels:' \
  '1:tree file:_files' \
  '2:graphic output file:_files' && ret=0

return ret
