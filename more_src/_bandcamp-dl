#compdef bandcamp-dl

# Zsh completion for bandcamp-dl (Bandcamp downloader)

_arguments -s -S \
  '--template[filename template]:template:' \
  '--base-dir[base download directory]:dir:_files -/' \
  '--full-album[download full album]' \
  '--overwrite[overwrite existing files]' \
  '--no-art[do not download album art]' \
  '--embed-lyrics[embed lyrics if available]' \
  '--group[group tracks in album directory]' \
  '--no-slugify[do not slugify file/directory names]' \
  '--ok-chars[characters to keep in filenames]:chars:' \
  '--space-char[character to replace spaces]:char:' \
  '--ascii-only[only use ASCII characters in filenames]' \
  '--keep-spaces[keep spaces in filenames]' \
  '--keep-upper[keep uppercase in filenames]' \
  '--no-confirm[do not confirm before downloading]' \
  '--debug[enable debug output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:URL:_urls' && return 0
