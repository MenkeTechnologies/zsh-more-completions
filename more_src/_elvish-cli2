#compdef elvish-cli2 elvish2
# _elvish-cli2 — Qi Xiao Elves elvish-cli2 CLI command-line frontend wrapping the Elvish modern friendly Powerful expressive programming language and versatile interactive shell open-source written in Go originally Qi Xiao now Elves team Elvish is an interactive shell and an expressive programming language Higher-order-functions Exceptions Namespaces Closures Lexical-scoping First-class-values Lambdas Exception-handling try except finally throw modules data types map array hash command-completion daemon directory-history history-server background-jobs piping-structured-data store-server modes -c -i -daemon -sock -db --version --help --json --bin -log --logprefix --norc --rc --buildinfo --compileonly --deprecation-level (Qi Xiao Elves team, Go); custom argparse
# upstream: https://elv.sh/

_elvish-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[command]:str:' \
        '-i[interactive]' \
        '-norc[no rc]' \
        '-rc=+[file]:file:_files -g "*.elv"' \
        '-daemon[run as daemon]' \
        '-sock=+[file]:_files' \
        '-db=+[file]:_files' \
        '-log=+[file]:_files' \
        '-logprefix=+[prefix]:str:' \
        '-cpuprofile=+[file]:file:_files' \
        '-buildinfo[show build info]' \
        '-json[JSON output]' \
        '-bin=+[file]:_files' \
        '-compileonly[compile only]' \
        '-deprecation-level=+[N]:n:' \
        '*:elv file:_files -g "*.elv"'
}

_elvish-cli2 "$@"
