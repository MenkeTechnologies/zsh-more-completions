#compdef kind

# Zsh completion for kind (Kubernetes in Docker)

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'build:Build one of \[node-image\]'
  'completion:Output shell completion code for the specified shell'
  'create:Creates one of \[cluster\]'
  'delete:Deletes one of \[cluster clusters\]'
  'export:Exports one of \[kubeconfig logs\]'
  'get:Gets one of \[clusters kubeconfig nodes\]'
  'load:Loads images into nodes'
  'version:Prints the kind CLI version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[Help for kind]' \
  '--loglevel=[DEPRECATED: use -v instead]:level:' \
  {-q,--quiet}'[Silence all stderr output]' \
  {-v,--verbosity}'=[Info log verbosity (0-9)]:level:' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'kind command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      build)
        _arguments -C \
          '1:target:(node-image)' \
          '--base-image=[Name:tag of the base image to use]:image:' \
          '--image=[Name:tag of the resulting image]:image:' \
          '--kube-root=[Path to the Kubernetes source directory]:dir:_directories' \
          '--type=[Build type (docker|bazel)]:type:(docker bazel)' && ret=0
        ;;
      completion)
        _arguments \
          '1:shell:(bash zsh fish)' && ret=0
        ;;
      create)
        _arguments -C \
          '1:resource:(cluster)' \
          '--config=[Path to a kind config file]:file:_files' \
          '--image=[Node docker image to use]:image:' \
          '--kubeconfig=[Sets kubeconfig path instead of $KUBECONFIG or default]:file:_files' \
          '--name=[Cluster name (default: kind)]:name:' \
          '--retain[Retain nodes for debugging when cluster creation fails]' \
          '--wait=[Wait for control plane node to be ready (e.g. 5m)]:duration:' && ret=0
        ;;
      delete)
        _arguments -C \
          '1:resource:(cluster clusters)' \
          '--kubeconfig=[Sets kubeconfig path]:file:_files' \
          '--name=[Cluster name]:name:' \
          '--all[Delete all clusters]' && ret=0
        ;;
      export)
        _arguments -C \
          '1:resource:(kubeconfig logs)' \
          '--kubeconfig=[Where to write kubeconfig]:file:_files' \
          '--name=[Cluster name]:name:' \
          '--internal[Export the internal kubeconfig]' && ret=0
        ;;
      get)
        _arguments -C \
          '1:resource:(clusters kubeconfig nodes)' \
          '--name=[Cluster name]:name:' && ret=0
        ;;
      load)
        _arguments -C \
          '1:subcommand:(docker-image image-archive)' \
          '--name=[Cluster name]:name:' \
          '--nodes=[Comma separated list of nodes to load images into]:nodes:' \
          '*:image:' && ret=0
        ;;
      version)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
