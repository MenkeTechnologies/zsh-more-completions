#compdef s6-rc-db
# Documentation: https://man.archlinux.org/search?q=s6-rc-db
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-l[path to live state directory]:live directory:_files -/' \
  '-c[path to compiled database]:database directory:_files -/' \
  '-b[use the backup database]' \
  '1:command:(list type timeout contents dependencies)' \
  '*:service name' && ret=0

return ret
