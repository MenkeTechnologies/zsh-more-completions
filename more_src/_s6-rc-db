#compdef s6-rc-db

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-l[path to live state directory]:live directory:_files -/' \
  '-c[path to compiled database]:database directory:_files -/' \
  '-b[use the backup database]' \
  '1:command:(list type timeout contents dependencies)' \
  '*:service name' && ret=0

return ret
