#compdef vis-menu
# Documentation: https://github.com/martanne/vis/blob/master/man/vis-menu.1
# vis-menu - interactive menu/filter for the vis editor (dmenu-like)

local ret=1

_arguments -s -S \
  '-i[use case-insensitive comparison when filtering items]' \
  '(-b)-t[display menu on the top line of the terminal]' \
  '(-t)-b[display menu on the bottom line of the terminal]' \
  '-p+[display prompt before the list of items]:prompt:' \
  '-l+[display each item on its own line, lines high]:lines:' \
  '-v[print version number and exit]' \
  '*:initial:' && ret=0

return ret
