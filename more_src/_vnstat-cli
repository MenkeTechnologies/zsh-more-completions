#compdef vnstat-cli
# _vnstat-cli — Teemu Toivola vnStat console-based network traffic monitor CLI alias (vergoh team, C); custom argparse
# upstream: https://github.com/vergoh/vnstat

_vnstat-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-?[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--longhelp[show extended help]' \
        '--query[query database]' \
        '-q[query database]' \
        '--hours[show last 24 hours]' \
        '-hg[show last 24 hours]' \
        '--hourly[show hourly]' \
        '-H[show hourly]' \
        '--days[show daily]' \
        '-d[show daily]' \
        '--weeks[show weekly]' \
        '-w[show weekly]' \
        '--months[show monthly]' \
        '-m[show monthly]' \
        '--years[show yearly]' \
        '-y[show yearly]' \
        '--top[show top days]' \
        '-t[show top days]' \
        '--sumof=+[period]:p:(hour day month year)' \
        '--limit=+[entries]:n:' \
        '--add[add interface]' \
        '--remove[remove interface]' \
        '--rename=+[new name]:str:' \
        '--force[force operation]' \
        '--iface=+[interface]:_net_interfaces' \
        '-i+[interface]:_net_interfaces' \
        '--config=+[config file]:file:_files -g "vnstat.conf"' \
        '--style=+[output style]:n:(0 1 2 3 4)' \
        '--dbdir=+[database dir]:dir:_files -/' \
        '--locale=+[locale]:str:' \
        '--enable-bw-detection[enable bw detection]' \
        '--disable-bw-detection[disable bw detection]' \
        '--rateunit=+[unit]:u:(0 1)' \
        '--showconfig[show effective config]' \
        '--showbeginsalert[show begins-alert]' \
        '--alert=+[options]:str:' \
        '--xml=+[mode]:m:(a c d h m s t y)' \
        '-x+[mode]:m:(a c d h m s t y)' \
        '--xmlrows=+[n]:n:' \
        '--xmlmaxsize=+[n]:n:' \
        '--xmlsize[include sizes in xml]' \
        '--json=+[mode]:m:(a c d h m s t y)' \
        '-j+[mode]:m:(a c d h m s t y)' \
        '--jsonrows=+[n]:n:' \
        '--oneline[one line summary]' \
        '-O[one line summary]' \
        '--short[short format]' \
        '-s[short format]' \
        '--traffic=+[seconds]:n:' \
        '-tr+[seconds]:n:' \
        '--live[live mode]' \
        '-l[live mode]' \
        '--iflist[list interfaces]' \
        '--dbiflist[list db interfaces]' \
        '--testkernel[test kernel]' \
        '*:interface:_net_interfaces'
}

_vnstat-cli "$@"
