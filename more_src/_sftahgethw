#compdef sftahgethw
# Documentation: http://www.ahay.org/RSF/sftahgethw.html
# Madagascar: print trace header keys from trace-and-header (tah) data

local ret=1

_arguments -s \
  'key=[list of header keys to print]:keys' \
  'verbose=[print level: 0 terse 1 info 2 chatty 3 debug]:level:(0 1 2 3)' \
  '*:rsf file:_files' && ret=0

return ret
