#compdef lorri

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create a new shell.nix and .envrc'
  'watch:rebuild on shell.nix changes'
  'daemon:start the lorri daemon'
  'info:show information about the current project'
  'gc:garbage collect unused build results'
  'direnv:output direnv integration'
  'self-upgrade:upgrade lorri to the latest version'
  'internal:internal commands (not for direct use)'
)

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      init)
        _arguments \
          '(-s --shell-file)'{-s,--shell-file}'[path to shell.nix file]:shell file:_files -g "*.nix"' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      watch)
        _arguments \
          '(-s --shell-file)'{-s,--shell-file}'[path to shell.nix file]:shell file:_files -g "*.nix"' \
          '--once[exit after one build]' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      daemon)
        _arguments \
          '--extra-nix-options=[extra options for nix-build]:options' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      info)
        _arguments \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      gc)
        _arguments \
          '--all[remove all build results]' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      direnv)
        _arguments \
          '(-s --shell-file)'{-s,--shell-file}'[path to shell.nix file]:shell file:_files -g "*.nix"' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
