#compdef an-pnmtofits
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/an-pnmtofits.1 — convert PNM to FITS (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '-o+[output file (default stdout)]:file:_files' \
    '-v[verbose]' \
    '-q[quiet]' \
    '1::input PNM file (stdin if absent):_files -g "*.{pnm,ppm,pgm,pbm}"' \
    '2::output FITS file:_files' \
    && ret=0

return ret
