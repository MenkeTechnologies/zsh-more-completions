#compdef melos
# _melos-cli — Melos Dart/Flutter monorepo CLI (Invertase + community, Dart); manage multi-package Dart projects
# upstream: https://github.com/invertase/melos

_melos-cli() {
    local -a sub=(
        'analyze:run analyze in workspace'
        'bootstrap:bootstrap workspace'
        'clean:clean workspace'
        'completion:print shell completion'
        'exec:execute a command in each package'
        'format:format workspace'
        'init:init workspace'
        'list:list packages'
        'publish:publish packages'
        'run:run a custom script'
        'test:run tests in workspace'
        'version:bump versions'
        'bs:alias for bootstrap'
        'b:alias for bootstrap'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--config+[config file]:file:_files -g "melos*.yaml"' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'melos subcommand' sub ;;
        args)
            case $words[1] in
                bootstrap|bs|b) _arguments \
                    '--no-example[exclude example packages]' \
                    '--enforce-lockfile[enforce lockfile]' \
                    '--offline[offline]' \
                    '--diff[show diff]' \
                    '--skip-linking[skip linking]' \
                    '--ignore+[ignore packages]:str:' ;;
                list|ls) _arguments \
                    '--long[long format]' \
                    '-l[long format]' \
                    '--parsable[parsable]' \
                    '-p[parsable]' \
                    '--graph[graph]' \
                    '-g[graph]' \
                    '--gviz[gviz dot]' \
                    '--all[show all]' \
                    '-a[show all]' \
                    '--json[json]' \
                    '--diff+[diff against ref]:ref:' \
                    '--scope+[scope]:str:' \
                    '--ignore+[ignore]:str:' \
                    '--no-private[no private]' \
                    '--private[only private]' \
                    '--published+[only published]:bool:(true false)' \
                    '--depends-on+[depends on]:str:' \
                    '--no-depends-on+[no depends on]:str:' ;;
                exec) _arguments \
                    '--scope+[scope]:str:' \
                    '--ignore+[ignore]:str:' \
                    '-c+[concurrency]:n:' \
                    '--concurrency+[concurrency]:n:' \
                    '--no-private[no private]' \
                    '*::cmd:_command_names -e' ;;
                version) _arguments \
                    '--yes[yes]' \
                    '-y[yes]' \
                    '--no-private[no private]' \
                    '--no-git-tag-version[no git tag version]' \
                    '--git-commit-version+[git commit version]:bool:(true false)' \
                    '--no-changelog[no changelog]' \
                    '--scope+[scope]:str:' \
                    '--graduate[graduate]' \
                    '--exact[exact deps]' \
                    '--include-scope+[include scope]:str:' \
                    '--manual-version+[manual version]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_melos-cli "$@"
