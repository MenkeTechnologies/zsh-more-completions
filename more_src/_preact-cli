#compdef preact

# Zsh completion for Preact CLI

_preact-cli() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'create:create a new application'
    'build:create a production build'
    'watch:start a live-reload server for development'
    'info:print out useful information about the environment'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'preact command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        create)
          _arguments -s -S \
            '--name=[the application name]:name:' \
            '--cwd=[a directory to use instead of CWD]:directory:_files -/' \
            '--git[initialize version control using git]' \
            '--no-install[skip installing dependencies]' \
            '--license=[application license]:license:(MIT Apache-2.0 BSD-2-Clause BSD-3-Clause ISC)' \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            '1:template:(default simple netlify typescript widget)' \
            '2:dest:_files -/' \
            && ret=0
          ;;
        build)
          _arguments -s -S \
            '--src=[entry file]:source:_files -/' \
            '--dest=[output directory]:directory:_files -/' \
            '-p[production build]' \
            '--production[production build]' \
            '--no-prerender[disable prerendering]' \
            '--prerenderUrls=[prerender URLs config]:config file:_files' \
            '--clean[clear output directory before building]' \
            '--json[generate build stats]' \
            '--template=[HTML template]:template:_files -g "*.html"' \
            '--analyze[launch interactive bundle analyzer]' \
            '--brotli[compress with brotli]' \
            '-c+[custom config file]:config:_files' \
            '--config=[custom config file]:config:_files' \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            && ret=0
          ;;
        watch)
          _arguments -s -S \
            '--src=[entry file]:source:_files -/' \
            '--cwd=[working directory]:directory:_files -/' \
            '-p+[port to start a server on]:port:' \
            '--port=[port to start a server on]:port:' \
            '-H+[hostname]:hostname:_hosts' \
            '--host=[hostname]:hostname:_hosts' \
            '--https[enable HTTPS]' \
            '--sw[generate and attach a Service Worker]' \
            '--rhl[enable react-hot-loader]' \
            '--template=[custom HTML template]:template:_files -g "*.html"' \
            '-c+[custom config file]:config:_files' \
            '--config=[custom config file]:config:_files' \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            '--version[output the version]' \
            '--help[display help]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_preact-cli "$@"
