#compdef pmnsdel
# Documentation: https://man.archlinux.org/man/pmnsdel.1.en
# Delete a subtree of names from a Performance Co-Pilot PMNS

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[load an alternative PMNS from file]:pmnsfile:_files' \
  '(-D --debug)'{-D+,--debug=}'[enable diagnostic output]:debug' \
  '*:file:_files' && ret=0

return ret
