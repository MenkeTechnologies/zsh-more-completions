#compdef vgscan
# _vgscan — LVM2 vgscan scan for VGs CLI (Red Hat / LVM2 team, C); custom argparse
# upstream: https://github.com/lvmteam/lvm2

_vgscan() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--cache[refresh cache]' \
        '--ignorelockingfailure[ignore locking failure]' \
        '--mknodes[make device nodes]' \
        '--notifydbus[notify dbus]' \
        '--reportformat=+[report format]:fmt:(basic json json_std)' \
        '-d[debug]' \
        '--debug[debug]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--devices=+[devices]:list:' \
        '--devicesfile=+[devices file]:file:_files' \
        '*:arg:'
}

_vgscan "$@"
