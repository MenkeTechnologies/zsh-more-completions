  '--speculate=[speculate tokens]:n:' \
  '--dtype=[dtype]:dtype:(float16 bfloat16)' \
  '--kv-cache-dtype=[KV cache dtype]:dtype:(fp8_e4m3fn fp8_e5m2)' \
  '--trust-remote-code[trust remote code]' \
  '--max-concurrent-requests=[max concurrent requests]:n:' \
  '--max-best-of=[max best_of]:n:' \
  '--max-stop-sequences=[max stop sequences]:n:' \
  '--max-top-n-tokens=[max top_n_tokens]:n:' \
  '--max-input-tokens=[max input tokens]:n:' \
  '--max-input-length=[max input length]:n:' \
  '--max-total-tokens=[max total tokens]:n:' \
  '--waiting-served-ratio=[waiting served ratio]:ratio:' \
  '--max-batch-prefill-tokens=[max batch prefill tokens]:n:' \
  '--max-batch-total-tokens=[max batch total tokens]:n:' \
  '--max-waiting-tokens=[max waiting tokens]:n:' \
  '--max-batch-size=[max batch size]:n:' \
  '*--cuda-graphs=[CUDA graph sizes]:sizes:' \
  '--hostname=[hostname]:host:_hosts' \
  '(-p --port)'{-p,--port}'=[port]:port:' \
  '--prometheus-port=[Prometheus port]:port:' \
  '--shard-uds-path=[shard UDS path]:file:_files' \
  '--master-addr=[master address]:addr:' \
  '--master-port=[master port]:port:' \
  '--huggingface-hub-cache=[HF hub cache dir]:dir:_files -/' \
  '--weights-cache-override=[weights cache override]:dir:_files -/' \
  '--disable-custom-kernels[disable custom kernels]' \
  '--cuda-memory-fraction=[CUDA memory fraction]:f:' \
  '--rope-scaling=[rope scaling]:type:(linear dynamic)' \
  '--rope-factor=[rope factor]:f:' \
  '--json-output[JSON output]' \
  '--otlp-endpoint=[OTLP endpoint]:url:' \
  '--otlp-service-name=[OTLP service name]:name:' \
  '*--cors-allow-origin=[CORS allowed origin]:origin:' \
  '--watermark-gamma=[watermark gamma]:f:' \
  '--watermark-delta=[watermark delta]:f:' \
