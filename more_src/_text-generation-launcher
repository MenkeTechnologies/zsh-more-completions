#compdef text-generation-launcher

_arguments -s \
  '--model-id=[HF model id]:id:' \
  '--revision=[model revision]:rev:' \
  '--validation-workers=[validation workers]:n:' \
  '--sharded=[sharded]:bool:(true false)' \
  '--num-shard=[num shards]:n:' \
