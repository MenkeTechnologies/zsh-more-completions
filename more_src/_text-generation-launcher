  '--ngrok-authtoken=[ngrok auth token]:token:' \
  '--ngrok-edge=[ngrok edge]:edge:' \
  '--tokenizer-config-path=[tokenizer config]:file:_files' \
  '--disable-grammar-support[disable grammar support]' \
  '*--env=[env var]:KEY=VAL:' \
  '--max-client-batch-size=[max client batch size]:n:' \
  '*--lora-adapters=[LoRA adapters]:adapters:' \
  '--usage-stats=[usage stats]:mode:(on off no-stack)' \
  '--payload-limit=[payload limit bytes]:n:' \
  '--api-key=[API key]:key:' \
  '--enable-prefill-logprobs[enable prefill logprobs]' \
  '(-g --graceful-termination-timeout)'{-g,--graceful-termination-timeout}'=[graceful termination timeout]:s:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
