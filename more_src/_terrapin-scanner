#compdef terrapin-scanner
# Documentation: https://github.com/RUB-NDS/Terrapin-Scanner
# Reference accessed: 2026-05-21
# Verified: upstream README. Only three flags exist: --connect,
# --listen, --json. No -h/--help in upstream docs (kept for safety).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(--connect)--connect=[host:port to scan]:endpoint:' \
  '(--listen)--listen=[listen address:port]:address:' \
  '--json[JSON output]' \
  '*::args: _default'
