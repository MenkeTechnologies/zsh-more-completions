#compdef terrapin-scanner
# Documentation: https://man.archlinux.org/search?q=terrapin-scanner
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(--connect)--connect=[host:port to scan]:endpoint:' \
  '(--listen)--listen=[listen address:port]:address:' \
  '--json[JSON output]' \
  '*::args: _default'
