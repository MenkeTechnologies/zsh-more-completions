#compdef gapToLift
# Documentation: https://github.com/ucscGenomeBrowser/kent/blob/master/src/hg/utils/gapToLift/gapToLift.c
# create lift file from gap table(s)

local ret=1

_arguments -s -S \
  '-chr=[work only on given chrom]:chrom:' \
  '-minGap=[examine gaps only >= than M]:m:' \
  '-insane[do not perform coordinate sanity checks on gaps]' \
  '-bedFile=[output segments to bed file]:bed:_files' \
  '-allowBridged[consider any type of gap not just non-bridged gaps]' \
  '-verbose=[N > 1 see more information about procedure]:n:' \
  '*:db liftFile.lft:_files' && ret=0

return ret
