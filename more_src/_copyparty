#compdef copyparty

# 9001/copyparty — core server flags from copyparty/__main__.py (argparse; not every --help-* topic).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '*'{-c+}'[add config file]:config:_files' \
  '-nc+[max concurrent clients]:count:' \
  '*'{-a+}'[account USER:PASS]:account:' \
  '*'{-v+}'[volume SRC:DST:flags]:volume:' \
  '*'--grp='[group NAME:u1,u2]:group:' \
  --usernames'[require username+password for login]' \
  --chdir='[cwd before volume mapping]:directory:_files -/' \
  '-ed[enable ?dots / dotfile listings]' \
  --urlform='[url-form POST mode]:mode:' \
  --wintitle='[terminal title template]:text:' \
  --name='[server display name]:text:' \
  --name-url='[hyperlink for server name]:url:' \
  --site='[public URL for links]:url:' \
  --env-expand='[expand env in config 0/1/2]:level:(0 1 2)' \
  '*'--mime='[map EXT=MIME]:map:' \
  --mimes'[print default mime map and exit]' \
  --rmagic'[slower accurate mime detection]' \
  '-j+[parallel CPUs for I/O (0=all)]:cores:' \
  --vc-url='[vulnerability check URL]:url:' \
  --vc-age='[hours between vuln checks]:hours:' \
  --vc-exit'[exit if version vulnerable]' \
  --license'[show licenses and exit]' \
  --version'[show versions and exit]' \
  --versionb'[show version and exit]' \
  '-i+[listen addresses or unix sockets]:bind list:' \
  '-p+[TCP ports]:ports:' \
  --list-nics'[list network adapters]' \
  --list-ips'[list LAN IPs]' \
  '-q[quiet stdout]' \
  '-lo=[log file path]:log:_files' \
  --qr'[print QR on start]' \
  --qrs'[QR URL uses https]' \
  --qrp='[QR padding cells]:cells:' \
  --dotpart'[dot-prefix partial uploads]' \
  --plain-ip'[plain-text IP suffix on name collisions]' \
  '(- *)'{-h,--help}'[help]' \
  '*: :_default' && ret=0

return ret
