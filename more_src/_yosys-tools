#compdef yosys-tools yosys-config yosys-abc yosys-smtbmc yosys-witness
# _yosys-tools — Claire Wolf YosysHQ Yosys tool-suite CLI dispatching to yosys-config yosys-abc yosys-smtbmc yosys-witness sby for Verilog synthesis ABC technology mapping formal verification proofs (yosyshq team, C++); getopt
# upstream: https://github.com/YosysHQ/yosys

_yosys-tools() {
    local -a sub=(
        'config:show Yosys configuration'
        'abc:invoke embedded ABC for technology mapping'
        'smtbmc:run SMT-based bounded model checking'
        'witness:explore SMT witness'
        'sby:run SymbiYosys flow'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yosys-tools subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments \
                    '--prefix[show install prefix]' \
                    '--datdir[show data dir]' \
                    '--exec[exec command]' \
                    '--cxx[show C++ compiler]' \
                    '--cxxflags[show CXXFLAGS]' \
                    '--ldflags[show LDFLAGS]' \
                    '--ldlibs[show LDLIBS]' \
                    '--objdir[show objdir]' \
                    '--build[build module]' ;;
                abc) _arguments \
                    '-c+[script]:str:' \
                    '-f+[script file]:file:_files -g "*.scr"' \
                    '-o+[output blif]:file:_files -g "*.blif *.aig"' ;;
                smtbmc) _arguments \
                    '--no-progress[no progress]' \
                    '--unroll[unroll]' \
                    '--noinit[no init]' \
                    '-t+[timesteps]:n:' \
                    '*:smt2 file:_files -g "*.smt2 *.smt"' ;;
                sby) _arguments \
                    '-f[force]' \
                    '-d+[dir]:dir:_files -/' \
                    '*:sby task file:_files -g "*.sby"' ;;
            esac
            ;;
    esac
}

_yosys-tools "$@"
