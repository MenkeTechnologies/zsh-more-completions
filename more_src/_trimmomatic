#compdef trimmomatic
# Documentation: https://man.archlinux.org/search?q=trimmomatic
# Reference accessed: 2026-05-16

# Trimmomatic: flexible read trimming for Illumina NGS data
local curcontext="$curcontext" ret=1
_arguments -C \
  '-version[show version]' \
  '1: :(SE PE)' \
  '-threads[number of threads]:n:' \
  '-phred33[Phred 33 quality]' \
  '-phred64[Phred 64 quality]' \
  '-trimlog[write trim log]:file:_files' \
  '-summary[write summary statistics]:file:_files' \
  '-quiet[suppress progress output]' \
  '-validatePairs[verify R1/R2 pairing]' \
  '-basein[base name input for PE]:file:_files' \
  '-baseout[base name output for PE]:file:_files' \
  '*::Trimmomatic step args (ILLUMINACLIP MAXINFO LEADING TRAILING SLIDINGWINDOW MINLEN HEADCROP CROP TOPHRED33 TOPHRED64 AVGQUAL):' && ret=0
return ret
