#compdef samtools-reset
# Documentation: http://www.htslib.org/doc/samtools-reset.html
# samtools reset: Reverts aligner changes in reads

local ret=1

_arguments -s -S \
  '(-o)'-o'[Output file to which reset data is to be written. If not given, standa]:FILE:_files' \
  '(-x)'-x'[Read tag(s) to exclude from output (repeatable) \[null\]. This can be a]:STR--remove-tagSTR: ' \
  '(--keep-tag)'--keep-tag'[This keeps only tags listed in STR and is directly equivalent to --rem]:STR: ' \
  '(--reject-PG)'--reject-PG'[The PG line which has the ID matching pgid and all subsequent PG lines]:pgid: ' \
  '(--no-RG)'--no-RG'[RG lines in input will be discarded with this option. By default, RG l]' \
  '(--no-PG)'--no-PG'[Do not add a @PG line to the header of the output file listing the res]' \
  '(--dupflag)'--dupflag'[Keep the duplicate flag as it is. This option is absent by default and]' \
  '(--threads)'--threads'[This gives the number of worker threads to be used.]:N: ' \
  '(-O --output-fmt)'{-O,--output-fmt}'[Sets the format of the output file and any associated format-specific]:FMT: ' \
  '*:file:_files' && ret=0

return ret
