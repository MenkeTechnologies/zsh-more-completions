#compdef papd
# _papd — Netatalk papd (AppleTalk Printer Access Protocol daemon exposing CUPS / LPR queues to AppleTalk clients; -d debug, -f config file (papd.conf), -P pidfile, -p queue, -L printer name to advertise, -F foreground, -V version, -n no-banner-page)
# upstream: https://github.com/Netatalk/netatalk
# Flags from Netatalk/netatalk etc/papd/main.c on tip.

_papd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d+[debug level]:level:' \
        '-f+[config file]:file:_files' \
        '-P+[pidfile]:file:_files' \
        '-p+[queue]:queue:' \
        '-L+[advertised printer name]:name:' \
        '-F[foreground]' \
        '-n[no banner page]'
}

_papd "$@"
