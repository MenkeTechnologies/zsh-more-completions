# Source:  https://github.com/emitter-io/emitter
# CLI:     main.go (uses github.com/jawher/mow.cli)
# Library: jawher/mow.cli
#          ("A versatile library for building command line applications in Go")
# License: AGPL-3.0-or-later
# Status:  Stable production deployments — 4,004+ stars, used in IoT
#          infrastructure at multiple companies including Misakai itself.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 25 LIBRARIES
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 25TH Go CLI library variant.  Go climbs from 24 to 25 documented libraries
# (mow.cli via emitter).  New leaderboard: Go=25 (SOLO LEAD), Rust=24,
# TypeScript-Node=24.  Taxonomy now spans 209 cross-language CLI library
# variants across 50 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS mow.cli AND WHY IS IT A DISTINCT 25TH GO CLI LIBRARY VARIANT?
#
# mow.cli (https://github.com/jawher/mow.cli, 884+ stars) is Jawher Moussa's
# command-line library for Go.  Its defining feature is the **SPEC STRING**
# pattern — a SHELL-USAGE-LIKE GRAMMAR for combining options, positionals,
# and subcommands declared as a runtime string assigned to `app.Spec`.
# The library then VALIDATES argv against this grammar at runtime, providing
# both PARSING and USAGE VALIDATION from the same declaration.
#
# Compare to docopt (R413 in Rust): docopt parses a human-readable help
# block and DERIVES the spec.  mow.cli flips this: you write the spec
# directly in shell-usage grammar, and the human-readable help is GENERATED
# from the spec.  This is the FIRST documented Go CLI library where the
# spec is a STRING grammar evaluated at runtime, distinct from:
#
#   * commander.js (TS) — fluent builder method chain
#   * yargs (TS)        — chainable builder with implicit spec
#   * cobra (Go)        — subcommand tree builder objects
#   * kong (Go, R465)   — struct-tag declaration
#   * clap-derive (Rust, R275) — derive-macro struct declaration
#   * stricli (TS, R466) — data-structure declaration
#   * lapp (Rust, R464) — usage-text-as-spec parser
#   * docopt.rs (Rust, R413) — POSIX usage-block parser
#
# mow.cli's spec grammar is most similar to docopt but with these distinctions:
#
#   1. SPEC IS A SEPARATE STRING from the help text — `app.Spec = "..."` is
#      a structured grammar string, not human-readable help.  Help is
#      auto-generated from option declarations + spec.
#
#   2. GRAMMAR ELEMENTS:
#        -x           Short option (boolean by default)
#        --long       Long option
#        -x=<val>     Option with value
#        <ARG>        Positional argument
#        [...]        Optional element
#        (... | ...)  Choice (exclusive or)
#        ...          Repetition (one or more)
#        OPT OPT2     Sequence (both required, in order)
#
#   3. RUNTIME VALIDATION — the spec is parsed at runtime via mow.cli's
#      own internal grammar parser; invalid specs panic at app construction
#      time.
#
#   4. NESTED SUBCOMMANDS — each subcommand has its OWN spec, allowing
#      different argument grammars per subcommand:
#        app.Command("license", "...", func(cmd *cli.Cmd) {
#            cmd.Command("new", "...", license.New)
#        })
#
#   5. TYPED OPTION ACCESSORS — `app.StringOpt`, `app.BoolOpt`, `app.IntOpt`,
#      `app.StringsOpt`, `app.IntsOpt` return TYPED POINTERS that are
#      dereferenced after `app.Run()`.  This gives Go-native type safety
#      without struct tags or reflection.
#
#   6. MULTIPLE NAMES PER OPTION — `app.StringOpt("c config", ...)` declares
#      BOTH `-c` short form AND `--config` long form in a single space-
#      separated string.  No separate alias registration.
#
# THE mow.cli API SURFACE (verbatim from emitter usage)
#
#   cli.App(name, description) *Cli
#       — construct top-level CLI application
#
#   app.Spec = "..." string
#       — declare argument grammar spec
#
#   app.StringOpt(names, default, desc) *string
#   app.BoolOpt(names, default, desc) *bool
#   app.IntOpt(names, default, desc) *int
#   app.StringsOpt(names, default, desc) *[]string
#       — typed option declarations
#
#   app.StringArg(name, default, desc) *string
#   app.IntArg(name, default, desc) *int
#   app.StringsArg(name, default, desc) *[]string
#       — typed positional argument declarations
#
#   app.Command(name, desc, init func(*Cmd)) — register subcommand
#
#   app.Action func() — default handler when no subcommand
#
#   app.Run(args []string) — execute against argv
#
#   cmd.Spec = "..." — per-subcommand spec
#   cmd.Action func() — per-subcommand handler
#
# CONTRAST WITH OTHER GO CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * flag (stdlib)               — single-pass argv loop, no subcommands
#   * spf13/cobra                 — subcommand tree builder
#   * spf13/pflag                 — flag stdlib with POSIX --long
#   * urfave/cli (v1, v2, v3)     — declarative struct list + actions
#   * alecthomas/kingpin          — fluent builder
#   * alecthomas/kong (R465)      — struct-tag declarative
#   * jessevdk/go-flags           — struct-tag like Rust clap
#   * mitchellh/cli               — Hashicorp interface dispatch
#   * akamensky/argparse          — Python argparse clone
#   * google/subcommands          — flag-tree wrapper
#   * tj/docopt.go                — docopt for Go
#   * pborman/getopt              — getopt(3) port
#   * muesli/coral                — cobra fork
#   * c-bata/go-prompt (R451)     — interactive prompt
#   * chzyer/readline (R455)      — pure Go readline
#   * jawher/mow.cli (THIS)       — SPEC-string grammar, docopt-influenced
#                                   but runtime-defined
#
# mow.cli's spec-string approach is closest to docopt's usage-block but
# is JUSTIFIED differently: docopt parses help text into a spec; mow.cli
# treats the spec as primary and generates help.  This separation means
# mow.cli's specs are more compact and don't require maintaining a
# human-readable help block as the canonical source of truth.
#
# REAL-WORLD mow.cli USERS:
#
#   * emitter-io/emitter — distributed pub/sub broker (THIS completion)
#   * gocolly/colly — web scraping framework (uses mow.cli for cmd/colly)
#   * sgreben/yeetgif — animated gif manipulator
#   * suutaku/sshx — P2P SSH via WebRTC
#   * InjectiveLabs/etherman — Ethereum bridge daemon
#   * WAY29/pocV — vulnerability PoC framework
#   * seantis/roots — Roots CLI
#   * thanos-io/thanos (build tooling)
#
# -----------------------------------------------------------------------------
# EMITTER'S CLI SURFACE (verbatim from main.go)
# -----------------------------------------------------------------------------
#
# USAGE:
#   emitter [-c=<configuration path>] [<subcommand> [<subcommand-args>]]
#
# Top-level (default action — run the broker):
#   -c, --config <path>     Specifies configuration file path (default: emitter.conf)
#
# Subcommands:
#   version                 Prints the version of the executable
#   load                    Runs the load testing client for emitter
#   license                 Manipulates licenses and secret keys
#     new                   Generates a new license and secret key pair
#   keygen                  Generates a new key for a channel
#
# Spec (literal from main.go):
#   "[ -c=<configuration path> ] "  (top-level only; subcommands have their own)
#
# When no config file is found, emitter logs an error and INVOKES ITSELF
# with `license new` to generate a fresh license.  This is a runtime
# self-reentry trick that uses mow.cli's `app.Run([]string{...})` to
# dispatch to the license subcommand without forking a new process.
#
# Environment variables:
#   EMITTER_LICENSE   — license string (overrides config file)
#   (mow.cli does not auto-bind these; emitter reads them manually)
#
# =============================================================================

_emitter() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands license_subs

    subcommands=(
        'version:print version of the executable'
        'load:run load testing client'
        'license:manipulate licenses and secret keys'
        'keygen:generate a new key for a channel'
    )

    license_subs=(
        'new:generate a new license and secret key pair'
    )

    _arguments -C \
        '(-c --config)'{-c,--config}'[configuration file path]:config:_files' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t commands 'emitter command' subcommands && ret=0
            ;;
        (args)
            case $line[1] in
                (license)
                    _describe -t license_subs 'license subcommand' license_subs && ret=0
                    ;;
                (*)
                    ;;
            esac
            ;;
    esac

    return ret
}

_emitter "$@"
