#compdef dragonplayer dragon
# Documentation: https://invent.kde.org/multimedia/dragon
# Reference accessed: 2026-05-16
# Verified: upstream src/main.cpp only inherits KAboutData::setupCommandLine
# (no custom QCommandLineOption entries).

# Dragon Player: simple KDE video player
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '*:file/URL:_files' && ret=0
return ret
