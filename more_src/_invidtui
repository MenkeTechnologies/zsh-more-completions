#compdef invidtui
# Documentation: https://github.com/darkhz/invidtui/blob/master/cmd/flags.go
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--token=[invidious authorization token (use with --force-instance)]:token:' \
  '--mpv-path=[mpv executable path]:cmd:_command_names -e' \
  '--ytdl-path=[youtube-dl or yt-dlp executable path]:cmd:_command_names -e' \
  '--ffmpeg-path=[ffmpeg executable path]:cmd:_command_names -e' \
  '--download-dir=[directory to download media into]:dir:_files -/' \
  '--search-video=[search for a video]:term:' \
  '--search-playlist=[search for a playlist]:term:' \
  '--search-channel=[search for a channel]:term:' \
  '--play-audio=[video/playlist URL to play audio from]:url:' \
  '--play-video=[video/playlist URL to play video from]:url:' \
  '--video-res=[default video resolution]:res:(144p 240p 360p 480p 720p 1080p 1440p 2160p)' \
  '--num-retries=[retries for connecting to the socket]:n:' \
  '--force-instance=[force load media from this Invidious instance]:url:' \
  '--theme=[theme file to apply on startup]:file:_files' \
  '--close-instances[close all currently running instances]' \
  '--show-instances[show a list of instances]' \
  '--token-link[display a link to the token generation page]' \
  '--generate[generate configuration]' \
  '*: :' && ret=0

return ret
