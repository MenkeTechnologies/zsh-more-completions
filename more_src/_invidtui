#compdef invidtui

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config-dir=[config directory]:dir:_files -/' \
  '--mpv-path=[mpv binary path]:cmd:_command_names' \
  '--ytdlp-path=[yt-dlp binary path]:cmd:_command_names' \
  '--ffmpeg-path=[ffmpeg binary path]:cmd:_command_names' \
  '--token=[invidious token]:tok:' \
  '--instance=[invidious instance]:url:' \
  '--force-instance=[force load from instance]:url:' \
  '--use-current-instance[reuse current invidious instance]' \
  '--num-retries=[socket retries]:n:' \
  '--video-res=[default video resolution]:res:(144p 240p 360p 480p 720p 1080p 1440p 2160p best)' \
  '--play-audio=[play audio of video id]:id:' \
  '--play-video=[play video of video id]:id:' \
  '--search-channel=[search channel]:term:' \
  '--search-playlist=[search playlist]:term:' \
  '--search-video=[search video]:term:' \
  '--close-instances[close all running instances]' \
  '--no-config[skip config]' \
  '--no-history[skip history]' \
  '--show-instances[show available instances]' \
  '--token-link=[generate token link]:url:' \
  '--mark-channel-watched=[mark watched]:url:' \
  '*: :' && ret=0

return ret
