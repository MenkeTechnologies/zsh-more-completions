#compdef lacy
# Documentation: https://github.com/lacymorrow/lacy
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lacy (Lacy Shell CLI)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'setup:interactive settings (tool, mode, config)'
  'status:show installation status'
  'doctor:diagnose common issues'
  'update:pull latest changes'
  'config:open or manage config'
  'uninstall:remove Lacy Shell'
  'help:show all commands'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'lacy command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (config)
        _arguments '1:config sub:(edit)' && ret=0
        ;;
    esac
    ;;
esac

return ret
