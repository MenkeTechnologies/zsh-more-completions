#compdef swcx swc-cli swc
# Documentation: https://man.archlinux.org/search?q=swcx
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'compile:run SWC transformer on input files'
  'plugin:utilities for creating and building SWC plugins'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --filename)'{-f+,--filename=}'[filename when reading from stdin]:filename:' \
  '--config-file=[path to .swcrc]:file:_files -g "*.swcrc"' \
  '--env-name=[environment name for configs/plugins]:env:' \
  '--no-swcrc[disable .swcrc lookup]' \
  '*--ignore=[glob to exclude]:glob:' \
  '*--only=[glob to compile exclusively]:glob:' \
  '(-w --watch)'{-w,--watch}'[auto-recompile on file changes]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-s --source-maps)'{-s+,--source-maps=}'[generate source maps]:type:(true false inline both)' \
  '--source-map-target=[source map output filename]:file:_files' \
  '--source-file-name=[source map sources[0]]:name:' \
  '--source-root=[source root]:path:_files -/' \
  '(-o --out-file)'{-o+,--out-file=}'[compile to single output file]:file:_files' \
  '(-d --out-dir)'{-d+,--out-dir=}'[output directory]:dir:_files -/' \
  '(-D --copy-files)'{-D,--copy-files}'[copy non-compilable files]' \
  '--include-dotfiles[include dotfiles]' \
  '*'{-C+,--config=}'[override config value]:k=v:' \
  '--sync[invoke synchronously]' \
  '--log-watch-compilation[log successful watch compilations]' \
  '--extensions=[file extensions to process]:extensions:' \
  '--strip-leading-paths[strip leading directories from output paths]' \
  '--out-file-extension=[output file extension]:ext:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _alternative \
      'cmds:command:_describe -t cmds "command" commands' \
      'files:file:_files'
    ret=0 ;;
  (args)
    case $line[1] in
      (plugin)
        _arguments '*::sub:(new build pack publish)' && ret=0 ;;
    esac ;;
esac

return ret
