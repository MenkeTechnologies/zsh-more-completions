#compdef otbcli_LineSegmentDetection
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_LineSegmentDetection.html
# Orfeo ToolBox: detect line segments in an image as vector data

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image on which lines are detected]:image:_files' \
  '-out[output detected line segments]:output:_files' \
  '-elev.dem[directory containing DEM files]:dir:_files -/' \
  '-elev.geoid[geoid grid file]:file:_files' \
  '-elev.default[default height above ellipsoid]:value:' \
  '-norescale[skip rescaling amplitude to 0-255]:bool:(true false)' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
