#compdef ods-enforcer ods-enforcerd
# Documentation: https://man.archlinux.org/search?q=ods-enforcer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'time-leap:advance enforcer time'
  'enforce:run enforce task now'
  'queue:show task queue'
  'flush:flush all tasks'
  'cancel:cancel a task'
  'running:show running tasks'
  'start:start enforcer'
  'stop:stop enforcer'
  'reload:reload enforcer'
  'policy-list:list policies'
  'policy-export:export policies'
  'policy-import:import policies'
  'policy-purge:purge policies'
  'zone-add:add a zone'
  'zone-del:delete a zone'
  'zone-list:list zones'
  'zone-set-policy:set zone policy'
  'key-list:list keys'
  'key-rollover:rollover a key'
  'key-purge:purge keys'
  'key-export:export keys'
  'key-import:import keys'
  'key-generate:generate keys'
  'key-ds-seen:mark DS as seen'
  'key-ds-submit:mark DS submitted'
  'key-ds-retract:retract DS'
  'key-ds-gone:mark DS as gone'
  'backup-prepare:prepare HSM backup'
  'backup-commit:commit HSM backup'
  'backup-rollback:rollback HSM backup'
  'backup-list:list backups'
  'repository-list:list HSM repositories'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ods-enforcer command' commands && ret=0 ;;
esac

return ret
