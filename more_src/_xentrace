#compdef xentrace
# Documentation: https://man.archlinux.org/search?q=xentrace
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --cpu-mask)'{-c,--cpu-mask}'+[CPU mask hex]:mask:' \
  '(-e --evt-mask)'{-e,--evt-mask}'+[event mask hex]:mask:' \
  '(-s --poll-sleep)'{-s,--poll-sleep}'+[poll sleep ms]:ms:' \
  '(-S --trace-buf-size)'{-S,--trace-buf-size}'+[trace buffer pages]:pages:' \
  '(-T --time-interval)'{-T,--time-interval}'+[time interval seconds]:sec:' \
  '(-D --discard-buffers)'{-D,--discard-buffers}'[discard buffers without writing]' \
  '(-x --dont-disable)'{-x,--dont-disable}'[do not disable tracing on exit]' \
  '(-r --reset-buffer-size)'{-r,--reset-buffer-size}'+[reset buffer size to N pages]:pages:' \
  '(-M --memory-buffer)'{-M,--memory-buffer}'+[memory buffer size pages]:pages:' \
  '(-?)*:trace_file:_files' && ret=0

return ret
