#compdef ftdelhdu
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftdelhdu.html
# Delete a specified HDU from a FITS file

local ret=1

_arguments -s -S \
  'infile=[input FITS file with HDU extension]:infile:_files' \
  'outfile=[output file, or none/blank for in-place]:outfile:_files' \
  'confirm=[require confirmation before deletion]:confirm:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  '*:file:_files' && ret=0

return ret
