#compdef woke

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '--disable-default-rules[disable default rules]' \
  '-e+[exit code when violations found]:code' \
  '--exit-1-on-failure[exit with code 1 on failures]' \
  '--no-ignore[do not respect .gitignore/.wokeignore]' \
  '-o+[output format]:format:(simple github-actions json sonarqube)' \
  '--output=[output format]:format:(simple github-actions json sonarqube)' \
  '--stdin[read from stdin]' \
  '*:file or directory:_files' && ret=0

return ret
