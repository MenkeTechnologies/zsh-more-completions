#compdef zipkin
# Documentation: https://man.archlinux.org/search?q=zipkin
# Reference accessed: 2026-05-16

# zipkin: standalone distributed tracing system (Java)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--server.port=[HTTP port]:port:' \
  '--zipkin.collector.http.enabled=[enable HTTP collector]:bool:(true false)' \
  '--zipkin.collector.scribe.enabled=[enable scribe collector]:bool:(true false)' \
  '--zipkin.collector.kafka.bootstrap-servers=[Kafka bootstrap]:servers:' \
  '--zipkin.collector.rabbitmq.addresses=[RabbitMQ addresses]:addr:' \
  '--zipkin.storage.type=[storage type]:type:(mem mysql cassandra3 elasticsearch)' \
  '--zipkin.self-tracing.enabled=[enable self-tracing]:bool:(true false)' \
  '--zipkin.ui.basepath=[UI base path]:path:' \
  '--logging.level.zipkin2=[zipkin log level]:level:(TRACE DEBUG INFO WARN ERROR)' \
  '*::zipkin args:_files' && ret=0
return ret
