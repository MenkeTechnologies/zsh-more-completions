#compdef rsgiscopybandnames
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgiscopybandnames RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --refimg)'{-r,--refimg}'[Input reference image]:value:_files' \
  '(-o --outimg)'{-o,--outimg}'[Output image.]:value:_files' \
  '*:file:_files' && ret=0

return ret
