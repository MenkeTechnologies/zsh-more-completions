#compdef pmlogger_rewrite
# _pmlogger_rewrite — Performance Co-Pilot pmlogger_rewrite (rewrite-in-place utility for PCP archives applying a pmrewrite(1) config to update metric names, instances or units across one or more archives; -c config file, -V verbose, -q quiet, -N show would-do only, -i in-place; positional archive list)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmlogger/pmlogger_rewrite on tip.

_pmlogger_rewrite() {
    _arguments \
        '-c+[config file]:file:_files' \
        '-V[verbose]' \
        '-q[quiet]' \
        '-N[show would-do only]' \
        '-i[in-place rewrite]' \
        '-r[recursive]' \
        '*:archive:_files'
}

_pmlogger_rewrite "$@"
