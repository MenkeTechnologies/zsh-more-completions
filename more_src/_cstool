#compdef cstool
# _cstool — Capstone disassembler driver (capstone-engine/capstone)
# upstream: https://github.com/capstone-engine/capstone
# Flags from cstool/cstool.c (getopt).

_cstool() {
    local -a archs
    archs=(
        x16 x32 x64 x16att x32att x64att
        arm armbe thumb thumbbe cortexm
        aarch64 arm64 aarch64be arm64be
        mips mipsbe mips64 mips64be mips32R6
        ppc32 ppc32be ppc64 ppc64be ppc32qpx ppc64qpx
        sparc sparcv9 systemz sysz s390x
        xcore m68k m68k040 mos65xx tms320c64x m680x m6800 m6801 m6805 m6808 m6809 m6811 cpu12 hd6301 hd6309 hcs08
        evm wasm bpf cbpf ebpf riscv32 riscv64
        sh4 sh4be sh4a sh4abe sh2 sh2be sh2a sh2abe dh tricore alpha
    )
    local -a args
    args=(
        '(- *)-h[show help]'
        '(- *)-v[show version + build]'
        '-s[skip undecodable bytes]'
        '-u[treat operands as unsigned]'
        '-d[print detail info for each instruction]'
        "1:arch+mode:($archs)"
        '2:hex bytes:'
        '3:start address (hex):'
    )
    _arguments -s $args
}

_cstool "$@"
