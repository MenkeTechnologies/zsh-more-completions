#compdef map2gif
# Documentation: https://healpix.sourceforge.io/html/fac_map2gif.htm
# HEALPix: convert a FITS HEALPix map to a GIF image

local ret=1

_arguments -s -S \
  '-hlp[print help information]' \
  '-inp[input HEALPix sky map]:FITS file:_files' \
  '-out[output GIF image]:GIF file:_files' \
  '-add[real offset added to signal]:offset' \
  '-mul[real multiplier applied after offset]:factor' \
  '-min[minimum value for plotted signal]:minval' \
  '-max[maximum value for plotted signal]:maxval' \
  '-sig[signal column (1=I 2=Q 3=U)]:signal' \
  '-col[color table number (1-5)]:table' \
  '-xsz[image width in pixels]:xsize' \
  '-pro[projection type]:projection:(MOL GNO)' \
  '-res[resolution in arcmin (gnomonic only)]:reso' \
  '-lon[central longitude in degrees]:lon0' \
  '-lat[central latitude in degrees]:lat0' \
  '-ttl[plot title string]:title' \
  '-bar[display a color bar]' \
  '-log[apply logarithmic scaling]' \
  '-ash[apply hyperbolic arc sine transform]' \
  '*:FITS file:_files' && ret=0

return ret
