#compdef cosmoranlib
# Documentation: https://github.com/jart/cosmopolitan/blob/master/tool/cosmocc/bin/cosmoranlib
# Reference accessed: 2026-05-27
# Verified: upstream tool/cosmocc/bin/cosmoranlib shell script
# (literal contents: `exec x86_64-linux-cosmo-ranlib "$@"`)

# Zsh completion for cosmoranlib.
# Two-line shell wrapper that exec's x86_64-linux-cosmo-ranlib with the
# caller's argv unchanged. Accepts the standard GNU binutils ranlib
# flags.

local arguments

arguments=(
  '(-D)-D[use zero for timestamps and uids/gids (default)]'
  '(-U)-U[use actual timestamps and uids/gids]'
  '(-t)-t[update the archive timestamp]'
  '(-h --help)'{-h,--help}'[display help and exit]'
  '(-v -V --version)'{-v,-V,--version}'[print version information]'
  '--plugin=[load the named plugin]:plugin:_files'
  '*:archive:_files -g "*.a(-.)"'
)

_arguments -s $arguments
