#compdef bbot
# _bbot — BBOT recursive recon framework (Black Lantern Security, Python); modular OSINT/subdomain/web/secrets scanner
# upstream: https://github.com/blacklanternsecurity/bbot

_bbot() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(--version)--version[show version]' \
        '(-t --targets)'{-t,--targets}'+[targets]:targets:' \
        '(-w --whitelist)'{-w,--whitelist}'+[whitelist targets]:targets:' \
        '(-b --blacklist)'{-b,--blacklist}'+[blacklist targets]:targets:' \
        '(-m --modules)'{-m,--modules}'+[modules]:modules:' \
        '(-l --list-modules)'{-l,--list-modules}'[list modules]' \
        '(-em --exclude-modules)'{-em,--exclude-modules}'+[exclude modules]:modules:' \
        '(-f --flags)'{-f,--flags}'+[flags]:flags:' \
        '(-rf --require-flags)'{-rf,--require-flags}'+[require flags]:flags:' \
        '(-ef --exclude-flags)'{-ef,--exclude-flags}'+[exclude flags]:flags:' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files' \
        '(-y --yes)'{-y,--yes}'[skip confirmation]' \
        '(-d --debug)'{-d,--debug}'[debug]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-o --output-dir)'{-o,--output-dir}'+[output dir]:dir:_files -/' \
        '-om+[output modules]:modules:' \
        '--output-modules+[output modules]:modules:' \
        '-os+[output silent]:bool:' \
        '--strict-scope[strict scope]' \
        '--ignore-failed-deps[ignore failed deps]' \
        '--install-all-deps[install all deps]' \
        '--list-flags[list flags]' \
        '--list-module-options[list module options]' \
        '--retry-deps[retry deps]' \
        '--silent[silent]' \
        '-s[silent]' \
        '--list-presets[list presets]' \
        '-p+[preset]:preset:' \
        '--preset+[preset]:preset:' \
        '-mp+[multi presets]:presets:' \
        '*:target:'
}

_bbot "$@"
