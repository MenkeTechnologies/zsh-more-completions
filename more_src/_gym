#compdef gym
# _gym — fastlane gym Xcode build/archive wrapper (fastlane, Ruby); commander
# upstream: https://github.com/fastlane/fastlane

_gym() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--workspace=+[workspace]:file:_files -g "*.xcworkspace"' \
        '-w+[workspace]:file:_files -g "*.xcworkspace"' \
        '--project=+[project]:file:_files -g "*.xcodeproj"' \
        '-p+[project]:file:_files -g "*.xcodeproj"' \
        '--scheme=+[scheme]:str:' \
        '-s+[scheme]:str:' \
        '--clean[clean before building]' \
        '-c[clean before building]' \
        '--output-directory=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--output-name=+[output name]:str:' \
        '-n+[output name]:str:' \
        '--configuration=+[configuration]:str:' \
        '--silent[silent]' \
        '-a[silent]' \
        '--codesigning-identity=+[codesigning identity]:str:' \
        '-i+[codesigning identity]:str:' \
        '--skip-package-ipa[skip package ipa]' \
        '--skip-package-pkg[skip package pkg]' \
        '--skip-build-archive[skip build archive]' \
        '--skip-archive[skip archive]' \
        '--skip-codesigning[skip codesigning]' \
        '--include-symbols=+[include symbols]:b:(true false)' \
        '--include-bitcode=+[include bitcode]:b:(true false)' \
        '--export-method=+[export method]:m:(app-store ad-hoc package enterprise development developer-id mac-application)' \
        '--export-options=+[export options plist or hash]:str:' \
        '--export-xcargs=+[export xcargs]:str:' \
        '--build-path=+[build path]:dir:_files -/' \
        '--archive-path=+[archive path]:dir:_files -/' \
        '--installer-cert-name=+[installer cert name]:str:' \
        '--analyze-build-time=+[analyze build time]:b:(true false)' \
        '--xcconfig=+[xcconfig]:file:_files -g "*.xcconfig"' \
        '--suppress-xcode-output=+[suppress xcode output]:b:(true false)' \
        '--xcargs=+[xcargs]:str:' \
        '--destination=+[destination]:str:' \
        '--toolchain=+[toolchain]:str:' \
        '--disable-xcpretty=+[disable xcpretty]:b:(true false)' \
        '--xcpretty-test-format=+[xcpretty test format]:b:(true false)' \
        '--xcpretty-formatter=+[xcpretty formatter]:str:' \
        '--xcpretty-report-junit=+[junit report path]:file:_files' \
        '--xcpretty-report-html=+[html report path]:file:_files' \
        '--xcpretty-report-json=+[json report path]:file:_files' \
        '--xcpretty-utf=+[utf]:b:(true false)' \
        '--result-bundle=+[result bundle]:b:(true false)' \
        '--build-timing-summary=+[build timing summary]:b:(true false)' \
        '--export-team-id=+[export team id]:str:' \
        '--use-system-scm=+[use system scm]:b:(true false)' \
        '--skip-profile-detection=+[skip profile detection]:b:(true false)' \
        '*:arg:'
}

_gym "$@"
