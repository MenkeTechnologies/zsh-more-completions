#compdef mkpsfmap
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/mkpsfmap.html
# Look up the radius of the PSF for each pixel in an image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input image]:file:_files' \
  'outfile=[output image]:file:_files' \
  'energy=[energy of the PSF to lookup in keV]:energy:' \
  'spectrum=[spectral weights file (two column)]:file:_files' \
  'ecf=[encircled counts fraction value between 0 and 1]:ecf:' \
  'psffile=[PSF calibration file]:file:_files' \
  'units=[output units]:units:(logical physical arcsec)' \
  'geompar=[Pixlib geometry file name]:file:_files' \
  'clobber=[overwrite existing output dataset]:clobber:(yes no)' && ret=0

return ret
