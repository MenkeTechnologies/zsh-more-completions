#compdef llama-tokenize
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/tools/tokenize/tokenize.cpp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# llama.cpp tokenization utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-m[model file]:file:_files -g "*.gguf"' \
  '--model=[model file]:file:_files -g "*.gguf"' \
  '-f[file to tokenize]:file:_files' \
  '--file=[file to tokenize]:file:_files' \
  '-p[prompt]:text:' \
  '--prompt=[prompt]:text:' \
  '-bos[prepend BOS token]' \
  '-eos[append EOS token]' \
  '--ids[print token ids only]' \
  '--decoded[show decoded form too]' \
  '--no-bom[no BOM]' \
  '--show-token-count[show count]' \
  '*::llama-tokenize args:_files' && ret=0
return ret
