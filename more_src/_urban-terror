#compdef urban-terror urbanterror
# Documentation: (no Debian/Ubuntu manpage)
# Reference accessed: 2026-05-16
# Verified: no upstream manpage retrievable. Urban Terror runs on the ioquake3
# engine; the universal id Tech 3 convention is +cmd cbuf parsing (Cbuf_AddText
# of '+'-prefixed args). Listed +commands are engine convention.

# Urban Terror: tactical FPS on ioquake3
local curcontext="$curcontext" ret=1
_arguments -C \
  '+set[set cvar before init]:cvar:: :' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+devmap[load map in dev mode]:map:' \
  '+demo[play demo at startup]:name:' \
  '+connect[connect to server at startup]:host:_hosts' \
  '*::extra args:_files' && ret=0
return ret
