#compdef baverage
# Documentation: https://www.ccp4.ac.uk/html/baverage.html
# CCP4: calculate average B factors and RMS deviations per residue

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZOUT[output coordinate file with adjusted B values]:output:_files' \
  'RMSTAB[output table of average B factors and RMS deviations]:table:_files' \
  '*:keyword:(TITLE BLIMIT BRANGE END)' && ret=0

return ret
