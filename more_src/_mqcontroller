#compdef mqcontroller
# Documentation: https://rocketmq.apache.org/docs/deploymentOperations/01deploy/
# Apache RocketMQ controller startup (master-slave auto switch)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-n --namesrvAddr)'{-n,--namesrvAddr}'=[name server address list]:addr' \
  '(-c --configFile)'{-c,--configFile}'=[controller config properties file]:file:_files' \
  '(-p --printConfigItem)'{-p,--printConfigItem}'[print all config item]' && ret=0

return ret
