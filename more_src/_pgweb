#compdef pgweb

# Zsh completion for pgweb - web-based PostgreSQL browser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--host=[database host]:host' \
  '--port=[database port]:port' \
  '--user=[database user]:user' \
  '--pass=[database password]:password' \
  '--db=[database name]:database' \
  '--url=[connection URL]:url' \
  '--ssl=[SSL mode]:mode:(disable allow prefer require verify-ca verify-full)' \
  '--listen=[web server listen address]:address' \
  '--bind=[bind address]:address' \
  '--prefix=[URL prefix]:prefix' \
  '--skip-open[do not open browser on start]' \
  '--readonly[enable read-only mode]' \
  '--sessions[enable session support]' \
  '--lock-session[lock session to single connection]' \
  '--bookmark-dir=[bookmarks directory]:directory:_directories' \
  '--bookmarks-dir=[bookmarks directory]:directory:_directories' \
  '--no-idle-timeout[disable idle timeout]' \
  '--idle-timeout=[idle timeout in minutes]:minutes' \
  '--connect-backend=[connect via backend URL]:url' \
  '--cors[enable CORS]' \
  '--cors-origin=[CORS allowed origin]:origin' \
  '--debug[enable debug mode]' \
  '--quiet[suppress log output]' && ret=0

return ret
