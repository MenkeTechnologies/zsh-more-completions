#compdef sorbet srb

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-e+[inline Ruby code to check]:code' \
  '*--dir=[add directory to check]:directory:_directories' \
  '*--file=[add file to check]:file:_files' \
  '--typed=[default strictness level]:level:(false ignore true strict strong)' \
  '--typed-override=[override strictness for path]:path\=level' \
  '--cache-dir=[directory to use for caching]:directory:_directories' \
  '--max-threads=[number of threads to use]:threads' \
  '--no-error-count[do not print error count at end]' \
  '--silence-dev-message[silence dev message]' \
  '--print=[print specified output]:output:(parse-tree parse-tree-json ast ast-raw name-tree name-tree-raw resolve-tree resolve-tree-raw cfg cfg-raw cfg-text autogen autogen-msgpack file-table-json)' \
  '--stop-after=[stop processing after phase]:phase:(init parser namer resolver cfg inferencer)' \
  '--no-stdlib[do not load standard library]' \
  '--stripe-mode[enable stripe-specific behavior]' \
  '(-q --quiet)'{-q,--quiet}'[silence all non-critical errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbosity level]:' \
  '--color=[use color output]:when:(always never auto)' \
  '--suggest-typed[suggest typed sigils]' \
  '--autocorrect[auto-correct errors where possible]' \
  '--isolate-error-code=[isolate specific error code]:code' \
  '--suppress-error-code=[suppress error code]:code' \
  '--error-url-base=[base URL for error docs]:url' \
  '-p+[alias for --print]:output' \
  '-a[alias for --autocorrect]' \
  '*:file:_files' && ret=0

return ret
