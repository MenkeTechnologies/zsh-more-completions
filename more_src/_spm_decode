#compdef spm_decode
# Documentation: https://github.com/google/sentencepiece/blob/master/src/spm_decode_main.cc
# SentencePiece decoder: subword pieces or ids back to text

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model=[model file name]:model:_files' \
  '--input=[input filename]:file:_files' \
  '--output=[output filename]:file:_files' \
  '--input_format=[input format]:format:(piece id)' \
  '--output_format=[output format]:format:(string proto)' \
  '--extra_options=[colon-separated decoder extra options, e.g. reverse:bos:eos]:opts' \
  '*:input file:_files' && ret=0

return ret
