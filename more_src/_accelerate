#compdef accelerate

# Zsh completion for Hugging Face Accelerate

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:configure accelerate for your environment'
      'estimate-memory:estimate memory usage of a model'
      'env:print environment information'
      'launch:launch a training script'
      'test:test accelerate setup'
      'tpu-config:configure TPU training'
    )
    _describe -t commands 'accelerate command' commands && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config_file=[path to config file]:config file:_files -g "*.yaml"' && ret=0
        ;;
      launch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config_file=[path to config file]:config file:_files -g "*.yaml"' \
          '--multi_gpu[launch multi GPU training]' \
          '--tpu[launch TPU training]' \
          '--use_deepspeed[use DeepSpeed]' \
          '--use_fsdp[use Fully Sharded Data Parallelism]' \
          '--use_megatron_lm[use Megatron-LM]' \
          '--num_processes=[number of processes]:num' \
          '--num_machines=[number of machines]:num' \
          '--machine_rank=[rank of current machine]:rank' \
          '--main_process_ip=[IP of main process]:ip' \
          '--main_process_port=[port of main process]:port' \
          '--mixed_precision=[mixed precision mode]:mode:(no fp16 bf16 fp8)' \
          '--num_cpu_threads_per_process=[CPU threads per process]:threads' \
          '--dynamo_backend=[torch dynamo backend]:backend:(no eager aot_eager inductor)' \
          '--gradient_accumulation_steps=[gradient accumulation steps]:steps' \
          '*:training script:_files -g "*.py"' && ret=0
        ;;
      estimate-memory)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--model_name=[model name or path]:model' \
          '--library_name=[modeling library]:library:(transformers timm)' \
          '--dtypes=[data types to estimate]:dtypes' \
          '--num_gpus=[number of GPUs]:num' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config_file=[path to config file]:config file:_files -g "*.yaml"' && ret=0
        ;;
      env)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
