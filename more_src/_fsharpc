#compdef fsharpc fsc
# _fsharpc — F# compiler (Microsoft + Mono + F# community, F#); compile F# source to .NET assemblies
# upstream: https://github.com/dotnet/fsharp

_fsharpc() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-a[build library]' \
        '--target:+[output type]:type:(exe winexe library module)' \
        '--targetprofile:+[target profile]:profile:(mscorlib netcore netstandard)' \
        '--platform:+[platform]:platform:(anycpu anycpu32bitpreferred x64 x86 itanium)' \
        '--out:+[output file]:file:_files' \
        '-o:+[output file]:file:_files' \
        '--reference:+[reference]:file:_files' \
        '-r:+[reference]:file:_files' \
        '--lib:+[search path]:dir:_files -/' \
        '-I:+[search path]:dir:_files -/' \
        '--define:+[define]:def:' \
        '-d:+[define]:def:' \
        '--debug+[debug type]:type:(full pdbonly portable embedded)' \
        '-g+[debug type]:type:(full pdbonly portable embedded)' \
        '--optimize+[optimize]:val:(+ -)' \
        '-O+[optimize]:val:(+ -)' \
        '--tailcalls+[tail calls]:val:(+ -)' \
        '--crossoptimize+[cross optimize]:val:(+ -)' \
        '--standalone[standalone]' \
        '--staticlink:+[static link]:str:' \
        '--checked+[checked arithmetic]:val:(+ -)' \
        '--noframework[no framework]' \
        '--mlcompatibility[ml compatibility]' \
        '--keyfile:+[strong name key]:file:_files' \
        '--keycontainer:+[key container]:str:' \
        '--delaysign+[delay sign]:val:(+ -)' \
        '--publicsign+[public sign]:val:(+ -)' \
        '--codepage:+[codepage]:cp:' \
        '--utf8output[utf8 output]' \
        '--baseaddress:+[base address]:hex:' \
        '--subsystemversion:+[subsystem version]:ver:' \
        '--highentropyva+[high entropy va]:val:(+ -)' \
        '--win32res:+[win32 resource]:file:_files' \
        '--win32manifest:+[win32 manifest]:file:_files' \
        '--resource:+[embed resource]:file:_files' \
        '--linkresource:+[link resource]:file:_files' \
        '--simpleresolution[simple resolution]' \
        '--noframework[no framework]' \
        '--nologo[no logo]' \
        '--nointerfacedata[no interface data]' \
        '--nooptimizationdata[no optimization data]' \
        '--nocopyfsharpcore[no copy FSharp.Core]' \
        '--warn:+[warn level]:n:' \
        '--warnaserror+[warn as error]:val:(+ -)' \
        '--nowarn:+[no warning]:n:' \
        '--allownullliterals+[allow null literals]:val:(+ -)' \
        '*:file:_files -g "*.(fs|fsi|fsx)"'
}

_fsharpc "$@"
