#compdef compare_hkl
# Documentation: https://www.desy.de/~twhite/crystfel/manual-compare_hkl.html
# Compare two reflection lists, calculating figures of merit (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-y --symmetry)'{-y+,--symmetry=}'[point group symmetry]:pointgroup:' \
  '(-p --pdb)'{-p+,--pdb=}'[unit cell file]:file:_files' \
  '--fom=[figure of merit]:FoM:(Rsplit R1f R1i R2 CC CCstar CCano CRDano Rano Rano/Rsplit d1sig d2sig)' \
  '--nshells=[number of resolution shells]:n:' \
  '-u[fix scale factors to unity]' \
  '--shell-file=[write resolution shell statistics]:file:_files' \
  '--ignore-negs[exclude negative intensities]' \
  '--zero-negs[set negative intensities to zero]' \
  '--sigma-cutoff=[discard reflections below I/sigma(I)]:n:' \
  '--rmin=[low resolution cutoff in m^-1]:1/d:' \
  '--lowres=[low resolution cutoff in Angstroms]:d:' \
  '--rmax=[high resolution cutoff in m^-1]:1/d:' \
  '--highres=[high resolution cutoff in Angstroms]:d:' \
  '*:reflection list:_files' && ret=0

return ret
