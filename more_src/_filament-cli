#compdef filament-cli
# _filament-cli — Dan Harrin Filament TALL-stack Laravel admin panel CLI alias (filamentphp team, PHP); artisan-based
# upstream: https://github.com/filamentphp/filament

_filament-cli() {
    local -a sub=(
        'install:install filament'
        'make:cluster:scaffold cluster'
        'make:filament-page:scaffold page'
        'make:filament-relation-manager:scaffold relation manager'
        'make:filament-resource:scaffold resource'
        'make:filament-theme:scaffold theme'
        'make:filament-user:scaffold admin user'
        'make:filament-widget:scaffold widget'
        'make:form:scaffold form'
        'make:livewire-form:scaffold livewire form'
        'make:notifications-table:scaffold notifications table'
        'make:table:scaffold table'
        'optimize:cache filament components'
        'optimize-clear:clear filament cache'
        'upgrade:upgrade filament install'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'filament subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--panels[install panels package]' \
                    '--forms[install forms package]' \
                    '--tables[install tables package]' \
                    '--notifications[install notifications package]' \
                    '--actions[install actions package]' \
                    '--infolists[install infolists package]' \
                    '--widgets[install widgets package]' \
                    '--scaffold[scaffold default panel]' \
                    '--force[force overwrite]' ;;
            esac
            ;;
    esac
}

_filament-cli "$@"
