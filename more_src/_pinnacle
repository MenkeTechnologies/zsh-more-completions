#compdef pinnacle
# Documentation: https://github.com/pinnacle-comp/pinnacle
# pinnacle: a Smithay-based Wayland compositor configured in Lua or Rust

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --config-dir)'{-c,--config-dir}'[specify the config directory]:dir:_files -/' \
  '(-s --socket-dir)'{-s,--socket-dir}'[set the gRPC socket directory]:dir:_files -/' \
  '--no-config[start without a config file]' \
  '--no-xwayland[prevent Xwayland from launching]' \
  '--allow-root[allow running as root (not recommended)]' \
  '--session[run as a systemd/D-Bus session]' \
  '1:command:((
    config\:"generate a new config"
    client\:"open an interactive Lua REPL"
    debug\:"debugging subcommands"
    gen-completions\:"generate shell completions"
  ))' \
  '*::arg:_default' && ret=0

return ret
