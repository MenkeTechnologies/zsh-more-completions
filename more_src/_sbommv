#compdef sbommv
# Documentation: https://github.com/interlynk-io/sbommv
# move SBOMs between input and output systems (interlynk-io)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    transfer:"move SBOMs from an input source to an output destination"
    version:"show version information"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      transfer)
        _arguments -s \
          '--input-adapter[source system]:adapter:(github folder s3)' \
          '--output-adapter[destination system]:adapter:(dtrack interlynk folder s3)' \
          '--in-github-url[GitHub repository URL]:url:' \
          '--in-github-method[fetch method]:method:(release api clone)' \
          '--out-folder-path[local folder destination path]:dir:_files -/' \
          '--out-dtrack-url[Dependency-Track instance URL]:url:' \
          '--dry-run[print actions without performing them]' \
          '*:arg:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
