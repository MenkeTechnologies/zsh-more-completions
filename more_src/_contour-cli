#compdef contour-cli contour2
# _contour-cli — VMware Tanzu projectcontour contour-cli CLI Envoy proxy backed Kubernetes Ingress controller HTTPProxy CRD-supporting xDS-server REST control-plane delivering routes clusters listeners endpoints to Envoy with TLS termination L7 routing rate-limiting authorization filter chain global-ext-authz Gateway API conformant (VMware team, Go); cobra
# upstream: https://projectcontour.io/

_contour-cli() {
    local -a sub=(
        'bootstrap:generate Envoy bootstrap config'
        'cli:Contour debug CLI'
        'envoy:Envoy helpers'
        'gatewayprovisioner:Gateway provisioner mode'
        'serve:serve xDS API'
        'leader-elector:run leader elector'
        'gateway-api:GatewayAPI helpers'
        'certgen:certificate generation'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '--debug=+[bool]:s:(true false)' \
        '--kubeconfig=+[file]:file:_files' \
        '--root-namespaces=+[list]:str:' \
        '--ingress-class-name=+[name]:str:' \
        '--ingress-status-address=+[host]:_hosts' \
        '--accesslog-format=+[fmt]:f:(envoy json)' \
        '--xds-address=+[host]:_hosts' \
        '--xds-port=+[port]:n:' \
        '--http-address=+[host]:_hosts' \
        '--http-port=+[port]:n:' \
        '--envoy-service-name=+[name]:str:' \
        '--envoy-service-namespace=+[ns]:str:' \
        '--insecure[insecure mode]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'contour-cli subcommand' sub ;;
        args)
            case $words[1] in
                bootstrap) _arguments '*:file:_files -g "*.yaml *.yml"' ;;
                certgen) _arguments \
                    '--namespace=+[ns]:str:' \
                    '--kube[kube cert mode]' \
                    '--lifetime=+[duration]:str:' \
                    '--overwrite[overwrite existing]' ;;
            esac
            ;;
    esac
}

_contour-cli "$@"
