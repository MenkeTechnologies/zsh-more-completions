#compdef dhall-lsp-server
# Documentation: https://github.com/dhall-lang/dhall-haskell/blob/main/dhall-lsp-server/app/Main.hs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Language server — common Node LSP transports (see upstream for extras).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(--version)'--version'[version]' \
  '(--stdio)'--stdio'[use stdio]' \
  '(--node-ipc)'--node-ipc'[Node IPC transport]' \
  '(--socket)'--socket'[port or host:port]' \
  '(--pipe)'--pipe'[pipe transport]' \
  '(--clientProcessId)'--clientProcessId'[parent PID]' \
  '*::args:_normal' && ret=0

return ret
