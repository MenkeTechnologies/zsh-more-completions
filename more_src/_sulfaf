#compdef sulfaf
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/sulfaf.c
# Low frequency array forming

local ret=1

_arguments -s -S \
  'key=[key]:key:' \
  'f1=[f1]:f1:' \
  'f2=[f2]:f2:' \
  'fr=[fr]:fr:' \
  'vel=[vel]:vel:' \
  'dx=[dx]:dx:' \
  'maxmix=[maxmix]:maxmix:' \
  'adb=[adb]:adb:' \
  'tri=[tri]:tri:' \
  'Mix=[Mix]:Mix:' \
  'dir=[dir]:dir:' \
  'verbose=[verbose]:verbose:' \
  '*:file:_files' && ret=0

return ret
