# Zsh completion for amfora - Gemini protocol TUI browser

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  '*:url'
