#compdef afl-cron
# Documentation: https://gitlab.com/rc0r/afl-utils
# Schedule periodic execution of afl-utils tasks (afl-utils)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'=[afl-cron config file]:file:_files' \
  '(-d --daemon)'{-d,--daemon}'[daemon mode: run in background]' \
  '(-q --quiet)'{-q,--quiet}'[suppress any output]' && ret=0

return ret
