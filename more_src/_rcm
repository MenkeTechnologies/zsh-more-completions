#compdef rcup mkrc rcdn lsrc
# Documentation: https://thoughtbot.github.io/rcm/rcup.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for rcm - dotfile management suite

local curcontext="$curcontext" ret=1

case $service in
  (rcup)
    _arguments -s -S \
      '-B[set hostname]:hostname:_hosts' \
      '-C[copy files instead of symlinking]' \
      '-d[set dotfiles directory]:dir:_directories' \
      '-f[force overwrite]' \
      '-g[install as root-owned files]' \
      '-i[prompt before overwrite]' \
      '-I[only install listed files]' \
      '-K[skip pre/post hooks]' \
      '-k[run pre/post hooks]' \
      '-q[quiet mode]' \
      '-S[set symlink directory]:dir:_directories' \
      '-s[set source directory]:dir:_directories' \
      '-t[set tag]:tag:' \
      '-U[only update listed files]' \
      '-u[convert files to be managed]' \
      '-V[show version]' \
      '-v[verbose output]' \
      '-x[set exclude pattern]:pattern:' \
      '*:file:_files' && ret=0
    ;;
  (mkrc)
    _arguments -s -S \
      '-B[set hostname]:hostname:_hosts' \
      '-d[set dotfiles directory]:dir:_directories' \
      '-o[install from host-specific directory]' \
      '-q[quiet mode]' \
      '-S[set symlink directory]:dir:_directories' \
      '-s[set source directory]:dir:_directories' \
      '-t[set tag]:tag:' \
      '-U[convert a file to be unmanaged]' \
      '-u[convert a file to be managed]' \
      '-v[verbose output]' \
      '*:file:_files' && ret=0
    ;;
  (rcdn)
    _arguments -s -S \
      '-B[set hostname]:hostname:_hosts' \
      '-d[set dotfiles directory]:dir:_directories' \
      '-I[only remove listed files]' \
      '-K[skip pre/post hooks]' \
      '-k[run pre/post hooks]' \
      '-q[quiet mode]' \
      '-S[set symlink directory]:dir:_directories' \
      '-s[set source directory]:dir:_directories' \
      '-t[set tag]:tag:' \
      '-v[verbose output]' \
      '-x[set exclude pattern]:pattern:' \
      '*:file:_files' && ret=0
    ;;
  (lsrc)
    _arguments -s -S \
      '-B[set hostname]:hostname:_hosts' \
      '-d[set dotfiles directory]:dir:_directories' \
      '-F[output format]:format:(colon)' \
      '-I[only list specific files]' \
      '-S[set symlink directory]:dir:_directories' \
      '-s[set source directory]:dir:_directories' \
      '-t[set tag]:tag:' \
      '-U[only list undotted files]' \
      '-v[verbose output]' \
      '-x[set exclude pattern]:pattern:' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
