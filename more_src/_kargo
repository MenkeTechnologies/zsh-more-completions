#compdef kargo

# Zsh completion for kargo - Kubernetes continuous promotion

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'apply:Apply a resource from a file or stdin'
  'approve:Approve a freight for a stage'
  'completion:Generate the autocompletion script'
  'create:Create a resource'
  'dashboard:Open the Kargo dashboard'
  'delete:Delete resources'
  'get:Display one or many resources'
  'grant:Grant permissions'
  'login:Log in to a Kargo server'
  'logout:Log out from a Kargo server'
  'promote:Promote freight to a stage'
  'refresh:Refresh a resource'
  'revoke:Revoke permissions'
  'server:Start the Kargo server'
  'update:Update a resource'
  'verify:Verify a stage'
  'version:Print version information'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'kargo command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      get|delete|create)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--project=[specify project]:project' \
          '(-o --output)'{-o,--output}'=[output format]:format:(json yaml)' \
          '*:resource' && ret=0
        ;;
      promote)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--freight=[freight to promote]:freight' \
          '--stage=[target stage]:stage' \
          '--project=[specify project]:project' && ret=0
        ;;
      approve)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--freight=[freight to approve]:freight' \
          '--stage=[stage to approve for]:stage' \
          '--project=[specify project]:project' && ret=0
        ;;
      login)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--admin[log in as admin]' \
          '--password=[password]:password' \
          '--sso[log in via SSO]' \
          '1:server URL' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
