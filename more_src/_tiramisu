#compdef tiramisu
# Documentation: https://man.archlinux.org/search?q=tiramisu
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output}'[output format string]:format:' \
  '(-s --subscribe)'{-s,--subscribe}'[subscribe to notification category]:category:' \
  '(-j --json)'{-j,--json}'[output in JSON format]' && ret=0

return ret
