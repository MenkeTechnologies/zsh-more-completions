#compdef kctrl

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--color[enable color output]' \
  '--column=[filter columns]:columns:' \
  '--debug[enable debug output]' \
  '--json[output as JSON]' \
  '--kube-api-burst=[Kubernetes API burst]:burst:' \
  '--kube-api-qps=[Kubernetes API QPS]:qps:' \
  '--kubeconfig=[kubeconfig file]:config file:_files' \
  '--kubeconfig-context=[kubeconfig context]:context:' \
  '-n+[namespace]:namespace:' \
  '--namespace=[namespace]:namespace:' \
  '--tty[enable TTY behavior]' \
  '-y[answer yes to prompts]' \
  '--yes[answer yes to prompts]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'app:manage apps'
      'package:manage packages'
      'dev:developer workflows'
      'completion:generate shell completion'
      'version:show version'
    )
    _describe -t commands 'kctrl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      app)
        local -a app_commands=(
          'get:get app details'
          'list:list apps'
          'status:show app status'
          'delete:delete app'
          'kick:trigger reconciliation'
          'pause:pause reconciliation'
          'init:initialize app'
        )
        _describe -t commands 'app command' app_commands && ret=0
        ;;
      package)
        local -a package_commands=(
          'installed:manage installed packages'
          'available:manage available packages'
          'repository:manage package repositories'
          'release:release a package'
          'init:initialize package'
        )
        _describe -t commands 'package command' package_commands && ret=0
        ;;
      dev)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[file or directory]:file:_files' \
          '--file=[file or directory]:file:_files' \
          '--local[use local source]' \
          '--namespace=[namespace]:namespace:' && ret=0
        ;;
    esac
    ;;
esac

return ret
