#compdef portpester
# Documentation: https://man.archlinux.org/search?q=portpester
# Reference accessed: 2026-05-16
# Source: https://github.com/dmytro/zsh-compdef/blob/5b2c600c509cda1fb0a05a6055fdcb035c886616/_portpester
# Repository: dmytro/zsh-compdef (_portpester)

local ret=1

_arguments -C -s \
  '(-6)-4[family AF_INET]' \
  '(-4)-6[family AF_INET6]' \
  '-n[do not lookup hostname]' \
  '-v[verbose]' \
  ':host:_hosts' \
  ':port:_ports' \
  && ret=0

return $ret
