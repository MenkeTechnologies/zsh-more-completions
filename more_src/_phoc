#compdef phoc
# Documentation: https://manpages.debian.org/unstable/phoc/phoc.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian unstable phoc(1) manpage OPTIONS section.

# phoc: phosh wlroots-based compositor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[show version information]' \
  '(-C --config)'{-C,--config=}'[path to configuration file (default phoc.ini)]:file:_files -g "*.ini"' \
  '(-E --exec)'{-E,--exec=}'[session executable to run at startup]:command:' \
  '--socket=[Wayland socket to listen on]:socket:' \
  '(-S --shell)'{-S,--shell}'[expect a shell to attach]' \
  '(-X --xwayland --no-xwayland)'{-X,--xwayland}'[start XWayland]' \
  '(-X --xwayland)--no-xwayland[disable XWayland]' && ret=0
return ret
