#compdef termite
# Documentation: https://github.com/aperezdc/termite/blob/master/man/termite.1
# Reference accessed: 2026-05-21
# Verified: upstream manpage. All flags (-h/--help, -v/--version, -e/--exec,
# -r/--role, -t/--title, -d/--directory, --icon, --hold, --display,
# -c/--config, --name, --class) confirmed against termite.1.

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-e --exec)'{-e,--exec}'=[command]:cmd:_command_names' \
  '(-r --role)'{-r,--role}'=[role]:role:' \
  '(-t --title)'{-t,--title}'=[title]:title:' \
  '(-d --directory)'{-d,--directory}'=[dir]:dir:_files -/' \
  '--icon=[icon name]:name:' \
  '--hold[hold open]' \
  '--display=[display]:display:' \
  '(-c --config)'{-c,--config}'=[config]:file:_files' \
  '--name=[WM name]:name:' \
  '--class=[WM class]:class:'
