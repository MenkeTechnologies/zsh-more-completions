#compdef termite
# Documentation: https://github.com/thestinger/termite
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-e --exec)'{-e,--exec}'=[command]:cmd:_command_names' \
  '(-r --role)'{-r,--role}'=[role]:role:' \
  '(-t --title)'{-t,--title}'=[title]:title:' \
  '(-d --directory)'{-d,--directory}'=[dir]:dir:_files -/' \
  '--icon=[icon name]:name:' \
  '--hold[hold open]' \
  '--display=[display]:display:' \
  '(-c --config)'{-c,--config}'=[config]:file:_files' \
  '--name=[WM name]:name:' \
  '--class=[WM class]:class:'
