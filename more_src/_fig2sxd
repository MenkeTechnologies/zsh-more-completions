#compdef fig2sxd
# Documentation: https://man.archlinux.org/search?q=fig2sxd
# Reference accessed: 2026-05-16

# fig2sxd: convert xfig figures to OpenOffice Draw (sxd) format
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-o[output file]:file:_files -g "*.sxd"' \
  '*:xfig file:_files -g "*.fig"' && ret=0
return ret
