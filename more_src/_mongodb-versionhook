#compdef mongodb-versionhook
# _mongodb-versionhook — MongoDB Community Operator version-upgrade hook (PostStart hook that detects a mongod version change in the agent status and triggers a rolling restart)
# upstream: https://github.com/mongodb/mongodb-kubernetes-operator
# Source: cmd/versionhook/main.go on tip; no CLI flags — runtime config is env-driven (AGENT_STATUS_FILEPATH, HOSTNAME, NAMESPACE).

_mongodb-versionhook() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_mongodb-versionhook "$@"
