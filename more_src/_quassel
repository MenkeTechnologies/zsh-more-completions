#compdef quassel quasselclient quasselcore
# Documentation: https://manpages.debian.org/bookworm/quassel-core/quasselcore.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URLs:
#   https://manpages.debian.org/bookworm/quassel-core/quasselcore.1.en.html
#   https://manpages.debian.org/bookworm/quassel-client/quasselclient.1.en.html

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --configdir)'{-c,--configdir=}'[config directory]:dir:_files -/' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '--debug-irc[log raw IRC messages]' \
  '--debug-irc-id=[restrict raw IRC logging to network id]:id:' \
  '--debug-irc-parsed[log parsed IRC messages]' \
  '--debug-irc-parsed-id=[restrict parsed IRC logging to network id]:id:' \
  '--icontheme=[icon theme]:theme:' \
  '(-l --logfile)'{-l,--logfile=}'[log to file]:file:_files' \
  '(-L --loglevel)'{-L,--loglevel=}'[log level]:lvl:(Debug Info Warning Error)' \
  '--syslog[log to syslog]' \
  '--hidewindow[start client minimized]' \
  '--qss=[application stylesheet]:file:_files -g "*.qss"' \
  '--port=[core listen port]:port:' \
  '--listen=[core listen address]:addr:' \
  '--norestore[skip restoring previous state]' \
  '-n[skip restoring previous state]' \
  '--config-from-environment[load config from env vars]' \
  '--select-backend=[storage backend]:backend:' \
  '--select-authenticator=[auth backend]:backend:' \
  '--add-user[add a new core user]' \
  '--change-userpass=[change user password]:user:' \
  '--strict-ident[use core username as ident]' \
  '--ident-daemon[enable internal ident daemon]' \
  '--ident-port=[ident daemon port]:port:' \
  '--ident-listen=[ident daemon listen address]:addr:' \
  '--require-ssl[require SSL for remote connections]' \
  '--ssl-cert=[SSL cert]:file:_files' \
  '--ssl-key=[SSL key]:file:_files' \
  '--oidentd[enable oidentd integration]' \
  '--oidentd-conffile=[oidentd config file]:file:_files' \
  '--proxy-cidr=[proxy protocol IP range]:cidr:' \
  '--metrics-daemon[enable metrics API]' \
  '--metrics-port=[metrics port]:port:' \
  '--metrics-listen=[metrics listen address]:addr:' && ret=0

return ret
