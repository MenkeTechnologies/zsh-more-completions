#compdef SemiBin2
# Documentation: https://semibin.readthedocs.io/en/latest/subcommands/
# SemiBin2 - metagenomic binning with deep siamese networks

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'single_easy_bin:reconstruct bins with single or co-assembly'
      'multi_easy_bin:reconstruct bins across multiple samples'
      'generate_sequence_features_single:training data for single/co-assembly'
      'generate_sequence_features_multi:training data for multi-sample'
      'train_self:train models in a self-supervised way'
      'train_semi:train using semi-supervised learning (deprecated)'
      'bin_short:generate final bins from trained model'
      'bin_long:output final long-read bins'
      'generate_cannot_links:create cannot-link constraints'
      'download_GTDB:obtain GTDB reference genomes'
      'concatenate_fasta:merge fasta files for multi-sample'
      'check_install:check required dependencies'
      'citation:display publication information'
    )
    _describe -t commands 'SemiBin2 command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-i --input-fasta)'{-i,--input-fasta}'=[input contig fasta file]:file:_files' \
      '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
      '(-b --input-bam)'{-b,--input-bam}'+[BAM or CRAM files]:files:_files' \
      '(-a --abundance)'{-a,--abundance}'+[abundance file from strobealign-aemb]:files:_files' \
      '--environment=[prebuilt model habitat]:env' \
      '--self-supervised[use self-supervised training]' \
      '--semi-supervised[use semi-supervised training]' \
      '--sequencing-type=[read type]:type:(short_read long_read)' \
      '(-p --processes)'{-p,--processes}'=[number of CPUs]:cpus' \
      '--engine=[device selection]:engine:(auto gpu cpu)' \
      '--model=[path to trained model file]:file:_files' \
      '--epochs=[training iterations]:epochs' \
      '--batch-size=[training batch size]:size' \
      '--random-seed=[reproducibility seed]:seed' \
      '--compression=[output compression method]:method:(gz bz2 xz none)' \
      '--tmpdir=[temporary directory]:dir:_files -/' && ret=0
    ;;
esac

return ret
