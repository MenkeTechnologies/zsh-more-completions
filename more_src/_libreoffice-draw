#compdef sdraw
# _libreoffice-draw — LibreOffice sdraw / soffice --draw (vector drawing entrypoint; --convert-to pdf/svg/png/odg, --outdir, --headless, --norestore; opens .odg natively and many import filters (Visio .vsd/.vsdx, AutoCAD .dwg, Corel)
# upstream: https://git.libreoffice.org/core
# Flags from libreoffice core/desktop/source/app on tip.

_libreoffice-draw() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--headless[run without UI]' \
        '--norestore[skip restoring previous session]' \
        '--nologo[no splash]' \
        '--convert-to+[convert to format]:format:(pdf svg png jpg odg fodg eps emf wmf xhtml)' \
        '--outdir+[output directory]:dir:_files -/' \
        '--print-to-file[print to file]' \
        '--printer-name+[printer]:printer:_printers' \
        '*-env+[env var]:key=value:' \
        '*:drawing:_files -g "*.(odg|fodg|vsd|vsdx|dwg|dxf|cdr|svg|emf|wmf|eps)"'
}

_libreoffice-draw "$@"
