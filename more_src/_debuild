#compdef debuild
# Documentation: https://manpages.debian.org/debuild
# Source: debian/devscripts scripts/debuild.pl — wrapper around dpkg-buildpackage with lintian (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '--check-dirname-level=-[directory name check level]:level:(0 1 2)' \
    '--check-dirname-regex=-[directory name check regex]:regex:_default' \
    '--clear-hooks[clear all hooks]' \
    '--cvs-debuild[CVS debuild mode]' \
    '--cvs-debuild-deb=-[binary cvs-debuild]:opts:_default' \
    '--cvs-debuild-lin=-[lintian cvs-debuild]:opts:_default' \
    '--force-sign[force signing]' \
    '--lintian[run lintian (default)]' \
    '--no-lintian[do not run lintian]' \
    '--lintian-opts=-[options for lintian]:opts:_default' \
    '--prepend-path=-[prepend directory to PATH]:dir:_files -/' \
    '--preserve-env[preserve full environment]' \
    '*--preserve-envvar=-[preserve environment variable]:var:_default' \
    '*--set-envvar=-[set environment variable]:var=value:_default' \
    '--rootcmd=-[run command as root]:cmd:_command_names' \
    '--rules-target=-[debian/rules target]:target:(build clean install binary binary-arch binary-indep)' \
    '--tgz-check[require tarball matching]' \
    '--unsigned-buildinfo[do not sign buildinfo]' \
    '--unsigned-changes[do not sign changes]' \
    '--unsigned-source[do not sign source]' \
    '--username=-[username for signing]:user:_users' \
    '--no-sign[do not sign result]' \
    '-A[binary-arch only]' \
    '-b[binary-only build]' \
    '-B[binary-only, no arch-indep]' \
    '-d[do not check build-dependencies]' \
    '-D[check build-dependencies (default)]' \
    '-e+[maintainer (Changed-By)]:maintainer:_default' \
    '-E[same as -e]' \
    '-F[full build (default)]' \
    '-G[source build, no diff]' \
    '-g[source build]' \
    '-r+[command to gain root]:cmd:_command_names' \
    '-S[source-only build]' \
    '-f+[changes-file destination]:file:_files' \
    '*::passthrough to dpkg-buildpackage:_default' \
    && ret=0

return ret
