#compdef foam foam-cli
# _foam — Foam Foam personal knowledge management VS Code workspace CLI for graph view backlinks templating Roam-style note-taking with Markdown wikilinks (foambubble team, TypeScript); commander.js
# upstream: https://github.com/foambubble/foam

_foam() {
    local -a sub=(
        'init:initialize new Foam workspace'
        'janitor:run janitor cleanup'
        'create:create new note from template'
        'create-from-template:create from template'
        'orphans:list orphan notes'
        'placeholders:list placeholders'
        'graph:open graph view'
        'sync:sync notes'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--cwd=+[dir]:dir:_files -/' \
        '-w+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'foam subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--template=+[t]:t:(default blank academic research scientific)' \
                    '--git[init git repo]' \
                    '*:workspace dir:_files -/' ;;
                create|create-from-template) _arguments \
                    '--template=+[t]:str:' \
                    '--title=+[title]:str:' \
                    '--tags=+[csv]:str:' \
                    '*:note name:' ;;
                janitor) _arguments \
                    '--fix-headings[fix headings]' \
                    '--fix-frontmatter[fix frontmatter]' \
                    '--check-references[check references]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_foam "$@"
