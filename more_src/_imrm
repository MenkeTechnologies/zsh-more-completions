#compdef imrm
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imrm.html
# MIRIAD: compute rotation measure and zero-wavelength PA images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input position angle images]:in:_files' \
  'inerr=[position angle error images]:inerr:_files' \
  'rmi=[initial rotation measure to remove]:rmi:' \
  'rm=[output rotation measure image]:rm:_files' \
  'pa0=[output zero-wavelength PA image]:pa0:_files' \
  'qcut=[goodness of fit blank threshold]:qcut:' \
  'errcut=[input PA error blank threshold]:errcut:' \
  'rmcut=[fitted RM error blank threshold]:rmcut:' \
  'pacut=[fitted PA0 error blank threshold]:pacut:' \
  'device=[PGPLOT device]:device:' \
  'nxy=[subplots per page in x and y]:nxy:' \
  'csize=[PGPLOT character height]:csize:' \
  'options=[relax,guess,ambiguous,accumulate,yindependent]:options:(relax guess ambiguous accumulate yindependent)' \
  '*:image:_files' && ret=0

return ret
