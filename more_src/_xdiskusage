#compdef xdiskusage
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/xdiskusage.1.html
# xdiskusage - show where disk space is being used

local ret=1

_arguments -s -S \
  '-a[pass the -a switch to du to measure all files]' \
  '-display[specify X display]:display' \
  '-geometry[set window geometry]:geometry' \
  '-title[set window title]:title' \
  '-name[set class name]:name' \
  '-iconic[start in iconic mode]' \
  '-fg[set foreground color]:color' \
  '-bg[set background color]:color' \
  '-bg2[set secondary background color]:color' \
  '*:path:_files' && ret=0

return ret
