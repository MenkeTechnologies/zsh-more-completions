#compdef fourmolu

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-m+[mode of operation]:mode:(stdout inplace check)' \
  '--mode=[mode of operation]:mode:(stdout inplace check)' \
  '-o+[GHC option]:option:' \
  '--ghc-opt=[GHC option]:option:' \
  '-p+[fixity info]:package:' \
  '--package=[fixity info]:package:' \
  '-e+[fixity declaration]:fixity:' \
  '--fixity=[fixity declaration]:fixity:' \
  '-c[check mode]' \
  '--check-idempotence[check formatting idempotence]' \
  '--no-cabal[do not use .cabal file]' \
  '--stdin-input-file=[file path for stdin input]:file:_files' \
  '--color=[colorize output]:when:(auto always never)' \
  '--start-line=[start line]:line:' \
  '--end-line=[end line]:line:' \
  '--column-limit=[column limit]:columns:' \
  '--function-arrows=[function arrow style]:style:(trailing leading)' \
  '--comma-style=[comma style]:style:(leading trailing)' \
  '--import-export-style=[import/export style]:style:(leading trailing diff-friendly)' \
  '--indent-wheres=[indent where clauses]:boolean:(true false)' \
  '--record-brace-space=[space before record braces]:boolean:(true false)' \
  '--newlines-between-decls=[newlines between declarations]:count:' \
  '--haddock-style=[Haddock comment style]:style:(multi-line single-line)' \
  '--let-style=[let style]:style:(auto inline newline mixed)' \
  '--in-style=[in style]:style:(right-align same-line no-space)' \
  '--single-constraint-parens=[parens for single constraints]:style:(auto always never)' \
  '--unicode=[unicode syntax]:style:(detect always never)' \
  '--respectful[be respectful of existing formatting]' \
  '--quiet[suppress non-error output]' \
  '*:Haskell source files:_files -g "*.hs"' && ret=0

return ret
