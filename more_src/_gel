#compdef gel edgedb
# Documentation: https://man.archlinux.org/search?q=gel
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new project'
  'project:manage projects'
  'ui:open the Gel UI'
  'watch:watch for changes and apply migrations'
  'query:execute a query'
  'migrate:apply migrations'
  'migration:manage migration files'
  'database:create/drop/wipe databases'
  'branch:manage database branches'
  'describe:inspect objects and schemas'
  'instance:manage local/remote instances'
  'server:install/manage server versions'
  'cloud:Gel Cloud login/logout/secret'
  'dump:dump database to file'
  'restore:restore from a dump file'
  'configure:configure server/instance settings'
  'analyze:analyze a query'
  'list:list local instances'
  'info:show CLI/system information'
  'extension:manage extensions'
  'cli:CLI self-management (upgrade/install)'
  'completion:generate shell completion'
  'help:show help for any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-I --instance)'{-I+,--instance=}'[named instance]:instance:' \
  '--dsn=[DSN connection string]:dsn:' \
  '--credentials-file=[credentials file]:file:_files' \
  '(-H --host)'{-H+,--host=}'[host]:host:_hosts' \
  '(-P --port)'{-P+,--port=}'[port]:port:' \
  '(-u --user)'{-u+,--user=}'[user]:user:' \
  '(-d --database)'{-d+,--database=}'[database]:database:' \
  '(-b --branch)'{-b+,--branch=}'[branch]:branch:' \
  '--password[prompt for password]' \
  '--no-password[do not prompt for password]' \
  '--password-from-stdin[read password from stdin]' \
  '--tls-ca-file=[TLS CA file]:file:_files' \
  '--tls-security=[TLS security mode]:mode:(strict no_host_verification insecure default)' \
  '--quiet[reduce output]' \
  '--no-cli-update-check[skip CLI update check]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gel command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (project)
        _arguments '*::sub:(init unlink info upgrade)' && ret=0 ;;
      (migration)
        _arguments '*::sub:(apply create edit extract log status upgrade-check)' && ret=0 ;;
      (database)
        _arguments '*::sub:(create drop wipe list)' && ret=0 ;;
      (branch)
        _arguments '*::sub:(create drop list switch wipe rebase merge)' && ret=0 ;;
      (instance)
        _arguments '*::sub:(create destroy start stop restart status logs upgrade reset-password revert resetauth credentials list link unlink)' && ret=0 ;;
      (server)
        _arguments '*::sub:(install uninstall upgrade list-versions list)' && ret=0 ;;
      (cloud)
        _arguments '*::sub:(login logout secretkey)' && ret=0 ;;
      (cli)
        _arguments '*::sub:(upgrade install migrate list)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
