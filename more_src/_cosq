(( $+functions[_cosq_commands] )) ||
_cosq_commands() {
    local commands; commands=(
'query:Execute a SQL query against Cosmos DB' \
'run:Execute a stored query by name (interactive picker if no name given)' \
'queries:Manage stored queries' \
'init:Initialize cosq with a Cosmos DB account' \
'auth:Manage Azure authentication' \
'completion:Generate shell completions' \
'ai:Manage AI features (shows status when run without a subcommand)' \
'version:Show version information' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'cosq commands' commands "$@"
}
(( $+functions[_cosq__ai_commands] )) ||
_cosq__ai_commands() {
    local commands; commands=(
'test:Test AI integration by sending a message' \
'enable:Enable AI features for cosq' \
'disable:Disable AI features for cosq' \
'config:Interactively configure AI provider and model settings' \
'status:Show AI status (same as running \`cosq ai\` without a subcommand)' \
'skill:AI agent skill information — helps set up Claude Code skills for cosq' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'cosq ai commands' commands "$@"
}
(( $+functions[_cosq__ai__config_commands] )) ||
_cosq__ai__config_commands() {
    local commands; commands=()
    _describe -t commands 'cosq ai config commands' commands "$@"
}
