#compdef create-expo-nativewind
# Documentation: https://www.npmjs.com/package/create-expo-nativewind
# Reference accessed: 2026-05-24
# Verified: npm view create-expo-nativewind bin; npm readme Command Line Options table.

# Zsh completion for create-expo-nativewind - Expo app scaffolder with NativeWind

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--nativewind[set up project with NativeWind/TailwindCSS]' \
  '--template=[Expo template]:template:(blank tabs)' \
  '--npm[use npm as package manager]' \
  '--yarn[use yarn as package manager]' \
  '--pnpm[use pnpm as package manager]' \
  '--bun[use bun as package manager]' \
  '--no-install[skip dependency installation]' \
  '--no-git[skip Git repository initialization]' \
  '(-v --version)'{-v,--version}'[display CLI version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':project name:' && ret=0

return ret
