#compdef sstablekeys
# Documentation: https://docs.datastax.com/en/cassandra-oss/3.x/cassandra/tools/toolsSStabkeys.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# sstablekeys: dump keys from Cassandra SSTable
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '*:sstable file:_files -g "*-Data.db"' && ret=0
return ret
