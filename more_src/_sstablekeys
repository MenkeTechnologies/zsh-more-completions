#compdef sstablekeys
# Documentation: https://man.archlinux.org/search?q=sstablekeys
# Reference accessed: 2026-05-16

# sstablekeys: dump keys from Cassandra SSTable
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '*:sstable file:_files -g "*-Data.db"' && ret=0
return ret
