#compdef 66 66-echo 66-execute 66-fdholder-filler 66-hpr 66-nuke 66-oneshot 66-shutdown 66-shutdownd 66-umountall execl-envfile
# Documentation: source-direct extraction from upstream Obarun/66
# src/66/*/*.c USAGE strings + subgetopt_r option-string specs +
# subcommand-dispatch table extraction (66 master: 23 subcommands
# decoded from src/66/66/66.c `if (!strcmp(argv[0], "<sub>"))`
# chain) + OPTS_MAIN macro from src/include/66/ssexec.h.
# Reference accessed: 2026-05-30 via gh api.
# Obarun 66 service-manager R130 — 11-stem multi-binary harvest of
# the Obarun 66 service-manager toolkit. 66 is a layer atop s6 and
# s6-rc that gives them a friendlier service-management UX (similar
# to systemd's `systemctl <verb> <unit>`). Composes with the wider
# Skarnet ecosystem (R117-R129) - 66 specifically delegates fdholder
# / shutdown / hpr / nuke / umountall functions to its own
# wrapper binaries (66-fdholder-filler / 66-shutdown / 66-hpr /
# 66-nuke / 66-umountall) that internally wrap the s6-linux-init
# binaries from R124. Filename uses alphabetically-first stem `66`.

case $service in

  66)
    # Master service-manager dispatch binary. The 23 subcommands
    # extracted source-direct from src/66/66/66.c argv[0] dispatch.
    _arguments -s -S \
      '-h[help]' \
      '-v+[verbosity level]:level:' \
      '-l+[live state directory (default /run/66)]:livedir:_directories' \
      '-t+[tree (service group) name]:tree:' \
      '-T+[transition timeout in ms]:ms:' \
      '-z[disable color output]' \
      '1:subcommand:(boot enable disable start stop configure parse reconfigure reload restart free signal status resolve state remove tree snapshot scandir poweroff reboot halt wall version)' \
      '*:: :_default'
    ;;

  66-echo)
    # Static-build-friendly echo(1) replacement for 66 startup
    # scripts where /bin/echo may not be on PATH.
    _arguments -s -S \
      '-h[help]' \
      '-n[no trailing newline]' \
      '-s+[field separator (default single space)]:sep:' \
      '*:argument:'
    ;;

  66-execute)
    # Low-level start/stop helper invoked by 66 to actually drive
    # a service-state transition. Not typically called directly.
    _arguments -s -S \
      '-h[help]' \
      '-v+[verbosity level]:level:' \
      '1:transition direction:(start stop)' \
      '2:service name:'
    ;;

  66-fdholder-filler)
    # Bootstrap helper that populates the s6-fdholderd server (R120)
    # with pre-bound socket fds from a 66 service definition.
    _arguments -s -S \
      '-h[help]' \
      '-v+[verbosity level]:level:' \
      '-1[notify readiness by writing newline + closing fd 1]' \
      '-t+[per-fd-handoff timeout in ms]:ms:'
    ;;

  66-hpr)
    # Low-level halt/poweroff/reboot binary called by 66-shutdown
    # after the grace period. Equivalent to s6-linux-init-hpr (R124)
    # but with the 66-specific -H/-l/-b flags layered on top.
    _arguments -s -S \
      '-H[do NOT call sync(2); halt unsafe-but-fast]' \
      '-l+[live state directory (default /run/66)]:livedir:_directories' \
      '-b+[wall banner string before halt]:banner:' \
      '-f[force: skip /run/initctl FIFO write; call reboot(2) directly]' \
      '(-p -r)-h[HALT the system]' \
      '(-h -r)-p[POWEROFF the system]' \
      '(-h -p)-r[REBOOT the system]' \
      '-n[do NOT call sync(2) before halting]' \
      '(-w)-d[do NOT write a wtmp/utmp shutdown record]' \
      '(-d)-w[ONLY write the wtmp record; do not actually halt/poweroff/reboot]' \
      '-W[do NOT broadcast a wall(1) message to logged-in users]'
    ;;

  66-nuke)
    # SIGKILL every process except pid 1 and itself. Equivalent to
    # s6-linux-init-nuke from R124. No CLI flags besides -h.
    _arguments -s -S \
      '-h[help]'
    ;;

  66-oneshot)
    # Internal helper invoked by 66 to run a oneshot service's
    # up or down script. Equivalent to s6-rc-oneshot-run (R124)
    # but with 66-specific state-directory conventions.
    _arguments -s -S \
      '-h[help]' \
      '-v+[verbosity level]:level:' \
      '1:transition direction:(up down)' \
      '2:state file path (e.g. /run/66/state/<uid>/<service>):_files'
    ;;

  66-shutdown)
    # User-facing shutdown(8) replacement for systems booted by 66.
    # Schedules a halt/poweroff/reboot at a given time.
    _arguments -s -S \
      '-v+[verbosity level]:level:' \
      '-H[do NOT call sync(2); halt unsafe-but-fast]' \
      '-l+[live state directory]:livedir:_directories' \
      '(-h -p -r -k -c)-h[HALT the system at the scheduled time]' \
      '(-h -p -r -k -c)-p[POWEROFF the system at the scheduled time]' \
      '(-h -p -r -k -c)-r[REBOOT the system at the scheduled time]' \
      '(-h -p -r -k -c)-k[KICK only: broadcast warning then cancel]' \
      '(-h -p -r -k)-c[cancel an already-scheduled shutdown]' \
      '(-F)-f[skip fsck on next boot (no-op; kept for util-linux compat)]' \
      '(-f)-F[force fsck on next boot (no-op; kept for util-linux compat)]' \
      '-a[honor /etc/shutdown.allow access-control list]' \
      '-t+[grace time in seconds before SIGKILL]:sec:' \
      '1:time spec (now / +mins / hh:mm) or message for -c:' \
      '*:broadcast message:'
    ;;

  66-shutdownd)
    # Long-running daemon that listens for shutdown requests from
    # 66-shutdown / 66-hpr and orchestrates the shutdown sequence.
    _arguments -s -S \
      '-h[help]' \
      '-l+[live state directory]:livedir:_directories' \
      '-s+[skeleton directory of shutdown scripts]:skel:_directories' \
      '-g+[grace period in ms between SIGTERM and SIGKILL]:ms:' \
      '-C[run inside a container (do NOT touch hardware reboot)]' \
      '-B[do NOT use a catch-all logger]'
    ;;

  66-umountall)
    # Unmount every filesystem in /proc/mounts except the hardcoded
    # exclude list. Equivalent to s6-linux-init-umountall (R124).
    # No CLI flags.
    _arguments -s -S \
      ': :_default'
    ;;

  execl-envfile)
    # Read variable assignments from an envfile, then chain-load
    # prog with those variables exported to env. Used inside 66
    # oneshot scripts.
    _arguments -s -S \
      '-h[help]' \
      '-v+[verbosity level]:level:' \
      '-l[lax mode: chain-load even if envfile is missing or unparseable]' \
      '1:envfile (key=value lines):_files' \
      '*:program and arguments:_command_names -e'
    ;;

esac
