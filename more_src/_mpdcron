#compdef mpdcron
# Documentation: https://man.archlinux.org/search?q=mpdcron
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-k --kill)'{-k,--kill}'[kill running mpdcron]' \
  '(-N --no-daemon)'{-N,--no-daemon}'[do not daemonize]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0

return ret
