#compdef mpdcron
# Documentation: https://manpages.debian.org/testing/mpdcron/mpdcron.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-k --kill)'{-k,--kill}'[kill running mpdcron]' \
  '(-n --no-daemon)'{-n,--no-daemon}'[do not daemonize]' && ret=0

return ret
