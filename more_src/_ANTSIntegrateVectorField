#compdef ANTSIntegrateVectorField
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ANTSIntegrateVectorField.cxx — integrate a vector field as streamlines (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:VecImageIN.nii.gz (vector field):_files -g "*.{nii,nii.gz}"' \
    '2:ROIMaskIN.nii.gz (integer ROI):_files -g "*.{nii,nii.gz}"' \
    '3:FibersOUT.vtk:_files -g "*.vtk"' \
    '4:LengthImageOUT.nii.gz:_files -g "*.{nii,nii.gz}"' \
    && ret=0

return ret
