#compdef atxy
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/atxy.html
# Apply on-line XY phase measurements to Miriad data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'xyphase=[xyphase keyword]:xyphase:' \
  'refant=[refant keyword]:refant:' \
  'interval=[interval keyword]:interval:' \
  'break=[break keyword]:break:' \
  'sideband=[sideband keyword]:sideband:' \
  'out=[out keyword]:out:' \
  'options=[options keyword]:options:' \
  '*:visibility dataset:_files' && ret=0

return ret
