#compdef gpconfig
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpconfig.html
# Set or view Greenplum Database server configuration parameters

local ret=1

_arguments -s -S \
  '(-? -h --help)'{-\?,-h,--help}'[display online help]' \
  '(-c --change)'{-c,--change}'=[change a configuration parameter setting]:parameter' \
  '(-v --value)'{-v,--value}'=[parameter value to apply across all segments and coordinator]:value' \
  '(-m --coordinatorvalue)'{-m,--coordinatorvalue}'=[distinct value for coordinator and standby only]:value' \
  '--coordinatoronly[restrict edits to coordinator postgresql.conf]' \
  '(-r --remove)'{-r,--remove}'=[remove a configuration parameter setting]:parameter' \
  '(-l --list)'{-l,--list}'[list all parameters supported by gpconfig]' \
  '(-s --show)'{-s,--show}'=[show value for a parameter on all instances]:parameter' \
  '--file[display parameter values from postgresql.conf files]' \
  '--file-compare[compare current database values against postgresql.conf]' \
  '--skipvalidation[bypass validation to operate on restricted parameters]' \
  '--verbose[enable additional logging]' \
  '--debug[set output to debug-level logging]' && ret=0

return ret
