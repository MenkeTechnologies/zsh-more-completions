#compdef sfheadermath
# Documentation: http://www.ahay.org/RSF/sfheadermath.html
# Madagascar: mathematical operations on data headers

local ret=1

_arguments -s \
  'output=[describes the output in mathematical notation]:expr' \
  'key=[key to replace]:key' \
  'nkey=[number of key to replace]:nkey' \
  'segy=[y if SEGY headers]:flag:(y n)' \
  'memsize=[max amount of RAM (in Mb) to be used]:mb' \
  '*:rsf file:_files' && ret=0

return ret
