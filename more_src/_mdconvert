#compdef mdconvert
# Documentation: https://mdtraj.org/1.9.4/mdconvert.html
# Convert MD trajectories between formats (MDTraj)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'[output file path (format from extension)]:output:_files' \
  '(-c --chunk)'{-c,--chunk}'[number of frames to read at once (default 1000)]:frames' \
  '(-f --force)'{-f,--force}'[force overwrite if output exists]' \
  '(-s --stride)'{-s,--stride}'[load only every stride-th frame]:stride' \
  '(-i --index)'{-i,--index}'[load a specific set of frames (slice notation)]:index' \
  '(-a --atom_indices)'{-a,--atom_indices}'[file listing atoms to load]:file:_files' \
  '(-t --topology)'{-t,--topology}'[PDB file for topology]:pdb:_files -g "*.pdb"' \
  '*:input trajectory:_files' && ret=0

return ret
