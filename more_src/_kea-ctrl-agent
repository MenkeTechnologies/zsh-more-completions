#compdef kea-ctrl-agent

# kea-ctrl-agent: Kea REST/JSON control agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[print version]' \
  '-V[print extended version]' \
  '-W[print extended version with file list]' \
  '-d[debug mode (foreground)]' \
  '-c[config file]:file:_files -g "*.(conf|json)"' \
  '-t[test config file, do not start]:file:_files -g "*.(conf|json)"' \
  '-X[debug exit]' \
  '*::kea-ctrl-agent args:_files' && ret=0
return ret
