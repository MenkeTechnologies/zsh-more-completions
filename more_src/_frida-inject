#compdef frida-inject
# Documentation: https://github.com/frida/frida-core/blob/main/inject/inject.vala
# Frida inject - inject a script into a process and detach

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[output version information and exit]' \
  '(-D --device)'{-D+,--device=}'[connect to device with the given ID]:device ID' \
  '(-f --file)'{-f+,--file=}'[spawn FILE]:file:_files' \
  '(-p --pid)'{-p+,--pid=}'[attach to PID]:pid' \
  '(-n --name)'{-n+,--name=}'[attach to NAME]:name' \
  '(-r --realm)'{-r+,--realm=}'[attach in REALM]:realm:(native emulated)' \
  '(-s --script)'{-s+,--script=}'[script to inject]:script:_files' \
  '(-R --runtime)'{-R+,--runtime=}'[script runtime to use]:runtime:(qjs v8)' \
  '(-P --parameters)'{-P+,--parameters=}'[parameters as JSON, same as Gadget]:json' \
  '(-e --eternalize)'{-e,--eternalize}'[eternalize script and exit]' \
  '(-i --interactive)'{-i,--interactive}'[interact with script through stdin]' \
  '--development[enable development mode]' && ret=0

return ret
