#compdef JLinkSWOViewerCL
# Documentation: https://kb.segger.com/J-Link_SWO_Viewer
# SEGGER J-Link SWO Viewer - display target terminal output via the SWO pin

local ret=1

_arguments -s -S \
  '-cpufreq[set the CPU frequency in Hz]:freq' \
  '-device[specify target device name for auto CPU frequency detection]:device' \
  '-itmmask[set of stimulus ports to receive SWO data from]:mask' \
  '-itmport[select a single stimulus port for SWO data]:port' \
  '-outputfile[redirect SWO Viewer output to a file]:file:_files' \
  '-jlinkscriptfile[load a J-Link script file]:file:_files' \
  '-swoattach[enable attach mode]' \
  '-swofreq[set the SWO sampling frequency in Hz]:freq' \
  '-usb[connect to a probe via USB serial number or nickname]:serial/nickname' \
  '-ip[connect to a J-Link probe via IP/host/serial/nickname]:host' && ret=0

return ret
