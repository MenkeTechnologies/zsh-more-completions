#compdef piko
# Documentation: https://github.com/andydunstall/piko
# piko - reverse proxy and tunnel for exposing upstream endpoints

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(agent forward server)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      agent)
        _arguments -s \
          '1:mode:(http tcp)' \
          '*:arg:' && ret=0
        ;;
      forward)
        _arguments -s '*:arg:' && ret=0
        ;;
      server)
        _arguments -s '*:arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
