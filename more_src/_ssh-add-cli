#compdef ssh-add
# _ssh-add-cli — OpenSSH ssh-add; add private keys to running ssh-agent
# upstream: https://github.com/openssh/openssh-portable

_ssh-add-cli() {
    _arguments \
        '-c[require confirmation on each use]' \
        '-D[delete all identities]' \
        '-d[delete identities listed]' \
        '-E+[fingerprint hash]:algo:(md5 sha256)' \
        '-e+[PKCS#11 library to remove]:lib:_files' \
        '-H+[known hosts file]:file:_files' \
        '-h+[host key]:file:_files' \
        '-K[load resident keys from FIDO]' \
        '-k[only load plain private keys]' \
        '-L[show all identities currently in agent]' \
        '-l[list identities]' \
        '-M+[max signatures]:n:' \
        '-m+[minimum lifetime sec]:n:' \
        '-q[quiet]' \
        '-S+[provider]:provider:' \
        '-s+[PKCS#11 library]:lib:_files' \
        '-T+[test against host]:host:_hosts' \
        '-t+[life sec]:n:' \
        '-V[show version]' \
        '-X[unlock agent]' \
        '-x[lock agent with password]' \
        '*::key file:_files'
}

_ssh-add-cli "$@"
