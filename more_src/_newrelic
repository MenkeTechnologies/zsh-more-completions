#compdef newrelic nr
# _newrelic — New Relic newrelic CLI for interacting with the New Relic NRDB API NRQL queries metric streams logs entities workloads dashboards alerts deployment markers via NEW_RELIC_API_KEY (newrelic team, Go); cobra
# upstream: https://github.com/newrelic/newrelic-cli

_newrelic() {
    local -a sub=(
        'agent:agent operations'
        'apiaccess:API access operations'
        'apm:APM operations'
        'config:config operations'
        'decode:decode entity GUID'
        'deployment:deployment marker operations'
        'diagnose:diagnose system'
        'edge:edge tracing operations'
        'entity:entity operations'
        'events:events operations'
        'install:install integration'
        'logs:logs operations'
        'nerdstorage:NerdStorage operations'
        'nrql:run NRQL query'
        'organization:organization operations'
        'profile:profile operations'
        'pixie:Pixie operations'
        'reporting:reporting operations'
        'synthetics:synthetics operations'
        'tag:tag operations'
        'utils:utility operations'
        'workload:workload operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--profile=+[name]:str:' \
        '-p+[name]:str:' \
        '--region=+[r]:r:(US EU Staging)' \
        '--api-key=+[key]:str:' \
        '--license-key=+[key]:str:' \
        '--account-id=+[id]:n:' \
        '--insights-insert-key=+[key]:str:' \
        '--format=+[fmt]:f:(text json plain yaml)' \
        '--debug[debug]' \
        '--no-color[no color]' \
        '--no-input[no interactive]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'newrelic subcommand' sub ;;
        args)
            case $words[1] in
                nrql) _arguments \
                    '1:action:(query history schema)' \
                    '--query=+[NRQL]:str:' \
                    '*:NRQL query:' ;;
                deployment) _arguments \
                    '1:action:(create list delete)' \
                    '--application=+[id]:str:' \
                    '--revision=+[rev]:str:' \
                    '--description=+[text]:str:' \
                    '--user=+[user]:str:' ;;
                entity) _arguments \
                    '1:action:(search describe-tags tags policy)' \
                    '--guid=+[guid]:str:' \
                    '--name=+[name]:str:' \
                    '--type=+[t]:t:(APPLICATION HOST CONTAINER DATABASE QUEUE WORKLOAD)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_newrelic "$@"
