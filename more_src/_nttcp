#compdef nttcp
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/nttcp.1.html
# nttcp - new test TCP program

local ret=1

_arguments -s -S \
  '-r[receive direction: data flows partner to local]' \
  '-t[transmit direction: data flows local to partner (default)]' \
  '-T[print a title line in output]' \
  '-u[use UDP protocol instead of TCP]' \
  '-g[gap time in microseconds between packets]:usec' \
  '-v[verbose output for debugging]' \
  '-D[set TCP_NODELAY on transmitting socket]' \
  '-f[custom output format string]:format' \
  '-n[number of buffers to write (default 2048)]:count' \
  '-l[length of each buffer in bytes (default 4096)]:length' \
  '-x[fixed total data length]:length' \
  '-w[socket buffer size in kilobytes]:kbytes' \
  '-c[compare received bytes with senders pattern]' \
  '-s[force stream pattern generation for UDP comparison]' \
  '-S[seed string for pattern generator]:seed' \
  '-p[partner host listening port (default 5037)]:port' \
  '-i[daemon mode: wait for connections]' \
  '-R[run getpid() calls to measure system speed]:count' \
  '-m[multicast IP:port address (enforces -u -t)]:addr' \
  '*::host:_hosts' && ret=0

return ret
