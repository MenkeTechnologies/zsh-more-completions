#compdef kubeval
# Documentation: https://github.com/instrumenta/kubeval
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kubeval. Flags derived from kubeval/config.go (cobra) in
# the upstream repo. Note: project is archived/unmaintained upstream.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[print version]' \
  '--strict[disallow additional properties not in schema]' \
  '(-v --kubernetes-version)'{-v+,--kubernetes-version=}'[Kubernetes version to validate against]:version:' \
  '(-s --schema-location)'{-s+,--schema-location=}'[base URL used to download schemas]:url:' \
  '--additional-schema-locations=[comma-separated secondary schema URLs]:locations:' \
  '--openshift[use OpenShift schemas instead of upstream Kubernetes]' \
  '--ignore-missing-schemas[skip validation for resources without a schema]' \
  '--exit-on-error[stop execution on first error]' \
  '(-f --filename)'{-f+,--filename=}'[filename for stdin output]:filename:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(stdout json tap)' \
  '*--skip-kinds=[comma-separated kinds to skip]:kinds:' \
  '*--reject-kinds=[comma-separated kinds to prohibit]:kinds:' \
  '--quiet[silence output aside from results]' \
  '(-n --default-namespace)'{-n+,--default-namespace=}'[namespace if not set in metadata]:namespace:' \
  '--insecure-skip-tls-verify[do not validate server certificate]' \
  '*:file:_files -g "*.{yaml,yml,json}"' \
  && ret=0

return ret
