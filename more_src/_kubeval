#compdef kubeval

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--strict[disallow additional properties]' \
  {-v,--kubernetes-version}'=[Kubernetes version]:version' \
  '--schema-location=[schema location URL]:url' \
  '--openshift[use OpenShift schemas]' \
  '--ignore-missing-schemas[ignore missing schemas]' \
  '--exit-on-error[exit on first error]' \
  '--filename=[filename for stdin]:filename' \
  '--output=[output format]:format:(stdout json tap)' \
  '*--skip-kinds=[kinds to skip]:kinds' \
  '*--reject-kinds=[kinds to reject]:kinds' \
  '--force-color[force color output]' \
  '--quiet[quiet output]' \
  '--additional-schema-locations=[additional schema locations]:locations' \
  '*:file:_files' \
  && ret=0
return ret
