#compdef cubegen
# Documentation: https://gaussian.com/cubegen/
# Generate cube files of densities, MOs and other properties from a formatted checkpoint file

local ret=1

_arguments -s -S \
  '1:nprocs (shared memory processors):(0 1 2 4 8)' \
  '2:kind (MO=n, Density=type, Spin=type, Potential=type)' \
  '3:fchkfile:_files -g "*.fchk"' \
  '4:cubefile:_files -g "*.cube"' \
  '5:npts (points per side; 0=default 80)' \
  '6:format (h=header, n=no header):(h n)' \
  '7:cubefile2 (reference cube for dimensions):_files -g "*.cube"' && ret=0

return ret
