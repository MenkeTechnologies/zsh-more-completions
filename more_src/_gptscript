#compdef gptscript

# Zsh completion for gptscript - build AI assistants using GPT

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help for gptscript]' \
  '--version[version for gptscript]' \
  '--cache-dir[directory to store cache]:directory:_files -/' \
  '--disable-cache[disable caching]' \
  '--debug[enable debug logging]' \
  '--debug-messages[enable debug messages]' \
  '--default-model[default model]:model:' \
  '--dump-state[dump the internal execution state to a file]:file:_files' \
  '(-f --input)'{-f,--input}'[read input from a file ("-" for stdin)]:file:_files' \
  '(-o --output)'{-o,--output}'[output file to write to]:file:_files' \
  '--quiet[no output logging (set --quiet=false to force on even when there is no TTY)]' \
  '--dry-run[only print the commands that would be executed]' \
  '--sub-tool[use tool of this name from inside the source file]:tool:' \
  '--workspace[directory to use as workspace]:directory:_files -/' \
  '--list-models[list the models available and exit]' \
  '--list-tools[list built-in tools and exit]' \
  '--openai-api-key[OpenAI API key]:key:' \
  '--openai-base-url[OpenAI base URL]:url:' \
  '--openai-org-id[OpenAI organization ID]:id:' \
  '--events-stream-to[stream events to the provided location]:url or file:' \
  '--chat-state[the chat state to continue or null to start a new chat]:state:' \
  '--confirm[prompt before running potentially dangerous commands]' \
  '--credential-context[context name in which to store credentials]:context:' \
  '--credential-override[credentials to override the store]:override:' \
  '*:files:_files'
