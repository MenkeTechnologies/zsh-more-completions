#compdef mingetty

_arguments -s -S \
  '--noclear[do not clear the screen before prompting]' \
  '--nonewline[do not print a newline before the issue file]' \
  '--noissue[do not display /etc/issue]' \
  '--nohostname[do not show hostname in login prompt]' \
  '--long-hostname[show fully qualified hostname]' \
  '--prompt[set login prompt format string]:prompt format:' \
  '--loginprog[use specified login program]:login program:_command_names' \
  '--nice[set nice value for login program]:nice value:' \
  '--delay[set delay before reprompting after failed login]:seconds:' \
  '--chdir[change to directory before login]:directory:_files -/' \
  '--chroot[chroot to directory before login]:directory:_files -/' \
  '--autologin[automatically log in the specified user]:username:_users' \
  '1:tty device:'
