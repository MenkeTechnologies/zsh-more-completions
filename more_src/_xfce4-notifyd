#compdef xfce4-notifyd xfce4-notifyd-config
# Documentation: https://man.archlinux.org/search?q=xfce4-notifyd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--socket-name=+[D-Bus socket]:sock:' \
  '--replace[replace running instance]' \
  '--no-daemon[do not detach]' && ret=0

return ret
