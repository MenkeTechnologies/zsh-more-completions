#compdef ente
# Documentation: https://github.com/ente-io/ente/tree/main/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ente CLI: photos/auth backup, account and export management.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --toggle)'{-t,--toggle}'[toggle help message]' \
  '1:subcommand:->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a cmds=(
      'account:manage accounts'
      'admin:admin actions'
      'auth:authenticator commands'
      'export:start the export process'
      'version:print version'
    )
    _describe -t commands 'ente subcommand' cmds && ret=0
    ;;
  args)
    case ${words[1]} in
      account)
        if (( CURRENT == 2 )); then
          local -a sub=(
            'add:add a pre-existing account'
            'list:list configured accounts'
            'update:modify account settings'
            'get-token:print auth token for account'
          )
          _describe -t commands 'account subcommand' sub && ret=0
        else
          _arguments -s -S \
            '--app=[ente app]:app:(auth photos)' \
            '--email=[account email]:email:' \
            '--dir=[export directory]:dir:_files -/' \
            && ret=0
        fi
        ;;
      export)
        _arguments -s -S \
          '--shared[include shared albums]' \
          '--hidden[include hidden albums]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
