#compdef cargo-bundle
# Documentation: https://github.com/burtonageo/cargo-bundle
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-r --release)'{-r,--release}'[build a bundle from a target built in release mode]' \
  '--profile=[build using the given profile]:profile:' \
  '(-f --format)'{-f+,--format=}'[bundle output format]:fmt:(deb ios msi wxsmsi osx rpm appimage)' \
  '(-t --target)'{-t+,--target=}'[target triple]:triple:' \
  '(-b --bin)'{-b+,--bin=}'[bundle the specified binary]:name:' \
  '(-e --example)'{-e+,--example=}'[bundle the specified example]:name:' \
  '(-p --package)'{-p+,--package=}'[package to bundle]:spec:' \
  '--features=[features to include]:list:' \
  '--all-features[build with all crate features]' \
  '--no-default-features[build without default features]' \
  '*: :' && ret=0

return ret
