#compdef pmlogger_daily
# _pmlogger_daily — Performance Co-Pilot pmlogger_daily (daily housekeeping cron driver for pmlogger archives; merges yesterday's per-pmlogger archive into one, rotates files, prunes archives older than --rotate days, optionally compresses with --compress-format; -c config, -V verbose, -d path override, -K dry-run)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmlogger/pmlogger_daily on tip.

_pmlogger_daily() {
    _arguments \
        '-c+[control file]:file:_files' \
        '-d+[archive dir]:dir:_files -/' \
        '-x+[exec command]:command:' \
        '-X+[compress program]:compress:' \
        '-V[verbose]' \
        '-r[recover]' \
        '-K[dry run (debug)]' \
        '-N[show would-do only]' \
        '-l+[log file]:file:_files' \
        '-m+[mail address]:addr:' \
        '-o[once]' \
        '-O[stdout]' \
        '-t+[trace]:trace:' \
        '-w[wait]' \
        '-y[reduce verbosity]' \
        '-Z+[timezone]:tz:' \
        '--compress-format+[format]:format:(xz gz bz2 zstd)' \
        '--cull+[days]:n:' \
        '--rotate+[days]:n:' \
        '--keep+[count]:n:' \
        '--no-rewrite[do not rewrite]' \
        '*:hostname:'
}

_pmlogger_daily "$@"
