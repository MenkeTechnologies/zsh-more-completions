#compdef appcenter-cli
# _appcenter-cli — Microsoft App Center CLI (Microsoft, Node.js); commander
# upstream: https://github.com/microsoft/appcenter-cli

_appcenter-cli() {
    local -a sub=(
        'analytics:analytics queries'
        'apps:manage apps'
        'build:manage build branches and configs'
        'codepush:CodePush over-the-air updates'
        'crashes:upload symbols'
        'distribute:distribute releases'
        'login:authenticate'
        'logout:logout'
        'orgs:manage organizations'
        'profile:manage user profile'
        'telemetry:enable/disable telemetry'
        'test:run UI tests'
        'tokens:manage api tokens'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--token=+[API token]:str:' \
        '--env=+[environment]:env:(int prod)' \
        '--debug[debug]' \
        '--format=+[output format]:fmt:(list json csv table)' \
        '--quiet[quiet]' \
        '--output=+[output format]:fmt:(list json csv table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'appcenter subcommand' sub ;;
        args)
            case $words[1] in
                apps) _arguments \
                    '1:cmd:(create delete list show set-current get-current update)' \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '*:arg:' ;;
                build) _arguments \
                    '1:cmd:(branches builds download logs queue stop)' \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '--branch=+[branch]:str:' \
                    '-b+[branch]:str:' \
                    '*:arg:' ;;
                codepush) _arguments \
                    '1:cmd:(deployment release-cordova release-electron release-react release patch promote rollback)' \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '--deployment-name=+[deployment name]:str:' \
                    '-d+[deployment name]:str:' \
                    '*:arg:' ;;
                crashes) _arguments \
                    '1:cmd:(upload-symbols upload-mappings upload-missing-symbols)' \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '--symbol=+[symbol path]:file:_files' \
                    '*:arg:' ;;
                distribute) _arguments \
                    '1:cmd:(groups stores releases release upload)' \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '--file=+[binary file]:file:_files' \
                    '-f+[binary file]:file:_files' \
                    '*:arg:' ;;
                test) _arguments \
                    '1:cmd:(generate prepare run download status wizard)' \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '*:arg:' ;;
                orgs) _arguments \
                    '1:cmd:(apps collaborators create delete list show update)' \
                    '*:arg:' ;;
                profile) _arguments \
                    '1:cmd:(list update)' \
                    '*:arg:' ;;
                tokens) _arguments \
                    '1:cmd:(create delete list)' \
                    '*:arg:' ;;
                login|logout|telemetry) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_appcenter-cli "$@"
