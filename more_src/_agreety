#compdef agreety
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/agreety.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for agreety (text-based greeter for greetd)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --cmd)'{-c,--cmd=}'[command to run after login]:command:_command_names' \
  '(-f --max-failures)'{-f,--max-failures=}'[maximum login failures before exit]:count:' && ret=0

return ret
