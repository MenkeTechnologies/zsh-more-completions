#compdef tvnamer

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-b[batch mode, rename without confirmation]' \
  '-c[custom config file]:file:_files' \
  '--not-recursive[do not descend into subdirectories]' \
  '--dry-run[do not actually rename files]' \
  '--move[move files to destination]:dir:_directories' \
  '--force-rename[force file rename]' \
  '--series-id=[specify TVDB series ID]:id' \
  '--order=[episode ordering]:order:(aired dvd absolute)' \
  '--name=[override series name]:name' \
  '--lang=[language for episode names]:lang' \
  '*:file or directory:_files'
