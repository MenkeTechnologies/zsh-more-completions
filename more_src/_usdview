#compdef usdview
# Documentation: https://openusd.org/release/toolset.html
# Interactive viewer combining GL preview, scenegraph navigation, and debugging

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --renderer)'{-r,--renderer}'[select render backend]:renderer:(Storm Embree "RenderMan RIS" "RenderMan XPU" GL)' \
  '--select[initially select and frame specified prim]:primpath:' \
  '(-cam --camera)'{-cam,--camera}'[set initial camera view]:camera:' \
  '--mask[limit stage population to specified prims]:primpaths:' \
  '--clearsettings[restore default settings]' \
  '--config[load from specified config file]:config:_files' \
  '--defaultsettings[launch with default settings]' \
  '--norender[display hierarchy browser only]' \
  '--noplugins[do not load plugins]' \
  '--unloaded[do not load payloads]' \
  '--bboxStandin[display unloaded prims with bounding boxes]' \
  '--timing[echo timing stats to console]' \
  '--allow-async[enable asynchronous Hydra scene processing]' \
  '--traceToFile[write trace output to file]:file:_files' \
  '--traceFormat[set trace output format]:format:(chrome trace)' \
  '--tracePython[enable Python trace collection]' \
  '--memstats[profile memory usage]:mode:(none stage stageAndImaging)' \
  '--dumpFirstImage[save first rendered image as PNG]:file:_files' \
  '--numThreads[set thread count for processing]:count:' \
  '--ff[set first frame]:frame:' \
  '--lf[set last frame]:frame:' \
  '--cf[set current frame]:frame:' \
  '(-c --complexity)'{-c,--complexity}'[set mesh refinement level]:level:(low medium high veryhigh)' \
  '--quitAfterStartup[exit immediately after startup]' \
  '--sessionLayer[use specified persistent session layer]:layer:_files' \
  '--mute[mute layers matching regex expression]:regex:' \
  '--detachLayers[detach all layers from data source]' \
  '--detachLayersInclude[detach matching layers]:patterns:' \
  '--detachLayersExclude[exclude layers from detachment]:patterns:' \
  '*:USD file:_files' && ret=0

return ret
