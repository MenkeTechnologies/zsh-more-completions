#compdef keto

# Zsh completion for Ory Keto - permission/authorization server

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:check a permission'
      'create:create resources'
      'delete:delete resources'
      'expand:expand a permission tree'
      'list:list resources'
      'migrate:database migration commands'
      'namespace:manage namespaces'
      'parse:parse permission config'
      'serve:start the server'
      'status:check server status'
      'validate:validate configuration'
      'version:show version'
    )
    _describe -t commands 'keto command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[config file]:config:_files -g "*.{yaml,yml,json}"' \
          '--config=[config file]:config:_files -g "*.{yaml,yml,json}"' \
          '--read-remote=[read API address]:address' \
          '--write-remote=[write API address]:address' \
          '--metrics-remote=[metrics address]:address' && ret=0
        ;;
      check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--read-remote=[read API address]:address' \
          '--namespace=[namespace]:namespace' \
          '--object=[object ID]:object' \
          '--relation=[relation]:relation' \
          '--subject-id=[subject ID]:subject' \
          '--subject-set=[subject set]:set' \
          '--format=[output format]:format:(json table)' && ret=0
        ;;
      create|delete)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '--write-remote=[write API address]:address' \
          '1:resource:(relation-tuple)' && ret=0
        ;;
      expand)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--read-remote=[read API address]:address' \
          '--namespace=[namespace]:namespace' \
          '--object=[object ID]:object' \
          '--relation=[relation]:relation' \
          '--max-depth=[maximum expansion depth]:depth' \
          '--format=[output format]:format:(json table tree)' && ret=0
        ;;
      migrate)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[config file]:config:_files -g "*.{yaml,yml,json}"' \
          '--config=[config file]:config:_files -g "*.{yaml,yml,json}"' \
          '1:subcommand:(up down status)' && ret=0
        ;;
    esac
    ;;
esac

return ret
