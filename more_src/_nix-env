#compdef nix-env

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-f --file)'{-f,--file}'[path to Nix expression]:file:_files' \
  '(-p --profile)'{-p,--profile}'[path to profile]:profile:_files' \
  '--system-filter[only show derivations for system]:system' \
  '--dry-run[show what would be done without doing it]' \
  '--max-jobs[maximum number of parallel build jobs]:jobs' \
  '--cores[number of CPU cores per build]:cores' \
  '--keep-going[keep going on build failure]' \
  '--keep-failed[keep build directory on failure]' \
  '--fallback[fall back to building from source]' \
  '--no-build-output[suppress build log output]' \
  '--option[set a Nix option]:name: :value' \
  '-v[increase verbosity level]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      '-i:install packages'
      '--install:install packages'
      '-u:upgrade packages'
      '--upgrade:upgrade packages'
      '-e:uninstall packages'
      '--uninstall:uninstall packages'
      '--set-flag:set package flag'
      '-q:query installed packages'
      '--query:query installed packages'
      '--switch-profile:switch to a different profile'
      '--switch-generation:switch to a different generation'
      '--rollback:roll back to the previous generation'
      '--list-generations:list profile generations'
      '--delete-generations:delete profile generations'
    )
    _describe -t commands 'nix-env command' commands
    ;;
  args)
    case $words[1] in
      -i|--install)
        _arguments -s -S \
          '(-A --attr)'{-A,--attr}'[select attribute from top-level expression]' \
          '--from-expression[interpret arguments as Nix expressions]' \
          '--from-profile[install from another profile]:profile:_files' \
          '--prebuilt-only[only install pre-built packages]' \
          '--preserve-installed[do not remove previous versions]' \
          '--remove-all[remove all previous packages]' \
          '*:package:' && ret=0
        ;;
      -u|--upgrade)
        _arguments -s -S \
          '--lt[upgrade if version is less than]' \
          '--leq[upgrade if version is less than or equal]' \
          '--eq[upgrade if version is equal]' \
          '--always[upgrade regardless of version]' \
          '*:package:' && ret=0
        ;;
      -e|--uninstall)
        _arguments '*:package:' && ret=0
        ;;
      -q|--query)
        _arguments -s -S \
          '--installed[show installed packages]' \
          '--available[show available packages]' \
          '(-s --status)'{-s,--status}'[show package status]' \
          '(-P --attr-path)'{-P,--attr-path}'[show attribute path]' \
          '--no-name[suppress package name]' \
          '(-c --compare-versions)'{-c,--compare-versions}'[compare installed vs available]' \
          '--system[show system attribute]' \
          '--drv-path[show derivation path]' \
          '--out-path[show output path]' \
          '--description[show description]' \
          '--xml[output in XML format]' \
          '--json[output in JSON format]' \
          '*:package:' && ret=0
        ;;
      --delete-generations)
        _arguments '*:generation:' && ret=0
        ;;
      --switch-generation)
        _arguments '1:generation:' && ret=0
        ;;
    esac
    ;;
esac

return ret