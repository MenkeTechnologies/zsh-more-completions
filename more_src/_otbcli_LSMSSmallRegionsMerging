#compdef otbcli_LSMSSmallRegionsMerging
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_LSMSSmallRegionsMerging.html
# Orfeo ToolBox: third step of LSMS, merge small regions of a segmentation

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image of initial spectral signatures]:image:_files' \
  '-inseg[segmented label image]:image:_files' \
  '-out[output segmented image with merged segments]:output:_files' \
  '-minsize[minimum segment size]:value:' \
  '-tilesizex[size of tiles along X-axis]:value:' \
  '-tilesizey[size of tiles along Y-axis]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
