#compdef psredit
# Documentation: http://psrchive.sourceforge.net/manuals/psredit/
# PSRCHIVE: query or change archive metadata.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '*-c+[commands to query/modify/add parameters]:commands:' \
  '-q[suppress the filename from output]' \
  '-Q[suppress filename and parameter names from output]' \
  '-e+[extension for the edited output file]:ext:' \
  '-m[overwrite the input file with modified output]' \
  '-a+[view or add archive-level extensions]:extension:' \
  '-r+[remove a named extension from an archive]:extension:' \
  '-C+[read psredit commands from a text file]:file:_files' \
  '*:archive:_files' && ret=0

return ret
