#compdef rsnapshot
# Documentation: https://man.archlinux.org/search?q=rsnapshot
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-V[show version]' \
  '-h[show help]' \
  '-v[verbose]' \
  '-D[debug]' \
  '-x[exit on first error]' \
  '-q[quiet]' \
  '-t[test mode]' \
  '-c+[config file]:file:_files' \
  '*: :_values "command" configtest version-check du diff sync hourly daily weekly monthly yearly help' && ret=0

return ret
