#compdef dimfilter
# Documentation: https://docs.generic-mapping-tools.org/latest/dimfilter.html
# Source: GenericMappingTools/gmt classic-mode dimfilter — directional-decomposed two-stage grid filter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D+[distance mode (0-4)]:mode:(0 1 2 3 4)' \
    '-F+[primary filter type + width (b/c/g/m/p)]:spec:_default' \
    '-N+[secondary filter (l/u/a/m/p) + sectors]:spec:_default' \
    '-G+[output grid file]:file:_files' \
    '-I+[output grid spacing (dx/dy)]:spacing:_default' \
    '-L[print bash template for DiM analysis]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-T[toggle gridline ↔ pixel registration]' \
    '-Q+[error-analysis mode for multiple depths]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
