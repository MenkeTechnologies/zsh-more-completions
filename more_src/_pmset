#compdef pmset

local -a subcommands

subcommands=(
    'schedule:Schedule power events'
    'repeat:Set repeating power events'
    'cancelall:Cancel all scheduled events'
    'relative:Set wake relative to sleep'
    'displaysleepnow:Put display to sleep immediately'
    'sleepnow:Put machine to sleep immediately'
    'noidle:Prevent idle sleep'
    'touch:Reset idle timer'
    'resetdisplayambientparams:Reset ambient light sensor parameters'
    'thermlog:Show thermal log'
    'advancedpm:Set Advanced Power Management (APM) on or off'
)

local -a settings
settings=(
    'displaysleep' 'disksleep' 'sleep' 'womp' 'ring' 'autorestart'
    'lidwake' 'acwake' 'lessbright' 'halfdim' 'sms' 'hibernatemode'
    'hibernatefile' 'ttyskeepawake' 'networkoversleep' 'destroyfvkeyonstandby'
    'powernap' 'proximitywake' 'lowpowermode' 'tcpkeepalive'
    'standby' 'standbydelayhigh' 'standbydelaylow' 'highstandbythreshold'
    'autopoweroff' 'autopoweroffdelay' 'reducebright'
)

_arguments -s -S \
    '-a[Apply setting to all power sources]' \
    '-b[Apply setting to battery power]' \
    '-c[Apply setting to charger/AC power]' \
    '-u[Apply setting to UPS power]' \
    '-g[Get current settings]' \
    '-l[Synonym for -g live]' \
    '1:subcommand or setting:->subcmd' \
    '*:: :->args' && return

case $state in
    subcmd)
        local -a all_opts
        all_opts=($subcommands)
        for s in $settings; do
            all_opts+=("$s:power management setting")
        done
        _describe 'pmset subcommand or setting' all_opts
        ;;
    args)
        case $words[1] in
            schedule)
                _arguments \
                    '1:event type:(sleep wake poweron shutdown wakeorpoweron)' \
                    '2:date/time (MM/dd/yy HH\:mm\:ss)'
                ;;
            repeat)
                _arguments \
                    '1:event type:(sleep wake poweron shutdown wakeorpoweron)' \
                    '2:day:(M T W R F S U)' \
                    '3:time (HH\:mm\:ss)'
                ;;
            -g)
                _arguments \
                    '1:option:(live batt ac ups sched cap log rawlog therm thermlog assertions assertionslog activity rawlog ps pslog everything)'
                ;;
        esac
        ;;
esac
