#compdef pmset
# Documentation: https://www.unix.com/man-page/osx/1/pmset/
# Source: Apple macOS — Power Management Set (sleep / display / hibernate / wake settings).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-g)-a[apply to all power sources]' \
    '(-g)-b[apply to battery power]' \
    '(-g)-c[apply to charger / wall power]' \
    '(-g)-u[apply to UPS]' \
    '(-a -b -c -u)-g[display current settings]:domain:(custom live disk batt ps therm thermlog assertions log sched cap hid bt sleep capabilities accps lastassertion fanlevel)' \
    '*:setting:(displaysleep sleep disksleep womp autorestart ttyskeepawake hibernatemode lidwake acwake autopoweroff autopoweroffdelay halfdim networkoversleep gpuswitch hibernatefile standby standbydelay standbydelaylow standbydelayhigh highstandbythreshold powernap proximitywake tcpkeepalive disablesleep restartafterkillpower haltlevel haltafter haltremain repeat schedule)' \
    && ret=0

return ret
