#compdef pdm

# Zsh completion for pdm - Python package and dependency manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'add:Add package(s) to pyproject.toml and install them'
  'build:Build artifacts for distribution'
  'cache:Control the caches of PDM'
  'completion:Generate completion scripts for the given shell'
  'config:Display the current configuration'
  'export:Export the locked packages set to other formats'
  'fix:Fix the project problems according to the latest version of PDM'
  'import:Import project metadata from other formats'
  'info:Show the project information'
  'init:Initialize a pyproject.toml for PDM project'
  'install:Install packages from lock file'
  'list:List packages installed in the current working set'
  'lock:Resolve and lock dependencies'
  'outdated:Check for outdated packages and list the latest versions'
  'publish:Build and publish the project to PyPI'
  'remove:Remove packages from pyproject.toml'
  'run:Runs a command or script defined in pyproject.toml'
  'search:Search for PyPI packages'
  'show:Show the package information'
  'sync:Synchronize the current working set with lock file'
  'update:Update package(s) in pyproject.toml'
  'use:Use the given python version or path as base interpreter'
  'venv:Manage virtual environments created for this project'
  'plugin:Manage the PDM plugins'
)

_arguments -s -S \
  '(-c --config)'{-c,--config}'[specify another config file path]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity (can be repeated)]' \
  '(-q --quiet)'{-q,--quiet}'[silence the output, repeat to suppress warnings]' \
  '--pep582[inject the pep582 packages path to the current Python interpreter]' \
  '--no-cache[disable the cache for the current command]' \
  '--ignore-python[ignore the python environment variable]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      add|remove|update)
        _arguments \
          '(-d --dev)'{-d,--dev}'[add as development dependencies]' \
          '--no-sync[only write to pyproject.toml, do not install package]' \
          '--save-compatible[save compatible version specifiers]' \
          '--save-wildcard[save wildcard version specifiers]' \
          '--save-exact[save exact version specifiers]' \
          '--save-minimum[save minimum version specifiers]' \
          '-G[select group of dev-dependencies or optional dependencies]:group:' \
          '--group[select group]:group:' \
          '*:package:' && ret=0
        ;;
      install|sync)
        _arguments \
          '--dev[install dev requirements]' \
          '--no-editable[install all packages in non-editable mode]' \
          '--no-self[do not install the project itself]' \
          '-G[select group]:group:' \
          '--group[select group]:group:' && ret=0
        ;;
      run)
        _arguments \
          '-l[list all available scripts defined in pyproject.toml]' \
          '*:script or command:' && ret=0
        ;;
      completion)
        _arguments ':shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
