#compdef lxqt-session lxqt-config
# _lxqt — LXQt lightweight Qt desktop env session manager and config CLI alias (LXQt team, C++); custom argparse
# upstream: https://github.com/lxqt/lxqt-session

_lxqt() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config-file=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--window-manager=+[window manager]:str:_command_names -e' \
        '-w+[window manager]:str:_command_names -e' \
        '--debug[debug]' \
        '-d[debug]' \
        '--no-daemon[no daemon]' \
        '*:arg:'
}

_lxqt "$@"
