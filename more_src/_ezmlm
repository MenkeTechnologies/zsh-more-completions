#compdef ezmlm

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'make:create new mailing list'
  'list:list subscribers'
  'sub:subscribe address'
  'unsub:unsubscribe address'
  'send:process incoming mail'
  'manage:manage list'
  'archive:archive mailing list'
  'warn:warn bouncing addresses'
  'clean:clean bounce database'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ezmlm command' commands && ret=0 ;;
esac

return ret
