#compdef obsctl
# CLI to interact with Observatorium instances

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--log.format=[log format to use]:format:(clilog logfmt json)' \
  '--log.level=[log filtering level]:level:(error warn info debug)' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    if (( CURRENT == 1 )); then
      _values 'obsctl command' \
        'context[manage context configuration]' \
        'login[login as a tenant and save tenant details locally]' \
        'logout[logout a tenant and remove locally saved details]' \
        'logs[logs based operations for Observatorium]' \
        'metrics[metrics based operations for Observatorium]' \
        'traces[trace-based operations for Observatorium]'
    else
      case $words[1] in
        context)
          _values 'context subcommand' \
            'api[add/edit/remove API configuration]' \
            'current[view current context configuration]' \
            'list[view all context configuration]' \
            'rm[remove context configuration]' \
            'switch[switch to another context]'
          ;;
        metrics)
          _values 'metrics subcommand' \
            'get[read series, labels and rules of a tenant]' \
            'query[query metrics for a tenant]' \
            'set[write Prometheus Rules configuration for a tenant]' \
            'ui[start a proxy server and open a Thanos Query UI]'
          ;;
      esac
    fi
    ;;
esac

return ret
