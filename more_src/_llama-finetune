#compdef llama-finetune
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/examples/training/finetune.cpp
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/examples/training/CMakeLists.txt
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/common/arg.cpp
# Reference accessed: 2026-05-27
# Verified: upstream LLAMA_EXAMPLE_FINETUNE-tagged args in common/arg.cpp + CMake TARGET llama-finetune in examples/training/

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-m+[model path]:model:_files -g "*.gguf"' \
  '--model=[model path]:model:_files -g "*.gguf"' \
  '-f+[file containing training prompt]:file:_files' \
  '--file=[file containing training prompt]:file:_files' \
  '-c+[context size]:size' \
  '--ctx-size=[context size]:size' \
  '-b+[logical batch size]:size' \
  '--batch-size=[logical batch size]:size' \
  '-ub+[physical micro batch size]:size' \
  '--ubatch-size=[physical micro batch size]:size' \
  '-t+[number of threads]:threads' \
  '--threads=[number of threads]:threads' \
  '-ngl+[number of layers to store in VRAM]:layers' \
  '--gpu-layers=[number of layers to store in VRAM]:layers' \
  '--split-mode=[how to split the model]:mode:(none layer row)' \
  '--main-gpu=[main GPU]:gpu' \
  '--tensor-split=[how to split tensors]:split' \
  '--no-mmap[do not memory-map model]' \
  '--mlock[force keep model in RAM]' \
  '-s+[RNG seed]:seed' \
  '--seed=[RNG seed]:seed' \
  '-lr+[adamw or sgd optimizer alpha (learning rate)]:alpha' \
  '--learning-rate=[adamw or sgd optimizer alpha (learning rate)]:alpha' \
  '-lr-min+[if >0, final learning rate after decay]:alpha' \
  '--learning-rate-min=[if >0, final learning rate after decay]:alpha' \
  '-decay-epochs+[if >0, decay learning rate after this many epochs]:value' \
  '--learning-rate-decay-epochs=[if >0, decay learning rate after this many epochs]:value' \
  '-wd+[adamw or sgd optimizer weight decay]:wd' \
  '--weight-decay=[adamw or sgd optimizer weight decay]:wd' \
  '-val-split+[fraction of data to use as validation set]:fraction' \
  '--val-split=[fraction of data to use as validation set]:fraction' \
  '-epochs+[optimizer max number of epochs]:n' \
  '--epochs=[optimizer max number of epochs]:n' \
  '-opt+[optimizer]:opt:(adamw sgd)' \
  '--optimizer=[optimizer]:opt:(adamw sgd)' && ret=0

return ret
