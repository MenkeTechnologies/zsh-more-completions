#compdef mapcidr

# Zsh completion for mapcidr - utility program to perform multiple operations for a given subnet/CIDR ranges

_arguments -s -S \
  '(-cl --cidr-list)'{-cl,--cidr-list}'[file containing list of CIDRs]:file:_files' \
  '(-cidr --cidr)'{-cidr,--cidr}'[CIDR to use]:CIDR:' \
  '(-ip --ip)'{-ip,--ip}'[IP to use]:IP:' \
  '(-ips --ip-list)'{-ips,--ip-list}'[file containing list of IPs]:file:_files' \
  '(-a --aggregate)'{-a,--aggregate}'[aggregate CIDRs into a minimal set]' \
  '(-ae --aggregate-approx)'{-ae,--aggregate-approx}'[approx aggregate CIDRs ignoring IP octets]' \
  '(-c --count)'{-c,--count}'[count IPs in a CIDR]' \
  '(-t --to-cidr)'{-t,--to-cidr}'[convert the given IP to CIDR range]:mask:' \
  '-f4[filter IPv4 IPs from the list of IP/CIDR]' \
  '-f6[filter IPv6 IPs from the list of IP/CIDR]' \
  '(-s --slice)'{-s,--slice}'[slice CIDR into smaller CIDRs]:size:' \
  '(-sp --slice-port)'{-sp,--slice-port}'[append ports to results]:ports:' \
  '--skip-base-ip[skip IP address of network]' \
  '--skip-broadcast-ip[skip broadcast IP address]' \
  '(-mr --match-cidr)'{-mr,--match-cidr}'[match CIDRs against specified list]:CIDR:' \
  '(-fr --filter-cidr)'{-fr,--filter-cidr}'[filter CIDRs against specified list]:CIDR:' \
  '(-mi --match-ip)'{-mi,--match-ip}'[match IPs against specified list]:IP:' \
  '(-fi --filter-ip)'{-fi,--filter-ip}'[filter IPs against specified list]:IP:' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-silent --silent)--silent[display results only]' \
  '(-verbose --verbose)--verbose[display verbose output]' \
  '(-version --version)--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
