#compdef mapcidr
# Documentation: https://github.com/projectdiscovery/mapcidr
# Reference accessed: 2026-05-19
# Verified: projectdiscovery/mapcidr README. Flags use single-dash long
# names (Go flag library convention).
# Removed from prior file: fabricated --aggregate-approx (real -aa),
# fabricated --to-cidr (real -t4/-t6), fabricated --slice (real -sbc/-sbh),
# fabricated --match-cidr/--filter-cidr (no CIDR-only variants upstream),
# bogus man.archlinux.org URL.

# mapcidr: utility to perform multiple operations for given subnet/CIDR ranges

_arguments -s -S \
  '(-cl -cidr)'{-cl,-cidr}'[CIDR/IP/file containing list of CIDR/IP]:input:_files' \
  '-sbc[slice CIDRs by given CIDR count]:count:' \
  '-sbh[slice CIDRs by given HOST count]:count:' \
  '(-a -aggregate)'{-a,-aggregate}'[aggregate IPs/CIDRs into minimum subnet]' \
  '(-aa -aggregate-approx)'{-aa,-aggregate-approx}'[aggregate sparse IPs/CIDRs into approximated subnet]' \
  '(-c -count)'{-c,-count}'[count number of IPs in given CIDR]' \
  '(-t4 -to-ipv4)'{-t4,-to-ipv4}'[convert IPs to IPv4 format]' \
  '(-t6 -to-ipv6)'{-t6,-to-ipv6}'[convert IPs to IPv6 format]' \
  '(-if -ip-format)'{-if,-ip-format}'[IP formats (0-11)]:format:' \
  '(-zpn -zero-pad-n)'{-zpn,-zero-pad-n}'[number of padded zeros to use]:n:' \
  '(-zpp -zero-pad-permute)'{-zpp,-zero-pad-permute}'[enable octet permutations from 0 to zero-pad-n]' \
  '(-f4 -filter-ipv4)'{-f4,-filter-ipv4}'[filter IPv4 IPs from input]' \
  '(-f6 -filter-ipv6)'{-f6,-filter-ipv6}'[filter IPv6 IPs from input]' \
  '-skip-base[skip base IPs ending in .0]' \
  '-skip-broadcast[skip broadcast IPs ending in .255]' \
  '(-mi -match-ip)'{-mi,-match-ip}'[IP/CIDR/file to match]:input:_files' \
  '(-fi -filter-ip)'{-fi,-filter-ip}'[IP/CIDR/file to filter]:input:_files' \
  '(-s -sort)'{-s,-sort}'[sort input IPs/CIDRs ascending]' \
  '(-sr -sort-reverse)'{-sr,-sort-reverse}'[sort input IPs/CIDRs descending]' \
  '(-si -shuffle-ip)'{-si,-shuffle-ip}'[shuffle input IPs in random order]' \
  '(-sp -shuffle-port)'{-sp,-shuffle-port}'[shuffle input IP:port in random order]:ports:' \
  '(-up -update)'{-up,-update}'[update mapcidr to latest version]' \
  '(-duc -disable-update-check)'{-duc,-disable-update-check}'[disable automatic update check]' \
  '-verbose[verbose mode]' \
  '(-o -output)'{-o,-output}'[file to write output to]:file:_files' \
  '-silent[silent mode]' \
  '-version[show version]'
