#compdef tpocket
# Documentation: https://github.com/Discngine/fpocket/blob/master/doc/MANUAL.md
# tpocket - large-scale testing of pocket scoring functions.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-L+[input file: PDB paths, reference PDBs, ligand codes]:file:_files' \
  '-o+[detailed statistics output filename]:file:_files' \
  '-e+[global statistics output filename]:file:_files' \
  '-d+[distance criteria for pocket definition]:float:' \
  '-k[keep fpocket output for each PDB tested]' \
  '*:file:_files' && ret=0

return ret
