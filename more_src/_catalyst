#compdef catalyst
# Gentoo release building tool

local ret=1

_arguments -s -S \
  '-a[print available target definitions and exit]' \
  '-c[use specified configuration file]:config file:_files' \
  '-C[set configuration values on the command line]:key=value:' \
  '-d[enable debug mode]' \
  '-f[use specified spec file]:spec file:_files' \
  '-F[fetch snapshot from mirror]' \
  '-l[display all available sub-targets]' \
  '-p[output all configuration settings and exit]' \
  '-P[purge temporary files and directories]' \
  '-s[generate a new snapshot]:snapshot name:' \
  '-T[used to purge a snapshot tarball]:snapshot name:' \
  '-v[verbose output]' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
