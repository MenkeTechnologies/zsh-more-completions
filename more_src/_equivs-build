#compdef equivs-build

# Zsh completion for equivs-build - Build Debian packages from equivs control files

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--full[do a full build]' \
  '--source[build a source package only]' \
  '--arch[build for architecture-specific]' \
  '--nocheck[skip build-time tests]' \
  '1:control file:_files -g "*.ctl(-.)"' && ret=0

return ret
