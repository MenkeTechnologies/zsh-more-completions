#compdef tccli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'configure:configure profiles and credentials'
  'help:show help'
  'cvm:Cloud Virtual Machine'
  'cdb:TencentDB for MySQL'
  'cdwpg:Cloud Data Warehouse PG'
  'cdwdoris:Cloud Data Warehouse Doris'
  'cos:Cloud Object Storage'
  'vpc:Virtual Private Cloud'
  'clb:Cloud Load Balancer'
  'cdn:Content Delivery Network'
  'cls:Cloud Log Service'
  'mongodb:TencentDB for MongoDB'
  'redis:TencentDB for Redis'
  'postgres:TencentDB for PostgreSQL'
  'mariadb:TencentDB for MariaDB'
  'tdmq:Tencent Distributed Message Queue'
  'cmq:Cloud Message Queue'
  'tke:Tencent Kubernetes Engine'
  'tcr:Tencent Container Registry'
  'scf:Serverless Cloud Function'
  'eb:EventBridge'
  'cam:Cloud Access Management'
  'sts:Security Token Service'
  'ssl:SSL Certificate Service'
  'kms:Key Management Service'
  'monitor:Cloud Monitor'
  'apm:Application Performance Monitoring'
  'mps:Media Processing Service'
  'vod:Video on Demand'
  'asr:Automatic Speech Recognition'
  'tts:Text To Speech'
  'tmt:Tencent Machine Translation'
  'sms:SMS'
  'ses:Email Service'
  'tcb:Tencent CloudBase'
  'lighthouse:Lighthouse'
  'gaap:Global Application Acceleration Platform'
  'antiddos:Anti-DDoS'
  'waf:Web Application Firewall'
  'cwp:Cloud Workload Protection'
  'tag:Tag Service'
  'organization:Organization'
  'billing:Billing'
  'tat:TAT (Tencent Automation Tools)'
  'dts:Data Transmission Service'
  'dlc:Data Lake Compute'
  'dataintegration:Data Integration'
  'wedata:WeData'
  'dnspod:DNSPod'
  'domain:Domain Service'
  'es:Elasticsearch Service'
  'ckafka:Cloud Kafka'
  'tsf:TSF (microservices)'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--profile=[profile name]:profile:' \
  '--secretId=[secret ID]:id:' \
  '--secretKey=[secret key]:key:' \
  '--token=[STS token]:token:' \
  '--role-arn=[role ARN]:arn:' \
  '--role-session-name=[role session name]:name:' \
  '--use-cvm-role[use CVM role]' \
  '--region=[region]:region:' \
  '--endpoint=[endpoint domain]:domain:' \
  '--filter=[output JMESPath filter]:expr:' \
  '--timeout=[timeout seconds]:secs:' \
  '--output=[output format]:format:(json table text)' \
  '--generate-cli-skeleton=[generate skeleton]:type:(input output)' \
  '--cli-input-json=[CLI input JSON]:json:' \
  '--cli-unfold-argument[unfold dot-syntax args]' \
  '--https-proxy=[HTTPS proxy URL]:url:' \
  '--warning[show warning]' \
  '--waiter=[waiter spec]:expr:' \
  '--language=[response language]:lang:(zh-CN en-US)' \
  '--detail[show detail]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tccli product' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (configure)
        _values 'configure action' \
          'set' 'get' 'list' 'remove' 'set-root-domain' && ret=0
        ;;
    esac
    ;;
esac

return ret
