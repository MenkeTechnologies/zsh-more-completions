#compdef vlogs

# vlogs: VictoriaLogs single-binary all-in-one server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-storageDataPath=[storage data path]:dir:_files -/' \
  '-retentionPeriod=[retention period]:duration:' \
  '-httpListenAddr=[HTTP listen addr]:addr:' \
  '-loggerLevel=[logger level]:level:(INFO WARN ERROR)' \
  '-loggerFormat=[logger format]:fmt:(default json)' \
  '-loggerOutput=[logger output]:out:' \
  '-pprofAuthKey=[pprof auth key]:key:' \
  '-metricsAuthKey=[metrics auth key]:key:' \
  '-tls=[enable TLS]:bool:(true false)' \
  '-tlsCertFile=[TLS cert file]:file:_files' \
  '-tlsKeyFile=[TLS key file]:file:_files' \
  '-tlsCipherSuites=[TLS cipher suites]:list:' \
  '-tlsMinVersion=[TLS min version]:ver:(TLS10 TLS11 TLS12 TLS13)' \
  '-search.maxQueryDuration=[max query duration]:duration:' \
  '-select.disableDuplicates[disable dedup]' \
  '*::vlogs args:_files' && ret=0
return ret
