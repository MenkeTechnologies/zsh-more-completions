#compdef distribution
# Documentation: https://github.com/distribution/distribution
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for distribution histogram (time-less-ness/distribution, perl)

_arguments -s -S \
  '--rcfile=[config file]:file:_files' \
  '--size=[preset]:size:(sm med lg full)' \
  '--width=[terminal width]:cols' \
  '--height=[terminal height]:rows' \
  '--color[colourise output]' \
  '--palette=[palette]:palette' \
  '--tokenize=[token char]:char' \
  '--graph=[kv or vk]:ordering:(kv vk)' \
  '--numonly=[derivative modes]:mode' \
  '--char=[bar characters]:chars' \
  '--keys=[max hash keys]:K' \
  '--verbose[verbose log]' \
  '(-h --help)'{-h,--help}'[usage]' && ret=0

return ret
