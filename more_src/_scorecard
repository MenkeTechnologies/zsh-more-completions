#compdef scorecard

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--repo=[repository to check]:repository URL' \
  '--local=[path to local repository]:directory:_files -/' \
  '--checks=[comma-separated list of checks to run]:checks' \
  '--format=[output format]:format:(default json csv)' \
  '--show-details[show additional check details]' \
  '--show-annotations[show check annotations]' \
  '--metadata=[additional metadata]:metadata' \
  '--npm=[npm package to check]:package name' \
  '--pypi=[PyPI package to check]:package name' \
  '--rubygems=[RubyGems package to check]:gem name' \
  '--nuget=[NuGet package to check]:package name' \
  '--commit=[specific commit to check]:commit hash' \
  '--policy=[path to policy file]:policy file:_files' \
  '(-v --verbosity)'{-v,--verbosity}'[set log verbosity level]:level:(panic fatal error warn info debug trace)' \
  '--version[display version]' \
  '--help[display help]' && ret=0

return ret
