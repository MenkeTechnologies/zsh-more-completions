#compdef aws-s3-csi-daemonset-mounter
# _aws-s3-csi-daemonset-mounter — Mountpoint for S3 CSI DaemonSet-mode mounter (process manager that execs mount-s3 per request)
# upstream: https://github.com/awslabs/mountpoint-s3-csi-driver
# Flags from cmd/aws-s3-csi-daemonset-mounter/main.go on tip.

_aws-s3-csi-daemonset-mounter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--comm-dir=[directory for communication socket and error files]:dir:_files -/' \
        '--mountpoint-bin-dir=[directory containing the mount-s3 binary]:dir:_files -/' \
        '--recv-timeout=[timeout for receiving mount options from a connection]:duration:' \
        '-v[klog verbosity level]:n:'
}

_aws-s3-csi-daemonset-mounter "$@"
