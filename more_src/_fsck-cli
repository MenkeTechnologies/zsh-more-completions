#compdef fsck-cli
# _fsck-cli — util-linux fsck filesystem check dispatcher CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_fsck-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-V[show version]' \
        '-A[check all]' \
        '-C+[fd]:n:' \
        '-l[lock device]' \
        '-M[skip mounted filesystems]' \
        '-N[no-op]' \
        '-P[run in parallel]' \
        '-R[skip root fs]' \
        '-r+[report stats fd]:n:' \
        '-T[no title]' \
        '-t+[fstype]:str:' \
        '-s[serialize]' \
        '-v[verbose]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper}*"'
}

_fsck-cli "$@"
