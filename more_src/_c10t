#compdef c10t
# Documentation: https://github.com/udoprog/c10t
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# c10t - Minecraft cartography / map renderer.
# Upstream README documents only --debug and --version explicitly; full option
# set is exposed via the binary's own --help output.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[run with diagnostic debug output]' \
  '*:args:_files'
