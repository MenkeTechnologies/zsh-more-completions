#compdef hydroxide
# Documentation: https://github.com/emersion/hydroxide
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:authenticate a Proton Mail account'
  'export-secret-keys:export private PGP keys'
  'export-messages:export messages'
  'import-messages:import messages'
  'smtp:run SMTP-only bridge'
  'imap:run IMAP-only bridge'
  'carddav:run a CardDAV server'
  'serve:run the IMAP/SMTP/CardDAV server'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[print debug logs]' \
  '-disable-imap[disable the IMAP server]' \
  '-disable-smtp[disable the SMTP server]' \
  '-disable-carddav[disable the CardDAV server]' \
  '-imap-host=[IMAP listen host]:host:_hosts' \
  '-imap-port=[IMAP listen port]:port:' \
  '-smtp-host=[SMTP listen host]:host:_hosts' \
  '-smtp-port=[SMTP listen port]:port:' \
  '-carddav-host=[CardDAV listen host]:host:_hosts' \
  '-carddav-port=[CardDAV listen port]:port:' \
  '-tls-cert=[TLS certificate]:file:_files' \
  '-tls-key=[TLS key]:file:_files' \
  '-tls-client-ca=[TLS client CA]:file:_files' \
  '-config=[config file]:file:_files' \
  '-cpu-profile=[write CPU profile to file]:file:_files' \
  '-api-endpoint=[Proton API endpoint]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hydroxide command' commands && ret=0 ;;
esac

return ret
