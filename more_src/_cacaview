#compdef cacaview

local -a arguments

arguments=(
    '-d[Driver]:driver:(x11 gl caca slang ncurses raw null)'
    '-h[Show help]'
    '-l[List available drivers]'
    '-v[Show version]'
    '-W[Width]:width:'
    '-H[Height]:height:'
    '*:image file:_files -g "*.{png,jpg,jpeg,gif,bmp,tga,pcx}"'
)

_arguments -s -S $arguments
