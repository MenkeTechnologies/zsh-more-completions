#compdef golicense
# _golicense — scan Go binaries to verify dependency licenses (mitchellh/golicense)
# upstream: https://github.com/mitchellh/golicense
# Flags from main.go (flag).

_golicense() {
    _arguments \
        '(- *)-h[show help]' \
        '-license[verify license info (default true)]:bool:(true false)' \
        '-plain[plain terminal output (no colors / live updates)]' \
        '-verbose[verbose terminal output (requires -plain)]' \
        '-out-xlsx=[write report as XLSX]:file:_files -g "*.xlsx"' \
        '*:file:_files'
}

_golicense "$@"
