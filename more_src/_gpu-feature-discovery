#compdef gpu-feature-discovery

# gpu-feature-discovery: NVIDIA GPU feature discovery for k8s
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--mig-strategy=[MIG strategy]:strategy:(none single mixed)' \
  '--fail-on-init-error=[fail on init error]:bool:(true false)' \
  '--oneshot[run once and exit]' \
  '--sleep-interval=[sleep interval]:duration:' \
  '--output-file=[output file]:file:_files' \
  '--no-timestamp[do not output a timestamp]' \
  '--use-node-feature-api[use Node Feature API]' \
  '*::gpu-feature-discovery args:_files' && ret=0
return ret
