#compdef 3dWarp
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dWarp.html
# AFNI: warp a dataset by an affine or atlas transformation

local ret=1

_arguments -s -S \
  '-matvec_in2out[3x4 affine matrix+vector (in to out)]:file:_files' \
  '-matvec_out2in[3x4 affine matrix+vector (out to in)]:file:_files' \
  '-tta2mni[convert TT atlas coords to MNI-152]' \
  '-mni2tta[convert MNI-152 coords to TT atlas]' \
  '-matparent[extract matrix from another dataset header]:dataset:_files' \
  '-card2oblique[apply oblique transform from reference]:dataset:_files' \
  '-oblique_parent[alias for -card2oblique]:dataset:_files' \
  '-deoblique[convert oblique dataset to cardinal]' \
  '-oblique2card[alias for -deoblique]' \
  '-disp_obl_xform_only[display oblique transform matrix only]' \
  '-linear[linear interpolation (default)]' \
  '-cubic[cubic interpolation]' \
  '-NN[nearest-neighbor interpolation]' \
  '-quintic[quintic interpolation]' \
  '-wsinc5[windowed sinc interpolation]' \
  '-fsl_matvec[matrix file uses FSL (LPI) order]' \
  '-newgrid[new grid spacing in mm]:mm:' \
  '-gridset[align output to reference grid]:dataset:_files' \
  '-zpad[pad input with N zero planes]:planes:' \
  '-verb[verbose output]' \
  '-prefix[output dataset prefix]:prefix:' \
  '*:dataset:_files' && ret=0

return ret
