#compdef 3dnoise
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dnoise.html
# Estimate and zero out the noise level in a dataset

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-blast[zero voxels at or below the noise cutoff]' \
  '-snr[cutoff as a multiplier of estimated noise level]:fac:' \
  '-nl[manually specify the noise level value]:x:' \
  '*:dataset:_files' && ret=0

return ret
