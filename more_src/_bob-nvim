#compdef bob-nvim
# Documentation: https://github.com/MordechaiHadad/bob
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for bob - Neovim version manager (alias entrypoint)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'use:switch to specified version'
  'run:run a specific Neovim version with arguments'
  'install:install specified version'
  'sync:sync versions from bob config file'
  'uninstall:uninstall specified version'
  'rollback:rollback to previously used version'
  'erase:erase any changes bob has made'
  'list:list installed versions'
  'list-remote:list remote available versions'
  'complete:generate shell completions'
  'update:update existing version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'bob command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      use|install|uninstall|update|run)
        _arguments '1:version:(stable nightly latest)' '*:args:' && ret=0
        ;;
      complete)
        _arguments '1:shell:(bash zsh fish elvish powershell nushell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
