#compdef bob

# Zsh completion for bob - Neovim version manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'use:switch to specified version'
  'install:install specified version'
  'uninstall:uninstall specified version'
  'rollback:rollback to previously used version'
  'erase:erase any changes bob has made'
  'list:list installed versions'
  'ls-remote:list remote available versions'
  'complete:generate shell completions'
  'update:update existing version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'bob command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      use|install|uninstall|update)
        _arguments '1:version:(stable nightly latest)' && ret=0
        ;;
    esac
    ;;
esac

return ret
