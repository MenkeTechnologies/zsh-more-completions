#compdef jack_simple_session_client

# jack_simple_session_client: minimal JACK session-aware client
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-n[JACK client name]:name:' \
  '--name=[JACK client name]:name:' \
  '-s[JACK server name]:name:' \
  '--server=[JACK server name]:name:' \
  '*::jack_simple_session_client args:_files' && ret=0
return ret
