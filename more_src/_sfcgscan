#compdef sfcgscan
# Documentation: https://raw.githubusercontent.com/ahay/src/master/system/seismic/Mcgscan.c
# Madagascar: Hyperbolic Radon transform with conjugate-directions inversion

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'adj=[adjoint flag (y/n)]:flag:(y n)' \
  'niter=[number of iterations]:n:' \
  'miter=[conjugate-direction memory]:n:' \
  'psun1=[amplitude type for adjoint]:n:' \
  'psun2=[amplitude type for forward]:n:' \
  'anti=[antialiasing]:a:' \
  'nx=[number of offset samples]:n:' \
  'x0=[offset origin]:o:' \
  'dx=[offset sampling]:d:' \
  'nv=[number of velocity samples]:n:' \
  'v0=[velocity origin]:o:' \
  'dv=[velocity sampling]:d:' \
  's02=[reference slowness squared]:s:' \
  'mask=[mask file]:file:_files' \
  'ncycle=[number of sharpening cycles]:n:' \
  'perc=[sharpening percentage]:p:' \
  'fact=[sharpening factor]:f:' \
  'error=[error output file]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
