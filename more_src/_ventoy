#compdef ventoy

# Zsh completion for ventoy - bootable USB solution

_arguments -s -S \
  '-i[install Ventoy to device]' \
  '-I[force install Ventoy to device]' \
  '-u[update Ventoy on device]' \
  '-l[list Ventoy info on device]' \
  '--secure-boot[enable secure boot support]' \
  '--reserve=[reserve space at end of disk]:size:' \
  '--label=[set partition label]:label:' \
  '--exfat[use exFAT filesystem]' \
  '--ntfs[use NTFS filesystem]' \
  '--ext[use ext4 filesystem]' \
  '--xfs[use XFS filesystem]' \
  '--fat32[use FAT32 filesystem]' \
  '--gpt[use GPT partition style]' \
  '*:device:_files -g "/dev/sd*" -g "/dev/nvme*"'
