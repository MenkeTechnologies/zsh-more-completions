#compdef tssmartcard
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tssmartcard.cpp
# tssmartcard - list or reset smartcard readers via PC/SC

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-a,--apdu}'=[send an APDU (even number of hex digits)]:hex:' \
  '--continue-on-error[continue sending APDUs after a PC/SC error]' \
  '(-c --cold-reset)'{-c,--cold-reset}'[perform a cold reset on the smartcard]' \
  '(-e --eject)'{-e,--eject}'[eject the smartcard]' \
  '(-t --timeout)'{-t,--timeout}'=[timeout in milliseconds (default 1000)]:ms:' \
  '(-w --warm-reset)'{-w,--warm-reset}'[perform a warm reset on the smartcard]' \
  '*:reader name:' && ret=0

return ret
