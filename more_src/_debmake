#compdef debmake
# _debmake — helper script to make Debian source packages (Debian/debmake)
# upstream: https://salsa.debian.org/debian/debmake
# Flags from debmake(1) man page.

_debmake() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --copyright)'{-c,--copyright}'[scan source for copyright/license text and exit]' \
        '(-k --kludge)'{-k,--kludge}'[compare debian/copyright with the source and exit]' \
        '(-n --native)'{-n,--native}'[native Debian source package (3.0 native)]' \
        '(-a --archive)'{-a+,--archive=}'[upstream source tarball]:file:_files -g "*.tar.*"' \
        '(-d --dist)'{-d,--dist}'[run make-dist equivalents to generate tarball]' \
        '(-t --tar)'{-t,--tar}'[run tar to generate the upstream tarball]' \
        '(-p --package)'{-p+,--package=}'[Debian package name]:name:' \
        '(-u --upstreamversion)'{-u+,--upstreamversion=}'[upstream package version]:version:' \
        '(-r --revision)'{-r+,--revision=}'[Debian package revision]:rev:' \
        '(-z --targz)'{-z+,--targz=}'[tarball extension]:ext:(tar.gz tar.bz2 tar.xz)' \
        '(-b --binaryspec)'{-b+,--binaryspec=}'[binary package specs (binpkg:type,...)]:specs:' \
        '(-e --email)'{-e+,--email=}'[email address]:email:' \
        '(-f --fullname)'{-f+,--fullname=}'[fullname]:name:' \
        '(-i --invoke)'{-i+,--invoke=}'[buildtool to invoke at end]:tool:(debuild "debuild -us -uc" pdebuild sbuild)' \
        '(-j --judge)'{-j,--judge}'[run dpkg-depcheck to judge build deps]' \
        '(-l --license)'{-l+,--license=}'[license files (comma-separated)]:files:' \
        '(-m --monoarch)'{-m,--monoarch}'[force non-multiarch packages]' \
        '(-o --option)'{-o+,--option=}'[read optional parameters from file]:file:_files' \
        '(-q --quitearly)'{-q,--quitearly}'[quit before creating debian/ files]' \
        '(-s --spec)'{-s,--spec}'[use upstream spec for description]' \
        '(-w --with)'{-w+,--with=}'[extra dh(1) addons]:addons:' \
        '(-x --extra)'{-x+,--extra=}'[template generation level]:n:(0 1 2 3 4)' \
        '(-y --yes)*'{-y,--yes}'[force yes for prompts (-yy = force no)]' \
        '(-L --local)'{-L,--local}'[generate local-only config (lintian-fooling)]' \
        '(-P --pedantic)'{-P,--pedantic}'[pedantically check auto-generated files]' \
        '(-T --tutorial)'{-T,--tutorial}'[output tutorial comments in templates]'
}

_debmake "$@"
