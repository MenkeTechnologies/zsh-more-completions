#compdef premake4
# Documentation: https://premake.github.io/docs/Using-Premake/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--cc=[choose a C/C++ compiler]:compiler:(gcc ow)' \
  '--dotnet=[choose a .NET compiler]:compiler:(mono msnet pnet)' \
  '--os=[target operating system]:os:(bsd linux macosx solaris windows)' \
  '--platform=[target platform]:platform:(universal32 universal64 universal x32 x64 native)' \
  '--file=[read specified premake script]:file:_files' \
  '--scripts=[search for scripts in specified directory]:directory:_directories' \
  '1:action:->action' && ret=0

case $state in
  (action)
    local -a actions=(
      'clean:remove all generated files'
      'gmake:generate GNU Makefiles'
      'vs2005:generate Visual Studio 2005 project files'
      'vs2008:generate Visual Studio 2008 project files'
      'vs2010:generate Visual Studio 2010 project files'
      'xcode3:generate Xcode 3 project files'
      'xcode4:generate Xcode 4 project files'
      'codelite:generate CodeLite project files'
      'codeblocks:generate Code::Blocks project files'
    )
    _describe -t actions 'action' actions && ret=0
    ;;
esac

return ret
