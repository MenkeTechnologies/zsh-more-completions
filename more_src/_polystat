#compdef polystat gmx-polystat
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-polystat.html
# gmx polystat: calculate static properties of polymers

local ret=1

_arguments -s \
  '-s[portable xdr run input file]:file:_files' \
  '-f[trajectory file]:file:_files' \
  '-n[index file]:file:_files' \
  '-o[xvgr/xmgr file]:file:_files' \
  '-v[xvgr/xmgr file]:file:_files' \
  '-p[xvgr/xmgr file]:file:_files' \
  '-i[xvgr/xmgr file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[frame selection interval]:time:' \
  '-tu[unit for time values]:unit:(fs ps ns us ms s)' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-mw[use mass weighting for radii of gyration]' \
  '-pc[plot average eigenvalues]' && ret=0

return ret
