#compdef w3
# _w3 — Storacha (web3.storage) command-line client (storacha/w3cli)
# upstream: https://github.com/storacha/w3cli
# Subcommands from bin.js (sade).

_w3() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_w3_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                login)
                    _arguments '1:email:' && ret=0 ;;
                up)
                    _arguments \
                        '--no-wrap[do not wrap input files in a directory]' \
                        '--hidden[include paths that start with "."]' \
                        '(-H --car)'{-H,--car}'[file is a CAR file; upload as-is]' \
                        '*:file:_files' && ret=0 ;;
                open)
                    _arguments '1:CID:' && ret=0 ;;
                rm)
                    _arguments \
                        '--shards[also remove the data shards from the store]' \
                        '1:root CID:' && ret=0 ;;
                space)
                    _arguments \
                        '1: :(create provision add ls info use)' \
                        '*:space arg:' && ret=0 ;;
                coupon)
                    _arguments \
                        '1: :(create)' \
                        '2:audience DID:' && ret=0 ;;
                bridge)
                    _arguments \
                        '1: :(generate-tokens)' \
                        '2:audience DID:' && ret=0 ;;
                delegation)
                    _arguments \
                        '1: :(create ls revoke)' \
                        '*:delegation arg:' && ret=0 ;;
                proof)
                    _arguments \
                        '1: :(add ls)' \
                        '*:proof arg:_files' && ret=0 ;;
                plan)
                    _arguments \
                        '1: :(get)' \
                        '2:email:' && ret=0 ;;
                account)
                    _arguments '1: :(ls)' && ret=0 ;;
                usage)
                    _arguments '1: :(report)' && ret=0 ;;
                can)
                    _arguments \
                        '1: :(access blob index store upload filecoin)' \
                        '*:can arg:->canargs' && ret=0
                    case $state in
                        canargs)
                            case $words[1] in
                                blob)   _arguments '1: :(add ls rm)' '*:_files' && ret=0 ;;
                                index)  _arguments '1: :(add)' '*:CID:' && ret=0 ;;
                                store)  _arguments '1: :(add ls rm)' '*:_files' && ret=0 ;;
                                upload) _arguments '1: :(add ls rm)' '*:CID:' && ret=0 ;;
                                filecoin) _arguments '1: :(info)' '*:piece CID:' && ret=0 ;;
                                access) _arguments '1: :(claim)' && ret=0 ;;
                            esac ;;
                    esac ;;
                key)
                    _arguments '1: :(create)' && ret=0 ;;
                ls|whoami|reset) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_w3_commands] )) ||
_w3_commands() {
    local -a commands
    commands=(
        'login:authenticate this agent with your email address'
        'up:upload one or more files'
        'ls:list uploads in the current space'
        'open:open a CID in the gateway in your browser'
        'rm:remove an upload from the current space'
        'whoami:print the agent DID'
        'space:manage spaces (create/provision/add/ls/info/use)'
        'coupon:create reusable space-access coupons'
        'bridge:generate API bridge tokens'
        'delegation:create / list / revoke UCAN delegations'
        'proof:add or list proofs (delegations) held by this agent'
        'usage:print usage reports'
        'plan:print or get the space billing plan'
        'account:list accounts'
        'can:low-level capability invocations (blob/index/store/upload/filecoin/access)'
        'key:create a new private agent key'
        'reset:reset local state (forget agent and proofs)'
    )
    _describe -t commands 'w3 command' commands
}

_w3 "$@"
