#compdef gitpod

# Zsh completion for gitpod (Gitpod CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'completion:generate shell completions'
      'config:manage Gitpod configuration'
      'env:manage workspace environment variables'
      'help:show help'
      'idp:interact with identity provider'
      'info:display workspace info'
      'init:create a .gitpod.yml file'
      'open:open a URL in the browser'
      'ports:manage workspace ports'
      'preview:open a URL in the IDE preview'
      'rebuild:rebuild the workspace'
      'ssh:connect via SSH'
      'tasks:interact with workspace tasks'
      'timeout:interact with workspace timeout'
      'top:display workspace resource usage'
      'url:print the workspace URL'
      'validate:validate a .gitpod.yml file'
      'version:show version'
    )
    _describe -t commands 'gitpod command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (ports)
        local -a subcmds=(
          'await:wait for port to be available'
          'expose:expose a port'
          'list:list exposed ports'
          'visibility:change port visibility'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'subcommand' subcmds && ret=0
            ;;
          (subargs)
            case ${words[1]} in
              (expose)
                _arguments '1:port' && ret=0
                ;;
              (visibility)
                _arguments \
                  '1:port' \
                  '2:visibility:(public private)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (tasks)
        _arguments '1:subcommand:(attach list stop)' && ret=0
        ;;
      (timeout)
        _arguments '1:subcommand:(extend set show)' && ret=0
        ;;
      (env)
        _arguments \
          '(-e --export)'{-e,--export}'[export as environment variable]' \
          '(-u --unset)'{-u,--unset}'[unset variable]' \
          '1:variable or name=value' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash fish powershell zsh)' && ret=0
        ;;
      (init)
        _arguments \
          '-i[interactive mode]' && ret=0
        ;;
    esac
    ;;
esac

return ret
