#compdef opennlp

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'Doccat:document categorizer'
  'DoccatTrainer:train a document categorizer'
  'DoccatEvaluator:evaluate a document categorizer'
  'DoccatCrossValidator:cross-validate a document categorizer'
  'DoccatConverter:convert document categorizer training data'
  'SimpleTokenizer:simple whitespace tokenizer'
  'TokenizerME:learnable tokenizer'
  'TokenizerTrainer:train a tokenizer'
  'TokenizerMEEvaluator:evaluate a tokenizer'
  'TokenizerCrossValidator:cross-validate a tokenizer'
  'TokenizerConverter:convert tokenizer training data'
  'DictionaryDetokenizer:detokenize using a dictionary'
  'SentenceDetector:detect sentence boundaries'
  'SentenceDetectorTrainer:train a sentence detector'
  'SentenceDetectorEvaluator:evaluate a sentence detector'
  'SentenceDetectorCrossValidator:cross-validate a sentence detector'
  'TokenNameFinder:find named entities'
  'TokenNameFinderTrainer:train a name finder'
  'TokenNameFinderEvaluator:evaluate a name finder'
  'TokenNameFinderCrossValidator:cross-validate a name finder'
  'TokenNameFinderConverter:convert name finder training data'
  'CensusDictionaryCreator:create a census dictionary'
  'POSTagger:POS tagger'
  'POSTaggerTrainer:train a POS tagger'
  'POSTaggerEvaluator:evaluate a POS tagger'
  'POSTaggerCrossValidator:cross-validate a POS tagger'
  'POSTaggerConverter:convert POS tagger training data'
  'ChunkerME:chunker'
  'ChunkerTrainerME:train a chunker'
  'ChunkerEvaluator:evaluate a chunker'
  'ChunkerCrossValidator:cross-validate a chunker'
  'ChunkerConverter:convert chunker training data'
  'Parser:parser'
  'ParserTrainer:train a parser'
  'ParserEvaluator:evaluate a parser'
  'BuildModelUpdater:update parser build model'
  'CheckModelUpdater:update parser check model'
  'TaggerModelReplacer:replace parser tagger model'
  'LanguageDetector:detect language'
  'LanguageDetectorTrainer:train a language detector'
  'LanguageDetectorEvaluator:evaluate a language detector'
  'LanguageDetectorCrossValidator:cross-validate a language detector'
  'LanguageDetectorConverter:convert language detector training data'
  'DictionaryBuilder:build a dictionary'
  'LemmatizerME:lemmatizer'
  'LemmatizerTrainerME:train a lemmatizer'
  'LemmatizerEvaluator:evaluate a lemmatizer'
  'EntityLinker:entity linker'
  'NGramLanguageModel:n-gram language model'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'opennlp tool' subcommands && ret=0
    ;;
  (args)
    _arguments \
      '-model=[model file]:file:_files -g "*.bin"' \
      '-lang=[language code]:lang:' \
      '-data=[training data]:file:_files' \
      '-encoding=[encoding]:encoding:' \
      '-params=[training parameters]:file:_files' && ret=0
    ;;
esac

return ret
