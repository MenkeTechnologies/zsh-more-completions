#compdef sfenvelope
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Menvelope.c
# Madagascar: compute data envelope or phase rotation

local ret=1

_arguments -s -S \
  'order=[Hilbert transformer order]:order' \
  'ref=[Hilbert transformer reference (0.5 < ref <= 1)]:ref' \
  'hilb=[if y, compute Hilbert transform]:hilb:(y n)' \
  'phase=[phase shift in degrees to use with hilb=y]:phase' \
  '*:RSF file:_files' && ret=0

return ret
