#compdef plotPCA
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/plotPCA.html
# deepTools: generate a PCA plot from multiBamSummary/multiBigwigSummary output

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--transpose[transpose the matrix before analysis]' \
  '--rowCenter[center rows before analysis]' \
  '(-in --corData)'{-in,--corData}'[input matrix file]:file:_files' \
  '(-o --plotFile)'{-o,--plotFile}'[output file path]:file:_files' \
  '(-l --labels)'{-l,--labels}'[sample labels]:labels:' \
  '(-T --plotTitle)'{-T,--plotTitle}'[plot title]:title:' \
  '--plotFileFormat[output file format]:format:(png pdf svg eps plotly)' \
  '--plotHeight[height in cm]:cm:' \
  '--plotWidth[width in cm]:cm:' \
  '--outFileNameData[data output file]:file:_files' \
  '--ntop[number of top variable rows used]:n:' \
  '--PCs[principal components to plot]:pcs:' \
  '--log2[log2 transform values]' \
  '--colors[plot colors]:colors:' \
  '--markers[plot marker symbols]:markers:' \
  '--version[show version]' && ret=0

return ret
