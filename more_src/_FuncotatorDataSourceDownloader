#compdef FuncotatorDataSourceDownloader
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/funcotator/FuncotatorDataSourceDownloader.java
# GATK4: download pre-packaged Funcotator data sources

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--somatic[download latest pre-packaged somatic annotation datasources]' \
  '--germline[download latest pre-packaged germline annotation datasources]' \
  '--hg38[extract data from the HG38 data sources bucket]' \
  '--hg19[extract data from the HG19 data sources bucket]' \
  '(-O --output)'{-O,--output}'=[output location for the data sources]:file:_files' \
  '--overwrite-output-file[overwrite output file if it exists already]' \
  '--validate-integrity[validate integrity of data sources after download using sha256]' \
  '--extract-after-download[extract the data sources to a sibling folder after download]' \
  '*:options:_files' && ret=0

return ret
