#compdef escript-cli
# Documentation: https://www.erlang.org/doc/apps/erts/escript_cmd.html
# Documentation: https://github.com/erlang/otp (erts/etc/common/escript.c)
# Reference accessed: 2026-05-27
# Verified: no canonical "escript-cli" upstream exists; modeled on standard Erlang/OTP escript
#           flag set documented at erlang.org/doc/apps/erts/escript_cmd.html

# escript-cli is not a canonical project (no upstream repo on GitHub matches the
# name). This completion mirrors the standard Erlang/OTP `escript` interpreter
# command line surface, which is the closest canonical tool for running Erlang
# escripts from the command line.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '-c[compile the escript regardless of the mode attribute]' \
  '-d[debug the escript (start debugger, breakpoint in main/1)]' \
  '-i[interpret the escript regardless of the mode attribute]' \
  '-s[syntactic and semantic check of the script file only]' \
  '1:escript file:_files' \
  '*::script arguments:' && ret=0

return ret
