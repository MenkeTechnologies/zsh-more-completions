#compdef teku
# Documentation: https://man.archlinux.org/search?q=teku
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--data-path=[Teku data directory]:directory:_directories' \
  '--network=[Predefined Eth2 network]:network:(mainnet sepolia holesky gnosis chiado lukso hoodi)' \
  '--ee-endpoint=[Execution client RPC URL]:url:' \
  '--ee-jwt-secret-file=[JWT secret for Engine API]:file:_files' \
  '--rest-api-interface=[REST API bind host]:host:' \
  '--rest-api-port=[REST API port]:port:' \
  '--metrics-port=[Prometheus port]:port:' \
  '--p2p-port=[LibP2P port]:port:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'beacon:Run beacon node'
      'validator:Run validator client'
      'deposit:Eth1 deposit tooling'
      'slashing-protection:Manage slashing protection DB'
      'help:Print command help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
