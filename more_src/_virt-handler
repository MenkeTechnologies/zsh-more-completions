#compdef virt-handler
# _virt-handler — KubeVirt per-node daemon (kubevirt/kubevirt)
# upstream: https://github.com/kubevirt/kubevirt
# Flags from cmd/virt-handler/virt-handler.go + pkg/service/service.go on tip.

_virt-handler() {
    _arguments \
        '--listen=[bind address]:ip:' \
        '--port=[bind port]:port:' \
        '--libvirt-uri=[libvirt connection URI]:uri:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--master=[apiserver URL override]:url:_urls' \
        '-v[klog verbosity level]:n:' \
        '--hostname-override=[node hostname override]:host:_hosts' \
        '--pod-ip-address=[pod IP address advertised to peers]:ip:' \
        '--kubevirt-share-dir=[shared dir between virt-handler and virt-launcher]:dir:_files -/' \
        '--kubevirt-private-dir=[per-host private state dir]:dir:_files -/' \
        '--kubelet-pods-dir=[kubelet pods root]:dir:_files -/' \
        '--kubelet-root=[kubelet root dir]:dir:_files -/' \
        '--ca-configmap-name=[CA configmap name]:name:' \
        '--client-cert-file=[client TLS cert]:file:_files' \
        '--client-key-file=[client TLS key]:file:_files' \
        '--migration-client-cert-file=[migration client TLS cert]:file:_files' \
        '--migration-client-key-file=[migration client TLS key]:file:_files' \
        '--tls-cert-file=[server TLS cert]:file:_files' \
        '--tls-key-file=[server TLS key]:file:_files' \
        '--externally-managed[treat certs as externally managed]' \
        '--watchdog-timeout=[watchdog timeout]:dur:' \
        '--max-devices=[max attached devices per VM]:n:' \
        '--max-metric-requests=[max parallel metric requests]:n:' \
        '--console-server-port=[console proxy port]:port:' \
        '--domain-resync-period-seconds=[libvirt domain resync interval (s)]:n:' \
        '--graceful-shutdown-seconds=[graceful shutdown timeout (s)]:n:' \
        '--enable-node-labeller=[run node labeller]:bool:(true false)' \
        '*--migration-cn-types=[asserted CN types for migration conns]:list:' \
        '--vsock-client-cert-file=[vsock client TLS cert]:file:_files' \
        '--vsock-client-key-file=[vsock client TLS key]:file:_files'
}

_virt-handler "$@"
