#compdef systemd-rfkill
# _systemd-rfkill (systemd helper that saves the soft-block state of every rfkill switch under /var/lib/systemd/rfkill/ at shutdown and restores it at next boot so wireless radio toggles persist; takes no positional arguments — invoked by systemd-rfkill.service / systemd-rfkill@.service)
# upstream: https://github.com/systemd/systemd (src/rfkill)
# Argument shape from systemd src/rfkill/rfkill.c on tip.

_systemd-rfkill() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-rfkill "$@"
