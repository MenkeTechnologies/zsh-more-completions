#compdef treebest
# Documentation: https://github.com/Ensembl/treebest
# TreeBeST: tree building guided by a species tree

local ret=1
local context state line

_arguments -C \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _values 'treebest command' \
      'nj[neighbor-joining tree reconstruction]' \
      'best[build a tree with best accuracy from an alignment]' \
      'phyml[maximum likelihood tree building]' \
      'sdi[species tree-guided duplication/loss inference]' \
      'root[root a tree]' \
      'format[reformat a tree]' \
      'filter[filter a tree]' \
      'trans[translate coding nucleotides to protein]' \
      'backtrans[back-translate a protein alignment to codons]' \
      'leaf[list the leaves of a tree]' \
      'treedist[compute distance between trees]' \
      'mfa2aln[convert multi-FASTA to alignment]' \
      'ortho[infer orthologs/paralogs]' \
      'distmat[compute a distance matrix]' \
      'pwalign[pairwise alignment]' \
      'mmerge[merge multiple trees]' \
      'export[export a tree to another format]' \
      'subtree[extract a subtree]' \
      'simulate[simulate a tree]' \
      'sortleaf[sort leaves of a tree]' \
      'estlen[estimate branch lengths]' \
      'trimpoor[trim poorly aligned leaves]' \
      'spec[generate or manipulate a species tree]' && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
