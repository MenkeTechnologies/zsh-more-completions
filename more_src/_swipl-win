#compdef swipl-win
# Documentation: https://man.archlinux.org/search?q=swipl-win
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(- *)--abi-version[show ABI version]' \
  '(- *)--arch[show architecture]' \
  '(- *)--dump-runtime-variables=-[dump link info]:format:' \
  '-o+[output executable]:file:_files' \
  '-c[compile file]' \
  '*:Prolog source file:_files -g "*.(pl|pro|prolog)"' && ret=0

return ret
