#compdef yor

# Zsh completion for yor - auto-tag infrastructure as code files with metadata

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'tag:apply tags to IaC files'
  'list-tag-groups:list available tag groups'
  'list-tags:list tags within tag groups'
  'version:display yor version'
  'help:show help for a subcommand'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'yor command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (tag)
        _arguments \
          '(-d --directory)'{-d,--directory}'[directory to tag]:dir:_files -/' \
          '--tag-groups[comma-separated list of tag groups to apply]:groups:(git code2cloud)' \
          '--skip-dirs[directories to skip]:dirs:' \
          '--skip-resource-types[resource types to skip]:types:' \
          '--skip-tags[tags to skip]:tags:' \
          '--tag-prefix[prefix to prepend to tag keys]:prefix:' \
          '--tag-group-args[extra args for tag groups]:args:' \
          '--config-file[path to yor config file]:file:_files -g "*.(yml|yaml)"' \
          '--dry-run[do not write changes]' \
          '(-o --output)'{-o,--output}'[output format]:format:(cli json)' \
          '--output-json-file[path to output JSON file]:file:_files' \
          '--custom-tagging[custom tagging plugins directory]:path:_files -/' \
          '--parsers[list of parsers to use]:parsers:(Terraform Serverless CloudFormation)' && ret=0
        ;;
      (list-tags)
        _arguments '--tag-groups[tag groups to list]:groups:' && ret=0
        ;;
      (list-tag-groups)
        ;;
    esac
    ;;
esac

return ret
