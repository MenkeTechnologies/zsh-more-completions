#compdef iqtree
# Documentation: https://man.archlinux.org/search?q=iqtree
# Reference accessed: 2026-05-16

# IQ-TREE 1.x: maximum-likelihood phylogenetic tree inference
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h)-h[show help]' \
  '(-version)-version[print version]' \
  '-s[input alignment file]:file:_files' \
  '-st[sequence type]:type:(DNA AA BIN MORPH CODON NT2AA)' \
  '-q[partition file (proportional model)]:file:_files' \
  '-spp[partition file (edge-proportional)]:file:_files' \
  '-sp[partition file (separate edge lengths)]:file:_files' \
  '-m[substitution model]:model:(JC HKY GTR WAG LG JTT)' \
  '-mset[restrict model selection set]:set:' \
  '-mrate[rate heterogeneity types]:set:(E I G R)' \
  '-cmin[minimum number of rate categories]:n:' \
  '-cmax[maximum number of rate categories]:n:' \
  '-merit[model selection criterion]:crit:(AIC AICc BIC)' \
  '-mtree[FastME branch swap during model selection]' \
  '-mredo[recompute model selection if files exist]' \
  '-b[non-parametric bootstrap replicates]:n:' \
  '-bo[only do non-parametric bootstrap]:n:' \
  '-bb[ultrafast bootstrap replicates]:n:' \
  '-bnni[optimise UFBoot trees by NNI on resampled data]' \
  '-alrt[SH-aLRT replicates]:n:' \
  '-abayes[approximate Bayes test]' \
  '-lbp[local bootstrap probabilities]:n:' \
  '-pre[output file prefix]:prefix:' \
  '-redo[redo analysis even if checkpoint exists]' \
  '-nt[number of CPU cores (AUTO to auto-detect)]:n:' \
  '-ntmax[maximum number of CPU cores]:n:' \
  '-seed[random seed]:n:' \
  '-z[user trees file for tree topology tests]:file:_files' \
  '-zb[test trees with bootstrap replicates]:n:' \
  '-zw[Weighted tests (WKH WSH)]' \
  '-au[approximately unbiased test]' \
  '-g[constraint tree file]:file:_files' \
  '-asr[ancestral sequence reconstruction]' \
  '-t[input tree file]:file:_files' \
  '-te[constraint tree (for ML param est)]:file:_files' \
  '-o[outgroup taxon]:taxon:' \
  '-keep-ident[keep identical sequences in alignment]' \
  '*::files and options:_files' && ret=0
return ret
