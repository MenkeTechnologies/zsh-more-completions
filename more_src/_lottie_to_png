#  Surface (verbatim from src/main.cpp):
#
#  Positional:
#    <path>                      Path to Lottie animation file
#                                (.json / .lottie / .tgs)
#
#  Options:
#    -o, --output PATH           Output directory (default: cwd)
#    -w, --width N               Output image width (default: 512)
#    -h, --height N              Output image height (default: 512)
#                                NOTE: overrides default -h for --help
#    -f, --fps F                 Output animation FPS (default: 0 =
#                                use source animation FPS)
#    -t, --threads N             Worker threads (default: 0 = use
#                                num CPUs)
#    -b, --background COLOR      Background color for transparent
#                                pixels: rgb(r,g,b) / rgba(r,g,b,a) /
#                                #RRGGBB / #RRGGBBAA
#
#  Companion shell wrappers (in lottie-converter/bin/):
#    lottie_to_apng.sh           Wraps to produce APNG via ffmpeg
#    lottie_to_gif.sh            Wraps to produce GIF via ffmpeg
#    lottie_to_webp.sh           Wraps to produce WebP via ffmpeg
#    lottie_to_webm.sh           Wraps to produce WebM via ffmpeg
