_lottie_to_png() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--help[show help]' \
    '(-o --output)'{-o,--output}'=[output directory]:dir:_directories' \
    '(-w --width)'{-w,--width}'=[output image width (default 512)]:width' \
    '(-h --height)'{-h,--height}'=[output image height (default 512)]:height' \
    '(-f --fps)'{-f,--fps}'=[output FPS (0 = source FPS)]:fps' \
    '(-t --threads)'{-t,--threads}'=[worker threads (0 = num CPUs)]:threads' \
    '(-b --background)'{-b,--background}'=[background color (rgb/rgba/#hex)]:color' \
    '1:Lottie animation file:_files -g "*.(json|lottie|tgs)"'
}

_lottie_to_png "$@"
