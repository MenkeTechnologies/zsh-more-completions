#compdef jj-fzf
# Documentation: https://github.com/tim-janik/jj-fzf
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# tim-janik/jj-fzf — trunk/jj-fzf option parser (lines 15–33): --version --help-bindings -h|--help
# -c +c -r +r -s --man --no-preview -x, then remaining args to jj workspace.

local ret=1

_arguments -s -S \
  '--version[print jj-fzf wrapper version]' \
  '--help-bindings[dump hotkey documentation]' \
  '(-h --help)'{-h,--help}'[usage]' \
  {-c}'[ENTER emits single commit id list]' \
  '+c[ENTER emits multiple commit ids]' \
  {-r}'[ENTER emits single change id]' \
  '+r[ENTER emits multiple change ids]' \
  {-s}'[ENTER opens revset editor]' \
  '--man[open doc/jj-fzf.1]' \
  '--no-preview[disable fzf preview]' \
  {-x}'[set -x in wrapper]' && ret=0

return ret
