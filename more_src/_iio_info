#compdef iio_info iio-info
# _iio_info — Industrial I/O context information utility (analogdevicesinc/libiio)
# upstream: https://github.com/analogdevicesinc/libiio
# Flags from utils/iio_info.c + utils/iio_common.c (getopt_long).

_iio_info() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-u --uri)'{-u+,--uri=}'[IIO context URI]:uri:' \
        '(-S --scan)'{-S+,--scan=}'[scan backends for contexts]:backends:' \
        '(-a --auto)'{-a+,--auto=}'[auto-detect a context]:backends:' \
        '(-T --timeout)'{-T+,--timeout=}'[I/O timeout (ms)]:ms:' \
        '(-d --read-debug-attr)'{-d,--read-debug-attr}'[read debug attributes]' \
        '(-n --no-read-attr)'{-n,--no-read-attr}'[skip regular attribute reads]'
}

_iio_info "$@"
