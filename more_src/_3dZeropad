#compdef 3dZeropad
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dZeropad.html
# AFNI: add/remove planes of zeros from a dataset

local ret=1

_arguments -s -S \
  '-I[add n planes of zero at Inferior edge]:n:' \
  '-S[add n planes of zero at Superior edge]:n:' \
  '-A[add n planes of zero at Anterior edge]:n:' \
  '-P[add n planes of zero at Posterior edge]:n:' \
  '-L[add n planes of zero at Left edge]:n:' \
  '-R[add n planes of zero at Right edge]:n:' \
  '-z[add n planes of zeros on each z-axis face]:n:' \
  '-RL[symmetric total of a slices R/L]:a:' \
  '-AP[symmetric total of b slices A/P]:b:' \
  '-IS[symmetric total of c slices I/S]:c:' \
  '-pad2odds[make each axis an odd number of slices]' \
  '-pad2evens[make each axis an even number of slices]' \
  '-pad2mult[make each axis a multiple of N]:N:' \
  '-mm[interpret pad counts in millimeters]' \
  '-master[match volume extents of dataset]:mset:_files' \
  '-prefix[output prefix (default zeropad)]:prefix:' \
  '*:dataset:_files' && ret=0

return ret
