#compdef pack

# Zsh completion for pack (Cloud Native Buildpacks CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--no-color[disable color output]' \
  '--quiet[show less output]' \
  '--timestamps[enable timestamps in output]' \
  '--verbose[show more output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:generate app image from source code'
      'builder:interact with builders'
      'buildpack:interact with buildpacks'
      'config:interact with config'
      'extension:interact with extensions'
      'inspect:show information about a built image'
      'manifest:interact with manifest lists'
      'new:create a new buildpack project'
      'rebase:rebase app image with updated base image'
      'registry:interact with buildpack registries'
      'report:display useful information for reporting'
      'sbom:interact with SBoM'
      'stack:interact with stacks'
      'completion:generate shell completion'
    )
    _describe -t commands 'pack command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-B+[builder image]:builder' \
          '--builder=[builder image]:builder' \
          '-b+[buildpack to use]:buildpack' \
          '--buildpack=[buildpack to use]:buildpack' \
          '--cache-image=[cache image name]:image' \
          '--clear-cache[clear image cache]' \
          '--creation-time=[set creation time]:time' \
          '--default-process=[set default process type]:type' \
          '-d+[docker host]:host' \
          '--docker-host=[docker host]:host' \
          '-e+[environment variable]:env (KEY=VALUE)' \
          '--env=[environment variable]:env (KEY=VALUE)' \
          '--env-file=[env file path]:file:_files' \
          '--network=[build network mode]:network' \
          '-p+[path to app source]:path:_files' \
          '--path=[path to app source]:path:_files' \
          '--platform=[platform to build for]:platform' \
          '--publish[publish to registry]' \
          '--pull-policy=[image pull policy]:policy:(always if-not-present never)' \
          '-r+[buildpack registry]:registry' \
          '--run-image=[run image]:image' \
          '-t+[image tag]:tag' \
          '--tag=[image tag]:tag' \
          '--trust-builder[trust builder]' \
          '--volume=[mount volume during build]:volume' \
          '--workspace=[subdirectory in source]:path' \
          '*:image name' && ret=0
        ;;
      builder)
        _arguments \
          '1:subcommand:(create inspect suggest)' \
          '*:args' && ret=0
        ;;
      buildpack)
        _arguments \
          '1:subcommand:(inspect new package pull register yank)' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
