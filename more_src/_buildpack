#compdef pack
# Documentation: https://buildpacks.io/docs/for-platform-operators/how-to/integrate-ci/pack/cli/pack_build/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Cloud Native Buildpacks pack CLI.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--no-color[disable color output]' \
  '--quiet[show less output]' \
  '--timestamps[enable timestamps in output]' \
  '--verbose[show more output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:generate app image from source code'
      'builder:interact with builders'
      'buildpack:interact with buildpacks'
      'config:interact with config'
      'extension:interact with extensions'
      'inspect:show information about a built image'
      'manifest:interact with manifest lists'
      'new:create a new buildpack project'
      'rebase:rebase app image with updated base image'
      'registry:interact with buildpack registries'
      'report:display useful information for reporting'
      'sbom:interact with SBoM'
      'stack:interact with stacks'
      'completion:generate shell completion'
    )
    _describe -t commands 'pack command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-B --builder)'{-B+,--builder=}'[builder image]:builder' \
          '(-b --buildpack)'{-b+,--buildpack=}'[buildpack to use]:buildpack' \
          '(-r --buildpack-registry)'{-r+,--buildpack-registry=}'[buildpack registry by name]:registry' \
          '--extension=[extension to use]:extension' \
          '--disable-system-buildpacks[disable system buildpacks]' \
          '--trust-builder[trust the provided builder]' \
          '--trust-extra-buildpacks[trust additional buildpacks]' \
          '(-p --path)'{-p+,--path=}'[path to app source]:path:_files' \
          '(-d --descriptor)'{-d+,--descriptor=}'[path to project descriptor]:file:_files' \
          '(-e --env)'{-e+,--env=}'[build-time environment variable]:env (KEY=VALUE)' \
          '--env-file=[env file path]:file:_files' \
          '--cache=[cache techniques]:cache' \
          '--cache-image=[cache image name]:image' \
          '--clear-cache[clear image cache before build]' \
          '(-t --tag)'{-t+,--tag=}'[additional image tag]:tag' \
          '(-D --default-process)'{-D+,--default-process=}'[default process type]:type' \
          '--publish[publish to registry]' \
          '--run-image=[run image]:image' \
          '--creation-time=[set creation time]:time' \
          '--previous-image=[previous image reference]:image' \
          '--platform=[platform to build for]:platform' \
          '--network=[build network mode]:network' \
          '--volume=[mount host volume]:volume' \
          '--docker-host=[docker daemon address]:host' \
          '--uid=[override user ID]:uid' \
          '--gid=[override group ID]:gid' \
          '--userns-host[enable user namespace isolation]' \
          '--workspace=[mount path inside builder]:path' \
          '--exec-env=[execution environment]:env' \
          '--sbom-output-dir=[export SBoM contents]:dir:_directories' \
          '--report-output-dir=[export build report]:dir:_directories' \
          '--sparse[avoid saving run-image layers]' \
          '--interactive[launch terminal UI]' \
          '--pull-policy=[image pull policy]:policy:(always if-not-present never)' \
          '--insecure-registry=[insecure registries (repeatable)]:registry' \
          '--lifecycle-image=[custom lifecycle image]:image' \
          '--pre-buildpack=[prepend buildpack to order]:buildpack' \
          '--post-buildpack=[append buildpack to order]:buildpack' \
          '*:image name' && ret=0
        ;;
      builder)
        _arguments \
          '1:subcommand:(create inspect suggest)' \
          '*:args' && ret=0
        ;;
      buildpack)
        _arguments \
          '1:subcommand:(inspect new package pull register yank)' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
