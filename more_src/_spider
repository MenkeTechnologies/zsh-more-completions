#compdef spider
# Documentation: https://lmod.readthedocs.io/en/latest/136_spider.html
# Lmod admin 'spider' tool: builds spider cache / JSON software pages from MODULEPATH

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output format]:format:(jsonSoftwarePage spider-json softwarePage)' \
  '*:MODULEPATH:_files -/' && ret=0

return ret
