#compdef dnf2 dnf5
# _dnf2 — Red Hat Fedora dnf2 CLI command-line frontend wrapping the DNF package manager Dandified YUM next-generation version of Yellowdog Updater Modified for RPM-based distributions Red Hat Fedora CentOS Stream RHEL Rocky AlmaLinux open-source originally Aleš Kozumplík now Red Hat dnf-5 reimplementation written in C++ Python uses libsolv hawkey librepo dnf5 modern CLI install reinstall upgrade upgrade-minimal downgrade remove erase autoremove search info list repolist makecache check check-update clean updateinfo group module repoquery shell distro-sync provides whatprovides history mark download deplist repograph builddep system-upgrade (Red Hat Fedora team Aleš Kozumplík Jaroslav Mracek, C++/Python); custom argparse
# upstream: https://dnf.readthedocs.io/

_dnf2() {
    local -a sub=(
        'autoremove:remove leaf packages'
        'check:check rpmdb'
        'check-update:check for updates'
        'clean:clean cache'
        'distro-sync:dist-sync packages'
        'downgrade:downgrade packages'
        'download:download packages'
        'erase:remove packages (alias)'
        'group:group operations'
        'help:show help'
        'history:show command history'
        'info:show package info'
        'install:install packages'
        'list:list packages'
        'makecache:make metadata cache'
        'mark:mark packages'
        'module:module operations'
        'needs-restarting:show services to restart'
        'offline:offline update operations'
        'reinstall:reinstall packages'
        'remove:remove packages'
        'repolist:list repos'
        'repoinfo:show repo info'
        'repoquery:query packages'
        'repository-packages:run on repo packages'
        'search:search packages'
        'shell:open DNF shell'
        'swap:swap packages'
        'system-upgrade:upgrade system to next release'
        'transaction-history:show transaction history'
        'undo:undo a transaction'
        'update:update packages'
        'updateinfo:show advisory info'
        'upgrade:upgrade packages'
        'upgrade-minimal:upgrade to minimal needed'
        'versionlock:version lock operations'
        'whatprovides:show what provides'
        'provides:show what provides (alias)'
        'mock-config:show mock config'
        'config-manager:manage config'
        'copr:Copr operations'
        'reposync:sync repo'
        'builddep:install build deps'
        'changelog:show changelog'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-y[assume yes]' \
        '--assumeyes[assume yes]' \
        '--assumeno[assume no]' \
        '-b[best]' \
        '--best[best]' \
        '--nobest[no best]' \
        '-C[cacheonly]' \
        '--cacheonly[cache only]' \
        '--refresh[refresh metadata]' \
        '-c+[config file]:file:_files -g "dnf.conf *.conf"' \
        '--config=+[file]:file:_files -g "dnf.conf *.conf"' \
        '--color=+[c]:c:(always auto never)' \
        '-d+[debug level]:n:' \
        '--debuglevel=+[N]:n:' \
        '-e+[error level]:n:' \
        '--errorlevel=+[N]:n:' \
        '--debugsolver[debug solver]' \
        '--installroot=+[dir]:dir:_files -/' \
        '--noplugins[no plugins]' \
        '--enableplugin=+[name]:str:' \
        '*--enableplugin=+[name]:str:' \
        '--disableplugin=+[name]:str:' \
        '*--disableplugin=+[name]:str:' \
        '--enablerepo=+[name]:str:' \
        '*--enablerepo=+[name]:str:' \
        '--disablerepo=+[name]:str:' \
        '*--disablerepo=+[name]:str:' \
        '--repo=+[name]:str:' \
        '*--repo=+[name]:str:' \
        '--repoid=+[name]:str:' \
        '*--repoid=+[name]:str:' \
        '--repofrompath=+[id,path]:str:' \
        '*--repofrompath=+[id,path]:str:' \
        '--enable[enable]' \
        '--disable[disable]' \
        '-x+[exclude pkg]:str:' \
        '*-x+[exclude pkg]:str:' \
        '--exclude=+[pkg]:str:' \
        '*--exclude=+[pkg]:str:' \
        '--disableexcludes=+[name]:str:' \
        '*--disableexcludes=+[name]:str:' \
        '--skip-broken[skip broken]' \
        '--allowerasing[allow erasing]' \
        '--allow-downgrade[allow downgrade]' \
        '--no-allow-downgrade[no allow downgrade]' \
        '--obsoletes[obsoletes]' \
        '--noautoremove[no autoremove]' \
        '--no-autoremove[no autoremove]' \
        '--setopt=+[opt]:str:' \
        '*--setopt=+[opt]:str:' \
        '--downloadonly[download only]' \
        '--destdir=+[dir]:dir:_files -/' \
        '--downloaddir=+[dir]:dir:_files -/' \
        '--showduplicates[show duplicates]' \
        '--bugfix[bugfix advisories]' \
        '--enhancement[enhancement advisories]' \
        '--newpackage[new package]' \
        '--security[security advisories]' \
        '--advisory=+[id]:str:' \
        '*--advisory=+[id]:str:' \
        '--advisories=+[id]:str:' \
        '*--advisories=+[id]:str:' \
        '--bz=+[id]:str:' \
        '*--bz=+[id]:str:' \
        '--cve=+[id]:str:' \
        '*--cve=+[id]:str:' \
        '--sec-severity=+[s]:s:(critical important moderate low)' \
        '*--sec-severity=+[s]:s:(critical important moderate low)' \
        '--secseverity=+[s]:s:(critical important moderate low)' \
        '--rpmverbosity=+[l]:l:(critical emergency error warn info debug)' \
        '--forcearch=+[arch]:str:' \
        '--releasever=+[v]:str:' \
        '--installroot=+[dir]:dir:_files -/' \
        '--use-host-config[use host config]' \
        '--no-gpgchecks[no GPG checks]' \
        '-R+[random wait min]:n:' \
        '--randomwait=+[N]:n:' \
        '-x[exclude]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dnf subcommand' sub ;;
        args) _arguments '*:package:' ;;
    esac
}

_dnf2 "$@"
