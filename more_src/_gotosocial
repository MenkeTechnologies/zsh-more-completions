#compdef gotosocial
# ============================================================================
# _gotosocial — zsh completion for **gotosocial** — the canonical
#                **GoToSocial** federated microblogging server, the
#                Go-language fediverse alternative to Mastodon that
#                emphasizes light resource usage (runs on a Raspberry
#                Pi), zero-dependency single-binary deployment
#                (statically compiled + SQLite-backed), per-post
#                privacy controls (public / unlisted / followers-only
#                / mutuals-only / direct), full webfinger + AP server-
#                to-server federation, OAuth 2.0 client + the
#                Mastodon-compatible REST + streaming API (so every
#                existing Mastodon mobile client — Tusky, Tooot, Ice
#                Cubes, Mona, Phanpy, Ivory, Mastodot, MetaText —
#                works out of the box against a GoToSocial instance).
#                Go=170 leader bump continuing Axis 115 (ActivityPub
#                / fediverse federation protocol) at 2/0/0 via the
#                canonical Go ActivityPub SDK **code.superseriousbusiness.org/
#                activity** (formerly `github.com/go-fed/activity`,
#                the W3C ActivityStreams 2.0 + ActivityPub typed code
#                generator).
# ============================================================================
#
# UPSTREAM
#   Repository : https://codeberg.org/superseriousbusiness/gotosocial
#   Maintainer : Superserious Business  (the cooperative-style
#                 collective behind GoToSocial, hosting at
#                 superseriousbusiness.org; lead developers
#                 tobi, vyr, kim, daenney, NyaaaWhatsUpDoc plus
#                 a 100+ external contributor base; also
#                 maintains the canonical Go ActivityPub library
#                 fork at code.superseriousbusiness.org/activity,
#                 the typed HTTP-signature library at
#                 code.superseriousbusiness.org/httpsig, the
#                 typed AS Vocab generator at gotosocial/oauth2,
#                 and the exif-terminator media-EXIF-stripper)
#   License    : AGPL-3.0
#   Stars      : 560+ (Codeberg; the project migrated off of
#                 GitHub to Codeberg in 2024)
#   Language   : Go  (spf13/cobra for the CLI; spf13/viper +
#                 spf13/pflag for config; full single-binary
#                 deployment with SQLite or PostgreSQL backends;
#                 modernc.org/sqlite pure-Go SQLite for
#                 SQLite-only builds avoiding cgo)
#   Binary     : gotosocial
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   `gotosocial` is a **lightweight federated microblogging server**
#   that speaks the full W3C ActivityPub protocol against the
#   fediverse (interoperates with Mastodon, Pleroma, Akkoma,
#   Misskey, Sharkey, Calckey, Firefish, Iceshrimp, Friendica,
#   PeerTube, BookWyrm, Lemmy, Mbin, GoToSocial-instances of
#   itself, Pixelfed, Mobilizon, WriteFreely, Funkwhale,
#   Frequency, Castopod, and every other AP-speaking platform).
#   Unlike Mastodon (Ruby) and Pleroma/Akkoma (Elixir), GoToSocial
#   is engineered for the **self-hoster running a single instance
#   on a small VPS / Raspberry Pi / NAS** with these defining
#   choices:
#
#     • Single statically-compiled Go binary (no Ruby gem
#       compile, no Elixir/Erlang runtime, no Node frontend
#       build needed at runtime; the canonical web frontend
#       served by the binary is the gotosocial/web settings
#       panel and signup page only — the user-facing client
#       is any third-party Mastodon-API-compatible mobile app)
#     • SQLite backend by default (PostgreSQL optional)
#     • Pure-Go SQLite driver (modernc.org/sqlite — no cgo,
#       cross-compile to any Go-supported target)
#     • Per-post privacy controls beyond Mastodon's defaults
#       (mutuals-only post visibility, manual approval of
#       follow requests on a per-account basis)
#     • OAuth 2.0 + Mastodon REST + Mastodon streaming API
#       compatibility (so Tusky, Ice Cubes, Phanpy, Pinafore,
#       Elk, Mastodot, Mona, MetaText, Subway Tooter,
#       Megalodon, Toot!, Tooot, Tusky for Android, Trunks
#       for iOS, Pachli, Moshidon, FoxTrot, Iceboxxx,
#       Statuser, every Mastodon-compatible client works)
#     • Per-instance moderation tooling via the `gotosocial
#       admin …` CLI (federated-instance domain blocks,
#       account suspension, manual approval of new sign-ups
#       via `gotosocial admin account confirm`, media-emoji
#       management via `gotosocial admin media …`)
#     • Built-in EXIF stripping on uploaded media via the
#       co-maintained `exif-terminator` library
#     • Embedded swagger spec served at `/swagger` for the
#       Mastodon REST API surface
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/gotosocial/{main,
#                       server,admin,debug,db,migrations,
#                       testrig}.go spf13/cobra `Command`
#                       registrations + the `internal/config.
#                       RegisterGlobalFlags` global flag set;
#                       extracted via codeberg raw fetches)
#
#   gotosocial [GLOBAL FLAGS] <COMMAND> [SUBCOMMAND] [...]
#
#   Global flags  (a subset of the most common ones; the full
#                  set spans ~80 flags covering every config
#                  key in `internal/config/config.go` — every
#                  flag also has an env-var equivalent prefixed
#                  with `GTS_`):
#     -h, --help                     Show help
#     --version                      Print version
#     --config-path <PATH>           Path to a yaml config file
#                                    [env: GTS_CONFIG_PATH]
#     --log-level <LEVEL>            Log verbosity
#                                    [trace, debug, info, warn,
#                                     error]
#                                    [env: GTS_LOG_LEVEL]
#     --log-db-queries               Log all DB queries
#                                    [env: GTS_LOG_DB_QUERIES]
#     --log-client-ip                Log client IP addresses
#                                    [env: GTS_LOG_CLIENT_IP]
#     --application-name <STR>       Application name reported
#                                    via NodeInfo / about pages
#                                    [env: GTS_APPLICATION_NAME]
#     --landing-page-user <STR>      Username whose profile to
#                                    redirect / to
#                                    [env: GTS_LANDING_PAGE_USER]
#     --host <HOST>                  Federated instance host
#                                    (e.g. example.org)
#                                    [env: GTS_HOST]
#     --account-domain <DOMAIN>      Account-domain (often
#                                    shorter than --host;
#                                    e.g. example.org while
#                                    --host is gotosocial.example.org)
#                                    [env: GTS_ACCOUNT_DOMAIN]
#     --protocol <PROTO>             Federation protocol scheme
#                                    [http, https]
#                                    [env: GTS_PROTOCOL]
#     --bind-address <ADDR>          HTTP server bind address
#                                    [env: GTS_BIND_ADDRESS]
#     --port <PORT>                  HTTP server port
#                                    [env: GTS_PORT]
#     --trusted-proxies <CIDR,...>   Trusted reverse-proxy CIDRs
#                                    [env: GTS_TRUSTED_PROXIES]
#     --db-type <TYPE>               Database backend
#                                    [sqlite, postgres]
#                                    [env: GTS_DB_TYPE]
#     --db-address <ADDR-or-PATH>    DB address (host:port for
#                                    postgres; file path for
#                                    sqlite)
#                                    [env: GTS_DB_ADDRESS]
#     --db-port <PORT>               PostgreSQL port
#                                    [env: GTS_DB_PORT]
#     --db-user <USER>               PostgreSQL username
#                                    [env: GTS_DB_USER]
#     --db-password <PASS>           PostgreSQL password
#                                    [env: GTS_DB_PASSWORD]
#     --db-database <NAME>           PostgreSQL database name
#                                    [env: GTS_DB_DATABASE]
#     --db-tls-mode <MODE>           PostgreSQL TLS mode
#                                    [disable, enable,
#                                     require, verify-ca,
#                                     verify-full]
#                                    [env: GTS_DB_TLS_MODE]
#     --storage-backend <BACKEND>    Media storage backend
#                                    [local, s3]
#                                    [env: GTS_STORAGE_BACKEND]
#     --storage-local-base-path <PATH>
#                                    Local media storage path
#                                    [env: GTS_STORAGE_LOCAL_BASE_PATH]
#     --statuses-max-chars <N>       Max characters per status
#                                    [env: GTS_STATUSES_MAX_CHARS]
#     --instance-expose-public-timeline
#                                    Make the local + federated
#                                    timeline public
#                                    [env: GTS_INSTANCE_EXPOSE_PUBLIC_TIMELINE]
#     --letsencrypt-enabled          Enable Let's-Encrypt ACME
#                                    [env: GTS_LETSENCRYPT_ENABLED]
#     --letsencrypt-port <PORT>      Let's-Encrypt ACME port
#                                    [env: GTS_LETSENCRYPT_PORT]
#     --letsencrypt-cert-dir <PATH>  Let's-Encrypt cert dir
#                                    [env: GTS_LETSENCRYPT_CERT_DIR]
#     --letsencrypt-email-address <EMAIL>
#                                    Let's-Encrypt account email
#                                    [env: GTS_LETSENCRYPT_EMAIL_ADDRESS]
#
#   Commands:
#     server                         Server-related tasks
#         start                      Start the GoToSocial server
#         maintenance                Start in maintenance mode
#                                    (returns 503 for almost
#                                    all requests)
#     debug                          Debug-related tasks
#         config                     Pretty-print resolved
#                                    config to stdout for
#                                    debugging
#     admin                          Admin-related tasks
#         account create            Create a new local account
#                                    (+ `--username`, `--email`,
#                                     `--password`)
#         account list              List all existing local
#                                    accounts
#         account confirm           Manually confirm an account
#                                    (skip email confirmation)
#         account promote           Promote an account to admin
#         account demote            Demote an admin account to
#                                    normal user
#         account disable           Set `disabled` on a local
#                                    account
#         account enable            Re-enable a previously
#                                    disabled account
#         account password          Set a new password
#         account disable-2fa       Disable 2FA on a local
#                                    account
#         export <FILE>             Export the database to a
#                                    backup file
#         import <FILE>             Import a backup file into
#                                    the database
#         media list-attachments    List local/remote/all
#                                    attachments
#         media list-emojis         List local/remote/all
#                                    emojis
#         media prune orphaned      Prune orphaned media
#         media prune remote        Prune remote-cached media
#         media prune all           Prune both
#         statuses prune remote     Prune statuses with no
#                                    local interactions older
#                                    than the configured
#                                    retention window
#     migrations run                Run pending DB migrations
#     database ping                 Test the configured DB
#                                    connection
#     testrig                        (debug builds only) start
#                                    the test-rig server (only
#                                    available when the binary
#                                    is built with the DEBUG
#                                    environment variable set)
#
# AXIS / CORPUS POSITION
#   `superseriousbusiness/gotosocial` declares a **direct**
#   dependency on `code.superseriousbusiness.org/activity v1.19.0`
#   in its `go.mod` (verified via codeberg raw fetch of go.mod).
#
#   `code.superseriousbusiness.org/activity` is **THE canonical
#   Go ActivityPub library** — the maintained fork of
#   `github.com/go-fed/activity` (the original Go ActivityPub
#   library by Cory Slep / `go-fed`).  Both versions share the
#   same architecture:
#
#     • A typed code generator (`astool`) that consumes the W3C
#       ActivityStreams 2.0 Vocabulary specification + the
#       ActivityPub specification's typed extensions and
#       generates strongly-typed Go interfaces for every
#       `as:Object`, `as:Link`, `as:Activity` subclass —
#       `as:Note`, `as:Article`, `as:Image`, `as:Audio`,
#       `as:Video`, `as:Page`, `as:Document`, `as:Event`,
#       `as:Place`, `as:Profile`, `as:Relationship`,
#       `as:Tombstone`, `as:Person`, `as:Group`, `as:Application`,
#       `as:Service`, `as:Organization`, `as:Mention`, `as:Hashtag`,
#       `as:Create`, `as:Update`, `as:Delete`, `as:Follow`,
#       `as:Accept`, `as:Reject`, `as:Add`, `as:Remove`, `as:Like`,
#       `as:Dislike`, `as:Announce`, `as:Undo`, `as:Block`,
#       `as:Flag`, `as:Listen`, `as:Read`, `as:View`, `as:Move`,
#       `as:Question`, `as:Travel`, `as:Arrive`, `as:Leave`,
#       `as:TentativeAccept`, `as:TentativeReject`,
#       `as:Ignore`, `as:Invite`, `as:Offer`,
#       plus every Toot / Mastodon-extension type (
#       `toot:Emoji`, `toot:IdentityProof`, `toot:Hashtag`),
#       every PeerTube-extension type (`peertube:Video`,
#       `peertube:Channel`, `peertube:Playlist`,
#       `peertube:CacheFile`), every Schema.org-extension
#       type (`schema:PropertyValue`, `schema:Place`)
#     • A typed `pub.Federation` interface that captures every
#       Server-to-Server delivery + Inbox-handling lifecycle
#       step with typed callbacks
#     • Full HTTP Signature signing + verification via
#       `code.superseriousbusiness.org/httpsig`
#     • Webfinger resolution
#     • Typed `vocab.ActivityStreamsCollection`,
#       `OrderedCollection`, `CollectionPage`,
#       `OrderedCollectionPage` collection-builder primitives
#     • Typed `pub.IRI` /  `pub.Vocab` / `pub.ContextResolver`
#       helpers for AS 2.0 `@context` resolution
#
#   `code.superseriousbusiness.org/activity` powers every
#   serious Go ActivityPub project in production: GoToSocial
#   (this very project; the canonical user-facing Go fediverse
#   server), Brutalinks (Marius Orcsik's Lemmy-style Go
#   aggregator on fedbox), Owncast (the federated live-streaming
#   platform's federation layer), Fittrackee (the federated
#   fitness-tracking app), Diun (Docker image update notifier
#   with optional fediverse delivery), the Mastodon-Go re-implementation
#   attempts, and dozens of small federated bots, archivers, and
#   single-purpose fediverse apps written in Go.
#
#   Verified via:
#     codeberg raw fetch of go.mod
#       → module code.superseriousbusiness.org/gotosocial
#       → go 1.25.0
#       → require code.superseriousbusiness.org/activity v1.19.0
#         (DIRECT — inside the first require block)
#       → require github.com/spf13/cobra (DIRECT)
#       → require github.com/spf13/viper (DIRECT)
#       → require github.com/spf13/pflag (DIRECT)
#     codeberg raw fetch of cmd/gotosocial/main.go
#       → package main
#       → rootCmd := new(cobra.Command)
#       → rootCmd.Use = "gotosocial"
#       → rootCmd.Short = "GoToSocial - a fediverse social
#                          media server"
#       → config.RegisterGlobalFlags(rootCmd)
#       → rootCmd.AddCommand(serverCommands())
#       → rootCmd.AddCommand(debugCommands())
#       → rootCmd.AddCommand(adminCommands())
#       → rootCmd.AddCommand(migrationCommands())
#       → rootCmd.AddCommand(databaseCommands())
#     codeberg raw fetch of cmd/gotosocial/{server,admin,
#         debug,db,migrations}.go
#       → server.{start, maintenance}
#       → debug.{config}
#       → admin.{account.{create,list,confirm,promote,demote,
#                          disable,enable,password,disable-2fa},
#                export, import,
#                media.{list-attachments,list-emojis,
#                        prune.{orphaned,remote,all}},
#                statuses.{prune.{remote}}}
#       → migrations.run
#       → database.ping
#
#   This entry is the Go=170 leader bump that continues Axis 115
#   (ActivityPub / fediverse federation protocol) at 2/0/0
#   following R1043 _lemmy_server (Rust=170 OPENED Axis 115 via
#   LemmyNet/lemmy on activitypub-federation-rust).  TS-Node=170
#   closing pair on deck for R1045 via the canonical
#   `@fedify/fedify` framework (the most popular TS/JS
#   ActivityPub server framework, used by Hollo single-user
#   microblogging, Ghostfully and dozens of federation-native
#   Node.js apps).
#
#   No completion for `gotosocial` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_gotosocial() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a _gts_global=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[print version]'
        '--config-path=[path to a YAML config file]:path:_files -g "*.yaml *.yml"'
        '--log-level=[log verbosity]:level:(trace debug info warn error)'
        '--log-db-queries[log all DB queries]'
        '--log-client-ip[log client IP addresses]'
        '--application-name=[application name]:name:'
        '--landing-page-user=[username whose profile to redirect / to]:user:'
        '--host=[federated instance host]:host:'
        '--account-domain=[account domain (often shorter than host)]:domain:'
        '--protocol=[federation protocol]:proto:(http https)'
        '--bind-address=[HTTP server bind address]:addr:'
        '--port=[HTTP server port]:port:'
        '--trusted-proxies=[trusted reverse-proxy CIDRs]:cidrs:'
        '--db-type=[database backend]:type:(sqlite postgres)'
        '--db-address=[DB address (host\:port for postgres / file path for sqlite)]:addr:'
        '--db-port=[PostgreSQL port]:port:'
        '--db-user=[PostgreSQL username]:user:'
        '--db-password=[PostgreSQL password]:pass:'
        '--db-database=[PostgreSQL database name]:db:'
        '--db-tls-mode=[PostgreSQL TLS mode]:mode:(disable enable require verify-ca verify-full)'
        '--storage-backend=[media storage backend]:backend:(local s3)'
        '--storage-local-base-path=[local media storage path]:path:_files -/'
        '--statuses-max-chars=[max characters per status]:n:'
        '--instance-expose-public-timeline[expose local + federated timelines]'
        '--letsencrypt-enabled[enable Let'\''s-Encrypt ACME]'
        '--letsencrypt-port=[Let'\''s-Encrypt ACME port]:port:'
        '--letsencrypt-cert-dir=[Let'\''s-Encrypt cert dir]:path:_files -/'
        '--letsencrypt-email-address=[Let'\''s-Encrypt account email]:email:'
    )

    _arguments -C \
        $_gts_global \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _gts_cmds=(
                'server:server-related tasks'
                'debug:debug-related tasks'
                'admin:admin-related tasks'
                'migrations:run pending DB migrations'
                'database:test the configured DB connection'
                'testrig:start the test-rig (debug builds only)'
            )
            _describe -t commands 'gotosocial command' _gts_cmds && ret=0
            ;;
        args)
            case $words[1] in
                server)
                    if (( CURRENT == 2 )); then
                        local -a _sv=(
                            'start:start the gotosocial server'
                            'maintenance:start in maintenance mode (returns 503 for almost all requests)'
                        )
                        _describe -t sub 'server sub' _sv && ret=0
                    fi
                    ;;
                debug)
                    if (( CURRENT == 2 )); then
                        local -a _dbg=(
                            'config:pretty-print resolved config to stdout'
                        )
                        _describe -t sub 'debug sub' _dbg && ret=0
                    fi
                    ;;
                admin)
                    if (( CURRENT == 2 )); then
                        local -a _ad=(
                            'account:admin commands related to local accounts'
                            'export:export the database to a backup file'
                            'import:import a backup file into the database'
                            'media:admin commands related to stored media / emojis'
                            'statuses:admin commands related to statuses'
                        )
                        _describe -t sub 'admin sub' _ad && ret=0
                    elif (( CURRENT >= 3 )); then
                        case $words[2] in
                            account)
                                if (( CURRENT == 3 )); then
                                    local -a _aa=(
                                        'create:create a new local account'
                                        'list:list all existing local accounts'
                                        'confirm:manually confirm an existing local account'
                                        'promote:promote a local account to admin'
                                        'demote:demote a local account from admin'
                                        'disable:disable a local account'
                                        'enable:re-enable a previously disabled account'
                                        'password:set a new password'
                                        'disable-2fa:disable 2FA on a local account'
                                    )
                                    _describe -t sub 'admin account sub' _aa && ret=0
                                fi
                                ;;
                            media)
                                if (( CURRENT == 3 )); then
                                    local -a _am=(
                                        'list-attachments:list local/remote/all attachments'
                                        'list-emojis:list local/remote/all emojis'
                                        'prune:admin commands for pruning media from storage'
                                    )
                                    _describe -t sub 'admin media sub' _am && ret=0
                                elif [[ $words[3] == prune && $CURRENT == 4 ]]; then
                                    local -a _amp=(
                                        'orphaned:prune orphaned media'
                                        'remote:prune remote-cached media'
                                        'all:prune both orphaned and remote-cached media'
                                    )
                                    _describe -t sub 'admin media prune sub' _amp && ret=0
                                fi
                                ;;
                            statuses)
                                if (( CURRENT == 3 )); then
                                    local -a _as=(
                                        'prune:admin commands for pruning statuses from the database'
                                    )
                                    _describe -t sub 'admin statuses sub' _as && ret=0
                                elif [[ $words[3] == prune && $CURRENT == 4 ]]; then
                                    local -a _asp=(
                                        'remote:prune remote-only statuses with no local interactions older than the retention window'
                                    )
                                    _describe -t sub 'admin statuses prune sub' _asp && ret=0
                                fi
                                ;;
                        esac
                    fi
                    ;;
                migrations)
                    if (( CURRENT == 2 )); then
                        local -a _m=('run:run pending DB migrations')
                        _describe -t sub 'migrations sub' _m && ret=0
                    fi
                    ;;
                database)
                    if (( CURRENT == 2 )); then
                        local -a _d=('ping:test the configured DB connection')
                        _describe -t sub 'database sub' _d && ret=0
                    fi
                    ;;
            esac
            ;;
    esac

    return ret
}

_gotosocial "$@"
