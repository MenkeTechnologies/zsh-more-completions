#compdef bwa-mem2 bwa-mem2.avx bwa-mem2.avx2 bwa-mem2.avx512bw bwa-mem2.sse41 bwa-mem2.sse42
# _bwa-mem2 — Vasimuddin Md Sanchit Misra bwa-mem2 next-generation BWA-MEM short read alignment with SIMD vectorization (bwa-mem2 team, C++); custom argparse
# upstream: https://github.com/bwa-mem2/bwa-mem2

_bwa-mem2() {
    local -a sub=(
        'index:build BWT index'
        'mem:run BWA-MEM alignment'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bwa-mem2 subcommand' sub ;;
        args)
            case $words[1] in
                index) _arguments \
                    '-p+[prefix]:str:' \
                    '*:reference fasta:_files -g "*.fa *.fasta *.fna"' ;;
                mem) _arguments \
                    '-t+[threads]:n:' \
                    '-k+[min seed length]:n:' \
                    '-w+[band width]:n:' \
                    '-d+[off-diagonal X-dropoff]:n:' \
                    '-r+[trigger re-seeding]:f:' \
                    '-y+[seed occurrence]:n:' \
                    '-c+[skip seeds with occ > N]:n:' \
                    '-D+[drop chains shorter than F]:f:' \
                    '-W+[min chain weight]:n:' \
                    '-m+[max iterations of mate-SW]:n:' \
                    '-S[skip mate rescue]' \
                    '-P[skip pairing]' \
                    '-A+[matching score]:n:' \
                    '-B+[mismatch penalty]:n:' \
                    '-O+[gap open penalties]:str:' \
                    '-E+[gap extension penalties]:str:' \
                    '-L+[5p/3p clipping penalty]:str:' \
                    '-U+[unpaired read penalty]:n:' \
                    '-x+[read type]:t:(pacbio ont2d intractg)' \
                    '-p[paired interleaved]' \
                    '-R+[read group header]:str:' \
                    '-H+[header insertions]:str:' \
                    '-j[treat ALT contigs as primary]' \
                    '-T+[min score to output]:n:' \
                    '-a[output all alignments]' \
                    '-C[append FASTA/FASTQ comment]' \
                    '-V[output 5p/3p clipping]' \
                    '-Y[use soft clipping for supplementary]' \
                    '-M[mark shorter split hits as secondary]' \
                    '-o+[output sam file]:file:_files -g "*.sam *.bam"' \
                    '-K+[chunk size]:n:' \
                    '-v+[verbose level]:n:' \
                    '-h+[soft clipping for sup alignments]:n:' \
                    '*:reads:_files -g "*.fq *.fq.gz *.fastq *.fastq.gz *.fa *.fasta"' ;;
            esac
            ;;
    esac
}

_bwa-mem2 "$@"
