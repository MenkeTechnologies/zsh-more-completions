#compdef schemaspy
# Documentation: https://man.archlinux.org/search?q=schemaspy
# Reference accessed: 2026-05-16

_arguments -s \
  '-t=[database type]:type:' \
  '-db=[database name]:db:' \
  '-host=[host]:host:_hosts' \
  '-port=[port]:port:' \
  '-u=[user]:user:_users' \
  '-p=[password]:password:' \
  '-pfp[prompt for password]' \
  '-dp=[driver path]:path:_files' \
  '-connprops=[connection props]:props:' \
  '-o=[output dir]:dir:_files -/' \
  '-s=[schema]:schema:' \
  '-cat=[catalog]:catalog:' \
  '-all[process all schemas]' \
  '-schemas=[schemas]:schemas:' \
  '-schemata=[schemas]:schemas:' \
  '-schemaSpec=[schema regex]:regex:' \
  '-meta=[schema meta XML]:file:_files' \
  '-i=[table inclusions regex]:regex:' \
  '-I=[table exclusions regex]:regex:' \
  '-X=[column exclusions regex]:regex:' \
  '-x=[indirect column exclusions regex]:regex:' \
  '-noviews[skip views]' \
  '-noexportedkeys[skip exported keys]' \
  '-norows[no rows]' \
  '-noimplied[no implied relationships]' \
  '-nohtml[no HTML]' \
  '-gv=[Graphviz install dir]:dir:_files -/' \
  '-imageformat=[image format]:fmt:(svg png)' \
  '-lq[low quality]' \
  '-renderer=[renderer]:renderer:' \
  '-vizjs[use vizjs]' \
  '-css=[stylesheet]:file:_files' \
  '-font=[font name]:font:' \
  '-fontsize=[font size]:n:' \
  '-maxdet=[max detailed tables]:n:' \
  '-rankdirbug[work around graphviz rankdir bug]' \
  '-template=[template dir]:dir:_files -/' \
  '-degree=[diagram depth]:n:' \
  '-rails[Rails inflection]' \
  '-sso[single sign-on]' \
  '-debug[debug logging]' \
  '-l[license summary]' \
  '-dbThreads=[db threads]:n:' \
  '-dbHelp[db type help]' \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '(- *)--help[show help]'
