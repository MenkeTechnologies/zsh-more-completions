#compdef ag
# Documentation: ag --help on The Silver Searcher 2.2.0
# Source: ggreer/the_silver_searcher — code-searching tool similar to ack, with focus on speed.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--ackmate[print results in AckMate-parseable format]' \
    '(-A --after)'{-A,--after=}'[print lines after match]:lines:' \
    '(-B --before)'{-B,--before=}'[print lines before match]:lines:' \
    '--break[print newlines between matches in different files]' \
    '--nobreak[suppress newlines between matches in different files]' \
    '(-c --count)'{-c,--count}'[only print the number of matches in each file]' \
    '--color[print color codes in results]' \
    '--nocolor[suppress color codes]' \
    '--color-line-number=[color codes for line numbers]:code:' \
    '--color-match=[color codes for result match numbers]:code:' \
    '--color-path=[color codes for path names]:code:' \
    '--column[print column numbers in results]' \
    '--filename[print file names]' \
    '--nofilename[suppress file names]' \
    '(-H --heading)'{-H,--heading}'[print file names before each file matches]' \
    '--noheading[suppress file-name headings]' \
    '(-C --context)'{-C,--context=}'[print lines before and after matches]:lines:' \
    '--group[same as --break --heading]' \
    '--nogroup[same as --nobreak --noheading]' \
    '(-g --filename-pattern)'{-g,--filename-pattern=}'[print filenames matching PATTERN]:pattern:' \
    '(-l --files-with-matches)'{-l,--files-with-matches}'[print only filenames that contain matches]' \
    '(-L --files-without-matches)'{-L,--files-without-matches}'[print only filenames that do not contain matches]' \
    '--print-all-files[print headings for all files searched]' \
    '--numbers[print line numbers]' \
    '--nonumbers[suppress line numbers]' \
    '(-o --only-matching)'{-o,--only-matching}'[print only the matching part of the lines]' \
    '--print-long-lines[print matches on very long lines]' \
    '--passthrough[print all stream lines even if they do not match]' \
    '--silent[suppress all log messages, including errors]' \
    '--stats[print stats (files scanned, time taken, etc)]' \
    '--stats-only[print stats and nothing else]' \
    '--vimgrep[print results like vims :vimgrep /pattern/g would]' \
    '(-0 --null --print0)'{-0,--null,--print0}'[separate filenames with NUL]' \
    '(-a --all-types)'{-a,--all-types}'[search all files (excludes hidden + ignored)]' \
    '(-D --debug)'{-D,--debug}'[ridiculous debugging]' \
    '--depth=[max directory depth to search]:n:' \
    '(-f --follow)'{-f,--follow}'[follow symlinks]' \
    '(-F --fixed-strings)'{-F,--fixed-strings}'[alias for --literal]' \
    '(-G --file-search-regex)'{-G,--file-search-regex=}'[limit search to filenames matching PATTERN]:pattern:' \
    '--hidden[search hidden files (obeys .*ignore files)]' \
    '(-i --ignore-case)'{-i,--ignore-case}'[match case insensitively]' \
    '*--ignore=[ignore files/dirs matching PATTERN]:pattern:' \
    '*--ignore-dir=[alias for --ignore]:dir:_files -/' \
    '(-m --max-count)'{-m,--max-count=}'[skip rest of file after N matches]:n:' \
    '--one-device[do not follow links to other devices]' \
    '(-p --path-to-ignore)'{-p,--path-to-ignore=}'[use .ignore file at PATH]:path:_files' \
    '(-Q --literal)'{-Q,--literal}'[do not parse PATTERN as regex]' \
    '(-s --case-sensitive)'{-s,--case-sensitive}'[match case sensitively]' \
    '(-S --smart-case)'{-S,--smart-case}'[case-insensitive unless PATTERN has uppercase]' \
    '--search-binary[search binary files for matches]' \
    '(-t --all-text)'{-t,--all-text}'[search all text files (excludes hidden)]' \
    '(-u --unrestricted)'{-u,--unrestricted}'[search all files (ignore .ignore/.gitignore)]' \
    '(-U --skip-vcs-ignores)'{-U,--skip-vcs-ignores}'[ignore VCS ignore files]' \
    '(-v --invert-match)'{-v,--invert-match}'[invert match]' \
    '(-w --word-regexp)'{-w,--word-regexp}'[only match whole words]' \
    '(-W --width)'{-W,--width=}'[truncate match lines after N chars]:n:' \
    '(-z --search-zip)'{-z,--search-zip}'[search contents of gzip-compressed files]' \
    '(- *)--list-file-types[list supported file types]' \
    '(- *)--version[display version]' \
    '(- *)--help[display help]' \
    '1:pattern:' \
    '*:path:_files' \
    && ret=0

return ret
