#compdef gaze
# Documentation: https://man.archlinux.org/search?q=gaze
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[clear screen before each run]' \
  '-r[restart command on file changes]' \
  '-t[throttle interval in milliseconds]:ms:' \
  '*:command:_command_names' && ret=0

return ret
