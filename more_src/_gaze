#compdef gaze
# Documentation: https://github.com/wtetsu/gaze
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gaze: blazing-fast file watcher that re-runs commands on changes.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)--version[show version]' \
  '-c+[command(s) to execute on change]:command:' \
  '-r[restart mode (SIGTERM before next run)]' \
  '-t+[timeout in milliseconds (SIGTERM after)]:ms:' \
  '-f+[YAML configuration file]:file:_files' \
  '-v[verbose mode]' \
  '-q[quiet mode]' \
  '-y[print default YAML configuration]' \
  '--color=[color output]:mode:(0 1)' \
  '*:command:_command_names' && ret=0

return ret
