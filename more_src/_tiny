#compdef tiny
# Documentation: https://github.com/osa1/tiny
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Upstream README documents --config <path>; positional args are server
# address patterns to filter which configured servers tiny connects to.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--config=[path to config file]:file:_files' \
  '*:server pattern:' && ret=0

return ret
