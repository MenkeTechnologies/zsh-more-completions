#compdef tiny
# Documentation: https://man.archlinux.org/search?q=tiny
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[config file]:file:_files -g "*.yml *.yaml"' \
  '--no-clean[do not clean log buffers on disconnect]' \
  '--debug-log=[log debug events to file]:file:_files' \
  '*:server name:' && ret=0

return ret
