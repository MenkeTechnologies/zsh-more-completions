#compdef dune-cli
# _dune-cli — OCaml dune composable build system CLI alias (ocaml team, OCaml); cmdliner
# upstream: https://github.com/ocaml/dune

_dune-cli() {
    local -a sub=(
        'build:build the targets'
        'cache:dune cache management'
        'clean:clean current project'
        'coq:coq related commands'
        'describe:describe the project'
        'diagnostics:list error/warnings'
        'exec:execute a command in the project context'
        'external-lib-deps:list external library deps'
        'fmt:format source code'
        'format-dune-file:format dune file'
        'init:initialize project component'
        'install:install released packages'
        'installed-libraries:print available installed libraries'
        'monitor:monitor RPC progress'
        'ocaml:OCaml related commands'
        'ocaml-merlin:start a merlin configuration server'
        'ocaml-merlin-reader:start a merlin reader'
        'ocaml-top:run ocaml toplevel'
        'opam-cli:create opam dev install description'
        'pkg:package management commands'
        'pkg:lock:create lockfile'
        'pkg:update:update lockfile'
        'pkg:print-solver-env:print solver env'
        'pkg:outdated:show outdated packages'
        'pkg:validate-lockdir:validate lock dir'
        'pkg:tools:install:install dev tools'
        'pkg:tools:uninstall:uninstall dev tools'
        'pkg:tools:print-source:print source'
        'pkg:list:list packages in lock dir'
        'pkg:fetch-lock-dir:fetch lock dir'
        'pkg:add:add package to lock dir'
        'pkg:remove:remove package from lock dir'
        'printenv:print the environment'
        'promote:promote files'
        'promotion:diff:show promotion diff'
        'promotion:apply:apply promotion'
        'rpc:dune-rpc commands'
        'rpc:status:show rpc status'
        'rpc:ping:ping rpc'
        'rpc:requests:list available rpc requests'
        'rules:dump rules'
        'runtest:run tests'
        'shutdown:shutdown dune watch mode'
        'subst:substitute watermarks in source tree'
        'targets:list available targets'
        'test:alias of runtest'
        'tools:builtin tool commands'
        'uninstall:uninstall released packages'
        'upgrade:upgrade jbuild files to dune files'
        'utop:load library in utop'
        'help:show help'
        'completion:generate completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--debug-dependency-path[debug dependency path]' \
        '--debug-cache=+[cache debug]:c:(fetch hit miss shared)' \
        '--debug-load-dir[debug load dir]' \
        '--debug-digests[debug digests]' \
        '--debug-findlib[debug findlib]' \
        '--display=+[display]:d:(progress short verbose quiet tui)' \
        '--workspace=+[workspace file]:file:_files -g "dune-workspace*"' \
        '--root=+[root dir]:dir:_files -/' \
        '--terminal-persistence=+[terminal persistence]:p:(preserve clear-on-rebuild clear-on-rebuild-and-flush-history)' \
        '--profile=+[profile]:p:(dev release)' \
        '-p+[profile]:p:(dev release)' \
        '--build-dir=+[build dir]:dir:_files -/' \
        '-j+[jobs]:n:' \
        '--cache=+[cache mode]:c:(disabled enabled)' \
        '--cache-storage-mode=+[storage mode]:s:(copy hardlink auto)' \
        '--config-file=+[config file]:file:_files' \
        '--diff-command=+[diff command]:str:' \
        '--auto-promote[auto promote]' \
        '--ignore-promoted-rules[ignore promoted rules]' \
        '--store-orig-source-dir[store orig source dir]' \
        '--always-show-command-line[always show command line]' \
        '--no-print-directory[no print directory]' \
        '--instrument-with=+[backends]:str:' \
        '--release[release mode]' \
        '--dev[dev mode]' \
        '--no-config[no config]' \
        '--no-buffer[no buffer]' \
        '--force[force]' \
        '-f[force]' \
        '--watch[watch mode]' \
        '-w[watch mode]' \
        '--passive-watch-mode[passive watch mode]' \
        '--passive[passive watch]' \
        '--wait-for-filesystem-clock[wait fs clock]' \
        '--keep-going[keep going on errors]' \
        '-k[keep going on errors]' \
        '--default-target=+[default target]:str:' \
        '--print-metrics[print metrics]' \
        '--trace-file=+[trace file]:file:_files' \
        '--require-dune-project-file[require dune-project]' \
        '--for-release-of-packages=+[packages]:str:' \
        '--release[release mode]' \
        '--store-digest-preimage[store digest preimage]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dune subcommand' sub ;;
        args)
            case $words[1] in
                build|runtest|test|clean) _arguments \
                    '*:target:' \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--force[force]' \
                    '-f[force]' \
                    '--auto-promote[auto promote]' \
                    '--diff-command=+[diff command]:str:' \
                    '--no-buffer[no buffer]' \
                    '--profile=+[profile]:p:(dev release)' \
                    '-p+[profile]:p:(dev release)' \
                    '--display=+[display]:d:(progress short verbose quiet tui)' ;;
                exec) _arguments \
                    '*:command:' \
                    '--context=+[context]:str:' \
                    '--no-build[no build first]' \
                    '--watch[watch]' \
                    '-w[watch]' ;;
                init) _arguments \
                    '1:kind:(executable library project)' \
                    '2:name:' \
                    '3:path:_files -/' \
                    '--public[public]' \
                    '--libs=+[libraries csv]:str:' \
                    '--ppx=+[ppx]:str:' \
                    '--inline-tests[inline tests]' \
                    '--kind=+[kind]:k:(executable library project)' ;;
                install|uninstall) _arguments \
                    '*:package:' \
                    '--prefix=+[prefix]:dir:_files -/' \
                    '--libdir=+[libdir]:dir:_files -/' \
                    '--mandir=+[mandir]:dir:_files -/' \
                    '--docdir=+[docdir]:dir:_files -/' \
                    '--etcdir=+[etcdir]:dir:_files -/' \
                    '--destdir=+[destdir]:dir:_files -/' \
                    '--dry-run[dry run]' ;;
                fmt) _arguments '*:target:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_dune-cli "$@"
