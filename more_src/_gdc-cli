#compdef gdc-cli gdc2
# _gdc-cli — GCC D Project gdc-cli CLI command-line frontend wrapping the GDC GNU D Compiler front-end for the D programming language as part of the GNU Compiler Collection GCC open-source written in D and C originally David Friedman now GCC D Iain Buclaw the GCC frontend for the D programming language using the official DMD frontend uses GCC backend share GCC infrastructure GCC-optimizations precision native code generation cross compile gcc-extensions multilib targets gcj gccd gdmd dpkg-d glibc -fall-instantiations -fno-debug -frelease -fdebug -frelease -funittest -fchecks -fextern-std -fpreview -frevert -fdoc -fdoc-inc -fdoc-dir -fdoc-file -fdump-d-original -fmodule-file -fonly -fproperty -fno-property -ftransition (GCC D Project David Friedman Iain Buclaw, D/C); custom argparse
# upstream: https://gdcproject.org/

_gdc-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c[compile only]' \
        '-o+[output]:file:_files' \
        '-O+[level]:n:(0 1 2 3 g s)' \
        '-O0[no optimize]' \
        '-O1[O1]' \
        '-O2[O2]' \
        '-O3[O3]' \
        '-Os[Os]' \
        '-Og[debug optimize]' \
        '-g[debug info]' \
        '-fdebug[d debug]' \
        '-frelease[release]' \
        '-funittest[unit tests]' \
        '-fchecks=+[k=v]:str:' \
        '*-fchecks=+[k=v]:str:' \
        '-fcheckaction=+[a]:a:(C D halt context)' \
        '-fdoc[generate D docs]' \
        '-fdoc-inc=+[file]:file:_files' \
        '-fdoc-dir=+[dir]:dir:_files -/' \
        '-fdoc-file=+[file]:file:_files' \
        '-fH[generate D headers]' \
        '-fHd=+[dir]:dir:_files -/' \
        '-fHf=+[file]:file:_files' \
        '-fX[generate JSON]' \
        '-fXf=+[file]:file:_files' \
        '-fall-instantiations[all instances]' \
        '-fno-druntime[no druntime]' \
        '-fno-moduleinfo[no moduleinfo]' \
        '-fno-bounds-check[no bounds check]' \
        '-fno-emit-moduleinfo[no emit moduleinfo]' \
        '-fno-builtin[no builtin]' \
        '-fproperty[property]' \
        '-fno-property[no property]' \
        '-frevert=+[id]:str:' \
        '*-frevert=+[id]:str:' \
        '-fpreview=+[id]:str:' \
        '*-fpreview=+[id]:str:' \
        '-ftransition=+[id]:str:' \
        '*-ftransition=+[id]:str:' \
        '-fdebug=+[id]:str:' \
        '*-fdebug=+[id]:str:' \
        '-fversion=+[id]:str:' \
        '*-fversion=+[id]:str:' \
        '-fdump-d-original=+[file]:file:_files' \
        '-fdump-d-cpp=+[file]:file:_files' \
        '-fextern-std=+[std]:s:(c++98 c++11 c++14 c++17 c++20)' \
        '-fonly=+[name]:str:' \
        '-fmain[generate main]' \
        '-fno-main[no main]' \
        '-fdebug-c[debug C output]' \
        '-fno-defer-globals[no defer globals]' \
        '-fno-emit-debug-frame[no debug frame]' \
        '-fmodule-file=+[k=v]:str:' \
        '*-fmodule-file=+[k=v]:str:' \
        '-J+[string import dir]:dir:_files -/' \
        '*-J+[string import dir]:dir:_files -/' \
        '-I+[include dir]:dir:_files -/' \
        '*-I+[include dir]:dir:_files -/' \
        '-L+[ldopt]:str:' \
        '*-L+[ldopt]:str:' \
        '-l+[lib]:str:' \
        '*-l+[lib]:str:' \
        '-Wall[all warnings]' \
        '-Wextra[extra warnings]' \
        '-Werror[warn as error]' \
        '-Wno-warnings[no warnings]' \
        '-fmessage-length=+[N]:n:' \
        '-fdiagnostics-color=+[v]:v:(always never auto)' \
        '-static[static link]' \
        '-shared[shared library]' \
        '-static-libphobos[static libphobos]' \
        '-defaultlib=+[name]:str:' \
        '-debuglib=+[name]:str:' \
        '*:d file:_files -g "*.d *.di *.o *.a"'
}

_gdc-cli "$@"
