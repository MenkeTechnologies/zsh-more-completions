#compdef hgLoadOutJoined
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: load new-style RepeatMasker .out files into the database

local ret=1

_arguments -s -S \
  '-tabFile=[do not load database, just create tab file]:file:_files' \
  '-table=[use a different suffix than the default rmskOutBaseline]:name' \
  '1:database:' \
  '*:out file:_files -g "*.out"' && ret=0

return ret
