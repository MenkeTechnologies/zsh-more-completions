#compdef hydra_persist
# Documentation: https://man.archlinux.org/search?q=hydra_persist
# Reference accessed: 2026-05-16

# hydra_persist: persistent Hydra process manager (MPICH)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--port=[port to listen on]:port:' \
  '--debug[debug]' \
  '*::hydra_persist args:_files' && ret=0
return ret
