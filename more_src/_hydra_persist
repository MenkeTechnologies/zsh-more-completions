#compdef hydra_persist
# Documentation: https://github.com/pmodels/mpich/blob/main/doc/wiki/how_to/Using_the_Hydra_Process_Manager.md
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hydra_persist: persistent Hydra process manager (MPICH)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--port=[port to listen on]:port:' \
  '--debug[debug]' \
  '*::hydra_persist args:_files' && ret=0
return ret
