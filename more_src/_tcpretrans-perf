#compdef tcpretrans-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/tcpretrans.8
# show TCP retransmits, with address and other details (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-l[trace TCP tail loss probes]' \
  '-s[print stack traces]' && ret=0

return ret
