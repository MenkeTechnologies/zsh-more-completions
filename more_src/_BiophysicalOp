#compdef BiophysicalOp
# Documentation: https://raw.githubusercontent.com/senbox-org/optical-toolbox/master/opttbx-biophysical/src/main/java/eu/esa/opt/biophysical/BiophysicalOp.java
# ESA SNAP gpt BiophysicalOp operator - retrieve Sentinel-2 biophysical variables

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-Psensor=[the sensor]:sensor:(S2A S2B S2C)' \
  '-Presolution=[the output resolution]:resolution:(10 20 60)' \
  '-PcomputeLAI=[compute LAI (Leaf Area Index)]:flag:(true false)' \
  '-PcomputeFapar=[compute FAPAR]:flag:(true false)' \
  '-PcomputeFcover=[compute FVC (Fraction of Vegetation Cover)]:flag:(true false)' \
  '-PcomputeCab=[compute Cab (Chlorophyll content in the leaf)]:flag:(true false)' \
  '-PcomputeCw=[compute Cw (Canopy Water Content)]:flag:(true false)' \
  '*:graph xml:_files' && ret=0

return ret
