#compdef vdb_tool
# Documentation: https://manpages.ubuntu.com/manpages/questing/man1/vdb_tool.1.html
# vdb_tool - perform a user-defined sequence of OpenVDB tasks

local ret=1

_arguments -s -S \
  '(-help -h)'{-help,-h}'[print documentation for available actions and exit]' \
  '-version[print version information and exit]' \
  '-verbose[print timing information to the terminal]' \
  '-quiet[disable printing to the terminal]' \
  '-debug[print debugging information to the terminal]' \
  '-examples[print examples to the terminal and terminate]' \
  '-default[define default values used by subsequent actions]' \
  '(-config -c)'{-config,-c}'[import and process one or more configuration files]:file:_files' \
  '-read[read .vdb, mesh (obj/ply/stl) or point cloud files]:file:_files' \
  '-write[write .vdb, mesh (obj/ply/stl/abc) or image files]:file:_files' \
  '-mesh2ls[convert a mesh to a level set]' \
  '-ls2mesh[convert a narrow-band level set to a polygon mesh]' \
  '*::action:' && ret=0

return ret
