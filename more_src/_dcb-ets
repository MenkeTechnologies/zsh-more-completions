#compdef dcb-ets
# Documentation: https://man.archlinux.org/man/dcb-ets.8.en
# dcb ets - manage Enhanced Transmission Selection

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'dcb ets command' \
      'show[display ETS configuration]' 'set[modify ETS configuration]' \
      'dev[network device]' 'willing[accept peer configuration]' \
      'ets-cap[supported ETS traffic classes]' 'cbs[CBS algorithm support]' \
      'tc-tsa[transmission selection algorithm mapping]' \
      'reco-tc-tsa[recommended TSA mapping]' \
      'tc-bw[transmit bandwidth distribution]' \
      'reco-tc-bw[recommended transmit bandwidth]' \
      'pg-bw[receive bandwidth allocation]' \
      'prio-tc[priority to traffic class mapping]' \
      'reco-prio-tc[recommended priority mapping]' && ret=0
    ;;
esac

return ret
