#compdef dud
# Documentation: https://man.archlinux.org/search?q=dud
# Reference accessed: 2026-05-16

# kevin-hanselman/dud src/cmd/root.go (cobra); Homebrew: Formula/d/dud.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '--profile[enable CPU profiling to dud.pprof]' \
  '--trace[enable runtime trace to dud.trace]' \
  '(-v)'{-v,--verbose}'[verbose]' \
  '(-h)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'dud command' compadd -- \
    init checkout commit completion config fetch graph pull push run stage status checksum version
  ;;
rest)
  case $line[1] in
    completion)
      _arguments '2:shell:(bash zsh fish)' && ret=0
      ;;
    config)
      _arguments '2:action:(get set)' '*::key or value:_default' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
