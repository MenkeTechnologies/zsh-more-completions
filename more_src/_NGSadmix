#compdef NGSadmix
# Documentation: http://www.popgen.dk/software/index.php/NgsAdmixTutorial
# NGSadmix: estimate individual admixture proportions from genotype likelihoods

local ret=1

_arguments -s -S \
  '-likes+[input genotype likelihoods in Beagle format]:file:_files' \
  '-K+[number of assumed ancestral populations]:int' \
  '-minMaf+[minimum minor allele frequency threshold]:float' \
  '-seed+[random seed for reproducibility]:int' \
  '-o+[output file prefix]:prefix' \
  '-P+[number of CPU cores for parallel processing]:int' && ret=0

return ret
