#compdef karmada
# _karmada — Karmada Authors karmada CLI launcher for the Karmada Kubernetes Multi-Cloud Multi-Cluster orchestration system supporting federated propagation override-policy scheduling cluster registration member-cluster join unjoin reschedule failover cordon uncordon top operations from the control-plane (Karmada team, Go); cobra
# upstream: https://karmada.io/

_karmada() {
    local -a sub=(
        'init:init karmada control plane'
        'deinit:tear down karmada control plane'
        'join:join a member cluster'
        'unjoin:unjoin a member cluster'
        'register:register an agent cluster'
        'unregister:unregister an agent cluster'
        'addons:addon management'
        'config:configuration'
        'options:show options'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--karmada-data=+[dir]:dir:_files -/' \
        '--namespace=+[name]:str:' \
        '-n+[namespace]:str:' \
        '--karmada-controller-manager-image=+[image]:str:' \
        '--karmada-scheduler-image=+[image]:str:' \
        '--karmada-aggregated-apiserver-image=+[image]:str:' \
        '--karmada-webhook-image=+[image]:str:' \
        '--karmada-apiserver-replicas=+[N]:n:' \
        '--karmada-scheduler-replicas=+[N]:n:' \
        '--karmada-webhook-replicas=+[N]:n:' \
        '--cluster-namespace=+[ns]:str:' \
        '--cluster-zone=+[zone]:str:' \
        '--cluster-region=+[region]:str:' \
        '--cluster-provider=+[name]:str:' \
        '--insecure-skip-tls-verify[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'karmada subcommand' sub ;;
        args)
            case $words[1] in
                join|unjoin|register|unregister) _arguments '*:cluster name:' ;;
                addons) _arguments '1:op:(install uninstall list)' '*:addon:' ;;
            esac
            ;;
    esac
}

_karmada "$@"
