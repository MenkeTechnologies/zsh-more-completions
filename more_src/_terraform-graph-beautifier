#compdef terraform-graph-beautifier
# Documentation: https://man.archlinux.org/search?q=terraform-graph-beautifier
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-exclude=[resource types to omit]:types:' \
  '-version[show version]' \
  '*:terraform graph flags passthrough: _default'
