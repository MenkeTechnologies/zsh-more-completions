#compdef scout
# Documentation: https://github.com/nccgroup/ScoutSuite/blob/master/ScoutSuite/core/cli_parser.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a common_args=(
  '(-f --force)'{-f,--force}'[overwrite existing files]'
  '(-l --local)'{-l,--local}'[use local data previously fetched and re-run analysis]'
  '--max-rate=[maximum API requests per second]:rate:'
  '--debug[print stack trace on exceptions]'
  '--quiet[disable CLI output]'
  '--logfile=[additional output to specified file]:file:_files'
  '--update[reload existing data, overwrite only in-scope data]'
  '--ruleset=[set of rules for analysis]:ruleset:_files'
  '--no-browser[do not auto-open report in browser]'
  '--max-workers=[maximum threads used]:n:'
  '--report-dir=[path for Scout report]:dir:_files -/'
  '--report-name=[name of Scout report]:name:'
  '--timestamp=[timestamp added to report name]:ts:'
  '*--services=[in-scope services]:service:'
  '--list-services[list available services]'
  '*--skip=[out-of-scope services]:service:'
  '--exceptions=[exception file for analysis]:file:_files'
  '--result-format=[result format]:format:(json sqlite)'
  '--serve[serve result database on server]'
  '--host=[server listening address]:address:'
  '--port=[server listening port]:port:'
)

local -a providers=(
  'aws:scan Amazon Web Services'
  'azure:scan Microsoft Azure'
  'gcp:scan Google Cloud Platform'
  'aliyun:scan Alibaba Cloud'
  'oci:scan Oracle Cloud Infrastructure'
  'kubernetes:scan a Kubernetes cluster'
  'digitalocean:scan DigitalOcean Cloud'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:provider:->providers' \
  '*::arg:->args' && ret=0

case $state in
  (providers)
    _describe -t providers 'cloud provider' providers && ret=0
    ;;
  (args)
    case ${line[1]} in
      (aws)
        _arguments \
          $common_args \
          '(-p --profile)'{-p+,--profile=}'[named profile]:profile:' \
          '--access-keys[run with access keys]' \
          '--access-key-id=[AWS Access Key ID]:id:' \
          '--secret-access-key=[AWS Secret Access Key]:key:' \
          '--session-token=[AWS Session Token]:token:' \
          '(-r --regions)*'{-r+,--regions=}'[regions to scan]:region:' \
          '(-xr --exclude-regions)*'{-xr+,--exclude-regions=}'[regions to exclude]:region:' \
          '--ip-ranges=[config files with known IP ranges]:file:_files' \
          '--ip-ranges-name-key=[key containing CIDR display name]:key:' && ret=0
        ;;
      (azure)
        _arguments \
          $common_args \
          '(-c --cli)'{-c,--cli}'[use configured azure-cli credentials]' \
          '--user-account[run with user credentials]' \
          '(-u --username)'{-u+,--username=}'[Azure account username]:user:' \
          '(-p --password)'{-p+,--password=}'[Azure account password]:password:' \
          '--user-account-browser[browser-based user authentication (MFA-friendly)]' \
          '(-s --service-principal)'{-s,--service-principal}'[Azure Service Principal]' \
          '--client-id=[service principal client ID]:id:' \
          '--client-secret=[service principal client secret]:secret:' \
          '--file-auth=[credential file for Service Principal]:file:_files' \
          '(-m --msi)'{-m,--msi}'[Managed Service Identity]' \
          '--tenant=[tenant (Directory) ID]:id:' \
          '--subscriptions=[subscription IDs]:ids:' \
          '--all-subscriptions[scan all accessible subscriptions]' && ret=0
        ;;
      (gcp)
        _arguments \
          $common_args \
          '(-u --user-account)'{-u,--user-account}'[run with Google Account]' \
          '(-s --service-account)'{-s+,--service-account=}'[Google Service Account credentials file]:file:_files -g "*.json"' \
          '--project-id=[GCP Project ID to scan]:id:' \
          '--folder-id=[GCP Folder ID to scan]:id:' \
          '--organization-id=[GCP Organization ID to scan]:id:' \
          '--all-projects[scan all accessible projects]' && ret=0
        ;;
      (aliyun)
        _arguments \
          $common_args \
          '--access-keys[run with user credentials]' \
          '(-k --access-key-id)'{-k+,--access-key-id=}'[Aliyun Access Key ID]:id:' \
          '(-s --access-key-secret)'{-s+,--access-key-secret=}'[Aliyun Access Key Secret]:secret:' && ret=0
        ;;
      (oci)
        _arguments \
          $common_args \
          '(-p --profile)'{-p+,--profile=}'[profile name]:profile:' && ret=0
        ;;
      (kubernetes)
        _arguments \
          $common_args \
          '(-c --cluster-provider)'{-c+,--cluster-provider=}'[cluster provider]:provider:(aks eks gke)' \
          '--config-file=[kube-config file name]:file:_files' \
          '--context=[cluster context to scan]:context:' \
          '--do-not-persist-config[do not update config file on changes]' \
          '--subscription-id=[Azure subscription ID (AKS only)]:id:' && ret=0
        ;;
      (digitalocean)
        _arguments \
          $common_args \
          '(-t --token)'{-t+,--token=}'[DigitalOcean token]:token:' \
          '--access_key=[Spaces Access Key ID]:id:' \
          '--access_secret=[Spaces Secret Access Key]:secret:' && ret=0
        ;;
    esac
    ;;
esac

return ret
