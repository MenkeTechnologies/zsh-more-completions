#compdef watpeak
# Documentation: https://www.ccp4.ac.uk/html/watpeak.html
# CCP4: select difference-map peaks as candidate water molecules

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'PEAKS[input peaks file]:peaks:_files' \
  'XYZOUT[output coordinate file]:output:_files' \
  '*:keyword:(BFACTOR CELL CHAIN DISTANCE HETATOMONLY SYMMETRY TITLE REMARK END)' && ret=0

return ret
