#compdef apk-info-cli
# Documentation: https://man.archlinux.org/search?q=apk-info-cli
# Reference accessed: 2026-05-16
# Source: cargo binstall apk-info-cli@1.0.11
# Probed via: completion zsh
# Repository: https://github.com/delvinru/apk-info

autoload -U is-at-least

_apk-info-cli() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_apk-info-cli_commands" \
"*::: :->apk-info-cli" \
&& ret=0
    case $state in
    (apk-info-cli)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:apk-info-cli-command-$line[1]:"
        case $line[1] in
            (show)
_arguments "${_arguments_options[@]}" : \
'-s[Show information about signatures]' \
'--sigs[Show information about signatures]' \
'-j[Show output as jsonl]' \
'--json[Show output as jsonl]' \
'-h[Print help]' \
'--help[Print help]' \
'*::paths -- One or more paths to APK files to inspect:_files' \
&& ret=0
;;
(extract)
_arguments "${_arguments_options[@]}" : \
'-o+[Output folder (default\: ./<filename>.unp)]:OUTPUT:_files' \
'--output=[Output folder (default\: ./<filename>.unp)]:OUTPUT:_files' \
'*-f+[A regular expressions for extracting specific files inside zip archive]:FILES:_default' \
'*--files=[A regular expressions for extracting specific files inside zip archive]:FILES:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'*::paths -- One or more paths to APK files to extract:_files' \
&& ret=0
;;
(x)
_arguments "${_arguments_options[@]}" : \
'-o+[Output folder (default\: ./<filename>.unp)]:OUTPUT:_files' \
'--output=[Output folder (default\: ./<filename>.unp)]:OUTPUT:_files' \
'*-f+[A regular expressions for extracting specific files inside zip archive]:FILES:_default' \
'*--files=[A regular expressions for extracting specific files inside zip archive]:FILES:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'*::paths -- One or more paths to APK files to extract:_files' \
&& ret=0
;;
(axml)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':path -- Path to the AndroidManifest.xml file or APK containing it:_files' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The shell to generate completion for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_apk-info-cli__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:apk-info-cli-help-command-$line[1]:"
        case $line[1] in
            (show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(extract)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(axml)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_apk-info-cli_commands] )) ||
_apk-info-cli_commands() {
    local commands; commands=(
'show:Show basic information about apk file' \
'extract:Unpack apk files as zip archive' \
'x:Unpack apk files as zip archive' \
'axml:Read and pretty-print binary AndroidManifest.xml' \
'completion:Generate shell completion' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'apk-info-cli commands' commands "$@"
}
(( $+functions[_apk-info-cli__axml_commands] )) ||
_apk-info-cli__axml_commands() {
    local commands; commands=()
    _describe -t commands 'apk-info-cli axml commands' commands "$@"
}
(( $+functions[_apk-info-cli__completion_commands] )) ||
_apk-info-cli__completion_commands() {
    local commands; commands=()
    _describe -t commands 'apk-info-cli completion commands' commands "$@"
}
(( $+functions[_apk-info-cli__extract_commands] )) ||
_apk-info-cli__extract_commands() {
    local commands; commands=()
    _describe -t commands 'apk-info-cli extract commands' commands "$@"
}
(( $+functions[_apk-info-cli__help_commands] )) ||
_apk-info-cli__help_commands() {
    local commands; commands=(
'show:Show basic information about apk file' \
'extract:Unpack apk files as zip archive' \
'axml:Read and pretty-print binary AndroidManifest.xml' \
'completion:Generate shell completion' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'apk-info-cli help commands' commands "$@"
}
(( $+functions[_apk-info-cli__help__axml_commands] )) ||
_apk-info-cli__help__axml_commands() {
    local commands; commands=()
    _describe -t commands 'apk-info-cli help axml commands' commands "$@"
}
(( $+functions[_apk-info-cli__help__completion_commands] )) ||
_apk-info-cli__help__completion_commands() {
    local commands; commands=()
    _describe -t commands 'apk-info-cli help completion commands' commands "$@"
}
(( $+functions[_apk-info-cli__help__extract_commands] )) ||
_apk-info-cli__help__extract_commands() {
    local commands; commands=()
    _describe -t commands 'apk-info-cli help extract commands' commands "$@"
}
(( $+functions[_apk-info-cli__help__help_commands] )) ||
_apk-info-cli__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'apk-info-cli help help commands' commands "$@"
}
(( $+functions[_apk-info-cli__help__show_commands] )) ||
_apk-info-cli__help__show_commands() {
    local commands; commands=()
    _describe -t commands 'apk-info-cli help show commands' commands "$@"
}
(( $+functions[_apk-info-cli__show_commands] )) ||
_apk-info-cli__show_commands() {
    local commands; commands=()
    _describe -t commands 'apk-info-cli show commands' commands "$@"
}

if [ "$funcstack[1]" = "_apk-info-cli" ]; then
    _apk-info-cli "$@"
else
    compdef _apk-info-cli apk-info-cli
fi
