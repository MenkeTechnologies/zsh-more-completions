#compdef ai-codex
# Documentation: https://www.npmjs.com/package/ai-codex
# Reference accessed: 2026-05-23
# Verified: npx ai-codex --help.

# Zsh completion for ai-codex - compact codebase index for AI assistants

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output directory]:directory:_directories' \
  '*--include[directories to scan]:directory:_directories' \
  '*--exclude[directories to skip]:directory:_directories' \
  '--schema[Prisma schema path]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress output for CI/hooks]' && ret=0

return ret
