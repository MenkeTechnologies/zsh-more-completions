# Source: cargo binstall ztn@1.3.4
# Probed via: completions zsh
# Repository: https://github.com/amit-devb/zetten

autoload -U is-at-least

_zetten() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_zetten_commands" \
"*::: :->ztn" \
&& ret=0
    case $state in
    (ztn)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:zetten-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::template -- Name of the template to use:_default' \
&& ret=0
;;
(run)
_arguments "${_arguments_options[@]}" : \
'-w+[Number of parallel workers]:WORKERS:_default' \
'--workers=[Number of parallel workers]:WORKERS:_default' \
'*-k+[Pass variables\: --k key=value]:KV:_default' \
'*--key-value=[Pass variables\: --k key=value]:KV:_default' \
'-t+[Filter tasks by a specific tag (e.g., --tag ci)]:TAG:_default' \
'--tag=[Filter tasks by a specific tag (e.g., --tag ci)]:TAG:_default' \
'--dry-run[Preview the execution plan without running commands]' \
'-h[Print help]' \
'--help[Print help]' \
'*::tasks -- Names of the tasks to run:_default' \
&& ret=0
;;
(tasks)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(watch)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'*::tasks:_default' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(graph)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash zsh fish)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_zetten__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:zetten-help-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(run)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(tasks)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(watch)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(graph)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_zetten_commands] )) ||
_zetten_commands() {
    local commands; commands=(
'init:Initialize a new Zetten (ztn) project' \
'run:Run tasks in parallel with caching' \
'tasks:List all available tasks' \
'watch:Watch for changes and re-run tasks' \
'doctor:Check project health' \
'graph:Visualize the task dependency graph' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'zetten commands' commands "$@"
}
