#compdef hatchling

# hatchling: pyproject build backend for Hatch
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'build:run build hook'
  'dep:dependency commands'
  'metadata:print metadata'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-t[target build type]:type:(wheel sdist app)' \
  '--target=[target build type]:type:(wheel sdist app)' \
  '-d[directory to build in]:dir:_files -/' \
  '--directory=[directory to build in]:dir:_files -/' \
  '--clean[clean before build]' \
  '--clean-only[clean only]' \
  '--clean-hooks-after[clean hooks after]' \
  '--hooks-only[only run hooks]' \
  '-l[list available targets]' \
  '--list[list available targets]' \
  '--no-hooks[skip hooks]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'hatchling command' commands && ret=0 ;;
esac
return ret
