#compdef rustcat rcat

_rustcat() {
    local -a commands
    commands=(
        'listen:Listen for incoming connections'
        'connect:Initiate a connection or reverse shell'
    )

    if (( CURRENT == 2 )); then
        _describe -t commands 'rustcat commands' commands
    else
        case $words[2] in
            listen)
                _arguments -s \
                    '(-i --interactive)'{-i,--interactive}'[Enable interactive mode]' \
                    '(-b --binary)'{-b,--binary}'[Enable binary mode]' \
                    '(-u --udp)'{-u,--udp}'[Use UDP]' \
                    '(-p --port)'{-p,--port}'[Specify port]:port'
                ;;
            connect)
                _arguments -s \
                    '(-s --shell)'{-s,--shell}'[Specify shell]:shell:(bash sh cmd.exe)' \
                    '(-u --udp)'{-u,--udp}'[Use UDP]' \
                    '*:address'
                ;;
        esac
    fi
}

_rustcat "$@"
