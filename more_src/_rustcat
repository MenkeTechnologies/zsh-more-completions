#compdef rustcat rcat
# Documentation: https://github.com/robiot/rustcat
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (src/input.rs clap definitions).

_rustcat() {
    local -a commands
    commands=(
        'listen:Listen for incoming connections'
        'connect:Initiate a connection or reverse shell'
    )

    if (( CURRENT == 2 )); then
        _describe -t commands 'rustcat commands' commands
    else
        case $words[2] in
            listen)
                _arguments -s \
                    '(-i --interactive -l --local-interactive)'{-i,--interactive}'[enable interactive mode]' \
                    '(-l --local-interactive -i --interactive)'{-l,--local-interactive}'[enable local interactive mode]' \
                    '(-b --block-signals)'{-b,--block-signals}'[block exit signals like CTRL-C]' \
                    '(-e --exec)'{-e,--exec}'[execute command upon receiving connection]:cmd' \
                    '*:host:_hosts'
                ;;
            connect)
                _arguments -s \
                    '(-s --shell)'{-s,--shell}'[specify the shell to use]:shell:(bash sh cmd.exe powershell)' \
                    '*:host:_hosts'
                ;;
        esac
    fi
}

_rustcat "$@"
