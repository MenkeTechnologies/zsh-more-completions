#compdef clusterawsadm

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'ami:manage AMIs'
  'bootstrap:set up credentials and IAM roles'
  'controller:manage controller credentials/operations'
  'eks:EKS-specific functionality and addons'
  'gc:configure garbage collection for AWS resources'
  'resource:work with AWS resources'
  'version:display version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --v)'{-v,--v=}'[log verbosity]:level:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'clusterawsadm subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (ami)
        _values 'ami action' 'copy' 'encrypt-copy' 'list' && ret=0
        ;;
    esac
    ;;
esac

return ret
