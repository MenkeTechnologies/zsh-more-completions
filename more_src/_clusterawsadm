#compdef clusterawsadm
# Documentation: https://cluster-api-aws.sigs.k8s.io/clusterawsadm/clusterawsadm.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'ami:manage AMIs (copy/encrypt-copy/list)'
  'bootstrap:set up IAM resources and credentials'
  'controller:management cluster controller operations'
  'eks:EKS-specific commands and addons'
  'gc:configure external garbage collection for AWS resources'
  'resource:work with AWS resources'
  'version:display version info'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --v)'{-v,--v=}'[log verbosity level]:level:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'clusterawsadm subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (ami)
        _values 'ami action' 'copy' 'encrypt-copy' 'list' && ret=0
        ;;
      (bootstrap)
        _values 'bootstrap action' 'iam' 'credentials' && ret=0
        ;;
    esac
    ;;
esac

return ret
