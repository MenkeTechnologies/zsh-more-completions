_cup() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '(-s --socket)'{-s,--socket}'=[Docker socket path (default: auto-detect /var/run/docker.sock or DOCKER_HOST)]:socket:_files' \
        '(-c --config-path)'{-c,--config-path}'=[config file path (TOML/YAML/JSON; default: ~/.config/cup/config.toml)]:path:_files' \
        '(-d --debug)'{-d,--debug}'[enable debug logging (per-registry-request tracing)]' \
        '--refresh[force refresh (ignore cached results from a previous run)]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'check:one-shot CLI mode — check Docker images for updates and print a formatted table'
                'serve:long-running mode — start the embedded web UI + cron-scheduled periodic refresh with webhook notifications'
            )
            _describe -t commands 'cup command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                check)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '(-i --icons)'{-i,--icons}'[enable Unicode icons in the formatted table output]' \
                        '(-r --raw)'{-r,--raw}'[output JSON instead of formatted text (for piping to jq / consumption by other tools)]' \
                        '*:image reference (e.g. nginx:1.27.0; omit to check ALL images Docker is currently running):' && ret=0
                    ;;
                serve)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '(-p --port)'{-p,--port}'=[HTTP server port for the web UI (default 8000)]:port:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_cup "$@"
