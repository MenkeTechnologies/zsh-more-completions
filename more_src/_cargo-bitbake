#compdef cargo-bitbake
# Documentation: https://man.archlinux.org/search?q=cargo-bitbake
# Reference accessed: 2026-05-16

# https://github.com/cardoe/cargo-bitbake — emit Yocto/meta-rust BitBake recipes

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-q --quiet)'{-q,--quiet}'[silence cargo output]' \
  '*'{-v,--verbose}'[increase cargo verbosity]' \
  '(-R --reproducible)'{-R,--reproducible}'[emit exact git refs for SRC_URI]' \
  '(-l --legacy-overrides)'{-l,--legacy-overrides}'[use old-style PV_append syntax]' && return 0
