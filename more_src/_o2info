#compdef o2info
# Documentation: https://www.mankier.com/1/o2info
# Show OCFS2 filesystem information

local ret=1

_arguments -s -S \
  '(-C --cluster-coherent)'{-C,--cluster-coherent}'[force cluster coherency when querying a mounted filesystem]' \
  '--fs-features[show enabled filesystem features]' \
  '--volinfo[show label, UUID, block/cluster sizes, node slots]' \
  '--mkfs[show filesystem info formatted for mkfs.ocfs2]' \
  '--freeinode[show allocated and free inode counts per slot]' \
  '--freefrag=[report free space fragmentation]:chunksize:' \
  '--space-usage[show disk space consumption]' \
  '--filestat[show extended stat with cluster counts]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:device or path:_files' && ret=0

return ret
