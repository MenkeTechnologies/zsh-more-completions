#compdef bdftops
# Convert a BDF bitmap font to a scalable Type 1 outline (.gsf) font
# Documentation: https://web.mit.edu/ghostscript/www/Fonts.htm
# Reference accessed: 2026-06-21

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input BDF file:_files -g "*.(bdf|BDF)"' \
  '*:AFM files / gsf output / fontname / UniqueID / XUID / encoding:_files' && ret=0

return ret
