#compdef condor_tail

# condor_tail: tail stdout/stderr of a running condor job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-name[schedd]:name:' \
  '-pool[pool]:pool:' \
  '-f[follow]' \
  '-no-stdout[do not show stdout]' \
  '-stderr[show stderr]' \
  '-maxbytes[max bytes]:n:' \
  '-auto-retry[retry until job runs]' \
  '*:jobid:' && ret=0
return ret
