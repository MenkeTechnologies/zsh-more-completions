#compdef condor_tail
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_tail.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-pool[central manager host[:port]]:pool:' \
  '-name[schedd name]:schedd:' \
  '-debug[debug output]' \
  '-maxbytes[max bytes per access]:n:' \
  '-no-stdout[do not tail stdout]' \
  '-stderr[tail stderr instead of stdout]' \
  '-auto-retry[retry every 2 seconds until job runs]' \
  '-follow[continuously tail until interrupted]' \
  '-f[continuously tail until interrupted]' \
  '*:jobid:' && ret=0
return ret
