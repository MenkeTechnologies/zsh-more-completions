#compdef maas-region-controller

# MAAS region controller: web API + workers for an availability region
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'createadmin:create the initial admin'
  'changepassword:change a user'\''s password'
  'configauth:configure authentication backend'
  'apikey:print API key for user'
  'createcustomsshkey:create a custom SSH key'
  'createsuperuser:create superuser (admin)'
  'set_up_dns:set up DNS for this controller'
  'support-dump:bundle support diagnostics'
)

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'region subcommand' commands && ret=0 ;;
esac
return ret
