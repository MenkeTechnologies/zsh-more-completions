#compdef CreateStack
# Documentation: https://github.com/senbox-org/s1tbx/blob/master/s1tbx-op-insar/src/main/java/org/esa/s1tbx/insar/gpf/coregistration/CreateStackOp.java
# ESA SNAP gpt CreateStack operator - collocate master and slave into a coregistration stack

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-PmasterBandNames=-[the list of master source bands]:bands' \
  '-PslaveBandNames=-[the list of slave source bands]:bands' \
  '-PresamplingType=-[method to resample slave grid onto master grid]:type' \
  '-Pextent=-[the output image extents]:extent:(Master Minimum Maximum)' \
  '-PinitialOffsetMethod=-[method for computing initial master-slave offset]:method:(Orbit Product\ Geolocation)' \
  '*:source product:_files' && ret=0

return ret
