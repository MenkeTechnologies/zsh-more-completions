#compdef po-fetch

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-q,--quiet}'[suppress progress output]' \
  {-v,--verbose}'[verbose output]' \
  '1:project type:(TP Weblate git)' \
  '*:project args:' && ret=0

return ret
