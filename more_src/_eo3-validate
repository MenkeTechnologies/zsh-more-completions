#compdef eo3-validate
# Documentation: https://eodatasets.readthedocs.io/
# Validate ODC EO3 dataset documents (eodatasets3)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version and exit]' \
  '(-W --warnings-as-errors)'{-W,--warnings-as-errors}'[fail if any warnings are produced]' \
  '(-f --output-format)'{-f,--output-format}'=[output format]:format:(plain quiet github)' \
  '--thorough[read the data/measurements and check properties match]' \
  '--explorer-url=[validate using product definitions from an Explorer URL]:url' \
  '--odc[validate using product definitions from datacube]' \
  '(-q --quiet)'{-q,--quiet}'[only print problems, one per line]' \
  '*:path:_files' && ret=0

return ret
