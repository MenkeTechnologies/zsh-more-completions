#compdef kn-quickstart
# Documentation: https://man.archlinux.org/search?q=kn-quickstart
# Reference accessed: 2026-05-16

# kn-quickstart: Knative quickstart plugin (one-command local install)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'kind:install Knative on kind'
  'minikube:install Knative on minikube'
  'completion:emit shell completion'
  'help:show help'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config=[config file]:file:_files' \
  '--install-eventing[install Knative Eventing]' \
  '--install-serving[install Knative Serving]' \
  '--registry-port=[registry port]:port:' \
  '--cluster-name=[cluster name]:name:' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'kn-quickstart command' commands && ret=0 ;;
esac
return ret
