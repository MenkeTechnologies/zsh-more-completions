#compdef mafSplitPos
# UCSC kent: pick positions to split multiple alignment input files

local ret=1

_arguments -s -S \
  '-chrom=[restrict to one chromosome]:chr' \
  '-minGap=[split only on gaps >N bp (default 100, -1 disables)]:n' \
  '-minRepeat=[split only on repeats >N bp (default 100, -1 disables)]:n' \
  '1:database:' \
  '2:size in Mbp:' \
  '3:output bed:_files -g "*.bed"' && ret=0

return ret
