#compdef wcsalign
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss203.html
# KAPPA: aligns a group of NDFs using World Co-ordinate System information

local ret=1

_arguments -s \
  'IN=[input NDFs]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDFs]:ndf:_files -g "*.sdf"' \
  'REF=[reference NDF for alignment]:ndf:_files -g "*.sdf"' \
  'REFCAT=[POLPACK catalogue defining target WCS]:catalogue:_files' \
  'ABORT=[abort on error]:bool:(TRUE FALSE)' \
  'ACC=[positional accuracy in pixels]:value' \
  'ALIGNREF=[align in reference coordinate system]:bool:(TRUE FALSE)' \
  'CONSERVE=[conserve total data value]:bool:(TRUE FALSE)' \
  'INSITU=[modify pixel origin in situ]:bool:(TRUE FALSE)' \
  'LBND=[lower pixel bounds of output]:bounds' \
  'UBND=[upper pixel bounds of output]:bounds' \
  'MAXPIX=[initial scale size in pixels]:n' \
  'METHOD=[resampling/rebinning method]:method' \
  'PARAMS=[additional interpolation parameters]:params' \
  'REBIN=[use rebinning rather than resampling]:bool:(TRUE FALSE)' \
  'WLIM=[min good pixels per output pixel]:frac' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
