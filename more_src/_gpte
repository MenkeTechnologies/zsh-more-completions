#compdef gpte
# Documentation: https://man.archlinux.org/search?q=gpte
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-m --model)'{-m+,--model=}'[model id]:model:(gpt-4o gpt-4-turbo gpt-4 gpt-3.5-turbo claude-3-opus-20240229 claude-3-sonnet-20240229)' \
  '(-t --temperature)'{-t+,--temperature=}'[sampling temperature]:n:' \
  '(-i --improve)'{-i,--improve}'[improve existing project]' \
  '(-l --lite)'{-l,--lite}'[lite mode - main prompt only]' \
  '(-c --clarify)'{-c,--clarify}'[clarify mode - discuss before impl]' \
  '--use-custom-preprompts[override default preprompts]' \
  '--image-directory=[image directory]:dir:_files -/' \
  '--use-cache[use API call cache]' \
  '--no-execution[do not execute generated code]' \
  '--azure-endpoint=[azure endpoint URL]:url:' \
  '--llm-via-clipboard[copy prompt to clipboard]' \
  '--prompt-file=[prompt file]:file:_files' \
  '--diff-timeout=[diff timeout seconds]:n:' \
  '--debug[enable debug logging]' \
  '*:project dir:_files -/' && ret=0

return ret
