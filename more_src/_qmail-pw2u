#compdef qmail-pw2u
# _qmail-pw2u — qmail's passwd → users/assign converter (reads a V7 passwd file on stdin and prints a qmail-users(5) assignment file; standard way to import a system account list into the qmail user database)
# upstream: https://github.com/notqmail/notqmail
# Flags from qmail-pw2u.9 on tip.

_qmail-pw2u() {
    _arguments \
        '-/[allow root in output]' \
        '-o[skip locked accounts]' \
        '-h[allow $HOME with leading hyphen]' \
        '-H[treat all accounts as having home directory]' \
        '-u[reject accounts whose uid is below mailuid]' \
        '-U[reject accounts whose uid is above mailuid]' \
        '-C[do not check for collisions]' \
        '-c+[separator character (default -)]:char:'
}

_qmail-pw2u "$@"
