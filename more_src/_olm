#compdef olm
# _olm — Operator Lifecycle Manager top-level controller (reconciles ClusterServiceVersions, Subscriptions, InstallPlans)
# upstream: https://github.com/operator-framework/operator-lifecycle-manager
# Flags from cmd/olm/main.go on tip + klog v2 + feature gates.

_olm() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[display olm version]' \
        '--debug[use debug log level]' \
        '--interval=[wake up interval]:duration:' \
        '--watchedNamespaces=[csv of namespaces to watch (empty = all)]:csv:' \
        '--writeStatusName=[ClusterOperator name to write status to (empty disables)]:name:' \
        '--writePackageServerStatusName=[ClusterOperator name for package API server status (empty disables)]:name:' \
        '--namespace=[namespace where cleanup runs]:ns:' \
        '--tls-cert=[TLS certificate file (requires --tls-key)]:file:_files' \
        '--tls-key=[TLS private key file (requires --tls-cert)]:file:_files' \
        '--client-ca=[path to watch for client CA bundle]:file:_files' \
        '--protectedCopiedCSVNamespaces=[csv of namespaces where global Copied CSVs always appear]:csv:' \
        '--feature-gates=[csv of feature gates to enable/disable]:gates:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_olm "$@"
