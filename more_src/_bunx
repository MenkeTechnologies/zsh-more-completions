#compdef bunx
# Documentation: https://bun.sh/docs/cli/bunx
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bunx — bun alias for `bun x` — run packages from npm (npx equivalent).

_arguments -s -S \
  '--bun[force command to run with Bun instead of Node.js]' \
  '(-p --package)'{-p+,--package=}'[run binary from specific package]:package:' \
  '--no-install[skip install if package not already installed]' \
  '--verbose[verbose output during install]' \
  '--silent[suppress install output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:package:' \
  '*::args:'
