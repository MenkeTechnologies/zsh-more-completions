#compdef bunx
# Documentation: https://man.archlinux.org/search?q=bunx
# Reference accessed: 2026-05-16

# Zsh completion for bunx - execute npm package binaries (bun equivalent of npx)

_arguments -s -S \
  '--bun[force use of bun runtime]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:package name:' \
  '*::args:'
