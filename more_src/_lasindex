#compdef lasindex
# LAStools: create a spatial LAX index for fast area-of-interest queries

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print help]' \
  '-version[report tool version]' \
  '-gui[start with GUI]' \
  '(-v -verbose)'{-v,-verbose}'[verbose output]' \
  '-vv[very verbose output]' \
  '-silent[output errors/warnings only]' \
  '-quiet[no output at all]' \
  '-append[append LAX index to end of LAZ file]' \
  '-dont_reindex[skip files that already have an index]' \
  '-tile_size+[smallest indexed spatial area (default 10)]:size' \
  '-maximum+[maximum intervals per spatial area]:n' \
  '-minimum+[index only files with minimum n points]:n' \
  '-threshold+[set threshold value]:n' \
  '-meta[create meta index above multiple files]' \
  '-force[continue despite serious warnings]' \
  '-errors_ignore[continue despite errors]' \
  '*-i+[input LAS/LAZ file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output filename]:output:_files' \
  '-cores+[process inputs on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
