#compdef recursebuster
# Documentation: https://github.com/C-Sto/recursebuster
# rapid content discovery tool for recursively querying webservers

local ret=1

_arguments -s -S \
  '-ajax[add the X-Requested-With: XMLHttpRequest header to all requests]' \
  '-all[show, and write the result of all checks]' \
  '-appendslash[append a / to all directory bruteforce requests]' \
  '-auth[basic auth (base64 encoded portion after Basic)]:auth' \
  '-bad[responses to consider bad or not found (comma-separated)]:codes' \
  '-badheader[check for presence of this header]:header' \
  '-blacklist[blacklist of prefixes to not check]:prefixes' \
  '-canary[custom value to use to check for wildcards]:value' \
  '-clean[output clean URLs to the output file]' \
  '-cookies[cookies to include with requests]:cookies' \
  '-debug[enable debugging]' \
  '-ext[extensions to append to checks (comma-separated)]:ext' \
  '-headers[additional headers to include with request]:headers' \
  '-https[use HTTPS instead of HTTP]' \
  '-iL[file to use as an input list of URLs to start from]:file:_files' \
  '-k[ignore SSL check]' \
  '-len[show, and write the length of the response]' \
  '-methods[methods to use for checks (comma-separated)]:methods' \
  '-nobase[do not perform a request to the base URL]' \
  '-noget[do not perform a GET request (only HEAD)]' \
  '-nohead[do not optimize GET requests with a HEAD]' \
  '-norecursion[disable recursion]' \
  '-nospider[do not search the page body for links]' \
  '-nostartstop[do not show start/stop info messages]' \
  '-nostatus[do not print status info]' \
  '-noui[do not use sexy ui]' \
  '-nowildcard[do not perform wildcard checks for soft 404 detection]' \
  '-o[local file to dump into]:file:_files' \
  '-proxy[proxy configuration in the form ip:port]:proxy' \
  '-ratio[similarity ratio to the 404 canary page]:ratio' \
  '-redirect[follow redirects]' \
  '-sitemap[send good requests to the configured proxy]' \
  '-t[number of concurrent threads]:n' \
  '-timeout[timeout (seconds) for HTTP/TCP connections]:n' \
  '-u[url to spider]:url:_urls' \
  '-ua[user agent to use when sending requests]:ua' \
  '-v[verbosity level for output messages]:level' \
  '-version[show version number and exit]' \
  '-w[wordlist to use for bruteforce]:file:_files' \
  '-whitelist[whitelist of domains to include in brute-force]:domains' && ret=0

return ret
