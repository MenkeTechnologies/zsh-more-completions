#compdef truss-cli truss
# _truss-cli — Baseten Truss truss-cli CLI command-line frontend wrapping the Truss open-source framework for packaging and deploying ML AI Generative AI models providing init build push predict run watch publish deploy lambda configs serializing-model-config-pipeline patch streaming-Hugging-Face-PyTorch-XGBoost-LightGBM-Scikit-LearnAI (Baseten team, Python); click
# upstream: https://truss.baseten.co/

_truss-cli() {
    local -a sub=(
        'init:scaffold a new Truss'
        'build:build the Truss image'
        'push:push the Truss to Baseten'
        'predict:run a prediction'
        'run:run the Truss locally'
        'watch:watch and patch a deployed Truss'
        'publish:publish the Truss image'
        'patch:patch a deployed Truss'
        'image:image management'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--target-directory=+[dir]:dir:_files -/' \
        '-d+[dir]:dir:_files -/' \
        '--truss-dir=+[dir]:dir:_files -/' \
        '--model-name=+[name]:str:' \
        '--model-version=+[v]:str:' \
        '--deployment-name=+[name]:str:' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--build-target=+[t]:t:(server training)' \
        '--build-tag=+[tag]:str:' \
        '--registry=+[name]:str:' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--detach[detach]' \
        '--no-detach[no detach]' \
        '--data=+[json]:str:' \
        '--data-file=+[file]:file:_files -g "*.json *.yaml *.yml"' \
        '-c+[config file]:file:_files -g "config.yaml *.yaml *.yml"' \
        '--config=+[file]:file:_files -g "config.yaml *.yaml *.yml"' \
        '-f+[format]:f:(json yaml table)' \
        '--format=+[format]:f:(json yaml table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'truss-cli subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments '*:name:' ;;
                build|push|run|watch|publish) _arguments '*:truss path:_files -/' ;;
                predict) _arguments '*:input:_files -g "*.json"' ;;
                image) _arguments '1:op:(list build push pull tag rm)' '*:tag:' ;;
            esac
            ;;
    esac
}

_truss-cli "$@"
