#compdef frontail
# Documentation: https://man.archlinux.org/search?q=frontail
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-h --host)'{-h,--host}'+[bind host]:host:_hosts' \
  '(-p --port)'{-p,--port}'+[bind port]:port:' \
  '(-n --number)'{-n,--number}'+[number of lines]:n:' \
  '(-l --lines)'{-l,--lines}'+[max lines]:n:' \
  '(-T --theme)'{-T,--theme}'+[theme name]:theme:(default dark)' \
  '(-d --daemonize)'{-d,--daemonize}'[run as daemon]' \
  '(-t --disable-usage-stats)'{-t,--disable-usage-stats}'[disable usage stats]' \
  '(-k --key)'{-k,--key}'+[SSL key]:file:_files' \
  '(-c --certificate)'{-c,--certificate}'+[SSL cert]:file:_files' \
  '(-r --auth-htpasswd)'{-r,--auth-htpasswd}'+[htpasswd file]:file:_files' \
  '(-w --auth-user)'{-w,--auth-user}'+[basic auth user]:user:' \
  '(-s --auth-password)'{-s,--auth-password}'+[basic auth password]:pw:' \
  '(-N --no-indicators)'{-N,--no-indicators}'[no indicators]' \
  '(--url-path)--url-path=+[url path prefix]:path:' \
  '(--ui-highlight)--ui-highlight[enable ui highlight]' \
  '(--ui-highlight-preset)--ui-highlight-preset=+[preset]:preset:_files' \
  '*:log file:_files' && ret=0

return ret
