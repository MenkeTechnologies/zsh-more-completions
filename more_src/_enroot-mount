#compdef enroot-mount
# Documentation: https://github.com/NVIDIA/enroot/blob/main/bin/enroot-mount.c
# enroot helper: perform mounts described by one or more fstab files.

local ret=1

_arguments -s -S \
  '--root[set the root directory for mounts]:dir:_files -/' \
  '--pass[fstab pass number to process]:num:' \
  '*:fstab file:_files' && ret=0

return ret
