#compdef virtualbox-cli2 vboxmanage2 VBoxManage2
# _virtualbox-cli2 — Oracle VirtualBox virtualbox-cli2 CLI command-line frontend wrapping the VBoxManage command-line interface for VirtualBox open-source x86 AMD64 Intel64 virtualization product for enterprise as well as home use written in C++ originally innotek now Oracle the only command-line interface that supports the full functionality of VirtualBox list showvminfo registervm unregistervm createvm modifyvm clonevm import export startvm controlvm closemedium adoptstate discardstate snapshot createhd modifyhd showhdinfo getextradata setextradata extpack metrics natnetwork dhcpserver guestcontrol guestproperty hostonlyif debugvm storagectl storageattach (Oracle VirtualBox team innotek Oracle, C++); custom argparse
# upstream: https://www.virtualbox.org/

_virtualbox-cli2() {
    local -a sub=(
        'list:list VMs'
        'showvminfo:show VM info'
        'registervm:register a VM'
        'unregistervm:unregister a VM'
        'createvm:create a new VM'
        'modifyvm:modify VM config'
        'clonevm:clone a VM'
        'import:import an OVF/OVA'
        'export:export an OVF/OVA'
        'startvm:start a VM'
        'controlvm:control a VM'
        'discardstate:discard saved state'
        'adoptstate:adopt saved state'
        'snapshot:snapshot operations'
        'closemedium:close a medium'
        'storagectl:storage controller ops'
        'storageattach:attach a medium'
        'bandwidthctl:bandwidth control ops'
        'showmediuminfo:show medium info'
        'createmedium:create a medium'
        'modifymedium:modify a medium'
        'clonemedium:clone a medium'
        'mediumproperty:medium property ops'
        'encryptmedium:encrypt a medium'
        'checkmediumpwd:check medium password'
        'convertfromraw:convert from raw'
        'getextradata:get extra data'
        'setextradata:set extra data'
        'setproperty:set a property'
        'usbfilter:USB filter ops'
        'sharedfolder:shared folder ops'
        'guestcontrol:guest control ops'
        'guestproperty:guest property ops'
        'hostonlyif:host-only interface ops'
        'natnetwork:NAT network ops'
        'dhcpserver:DHCP server ops'
        'extpack:extension pack ops'
        'unattended:unattended install ops'
        'metrics:metrics ops'
        'debugvm:VM debugger ops'
        'cloud:cloud operations'
        'cloudprofile:cloud profile ops'
        'updatecheck:update check'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--nologo[no logo]' \
        '--settingspw=+[password]:str:' \
        '--settingspwfile=+[file]:file:_files' \
        '--detailed-progress[detailed progress]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vboxmanage subcommand' sub ;;
        args)
            case $words[1] in
                list) _arguments '*:type:(vms runningvms ostypes hostdvds hostfloppies intnets bridgedifs hostonlyifs natnets dhcpservers hostinfo hostcpuids hddbackends hdds dvds floppies usbhost usbfilters systemproperties extpacks groups webcams screenshotformats cloudproviders cloudprofiles cloudnets natnetworks)' ;;
                showvminfo|startvm|controlvm|modifyvm|clonevm|unregistervm|registervm|discardstate|adoptstate|debugvm|guestcontrol|guestproperty) _arguments '*:vm:' ;;
                snapshot) _arguments '1:vm:' '2:op:(take delete restore restorecurrent list edit)' '*:arg:' ;;
                createmedium|modifymedium|closemedium|clonemedium|encryptmedium|showmediuminfo) _arguments '*:medium:_files -g "*.vdi *.vmdk *.vhd *.iso *.img"' ;;
            esac
            ;;
    esac
}

_virtualbox-cli2 "$@"
