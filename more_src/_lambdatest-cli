#compdef lambdatest-cli lt
# _lambdatest-cli — LambdaTest lambdatest-cli CLI command-line frontend to the LambdaTest cross-browser testing platform supporting Real Device Cypress Playwright WebDriverIO Selenium Appium Puppeteer test runners parallel-running tunnel HyperExecute KaneAI smart-test-execution session-management dashboard reporting (LambdaTest team, JavaScript); commander
# upstream: https://www.lambdatest.com/

_lambdatest-cli() {
    local -a sub=(
        'auth:authenticate'
        'init:scaffold a project'
        'run:run tests in cloud'
        'devices:list available devices'
        'browsers:list available browsers'
        'session:fetch session details'
        'build:build management'
        'platforms:list platforms'
        'tunnel:tunnel management'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[user]:str:' \
        '--user=+[user]:str:' \
        '-k+[access key]:str:' \
        '--access-key=+[key]:str:' \
        '-c+[config file]:file:_files -g "lambdatest-config.json *.yaml *.json"' \
        '--config=+[file]:file:_files -g "*.json *.yaml"' \
        '--framework=+[f]:f:(cypress playwright webdriverio selenium appium nightwatch testcafe puppeteer cucumber jest mocha)' \
        '-p+[parallels]:n:' \
        '--parallels=+[N]:n:' \
        '--browsers=+[list]:str:' \
        '--os=+[list]:str:' \
        '--devices=+[list]:str:' \
        '--build=+[name]:str:' \
        '--project=+[name]:str:' \
        '--tunnel[use tunnel]' \
        '--no-tunnel[no tunnel]' \
        '--tunnel-name=+[name]:str:' \
        '--build-name=+[name]:str:' \
        '--hyperexecute[run via HyperExecute]' \
        '--debug[debug]' \
        '--region=+[r]:r:(us eu in apac)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lambdatest-cli subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments '*:script:_files' ;;
                session|build) _arguments '*:id:' ;;
            esac
            ;;
    esac
}

_lambdatest-cli "$@"
