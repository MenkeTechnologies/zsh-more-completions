#compdef ompi-iof

# ompi-iof: redirect/show stdout/stderr of OMPI MPI processes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-mca[MCA parameter]:param value:' \
  '--mca=[MCA parameter]:param value:' \
  '*::ompi-iof args:_files' && ret=0
return ret
