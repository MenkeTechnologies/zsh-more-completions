#compdef kube-state-metrics
# Documentation: https://man.archlinux.org/search?q=kube-state-metrics
# Reference accessed: 2026-05-16

# kube-state-metrics: emit Kubernetes object metrics
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--add_dir_header[log header]' \
  '--alsologtostderr[also log to stderr]' \
  '--apiserver=[kube apiserver URL]:url:' \
  '--auto-gomemlimit-ratio=[auto GOMEMLIMIT ratio]:n:' \
  '--config=[config file]:file:_files' \
  '--custom-resource-state-config=[CRS config]:value:' \
  '--custom-resource-state-config-file=[CRS config file]:file:_files' \
  '--custom-resource-state-only[only CRS]' \
  '--enable-gzip-encoding[enable gzip encoding]' \
  '--host=[bind host]:host:' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--metric-allowlist=[metric allowlist]:list:' \
  '--metric-annotations-allowlist=[metric annotations allowlist]:list:' \
  '--metric-denylist=[metric denylist]:list:' \
  '--metric-labels-allowlist=[metric labels allowlist]:list:' \
  '--metric-opt-in-list=[metric opt-in list]:list:' \
  '--namespaces=[namespaces]:list:' \
  '--namespaces-denylist=[namespaces denylist]:list:' \
  '--node=[node]:node:' \
  '--port=[telemetry port]:port:' \
  '--pod=[pod]:pod:' \
  '--pod-namespace=[pod namespace]:ns:' \
  '--resources=[resources]:list:' \
  '--server-tls-config=[server TLS config]:file:_files' \
  '--shard=[shard]:n:' \
  '--telemetry-host=[telemetry host]:host:' \
  '--telemetry-port=[telemetry port]:port:' \
  '--tls-config=[tls config file]:file:_files' \
  '--total-shards=[total shards]:n:' \
  '--track-unscheduled-pods[track unscheduled pods]' \
  '--use-apiserver-cache[use apiserver cache]' \
  '*::kube-state-metrics args:_files' && ret=0
return ret
