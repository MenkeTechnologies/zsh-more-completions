#compdef kerl-cli
# _kerl-cli — Erlang kerl Erlang/OTP version manager CLI alias (Daniel Luna / Erlang community, Bash); custom argparse
# upstream: https://github.com/kerl/kerl

_kerl-cli() {
    local -a sub=(
        'active:show current active Erlang/OTP'
        'build:build an Erlang/OTP release'
        'build-install:build and install'
        'build-image:build OCI/docker image'
        'cleanup:cleanup release artifacts'
        'delete:delete builds/installs'
        'deploy:deploy to remote'
        'install:install built Erlang/OTP'
        'list:list builds/installs'
        'path:show install path'
        'plt:manage dialyzer PLT'
        'prompt:configure prompt'
        'status:show kerl status'
        'update:update kerl/builds'
        'upgrade:upgrade installs'
        'uninstall:uninstall'
        'use:use an install'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kerl subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '1:release:' \
                    '2:build-name:' \
                    '--git=+[git url]:url:_urls' \
                    '--config=+[config file]:file:_files' ;;
                build-install) _arguments \
                    '1:release:' \
                    '2:build-name:' \
                    '3:install-path:_files -/' ;;
                build-image) _arguments \
                    '1:release:' \
                    '2:build-name:' ;;
                install) _arguments \
                    '1:build-name:' \
                    '2:install-path:_files -/' ;;
                use|active|status|path) _arguments \
                    '*:install:' ;;
                delete) _arguments \
                    '1:cmd:(build installation)' \
                    '*:name:' ;;
                uninstall) _arguments \
                    '1:install:' ;;
                cleanup) _arguments \
                    '1:cmd:(all builds installations downloads)' ;;
                list) _arguments \
                    '1:cmd:(builds installations releases)' ;;
                plt) _arguments \
                    '1:cmd:(build)' ;;
                deploy) _arguments \
                    '1:host:_hosts' \
                    '2:dir:_files -/' ;;
            esac
            ;;
    esac
}

_kerl-cli "$@"
