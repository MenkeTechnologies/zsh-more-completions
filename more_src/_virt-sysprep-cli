#compdef virt-sysprep-cli
# _virt-sysprep-cli — libguestfs virt-sysprep reset/unconfigure VM image CLI alias (libguestfs team, OCaml); custom argparse
# upstream: https://github.com/libguestfs/libguestfs

_virt-sysprep-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--add=+[disk]:file:_files' \
        '-a+[disk]:file:_files' \
        '--add-cdrom=+[cdrom]:file:_files' \
        '--blkdev=+[blkdev]:str:' \
        '--connect=+[libvirt URI]:str:' \
        '-c+[libvirt URI]:str:' \
        '--colors[force colors]' \
        '--colours[force colors]' \
        '--no-colors[no colors]' \
        '--domain=+[VM domain]:str:' \
        '-d+[VM domain]:str:' \
        '--dryrun[dry run]' \
        '--dry-run[dry run]' \
        '--enable=+[operation csv]:str:' \
        '--operation=+[operation csv]:str:' \
        '--operations=+[operation csv]:str:' \
        '--exit-on-error[exit on first error]' \
        '--firstboot=+[script file]:file:_files' \
        '--firstboot-command=+[command]:str:' \
        '--firstboot-install=+[package csv]:str:' \
        '--format=+[image format]:f:(raw qcow2 vmdk)' \
        '--hostname=+[hostname]:host:_hosts' \
        '--install=+[package csv]:str:' \
        '--keep-user-accounts=+[user csv]:str:' \
        '--key=+[key]:str:' \
        '--list-operations[list operations]' \
        '--mount-options=+[options]:str:' \
        '--network[use guest network]' \
        '--no-network[no guest network]' \
        '--no-selinux-relabel[no selinux relabel]' \
        '--password=+[user:spec]:str:' \
        '--password-crypto=+[crypto]:c:(md5 sha256 sha512)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--root-password=+[spec]:str:' \
        '--run=+[script file]:file:_files' \
        '--run-command=+[command]:str:' \
        '--scrub=+[path]:str:' \
        '--script=+[script]:file:_files' \
        '--selinux-relabel[selinux relabel]' \
        '--ssh-inject=+[user[:keystring]]:str:' \
        '--timezone=+[timezone]:str:' \
        '--truncate=+[file]:str:' \
        '--truncate-recursive=+[dir]:str:' \
        '--update[update packages]' \
        '--upload=+[file:dest]:str:' \
        '--uninstall=+[package csv]:str:' \
        '--user-password=+[user:spec]:str:' \
        '--user=+[user]:_users' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--write=+[file:content]:str:' \
        '--read-only[read only]' \
        '--ro[read only]' \
        '--rw[read write]' \
        '--copy=+[src:dest]:str:' \
        '--copy-in=+[local:remote]:str:' \
        '--mkdir=+[dir]:str:' \
        '--delete=+[path]:str:' \
        '--touch=+[file]:str:' \
        '--chmod=+[mode:file]:str:' \
        '--chown=+[user:group:path]:str:' \
        '*:arg:'
}

_virt-sysprep-cli "$@"
