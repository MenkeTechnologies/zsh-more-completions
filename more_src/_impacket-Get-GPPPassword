#compdef impacket-Get-GPPPassword

# Impacket Get-GPPPassword.py: extract Group Policy Preferences passwords
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-xmlfile[GPP XML file to parse]:file:_files -g "*.xml"' \
  '-share[SYSVOL share to scan]:share:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos auth]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-target-ip[target IP]:ip:' \
  '*:domain/user[:password]@host:' && ret=0
return ret
