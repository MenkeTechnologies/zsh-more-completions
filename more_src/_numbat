#compdef numbat
# Documentation: https://github.com/sharkdp/numbat/blob/main/numbat-cli/src/main.rs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for numbat (scientific calculator)

_arguments -s -S \
  '(-e --expression -c --command)'{-e,--expression,-c,--command}'[evaluate expression]:expression:' \
  '--no-prelude[do not load the prelude]' \
  '--no-init[do not load init.nbt]' \
  '--no-color[disable color output]' \
  '(-t --type)'{-t,--type}'[print the type of the result]' \
  '--debug[enable debug mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:file:_files -g "*.nbt"' && return 0
