#compdef pkdiff
# Documentation: https://pktools.nongnu.org/html/pkdiff.html
# compare raster image to reference dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input raster dataset.]:file:_files' \
  '(-ref --reference)'{-ref,--reference}'[Reference (raster or vector) dataset]:file:_files' \
  '(-ln --ln)'{-ln,--ln}'[Layer name(s) in sample. Leave empty to select all (for vector referen]:value:' \
  '(-b --band)'{-b,--band}'[Input (reference) raster band. Optionally, you can define different ba]:value:' \
  '(-rmse --rmse)'{-rmse,--rmse}'[Report root mean squared error]' \
  '(-reg --reg)'{-reg,--reg}'[Report linear regression (Input = c0+c1*Reference)]' \
  '(-cm --confusion)'{-cm,--confusion}'[Create confusion matrix (to std out)]' \
  '(-lr --lref)'{-lr,--lref}'[Attribute name of the reference label (for vector reference datasets o]:value:' \
  '(-c --class)'{-c,--class}'[List of class names.]:value:' \
  '(-r --reclass)'{-r,--reclass}'[List of class values (use same order as in classname option).]:value:' \
  '(-nodata --nodata)'{-nodata,--nodata}'[No data value(s) in input or reference dataset are ignored]:value:' \
  '(-m --mask)'{-m,--mask}'[Use the first band of the specified file as a validity mask. Nodata va]:file:_files' \
  '(-msknodata --msknodata)'{-msknodata,--msknodata}'[Mask value(s) where image is invalid. Use negative value for valid dat]:value:' \
  '(-o --output)'{-o,--output}'[Output dataset (optional)]:file:_files' \
  '(-f --f)'{-f,--f}'[OGR format for output vector (for vector reference datasets only)]:value:' \
  '(-of --oformat)'{-of,--oformat}'[Output image format (see also gdal_translate).]:value:' \
  '(-lc --lclass)'{-lc,--lclass}'[Attribute name of the classified label (for vector reference datasets]:value:' \
  '(-cmf --cmf)'{-cmf,--cmf}'[Format for confusion matrix (ascii or latex)]:value:' \
  '(-cmo --cmo)'{-cmo,--cmo}'[Output file for confusion matrix]:value:' \
  '(-se95 --se95)'{-se95,--se95}'[Report standard error for 95 confidence interval]' \
  '(-bnd --boundary)'{-bnd,--boundary}'[Boundary for selecting the sample (for vector reference datasets only)]:value:' \
  '(-hom --homogeneous)'{-hom,--homogeneous}'[Only take regions with homogeneous boundary into account (for referenc]' \
  '(-circ --circular)'{-circ,--circular}'[Use circular boundary (for vector reference datasets only)]' \
  '(-ct --ct)'{-ct,--ct}'[Color table in ASCII format having 5 columns\: id R G B ALFA (0\: transp]:file:_files' \
  '(-co --co)'{-co,--co}'[Creation option for output file. Multiple options can be specified.]:value:' \
  '--commission[Value for commission errors\: input label < reference label]:value:' \
  '*:file:_files' && ret=0

return ret
