#compdef disorderfs
# FUSE filesystem that randomizes directory ordering

local ret=1

_arguments -s -S \
  '--sort-dirents=[sort directory entries]:order:(yes no reverse)' \
  '--reverse-dirents[reverse directory entries]' \
  '--shuffle-dirents[shuffle directory entries]' \
  '--multi-user[allow multi-user access]' \
  '-o[FUSE options]:options:' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '1:source directory:_files -/' \
  '2:mount point:_files -/' && ret=0

return ret
