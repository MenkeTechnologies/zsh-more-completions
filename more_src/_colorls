#compdef colorls
# ============================================================================
#  _colorls — colorls.cr: Crystal port of athityakumar/colorls
#             (colorful ls(1) replacement with file-type icons + git status)
#
#  Source-direct extraction from
#    https://github.com/nanobowers/colorls.cr/blob/master/src/colorls.cr
#    https://github.com/nanobowers/colorls.cr/blob/master/src/colorls/flags.cr
#    https://github.com/nanobowers/optimist.cr (the Crystal Optimist
#    library by Ben Nanobowers)
#
#  Maintained by Ben Nanobowers (nanobowers/colorls.cr).  Crystal
#  port of the popular Ruby `colorls` gem (athityakumar/colorls) —
#  drop-in `ls(1)` replacement with file-type-specific Nerd-Font
#  icons, GitHub-status colors, language-aware coloring, and tree
#  view.  Sister tools: ls (POSIX, in corpus + stock), eza (modern
#  ls replacement in Rust, in corpus via _eza), exa (deprecated
#  predecessor of eza, in corpus), lsd (LSDeluxe — alternative
#  Rust ls, in corpus via _lsd), GNU ls (in corpus + stock).
#
#  CLI library taxonomy update: 6th Crystal CLI library — Ben
#  Nanobowers's **Optimist.cr** (nanobowers/optimist.cr).  Crystal
#  ecosystem now has 6 documented CLI libraries — TIED FOR SECOND-
#  MOST-DOCUMENTED CLI language with Python (6) and OCaml (6), behind
#  Rust/Go (9).  Crystal CLI libs: Crystal OptionParser stdlib +
#  commander + commander.cr (R332) + clim (R348) + Cling (R381) +
#  Optimist.cr (R392).
#
#  Optimist.cr (nanobowers/optimist.cr) is Ben Nanobowers's Crystal
#  port of the Ruby Optimist gem (originally Trollop by William
#  Morgan, later renamed to Optimist) — provides Ruby-Optimist-
#  equivalent DSL semantics adapted to Crystal's type system.
#  Distinct from R332 Crystal mosop/commander (block-DSL style),
#  R348 Crystal at-grandpa/clim (macro-block-DSL inside a class),
#  R381 devnote-dev/cling (inheritance-based with `< Cling::Command`),
#  Crystal stdlib OptionParser (low-level imperative), Crystal
#  commander.cr (different commander.cr library) by being a
#  RUBY-OPTIMIST-PORTED DSL with `parser.opt(:name, "desc", short:
#  'X', alt: "X", cls: TYPE, default: VAL, permitted: [VALS])` pattern.
#  Used by colorls.cr (Crystal port of Ruby colorls), nanobowers's
#  own optimist.cr examples, and Crystal tools that want the familiar
#  Ruby Optimist API in Crystal's typed environment.
#
#  Optimist.cr API:
#    require "optimist"
#
#    parser = Optimist::Parser.new
#    parser.banner "mytool [options] file..."
#    parser.opt(:verbose, "verbose output", short: 'v')
#    parser.opt(:output, "output file", short: 'o', cls: String,
#               default: "out.txt")
#    parser.opt(:count, "iteration count", short: 'n', cls: Int32,
#               default: 1)
#    parser.opt(:format, "format type",
#               permitted: %w[json csv xml],
#               default: "json") do |evalopt|
#      puts "format set to: #{evalopt.value.as(String)}"
#    end
#    parser.opt(:tree, "tree view", short: 't', cls: Int32,
#               default: 3) do |evalopt|
#      @depth = evalopt.value.as(Int32)
#    end
#    parser.opt(:git_status, "show git status", alt: "gs")
#    parser.opt(:sort_dirs, "group dirs first",
#               alt: ["sd", "group-directories-first"])
#
#    opts = parser.parse(ARGV)
#    remaining_args = ARGV  # consumed args removed by parser
#
#    # Access via:
#    opts[:verbose]   # => Bool
#    opts[:output]    # => String
#    opts[:count]     # => Int32
#
#  Optimist.cr distinctive features:
#    - RUBY-OPTIMIST-PORTED DSL — adapts the same DSL semantics as
#      Ruby Optimist gem (William Morgan's Trollop, renamed to
#      Optimist) to Crystal's typed environment
#    - `Optimist::Parser` class — typically instantiated as `parser
#      = Optimist::Parser.new` or used via DSL block `Optimist.options
#      { |p| p.opt(:name, ...) }`
#    - `parser.opt(:NAME, "DESCRIPTION", short: 'X'|nil, alt:
#      "ALIAS"|["A","B"], cls: TYPE, default: VAL, permitted: [VALS])
#      { |evalopt| ... }` — MAIN OPTION DSL with named parameters
#    - `:NAME` Crystal SYMBOL — option name (becomes `--name`,
#      auto-mapped to result hash key)
#    - `"DESCRIPTION"` STRING — help text shown in `--help`
#    - `short: 'X'` Crystal CHAR LITERAL — short option name (e.g.
#      `'a'` for `-a`); single-quoted CHAR (vs Crystal STRING `"a"`)
#    - `short: nil` — DISABLE short option (long-only flag like
#      `--almost-all`)
#    - `alt: "ALIAS"` or `alt: ["A", "B"]` — ALTERNATE LONG NAMES;
#      single string for one alias, array for multiple (e.g.
#      `alt: ["sd", "group-directories-first"]` for both `--sd` and
#      `--group-directories-first`)
#    - `cls: TYPE` — Crystal TYPE for value coercion; defaults to
#      `Bool` (presence flag); set `cls: String`/`cls: Int32`/`cls:
#      Float64` for typed value
#    - `default: VAL` — DEFAULT VALUE when flag not provided
#    - `permitted: [VALS]` or `permitted: %w[a b c]` — ENUM/CHOICES
#      validation (e.g. `%w[json csv xml]`); raises on invalid value
#    - VALUE HANDLER BLOCK — `{ |evalopt| ... }` callback receiving
#      `Optimist::EvalOpt` container; `evalopt.value.as(TYPE)` for
#      type-cast access
#    - `parser.banner "string"` — set banner line for `--help`
#    - `parser.version "v1.0"` — set version for `--version`
#    - `parser.educate` — print help text manually
#    - `parser.parse(ARGV)` — PARSE METHOD; returns NamedTuple of
#      parsed options; REMOVES consumed args from ARGV (so `ARGV`
#      after parse holds positional args)
#    - `opts[:NAME]` — typed access to parsed values
#    - AUTO-INJECTED `--help` / `-h` flag (auto-added unless caller
#      defines own `--help`)
#    - AUTO-INJECTED `--version` / `-v` flag (when `parser.version`
#      called)
#    - HUMAN-READABLE ERROR MESSAGES — pretty-prints invalid arg
#      values with suggestions
#    - PROCESS EXIT model via `Optimist::CommandlineError` raise +
#      caller catches; OR direct `exit 0` on `--help`/`--version`
#  Distinct from R332 Crystal mosop/commander (BLOCK-BASED DSL with
#  `Commander::Command.new do |cmd| ... end`), R348 Crystal at-
#  grandpa/clim (MACRO-BASED block DSL with `option`/`command` macros
#  inside a class), R381 Crystal devnote-dev/cling (INHERITANCE-BASED
#  via `class X < Cling::Command` + `setup`/`run` overrides), Crystal
#  stdlib OptionParser (LOW-LEVEL imperative `OptionParser.parse {
#  |parser| parser.on(...) }`), Crystal commander.cr (different
#  `commander.cr` library — block-DSL style), R281 Ruby Getopt::Long
#  (Perl-style — different language).  Optimist.cr's approach: RUBY-
#  OPTIMIST-PORTED DSL + `parser.opt(:NAME, "DESC", short: 'X'|nil,
#  alt: "X"|[X,Y], cls: TYPE, default: VAL, permitted: [VALS]) { |evalopt|
#  ... }` MAIN OPTION DSL + Crystal CHAR LITERAL `short: 'x'` (vs
#  STRING `"x"`) + Crystal SYMBOL `:NAME` for option names + ALT
#  ALIAS as STRING or ARRAY + `cls: TYPE` Crystal type coercion +
#  `permitted: [VALS]` ENUM validation + VALUE HANDLER BLOCK
#  `{ |evalopt| evalopt.value.as(TYPE) }` + `parser.parse(ARGV)`
#  returning NamedTuple of typed values + AUTO-INJECTED `--help`/
#  `--version` — corpus's **first documented Ruby-Optimist-ported
#  Crystal CLI library**.  Brings cross-language CLI library taxonomy
#  variant count to 131; Crystal ecosystem now has 6 documented CLI
#  libraries — TIED WITH PYTHON (6) AND OCAML (6) for SECOND-MOST-
#  DOCUMENTED CLI language behind Rust/Go (9).
#
#  Surface (verbatim from `src/colorls/flags.cr` `parser.opt` calls):
#
#  Common options:
#    -a, --all                      Do not ignore entries starting with .
#    -A, --almost-all               Do not list . and ..
#    -d, --dirs                     Show only directories
#    -f, --files                    Show only files
#        --git-status, --gs         Show git status for each file
#        --report                   Show brief report
#
#  Format options:
#        --format=FORMAT            Use format: across/horizontal/
#                                   vertical/long/single-column
#    -1, --one                      List one file per line
#                                   (short=nil; long-only)
#        --tree[=DEPTH]             Show tree view (default depth 3)
#    -x, --lines                    List entries by lines (horizontal)
#    -C, --columns                  List entries by columns (vertical)
#
#  Long-listing options:
#    -l, --long                     Use long listing format
#    -o, --long-groupless           Long listing without group info
#    -g, --long-ownerless           Long listing without owner info
#    -G, --no-group                 Hide group info in long listing
#
#  Group options:
#        --sort-dirs, --sd          Group directories first
#                                   (alt: --group-directories-first)
#        --sort-files, --sf         Group files first
#                                   (alt: --group-files-first)
#
#  Sort options:
#    -t, --sort-time                Sort by modification time (newest)
#    -U, --unsorted                 Do not sort
#    -S, --sort-size                Sort by file size (largest)
#    -X, --sort-extension           Sort by file extension
#        --sort=WORD                Sort by WORD: none/size/time/extension
#    -r, --reverse                  Reverse order while sorting
#    -h, --human-readable           Always enabled (compatibility)
#
#  Color options:
#        --color=MODE               Colorize output: auto/always/never
#                                   (default: auto)
#        --light                    Use light color scheme (long-only)
#        --dark                     Use dark color scheme (long-only)
#
#  Display options:
#        --hyperlink                Create hyperlinks (long-only)
#        --help                     Print help (auto-added)
#
#  Positional:
#    FILE/DIR...                    Files/directories to list
#                                   (default: current directory)
#
#  Dup-skipped neighbors during hunt (also Optimist.cr-based or
#  smaller community Crystal CLI tools):
#    - The colorls Ruby gem (athityakumar/colorls — uses Ruby
#      Optimist gem; this _colorls completion serves BOTH the Ruby
#      and Crystal ports since they share near-identical CLI surface)
#    - tmux-fingers (IN CORPUS via _tmux-fingers — uses Cling not
#      Optimist.cr, R381)
#    - geode / docr / crimson / soar / fossil / iris / focus / tanda /
#      dkeygen (other Crystal tools but use Cling, commander.cr,
#      clim, or OptionParser stdlib)
#    - nanobowers/optimist.cr (the library itself — flagship use is
#      colorls.cr; library has examples but not a user-facing binary)
# ============================================================================

_colorls() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-a --all)'{-a,--all}'[do not ignore entries starting with .]' \
    '(-A --almost-all)'{-A,--almost-all}'[do not list . and ..]' \
    '(-d --dirs)'{-d,--dirs}'[show only directories]' \
    '(-f --files)'{-f,--files}'[show only files]' \
    '--git-status[show git status for each file]' \
    '--gs[show git status for each file (alias)]' \
    '--report[show brief report]' \
    '--format=[output format]:format:(across horizontal vertical long single-column)' \
    '(-1 --one)--one[list one file per line]' \
    '--tree=-[show tree view of directory]::depth' \
    '(-x --lines)'{-x,--lines}'[list entries by lines (horizontal)]' \
    '(-C --columns)'{-C,--columns}'[list entries by columns (vertical)]' \
    '(-l --long)'{-l,--long}'[use long listing format]' \
    '(-o --long-groupless)'{-o,--long-groupless}'[long listing without group info]' \
    '(-g --long-ownerless)'{-g,--long-ownerless}'[long listing without owner info]' \
    '(-G --no-group)'{-G,--no-group}'[hide group info in long listing]' \
    '--sort-dirs[group directories first]' \
    '--sd[group directories first (alias)]' \
    '--group-directories-first[group directories first (alias)]' \
    '--sort-files[group files first]' \
    '--sf[group files first (alias)]' \
    '--group-files-first[group files first (alias)]' \
    '(-t --sort-time)'{-t,--sort-time}'[sort by modification time (newest first)]' \
    '(-U --unsorted)'{-U,--unsorted}'[do not sort; list in directory order]' \
    '(-S --sort-size)'{-S,--sort-size}'[sort by file size (largest first)]' \
    '(-X --sort-extension)'{-X,--sort-extension}'[sort by file extension]' \
    '--sort=[sort by word]:word:(none size time extension)' \
    '(-r --reverse)'{-r,--reverse}'[reverse order while sorting]' \
    '(-h --human-readable)'{-h,--human-readable}'[always enabled (compatibility)]' \
    '--color=[colorize output]:mode:(auto always never)' \
    '--light[use light color scheme]' \
    '--dark[use dark color scheme]' \
    '--hyperlink[create hyperlinks]' \
    '--help[print help]' \
    '*:file or directory:_files'
}

_colorls "$@"
