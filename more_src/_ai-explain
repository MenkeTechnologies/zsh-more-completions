#compdef ai-explain
# Documentation: https://github.com/lxgicstudios/ai-explain
# Reference accessed: 2026-05-22
# Verified: src/cli.ts Commander program definitions.

# Zsh completion for ai-explain - AI-powered code file explainer

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-l --level)'{-l,--level}'[explanation level]:level:(beginner intermediate expert)' \
  '1:file:_files' && ret=0

return ret
