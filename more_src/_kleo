#compdef kleo kleo-tool
# _kleo — KDE Kleopatra OpenPGP/S-MIME certificate manager kleo command-line tool CLI alias (KDE Project, C++); QCommandLineParser
# upstream: https://invent.kde.org/pim/kleopatra

_kleo() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--help-all[show all help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--platform=+[Qt platform plugin]:str:' \
        '--openpgp-import[OpenPGP import mode]' \
        '--cms-import[CMS import mode]' \
        '--encrypt-cms[CMS encrypt mode]' \
        '--encrypt-openpgp[OpenPGP encrypt mode]' \
        '--sign-cms[CMS sign mode]' \
        '--sign-openpgp[OpenPGP sign mode]' \
        '--sign-encrypt-cms[CMS sign+encrypt mode]' \
        '--sign-encrypt-openpgp[OpenPGP sign+encrypt mode]' \
        '--decrypt-verify-cms[CMS decrypt/verify mode]' \
        '--decrypt-verify-openpgp[OpenPGP decrypt/verify mode]' \
        '--verify-cms[CMS verify mode]' \
        '--verify-openpgp[OpenPGP verify mode]' \
        '--checksum[checksum mode]' \
        '--gen-key[gen key mode]' \
        '--gen-revoke[gen revoke mode]' \
        '--certify[certify mode]' \
        '--search[search keys]' \
        '--query=+[search query]:str:' \
        '--parent-windowid=+[parent window id]:str:' \
        '--no-window[no window]' \
        '--daemon[daemon mode]' \
        '--config=+[config file]:file:_files' \
        '*:file:_files'
}

_kleo "$@"
