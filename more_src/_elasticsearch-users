#compdef elasticsearch-users

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'useradd:add a new user'
  'userdel:remove a user'
  'passwd:change a user password'
  'roles:assign roles to a user'
  'list:list users and their roles'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-s,--silent}'[silent]' \
  {-v,--verbose}'[verbose]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'elasticsearch-users subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (useradd)
        _arguments \
          {-p+,--password=}'[password]:password:' \
          {-r+,--roles=}'[comma-separated roles]:roles:' \
          '1:username:_users' && ret=0
        ;;
      (userdel)
        _arguments \
          '1:username:_users' && ret=0
        ;;
      (passwd)
        _arguments \
          {-p+,--password=}'[new password]:password:' \
          '1:username:_users' && ret=0
        ;;
      (roles)
        _arguments \
          {-a+,--add=}'[roles to add]:roles:' \
          {-r+,--remove=}'[roles to remove]:roles:' \
          '1:username:_users' && ret=0
        ;;
    esac
    ;;
esac

return ret
