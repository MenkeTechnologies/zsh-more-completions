#compdef sclean
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Interactively clean an image of bad pixels

local ret=1

_arguments -s -S \
  'IMAGE=[image to be cleaned of bad pixels]:image:_files' \
  'OUTPUT=[resulting cleaned image]:output:_files' \
  'IDEV=[image display device]:idev:' \
  'QUIT=[confirm quitting the application]:quit:(TRUE FALSE)' \
  'DEG=[degree of fit for interpolation]:deg:' \
  'XSIZE=[size of interpolation box in X]:xsize:' \
  'YSIZE=[size of interpolation box in Y]:ysize:' \
  'HIGH=[highest displayed data value]:high:' \
  'LOW=[lowest displayed data value]:low:' \
  'BITNUM=[quality mask bit to modify]:bitnum:' \
  'ZOOM=[minimum pixel magnification factor]:zoom:' \
  'LOGFILE=[file to log cleaning operations to]:logfile:_files' \
  'BATCHFILE=[file to read batch input from]:batchfile:_files' \
  '*:NDF data file:_files' && ret=0

return ret
