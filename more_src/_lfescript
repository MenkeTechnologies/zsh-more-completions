#compdef lfescript
# Documentation: https://github.com/lfe/lfe/blob/develop/doc/lfescript.txt
# Run LFE scripts (LFE equivalent of escript)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show usage help]' \
  '-s[only perform syntactic and semantic check of the script]' \
  '*:lfe script:_files' && ret=0

return ret
