#compdef chasquid
# Documentation: https://man.archlinux.org/search?q=chasquid
# Reference accessed: 2026-05-16

_arguments -s \
  '--config_dir=[config dir]:dir:_files -/' \
  '*--config_overrides=[text proto override]:text:' \
  '--logfile=[log file]:file:_files' \
  '--logtostderr[log to stderr]' \
  '--vmodule=[vmodule]:spec:' \
  '--v=[verbose level]:level:' \
  '(- *)--version[show version]'
