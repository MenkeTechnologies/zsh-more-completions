#compdef chasquid
# Documentation: https://blitiri.com.ar/p/chasquid/man/chasquid.1/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--config_dir=[config dir]:dir:_files -/' \
  '*--config_overrides=[text proto override]:text:' \
  '--logfile=[log file]:file:_files' \
  '--logtostderr[log to stderr]' \
  '--vmodule=[vmodule]:spec:' \
  '--v=[verbose level]:level:' \
  '(- *)--version[show version]'
