#compdef mp4tags
# _mp4tags — set/remove iTunes-compatible MP4 tags (enzo1982/mp4v2)
# upstream: https://github.com/enzo1982/mp4v2
# Flags from util/mp4tags.cpp (prog::Option long_options table).

_mp4tags() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-A --album)'{-A+,--album=}'[album name]:name:' \
        '(-a --artist)'{-a+,--artist=}'[artist]:name:' \
        '(-c --comment)'{-c+,--comment=}'[comment]:text:' \
        '(-C --copyright)'{-C+,--copyright=}'[copyright]:text:' \
        '(-d --disk)'{-d+,--disk=}'[disk number]:n:' \
        '(-D --disks)'{-D+,--disks=}'[total disks]:n:' \
        '(-e --encodedby)'{-e+,--encodedby=}'[encoded by]:tool:' \
        '(-E --tool)'{-E+,--tool=}'[encoding tool name]:tool:' \
        '(-g --genre)'{-g+,--genre=}'[genre]:genre:' \
        '(-G --grouping)'{-G+,--grouping=}'[grouping]:group:' \
        '(-H --hdvideo)'{-H+,--hdvideo=}'[HD video flag]:flag:(0 1)' \
        '(-i --type)'{-i+,--type=}'[media type (e.g. tv/movie)]:type:' \
        '(-I --contentid)'{-I+,--contentid=}'[content ID]:id:' \
        '(-j --genreid)'{-j+,--genreid=}'[genre ID]:id:' \
        '(-l --longdesc)'{-l+,--longdesc=}'[long description]:text:' \
        '(-L --lyrics)'{-L+,--lyrics=}'[lyrics file]:file:_files' \
        '(-m --description)'{-m+,--description=}'[description]:text:' \
        '(-M --episode)'{-M+,--episode=}'[TV episode number]:n:' \
        '(-n --season)'{-n+,--season=}'[TV season number]:n:' \
        '(-N --network)'{-N+,--network=}'[TV network]:net:' \
        '(-o --episodeid)'{-o+,--episodeid=}'[episode ID]:id:' \
        '(-O --playlistid)'{-O+,--playlistid=}'[playlist ID]:id:' \
        '(-P --picture)'{-P+,--picture=}'[cover-art picture file]:file:_files' \
        '(-B --podcast)'{-B+,--podcast=}'[mark as podcast]:flag:(0 1)' \
        '(-s --song)'{-s+,--song=}'[song / track name]:name:' \
        '(-S --show)'{-S+,--show=}'[TV show name]:name:' \
        '(-T --tempo)'{-T+,--tempo=}'[BPM]:bpm:' \
        '(-t --track)'{-t+,--track=}'[track number]:n:' \
        '(-T --tracks)'{--tracks=}'[total tracks]:n:' \
        '(-x --xid)'{-x+,--xid=}'[external ID]:id:' \
        '(-w --writer)'{-w+,--writer=}'[composer]:name:' \
        '(-y --year)'{-y+,--year=}'[release date]:date:' \
        '--artistid=[artist ID]:id:' \
        '--composerid=[composer ID]:id:' \
        '(-R --albumartist)'{-R+,--albumartist=}'[album artist]:name:' \
        '--category=[category]:cat:' \
        '--rating=[content rating]:rating:' \
        '--sortname=[sort name]:name:' \
        '--sortartist=[sort artist]:name:' \
        '--sortalbum=[sort album]:name:' \
        '--sorttvshow=[sort TV show]:name:' \
        '--sortalbumartist=[sort album artist]:name:' \
        '--sortcomposer=[sort composer]:name:' \
        '--purchasedate=[purchase date]:date:' \
        '(-r --remove)'{-r+,--remove=}'[remove specified tags]:tags:' \
        '*:MP4 file:_files -g "*.(m4a|m4v|mp4)"'
}

_mp4tags "$@"
