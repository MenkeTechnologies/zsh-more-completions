#compdef udevadm

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'info:show device information'
  'trigger:request kernel events'
  'settle:wait for udev event queue to flush'
  'control:control udev daemon'
  'monitor:listen for kernel and udev events'
  'hwdb:hardware database tools'
  'test:test event run for a device'
  'test-builtin:test a builtin command'
  'verify:verify udev rules files'
  'cat:show currently active rules'
  'wait:wait for a device to appear/be initialized'
  'lock:lock a device'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'udevadm subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (info)
        _arguments \
          '(-q --query)'{-q,--query=}'[query type]:type:(name symlink path property all)' \
          '--property=[property name]:name:' \
          '--value[show only value]' \
          '(-p --path)'{-p,--path=}'[device path]:path:' \
          '(-n --name)'{-n,--name=}'[device file]:file:_files' \
          '(-r --root)'{-r,--root}'[show absolute paths]' \
          '(-a --attribute-walk)'{-a,--attribute-walk}'[walk parent attributes]' \
          '(-t --tree)'{-t,--tree}'[show device tree]' \
          '(-x --export)'{-x,--export}'[export key/value pairs]' \
          '(-P --export-prefix)'{-P,--export-prefix=}'[export prefix]:name:' \
          '(-d --device-id-of-file)'{-d,--device-id-of-file=}'[print device id]:file:_files' \
          '(-e --export-db)'{-e,--export-db}'[export database]' \
          '(-c --cleanup-db)'{-c,--cleanup-db}'[clean up database]' \
          '(-w --wait-for-initialization)'{-w,--wait-for-initialization=}'[wait until initialized]:secs:' \
          '--no-pager[disable pager]' \
          '--json=[JSON mode]:mode:(pretty short off)' && ret=0
        ;;
      (trigger)
        _arguments \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '(-t --type)'{-t,--type=}'[type to trigger]:type:(devices subsystems all)' \
          '(-c --action)'{-c,--action=}'[action]:action:(add remove change move online offline bind unbind)' \
          '(-s --subsystem-match)'{-s,--subsystem-match=}'[match subsystem]:subsystem:' \
          '(-S --subsystem-nomatch)'{-S,--subsystem-nomatch=}'[skip subsystem]:subsystem:' \
          '(-a --attr-match)'{-a,--attr-match=}'[attr match]:attr:' \
          '(-A --attr-nomatch)'{-A,--attr-nomatch=}'[attr nomatch]:attr:' \
          '(-p --property-match)'{-p,--property-match=}'[property match]:prop:' \
          '(-g --tag-match)'{-g,--tag-match=}'[tag match]:tag:' \
          '(-y --sysname-match)'{-y,--sysname-match=}'[sysname match]:name:' \
          '--name-match=[name match]:name:' \
          '(-b --parent-match)'{-b,--parent-match=}'[parent match]:syspath:' \
          '--include-parents[include parents]' \
          '(-w --settle)'{-w,--settle}'[wait for settle]' \
          '--uuid[print event UUIDs]' && ret=0
        ;;
      (settle)
        _arguments \
          '(-t --timeout)'{-t,--timeout=}'[timeout seconds]:secs:' \
          '(-E --exit-if-exists)'{-E,--exit-if-exists=}'[exit if file exists]:file:_files' && ret=0
        ;;
      (control)
        _arguments \
          '(-e --exit)'{-e,--exit}'[ask udevd to exit]' \
          '(-l --log-level)'{-l,--log-level=}'[set log level]:level:(emerg alert crit err warning notice info debug)' \
          '(-s --stop-exec-queue)'{-s,--stop-exec-queue}'[pause queue]' \
          '(-S --start-exec-queue)'{-S,--start-exec-queue}'[resume queue]' \
          '(-R --reload)'{-R,--reload}'[reload rules]' \
          '(-p --property)'{-p,--property=}'[set global property]:property:' \
          '(-m --children-max)'{-m,--children-max=}'[max forked children]:n:' \
          '--ping[ping the daemon]' \
          '--trace=[trace]:flag:(true false)' \
          '--revert[revert flags]' \
          '(-t --timeout)'{-t,--timeout=}'[timeout seconds]:secs:' && ret=0
        ;;
      (monitor)
        _arguments \
          '(-k --kernel)'{-k,--kernel}'[kernel events only]' \
          '(-u --udev)'{-u,--udev}'[udev events only]' \
          '(-p --property)'{-p,--property}'[show properties]' \
          '(-s --subsystem-match)'{-s,--subsystem-match=}'[match subsystem]:subsystem:' \
          '(-t --tag-match)'{-t,--tag-match=}'[match tag]:tag:' && ret=0
        ;;
      (hwdb)
        _arguments \
          '(-u --update)'{-u,--update}'[update hwdb files]' \
          '(-t --test)'{-t,--test=}'[test modalias]:modalias:' \
          '(-r --root)'{-r,--root=}'[root directory]:dir:_files -/' \
          '--usr[place hwdb in /usr]' \
          '--strict[fail on errors]' && ret=0
        ;;
      (test)
        _arguments \
          '(-a --action)'{-a,--action=}'[action]:action:(add remove change)' \
          '(-N --resolve-names)'{-N,--resolve-names=}'[resolve names]:when:(early late never)' \
          '(-D --extra-rules-dir)'{-D,--extra-rules-dir=}'[extra rules dir]:dir:_files -/' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '--json=[JSON mode]:mode:(pretty short off)' \
          ':device:' && ret=0
        ;;
      (test-builtin)
        _arguments \
          '(-a --action)'{-a,--action=}'[action]:action:(add remove change)' \
          ':builtin:(blkid btrfs hwdb input_id keyboard kmod net_id net_setup_link path_id usb_id uaccess)' \
          ':devpath:' && ret=0
        ;;
      (verify)
        _arguments \
          '(-N --resolve-names)'{-N,--resolve-names=}'[resolve names]:when:(early late never)' \
          '--root=[root directory]:dir:_files -/' \
          '--no-summary[do not print summary]' \
          '--no-style[plain output]' \
          '*:rules:_files -g "*.rules"' && ret=0
        ;;
      (cat)
        _arguments \
          '--root=[root directory]:dir:_files -/' \
          '--tldr[short summary]' \
          '--config[show config files]' && ret=0
        ;;
      (wait)
        _arguments \
          '(-t --timeout)'{-t,--timeout=}'[timeout seconds]:secs:' \
          '--initialized=[wait until initialized]:flag:(true false)' \
          '--removed[wait until removed]' \
          '--settle[wait for queue to settle]' && ret=0
        ;;
      (lock)
        _arguments \
          '(-d --device)'{-d,--device=}'[device]:dev:' \
          '(-b --backing)'{-b,--backing=}'[backing path]:path:_files' \
          '(-t --timeout)'{-t,--timeout=}'[timeout seconds]:secs:' \
          '(-p --print)'{-p,--print}'[print info]' && ret=0
        ;;
    esac
    ;;
esac

return ret
