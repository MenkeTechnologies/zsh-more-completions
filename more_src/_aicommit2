#compdef aicommit2
# Documentation: https://github.com/tak-bro/aicommit2
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-l --locale)'{-l,--locale}'=[locale for messages]:locale:' \
  '(-g --generate)'{-g,--generate}'[number of messages to generate]:n:' \
  '*'{-x,--exclude}'+[exclude path from analysis]:path:_files' \
  '(-a --all)'{-a,--all}'[stage tracked changes]' \
  '(-t --type)'{-t,--type}'=[commit message style]:type:' \
  '(-y --confirm)'{-y,--confirm}'[skip commit confirmation]' \
  '(-c --clipboard)'{-c,--clipboard}'[copy message to clipboard]' \
  '(-p --prompt)'{-p,--prompt}'+[custom prompt]:prompt:' \
  '--watch-commit[watch commit flow]' \
  '--hook-mode[git hook chaining mode]' \
  '--pre-commit[pre-commit framework mode]' \
  '(-i --include-body)'{-i,--include-body}'[force commit body in messages]' \
  '(-s --auto-select)'{-s,--auto-select}'[auto-select single message]' \
  '(-e --edit)'{-e,--edit}'[open message in editor]' \
  '--disable-lowercase[keep message casing]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '--git[force Git backend]' \
  '--yadm[force YADM backend]' \
  '--jj[force Jujutsu backend]' \
  '--jj-auto-new[jj new after describe]' \
  '(-d --dry-run)'{-d,--dry-run}'[print message without committing]' \
  '(-o --output)'{-o,--output}'=[output format]:format:(json)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*::args: _default' && ret=0

return ret
