#compdef sbocheck sboclean sboconfig sbofind sbohints sboinstall sboremove sbosnap sboupgrade
# Documentation: https://man.archlinux.org/search?q=sbocheck
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

case $service in
  (sboinstall|sboupgrade)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-c --noclean)'{-c,--noclean}'+[do not clean tmp]:flag:(TRUE FALSE)' \
      '(-d --distclean)'{-d,--distclean}'+[remove source tarballs]:flag:(TRUE FALSE)' \
      '(-i --noinstall)'{-i,--noinstall}'[build only]' \
      '(-j --jobs)'{-j,--jobs}'+[parallel jobs]:n:' \
      '(-p --compat32)'{-p,--compat32}'[build compat32 package]' \
      '(-r --nointeractive)'{-r,--nointeractive}'[non-interactive]' \
      '(-z --force)'{-z,--force}'[force upgrade]' \
      '*:package:' && ret=0 ;;
  (sboremove)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-a --alwaysask)'{-a,--alwaysask}'[ask about every removal]' \
      '(-p --compat32)'{-p,--compat32}'[remove compat32]' \
      '*:package:' && ret=0 ;;
  (sbofind)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-A --all-reverse)'{-A,--all-reverse}'[all reverse deps]' \
      '(-e --exact-case)'{-e,--exact-case}'[exact case]' \
      '(-E --exact)'{-E,--exact}'[exact match]' \
      '(-i --info)'{-i,--info}'[show info]' \
      '(-r --readme)'{-r,--readme}'[show README]' \
      '(-q --queue)'{-q,--queue}'[show queue]' \
      '(-t --top-reverse)'{-t,--top-reverse}'[top-level reverse]' \
      '(-R --reverse)'{-R,--reverse}'[reverse deps]' \
      '*:query:' && ret=0 ;;
  (sboconfig)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-l --list)'{-l,--list}'[list current config]' \
      '(-c --noclean)'{-c,--noclean}'+[NOCLEAN]:flag:(TRUE FALSE)' \
      '(-d --distclean)'{-d,--distclean}'+[DISTCLEAN]:flag:(TRUE FALSE)' \
      '(-j --jobs)'{-j,--jobs}'+[JOBS]:n:' \
      '(-p --pkg-dir)'{-p,--pkg-dir}'+[PKG_DIR]:dir:_files -/' \
      '(-s --sbo-home)'{-s,--sbo-home}'+[SBO_HOME]:dir:_files -/' \
      '(-V --version-set)'{-V,--version-set}'+[SBO_VERSION]:ver:' \
      '(-r --rsync)'{-r,--rsync}'+[RSYNC_DEFAULT]:url:' \
      '(-o --local-overrides)'{-o,--local-overrides}'+[LOCAL_OVERRIDES]:dir:_files -/' \
      '(-O --slackware-version)'{-O,--slackware-version}'+[SLACKWARE_VERSION]:ver:' \
      '(-R --repo)'{-R,--repo}'+[REPO]:url:' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' && ret=0 ;;
esac

return ret
