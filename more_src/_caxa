#compdef caxa
# Documentation: https://www.npmjs.com/package/caxa
# caxa - package Node.js applications into executable binaries

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --input)'{-i,--input}'=[the input directory to package]:dir:_files -/' \
  '(-o --output)'{-o,--output}'=[the path where the executable will be produced]:file:_files' \
  '(-e --exclude)'{-e,--exclude}'=[paths to exclude from the build]:path:_files' \
  '(-N --no-include-node)'{-N,--no-include-node}'[do not copy the Node.js executable into the package]' \
  '(-s --stub)'{-s,--stub}'=[path to a custom stub]:file:_files' \
  '--identifier=[build identifier used for the extraction path]:identifier' \
  '(-F --no-force)'{-F,--no-force}'[do not overwrite output if it exists]' \
  '(-m --uncompression-message)'{-m,--uncompression-message}'=[message to show while uncompressing]:message' \
  '*:command:_command_names' && ret=0

return ret
