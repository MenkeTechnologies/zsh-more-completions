#compdef ohdear-cli
# Documentation: https://github.com/ohdearapp/ohdear-cli
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:authenticate with API token'
  'logout:remove stored credentials'
  'list:display all available commands'
  'get-me:show authenticated user info'
  'clear-cache:remove cached OpenAPI spec'
  'list-monitors:view all monitors'
  'get-monitor:retrieve specific monitor details'
  'create-monitor:add new monitor'
  'delete-monitor:remove a monitor'
  'get-uptime:get monitor uptime'
  'get-downtime:get monitor downtime'
  'list-broken-links:list broken links'
  'list-mixed-content:list mixed content'
  'get-certificate-health:certificate health'
  'get-latest-lighthouse-report:latest Lighthouse report'
  'list-lighthouse-reports:list Lighthouse reports'
  'start-maintenance:start maintenance window'
  'stop-maintenance:stop maintenance window'
  'list-maintenance-periods:list maintenance periods'
  'list-status-pages:list status pages'
  'get-status-page:get status page'
  'create-status-page-update:post status page update'
  'list-cron-checks:list cron checks'
  'create-cron-check:create cron check'
  'list-tags:list tags'
  'install-skill:install AI assistant integration'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json[output as JSON]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:_default' && ret=0

case $state in
  cmd) _describe -t commands 'ohdear-cli command' commands && ret=0 ;;
esac

return ret
