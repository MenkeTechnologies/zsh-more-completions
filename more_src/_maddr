#compdef maddr
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/maddr.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# maddr: extract mail addresses from messages (courier-maildrop)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[only print the addr-spec, not the display name]' \
  '-d[only print the display name]' \
  '-h[colon-separated list of headers to search]:headers' \
  '*:message file:_files' && ret=0

return ret
