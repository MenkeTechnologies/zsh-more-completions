#compdef maddr
# Documentation: https://man.archlinux.org/search?q=maddr
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[print only the address part]' \
  '-h[print only the header name]' \
  '-d[print only the domain part]' \
  '*:message:_files' && ret=0

return ret
