#compdef tensorboard

# Zsh completion for TensorBoard

_tensorboard() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--logdir=[directory containing TensorFlow event files]:log directory:_files -/' \
    '--logdir_spec=[comma-separated list of name:logdir pairs]:logdir spec:' \
    '--host=[hostname to bind to]:hostname:_hosts' \
    '--port=[port to serve on]:port number:' \
    '--purge_orphaned_data[purge orphaned data]' \
    '--reload_interval=[how often to reload data in seconds]:seconds:' \
    '--reload_multifile[poll all event files for new data]' \
    '--reload_multifile_inactive_secs=[time before a file is considered inactive]:seconds:' \
    '--reload_task=[reload data task type]:type:(auto thread process)' \
    '--db=[database URI]:URI:' \
    '--db_import[import event files into database]' \
    '--inspect[print a summary of event files to command line]' \
    '--version_tb[print the version of TensorBoard]' \
    '--tag=[tag filter]:tag:' \
    '--event_file=[event file to load]:event file:_files' \
    '--path_prefix=[URL path prefix for TensorBoard]:prefix:' \
    '--window_title=[set the browser window title]:title:' \
    '--max_reload_threads=[max number of threads for loading data]:threads:' \
    '--reload_multifile_inactive_secs=[seconds before inactive file skip]:seconds:' \
    '--generic_data=[read generic data]:mode:(true false auto)' \
    '--samples_per_plugin=[sample count per plugin]:JSON:' \
    '--detect_file_replacement[detect files being replaced]' \
    '--bind_all[serve on all public interfaces]' \
    '--load_fast=[use fast loading]:mode:(true false auto)' \
    '--extra_data_server_flags=[additional data server flags]:flags:' \
    '--grpc_creds_type=[gRPC server credentials type]:type:(local insecure)' \
    '--grpc_data_provider=[use gRPC data provider]:address:' \
    '(-h --help)'{-h,--help}'[display help]' \
    '--helpfull[display full help]' \
    && ret=0

  return ret
}

_tensorboard "$@"
