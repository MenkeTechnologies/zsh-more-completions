#compdef qterm
# Documentation: https://man.archlinux.org/search?q=qterm
# Reference accessed: 2026-05-16

# qterm: terminate a PBS server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-t[type]:type:(immediate delay quick)' \
  '*:server:_hosts' && ret=0
return ret
