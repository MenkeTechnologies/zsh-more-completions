#compdef qterm
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man8/qterm.8B.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# qterm: terminate processing by a PBS batch server.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-t[type of shutdown]:type:(immediate delay quick)' \
  '*:server:_hosts' && ret=0

return ret
