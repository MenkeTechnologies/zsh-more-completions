#compdef crowdin
# Documentation: https://man.archlinux.org/search?q=crowdin
# Reference accessed: 2026-05-16

# crowdin/crowdin-cli — picocli RootCommand + CommandNames.java
# Nested verbs for upload|push, download|pull, config, status, branch, …

local curcontext="$curcontext" state line ret=1
local -a g top ch_upload ch_download ch_config ch_status ch_branch ch_string ch_glossary ch_tm ch_task ch_bundle ch_comment ch_distribution ch_screenshot ch_label ch_file ch_language ch_project ch_app ch_context

g=(
  '(-c --config)'{-c,--config=}'[crowdin.yml path]:file:_files'
  '--identity=[API credentials JSON]:file:_files'
  '(-h --help)'{-h,--help}'[help]'
  '(-V --version)'{-V,--version}'[version]'
  '(-v --verbose)'{-v,--verbose}'[verbose API logs]'
  '--no-progress[disable progress UI]'
  '--no-colors[disable ANSI colors]'
  '--debug[print stack traces]'
)

top=(
  'upload:push sources or translations'
  'push:alias for upload'
  'download:pull sources or translations'
  'pull:alias for download'
  'init:scaffold Crowdin configuration'
  'status:translation or proofreading progress'
  'string:string operations'
  'glossary:glossary import/export'
  'tm:translation memory'
  'task:translation tasks'
  'bundle:resource bundles'
  'pre-translate:apply TM/MT pre-translation'
  'branch:branches'
  'comment:comments'
  'distribution:CDN distributions'
  'screenshot:context screenshots'
  'label:project labels'
  'file:generic file operations'
  'language:languages'
  'config:validate/list config pieces'
  'project:project metadata'
  'app:Marketplace apps'
  'context:screenshot/context bundles'
  'completion:print shell completion script'
)

ch_upload=( sources translations )
ch_download=( sources translations )
ch_config=( lint sources translations )
ch_status=( translation proofreading )
ch_branch=( add clone delete edit list merge )
ch_string=( add delete edit list )
ch_glossary=( list upload download )
ch_tm=( list upload download )
ch_task=( add list )
ch_bundle=( add browse clone delete download list )
ch_comment=( add list resolve )
ch_distribution=( add edit list release )
ch_screenshot=( delete list upload )
ch_label=( add delete list )
ch_file=( delete download list upload )
ch_language=( list )
ch_project=( add browse list )
ch_app=( list install uninstall )
ch_context=( download reset status upload )

_arguments -s -S "$g[@]" '1: :->c1' '*:: :->rest' && ret=0

case $state in
  c1)
    _describe -t commands 'crowdin' top && ret=0
    ;;
  rest)
    case $line[1] in
      upload|push)
        if (( ${#line} == 1 )); then
          _wanted upload expl 'upload' compadd -a ch_upload && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      download|pull)
        if (( ${#line} == 1 )); then
          _wanted download expl 'download' compadd -a ch_download && ret=0
        else
          _arguments -s -S \
            "$g[@]" \
            '(-b --branch)'{-b,--branch=}'[branch name]:branch:' \
            '(-l --language)'{-l,--language=}'[language ID]:lang:' \
            '(-e --exclude-language)'{-e,--exclude-language=}'[exclude language]:lang:' \
            '--ignore-match[ignore export pattern filters]' \
            '--pseudo[pseudo translation]' \
            '--skip-untranslated-strings' \
            '--skip-untranslated-files' \
            '--export-only-approved' \
            '--keep-archive[keep downloaded zip]' \
            '--all[all files / all languages]' \
            '--dryrun[list remote files only]' \
            '--tree[tree-style dry run]' \
            '--plain[plain table output]' \
            '*: :_normal' && ret=0
        fi
        ;;
      config)
        if (( ${#line} == 1 )); then
          _wanted config expl 'config' compadd -a ch_config && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      status)
        if (( ${#line} == 1 )); then
          _wanted status expl 'status' compadd -a ch_status && ret=0
        else
          _arguments -s -S \
            "$g[@]" \
            '(-l --language)'{-l,--language=}'[language ID]:id:' \
            '(-b --branch)'{-b,--branch=}'[branch name]:branch:' \
            '(-f --file)'{-f,--file=}'[file path]:path:_files' \
            '(-d --directory)'{-d,--directory=}'[directory path]:dir:_files -/' \
            '*: :_normal' && ret=0
        fi
        ;;
      branch)
        if (( ${#line} == 1 )); then
          _wanted branch expl 'branch' compadd -a ch_branch && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      string)
        if (( ${#line} == 1 )); then
          _wanted string expl 'string' compadd -a ch_string && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      glossary)
        if (( ${#line} == 1 )); then
          _wanted glossary expl 'glossary' compadd -a ch_glossary && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      tm)
        if (( ${#line} == 1 )); then
          _wanted tm expl 'tm' compadd -a ch_tm && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      task)
        if (( ${#line} == 1 )); then
          _wanted task expl 'task' compadd -a ch_task && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      bundle)
        if (( ${#line} == 1 )); then
          _wanted bundle expl 'bundle' compadd -a ch_bundle && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      comment)
        if (( ${#line} == 1 )); then
          _wanted comment expl 'comment' compadd -a ch_comment && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      distribution)
        if (( ${#line} == 1 )); then
          _wanted distribution expl 'distribution' compadd -a ch_distribution && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      screenshot)
        if (( ${#line} == 1 )); then
          _wanted screenshot expl 'screenshot' compadd -a ch_screenshot && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      label)
        if (( ${#line} == 1 )); then
          _wanted label expl 'label' compadd -a ch_label && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      file)
        if (( ${#line} == 1 )); then
          _wanted file expl 'file' compadd -a ch_file && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      language)
        if (( ${#line} == 1 )); then
          _wanted language expl 'language' compadd -a ch_language && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      project)
        if (( ${#line} == 1 )); then
          _wanted project expl 'project' compadd -a ch_project && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      app)
        if (( ${#line} == 1 )); then
          _wanted app expl 'app' compadd -a ch_app && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      context)
        if (( ${#line} == 1 )); then
          _wanted context expl 'context' compadd -a ch_context && ret=0
        else
          _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        fi
        ;;
      init|pre-translate|completion)
        _arguments -s -S "$g[@]" '*: :_normal' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
