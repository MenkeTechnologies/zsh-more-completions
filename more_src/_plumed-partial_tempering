#compdef plumed-partial_tempering
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/partial_tempering.html
# PLUMED partial_tempering: scale GROMACS topology parameters for solute tempering

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--gromacs4[use GROMACS 4 compatibility]' \
  '*:scale:' && ret=0

return ret
