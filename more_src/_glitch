#compdef glitch
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss70.html
# KAPPA: replace bad pixels in a two-dimensional NDF with the local median

local ret=1

_arguments -s \
  'IN=[input two-dimensional image]:NDF:_files' \
  'OUT=[output corrected image]:NDF:_files' \
  'TITLE=[title for the output image]:title' \
  'INCAT=[positions-list catalogue]:catalogue:_files' \
  'INFILE=[text file of pixel coordinates]:file:_files' \
  'MODE=[method for identifying pixels]:mode:(Bad Catalogue File Interface)' \
  'PIXPOS=[individual pixel position to replace]:pixpos' \
  '*:NDF:_files' && ret=0

return ret
