#compdef abduco
# Documentation: https://www.mankier.com/1/abduco
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '-a[attach to existing session]:session name:'
  '-A[attach to session or create it]:session name:'
  '-c[create new session]:session name:'
  '-n[create detached session]:session name:'
  '-r[read-only attach]:session name:'
  '-e[set detach key]:key:'
  '-f[force create session]'
  '-l[list sessions]'
  '*::command:_command_names -e'
)

_arguments -s -S $arguments
