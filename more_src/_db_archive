#compdef db_archive
# Documentation: db_archive usage (Berkeley DB 18.1.40)
# Source: list / remove unused Berkeley DB log files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-a[show absolute paths]' \
    '-d[delete unused log files]' \
    '-l[list all log files]' \
    '-s[show all database files]' \
    '-v[verbose]' \
    '-h+[environment home]:dir:_files -/' \
    '-m+[message prefix]:msg_pfx:' \
    '-P+[password]:password:' \
    && ret=0

return ret
