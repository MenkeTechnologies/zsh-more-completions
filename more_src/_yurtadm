#compdef yurtadm
# _yurtadm — OpenYurt admin tool (openyurtio/openyurt)
# upstream: https://github.com/openyurtio/openyurt
# Subcommands from pkg/yurtadm/cmd/cmd.go (cobra).

_yurtadm() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                join:'join a node to a Kubernetes cluster as an OpenYurt edge node'
                reset:'reset node-side OpenYurt configuration'
                token:'manage bootstrap and discovery tokens'
                renew:'renew node certificates'
                static-pods:'manage static pods used by OpenYurt'
                config:'manage yurtadm config'
                docs:'generate documentation'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                join)
                    _arguments \
                        '--config=[joinConfiguration file]:file:_files' \
                        '--token=[bootstrap token]:token:' \
                        '--node-type=[node type]:type:(edge cloud)' \
                        '--node-name=[node name]:name:' \
                        '--namespace=[namespace]:ns:' \
                        '--nodepool-name=[node pool name]:name:' \
                        '--cri-socket=[CRI socket]:path:_files' \
                        '--organizations=[bootstrap certificate organizations]:list:' \
                        '--pause-image=[pause container image]:image:' \
                        '--yurthub-image=[yurthub image]:image:' \
                        '--yurthub-binary-url=[yurthub binary URL]:url:_urls' \
                        '--host-control-plane-addr=[host control plane address]:url:' \
                        '--discovery-token-unsafe-skip-ca-verification[skip CA verification]' \
                        '--node-labels=[node labels (k=v,...)]:labels:' \
                        '--kubernetes-resource-server=[Kubernetes resource download server]:url:_urls' \
                        '*::api endpoint:' ;;
            esac
            ;;
    esac
}

_yurtadm "$@"
