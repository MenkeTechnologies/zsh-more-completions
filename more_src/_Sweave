#compdef Sweave
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/utils/html/Sweave.html
# R CMD Sweave: front-end for Sweave and other vignette engines

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '--driver=[use named Sweave driver]:driver:' \
  '--engine=[use named vignette engine]:engine:' \
  '--encoding=[default encoding for file]:encoding:' \
  '--clean=[remove some of the files created in the working directory]:mode:(default keepOuts)' \
  '--clean[corresponds to --clean=default]' \
  '--options=[comma-separated list of Sweave/engine options]:options:' \
  '--pdf[convert to PDF document]' \
  '--compact=[try to compact PDF document]:mode:(no qpdf gs gs+qpdf both)' \
  '--compact[same as --compact=qpdf]' \
  '*:file:_files' && ret=0

return ret
