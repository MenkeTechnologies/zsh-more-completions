#compdef foxtrotgps
# Documentation: https://man.archlinux.org/search?q=foxtrotgps
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:gpx file:_files -g "*.gpx"' && ret=0

return ret
