#compdef create-bfs
# Documentation: https://www.npmjs.com/package/create-bfs
# Reference accessed: 2026-05-24
# Verified: npm view create-bfs bin; npx create-bfs --help; npx create-bfs create --help; npx create-bfs add --help.

# Zsh completion for create-bfs - Better Fullstack polyglot scaffolder (552 stack options)

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-h --help)'{-h,--help}'[display help]'   '(-V --version)'{-V,--version}'[print version]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command'       'create:scaffold a Better Fullstack project'       'add:add addons or deployment targets to an existing project'       'sponsors:show Better Fullstack sponsors'       'docs:open Better Fullstack documentation'       'builder:open the interactive web stack builder'       'history:show history of scaffolded projects'       'update-deps:check and update dependency versions'       'mcp:start the Better Fullstack MCP server' && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments -C           '--template=[predefined template]:template:(mern pern t3 uniwind none)'           '(-y --yes)'{-y,--yes}'[use default configuration]'           '--yolo[bypass validations and compatibility checks]'           '--verbose[show detailed result information]'           '--dry-run[preview generated file tree without writing]'           '--ecosystem=[language ecosystem]:ecosystem:(typescript react-native rust python go java elixir)'           '--database=[database type]:database:(none sqlite postgres mysql mongodb edgedb redis)'           '--orm=[ORM type]:orm:(drizzle prisma mongoose typeorm kysely mikroorm sequelize none)'           '--auth=[auth provider]:auth:(better-auth go-better-auth clerk nextauth stack-auth supabase-auth auth0 none)'           '--payments=[payments provider]:payments:(polar stripe lemon-squeezy paddle dodo none)'           '--backend=[backend framework]:backend:(hono elysia express fastify nest hono-node none)'           '--runtime=[runtime environment]:runtime:(bun node deno none)'           '--api=[API type]:api:(trpc orpc graphql rest none)'           '--package-manager=[package manager]:manager:(npm pnpm bun yarn uv auto)'           '--web-deploy=[web deployment target]:web-deploy:(cloudflare fly railway docker sst vercel none)'           '--server-deploy=[server deployment target]:server-deploy:(cloudflare fly railway docker sst vercel none)'           '--install[install dependencies after scaffolding]'           '--no-install[skip dependency installation]'           '--git[initialize git repository]'           '--no-git[skip git initialization]'           ':project name or path:_files' && ret=0
        ;;
      add)
        _arguments -C           '--addons=[comma-separated addons]:addons:(pwa tauri starlight biome lefthook husky ruler mcp skills turborepo fumadocs ultracite oxlint opentui wxt msw storybook tanstack-query tanstack-table tanstack-virtual tanstack-db tanstack-pacer docker-compose none)'           '--web-deploy=[web deployment target]:web-deploy:(cloudflare fly railway docker sst vercel none)'           '--server-deploy=[server deployment target]:server-deploy:(cloudflare fly railway docker sst vercel none)'           '--install[install dependencies after adding]'           '--package-manager=[package manager]:manager:(npm pnpm bun yarn)'           '--project-dir=[project directory]:directory:_directories' && ret=0
        ;;
      mcp)
        _arguments -C           '--input=[JSON input for MCP server]:json:' && ret=0
        ;;
      *)
        _arguments -C           '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
