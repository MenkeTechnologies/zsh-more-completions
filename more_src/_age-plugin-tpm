#compdef age-plugin-tpm

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--generate[generate a new identity bound to the TPM]' \
  '--age-plugin=[run as an age plugin]:state machine' \
  '--tpm-path=[path to TPM device]:device:_files -g "/dev/tpm*"' \
  '-o+[output file]:file:_files' && ret=0

return ret
