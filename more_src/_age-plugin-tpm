#compdef age-plugin-tpm
# Documentation: https://github.com/Foxboron/age-plugin-tpm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--generate[generate a new identity bound to the TPM]' \
  '--age-plugin=[run as an age plugin]:state machine' \
  '--tpm-path=[path to TPM device]:device:_files -g "/dev/tpm*"' \
  '-o+[output file]:file:_files' && ret=0

return ret
