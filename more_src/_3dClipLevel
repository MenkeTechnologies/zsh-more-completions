#compdef 3dClipLevel
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dClipLevel.html
# AFNI: estimate a clipping threshold separating brain from background

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-mfrac[clip-level multiplicative fraction]:ff:' \
  '-doall[process each sub-brick separately]' \
  '-grad[output per-voxel gradual clip dataset]:ppp:_files' \
  '*:dataset:_files' && ret=0

return ret
