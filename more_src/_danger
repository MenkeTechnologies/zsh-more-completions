#compdef danger

# Zsh completion for Danger - automated code review

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'ci:run Danger on CI'
      'init:create a Dangerfile'
      'local:run Danger locally on a PR'
      'pr:run Danger against a PR'
      'process:run Danger with a subprocess'
      'runner:run Danger'
      'reset-status:reset PR status'
    )
    _describe -t commands 'danger command' commands && ret=0
    ;;
  args)
    case $line[1] in
      ci)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--base=[base branch]:branch' \
          '--dangerfile=[path to Dangerfile]:file:_files -g "*.{ts,js}"' \
          '-d+[path to Dangerfile]:file:_files -g "*.{ts,js}"' \
          '--id=[danger run ID]:id' \
          '--failOnErrors[fail on errors]' \
          '--new-comment[always create a new comment]' \
          '--remove-previous-comments[remove previous comments]' \
          '--text-only[use text output only]' \
          '--verbose[verbose output]' && ret=0
        ;;
      local|pr)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--dangerfile=[path to Dangerfile]:file:_files -g "*.{ts,js}"' \
          '-d+[path to Dangerfile]:file:_files -g "*.{ts,js}"' \
          '--id=[danger run ID]:id' \
          '--verbose[verbose output]' \
          '1:PR URL or path' && ret=0
        ;;
      process)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--dangerfile=[path to Dangerfile]:file:_files' \
          '-d+[path to Dangerfile]:file:_files' \
          '--id=[danger run ID]:id' \
          '--verbose[verbose output]' \
          '1:process path:_files' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
