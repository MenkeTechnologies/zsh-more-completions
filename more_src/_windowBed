#compdef windowBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/window.html
# screen for overlaps within a window around features (bedtools window)

local ret=1

_arguments -s -S \
  '-a[query file (BAM/BED/GFF/VCF)]:file:_files' \
  '*-b[database file(s)]:file:_files' \
  '-abam[BAM file A]:file:_files' \
  '-ubam[write uncompressed BAM output]' \
  '-bed[when using BAM input, write output as BED]' \
  '-w[base pairs added upstream and downstream (default 1000)]:bp' \
  '-l[base pairs added upstream (left)]:bp' \
  '-r[base pairs added downstream (right)]:bp' \
  '-sw[define -l and -r based on strand]' \
  '-sm[only report B hits on the same strand]' \
  '-Sm[only report B hits on the opposite strand]' \
  '-u[write original A entry once if any overlaps]' \
  '-c[report number of hits in B per A entry]' \
  '-v[report A entries with no overlaps in B]' \
  '-header[print the header from the A file before results]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
