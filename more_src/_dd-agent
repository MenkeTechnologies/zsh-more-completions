#compdef dd-agent datadog-agent
# _dd-agent — Datadog Agent runtime CLI (Datadog, Go); spf13/cobra
# upstream: https://github.com/DataDog/datadog-agent

_dd-agent() {
    local -a sub=(
        'check:run a single check'
        'config:dump runtime config'
        'configcheck:print all loaded configs'
        'dogstatsd:dogstatsd server commands'
        'diagnose:run diagnose'
        'flare:collect flare bundle'
        'hostname:print resolved hostname'
        'health:show health'
        'integration:manage integrations'
        'jmx:JMX runtime'
        'launch-gui:launch gui'
        'remote-config:remote-config admin'
        'run:run agent in foreground'
        'secret:test secret backend'
        'start:start agent (systemd)'
        'status:show status'
        'stop:stop agent'
        'stream-logs:tail logs'
        'tagger-list:show tagger entities'
        'workload-list:show workload entities'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-c+[config dir]:dir:_files -/' \
        '--cfgpath=+[config dir]:dir:_files -/' \
        '-p+[pid file]:file:_files' \
        '--pidfile=+[pid file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datadog-agent subcommand' sub ;;
        args)
            case $words[1] in
                check) _arguments \
                    '1:check-name:' \
                    '--rate[run check at rate]' \
                    '--log-level=+[log level]:level:(trace debug info warn error)' \
                    '--breakpoint=+[breakpoint]:str:' \
                    '--check-period=+[check period]:dur:' \
                    '--check-rate[run rate check]' \
                    '--check-times=+[check times]:n:' \
                    '--delay=+[delay]:dur:' \
                    '--instance-filter=+[instance filter]:str:' \
                    '--json[output json]' \
                    '--table[output table]' \
                    '--pause=+[pause]:dur:' ;;
                config) _arguments \
                    '1:cmd:(by-source list-runtime get set)' \
                    '*:arg:' ;;
                integration) _arguments \
                    '1:cmd:(install remove show freeze list lock-package-dependency)' \
                    '--allow-third-party[allow third party]' \
                    '--verbose[verbose]' \
                    '*:integration:' ;;
                status) _arguments \
                    '--json[json output]' \
                    '--pretty-json[pretty json]' \
                    '--no-color[no color]' \
                    '--list-runtime-states[list runtime states]' ;;
                flare) _arguments \
                    '--email=+[email]:str:' \
                    '--send[send to support]' \
                    '--profile=+[profile dir]:dir:_files -/' \
                    '--case-id=+[case id]:id:' ;;
            esac
            ;;
    esac
}

_dd-agent "$@"
