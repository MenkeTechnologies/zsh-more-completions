#compdef xkbinfo

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-display+[X display]:display:' \
  '-device+[device id]:id:' \
  '-all[show all info]' \
  '-flags[show flags]' \
  '-controls[show controls]' \
  '-indicators[show indicators]' \
  '-radiogroups[show radio groups]' \
  '-keycodes[show keycode range]' \
  '-geometry[show geometry]' \
  '-symbols[show symbols]' \
  '-types[show types]' \
  '-compat[show compatibility map]' \
  '-keymap[show keymap]' && ret=0

return ret
