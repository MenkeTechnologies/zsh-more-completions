_investments() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'analyse:analyze portfolio performance (TWR, MWR, IRR vs benchmark)'
        'backtest:backtest portfolio against benchmarks'
        'show:show portfolio asset allocation'
        'sync:sync portfolio with broker statement'
        'buy:add bought shares to portfolio'
        'sell:remove sold shares from portfolio'
        'cash:set current cash assets'
        'rebalance:rebalance portfolio to configured target weights'
        'simulate-sell:compute capital-gains tax impact of selling shares'
        'tax-statement:generate FNS Form 3-NDFL XML for Russian tax filing'
        'cash-flow:print annual cash-flow ledger'
        'deposits:compare configured bank deposits by effective yield'
        'metrics:write Prometheus textfile-collector metrics'
        'completion:generate shell completion script'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[configuration directory (default ~/.investments)]:config dir:_files -/' \
        '(-e --cache-expire-time)'{-e+,--cache-expire-time=}'[override cache expire time]:duration:' \
        '*'{-v,--verbose}'[increase log verbosity (repeatable)]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'investments subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                analyse|backtest)
                    _arguments \
                        '(-m --method)'{-m+,--method=}'[analysis method]:method:(real virtual)' \
                        '(-a --all)'{-a,--all}'[do not hide closed positions]' \
                        '(-b --backfill)'{-b,--backfill}'[backfill backtesting results (backtest only)]' \
                        '1:portfolio name:' && ret=0
                    ;;
                show|rebalance)
                    _arguments \
                        '(-f --flat)'{-f,--flat}'[flat view (no hierarchy)]' \
                        '1:portfolio name:' && ret=0
                    ;;
                sync)
                    _arguments '1:portfolio name:' && ret=0
                    ;;
                buy|sell)
                    _arguments \
                        '1:portfolio name:' \
                        '2:shares spec (e.g. AAPL:10):' \
                        '3:cash assets:' && ret=0
                    ;;
                cash)
                    _arguments \
                        '1:portfolio name:' \
                        '2:cash assets:' && ret=0
                    ;;
                simulate-sell)
                    _arguments \
                        '(-b --base-currency)'{-b+,--base-currency=}'[base currency for tax calculations]:currency:(RUB USD EUR GBP CHF JPY HKD CNY KZT)' \
                        '1:portfolio name:' \
                        '2:shares to sell (e.g. AAPL:5 or ALL):' && ret=0
                    ;;
                tax-statement)
                    _arguments \
                        '1:portfolio name:' \
                        '2:year:' \
                        '3:tax statement file (.dc1 / .xml):_files -g "*.(dc1|xml)"' && ret=0
                    ;;
                cash-flow)
                    _arguments \
                        '1:portfolio name:' \
                        '2:year:' && ret=0
                    ;;
                deposits)
                    _arguments \
                        '(-d --date)'{-d+,--date=}'[reference date for yield computation (YYYY-MM-DD)]:date:' \
                        '--cron[cron mode (machine-readable output)]' && ret=0
                    ;;
                metrics)
                    _arguments '1:output file path:_files' && ret=0
                    ;;
                completion)
                    _arguments \
                        '(-s --shell)'{-s+,--shell=}'[target shell]:shell:(bash zsh fish powershell elvish)' \
                        '1:output file path:_files' && ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_investments "$@"
