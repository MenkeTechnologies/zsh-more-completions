#compdef xstdcmap
# _xstdcmap — X11 xstdcmap (define or delete a standard X colormap on the root window; -display picks display, -all defines all 6 standard maps, -delete removes one, plus per-map -best/-default/-red/-blue/-gray/-rgb flags)
# upstream: https://gitlab.freedesktop.org/xorg/app/xstdcmap
# Flags from xstdcmap xstdcmap.c on tip.

_xstdcmap() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-display+[X display]:display:' \
        '-all[define all standard colormaps]' \
        '-delete+[delete a standard colormap]:property:(RGB_BEST_MAP RGB_DEFAULT_MAP RGB_RED_MAP RGB_GREEN_MAP RGB_BLUE_MAP RGB_GRAY_MAP)' \
        '-best[define RGB_BEST_MAP]' \
        '-default[define RGB_DEFAULT_MAP]' \
        '-red[define RGB_RED_MAP]' \
        '-green[define RGB_GREEN_MAP]' \
        '-blue[define RGB_BLUE_MAP]' \
        '-gray[define RGB_GRAY_MAP]' \
        '-verbose[verbose]'
}

_xstdcmap "$@"
