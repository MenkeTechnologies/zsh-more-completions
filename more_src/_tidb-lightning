#compdef tidb-lightning

_arguments -s \
  '(- *)-V[show version]' \
  '-d=[source data directory or external storage URI]:src:_files -/' \
  '-L=[log level]:level:(debug info warn error fatal)' \
  '*-f=[table filter rule]:filter:' \
  '--config=[config file path]:file:_files' \
  '--backend=[import mode]:mode:(local tidb)' \
  '--log-file=[log file path]:file:_files' \
  '--status-addr=[lightning server listen address]:addr:' \
  '*--pd-urls=[PD endpoint addresses]:urls:' \
  '--tidb-host=[TiDB host]:host:_hosts' \
  '--tidb-port=[TiDB port]:port:' \
  '--tidb-status=[TiDB status port]:port:' \
  '--tidb-user=[TiDB user]:user:_users' \
  '--tidb-password=[TiDB password]:password:' \
  '--enable-checkpoint=[enable checkpoints]:flag:(true false)' \
  '--analyze=[analyze policy]:policy:(required optional off)' \
  '--checksum=[checksum policy]:policy:(required optional off)' \
  '--check-requirements=[verify requirements before start]:flag:(true false)' \
  '--ca=[CA cert path]:file:_files' \
  '--cert=[client cert path]:file:_files' \
  '--key=[client key path]:file:_files' \
  '--server-mode[run in server mode]'
