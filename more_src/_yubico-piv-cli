#compdef yubico-piv-tool
# _yubico-piv-cli — Yubico yubico-piv-tool (CLI for YubiKey PIV smartcard; -a action (status|info|set-management-key|change-pin|change-puk|generate|import-key|import-certificate|read-object|write-object|read-certificate|delete-certificate|version|reset|verify-pin|attest|selfsign-certificate|test-signature|test-decipher|set-chuid|set-ccc), -s slot id, -A algorithm, -P pin, -k management key, -i input file, -o output file, -K key format, --serial, --pin-policy, --touch-policy, -V version, -h help)
# upstream: https://github.com/Yubico/yubico-piv-tool
# Flags from Yubico/yubico-piv-tool tool/yubico-piv-tool.c on tip.

_yubico-piv-cli() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v+[verbose]:level:(0 1 2 3 4 5)' \
        '*-a+[action]:action:(status info set-management-key change-pin change-puk unblock-pin generate import-key import-certificate read-object write-object read-certificate delete-certificate version reset verify-pin attest selfsign-certificate request-certificate test-signature test-decipher set-chuid set-ccc)' \
        '-s+[slot]:slot:(9a 9c 9d 9e 82 83 84 85 86 87 88 89 8a 8b 8c 8d 8e 8f 90 91 92 93 94 95)' \
        '-A+[algorithm]:algo:(RSA1024 RSA2048 RSA3072 RSA4096 ECCP256 ECCP384 ED25519 X25519)' \
        '-P+[pin]:pin:' \
        '-k+[management key]:mgmt:' \
        '-i+[input]:file:_files' \
        '-o+[output]:file:_files' \
        '-K+[key format]:format:(PEM DER PKCS12 GZIP RAW SSH)' \
        '--serial+[device serial]:serial:' \
        '--pin-policy+[pin policy]:policy:(default never once always)' \
        '--touch-policy+[touch policy]:policy:(default never always cached)' \
        '-S+[subject DN]:subject:' \
        '-N+[CSR/cert name]:name:' \
        '-r+[reader]:reader:' \
        '--scp11+[SCP11 key version]:version:'
}

_yubico-piv-cli "$@"
