#compdef termsvg

# Zsh completion for termsvg (asciinema-like SVG)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'termsvg command' record play auth help && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
