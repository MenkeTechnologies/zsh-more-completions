#compdef ip-netns
# Documentation: https://man.archlinux.org/man/ip-netns.8.en
# ip netns - network namespace management

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip netns command' \
      'list[display all network namespaces]' 'add[create network namespace]' \
      'attach[associate namespace name with process]' 'delete[remove namespace]' \
      'del[remove namespace]' 'set[assign namespace identifier]' \
      'identify[locate namespace names for process]' 'pids[list namespace processes]' \
      'exec[run command within namespace]' \
      'monitor[observe namespace events]' 'list-id[display namespace identifiers]' \
      'target-nsid[target namespace id]' 'nsid[namespace id]' \
      'help[show help]' && ret=0
    ;;
esac

return ret
