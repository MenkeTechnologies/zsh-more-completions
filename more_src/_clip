#compdef clip

# asmuth/clip — src/cli.cc (getopt-style flags; single input file)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-e)'{-e+,--export=}'[export rendered image]:file:_files' \
  '(-f)'{-f+,--export-format=}'[export format]:format:(svg png)' \
  '*'--font-load='[add font file]:font:_files' \
  '(-d)-d --debug[enable debug mode]' \
  '(-h)-h --help[show help]' \
  '(-v)-v --version[show version]' \
  '1:input file:_files' && ret=0

return ret
