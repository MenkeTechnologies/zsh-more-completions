#compdef seqdiag

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-a --antialias)'{-a,--antialias}'[Pass diagram image through antialiasing filter]' \
  '(-c --config)'{-c,--config}'[Configuration file]:file:_files' \
  '(-f --font)'{-f,--font}'[Use custom font]:font file:_files' \
  '(-T --output-type)'{-T,--output-type}'[Output file type]:type:(png svg pdf)' \
  '(-o --output)'{-o,--output}'[Output file]:file:_files' \
  '--no-transparency[Make background opaque]' \
  '--size[Diagram size (WxH)]:size:' \
  '--fontmap[Font mapping file]:file:_files' \
  '(- *)--help[Show help message]' \
  '(- *)--version[Show version information]' \
  '*:input file:_files -g "*.diag"' \
  && ret=0

return ret
