#compdef bean-identify
# _bean-identify — identify which importers handle which downloaded files (beancount/beancount)
# upstream: https://github.com/beancount/beancount
# Flags from beancount/ingest/scripts_utils.py.

_bean-identify() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*'{-d+,--downloads=}'[directory containing downloads (repeatable)]:dir:_files -/' \
        '1:importer config:_files -g "*.{py,import}"' \
        '*:downloads file:_files'
}

_bean-identify "$@"
