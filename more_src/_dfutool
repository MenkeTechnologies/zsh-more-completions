#compdef dfutool
# Documentation: https://manpages.debian.org/wheezy/bluez/dfutool.1.en.html
# dfutool — BlueZ Device Firmware Upgrade utility

local ret=1

_arguments -s -S \
  '-h[give a list of possible commands]' \
  '-d+[specify the device to use]:device:' \
  '1:command:(verify modify upgrade archive)' \
  '*:dfu file:_files' && ret=0

return ret
