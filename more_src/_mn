#compdef mn

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create-app:create a new Micronaut application'
  'create-cli-app:create a new Micronaut CLI application'
  'create-function-app:create a new Micronaut function application'
  'create-grpc-app:create a new Micronaut gRPC application'
  'create-messaging-app:create a new messaging application'
  'create-federation:create a federation project'
  'create-job:create a new scheduled job'
  'create-test-resources-module:create a test-resources module'
  'create-broker:create a broker class'
  'create-controller:create a controller class'
  'create-bean:create a bean class'
  'create-listener:create an event listener'
  'create-test:create a test class'
  'list-profiles:list available profiles'
  'profile-info:show details about a profile'
  'feature-list:list available features'
  'feature-info:show details about a feature'
  'feature-diff:diff features between profiles'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mn subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create-*)
        _arguments \
          '(-l --lang)'{-l,--lang=}'[language]:lang:(java groovy kotlin)' \
          '(-b --build)'{-b,--build=}'[build system]:build:(gradle gradle_kotlin maven)' \
          '(-t --test)'{-t,--test=}'[test framework]:test:(junit spock kotlintest)' \
          '*'{-f,--features=}'[feature(s)]:features:' \
          '(-i --inplace)'{-i,--inplace}'[create in place]' \
          '(-j --jdk)'{-j,--jdk=}'[Java version]:version:' && ret=0
        ;;
    esac
    ;;
esac

return ret
