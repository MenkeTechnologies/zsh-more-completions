#compdef pt-pmp
# Documentation: https://man.archlinux.org/search?q=pt-pmp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--binary=[binary to profile]:file:_files' \
  '--interval=[interval between samples]:sec:' \
  '--iterations=[number of iterations]:n:' \
  '--lines=[strip backtrace to N lines]:n:' \
  '--pid=[PID to profile]:pid:' \
  '--save-samples=[save samples to file]:file:_files' \
  '*:file:_files' && ret=0

return ret
