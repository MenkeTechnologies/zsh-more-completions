#compdef mospsf
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/mospsf.html
# MIRIAD mospsf - determine the point-spread function of a mosaic

local ret=1

_arguments -s -S \
  'beam=[input beam-cube produced by INVERT (required)]:beam:_files' \
  'out=[output point-spread function filename]:out:_files' \
  'radec=[RA and DEC where the PSF is computed]:radec' \
  'freq=[frequency in GHz for PSF computation]:freq' \
  '*:beam:_files' && ret=0

return ret
