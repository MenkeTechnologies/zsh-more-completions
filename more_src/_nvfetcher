#compdef nvfetcher
# Documentation: https://man.archlinux.org/search?q=nvfetcher
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '-o+[Output nix file path]:file:_files -g "*.nix(-.)"' \
  '-j+[Parallel jobs]:jobs:' \
  '--help[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'build:Fetch sources and emit Nix attributes'
      'docs:Print build-in documentation examples'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
