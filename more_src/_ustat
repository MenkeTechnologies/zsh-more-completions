#compdef ustat ustat-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/lib/ustat.py argparse)
# Reference accessed: 2026-05-29
# ustat — top-like display of high-level language statistics via USDT (BCC/eBPF).
# Note: NOT the same as POSIX ustat() utility — this is BCC's userspace stats tool.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --language)'{-l,--language=}'[language to trace (default all)]:lang:(java node perl php python ruby tcl)' \
  '(-C --noclear)'{-C,--noclear}'[do not clear the screen]' \
  '(-S --sort)'{-S,--sort=}'[sort by this field (descending)]:field:(thread method objnew cload excp gc)' \
  '(-r --maxrows)'{-r,--maxrows=}'[maximum rows to print (default 20)]:N:' \
  '(-d --debug)'{-d,--debug}'[print the resulting BPF program (for debugging)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:interval (seconds, default 1):' \
  '2:count (number of outputs, default unlimited):' \
  && ret=0

return ret
