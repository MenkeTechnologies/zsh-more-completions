#compdef chalice

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new-project:create a new Chalice project'
  'deploy:deploy application to AWS Lambda'
  'delete:delete deployed application'
  'url:print the URL of the REST API'
  'generate-sdk:generate a client SDK'
  'local:run the app locally'
  'logs:print log messages from Lambda'
  'gen-policy:generate IAM policy'
  'package:package Chalice application for deployment'
  'invoke:invoke a deployed Lambda function'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--project-dir=[project directory]:directory:_files -/' \
  '--debug[enable debug output]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'chalice command' commands && ret=0
    ;;
  args)
    case $words[1] in
      new-project)
        _arguments \
          {-h,--help}'[show help]' \
          '--project-name=[project name]:name' \
          '--profile=[AWS profile]:profile' \
          '1:project name' && ret=0
        ;;
      deploy)
        _arguments \
          {-h,--help}'[show help]' \
          '--no-autogen-policy[do not auto generate IAM policy]' \
          '--profile=[AWS profile]:profile' \
          '--api-gateway-stage=[API gateway stage]:stage' \
          '--stage=[Chalice stage]:stage' \
          '--connection-timeout=[connection timeout]:timeout' && ret=0
        ;;
      delete)
        _arguments \
          {-h,--help}'[show help]' \
          '--profile=[AWS profile]:profile' \
          '--stage=[Chalice stage]:stage' && ret=0
        ;;
      local)
        _arguments \
          {-h,--help}'[show help]' \
          '--host=[local host]:host' \
          '--port=[local port]:port' \
          '--stage=[Chalice stage]:stage' \
          '--autoreload[enable auto-reload]' \
          '--no-autoreload[disable auto-reload]' && ret=0
        ;;
      logs)
        _arguments \
          {-h,--help}'[show help]' \
          '--name=[Lambda function name]:name' \
          '-n+[number of entries]:count' \
          '--num-entries=[number of entries]:count' \
          '--include-lambda-messages[include Lambda platform messages]' \
          '--stage=[Chalice stage]:stage' \
          '--profile=[AWS profile]:profile' && ret=0
        ;;
      package)
        _arguments \
          {-h,--help}'[show help]' \
          '--single-file[create a single output file]' \
          '--pkg-format=[packaging format]:format:(cloudformation terraform)' \
          '--stage=[Chalice stage]:stage' \
          '--merge-template=[merge with existing template]:file:_files -g "*.{json,yaml,yml}"' \
          '1:output directory:_files -/' && ret=0
        ;;
      gen-policy)
        _arguments \
          {-h,--help}'[show help]' \
          '--filename=[policy file]:file:_files' && ret=0
        ;;
      url)
        _arguments \
          {-h,--help}'[show help]' \
          '--stage=[Chalice stage]:stage' && ret=0
        ;;
      invoke)
        _arguments \
          {-h,--help}'[show help]' \
          '-n+[function name]:name' \
          '--name=[function name]:name' \
          '--profile=[AWS profile]:profile' \
          '--stage=[Chalice stage]:stage' && ret=0
        ;;
    esac
    ;;
esac

return ret
