#compdef dependency-check

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--project=[scan path]:dir:_files -/' \
  '--scan=[path to scan]:path:_files' \
  '--format=[report format]:format:(HTML XML JSON CSV SARIF JUNIT GROOVY ALL)' \
  '--out=[output directory]:dir:_files -/' \
  '--suppression=[suppression XML]:file:_files -g "*.xml"' \
  '--failOnCVSS=[fail on CVSS >= threshold]:score:' \
  '--enableExperimental[enable experimental analyzers]' \
  '*:properties or paths: _default'
