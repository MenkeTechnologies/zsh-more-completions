#compdef sevenn_get_model
# Documentation: https://sevennet.readthedocs.io/en/latest/user_guide/cli.html
# SevenNet: export a checkpoint into a deployable model

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--use_mliap[deploy for LAMMPS ML-IAP]' \
  '--enable_flash[enable flashTP acceleration]' \
  '--enable_cueq[enable cuEquivariance acceleration]' \
  '--enable_oeq[enable OpenEquivariance acceleration]' \
  '--modal=[task name, required for multi-fidelity model]:task' \
  '--get_parallel[export for parallel MD simulations]' \
  '*:checkpoint:_files' && ret=0

return ret
