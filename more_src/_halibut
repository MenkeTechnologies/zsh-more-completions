#compdef halibut
# Documentation: https://www.chiark.greenend.org.uk/~sgtatham/halibut/halibut-1.3/manpage.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(- *)--licence[show licence]' \
  '(- *)--license[show licence]' \
  '--input-charset=[input charset]:cs:(ASCII UTF-8 ISO-8859-1 ISO-8859-15 KOI8-R)' \
  '--text[generate plain text]' \
  '--html[generate HTML]' \
  '--chm[generate Windows HTML Help]' \
  '--winhelp[generate old-style Windows Help]' \
  '--man[generate Unix manpage]' \
  '--info[generate Info]' \
  '--ps[generate PostScript]' \
  '--pdf[generate PDF]' \
  '--text-filename=[text output file]:file:_files' \
  '--html-filename=[html output file]:file:_files' \
  '--chm-filename=[chm output file]:file:_files' \
  '--winhelp-filename=[winhelp output file]:file:_files' \
  '--info-filename=[info output file]:file:_files' \
  '--man-filename=[man output file]:file:_files' \
  '--ps-filename=[ps output file]:file:_files' \
  '--pdf-filename=[pdf output file]:file:_files' \
  '*-C[add configuration directive (form -Cword:word[:word...])]:directive:' \
  '--list-charsets[list charsets]' \
  '--list-fonts[list fonts]' \
  '--precise[report line and column numbers for errors]' \
  '*: :_files -g "*.but"' && ret=0

return ret
