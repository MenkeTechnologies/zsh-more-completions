#compdef mcrypt mdecrypt
# Documentation: https://manpages.debian.org/bookworm/mcrypt/mcrypt.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-F --force)'{-F,--force}'[force output to stdout / input from stdin even if terminal]' \
  '(-d --decrypt)'{-d,--decrypt}'[decrypt files]' \
  '(-z --gzip)'{-z,--gzip}'[compress with gzip before encryption]' \
  '(-p --bzip2)'{-p,--bzip2}'[compress with bzip2 before encryption]' \
  '(-u --unlink)'{-u,--unlink}'[delete input file after processing]' \
  '(-b --bare)'{-b,--bare}'[no algorithm/mode info written]' \
  '(-h --hash)'{-h+,--hash=}'[hash algorithm for corruption detection]:hash:' \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-L --license)'{-L,--license}'[display license]' \
  '(-r --random)'{-r,--random}'[use /dev/random instead of /dev/urandom]' \
  '(-k --key)'{-k+,--key=}'[provide key on command line]:key:' \
  '(-f --keyfile)'{-f+,--keyfile=}'[read key from file]:keyfile:_files' \
  '(-c --config)'{-c+,--config=}'[config file]:config file:_files' \
  '(-m --mode)'{-m+,--mode=}'[encryption mode]:mode:(CBC CFB OFB ECB nOFB STREAM)' \
  '(-a --algorithm)'{-a+,--algorithm=}'[encryption algorithm]:algorithm:(3DES CAST-128 CAST-256 GOST RIJNDAEL-128 RIJNDAEL-192 RIJNDAEL-256 SERPENT TWOFISH DES BLOWFISH SAFER-SK64 SAFER-SK128 RC2 XTEA ARCFOUR ENIGMA WAKE)' \
  '(-s --keysize)'{-s+,--keysize=}'[key size in bytes]:bytes:' \
  '(-o --keymode)'{-o+,--keymode=}'[key generation mode]:keymode:(hex pkdes mcrypt s2k scrypt)' \
  '(-g --openpgp)'{-g,--openpgp}'[use OpenPGP file format]' \
  '--help[display help screen]' \
  '--list[list supported algorithms]' \
  '--list-keymodes[list supported key modes]' \
  '--list-hash[list hash algorithms]' \
  '--flush[flush output after each write]' \
  '--time[print timing information]' \
  '--nodelete[do not delete output file on failure]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-critical warnings]' \
  '*:file:_files' && ret=0

return ret
