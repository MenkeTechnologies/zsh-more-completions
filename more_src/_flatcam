#compdef flatcam FlatCAM
# FlatCAM - PCB CAM: generate G-code from Gerber/Excellon for isolation routing
# Source: http://flatcam.org/manual/flatcamshell.html (launch flags --shellfile/--shellvar/--headless)
# Reference accessed: 2026-06-21

local ret=1

_arguments -s \
  '-h[show help]' \
  '--shellfile=[Tcl shell script file to run at startup]:script:_files' \
  '--shellvar=[pass variables into the Tcl shell]:vars:' \
  '--headless[run without the graphical user interface]' \
  '*:project file:_files -g "*.(FlatPrj|gbr|gbl|gtl|drl|nc)"' && ret=0

return ret
