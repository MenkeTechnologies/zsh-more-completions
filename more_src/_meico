#compdef meico
# Documentation: https://github.com/cemfi/meico
# MEI / MSM / MPM / MIDI / audio converter framework

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help text]' \
  '(-v --validate)'{-v,--validate}'[validate loaded MEI file against schema]:schema:_files' \
  '(-a --add-ids)'{-a,--add-ids}'[add missing xml:ids to note, rest and chord elements]' \
  '(-u --fix-duplicate-ids)'{-u,--fix-duplicate-ids}'[fix duplicate xml:ids]' \
  '(-r --resolve-copy-ofs)'{-r,--resolve-copy-ofs}'[resolve copyof/sameas into self-contained elements]' \
  '(-n --ignore-repetitions)'{-n,--ignore-repetitions}'[prevent expansion of repetition marks]' \
  '(-e --ignore-expansions)'{-e,--ignore-expansions}'[prevent expansion of MEI expansion elements]' \
  '(-ex --expressive)'{-ex,--expressive}'[convert to expressive MIDI]' \
  '(-x --xslt)'{-x,--xslt}'[apply an XSL transform to the MEI source]:file:_files -g "*.xsl"' \
  '(-m --msm)'{-m,--msm}'[convert to MSM]' \
  '(-f --mpm)'{-f,--mpm}'[convert to MPM]' \
  '(-o --chroma)'{-o,--chroma}'[convert to chromas]' \
  '(-h --pitches)'{-h,--pitches}'[convert to pitches]' \
  '(-i --midi)'{-i,--midi}'[convert to MIDI]' \
  '(-p --no-program-changes)'{-p,--no-program-changes}'[suppress MIDI program change events]' \
  '(-c --dont-use-channel-10)'{-c,--dont-use-channel-10}'[do not use drum channel 10 in MIDI]' \
  '(-t --tempo)'{-t,--tempo}'[set MIDI tempo (bpm)]:bpm:' \
  '(-w --wav)'{-w,--wav}'[convert to Wave]' \
  '(-3 --mp3)'{-3,--mp3}'[convert to MP3]' \
  '(-q --cqt)'{-q,--cqt}'[convert audio to CQT spectrogram]' \
  '(-s --soundbank)'{-s,--soundbank}'[use a specific sound bank file]:file:_files -g "*.(sf2|dls)"' \
  '(-d --debug)'{-d,--debug}'[write debug versions of MEI and MSM]' \
  '*:MEI file:_files -g "*.(mei|xml)"' && ret=0

return ret
