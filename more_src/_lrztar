#compdef lrztar
# Tar and lrzip compress files in one step

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-d[decompress]' \
  '-l[use lzo compression]' \
  '-b[use bzip2 compression]' \
  '-g[use gzip compression]' \
  '-z[use zpaq compression]' \
  '-n[no compression]' \
  '-L[compression level]:level:(1 2 3 4 5 6 7 8 9)' \
  '-p[number of processors]:threads:' \
  '-o[output directory]:dir:_files -/' \
  '-O[output filename]:file:_files' \
  '-S[suffix]:suffix:' \
  '*:file:_files' \
  && return 0
