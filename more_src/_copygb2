#compdef copygb2
# Documentation: https://noaa-emc.github.io/NCEPLIBS-grib_util/copygb2/index.html
# Copy and interpolate GRIB2 fields between grids (NCEP grib_util).

local ret=1

_arguments -s \
  '-a[append to output GRIB file]' \
  '-A+[inequality and threshold for copy region]:thresh:_default' \
  '-b+[index file for the map field]:mapindex:_files' \
  '-B+[GRIB file used for the map field]:mapgrib:_files' \
  '-g+[output grid identification (kgdtn [kgdt])]:grid:_default' \
  '-i+[interpolation options (ip [ipopts])]:interp:_default' \
  '-k+[PDT parameters selecting fields to copy]:kpdt:_default' \
  '-K+[kpds parameters identifying the map field]:mapkpds:_default' \
  '-m+[index file for the merge field]:mergeindex:_files' \
  '-M+[mask or merge GRIB file for bitmapped areas]:mask:_default' \
  '-N+[namelist file overriding output options]:namelist:_files' \
  '-v+[u-component vector parameters (disc|cat|num)]:uparms:_default' \
  '-x[turn off use of an index file]' \
  '-X[verbose output]' \
  ':input grib file:_files' \
  ':output grib file:_files' && ret=0

return ret
