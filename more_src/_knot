#compdef knotc
# Documentation: https://www.knot-dns.cz/docs/latest/html/man_knotc.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. There is no "knot" command;
# the user-facing control tool is knotc (daemon is knotd).

# knotc: Knot DNS control utility
local curcontext="$curcontext" state line ret=1

local -a commands=(
  'status:check if the server is running'
  'stop:stop the server'
  'reload:reload configured zones'
  'stats:show global statistics counters'
  'zone-check:test if zones can be loaded'
  'zone-status:show zone status'
  'zone-reload:reload a zone from disk'
  'zone-refresh:force zone refresh'
  'zone-retransfer:force zone retransfer'
  'zone-notify:send NOTIFY to slaves'
  'zone-flush:flush journal to disk'
  'zone-backup:backup zone data'
  'zone-restore:restore zone data from backup'
  'zone-sign:re-sign a zone'
  'zone-validate:validate DNSSEC signatures'
  'zone-keys-load:force KASP key reload'
  'zone-key-rollover:trigger key rollover'
  'zone-ksk-submitted:confirm KSK submission'
  'zone-freeze:freeze zone events'
  'zone-thaw:thaw zone events'
  'zone-xfr-freeze:freeze zone transfer'
  'zone-xfr-thaw:thaw zone transfer'
  'zone-read:read records from a zone'
  'zone-begin:begin a zone editing transaction'
  'zone-commit:commit zone transaction'
  'zone-abort:abort zone transaction'
  'zone-diff:show pending zone changes'
  'zone-get:get zone records'
  'zone-set:add a zone record'
  'zone-unset:remove a zone record'
  'zone-purge:purge zone data'
  'zone-stats:show zone statistics'
  'zone-serial-set:set zone SOA serial'
  'conf-init:initialize configuration database'
  'conf-check:test configuration'
  'conf-import:import configuration from file'
  'conf-export:export configuration to file'
  'conf-list:list configuration items'
  'conf-read:read configuration items'
  'conf-begin:begin configuration transaction'
  'conf-commit:commit configuration transaction'
  'conf-abort:abort configuration transaction'
  'conf-diff:show pending configuration changes'
  'conf-get:get configuration items'
  'conf-set:set configuration items'
  'conf-unset:unset configuration items'
)

_arguments -C \
  '(-c --config)'{-c,--config}'[textual configuration file]:file:_files' \
  '(-C --confdb)'{-C,--confdb}'[binary configuration database directory]:dir:_files -/' \
  '(-m --max-conf-size)'{-m,--max-conf-size}'[max config DB size MiB]:mib:' \
  '(-s --socket)'{-s,--socket}'[control UNIX socket path]:path:_files' \
  '(-t --timeout)'{-t,--timeout}'[control timeout seconds]:seconds:' \
  '(-b --blocking)'{-b,--blocking}'[wait until zone events finish]' \
  '(-e --extended)'{-e,--extended}'[show extended output]' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '(-x --mono)'{-x,--mono}'[disable colorized output]' \
  '(-X --color)'{-X,--color}'[force colorized output]' \
  '(-v --verbose)'{-v,--verbose}'[enable debug output]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'knotc command' commands && ret=0
    ;;
esac

return ret
