#compdef knot knotc
# Documentation: https://manpages.debian.org/bookworm/knot/knotc.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm knotc(8) manpage. The user-facing control tool
# is knotc; the daemon is knotd.

# knotc: Knot DNS daemon control tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[textual config file]:file:_files' \
  '(-C --confdb)'{-C,--confdb=}'[binary config database directory]:dir:_files -/' \
  '(-m --max-conf-size)'{-m,--max-conf-size=}'[max config DB size MiB]:mib:' \
  '(-s --socket)'{-s,--socket=}'[control UNIX socket path]:path:_files' \
  '(-t --timeout)'{-t,--timeout=}'[control timeout seconds (0=infinity)]:seconds:' \
  '(-b --blocking)'{-b,--blocking}'[wait for zone events to finish]' \
  '(-e --extended)'{-e,--extended}'[show extended output]' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '(-x --mono)'{-x,--mono}'[no color output]' \
  '(-X --color)'{-X,--color}'[force color output]' \
  '(-v --verbose)'{-v,--verbose}'[debug output]' \
  '*::knotc subcommand:_files' && ret=0
return ret
