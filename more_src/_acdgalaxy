#compdef acdgalaxy
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS acdgalaxy: convert ACD application definitions to Galaxy XML
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output]' \
  '-filter[read stdin/write stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[report version]' \
  '-outfile=[output filename]:file:_files' \
  '-full[generate full Galaxy tool definition]' \
  '*:program name:' && ret=0

return ret
