#compdef jjui

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-r --revision)'{-r+,--revision=}'[revision]:r:' \
  '(-l --limit)'{-l+,--limit=}'[limit]:n:' \
  '(--theme)--theme=[theme]:t:' \
  '(--keymap)--keymap=[keymap file]:file:_files' \
  '(--config)*--config=[config k=v]:cfg:' \
  '(-R --repo)'{-R+,--repo=}'[repo dir]:dir:_files -/' \
  '*: :_files' && ret=0

return ret
