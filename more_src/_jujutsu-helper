#compdef jjui
# Documentation: https://github.com/idursun/jjui/blob/main/cmd/jjui/main.go
# Reference accessed: 2026-05-19
# Verified: upstream flag definitions in main.go at the URL above.

# jjui: TUI for the Jujutsu version control system (idursun/jjui)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help information]' \
  '--version[show version information]' \
  '(-r --revset)'{-r+,--revset=}'[set default revset]:revset:' \
  '(-p --period)'{-p+,--period=}'[override auto-refresh interval (seconds, 0 to disable)]:seconds:' \
  '(-n --limit)'{-n+,--limit=}'[number of revisions to show]:n:' \
  '--config[open configuration file in $EDITOR]' \
  '--install-lua-types[write Lua type definitions to config directory]' \
  '*:repo dir:_files -/' && ret=0

return ret
