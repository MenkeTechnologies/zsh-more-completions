#compdef dlayer
# Documentation: https://github.com/orisano/dlayer
# docker image layer analyzer

local ret=1

_arguments -s -S \
  '-a[show details]' \
  '-d[max depth]:depth:' \
  '-f[image.tar path]:file:_files' \
  '-i[interactive mode]' \
  '-l[screen line width]:width:' \
  '-n[max files]:count:' && ret=0

return ret
