#compdef atf-check
# ATF check utility for test programs

local ret=1

_arguments -s -S \
  '-s[check exit status]:status spec:' \
  '-o[check stdout]:output spec:' \
  '-e[check stderr]:error spec:' \
  '-x[execute command through shell]' \
  '-r[specify results file]:file:_files' \
  '-h[show help]' \
  '--help[show help]' \
  '*:command:_command_names -e' && ret=0

return ret
