#compdef security-profiles-operator
# _security-profiles-operator — sigs.k8s.io/security-profiles-operator multi-mode binary
# upstream: https://github.com/kubernetes-sigs/security-profiles-operator
# Subcommands + flags from cmd/security-profiles-operator/main.go on tip.

_security-profiles-operator() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--verbosity=[log verbosity level]:n:' \
        '--profiling[enable pprof endpoint]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'manager:run the SPO Kubernetes controller manager'
                'daemon:run the per-node profile daemon (spod)'
                'webhook:run the SPO admission webhook server'
                'version:print SPO version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                manager)
                    _arguments \
                        '--webhook=[manage webhook K8s resources from the operator]:bool:(true false)' \
                        '--with-node-status-controller=[enable the node-status controller]:bool:(true false)' \
                        '--with-spod-controller=[enable the SPOD controller]:bool:(true false)' \
                        '--with-workload-annotator=[enable the workload annotator]:bool:(true false)' \
                        '--with-recording-merger=[enable the recording merger]:bool:(true false)'
                    ;;
                daemon)
                    _arguments \
                        '--with-seccomp=[listen for Seccomp API resources]:bool:(true false)' \
                        '--with-selinux=[listen for SELinux API resources]:bool:(true false)' \
                        '--with-apparmor=[listen for AppArmor API resources]:bool:(true false)' \
                        '--with-recording=[listen for ProfileRecording API resources]:bool:(true false)' \
                        '--mem-optim=[watch only labeled pods (memory optimization)]:bool:(true false)'
                    ;;
                webhook)
                    _arguments \
                        '--port=[webhook service port]:port:' \
                        '--static=[webhook K8s resources are managed statically]:bool:(true false)' \
                        '--runtime=[container runtime: cri-o, docker]:runtime:(cri-o docker)' \
                        '--apparmor=[enable AppArmor enforcement in admission]:bool:(true false)'
                    ;;
            esac
            ;;
    esac
}

_security-profiles-operator "$@"
