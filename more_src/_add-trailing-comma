#compdef add-trailing-comma
# Documentation: https://github.com/asottile/add-trailing-comma
# Reference accessed: 2026-06-04

# Zsh completion for add-trailing-comma - Python trailing comma fixer

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--py36-plus[apply Python 3.6+ trailing comma rules]' \
  '--py39-plus[apply Python 3.9+ trailing comma rules]' \
  '--exit-zero-even-if-changed[return exit code 0 even if files were changed]' \
  '*:file:_files'
