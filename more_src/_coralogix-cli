#compdef coralogix-cli coralogixctl coralogix
# _coralogix-cli — Coralogix coralogix-cli CLI command-line frontend wrapping the Coralogix observability platform full-stack logs metrics traces alerts security stateful-streaming-pipeline machine-learning-based-anomaly-detection-Sigma-Logz-DataDog-NewRelic-Splunk-Replacement platform CLI providing login logout whoami search alert dashboard parsing-rule data-map enrichment-rule extraction-rule team user role action target tco-policy archive-volume archive-policy ip-allowed-list (Coralogix team Ariel Assaraf, Go); cobra
# upstream: https://coralogix.com/

_coralogix-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'search:search logs'
        'alert:alert operations'
        'dashboard:dashboard operations'
        'parsing-rule:parsing rule operations'
        'data-map:data map operations'
        'enrichment:enrichment rule operations'
        'extraction:extraction rule operations'
        'team:team operations'
        'user:user operations'
        'role:role operations'
        'action:action operations'
        'target:target operations'
        'tco-policy:TCO policy operations'
        'archive:archive operations'
        'ip-allowed-list:IP allowed list ops'
        'webhook:webhook operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--team-api-key=+[key]:str:' \
        '--app-name=+[name]:str:' \
        '--subsystem-name=+[name]:str:' \
        '--api-url=+[url]:str:' \
        '--region=+[r]:r:(US US2 EU EU2 AP1 AP2 AP3 STAGE)' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coralogix subcommand' sub ;;
        args)
            case $words[1] in
                alert|dashboard|parsing-rule|data-map|enrichment|extraction|team|user|role|action|target|tco-policy|archive|ip-allowed-list|webhook) _arguments '1:op:(list get create update delete enable disable)' '*:id:' ;;
                search) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_coralogix-cli "$@"
