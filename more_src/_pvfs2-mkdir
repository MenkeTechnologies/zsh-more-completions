#compdef pvfs2-mkdir
# Documentation: https://man.archlinux.org/search?q=pvfs2-mkdir
# Reference accessed: 2026-05-16

# pvfs2-mkdir: create a PVFS2 directory
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:files:_files' && ret=0
return ret
