#compdef git-fame

# Zsh completion for git-fame - pretty git summary by author

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--branch[branch to analyze]:branch:' \
  '--before[only consider commits before this date]:date:' \
  '--after[only consider commits after this date]:date:' \
  '--sort[sort by field]:field:(loc commits files)' \
  '--incl[include files matching pattern]:pattern:' \
  '--excl[exclude files matching pattern]:pattern:' \
  '--no-regex[do not use regex for include/exclude]' \
  '--loc[analysis type]:type:(ins del surv)' \
  '--cost[cost metric]:metric:(months weeks days commits)' \
  '--enum[show ranked numbers]' \
  '--format[output format]:format:(pipe markdown yaml json csv tsv tabulate)' \
  '--bytype[show results per file extension]' \
  '--show-email[show email addresses instead of names]' \
  '--no-merge[ignore merge commits]' \
  '--warn-binary[warn about binary files in summary]' \
  '--silent-progress[suppress progress bar]' \
  '-e[show email addresses]' \
  '-w[ignore whitespace changes]' \
  '-M[detect moved lines between files]' \
  '-C[detect copied lines between files]' \
  '-t[show stats per file extension]' \
  '1:git directory:_files -/' && return 0
