#compdef git-fame
# Documentation: https://github.com/casperdcl/git-fame
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git-fame - pretty git repository summary by author

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--branch=[branch or tag to analyze]:branch' \
  '(-R --recurse)'{-R,--recurse}'[recursively find repos and submodules]' \
  '--sort=[sort by field]:field:(loc commits files hours months)' \
  '--min=[minimum value for inclusion]:value' \
  '--enum[show ranked numbers]' \
  '--loc=[line count type]:type:(ins del surv)' \
  '--incl=[include files matching regex]:pattern' \
  '--excl=[exclude files matching regex]:pattern' \
  '(-n --no-regex)'{-n,--no-regex}'[treat patterns as exact match]' \
  '--since=[only commits after this date]:date' \
  '--until=[only commits before this date]:date' \
  '--cost=[cost metric]:metric:(months cocomo hours commits)' \
  '--show=[display fields]:fields' \
  '(-e --show-email)'{-e,--show-email}'[show emails instead of names]' \
  '(-t --bytype)'{-t,--bytype}'[show stats per file extension]' \
  '--format=[output format]:format:(pipe markdown md yaml json csv tsv tabulate svg)' \
  '(-w --ignore-whitespace)'{-w,--ignore-whitespace}'[ignore whitespace changes]' \
  '-M[detect moved lines]' \
  '-C[detect copied lines]' \
  '--ignore-rev=[ignore specific revision]:rev' \
  '--ignore-revs-file=[file of revisions to ignore]:file:_files' \
  '(-s --silent-progress)'{-s,--silent-progress}'[suppress progress bar]' \
  '--warn-binary[warn about binary files]' \
  '--manpath=[directory for man pages]:path:_directories' \
  '--log=[logging level]:level:(FATAL ERROR WARNING INFO DEBUG NOTSET)' \
  '1:git directory:_files -/' && return 0
