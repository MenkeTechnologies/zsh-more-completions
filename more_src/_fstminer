#compdef fstminer
# Documentation: https://verilator.org/guide/latest/
# Search for value/string data inside FST dumpfiles

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help screen]' \
  '(-d --dumpfile)'{-d+,--dumpfile=}'[specify FST input dumpfile]:file:_files -g "*.fst"' \
  '(-m --match)'{-m+,--match=}'[bitwise match data (binary, real, string)]:value' \
  '(-x --hex)'{-x+,--hex=}'[hexadecimal match data converted to binary]:value' \
  '(-n --namesonly)'{-n,--namesonly}'[print only facnames in gtkwave savefile format]' \
  '(-c --comprehensive)'{-c,--comprehensive}'[do not stop after the first match]' \
  '*:FST file:_files -g "*.fst"' && ret=0

return ret
