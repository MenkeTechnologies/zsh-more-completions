#compdef s3fs

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-f[foreground mode]' \
  '-d[debug mode]' \
  '-o+[mount options]:options' \
  '-o passwd_file=[password file]:file:_files' \
  '-o url=[S3 endpoint URL]:url' \
  '-o endpoint=[S3 region]:region' \
  '-o use_path_request_style[use path request style]' \
  '-o use_cache=[local cache directory]:directory:_directories' \
  '-o del_cache[delete local cache on exit]' \
  '-o storage_class=[storage class]:class:(STANDARD STANDARD_IA ONEZONE_IA INTELLIGENT_TIERING GLACIER DEEP_ARCHIVE)' \
  '-o connect_timeout=[connection timeout]:seconds' \
  '-o readwrite_timeout=[readwrite timeout]:seconds' \
  '-o max_stat_cache_size=[stat cache entries]:count' \
  '-o stat_cache_expire=[stat cache expiry]:seconds' \
  '-o retries=[retry count]:count' \
  '-o parallel_count=[parallel request count]:count' \
  '-o multipart_size=[multipart upload size in MB]:size' \
  '-o ensure_diskfree=[min free disk space in MB]:size' \
  '-o dbglevel=[debug level]:level:(crit err warn info dbg)' \
  '1:bucket or bucket\:/path:' \
  '2:mountpoint:_directories' && return 0
