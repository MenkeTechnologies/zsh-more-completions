#compdef bettertouchtool btt
# _bettertouchtool — Andreas Hegenberg BetterTouchTool macOS automation CLI alias (folivora.ai, Objective-C); custom argparse via URL scheme
# upstream: https://docs.bettertouchtool.net

_bettertouchtool() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--quit[quit BTT]' \
        '--restart[restart BTT]' \
        '--reload[reload BTT]' \
        '--start[start BTT]' \
        '--show-window[show window]' \
        '--hide-window[hide window]' \
        '--toggle-window[toggle window]' \
        '--show-floating-menu[show floating menu]' \
        '--hide-floating-menu[hide floating menu]' \
        '--toggle-floating-menu[toggle floating menu]' \
        '--execute-assigned-actions-for-trigger=+[trigger name/uuid]:str:' \
        '--trigger-action=+[trigger action json]:str:' \
        '--trigger-named=+[trigger named]:str:' \
        '--update-trigger=+[update trigger json]:str:' \
        '--update-touch-bar-widget=+[update touch bar widget json]:str:' \
        '--update-stream-deck-widget=+[update stream deck widget json]:str:' \
        '--get-trigger=+[get trigger uuid]:str:' \
        '--get-triggers=+[get triggers]:str:' \
        '--get-active-triggers[get active triggers]' \
        '--get-string-variable=+[get string variable]:str:' \
        '--get-number-variable=+[get number variable]:str:' \
        '--set-string-variable=+[set string variable key=value]:str:' \
        '--set-number-variable=+[set number variable key=value]:str:' \
        '--set-persistent-string-variable=+[set persistent string variable]:str:' \
        '--set-persistent-number-variable=+[set persistent number variable]:str:' \
        '--get-active-shortcut-uuid[get active shortcut uuid]' \
        '--toggle-floating-menu-bar[toggle floating menu bar]' \
        '--toggle-streamdeck=+[toggle streamdeck]:str:' \
        '--list-shortcuts[list shortcuts]' \
        '--shared-secret=+[shared secret]:str:' \
        '*:arg:'
}

_bettertouchtool "$@"
