autoload -U is-at-least

_vault-mgmt() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-n+[Namespace to work in]:NAMESPACE:_default' \
'--namespace=[Namespace to work in]:NAMESPACE:_default' \
'-l+[Log level]:LOG_LEVEL:(error warn info debug trace)' \
'--log-level=[Log level]:LOG_LEVEL:(error warn info debug trace)' \
'-s+[Statefulset name]:STATEFULSET:_default' \
'--statefulset=[Statefulset name]:STATEFULSET:_default' \
'-d+[Vault domain name, used for TLS verification]:DOMAIN:_default' \
'--domain=[Vault domain name, used for TLS verification]:DOMAIN:_default' \
'--no-tls[Do not use TLS for communication with vault]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_vault-mgmt_commands" \
"*::: :->vault-mgmt" \
&& ret=0
    case $state in
    (vault-mgmt)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:vault-mgmt-command-$line[1]:"
        case $line[1] in
            (show)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(exec)
_arguments "${_arguments_options[@]}" : \
'-i+[where to run the command]:IN:(active standby sealed)' \
'--in=[where to run the command]:IN:(active standby sealed)' \
'*-e+[environment variables to set as key=value pairs]:ENV:_default' \
'*--env=[environment variables to set as key=value pairs]:ENV:_default' \
'*-k+[environment variables to set from the current environment]:ENV_KEYS:_default' \
'*--env-keys=[environment variables to set from the current environment]:ENV_KEYS:_default' \
'-h[Print help]' \
'--help[Print help]' \
'*::cmd -- command to execute:_default' \
&& ret=0
;;
(unseal)
_arguments "${_arguments_options[@]}" : \
'-t+[vault token to use for retrieving the unseal keys if not provided, the token will be read from the VAULT_TOKEN environment variable]:TOKEN:_default' \
'--token=[vault token to use for retrieving the unseal keys if not provided, the token will be read from the VAULT_TOKEN environment variable]:TOKEN:_default' \
'--keys-secret-uri=[uri to vault kv secret containing the unseal keys. for example\: \`https\://vault.example.com/v1/secret/data/vault/unseal-keys\`. the secret must store the keys separated by newlines in the data field \`keys\`]:KEYS_SECRET_URI:_default' \
'--key-cmd=[command that writes unseal keys to its stdout. each line will be used as a key. the command will be executed locally]:KEY_CMD:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(step-down)
_arguments "${_arguments_options[@]}" : \
'-t+[vault token to use for the step down if not provided, the token will be read from the VAULT_TOKEN environment variable]:TOKEN:_default' \
'--token=[vault token to use for the step down if not provided, the token will be read from the VAULT_TOKEN environment variable]:TOKEN:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(wait-until-ready)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(upgrade)
_arguments "${_arguments_options[@]}" : \
'-t+[vault token to use for the step down (and retrieving the unseal keys if configured) if not provided, the token will be read from the VAULT_TOKEN environment variable]:TOKEN:_default' \
'--token=[vault token to use for the step down (and retrieving the unseal keys if configured) if not provided, the token will be read from the VAULT_TOKEN environment variable]:TOKEN:_default' \
'--keys-secret-uri=[uri to vault kv secret containing the unseal keys. for example\: \`https\://vault.example.com/v1/secret/data/vault/unseal-keys\`. the secret must store the keys separated by newlines in the data field \`keys\`]:KEYS_SECRET_URI:_default' \
'--key-cmd=[command that writes unseal keys to its stdout. each line will be used as a key. the command will be executed locally]:KEY_CMD:_default' \
'-u[Do not unseal the pods after upgrading. If this is specified, the upgrade process will wait for the pods to be unsealed externally]' \
'--do-not-unseal[Do not unseal the pods after upgrading. If this is specified, the upgrade process will wait for the pods to be unsealed externally]' \
'-f[Force upgrading the pods even when the version is already updated. If this is not enabled, every upgraded pod will be skipped. This is useful when you want to roll the pods gracefully for other reasons (e.g. certificate rotation)]' \
'--force-upgrade[Force upgrading the pods even when the version is already updated. If this is not enabled, every upgraded pod will be skipped. This is useful when you want to roll the pods gracefully for other reasons (e.g. certificate rotation)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate the autocompletion script for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(self-update)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_vault-mgmt__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:vault-mgmt-help-command-$line[1]:"
        case $line[1] in
            (show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(exec)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(unseal)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(step-down)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(wait-until-ready)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(upgrade)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(self-update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_vault-mgmt_commands] )) ||
_vault-mgmt_commands() {
    local commands; commands=(
'show:Show the current state of the vault pods' \
'exec:Execute a command in the vault pod' \
'unseal:Unseal all sealed pods' \
'step-down:Step down the active pod' \
'wait-until-ready:Wait until the statefulset is ready' \
'upgrade:Do a rolling upgrade of the vault pods without downtime' \
'completion:Generate autocompletion scripts for your shell' \
'self-update:Update the vault-mgmt binary to the latest version' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'vault-mgmt commands' commands "$@"
}
