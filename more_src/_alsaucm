#compdef alsaucm
# Documentation: https://manpages.debian.org/alsaucm.1
# Source: alsa-utils — Use Case Manager (UCM) configuration tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-c --card)'{-c+,--card=}'[open card NAME]:name:' \
    '(-i --interactive -b --batch)'{-i,--interactive}'[interactive mode]' \
    '(-i --interactive -b --batch)'{-b+,--batch=}'[batch mode (- for stdin)]:file:_files' \
    '(-n --no-open)'{-n,--no-open}'[do not open first card found]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'open:open card NAME'
            'reset:reset sound card to default state'
            'reload:reload configuration'
            'listcards:list available cards'
            'list:list command (items returning two entries)'
            'list1:list command (one item per entry)'
            'get:get string value'
            'geti:get integer value'
            'set:set string value'
            'h:help'
            'help:help'
            'q:quit'
            'quit:quit'
        )
        _describe -t subcmds 'alsaucm command' subcmds && ret=0
        ;;
    args)
        _default
        ;;
esac

return ret
