#compdef camunda

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'workflow:manage workflows/processes'
  'instance:manage process instances'
  'task:manage user tasks'
  'job:manage jobs'
  'message:publish/list messages'
  'cluster:manage Camunda cluster'
  'auth:authentication commands'
  'deploy:deploy BPMN/DMN/forms'
  'history:query history records'
  'config:print or edit config'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--engine=[Camunda engine URL]:url:' \
  '--cluster-id=[Camunda 8 cluster id]:id:' \
  '--region=[Camunda 8 region]:region:' \
  '--client-id=[OAuth client id]:id:' \
  '--client-secret=[OAuth client secret]:secret:' \
  '--profile=[CLI profile]:profile:' \
  '--insecure[use unsecured connection]' \
  '--json[JSON output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'camunda command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy)
        _arguments \
          '*:file:_files -g "*.{bpmn,dmn,form,xml}"' && ret=0 ;;
      (workflow|instance|task|job|message|cluster)
        _arguments \
          '*::sub:(list get create start cancel suspend resume delete history)' && ret=0 ;;
      (auth)
        _arguments '*::sub:(login logout status)' && ret=0 ;;
    esac ;;
esac

return ret
