#compdef cherrypicker
# _cherrypicker — Prow external plugin that cherry-picks PRs to release branches (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/external-plugins/cherrypicker/main.go (flag).

_cherrypicker() {
    _arguments \
        '-port=[listen port]:port:' \
        '-dry-run=[dry run for testing]:val:(true false)' \
        '*-labels=[labels to apply to the cherrypicked PR]:label:' \
        '-hmac-secret-file=[GitHub HMAC secret file]:file:_files' \
        '-log-level=[log level]:level:(debug info warn error)' \
        '-use-prow-assignments=[use Prow commands to assign cherrypicked PRs]:val:(true false)' \
        '-allow-all[allow anybody to use cherrypicker]' \
        '-create-issue-on-conflict[create a GitHub issue on cherrypick conflict]' \
        '-label-prefix=[custom label prefix]:prefix:' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls'
}

_cherrypicker "$@"
