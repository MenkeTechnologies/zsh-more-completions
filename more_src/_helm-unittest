#compdef helm-unittest
# Documentation: https://man.archlinux.org/search?q=helm-unittest
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--color[force color output]' \
  '--strict[strict test assertions]' \
  '--failfast[stop on first failure]' \
  '--update-snapshot[update test snapshots]' \
  '-f+[use additional chart values file]:file:_files -g "*.yaml" "*.yml"' \
  '-3[use Helm v3 templates]' \
  '1:chart directory:_files -/'
