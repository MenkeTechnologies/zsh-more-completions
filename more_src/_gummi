#compdef gummi
# Documentation: https://github.com/alexandervdm/gummi
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[print debug info]' \
  '(-i --ignore)'{-i,--ignore}'[ignore existing session]' \
  '*:tex_file:_files -g "*.tex"' && ret=0

return ret
