#compdef gummi
# Documentation: https://man.archlinux.org/search?q=gummi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[print debug info]' \
  '(-i --ignore)'{-i,--ignore}'[ignore existing session]' \
  '*:tex_file:_files -g "*.tex"' && ret=0

return ret
