#compdef opam-monorepo
# Documentation: https://github.com/tarides/opam-monorepo/blob/main/bin/opam_monorepo.ml
# Documentation: https://github.com/tarides/opam-monorepo/blob/main/cli/common.ml
# Documentation: https://github.com/tarides/opam-monorepo/blob/main/cli/lock.ml
# Documentation: https://github.com/tarides/opam-monorepo/blob/main/cli/pull.ml
# Documentation: https://github.com/tarides/opam-monorepo/blob/main/cli/depext.ml
# Documentation: https://github.com/tarides/opam-monorepo/blob/main/cli/list_cmd.ml
# Reference accessed: 2026-05-27
# Verified: upstream tarides/opam-monorepo main branch cli/ subcommand definitions

local curcontext="$curcontext" state line ret=1

local -a _opam_monorepo_subcommands
_opam_monorepo_subcommands=(
  'lock:analyse opam files to generate a project-wide lock file'
  'pull:fetch the dependencies sources as specified by the lockfile'
  'depext:install external dependencies'
  'list:display the list of monorepo packages'
)

_opam_monorepo_common_args=(
  '(-r --root)'{-r+,--root=}'[use this directory as the project root]:dir:_files -/'
  '(-l --lockfile)'{-l+,--lockfile=}'[path to the lockfile to use or generate]:file:_files'
  '--verbosity=[set logging verbosity]:level:(error warning info debug)'
  '(-v --verbose)*'{-v,--verbose}'[increase verbosity]'
  '(-q --quiet)'{-q,--quiet}'[silence informational logs]'
  '--color=[control colors in output]:when:(auto always never)'
  '--help=[show help]::format:(auto pager groff plain)'
  '--version[print version]'
)

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'opam-monorepo subcommand' _opam_monorepo_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      lock)
        _arguments -s -S \
          $_opam_monorepo_common_args \
          '--recurse-opam[recursively look for opam files in subdirectories]' \
          '--build-only[only lock build dependencies (ignore test deps)]' \
          '--allow-jbuilder[include packages depending on jbuilder]' \
          '--ocaml-version=[version of ocaml to lock]:version:' \
          '--require-cross-compile[require packages tagged for cross-compilation]' \
          '--minimal-update[prefer to keep existing versions in lock file]' \
          '--add-opam-provided=[add an opam-provided package]:package:' \
          '--add-repositories=[add explicit repositories for the solver]:url:' \
          '--no-extra-pin[disable extra-pin behaviour]' \
          '*:local-package:' && ret=0
        ;;
      pull)
        _arguments -s -S \
          $_opam_monorepo_common_args \
          '(-y --yes)'{-y,--yes}'[do not prompt for confirmation]' \
          '--keep-git-dir[keep .git directory in vendored git sources]' \
          '--keep-symlinked-dir[preserve directories that are symlinked]' \
          '*:repository:' && ret=0
        ;;
      depext)
        _arguments -s -S \
          $_opam_monorepo_common_args \
          '(-y --yes)'{-y,--yes}'[do not prompt for confirmation]' \
          '--dry-run[display the system packages instead of installing them]' && ret=0
        ;;
      list)
        _arguments -s -S \
          $_opam_monorepo_common_args \
          '(-s --short)'{-s,--short}'[only display package names]' && ret=0
        ;;
      *)
        _files
        ;;
    esac
    ;;
esac

return ret
