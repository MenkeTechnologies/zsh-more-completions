#compdef asciidoctor-epub3
# Documentation: https://docs.asciidoctor.org/epub3-converter/latest/
# Convert AsciiDoc documents to EPUB3 e-books

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show the usage message]' \
  '(-v --version)'{-v,--version}'[display the program version]' \
  '(-D --destination-dir)'{-D,--destination-dir}'[write files to specified directory]:dir:_directories' \
  '*'{-a,--attribute}'[set document attribute]:attribute=value' \
  '*:asciidoc file:_files -g "*.{adoc,asc,asciidoc}"' && ret=0

return ret
