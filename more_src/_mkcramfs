#compdef mkcramfs
# Documentation: https://man7.org/linux/man-pages/man8/mkfs.cramfs.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# mkcramfs: build a CRAMFS image from a directory tree
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-E[abort on error]' \
  '-b[blocksize]:bytes:' \
  '-e[edition number]:n:' \
  '-i[insert blob file]:file:_files' \
  '-n[volume name]:name:' \
  '-p[pad space at beginning]' \
  '-s[sort directory entries]' \
  '-z[allow holes in files]' \
  '-N[byte order]:order:(big little host)' \
  '1:source directory:_files -/' \
  '2:output image:_files' && ret=0
return ret
