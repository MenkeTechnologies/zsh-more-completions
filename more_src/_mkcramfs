#compdef mkcramfs

# mkcramfs: create compressed ROM filesystem image (alternative name)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-E[treat all warnings as errors]' \
  '-b[block size in bytes]:n:' \
  '-e[edition number]:n:' \
  '-i[insert mode (insert files from path)]:file:_files' \
  '-n[set image name]:name:' \
  '-N[byte order]:byte:(big little)' \
  '-p[pad output to 512-byte boundary]' \
  '-s[sort directory entries (old behaviour)]' \
  '-v[verbose]' \
  '-z[make explicit holes (sparse)]' \
  '*:directory to package and output file:_files' && ret=0
return ret
