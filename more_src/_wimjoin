#compdef wimjoin
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-join.1.html
# wimjoin — join split WIM parts into a single standalone WIM

local ret=1

_arguments -s -S \
  '--check[verify integrity and include integrity info in the joined WIM]' \
  '--include-integrity[add integrity info without prior verification]' \
  '*:split WIM part:_files' && ret=0

return ret
