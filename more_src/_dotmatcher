# Reference accessed: 2026-05-17
# Verified: Debian EMBOSS dotmatcher(1e) manpage.
# Removed from prior file: bogus man.archlinux.org search URL.

# EMBOSS dotmatcher: draw a threshold dot plot of two sequences
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-asequence=[first sequence]:sequence USA:_files' \
  '-bsequence=[second sequence]:sequence USA:_files' \
  '-matrixfile=[scoring matrix]:matrix:_files' \
  '-windowsize=[window size for averaging]:size:' \
  '-threshold=[score threshold to plot]:score:' \
  '-stretch[stretch second sequence to match aspect]' \
  '-xygraph=[graph output format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-graph=[graph format (for non-XY)]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '*:sequence USA:_files' && ret=0
return ret
