#compdef mp3wrap
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mp3wrap.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '-a[add files to existing Mp3Wrap archive]' \
  '-l[list files wrapped]' \
  '-v[verbose]' \
  '*:file:_files -g "*.mp3"'
