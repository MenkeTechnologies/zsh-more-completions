#compdef curator_cli
# _curator_cli — Elasticsearch Curator singleton CLI (elastic/curator)
# upstream: https://github.com/elastic/curator
# Flags from curator_cli(1) man page.

_curator_cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--host=[Elasticsearch host (default localhost)]:host:' \
        '--url_prefix=[ES HTTP URL prefix]:prefix:' \
        '--port=[ES port (default 9200)]:port:' \
        '--use_ssl[connect via SSL]' \
        '--certificate=[SSL CA certificate file]:file:_files' \
        '--client-cert=[client SSL certificate file]:file:_files' \
        '--ssl-no-validate[do not validate SSL certificate]' \
        '--http_auth=[basic auth user\:pass]:auth:' \
        '--timeout=[connection timeout (seconds)]:seconds:' \
        '--master-only[verify node is elected master before continuing]' \
        '--dry-run[do not perform any index changes]' \
        '--loglevel=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '--logfile=[log file]:file:_files' \
        '--logformat=[log output format]:format:(default logstash)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'allocation:apply index routing allocation rule'
                'close:close indices'
                'delete_indices:delete indices'
                'delete_snapshots:delete snapshots'
                'forcemerge:forceMerge index/shard segments'
                'open:open indices'
                'replicas:change replica count of indices'
                'show_indices:show indices'
                'show_snapshots:show snapshots'
                'snapshot:take snapshots of indices'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_curator_cli "$@"
