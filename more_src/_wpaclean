#compdef wpaclean
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/wpaclean.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# wpaclean: strip pcap to just WPA handshake packets (aircrack-ng)
# Syntax: wpaclean <out.cap> <in.cap> [in2.cap] [...]
local curcontext="$curcontext" ret=1

_arguments -C \
  '1:output pcap:_files' \
  '*:input pcaps:_files -g "*.(cap|pcap|pcapng)"' && ret=0

return ret
