#compdef wpaclean
# Documentation: https://man.archlinux.org/search?q=wpaclean
# Reference accessed: 2026-05-16

# wpaclean: strip pcap to just WPA handshake packets (aircrack-ng)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:output pcap:_files' \
  '*:input pcaps:_files -g "*.(cap|pcap|pcapng)"' && ret=0
return ret
