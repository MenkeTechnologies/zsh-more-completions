  'qa:QA fonts'
  'rangify:rangify'
  'rename-font:rename font'
  'rename-glyphs:rename glyphs'
  'remap-font:remap font'
  'remap-layout:remap layout'
  'sanity-check:sanity check'
  'set-primary-script:primary script'
  'tag-noto:tag Noto'
  'ttf2cp:TTF to CP'
  'ufo-fix-instances:UFO fix instances'
  'ufo-merge:UFO merge'
  'ufo-set-order:UFO set order'
  'ufo-setter:UFO setter'
  'ufo-transfer-data:UFO transfer data'
  'unicode-names:unicode names'
  'update-families:update families'
  'update-nameids:update nameIDs'
  'update-version:update version'
  'varfont-info:varfont info'
  'what-subsets:what subsets'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'gftools subcommand' subcommands && ret=0 ;;
  (args) _arguments '*:arg:_files' && ret=0 ;;
esac

return ret
