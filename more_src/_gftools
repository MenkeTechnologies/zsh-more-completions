  'add-font:add font'
  'autohint:autohint'
  'build-ofl:build OFL'
  'build-vtt:build VTT'
  'builder:builder'
  'check-bbox:check bbox'
  'check-category:check category'
  'check-copyright-notices:check copyright'
  'check-font-version:check version'
  'check-name:check name'
  'check-sandbox-family:check sandbox'
  'check-vertical-extents:check vertical'
  'check-vtt-compatibility:check VTT compat'
  'check-vtt-compile:check VTT compile'
  'compare-font:compare fonts'
  'drop-hints:drop hints'
  'family-html-snippet:family HTML'
  'find-features:find features'
  'fix-ascii-fontmetadata:fix ASCII metadata'
  'fix-cmap:fix cmap'
  'fix-family:fix family'
  'fix-familymetadata:fix family metadata'
  'fix-font:fix font'
  'fix-fsselection:fix fsSelection'
  'fix-fstype:fix fsType'
  'fix-gasp:fix gasp'
  'fix-glyph-private-encoding:fix encoding'
  'fix-hinting:fix hinting'
  'fix-isfixedpitch:fix isfixedpitch'
  'fix-nameids:fix nameIDs'
  'fix-nonhinting:fix nonhinting'
  'fix-ttfautohint:fix ttfautohint'
  'fix-unwanted-tables:fix tables'
  'fix-vendorid:fix vendor id'
  'fix-vertical-metrics:fix vertical metrics'
  'fix-weightclass:fix weight class'
  'fontsetter:fontsetter'
  'font-weights-coverage:weights coverage'
  'gen-html:generate HTML'
  'gen-push-lists:gen push lists'
  'gen-avar2:gen avar2'
  'gen-fvar-instances:gen fvar instances'
  'gen-stat:gen STAT'
  'gen-spac:gen spacing'
  'lang:language'
  'lang-support:lang support'
  'list-italicangle:list italic angle'
  'list-panose:list panose'
  'list-weightclass:list weight class'
  'list-widthclass:list width class'
  'manage-traffic-jam:traffic jam'
  'metadata-vs-api:metadata vs API'
  'nametable-from-filename:nametable'
  'ots:run OTS'
  'packager:packager'
  'push-stats:push stats'
