#compdef badger
# Documentation: https://pkg.go.dev/github.com/dgraph-io/badger/badger/cmd
# Badger - tools to manage Badger key-value database

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dir=[directory where the LSM tree files are located]:dir:_files -/' \
  '--vlog-dir=[directory where the value log files are located]:dir:_files -/' \
  '1:command:(backup bank bench flatten info read_bench restore stream write_bench)' \
  '*::arg:->args' && ret=0

return ret
