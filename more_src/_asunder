#compdef asunder
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/asunder.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--display=[X display]:display:' && ret=0

return ret
