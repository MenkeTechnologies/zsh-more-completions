#compdef iex-cli iex2
# _iex-cli — IEX Cloud iex-cli CLI command-line frontend wrapping the IEX Cloud financial data REST API managing accounts metadata symbols quote ohlc historical-prices charts dividends splits earnings financials key-stats company logo news options-chain price-target intraday-prices reference-data sectors collections (IEX Cloud team, Go); cobra
# upstream: https://iexcloud.io/

_iex-cli() {
    local -a sub=(
        'login:authenticate'
        'account:account operations'
        'metadata:metadata operations'
        'symbols:symbol list'
        'quote:quote operations'
        'ohlc:OHLC data'
        'historical-prices:historical prices'
        'chart:chart operations'
        'intraday-prices:intraday prices'
        'dividends:dividends'
        'splits:splits'
        'earnings:earnings'
        'financials:financials'
        'income:income statement'
        'balance:balance sheet'
        'cash-flow:cash flow statement'
        'key-stats:key stats'
        'company:company profile'
        'logo:company logo'
        'news:news'
        'options:options chain'
        'price-target:price target'
        'reference-data:reference data'
        'sector:sector performance'
        'collection:collection operations'
        'forex:forex operations'
        'crypto:crypto operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--secret-token=+[secret]:str:' \
        '--api-url=+[url]:str:' \
        '--api-version=+[v]:str:' \
        '--sandbox[use sandbox]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'iex-cli subcommand' sub ;;
        args)
            _arguments '*:symbol:'
            ;;
    esac
}

_iex-cli "$@"
