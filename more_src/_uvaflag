#compdef uvaflag
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvaflag.html
# MIRIAD uvaflag - use flags in one visibility dataset to flag another

local ret=1

_arguments -s -S \
  'vis=[input visibility file to be flagged]:vis:_files' \
  'tvis=[template visibility file used as flagging reference]:tvis:_files' \
  'select=[normal uv selection applied to template dataset]:select' \
  'options=[nopol,nofreq,nobin,freq,noapply]:options' \
  '*:visibility data:_files' && ret=0

return ret
