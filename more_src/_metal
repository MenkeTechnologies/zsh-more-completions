#compdef metal
# Documentation: https://github.com/equinix/metal-cli/blob/main/docs/metal.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  '2fa:two-factor authentication'
  'capacity:show capacity'
  'completion:generate shell completion'
  'device:manage devices'
  'docs:generate CLI docs'
  'emdocs:generate enhanced markdown docs'
  'env:show environment'
  'event:show events'
  'facilities:list facilities (deprecated)'
  'gateway:manage gateways'
  'hardware-reservation:manage hardware reservations'
  'init:initialize CLI configuration'
  'interconnections:manage interconnections'
  'ip:manage IP addresses and blocks'
  'metros:list metros'
  'operating-systems:list operating systems'
  'organization:manage organizations'
  'plan:list plans'
  'port:manage device ports'
  'project:manage projects'
  'ssh-key:manage SSH keys'
  'user:manage users'
  'virtual-circuit:manage virtual circuits'
  'virtual-network:manage virtual networks'
  'vrf:manage VRFs'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--token=[Metal API token (METAL_AUTH_TOKEN)]:token:' \
  '--config=[config file path (METAL_CONFIG)]:file:_files' \
  '--exclude=[Href refs to collapse in results]:list:' \
  '--include=[Href refs to expand in results]:list:' \
  '--filter=[filter results (name=value)]:expr:' \
  '--output=[output format]:fmt:(table json yaml)' \
  '--http-header=[extra HTTP header (key=value)]:header:' \
  '--search=[search keyword for get actions]:keyword:' \
  '--sort-by=[sort field for get actions]:field:' \
  '--sort-dir=[sort direction]:dir:(asc desc)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'metal command' commands && ret=0
    ;;
esac

return ret
