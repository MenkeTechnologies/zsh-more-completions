#compdef mdsh
# Documentation: https://github.com/bashup/mdsh
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mdsh - Markdown literate shell

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --compile)'{-c,--compile}'[compile markdown files to bash on stdout]' \
  '(-E --eval)'{-E,--eval}'[compile one file with shelldown-support footer]' \
  '(-o --out)'{-o,--out}'[write output to file instead of stdout]:file:_files' \
  '*:markdown file:_files' && ret=0

return ret
