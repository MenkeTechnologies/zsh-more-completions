#compdef mdsh
# Documentation: https://man.archlinux.org/search?q=mdsh
# Reference accessed: 2026-05-16

# mdsh — Markdown literate shell (see `mdsh --help` for -e eval, -f file, shebang mode).

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-e}"=[inline mdsh snippet]:code" \
  {-f,--file}"=[markdown file path]:file:_files" \
  '--quiet[suppress banners]' \
  '*:markdown document:_files' && ret=0

return ret
