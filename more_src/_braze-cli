#compdef braze-cli braze
# _braze-cli — Braze braze-cli CLI command-line frontend wrapping the Braze customer engagement platform REST API managing users events campaigns canvases segments content-blocks subscription-groups attributes purchases attributes-import bulk-update unsubscribe-list email-bounces transactional-email-API-key (Braze team, Go); cobra
# upstream: https://www.braze.com/

_braze-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'user:user operations'
        'event:event operations'
        'campaign:campaign operations'
        'canvas:canvas operations'
        'segment:segment operations'
        'content-block:content block operations'
        'subscription-group:subscription group operations'
        'unsubscribe:unsubscribe list'
        'export:export user data'
        'send:send transactional email'
        'track:track user attributes'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--instance=+[i]:i:(us-01 us-02 us-03 us-04 us-05 us-06 us-07 us-08 us-09 us-10 eu-01 eu-02 ind-01 ind-02 au-01)' \
        '--app-group-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'braze-cli subcommand' sub ;;
        args)
            case $words[1] in
                user|event|campaign|canvas|segment|content-block|subscription-group|unsubscribe) _arguments '1:op:(list get create update delete trigger send analytics)' '*:id:' ;;
                export|send|track) _arguments '*:file:_files -g "*.json *.csv"' ;;
            esac
            ;;
    esac
}

_braze-cli "$@"
