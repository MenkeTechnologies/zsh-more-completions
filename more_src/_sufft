#compdef sufft
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/transforms/sufft.c
# Fourier Transform of SU data (real time to complex frequency)

local ret=1

_arguments -s -S \
  'sign=[sign in exponent of fft]:sign:(1 -1)' \
  'dt=[sampling interval]:dt' \
  'verbose=[set to 0 to stop advisory messages]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
