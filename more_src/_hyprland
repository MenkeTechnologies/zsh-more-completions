#compdef Hyprland hyprland

# Zsh completion for Hyprland - dynamic tiling Wayland compositor

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version information]' \
  '-c+[specify config file]:config file:_files' \
  '--config[specify config file]:config file:_files' \
  '--i-am-really-stupid[allow running as root]' \
  '--socket[use a custom wayland socket name]:socket name:' \
  '--verbose[enable verbose logging]'
