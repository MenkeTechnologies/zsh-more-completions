#compdef pdns-server pdns_server
# Documentation: https://manpages.debian.org/bookworm/pdns-server/pdns_server.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm pdns_server(1) manpage. Many runtime options
# come via pdns.conf.

# pdns_server: PowerDNS authoritative DNS server
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--daemon[run in background]' \
  '--guardian[run inside guardian process]' \
  '--control-console[monitor mode (raw control socket)]' \
  '--loglevel=[set log level]:level:' \
  '--config=[show config]:mode:(default diff check)' && ret=0
return ret
