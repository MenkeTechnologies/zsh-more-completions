#compdef pkgfile

# Zsh completion for pkgfile - search Arch Linux package file lists

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --binaries)'{-b,--binaries}'[only search for files in binary directories]' \
  '(-d --directories)'{-d,--directories}'[search for directories]' \
  '(-g --glob)'{-g,--glob}'[use glob matching]' \
  '(-i --ignorecase)'{-i,--ignorecase}'[case-insensitive search]' \
  '(-l --list)'{-l,--list}'[list files of a package]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-r --regex)'{-r,--regex}'[use regex matching]' \
  '(-R --repo)'{-R,--repo}'[search only in repo]:repo' \
  '(-s --search)'{-s,--search}'[search for packages containing file]' \
  '(-u --update)'{-u,--update}'[update file database]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-w --raw)'{-w,--raw}'[disable line wrapping]' \
  '(-0 --null)'{-0,--null}'[use null separators]' \
  '(-z --compress)'{-z,--compress}'[download compressed databases]:type:(gzip xz none)' \
  '*:filename or package'
