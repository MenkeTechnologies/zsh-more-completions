#compdef pkgfile
# Documentation: https://man.archlinux.org/man/extra/pkgfile/pkgfile.1.en
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pkgfile - search Arch Linux package file lists

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --binaries)'{-b,--binaries}'[only files in bin/sbin directories]' \
  '(-d --directories)'{-d,--directories}'[include directories in results]' \
  '(-g --glob)'{-g,--glob}'[use glob matching]' \
  '(-i --ignorecase)'{-i,--ignorecase}'[case-insensitive search]' \
  '(-l --list)'{-l,--list}'[list files of a package]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-r --regex)'{-r,--regex}'[use regex matching]' \
  '(-R --repo)'{-R+,--repo=}'[search only in repo]:repo:' \
  '(-s --search)'{-s,--search}'[search for packages containing file]' \
  '(-u --update)'{-u,--update}'[update file database]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-w --raw)'{-w,--raw}'[disable line wrapping/justification]' \
  '(-0 --null)'{-0,--null}'[delimit output with NUL]' \
  '(-z --compress)'{-z-,--compress=-}'[repack downloaded repos]::type:(none gzip bzip2 lzop lz4 lzma xz zstd)' \
  '(-C --config)'{-C+,--config=}'[alternate config file]:file:_files' \
  '(-D --cachedir)'{-D+,--cachedir=}'[alternate cache path]:dir:_files -/' \
  '*:filename or package'
