#compdef criticalstat criticalstat-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/criticalstat.py argparse)
# Reference accessed: 2026-05-29
# criticalstat — trace long preempt-disabled or IRQ-disabled critical sections (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --preemptoff)'{-p,--preemptoff}'[find long sections where preemption was off]' \
  '(-i --irqoff)'{-i,--irqoff}'[find long sections where IRQ was off]' \
  '(-d --duration)'{-d,--duration=}'[duration in microseconds below which to filter (default 100)]:us:' \
  && ret=0

return ret
