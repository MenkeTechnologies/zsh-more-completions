#compdef cmstool cmsutil
# Documentation: https://manpages.debian.org/bookworm/libnss3-tools/cmsutil.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm cmsutil(1) manpage. Real binary is cmsutil.

# cmsutil: NSS CMS (Cryptographic Message Syntax) tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[encrypt a message]' \
  '-D[decode a message]' \
  '-E[envelope a message]' \
  '-O[create certificates-only message]' \
  '-S[sign a message]' \
  '-b[decode batch of files named in infile]' \
  '-c[detached content (decode only)]:content:_files' \
  '-d[key/certificate database dir]:dir:_files -/' \
  '-e[envelope file for recipients]:file:_files' \
  '-f[password file]:file:_files' \
  '-G[include signing time attribute (sign only)]' \
  '-H[hash algorithm]:hash:(SHA1 SHA256 SHA384 SHA512)' \
  '-h[generate email headers (decode only)]:n:' \
  '-i[input file (default stdin)]:file:_files' \
  '-k[keep decoded encryption certs in cert db]' \
  '-N[nickname of cert to sign with]:nickname:' \
  '-n[suppress contents output (decode only)]' \
  '-o[output file (default stdout)]:file:_files' \
  '-P[include S/MIME capabilities attribute]' \
  '-p[key database password]:password:' \
  '-r[recipients (comma-separated)]:list:' \
  '-T[suppress content in CMS message (sign only)]' \
  '-u[cert usage type]:usage:' \
  '-v[print debugging info]' \
  '-Y[encryption key preference nickname]:nickname:' && ret=0
return ret
