#compdef twoBitDup
# UCSC kent: check to see if a twobit file has any identical sequences in it

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-keyList=[write key list of md5sum and sequenceName]:file:_files' \
  '-udcDir=[cache dir for remote bigBed/bigWigs]:dir:_files -/' \
  ':file:_files -g "*.2bit"' && ret=0

return ret
