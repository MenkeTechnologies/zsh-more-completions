#compdef cachet
# _cachet — Cachet status page CLI (CachetHQ/Cachet)
# upstream: https://github.com/CachetHQ/Cachet

_cachet() {
    _arguments -s -S \
        '--url=[Cachet instance URL]:url:' \
        '--token=[API token]:token:' \
        '--format=[output format]:format:(json text)' \
        '--help[show help]'
}

_cachet "$@"
