#compdef openapi-python-client
# Documentation: https://github.com/openapi-generators/openapi-python-client
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: openapi-python-client is a Typer CLI; subcommands generate/update.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'generate:create a new Python client from an OpenAPI spec'
  'update:update an existing Python client from an OpenAPI spec'
  'config:emit a default configuration file'
  'version:show version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--install-completion[install shell completion]' \
  '--show-completion[show completion script]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'openapi-python-client command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (generate|update)
        _arguments \
          '--url=[fetch OpenAPI spec from URL]:url:' \
          '--path=[local OpenAPI spec file]:file:_files' \
          '--config=[configuration file]:file:_files' \
          '--meta=[metadata format]:format:(poetry pdm setup none)' \
          '--custom-template-path=[custom template directory]:dir:_files -/' \
          '--file-encoding=[output file encoding]:encoding:' \
          '--overwrite[overwrite existing client directory]' \
          '--output-path=[output directory]:dir:_files -/' && ret=0 ;;
    esac ;;
esac

return ret

