#compdef bristoljackstats
# Documentation: https://man.archlinux.org/search?q=bristoljackstats
# Reference accessed: 2026-05-16

# bristoljackstats: report Bristol synth JACK statistics
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '*::bristoljackstats args:_files' && ret=0
return ret
