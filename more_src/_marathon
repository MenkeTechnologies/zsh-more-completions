#compdef marathon

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--master=[Mesos master URL]:master:' \
  '--zk=[ZooKeeper URL]:url:' \
  '--zk_session_timeout=[ZK session timeout (ms)]:ms:' \
  '--zk_connection_timeout=[ZK connection timeout (ms)]:ms:' \
  '--zk_max_versions=[max ZK versions kept]:n:' \
  '--zk_compression[compress data in ZK]' \
  '--http_port=[HTTP port]:port:' \
  '--https_port=[HTTPS port]:port:' \
  '--http_address=[HTTP bind address]:addr:' \
  '--http_credentials=[HTTP basic auth user:pass]:cred:' \
  '--http_realm=[HTTP basic auth realm]:realm:' \
  '--ssl_keystore_path=[SSL keystore path]:file:_files' \
  '--ssl_keystore_password=[SSL keystore password]:password:' \
  '--checkpoint[checkpoint tasks]' \
  '--task_launch_timeout=[task launch timeout (ms)]:ms:' \
  '--task_lost_expunge_initial_delay=[task lost expunge delay (ms)]:ms:' \
  '--task_lost_expunge_interval=[task lost expunge interval (ms)]:ms:' \
  '--task_reservation_timeout=[task reservation timeout (ms)]:ms:' \
  '--mesos_user=[Mesos user]:user:_users' \
  '--mesos_role=[Mesos role]:role:' \
  '--mesos_authentication=[require Mesos auth]:flag:(true false)' \
  '--mesos_authentication_principal=[principal]:principal:' \
  '--mesos_authentication_secret=[secret]:secret:' \
  '--mesos_authentication_secret_file=[secret file]:file:_files' \
  '--leader_proxy_connection_timeout=[leader proxy connection timeout]:ms:' \
  '--leader_proxy_read_timeout=[leader proxy read timeout]:ms:' \
  '--framework_name=[framework name]:name:' \
  '--framework_id=[framework ID]:id:' \
  '--hostname=[advertised hostname]:host:_hosts' \
  '--decline_offer_duration=[offer decline duration]:ms:' \
  '--default_accepted_resource_roles=[default accepted roles]:roles:' \
  '--default_network_name=[default network name]:name:' \
  '--executor=[default executor]:executor:' \
  '--launch_token=[max concurrent task launches]:n:' \
  '--launch_token_refresh_interval=[token refresh interval (ms)]:ms:' \
  '--max_apps=[max apps]:n:' \
  '--max_running_deployments=[max concurrent deployments]:n:' \
  '--max_tasks_per_offer=[max tasks per offer]:n:' \
  '--metrics_averaging_window=[metrics window (sec)]:secs:' \
  '--metrics_histogram_reservoir_size=[reservoir size]:n:' \
  '--mesos_leader_ui_url=[Mesos leader UI URL]:url:' \
  '--scale_apps_initial_delay=[scale apps init delay]:ms:' \
  '--scale_apps_interval=[scale apps interval]:ms:' \
  '--enable_features=[enabled features]:features:(vips secrets external_volumes maintenance_mode)' \
  '--access_control_allow_origin=[CORS allow origin]:origin:' \
  '--logger_level=[log level]:level:(off error warn info debug trace)' && ret=0

return ret
