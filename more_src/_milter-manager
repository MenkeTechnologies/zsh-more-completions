#compdef milter-manager
# Documentation: https://man.archlinux.org/search?q=milter-manager
# Reference accessed: 2026-05-16

# milter-manager: unified milter management daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-c[config dir]:dir:_files -/' \
  '--config-dir=[config dir]:dir:_files -/' \
  '-d[run in daemon mode]' \
  '--daemon[run in daemon mode]' \
  '-s[milter socket]:path:_files' \
  '--connection-spec=[milter socket]:path:_files' \
  '--user-name=[run as user]:user:_users' \
  '--group-name=[run as group]:group:_groups' \
  '--pid-file=[PID file]:file:_files' \
  '--log-level=[log level]:level:(default none critical error warning info debug statistics)' \
  '--log-path=[log file]:file:_files' \
  '*::milter-manager args:_files' && ret=0
return ret
