#compdef authelia-cli
# _authelia-cli — Authelia authelia-cli CLI command-line frontend wrapping the Authelia open-source self-hosted Single Sign-On SSO multi-factor authentication MFA server providing OIDC OAuth2 SAML2 LDAP database storage notification password reset registration totp webauthn duo plus passkeys policies regulator session-store configuration (Authelia team, Go); cobra
# upstream: https://www.authelia.com/

_authelia-cli() {
    local -a sub=(
        'access-control:test access-control rules'
        'build-info:show build info'
        'config:configuration'
        'crypto:cryptographic operations'
        'debug:debug utilities'
        'hash-password:hash a password'
        'storage:storage management'
        'validate-config:validate configuration'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '--config.experimental.filters=+[filter]:str:' \
        '--encryption-key=+[key]:str:' \
        '--password-policy=+[file]:file:_files' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'authelia-cli subcommand' sub ;;
        args)
            case $words[1] in
                hash-password) _arguments \
                    '--variant=+[v]:v:(argon2id argon2i argon2d sha512 bcrypt scrypt)' \
                    '--iterations=+[N]:n:' \
                    '--key-length=+[N]:n:' \
                    '--memory=+[N]:n:' \
                    '--parallelism=+[N]:n:' \
                    '*:password:' ;;
                storage) _arguments \
                    '1:op:(migrate schema-info schema-info-history user-totp user-webauthn user-opaque-identifier encryption rand)' ;;
                crypto) _arguments \
                    '1:op:(rand hash pair certificate key)' ;;
                config) _arguments \
                    '1:op:(template validate)' ;;
            esac
            ;;
    esac
}

_authelia-cli "$@"
