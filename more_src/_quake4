#compdef quake4
# Documentation: https://manpages.debian.org/buster/quake4/quake4.6.en.html
# Reference accessed: 2026-05-20
# Verified: Debian quake4.6 manpage OPTIONS section.

# Quake 4: id Tech 4 first-person shooter
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help summary]' \
  '--quiet[suppress console output]' \
  '--smp[use multi-threaded client with modified SDL]' \
  '--debugger=[prepend debugger to engine command line]:debugger:(strace gdb valgrind)' \
  '--print-backtrace[use gdb to get backtrace if engine crashes]' \
  '+set[set cvar before init]:cvar:: :' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+devmap[load map in dev mode]:map:' \
  '+demo[play demo at startup]:name:' \
  '+connect[connect to server at startup]:host:_hosts' \
  '*::extra args:_files' && ret=0
return ret
