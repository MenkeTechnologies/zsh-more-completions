#compdef alock
# Documentation: https://github.com/Arkq/alock
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-bg+[background type]:type:(none blank shade image)' \
  '-cursor+[cursor type]:type:(none theme xcursor glyph)' \
  '-auth+[auth type]:type:(none passwd pam hash list)' \
  '-input+[input type]:type:(none frame xlock)' \
  '-modules[list modules]' && ret=0

return ret
