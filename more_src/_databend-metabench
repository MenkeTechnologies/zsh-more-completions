#compdef databend-metabench
# Documentation: https://github.com/databendlabs/databend/blob/main/src/meta/binaries/metabench/main.rs
# Databend meta-service benchmark tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--prefix=[the prefix of keys to write]:prefix' \
  '--client=[number of benchmark clients]:count' \
  '--client-pool-size=[number of independent MetaGrpcClient handles]:count' \
  '--number=[number of operations per client]:count' \
  '--log-level=[log level]:level' \
  '--grpc-api-address=[gRPC API address of the meta node]:address' \
  '--rpc=[the RPC to benchmark]:rpc:(upsert_kv table get_table table_copy_file list)' && ret=0

return ret
