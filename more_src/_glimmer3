#compdef glimmer3 glimmer-mg glimmer build-fixed build-icm long-orfs extract uncovered
# _glimmer3 — Steven Salzberg Glimmer3 microbial gene finder with Interpolated Context Models suite (CCB team, C++); getopt
# upstream: https://github.com/CCB-SB/glimmer-mg

_glimmer3() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-A+[start codons csv]:str:' \
        '--start_codons=+[start codons csv]:str:' \
        '-b+[ignore-orf-len]:n:' \
        '--rbs_pwm=+[file]:file:_files' \
        '-C+[GC content]:f:' \
        '--gc_percent=+[GC content]:f:' \
        '-d+[distance]:n:' \
        '--dist_max_overlap=+[distance]:n:' \
        '-E+[entropy]:f:' \
        '--entropy_filter=+[entropy]:f:' \
        '-f[fix codon]' \
        '--first_codon[fix codon]' \
        '-g+[gene length min]:n:' \
        '--gene_len=+[gene length min]:n:' \
        '-i+[ignore file]:file:_files' \
        '--ignore=+[ignore file]:file:_files' \
        '-l[allow linker]' \
        '--linear[allow linker]' \
        '-L+[locus tag]:str:' \
        '-M[max len]' \
        '--separate[separate]' \
        '-o+[max overlap]:n:' \
        '--max_olap=+[max overlap]:n:' \
        '-P+[period]:n:' \
        '-q+[stop codon shift]:n:' \
        '-r[no rbs]' \
        '--no_rbs[no rbs]' \
        '-s+[start codons file]:file:_files' \
        '--start_codons_file=+[start codons file]:file:_files' \
        '-t+[threshold]:n:' \
        '--score_thresh=+[threshold]:n:' \
        '-u[show usage]' \
        '-v[verbose]' \
        '-V[verbose]' \
        '-w+[width]:n:' \
        '-W+[width]:n:' \
        '-z+[period]:n:' \
        '-X[extended]' \
        '*:input fasta icm output_tag:_files -g "*.fa *.fasta *.fna *.icm *.fa.gz"'
}

_glimmer3 "$@"
