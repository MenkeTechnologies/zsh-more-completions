#compdef amcleanup
# _amcleanup — Zmanda Amanda amcleanup CLI for recovering Amanda server after a crashed amdump run cleaning up locks status files dropped flushes flushing holding disk to tape if necessary mail-report (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amcleanup() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-k[kill running processes]' \
        '--kill[kill running processes]' \
        '-K[kill quickly]' \
        '-p[run amreport]' \
        '--report[run amreport]' \
        '-n[no flush]' \
        '--no-flush[no flush]' \
        '-r[remove holding-disk]' \
        '--remove-holding=+[d]:str:' \
        '-m+[mail address]:str:' \
        '--mail=+[mail address]:str:' \
        '-M[no mail]' \
        '--no-mail[no mail]' \
        '-o+[option]:str:' \
        '*:config:'
}

_amcleanup "$@"
