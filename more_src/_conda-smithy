#compdef conda-smithy
# Documentation: https://github.com/conda-forge/conda-smithy
# conda-smithy: the tool for managing conda-forge feedstocks

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(init register-github register-ci azure-buildid regenerate rerender recipe-lint lint ci-skeleton generate-feedstock-token register-feedstock-token update-anaconda-token rotate-anaconda-token)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      init)
        _arguments -s -S \
          '--feedstock-directory=[target directory for new feedstock]:dir:_files -/' \
          '1:recipe_directory:_files -/' && ret=0
        ;;
      register-github)
        _arguments -s -S \
          '--add-teams[create teams and register maintainers]' \
          '--user=[GitHub username for repo registration]:user:' \
          '--organization=[GitHub organization]:org:' \
          '--remote-name=[name of remote to add]:remote:' \
          '*--extra-admin-users=[extra users to add as admins]:user:' \
          '--private[create a private repository]' \
          '1:feedstock_directory:_files -/' && ret=0
        ;;
      register-ci)
        _arguments -s -S \
          '--feedstock_directory=[feedstock git repository directory]:dir:_files -/' \
          '--feedstock_config=[feedstock configuration file path]:file:_files' \
          '--user=[GitHub username]:user:' \
          '--organization=[GitHub organization]:org:' \
          '--without-all[disable all CI providers]' \
          '--without-anaconda-token[do not register Anaconda token]' \
          '*--drone-endpoints=[drone server URL]:url:' \
          '--remove[revoke CI service access]' && ret=0
        ;;
      regenerate|rerender)
        _arguments -s -S \
          '--feedstock_directory=[feedstock git repository directory]:dir:_files -/' \
          '--feedstock_config=[feedstock configuration file path]:file:_files' \
          '(-c --commit)'{-c,--commit}'=[setup a commit]:mode:(edit auto)' \
          '--no-check-uptodate[skip uptodate checks]' \
          '(-e --exclusive-config-file)'{-e,--exclusive-config-file}'=[replace conda-forge-pinning]:file:_files' \
          '--check[check if regenerate can be performed]' \
          '--temporary-directory=[directory for temporary downloads]:dir:_files -/' && ret=0
        ;;
      recipe-lint|lint)
        _arguments -s -S \
          '--conda-forge[enable conda-forge linting]' \
          '--feedstock-dir=[feedstock directory]:dir:_files -/' \
          '*:recipe_directory:_files -/' && ret=0
        ;;
      ci-skeleton)
        _arguments -s -S \
          '--feedstock-directory=[feedstock git repository directory]:dir:_files -/' \
          '(-r --recipe-directory)'{-r,--recipe-directory}'=[recipe directory]:dir:_files -/' \
          '1:package_name:' && ret=0
        ;;
      generate-feedstock-token|register-feedstock-token)
        _arguments -s -S \
          '--feedstock_directory=[feedstock git repository directory]:dir:_files -/' \
          '--unique-token-per-provider[use unique token per CI provider]' \
          '--user=[GitHub username]:user:' \
          '--organization=[GitHub organization]:org:' \
          '--token_repo=[GitHub repo storing feedstock tokens]:repo:' \
          '--without-all[disable all providers]' && ret=0
        ;;
      update-anaconda-token|rotate-anaconda-token)
        _arguments -s -S \
          '--feedstock_directory=[feedstock git repository directory]:dir:_files -/' \
          '--feedstock_config=[feedstock configuration file path]:file:_files' \
          '--token_name=[environment variable name]:name:' \
          '--user=[GitHub username]:user:' \
          '--organization=[GitHub organization]:org:' \
          '--without-all[disable all providers]' && ret=0
        ;;
    esac
    ;;
esac

return ret
