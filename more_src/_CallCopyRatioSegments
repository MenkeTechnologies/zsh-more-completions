#compdef CallCopyRatioSegments
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/CallCopyRatioSegments.java
# Calls copy-ratio segments as amplified, deleted, or copy-number neutral

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--input -I)'{--input,-I}'[Input file containing copy-ratio segments (.cr.seg output of ModelSegments).]:value:_files' \
  '(--output -O)'{--output,-O}'[Output file for called copy-ratio segments.]:value:_files' \
  '--neutral-segment-copy-ratio-lower-bound=[Lower bound on non-log2 copy ratio used for determining copy-neutral segments.]:value:' \
  '--neutral-segment-copy-ratio-upper-bound=[Upper bound on non-log2 copy ratio used for determining copy-neutral segments.]:value:' \
  '--outlier-neutral-segment-copy-ratio-z-score-threshold=[Threshold on z-score of non-log2 copy ratio used for determining outlier copy-neutral s...]:value:' \
  '--calling-copy-ratio-z-score-threshold=[Threshold on z-score of non-log2 copy ratio used for calling segments.]:value:' \
  '*:argument:_files' && ret=0

return ret
