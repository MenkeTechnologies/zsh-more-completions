#compdef ecawave
# Documentation: https://sourceforge.net/projects/ecawave/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ecawave: simple GUI sound file editor on top of ecasound
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '*:sound file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3)"' && ret=0
return ret
