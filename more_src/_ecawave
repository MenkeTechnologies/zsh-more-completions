#compdef ecawave
# Documentation: https://man.archlinux.org/search?q=ecawave
# Reference accessed: 2026-05-16

# ecawave: simple GUI sound file editor on top of ecasound
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '*:sound file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3)"' && ret=0
return ret
