#compdef dipy_recobundles
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_recobundles.html
# DIPY: RecoBundles white matter bundle segmentation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--greater_than=[minimum streamline length in mm]:len' \
  '--less_than=[maximum streamline length in mm]:len' \
  '--no_slr[disable Streamline-based Linear Registration]' \
  '--clust_thr=[MDF distance threshold for streamlines]:thr' \
  '--reduction_thr=[search space reduction in mm]:thr' \
  '--reduction_distance=[distance type]:type:(mdf mam)' \
  '--model_clust_thr=[MDF distance threshold for model bundles]:thr' \
  '--pruning_thr=[post-matching pruning threshold]:thr' \
  '--pruning_distance=[pruning distance type]:type:(mdf mam)' \
  '--slr_metric=[SLR metric]:metric:(None symmetric asymmetric diagonal)' \
  '--slr_transform=[transformation type]:type:(translation rigid similarity scaling)' \
  '--slr_matrix=[matrix size]:size:(nano tiny small medium large huge)' \
  '--refine[enable bundle refinement]' \
  '--r_reduction_thr=[refine search space reduction in mm]:thr' \
  '--r_pruning_thr=[refine pruning threshold]:thr' \
  '--no_r_slr[disable refine Streamline-based Linear Registration]' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_recognized_transf=[output recognized bundle filename]:file:_files' \
  '--out_recognized_labels=[output labels filename]:file:_files' \
  '*:input (streamline model_bundle):_files' && ret=0

return ret
