#compdef aws-secrets-manager aws-secretsmanager-cli aws-sm
# _aws-secrets-manager — AWS aws-secrets-manager CLI alternative ergonomic command-line frontend wrapping the AWS Secrets Manager service create describe get put list delete rotate-secret restore-secret tag-rotate-rules KMS-key-arn-replication-region-cross-account-access for secret rotation management (AWS team, Go); cobra
# upstream: https://aws.amazon.com/secrets-manager/

_aws-secrets-manager() {
    local -a sub=(
        'create:create a secret'
        'describe:describe a secret'
        'get:fetch secret value'
        'put:put new value'
        'update:update metadata'
        'list:list secrets'
        'delete:schedule deletion'
        'restore:restore deleted secret'
        'rotate:rotate now or trigger lambda'
        'tag:tag operations'
        'untag:untag operations'
        'replicate:configure replication'
        'remove-replica:remove replica regions'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--region=+[r]:_aws_regions' \
        '--profile=+[name]:str:' \
        '--kms-key-id=+[id]:str:' \
        '--client-request-token=+[token]:str:' \
        '--secret-binary=+[file]:file:_files' \
        '--secret-string=+[json]:str:' \
        '--description=+[text]:str:' \
        '--version-stage=+[stage]:s:(AWSCURRENT AWSPENDING AWSPREVIOUS)' \
        '--rotation-lambda-arn=+[arn]:str:' \
        '--rotation-rules=+[json]:str:' \
        '--add-replica-regions=+[regions]:str:' \
        '--remove-replica-regions=+[regions]:str:' \
        '-f+[format]:f:(json yaml table text)' \
        '--format=+[format]:f:(json yaml table text)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aws-secrets-manager subcommand' sub ;;
        args)
            case $words[1] in
                describe|get|put|update|delete|restore|rotate|tag|untag|replicate|remove-replica) _arguments '*:secret name:' ;;
            esac
            ;;
    esac
}

_aws-secrets-manager "$@"
