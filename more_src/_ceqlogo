#compdef ceqlogo
# Documentation: https://meme-suite.org/meme/doc/ceqlogo.html
# MEME Suite: generate sequence logos from motifs

local ret=1

_arguments -s -S \
  '*-i[load all motifs from the file]:file:_files' \
  '*-m[load the numth motif or the motif with the given id]:id or num:' \
  '*-ix[load the xth motif or motif with id x from a file]:file:_files' \
  '-r[reverse-complement the logo]' \
  '-l[prefer to load motifs by id]' \
  '-s[offset the previously loaded motif]:shift:' \
  '-b[number of bits represented by the bar]:bar bits:' \
  '-c[number of bits between tic marks]:tic bits:' \
  '-e[fraction of the error bar to show]:error bar fraction:' \
  '-f[output format]:format:(EPS PNG)' \
  '-F[create a frequency logo with stack height 1]' \
  '-h[height of the output logo in cm]:logo height:' \
  '-o[output image file]:file:_files' \
  '-n[sample count for error bars]:sample number:' \
  '-t[image title label]:title label:' \
  '-w[width of the output logo in cm]:logo width:' \
  '-x[x-axis label]:x-axis label:' \
  '-y[y-axis label]:y-axis label:' \
  '-p[pseudocount added to motifs]:pseudocount:' \
  '-d[fineprint shown at the bottom]:fineprint:' \
  '-S[toggle stack height scaling]' \
  '-B[toggle bar display]' \
  '-E[toggle error bars]' \
  '-O[toggle outlining]' \
  '-N[toggle numbering]' \
  '-X[toggle x-axis]' \
  '-Y[toggle y-axis]' \
  '--test[run self test at the given verbosity level]:verbosity:(0 1 2 3)' \
  '*:file:_files' && ret=0

return ret
