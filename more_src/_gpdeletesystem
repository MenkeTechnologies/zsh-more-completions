#compdef gpdeletesystem
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpdeletesystem.html
# Delete a Greenplum Database system

local ret=1

_arguments -s -S \
  '-?[display online help]' \
  '-d[coordinator host data directory]:dir:_files -/' \
  '-B[number of segments to delete in parallel]:parallel_processes' \
  '-f[force a delete even if backup files are found]' \
  '-l[directory to write the log file]:dir:_files -/' \
  '-D[set logging level to debug]' \
  '-v[display version, status, last updated date, and checksum]' && ret=0

return ret
