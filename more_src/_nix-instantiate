#compdef nix-instantiate

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--eval[evaluate an expression]' \
  '--parse[parse only]' \
  '--find-file[find file in search path]' \
  '--strict[evaluate strictly]' \
  '--json[output as JSON]' \
  '--xml[output as XML]' \
  '--read-write-mode[read-write mode]' \
  '--arg[set function argument]:name:value' \
  '--argstr[set function argument as string]:name:value' \
  '-A[select attribute]:attribute' \
  '--attr=[select attribute]:attribute' \
  '-E[evaluate expression]:expression' \
  '--expr=[evaluate expression]:expression' \
  '-I[add to search path]:path:_files' \
  '--add-root=[add GC root]:path:_files' \
  '--indirect[use indirect GC root]' \
  '*:nix files:_files -g "*.nix"' && ret=0

return ret
