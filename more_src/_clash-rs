#compdef clash-rs
# _clash-rs — Rust reimplementation of Clash rule-based proxy (Watfaq/clash-rs)
# upstream: https://github.com/Watfaq/clash-rs
# Flags from clash-bin/src/main.rs (clap derive).

_clash-rs() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-d --directory)'{-d+,--directory=}'[working directory]:dir:_files -/' \
        '(-c -f --config)'{-c+,-f+,--config=}'[configuration file]:file:_files -g "*.(yml|yaml)"' \
        '(-t --test-config)'{-t,--test-config}'[test config and exit]' \
        '(-l --log-file)'{-l+,--log-file=}'[additional log file]:file:_files' \
        '--help-improve[enable crash reports]' \
        '--controller-ipc=[controller IPC path]:path:_files' \
        '--ext-ctl-pipe=[controller pipe path]:path:_files' \
        '--ext-ctl-unix=[controller Unix socket]:path:_files' \
        '--compatibility=[mihomo compatibility mode]:bool:(true false)'
}

_clash-rs "$@"
