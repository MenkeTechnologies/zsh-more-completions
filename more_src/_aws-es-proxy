#compdef aws-es-proxy
# Documentation: https://github.com/abutaha/aws-es-proxy
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for aws-es-proxy
# Upstream: Small proxy between HTTP client and AWS Elasticsearch
# Conservative fallback — run `aws-es-proxy --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
