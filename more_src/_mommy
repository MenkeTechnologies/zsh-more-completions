#compdef mommy

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --capture-output)'{-c,--capture-output}'[suppress wrapped command output]' \
  '(-e --eval)'{-e+,--eval=}'[evaluate response template]:template:' \
  '(-s --status)'{-s+,--status=}'[use given exit status]:n:' \
  '*::command:_command_names' && ret=0

return ret
