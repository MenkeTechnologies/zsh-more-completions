#compdef prow-deck
# _prow-deck — Prow deck web UI (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/deck/main.go (flag).

_prow-deck() {
    _arguments \
        '-tide-url=[tide URL]:url:_urls' \
        '-hook-url=[hook plugin help endpoint]:url:_urls' \
        '-oauth-url=[deck user dashboard endpoint]:url:_urls' \
        '-github-oauth-config-file=[GitHub App client secret file]:file:_files' \
        '-cookie-secret=[cookie secret key file]:file:_files' \
        '-redirect-http-to=[host to redirect http->https to]:host:' \
        '-hidden-only[show only hidden jobs]' \
        '-pregenerated-data=[pre-generated API output (for runlocal)]:file:_files' \
        '-show-hidden[show all jobs including hidden]' \
        '-spyglass[use Spyglass instead of Gubernator]' \
        '-spyglass-files-location=[static files for Spyglass]:dir:_files -/' \
        '-static-files-location=[static files path]:dir:_files -/' \
        '-template-files-location=[template files path]:dir:_files -/' \
        '-gcs-cookie-auth[use storage.cloud.google.com instead of signed URLs]' \
        '-rerun-creates-job[allow Deck to recreate jobs]' \
        '-allow-insecure[allow insecure CSRF and GitHub OAuth]' \
        '-dry-run[disable mutating API calls]' \
        '*-tenant-id=[tenant IDs to display (repeatable)]:tenant:' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files'
}

_prow-deck "$@"
