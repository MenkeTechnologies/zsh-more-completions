#compdef lowcharts

_lowcharts() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--width=[chart width in columns]:width:' \
        '--height=[chart height in rows]:height:' \
        '1: :_lowcharts_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                timehist)
                    _arguments \
                        '--intervals=[number of intervals]:intervals:' \
                        '--format=[time format string]:format:' \
                        '--min=[minimum time]:min:' \
                        '--max=[maximum time]:max:' \
                        '--width=[chart width]:width:' \
                        '--height=[chart height]:height:' && ret=0 ;;
                plot)
                    _arguments \
                        '--min=[minimum value]:min:' \
                        '--max=[maximum value]:max:' \
                        '--width=[chart width]:width:' \
                        '--height=[chart height]:height:' && ret=0 ;;
                hist)
                    _arguments \
                        '--intervals=[number of intervals]:intervals:' \
                        '--min=[minimum value]:min:' \
                        '--max=[maximum value]:max:' \
                        '--width=[chart width]:width:' \
                        '--height=[chart height]:height:' && ret=0 ;;
                matches)
                    _arguments \
                        '--width=[chart width]:width:' \
                        '--height=[chart height]:height:' && ret=0 ;;
                split)
                    _arguments \
                        '--width=[chart width]:width:' \
                        '--height=[chart height]:height:' && ret=0 ;;
                common-prefix)
                    _arguments \
                        '--width=[chart width]:width:' \
                        '--height=[chart height]:height:' && ret=0 ;;
            esac ;;
    esac

    return ret
}

(( $+functions[_lowcharts_commands] )) ||
_lowcharts_commands() {
    local -a commands=(
        'timehist:time-based histogram'
        'plot:scatter plot'
        'hist:histogram'
        'matches:match rate chart'
        'split:split input into columns'
        'common-prefix:find common prefixes'
    )
    _describe -t commands 'lowcharts command' commands
}

_lowcharts "$@"
