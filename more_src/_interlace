#compdef interlace

_arguments -s \
  '-t=[target]:target:' \
  '-tL=[targets file]:file:_files' \
  '-e=[exclude target]:target:' \
  '-eL=[exclude file]:file:_files' \
  '-threads=[max threads]:n:' \
  '-timeout=[timeout seconds]:n:' \
  '-c=[command]:command:' \
  '-cL=[commands file]:file:_files' \
  '-o=[output dir]:dir:_files -/' \
  '-p=[ports]:ports:' \
  '-pL=[proxy list]:file:_files' \
  '--proto=[protocols]:protos:' \
  '-rp=[real port]:port:' \
  '-random=[random files dir]:dir:_files -/' \
  '(--no-bar --sober)'{--no-bar,--sober}'[no progress bar]' \
  '--no-cidr[disable CIDR expansion]' \
  '--no-color[no color]' \
  '--silent[silent]' \
  '-v[verbose]'
