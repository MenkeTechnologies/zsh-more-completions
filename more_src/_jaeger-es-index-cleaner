#compdef jaeger-es-index-cleaner
# _jaeger-es-index-cleaner — Jaeger Elasticsearch/OpenSearch index cleaner (jaegertracing/jaeger)
# upstream: https://github.com/jaegertracing/jaeger
# Flags from cmd/es-index-cleaner/app/flags.go on tip.

_jaeger-es-index-cleaner() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--index-prefix=[Jaeger index prefix]:prefix:' \
        '--archive[clean archive indices (rollover only)]' \
        '--rollover[clean rollover-managed indices]' \
        '--timeout=[master-node response timeout (s)]:n:' \
        '--index-date-separator=[date separator in index name]:sep:' \
        '--es.username=[Elasticsearch username]:user:' \
        '--es.password=[Elasticsearch password]:pass:' \
        '--es.tls.enabled[enable TLS for Elasticsearch]' \
        '--es.tls.ca=[CA cert file]:file:_files' \
        '--es.tls.cert=[client cert file]:file:_files' \
        '--es.tls.key=[client key file]:file:_files' \
        '--es.tls.server-name=[expected TLS server name]:name:' \
        '--es.tls.skip-host-verify[skip TLS host verification]' \
        '--feature-gates=[OTEL feature gates (key=bool,...)]:gates:' \
        ':number-of-days:'
}

_jaeger-es-index-cleaner "$@"
