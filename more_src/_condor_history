#compdef condor_history
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_history.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_history: show completed HTCondor jobs from history.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-debug[debug]' \
  '-name[schedd name]:name:' \
  '-pool[pool]:pool:' \
  '-userlog[read from user log file]:file:_files' \
  '-file[read from named history file]:file:_files' \
  '-search[search history files]:file:_files' \
  '-dir[history file directory]:dir:_files -/' \
  '-directory[history file directory]:dir:_files -/' \
  '-backwards[scan backwards (newest first)]' \
  '-forwards[scan forwards (oldest first)]' \
  '-since[scan since given job/time expression]:expr:' \
  '-completedsince[since job completion time]:datetime:' \
  '-local[query local history files]' \
  '-schedd[query schedd history]' \
  '-startd[query startd history]' \
  '-epochs[query epoch (per-run) history]' \
  '-transfer[query transfer history]' \
  '-transfer-history[query transfer history]' \
  '-daemon[query named daemon history]:daemon:' \
  '-format[printf-style format]:format attr:' \
  '-autoformat[autoformat list]:list:' \
  '-af[autoformat list]:list:' \
  '-print-format[print-format file]:file:_files' \
  '(-l --long)-l[long ClassAd format]' \
  '-long[long ClassAd format]' \
  '-xml[XML output]' \
  '-json[JSON output]' \
  '-jsonl[JSON Lines output]' \
  '-wide[wide output]' \
  '-extract[extract job to a directory]:dir:_files -/' \
  '-attributes[attributes list]:list:' \
  '-match[max jobs to display]:n:' \
  '-limit[max jobs to display]:n:' \
  '-scanlimit[max ads to scan]:n:' \
  '-constraint[constraint expression]:expr:' \
  '*:jobid or user:' && ret=0
return ret
