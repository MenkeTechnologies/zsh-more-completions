#compdef bencode bencode-cli bdecode
# _bencode — BitTorrent bencoded data format CLI alias (BitTorrent project, multiple langs); custom argparse
# upstream: https://en.wikipedia.org/wiki/Bencode

_bencode() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--decode[decode bencode to JSON]' \
        '-d[decode bencode to JSON]' \
        '--encode[encode JSON to bencode]' \
        '-e[encode JSON to bencode]' \
        '--input=+[input file]:file:_files -g "*.torrent *.bencode"' \
        '-i+[input file]:file:_files -g "*.torrent *.bencode"' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--pretty[pretty print]' \
        '-p[pretty print]' \
        '--strict[strict]' \
        '*:file:_files -g "*.torrent *.bencode"'
}

_bencode "$@"
