#compdef @ROI_Corr_Mat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@ROI_Corr_Mat.html
# Produce an NxN ROI correlation matrix of N ROIs

local ret=1

_arguments -s -S \
  '-ts[time series volume input]:vol:_files' \
  '-roi[ROI volume (auto-resampled to EPI resolution)]:vol:_files' \
  '-prefix[output prefix for results]:prefix' \
  '-roisel[force processing of specific ROI labels in 1D file]:file:_files' \
  '-zval[output a z-score version of the correlation matrix]' \
  '-mat[matrix output format]:opt:(FULL TRI TRI_ND)' \
  '-dirty[preserve temporary files]' \
  '-keep_tmp[preserve temporary files]' \
  '-echo[display all commands to screen]' \
  '-verb[enable verbose output]' && ret=0

return ret
