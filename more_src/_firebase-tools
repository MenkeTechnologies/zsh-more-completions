#compdef firebase-tools
# _firebase-tools — Google Firebase command-line tools CLI alias (Firebase team, TypeScript); commander
# upstream: https://github.com/firebase/firebase-tools

_firebase-tools() {
    local -a sub=(
        'login:login to firebase'
        'login:ci:login for CI'
        'login:add:add account'
        'login:list:list accounts'
        'login:use:use account'
        'logout:logout'
        'init:init project'
        'use:set active project'
        'projects:list:list projects'
        'projects:create:create project'
        'projects:addfirebase:add firebase to gcp project'
        'deploy:deploy project'
        'serve:serve locally'
        'emulators:start:start emulators'
        'emulators:exec:run command with emulators'
        'emulators:export:export emulator data'
        'apps:list:list apps'
        'apps:create:create app'
        'apps:android:list:list android apps'
        'apps:ios:list:list ios apps'
        'apps:web:list:list web apps'
        'apps:sdkconfig:get sdk config'
        'auth:export:export auth data'
        'auth:import:import auth data'
        'database:get:get database value'
        'database:set:set database value'
        'database:update:update database value'
        'database:push:push to database list'
        'database:remove:remove database value'
        'database:profile:profile database'
        'database:instances:list:list rtdb instances'
        'database:instances:create:create rtdb instance'
        'firestore:databases:list:list firestore dbs'
        'firestore:databases:create:create firestore db'
        'firestore:databases:delete:delete firestore db'
        'firestore:databases:update:update firestore db'
        'firestore:delete:delete firestore docs'
        'firestore:indexes:show indexes'
        'firestore:locations:list locations'
        'firestore:export:export firestore'
        'firestore:import:import firestore'
        'functions:list:list functions'
        'functions:log:show logs'
        'functions:secrets:set:set secret'
        'functions:secrets:get:get secret'
        'functions:secrets:access:access secret'
        'functions:secrets:destroy:destroy secret'
        'functions:secrets:prune:prune secrets'
        'functions:shell:open function shell'
        'functions:config:get:get function config'
        'functions:config:set:set function config'
        'functions:config:unset:unset function config'
        'functions:config:clone:clone function config'
        'functions:delete:delete function'
        'hosting:disable:disable hosting'
        'hosting:channel:list:list channels'
        'hosting:channel:create:create channel'
        'hosting:channel:delete:delete channel'
        'hosting:channel:deploy:deploy to channel'
        'hosting:clone:clone hosting site'
        'hosting:sites:list:list sites'
        'hosting:sites:create:create site'
        'hosting:sites:delete:delete site'
        'hosting:sites:get:get site'
        'ext:install:install extension'
        'ext:list:list extensions'
        'ext:info:show extension info'
        'ext:uninstall:uninstall extension'
        'ext:update:update extension'
        'ext:configure:configure extension'
        'ext:dev:init:scaffold extension'
        'remoteconfig:get:get remote config'
        'remoteconfig:rollback:rollback remote config'
        'remoteconfig:versions:list:list versions'
        'appdistribution:distribute:distribute build'
        'appdistribution:testers:add:add tester'
        'appdistribution:testers:remove:remove tester'
        'crashlytics:mappingfile:upload:upload mapping file'
        'crashlytics:symbols:upload:upload symbols'
        'dataconnect:sdk:generate:generate sdks'
        'dataconnect:services:list:list services'
        'open:open url'
        'help:show help'
        'experiments:list:list experiments'
        'setup:emulators:database:setup db emulator'
        'setup:emulators:firestore:setup firestore emulator'
        'setup:emulators:pubsub:setup pubsub emulator'
        'setup:emulators:storage:setup storage emulator'
        'setup:emulators:ui:setup ui emulator'
        'target:apply:apply hosting target'
        'target:clear:clear hosting target'
        'target:remove:remove hosting target'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug[debug]' \
        '--non-interactive[non interactive]' \
        '--no-color[no color]' \
        '--no-warnings[no warnings]' \
        '--project=+[project id]:str:' \
        '-P+[project id]:str:' \
        '--account=+[account]:str:' \
        '-j[json output]' \
        '--json[json output]' \
        '--interactive[interactive]' \
        '--token=+[token]:str:' \
        '--config=+[config file]:file:_files -g "firebase.json"' \
        '-c+[config file]:file:_files -g "firebase.json"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'firebase subcommand' sub ;;
        args)
            case $words[1] in
                deploy) _arguments \
                    '--only=+[targets]:str:' \
                    '--except=+[targets]:str:' \
                    '--message=+[message]:str:' \
                    '-m+[message]:str:' \
                    '--force[force]' \
                    '-f[force]' \
                    '--dry-run[dry run]' \
                    '--debug[debug]' ;;
                emulators:start) _arguments \
                    '--only=+[emulators]:str:' \
                    '--inspect-functions=+[port]:port:' \
                    '--import=+[import path]:dir:_files -/' \
                    '--export-on-exit=+[export path]:dir:_files -/' ;;
                init) _arguments \
                    '*:feature:(database firestore functions hosting storage emulators remoteconfig extensions apphosting dataconnect)' ;;
                use) _arguments \
                    '1:project id or alias:' \
                    '--add[add project]' \
                    '--alias=+[alias]:str:' \
                    '--unalias=+[alias]:str:' \
                    '--clear[clear active]' ;;
                hosting:channel:deploy) _arguments \
                    '1:channel id:' \
                    '--expires=+[duration]:str:' \
                    '--site=+[site]:str:' \
                    '--only=+[targets]:str:' ;;
            esac
            ;;
    esac
}

_firebase-tools "$@"
