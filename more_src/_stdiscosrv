#compdef stdiscosrv
# Documentation: https://man.archlinux.org/search?q=stdiscosrv
# Reference accessed: 2026-05-16

_arguments -s \
  '--cert=[cert file]:file:_files' \
  '--key=[key file]:file:_files' \
  '--http[serve plain HTTP]' \
  '--compression[enable compression]' \
  '--listen=[listen address]:addr:' \
  '--metrics-listen=[metrics listen address]:addr:' \
  '--desired-unseen-not-found-rate=[desired unseen not-found rate]:f:' \
  '--desired-seen-not-found-rate=[desired seen not-found rate]:f:' \
  '--shutdown-delay=[shutdown delay s]:f:' \
  '--db-dir=[database directory]:dir:_files -/' \
  '--db-flush-interval=[db flush interval]:duration:' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(- *)'{-v,--version}'[show version]'
