#compdef pamstereogram
# Documentation: man pamstereogram (Netpbm)
# Source: Netpbm pamstereogram — create single-image stereogram (SIS/SIRDS/MTS) from a PAM depth map.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '-verbose[print messages about sizes and properties]' \
    '(-blackandwhite -grayscale -color)-blackandwhite[black-and-white SIRDS (default)]' \
    '(-blackandwhite -grayscale -color)-grayscale[grayscale SIRDS]' \
    '(-blackandwhite -grayscale -color)-color[color SIRDS]' \
    '-maxval=[max sample value (color resolution)]:value:' \
    '-patfile=[background pattern PAM file]:file:_files' \
    '-texfile=[texture PAM file for MTS]:file:_files' \
    '-bgcolor=[background color]:color:' \
    '-smoothing=[smoothing kernel size]:pixels:' \
    '-xbegin=[horizontal start coordinate]:pixels:' \
    '-xshift=[horizontal shift before generation]:pixels:' \
    '-yshift=[vertical shift before generation]:pixels:' \
    '-yfillshift=[vertical fill-shift]:pixels:' \
    '-magnifypat=[pattern magnification]:scale:' \
    '(-guidetop -guidebottom)-guidetop[draw guide boxes at top]' \
    '(-guidetop -guidebottom)-guidebottom[draw guide boxes at bottom]' \
    '-guidesize=[guide-box size]:pixels:' \
    '-dpi=[target device resolution]:resolution:' \
    '-crosseyed[generate cross-eyed stereogram (default wall-eyed)]' \
    '-makemask[output the mask layer]' \
    '-eyesep=[eye separation]:inches:' \
    '-depth=[depth fraction]:fraction:' \
    '-planes=[near,far depth planes]:near_px,far_px:' \
    '-randomseed=[random seed]:integer:' \
    '-tileable[make output horizontally tileable]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:input depth-map PAM:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
