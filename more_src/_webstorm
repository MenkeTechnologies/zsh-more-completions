#compdef webstorm
# Documentation: https://www.jetbrains.com/help/webstorm/working-with-the-ide-features-from-command-line.html
# Reference accessed: 2026-05-21
# Verified: upstream JetBrains WebStorm CLI launcher documentation.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'diff:open diff viewer for two files'
  'merge:open merge dialog for files'
  'format:apply code style formatting'
  'inspect:perform code inspection on a project'
  'installPlugins:install plugins from JetBrains Marketplace'
)

_arguments -C \
  '--wait[wait for files to be closed before returning]' \
  'nosplash[do not show splash screen]' \
  'dontReopenProjects[do not reopen projects; show welcome screen]' \
  'disableNonBundledPlugins[skip manually installed plugins]' \
  '1: :->cmd_or_file' \
  '*::arg:_files' && ret=0

case $state in
  (cmd_or_file)
    _alternative \
      'commands:webstorm command:_describe -t commands "webstorm command" commands' \
      'files:file or directory:_files' && ret=0 ;;
esac
return ret
