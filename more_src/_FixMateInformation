#compdef FixMateInformation
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/FixMateInformation.java
# Picard: verify and fix mate-pair information in a SAM/BAM/CRAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-I,--INPUT}'=[input SAM/BAM/CRAM file(s)]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output file (overwrites input if omitted)]:file:_files' \
  '(-SO --SORT_ORDER)'{-SO,--SORT_ORDER}'=[optional output sort order]:order:(coordinate queryname unsorted)' \
  '(-AS --ASSUME_SORTED)'{-AS,--ASSUME_SORTED}'=[assume input is queryname sorted]:b:(true false)' \
  '(-MC --ADD_MATE_CIGAR)'{-MC,--ADD_MATE_CIGAR}'=[add mate CIGAR (MC) tag]:b:(true false)' \
  '--IGNORE_MISSING_MATES=[ignore missing mates instead of failing]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
