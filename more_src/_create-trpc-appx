#compdef create-trpc-appx
# Documentation: https://www.npmjs.com/package/create-trpc-appx
# Reference accessed: 2026-05-24
# Verified: npm view create-trpc-appx bin; npm readme Options tables.

# Zsh completion for create-trpc-appx - tRPC example downloader and runner

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-e --example)'{-e,--example=}'[bundled template or GitHub URL]:example:' \
  '--example-path=[subdirectory inside GitHub example]:path:' \
  '--use-npm[prefer npm as package manager]' \
  '--use-pnpm[prefer pnpm as package manager]' \
  '--yes[skip prompts]' \
  '--verbose[extra logs]' \
  '--env=[inline env KEY=VALUE; repeatable]:env:' \
  '--env-file=[load env vars from file]:file:_files' \
  '--port=[set PORT]:port:' \
  '--auto-port[find free port starting at --port or 3000]' \
  '--script=[force npm script name]:script:' \
  '--offline[use cache only; no network]' \
  '--no-cache[disable cache; force re-download]' \
  '--cache-dir=[custom cache directory]:directory:_directories' \
  '--prepare-only[download/extract without running]' \
  '--no-install[skip dependency installation]' \
  '--prebuild=[prebuild mode before start]:mode:(auto always never)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' run && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -C \
          '(-e --example)'{-e,--example=}'[GitHub example URL]:example:' \
          '--example-path=[example subdirectory]:path:' \
          '--use-npm[prefer npm]' \
          '--use-pnpm[prefer pnpm]' \
          '--prepare-only[download/extract only]' \
          '--no-install[skip dependency installation]' \
          ':project name:' && ret=0
        ;;
      *)
        _arguments -C \
          '(-e --example)'{-e,--example=}'[example name or GitHub URL]:example:' \
          '--yes[skip prompts]' \
          ':project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
