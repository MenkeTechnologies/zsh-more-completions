#compdef jello
# Documentation: https://man.archlinux.org/search?q=jello
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --compact)'{-c,--compact}'[compact JSON output]' \
  '(-C --force-color)'{-C,--force-color}'[force color output]' \
  '(-e --empty)'{-e,--empty}'[empty pythonic expressions]' \
  '(-f --format)'{-f,--format}'[format output]' \
  '(-i --initialize)'{-i,--initialize}'=[initialization file]:file:_files' \
  '(-l --lines)'{-l,--lines}'[output as lines (for piping)]' \
  '(-m --mono)'{-m,--mono}'[monochrome output]' \
  '(-n --nulls)'{-n,--nulls}'[print null values]' \
  '(-r --raw)'{-r,--raw}'[raw string output (no quotes)]' \
  '(-s --schema)'{-s,--schema}'[print schema of JSON]' \
  '(-t --types)'{-t,--types}'[print types of JSON values]' \
  '*:query:' && ret=0

return ret
