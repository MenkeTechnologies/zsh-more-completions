#compdef antsMotionCorrDiffusionDirection
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsMotionCorrDiffusionDirection.cxx — adjust DWI directions after motion correction (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-s --scheme)'{-s+,--scheme=}'[DWI scheme file (input)]:file:_files -g "*.{scheme,txt}"' \
    '(-b --bvec)'{-b+,--bvec=}'[DWI bvec file (input)]:file:_files -g "*.{bvec,txt}"' \
    '(-p --physical)'{-p+,--physical=}'[reference image (physical space)]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-m --moco)'{-m+,--moco=}'[motion-correction parameters CSV]:file:_files -g "*.csv"' \
    '(-o --output)'{-o+,--output=}'[output corrected scheme/bvec]:file:_files' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
