#compdef ssacli
# Documentation: https://gist.github.com/mrpeardotnet/a9ce41da99936c0175600f484fa20d03
# Reference accessed: 2026-05-21
# Verified: usage examples in the URL above plus HPE Smart Storage Administrator
# CLI User Guide. ssacli uses a positional verb/object grammar
# (e.g. "ctrl all show config"), not flag-style options.

# ssacli: HPE Smart Storage Administrator CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)help[show help]' \
  '(- *)-h[show help]' \
  '(- *)version[show version]' \
  '1:target:(controller ctrl array logicaldrive ld physicaldrive pd enclosure rescan help version)' \
  '*:ssacli args:' && ret=0
return ret
