#compdef bfs

# completions for bfs - breadth-first search (find alternative)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-H[follow symlinks on command line]' \
  '-L[follow all symlinks]' \
  '-P[never follow symlinks (default)]' \
  '-D+[enable debug flags]:flags:(cost exec opt rates search stat tree all)' \
  '-O+[optimization level]:level:(0 1 2 3 4)' \
  '-S+[search strategy]:strategy:(bfs dfs ids eds)' \
  '-j+[use N threads]:threads' \
  '-mindepth+[ignore results shallower than N]:depth' \
  '-maxdepth+[ignore results deeper than N]:depth' \
  '-name+[match file name]:pattern' \
  '-iname+[match file name case-insensitively]:pattern' \
  '-path+[match full path]:pattern' \
  '-ipath+[match full path case-insensitively]:pattern' \
  '-regex+[match path with regex]:pattern' \
  '-iregex+[match path with regex case-insensitively]:pattern' \
  '-type+[match file type]:type:(b c d f l p s D)' \
  '-size+[match file size]:size' \
  '-empty[match empty files and directories]' \
  '-newer+[match files modified more recently than]:file:_files' \
  '-user+[match file owner]:user:_users' \
  '-group+[match file group]:group:_groups' \
  '-perm+[match file permissions]:mode' \
  '-print[print matching paths]' \
  '-print0[print matching paths null-terminated]' \
  '-printf+[print formatted]:format' \
  '-ls[list matching files]' \
  '-delete[delete matching files]' \
  '-exec+[execute command]:command' \
  '-execdir+[execute command in file directory]:command' \
  '-prune[skip directory contents]' \
  '-quit[quit after first match]' \
  '-depth[process directory contents before directory]' \
  '-follow[follow symlinks]' \
  '-daystart[measure times from start of day]' \
  '-color[colorize output]' \
  '-nocolor[disable color output]' \
  '-hidden[include hidden files]' \
  '-nohidden[exclude hidden files]' \
  '-unique[skip duplicate files]' \
  '-mount[do not cross filesystem boundaries]' \
  '-xdev[do not cross filesystem boundaries]' \
  '*:starting point:_files -/'
