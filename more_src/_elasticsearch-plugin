#compdef elasticsearch-plugin

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install a plugin from URL/coordinates/local file'
  'list:list installed plugins'
  'remove:remove an installed plugin'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-s,--silent}'[silent output]' \
  {-v,--verbose}'[verbose output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'elasticsearch-plugin subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          {-b,--batch}'[skip confirmation prompts]' \
          {-v,--verbose}'[verbose]' \
          '*:plugin name/URL/file:_files' && ret=0
        ;;
      (list)
        _arguments \
          {-v,--verbose}'[verbose]' && ret=0
        ;;
      (remove)
        _arguments \
          '--purge[purge configuration files]' \
          '*:plugin name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
