#compdef lvm
# _lvm-cli — Logical Volume Manager driver (Heinz Mauelshagen + Red Hat); top-level LVM2 command, dispatches to subcommands
# upstream: https://gitlab.com/lvmteam/lvm2

_lvm-cli() {
    local -a sub=(
        'pvcreate:initialize a physical volume'
        'pvs:list physical volumes'
        'pvdisplay:show pv details'
        'pvremove:remove pv label'
        'pvchange:change pv attributes'
        'pvscan:scan disks for PVs'
        'pvmove:move data off pv'
        'pvresize:resize pv'
        'vgcreate:create volume group'
        'vgs:list volume groups'
        'vgdisplay:show vg details'
        'vgremove:remove vg'
        'vgchange:change vg attributes'
        'vgscan:scan for vgs'
        'vgrename:rename vg'
        'vgreduce:remove pv from vg'
        'vgextend:add pv to vg'
        'vgexport:make vg portable'
        'vgimport:import portable vg'
        'lvcreate:create logical volume'
        'lvs:list logical volumes'
        'lvdisplay:show lv details'
        'lvremove:remove lv'
        'lvchange:change lv attributes'
        'lvresize:resize lv'
        'lvextend:extend lv'
        'lvreduce:shrink lv'
        'lvrename:rename lv'
        'lvscan:scan for lvs'
        'lvconvert:convert lv layout'
        'dumpconfig:print configuration'
        'config:print/edit configuration'
        'version:print LVM version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-d --debug)'{-d,--debug}'[debug log]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lvm subcommand' sub ;;
    esac
}

_lvm-cli "$@"
