#compdef kongctl
# Documentation: https://developer.konghq.com/kongctl/
# Reference accessed: 2026-05-19
# Verified: Kong kongctl docs (declarative.md, tail, sync) + repo README.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:authenticate with Konnect'
  'logout:clear saved credentials'
  'get:retrieve resources'
  'create:create a resource'
  'update:update a resource'
  'delete:delete a resource'
  'sync:sync declarative config to Konnect'
  'apply:apply planned changes (create/update only)'
  'plan:show planned changes'
  'dump:dump current configuration'
  'diff:show differences between local config and Konnect'
  'view:interactive viewing experience'
  'kai:Kong AI commands'
  'tail:tail control plane logs'
  'completion:generate shell completion'
  'config:manage local configuration'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[configuration profile]:profile:' \
  '--pat=[Konnect personal access token]:token:' \
  '--region=[Konnect region]:region:(us eu au global)' \
  '--base-url=[explicit API endpoint URL]:url:' \
  '--output=[output format]:format:(text json yaml)' \
  '--color-theme=[UI color theme]:theme:(kong-light kong-dark default-light default-dark)' \
  '--no-telemetry[disable usage data collection]' \
  '--config-file=[config file path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kongctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (get)
        _arguments \
          '*::resource:(me apis api-versions api-publications api-implementations control-planes services routes consumers plugins keys certificates ca-certificates upstreams targets snis vaults workspaces audit-logs portal-developers portal-applications)' && ret=0 ;;
      (create|update|delete)
        _arguments \
          '*::resource:(api control-plane service route consumer plugin key certificate ca-certificate upstream target sni vault workspace)' && ret=0 ;;
      (sync|apply)
        _arguments \
          '(-f --filename)*'{-f+,--filename=}'[config file]:file:_files -g "*.{yaml,yml,json}"' \
          '--auto-approve[skip confirmation prompt]' \
          '--dry-run[show plan only]' && ret=0 ;;
      (plan)
        _arguments \
          '(-f --filename)*'{-f+,--filename=}'[config file]:file:_files -g "*.{yaml,yml,json}"' \
          '(-o --output-file)'{-o+,--output-file=}'[plan output file]:file:_files' && ret=0 ;;
      (login)
        _arguments \
          '--region=[region]:region:(us eu au global)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
      (kai)
        _arguments '*::sub:(chat assistant)' && ret=0 ;;
    esac ;;
esac

return ret
