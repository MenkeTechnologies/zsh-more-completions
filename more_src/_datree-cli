#compdef datree-cli datree
# _datree-cli — Datree datree-cli CLI command-line frontend wrapping the Datree open-source command line tool to ensure Kubernetes manifest and Helm chart reliability by preventing developers from making errors and misconfigurations open-source written in Go provides admission webhook policies enforce best practices identifies and blocks misconfigurations on production preventing service unavailability test schema-version k8s-version policy-check policy-set policies-config-file no-record no-message stop on-error report ignore-missing-schemas policy-config (Datree team Shimon Tolts, Go); cobra
# upstream: https://www.datree.io/

_datree-cli() {
    local -a sub=(
        'test:test Kubernetes manifests'
        'config:configure CLI'
        'policy:policy operations'
        'publish:publish policy YAML'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-p+[policy name]:str:' \
        '--policy=+[name]:str:' \
        '--policy-config=+[file]:file:_files -g "*.yaml *.yml"' \
        '-c+[config file]:file:_files' \
        '-x+[extra args]:str:' \
        '-s+[schema version]:str:' \
        '--schema-version=+[v]:str:' \
        '--schema-location=+[url]:str:' \
        '--cluster-context=+[name]:str:' \
        '-k+[k8s version]:str:' \
        '--kube-version=+[v]:str:' \
        '--ignore-missing-schemas[ignore missing schemas]' \
        '--only-k8s-files[only k8s files]' \
        '-o+[output format]:f:(yaml json xml junit JUnit jsonc sarif)' \
        '--output=+[fmt]:f:(yaml json xml junit JUnit jsonc sarif)' \
        '--no-record[no record]' \
        '--no-message[no message]' \
        '--non-cluster-mode[non cluster mode]' \
        '--reuse-token[reuse token]' \
        '--no-color[no color]' \
        '--token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--client-id=+[id]:str:' \
        '--only-show-failed[only failed]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose-error[verbose error]' \
        '--output-file=+[file]:file:_files' \
        '-f+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datree subcommand' sub ;;
        args)
            case $words[1] in
                test) _arguments '*:file:_files' ;;
                policy) _arguments '1:op:(set show test)' '*:arg:' ;;
                config) _arguments '1:op:(set get update)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_datree-cli "$@"
