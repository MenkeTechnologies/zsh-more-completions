#compdef unpermute-quads
# Documentation: http://astrometry.net/doc/build-index.html
# remove the permutation from a quad file and code kdtree

local ret=1

_arguments -s \
  '-h[show help]' \
  '-q+[input quad filename]:input quad:_files' \
  '-c+[input code-kdtree filename]:input ckdt:_files' \
  '-Q+[output quad filename]:output quad:_files' \
  '-C+[output code-kdtree filename]:output ckdt:_files' && ret=0

return ret
