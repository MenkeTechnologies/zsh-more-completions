        curcontext="${curcontext%:*:*}:tally-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'*-v[Increase logging verbosity (-v info, -vv debug, -vvv trace)]' \
'*--verbose[Increase logging verbosity (-v info, -vv debug, -vvv trace)]' \
