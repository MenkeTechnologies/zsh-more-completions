    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'*-v[Increase logging verbosity (-v info, -vv debug, -vvv trace)]' \
'*--verbose[Increase logging verbosity (-v info, -vv debug, -vvv trace)]' \
'*-q[Decrease logging verbosity (-q error, -qq off)]' \
'*--quiet[Decrease logging verbosity (-q error, -qq off)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tally_commands" \
"*::: :->tally" \
&& ret=0
