#compdef pdb_selres
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Selects residues by their index, piecewise or in a range

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[residue selection, e.g. -1,2,3 or -1:10 or -1:10:2]:residue range' \
  '*:PDB file:_files' && ret=0

return ret
