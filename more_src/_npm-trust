#compdef npm-trust
# Documentation: https://www.npmjs.com/package/npm-trust
# Reference accessed: 2026-05-23
# Verified: npx npm-trust --help.

# Zsh completion for npm-trust - bulk npm OIDC trusted publishing setup

local curcontext="$curcontext" state line ret=1

_arguments -C   '--help[show help]'   '--scope=[npm org scope]:scope:'   '*--packages=[package names]:package:'   '--auto[detect packages from current directory]'   '--repo=[GitHub owner/repo]:repo:'   '--workflow=[GitHub Actions workflow file]:file:_files'   '--list[list current trust status]'   '--only-new[only packages without OIDC trust]'   '--dry-run[show planned changes only]'   '--doctor[print environment health report]'   '--json[emit machine-readable JSON]'   '--emit-workflow[print canonical OIDC release workflow]'   '--with-prepare-dist[include prepare-dist step in workflow template]'   '--verify-provenance[query provenance attestations]'   '--validate-only[read-only pre-flight validation]'   '--capabilities[emit capabilities report]'   '*::args:' && ret=0

return ret
