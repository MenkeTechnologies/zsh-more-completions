#compdef xnconvert

# XnConvert: batch image converter / processor (Qt CLI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '-load[load .xbs batch settings]:file:_files -g "*.xbs"' \
  '-save[save .xbs batch settings]:file:_files -g "*.xbs"' \
  '-out[output folder]:dir:_files -/' \
  '-quit[quit after run]' \
  '*:input image / folder:_files' && ret=0
return ret
