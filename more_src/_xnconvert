#compdef xnconvert

# XnConvert: cross-platform batch image converter (Qt)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-load[load preset/.xbs script]:file:_files -g "*.xbs"' \
  '-out=[output directory]:dir:_files -/' \
  '-quiet[no GUI - silent execution]' \
  '-batch[batch mode (use with -load)]' \
  '*:input image(s):_files' && ret=0
return ret
