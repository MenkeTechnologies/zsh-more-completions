#compdef sqlboiler

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[display version]' \
  '--config=[config file]:config file:_files' \
  '--output=[output directory]:directory:_directories' \
  '--pkgname=[package name]:package name' \
  '--templates=[template directories]:template dir:_directories' \
  '--tag=[struct tags to generate]:tags' \
  '--no-tests[disable test generation]' \
  '--no-hooks[disable hook generation]' \
  '--no-auto-timestamps[disable automatic timestamps]' \
  '--no-rows-affected[disable rows affected in update/delete]' \
  '--no-driver-templates[disable driver-specific templates]' \
  '--no-back-referencing[disable back referencing]' \
  '--add-global-variants[add global variant functions]' \
  '--add-panic-variants[add panic variant functions]' \
  '--add-soft-deletes[add soft delete support]' \
  '--add-enum-types[add enum types]' \
  '--struct-tag-casing=[struct tag casing style]:casing:(camel title snake alias)' \
  '--relation-tag=[relationship struct tag]:tag' \
  '--tag-ignore=[columns to ignore for tags]:columns' \
  '--wipe[wipe output directory before generating]' \
  '--debug[enable debug mode]' \
  '1:driver:->drivers' && ret=0

case $state in
  drivers)
    local -a drivers=(
      'mysql:Generate models for MySQL'
      'psql:Generate models for PostgreSQL'
      'mssql:Generate models for Microsoft SQL Server'
      'sqlite3:Generate models for SQLite3'
      'crdb:Generate models for CockroachDB'
    )
    _describe -t drivers 'database driver' drivers && ret=0
    ;;
esac

return ret
