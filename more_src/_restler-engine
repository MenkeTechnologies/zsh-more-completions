#compdef restler-engine restler.py
# _restler-engine — RESTler Python engine entrypoint (microsoft/restler-fuzzer)
# upstream: https://github.com/microsoft/restler-fuzzer
# Flags from restler/restler.py (argparse).

_restler-engine() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--max_sequence_length=[maximum request sequence length]:n:' \
        '--fuzzing_jobs=[number of parallel fuzzing jobs]:n:' \
        '--target_ip=[target IP]:ip:_hosts' \
        '--target_port=[target port]:port:' \
        '--time_budget=[stop fuzzing after this time (hours)]:hours:' \
        '--max_request_execution_time=[max request execution time]:s:' \
        '--fuzzing_mode=[fuzzing mode]:mode:(bfs bfs-cheap bfs-fast random-walk directed-smoke-test)' \
        '--ignore_feedback[ignore service feedback]' \
        '--ignore_dependencies[ignore producer/consumer dependencies]' \
        '--garbage_collection_interval=[garbage collection interval]:s:' \
        '--dyn_objects_cache_size=[dynamic objects cache size]:n:' \
        '--restler_grammar=[RESTler grammar file]:file:_files -g "*.py"' \
        '--custom_mutations=[custom mutations dictionary file]:file:_files -g "*.json"' \
        '--settings=[engine settings file]:file:_files -g "*.json"' \
        '--path_regex=[path regex filter]:regex:' \
        '--token_refresh_interval=[token refresh interval]:s:' \
        '--token_refresh_cmd=[token refresh command]:cmd:' \
        '--client_certificate_path=[client certificate]:file:_files' \
        '--producer_timing_delay=[delay after producer call]:s:' \
        '--no_tokens_in_logs[strip tokens from logs]' \
        '--save_results_in_fixed_dirname[do not timestamp result dirs]' \
        '--host=[override Host header]:host:_hosts' \
        '--no_ssl[do not use SSL]' \
        '--include_user_agent[include RESTler user agent]' \
        '--enable_checkers=[checkers to enable]:list:' \
        '--disable_checkers=[checkers to disable]:list:' \
        '--replay_log=[replay log file]:file:_files' \
        '--use_test_socket[use in-memory test socket]' \
        '--test_server=[in-memory test server module]:module:' \
        '--set_version=[set engine version string]:ver:'
}

_restler-engine "$@"
