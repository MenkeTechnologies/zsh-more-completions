#compdef cmake-format

# Zsh completion for cmake-format - CMake file formatter

_arguments -s -S \
  '(-c --config-files)'{-c+,--config-files=}'[config file paths]:config files:_files' \
  '--config-file=[path to config file]:config file:_files' \
  '-i[edit files in-place]' \
  '--in-place[edit files in-place]' \
  '--check[check formatting without modifying]' \
  '(-o --outfile-path)'{-o+,--outfile-path=}'[output file path]:file:_files' \
  '--dump-config=[dump config]:format:(yaml json python)' \
  '--no-help[suppress help on formatting]' \
  '--line-width=[max line width]:width:' \
  '--tab-size=[number of spaces per tab]:size:' \
  '--max-subgroups-hwrap=[max argument subgroups for horizontal wrapping]:count:' \
  '--max-pargs-hwrap=[max positional arguments for horizontal wrapping]:count:' \
  '--separate-ctrl-name-with-space[separate flow control from paren with space]' \
  '--separate-fn-name-with-space[separate function name from paren with space]' \
  '--dangle-parens[dangle closing parenthesis]' \
  '--no-dangle-parens[do not dangle closing parenthesis]' \
  '--command-case=[case for command names]:case:(lower upper canonical unchanged)' \
  '--keyword-case=[case for keywords]:case:(lower upper unchanged)' \
  '--first-comment-is-literal[treat first comment as literal]' \
  '--literal-comment-pattern=[regex for literal comments]:pattern:' \
  '--enable-markup[interpret comments as rst]' \
  '--no-enable-markup[do not interpret comments as rst]' \
  '--log-level=[log level]:level:(debug info warning error)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:files:_files -g "*.cmake" -g "CMakeLists.txt"'
