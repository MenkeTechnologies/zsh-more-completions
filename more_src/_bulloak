#compdef bulloak
# Documentation: https://github.com/alexfertel/bulloak
# bulloak - Bulloak Tree Notation (.tree) Solidity test scaffolder/checker

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-w --write-files)'{-w,--write-files}'[write generated contracts to disk]' \
  '(-f --force)'{-f,--force}'[overwrite existing .t.sol files]' \
  '(-S --vm-skip)'{-S,--vm-skip}'[add vm.skip(true) to each test function]' \
  '(-m --skip-modifiers)'{-m,--skip-modifiers}'[omit modifier definitions]' \
  '(-F --format-descriptions)'{-F,--format-descriptions}'[normalize comment capitalization/punctuation]' \
  '--fix[apply automatic fixes to Solidity files]' \
  '--stdout[print to console instead of overwriting]' \
  '1:command:(scaffold check)' \
  '*:tree file:_files -g "*.tree"' && ret=0

return ret
