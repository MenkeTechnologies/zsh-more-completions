#compdef 7za 7zr
# _7za-bin — 7-Zip standalone reduced binary (Igor Pavlov); supports 7z/zip/tar/gz/bz2/xz/wim and rar/cab decompression
# upstream: https://www.7-zip.org

_7za-bin() {
    local -a sub=(
        'a:add to archive'
        'b:benchmark'
        'd:delete files from archive'
        'e:extract (flat)'
        'h:hash files'
        'i:info on supported formats'
        'l:list contents'
        'rn:rename inside archive'
        't:test integrity'
        'u:update files in archive'
        'x:extract with paths'
    )
    _arguments -C \
        '-an[disable parsing of archive name]' \
        '-ai+[include archives regex]:regex:' \
        '-ax+[exclude archives regex]:regex:' \
        '-bb[set output log level]' \
        '-bd[disable progress]' \
        '-i+[include filter]:filter:' \
        '-m+[method param]:param:' \
        '-mhe=on[encrypt headers]' \
        '-mhe=off[do not encrypt headers]' \
        '-mmt=+[threads]:n:' \
        '-mx=+[compression lvl 0-9]:n:' \
        '-mxz=+[max threads]:n:' \
        '-o+[output dir]:dir:_files -/' \
        '-p+[password]:password:' \
        '-r[recurse]' \
        '-sdel[delete after success]' \
        '-sfx+[create SFX]:module:' \
        '-si[read from stdin]' \
        '-so[write to stdout]' \
        '-spd[disable wildcard matching]' \
        '-spe[exclude root prefix]' \
        '-spf[fullpath]' \
        '-ssc-[case insensitive]' \
        '-ssw[allow open shared write]' \
        '-stl[set archive mtime from newest file]' \
        '-stm+[set NT file mode]:n:' \
        '-stx+[exclude type]:type:' \
        '-t+[archive type]:type:(7z zip gzip bzip2 tar xz wim swfc rar cab arj cpio iso lzh lzma rpm vhd udf dmg hfs squashfs cramfs apm)' \
        '-u+[update spec]:spec:' \
        '-x+[exclude filter]:filter:' \
        '-y[assume yes]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands '7za subcommand' sub ;;
        args)
            _arguments \
                '1:archive:_files -g "*.(7z|zip|gz|bz2|tar|xz|wim)"' \
                '*:file:_files'
            ;;
    esac
}

_7za-bin "$@"
