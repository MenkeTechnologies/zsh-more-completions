#compdef hledger-stockquotes
# Documentation: https://github.com/prikhi/hledger-stockquotes
# Documentation: https://github.com/prikhi/hledger-stockquotes/blob/master/app/Main.hs
# Reference accessed: 2026-05-27
# Verified: upstream app/Main.hs (argSpec, CmdArgs-style flag definitions).

# Zsh completion for hledger-stockquotes (fetches stock/crypto quotes
# from AlphaVantage and emits hledger price directives).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-a --api-key)'{-a+,--api-key=}'[AlphaVantage API key (default: $ALPHAVANTAGE_KEY)]:key:' \
  '(-r --rate-limit -n --no-rate-limit)'{-r,--rate-limit}'[apply rate-limiting for the API]' \
  '(-n --no-rate-limit -r --rate-limit)'{-n,--no-rate-limit}'[disable rate-limiting for the API]' \
  '(-f --journal-file)'{-f+,--journal-file=}'[journal file to read commodities from]:file:_files -g "*.{journal,hledger}"' \
  '(-o --output-file)'{-o+,--output-file=}'[file to write prices into]:file:_files' \
  '*'{-c+,--crypto=}'[cryptocurrencies to fetch prices for (repeatable)]:tickers:' \
  '(-d --dry-run)'{-d,--dry-run}'[print the commodities and dates that would be processed]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:excluded currency:' && ret=0

return ret
