#compdef Geod3Solve
# Documentation: https://geographiclib.sourceforge.io/C++/doc/Geod3Solve.1.html
# GeographicLib: solve geodesic problems on a triaxial ellipsoid

local ret=1

_arguments -s -S \
  '-i[perform an inverse geodesic calculation]' \
  '-L[line mode from bet1 omg1 alp1]:bet1:' \
  '-t[specify ellipsoid via semiaxes a b c]:a:' \
  '-e[specify ellipsoid via median semiaxis and shape parameters]:b:' \
  '-e2[specify biaxial ellipsoid via equatorial radius and flattening]:b:' \
  '-u[unroll the latitude and longitude]' \
  '-d[output angles as degrees, minutes, seconds]' \
  '-:[like -d but use colons as separators]' \
  '-w[toggle longitude-first flag]' \
  '-f[full output of seven quantities per line]' \
  '-p[set output precision]:prec:' \
  '--comment-delimiter[set comment delimiter]:delim:' \
  '--version[print version and exit]' \
  '(-h --help)-h[print usage and exit]' \
  '(-h --help)--help[print full documentation and exit]' \
  '--input-file[read input from file]:infile:_files' \
  '--input-string[read input from string]:string:' \
  '--line-separator[set line separator character]:linesep:' \
  '--output-file[write output to file]:outfile:_files' && ret=0

return ret
