#compdef flux-ping
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-ping.html
# measure round-trip latency to a Flux service

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --rank)'{-r,--rank=}'[find target on specific broker rank]:rank' \
  '(-p --pad)'{-p,--pad=}'[include payload string of N bytes]:n' \
  '(-i --interval)'{-i,--interval=}'[delay in seconds between requests]:seconds' \
  '(-c --count)'{-c,--count=}'[number of requests to send]:n' \
  '(-b --batch)'{-b,--batch}'[process responses after all requests sent]' \
  '(-u --userid)'{-u,--userid}'[include userid and rolemask of request]' \
  '*:target:_default' && ret=0

return ret
