#compdef add-skill skills
# Documentation: https://github.com/vercel-labs/skills
# Reference accessed: 2026-05-22
# Verified: src/cli.ts command routing and help output.

# Zsh completion for skills / add-skill - open agent skills ecosystem CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-g --global)'{-g,--global}'[use global scope]' \
  '(-a --agent)'{-a,--agent}'[target agent]:agent:' \
  '(-s --skill)'{-s,--skill}'[skill name filter]:skill:' \
  '(-y --yes)'{-y,--yes}'[skip confirmation prompts]' \
  '--copy[copy files instead of symlinking]' \
  '--all[install all skills and agents]' \
  '--full-depth[search all subdirectories]' \
  '--json[JSON output for list]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'skills command' \
      'add[add skill package from GitHub or URL]' \
      'install[alias for add]' \
      'remove[remove installed skills]' \
      'rm[alias for remove]' \
      'list[list installed skills]' \
      'ls[alias for list]' \
      'find[search for skills]' \
      'search[alias for find]' \
      'update[update skills to latest versions]' \
      'upgrade[alias for update]' \
      'init[initialize a new skill]' \
      'experimental_install[restore from skills-lock.json]' \
      'experimental_sync[sync skills from node_modules]' && ret=0
    ;;
  args)
    case $line[1] in
      add|install)
        _arguments \
          '--list[list available skills without installing]' \
          '1:source: :_urls' && ret=0
        ;;
      remove|rm)
        _arguments '1:skill names:' && ret=0
        ;;
      list|ls)
        _arguments '--json[JSON output]' && ret=0
        ;;
      find|search)
        _arguments '1:search query:' && ret=0
        ;;
      init)
        _arguments '1:skill name:' && ret=0
        ;;
      update|upgrade)
        _arguments \
          '(-p --project)'{-p,--project}'[update project skills only]' \
          '1:skill names:' && ret=0
        ;;
    esac
    ;;
esac

return ret
