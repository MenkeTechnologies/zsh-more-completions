#compdef @auto_tlrc
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@auto_tlrc.html
# Transform an anatomical dataset to align with a standard space template

local ret=1

_arguments -s -S \
  '-base[reference anatomical volume in standard space]:template:_files' \
  '-input[original dataset to transform]:dset:_files' \
  '-apar[anatomical dataset in tlrc space (Usage 2)]:tlrc_parent:_files' \
  '-no_ss[do not strip skull of input data set]' \
  '-warp_orig_vol[produce TLRC version of the input volume]' \
  '-dxyz[cubic voxel size of output in TLRC space]:mm' \
  '-dx[size of voxel in x direction (R-L)]:mx' \
  '-dy[size of voxel in y direction (A-P)]:my' \
  '-dz[size of voxel in z direction (I-S)]:mz' \
  '-pad_base[pad the base dset by MM mm in each direction]:mm' \
  '-keep_tmp[keep temporary files]' \
  '-clean[clean all temp files]' \
  '-xform[transform to use for warping]:xform' \
  '-no_avoid_eyes[option passed to 3dSkullStrip]' \
  '-ncr[turn off coarserot option for 3dWarpDrive]' \
  '(-twopass)-onepass[turn off -twopass option for 3dWarpDrive]' \
  '(-onepass)-twopass[opposite of -onepass (default)]' \
  '-maxite[max iterations for 3dWarpDrive]:niter' \
  '-not_OK_maxite[see -maxite option]' \
  '-inweight[apply -weight INPUT in 3dWarpDrive]' \
  '-rigid_equiv[also output rigid-body version of the alignment]' \
  '-init_xform[apply affine transform before registration]:file:_files' \
  '-no_pre[delete temporary dataset created by -init_xform]' \
  '-out_space[set output to a particular space]:spacename' \
  '-3dAllineate[use 3dAllineate with lpa+ZZ cost function]' \
  '-3dAlcost[use alternative cost function]:costfunction' \
  '-overwrite[overwrite existing output]' \
  '-pad_input[pad the input DSET by MM mm in each direction]:mm' \
  '-onewarp[create follower data with one interpolation step]' \
  '-twowarp[create follower data with two interpolation steps]' \
  '-rmode[resampling mode]:mode:(linear cubic NN quintic)' \
  '-prefix[name output dataset]:prefix' \
  '-suffix[append SUF to the prefix]:suf' \
  '-keep_view[do not mark output dataset as +tlrc]' \
  '-base_copy[copy base dataset into COPY_PREFIX]:copy_prefix' \
  '-base_list[list the full path of the base dataset]' \
  '-use_gz[behave as if a prefix was provided]' \
  '-verb[verbose output]' \
  '(-hweb)-h_web[open webpage with help for this program]' \
  '(-hview)-h_view[open -help output in a GUI editor]' \
  '-all_opts[list all of the options for this script]' \
  '-h_find[search for lines containing WORD in -help output]:word' \
  '*:dataset:_files' && ret=0

return ret
