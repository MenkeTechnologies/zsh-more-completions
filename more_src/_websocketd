#compdef websocketd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--port=[listen port]:port:' \
  '--address=[listen address]:address:' \
  '--ssl[enable SSL]' \
  '--sslcert=[SSL certificate file]:certificate:_files' \
  '--sslkey=[SSL key file]:key:_files' \
  '--origin=[restrict allowed origins]:origin:' \
  '--passenv=[pass environment variables]:variables:' \
  '--binary[use binary WebSocket frames]' \
  '--reversedns[enable reverse DNS lookups]' \
  '--dir=[serve static files from directory]:directory:_directories' \
  '--staticdir=[directory for static files]:directory:_directories' \
  '--cgidir=[directory for CGI scripts]:directory:_directories' \
  '--header=[add custom HTTP header]:header:' \
  '--maxforks=[max number of concurrent forks]:count:' \
  '--closems=[time to wait before closing]:milliseconds:' \
  '--loglevel=[log level]:level:(debug trace access info error fatal)' \
  '--devconsole[enable development console]' \
  '*:command:_files' && ret=0

return ret
