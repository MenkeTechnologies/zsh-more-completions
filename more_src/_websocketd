#compdef websocketd
# Documentation: https://github.com/joewalnes/websocketd
# Reference accessed: 2026-05-21
# Verified: upstream help.go option list.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(- *)--license[show license]' \
  '--port=[listen port]:port:' \
  '--address=[bind address (IPv6 in brackets)]:address:' \
  '--sameorigin=[restrict upgrades by Origin match]:bool:(true false)' \
  '--origin=[whitelist allowed origins]:origin:' \
  '--ssl[enable HTTPS listening]' \
  '--sslcert=[SSL certificate file]:certificate:_files' \
  '--sslkey=[SSL key file]:key:_files' \
  '--redirport=[port for HTTP-to-HTTPS redirect]:port:' \
  '--passenv=[env vars to pass to scripts]:variables:' \
  '--binary=[binary communication mode]:bool:(true false)' \
  '--reverselookup=[DNS reverse lookups on clients]:bool:(true false)' \
  '--dir=[directory of scripts to serve]:directory:_directories' \
  '--staticdir=[directory for static files]:directory:_directories' \
  '--cgidir=[directory for CGI scripts]:directory:_directories' \
  '*--header=[custom HTTP header]:header:' \
  '*--header-ws=[header for WebSocket upgrade response]:header:' \
  '*--header-http=[header for plain HTTP responses]:header:' \
  '--maxforks=[max concurrent forks]:count:' \
  '--closems=[grace ms before terminating processes]:milliseconds:' \
  '--loglevel=[log level]:level:(debug trace access info error fatal)' \
  '--devconsole[enable development console]' \
  '*:command:_files' && ret=0

return ret
