#compdef 3dErrtsCormat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dErrtsCormat.html
# AFNI compute the correlation matrix of residual time series

local ret=1

_arguments -s -S \
  '-concat[concatenation dataset]:rname:_files' \
  '-input[input dataset]:dset:_files' \
  '-mask[mask dataset]:mset:_files' \
  '-maxlag[maximum lag parameter]:mm:' \
  '-polort[polynomial order level]:pp:' \
  '*:dataset:_files' && ret=0

return ret
