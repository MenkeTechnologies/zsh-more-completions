#compdef the-way
# Documentation: https://github.com/out-of-cheese-error/the-way
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:add a new code snippet'
  'cmd:add a new shell snippet'
  'search:fuzzy search to find a snippet'
  'sync:sync snippets to a Gist'
  'list:list (optionally filtered) snippets'
  'import:import snippets from JSON'
  'export:export snippets to JSON'
  'clear:clear all data'
  'complete:generate shell completions'
  'themes:manage syntax highlighting themes'
  'config:manage data locations'
  'edit:change snippet'
  'del:delete snippet'
  'cp:copy snippet to clipboard'
  'view:view snippet'
  'tags:list tags'
  'languages:list languages'
)

_arguments -C \
  '(-c --colorize)'{-c,--colorize}'[force colorization]' \
  '(-p --plain)'{-p,--plain}'[turn off colorization]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: : _default' && ret=0

case $state in
  (cmd) _describe -t commands 'the-way command' commands && ret=0 ;;
esac

return ret
