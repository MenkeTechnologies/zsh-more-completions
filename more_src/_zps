#compdef zps

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-p[match a process by PID]:pid:_pids' \
  '-t[scan process tree]' \
  '-r[reap zombie processes]' \
  '-s[show the process states]' \
  '-n[show only zombie processes]' \
  '*:pattern:' && ret=0

return ret
