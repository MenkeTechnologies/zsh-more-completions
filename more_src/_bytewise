#compdef bytewise
# _bytewise — bytewise binary-comparison forensic CLI for byte-by-byte difference reporting of binary files producing color-aware diff output and HTML reports with histogram visualisation (bytewise team, Python); argparse
# upstream: https://github.com/forensic-tools/bytewise

_bytewise() {
    local -a sub=(
        'diff:byte-by-byte diff'
        'patch:apply byte patch'
        'compare:compare to baseline'
        'inspect:inspect single file'
        'extract:extract slice'
        'hash:compute hashes'
        'histogram:byte histogram'
        'entropy:compute entropy'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output file]:file:_files -g "*.html *.txt *.json *.csv"' \
        '--output=+[output file]:file:_files -g "*.html *.txt *.json *.csv"' \
        '-f+[format]:f:(text html json csv hex)' \
        '--format=+[format]:f:(text html json csv hex)' \
        '--no-color[no color]' \
        '--chunk-size=+[bytes]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bytewise subcommand' sub ;;
        args)
            case $words[1] in
                diff|compare) _arguments \
                    '--offset=+[hex]:str:' \
                    '--length=+[bytes]:n:' \
                    '--threshold=+[F]:f:' \
                    '*:files:_files' ;;
                inspect|hash|histogram|entropy|extract) _arguments \
                    '--offset=+[hex]:str:' \
                    '--length=+[bytes]:n:' \
                    '*:file:_files' ;;
                patch) _arguments \
                    '--patch=+[file]:file:_files' \
                    '*:target file:_files' ;;
            esac
            ;;
    esac
}

_bytewise "$@"
