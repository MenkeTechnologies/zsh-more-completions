#compdef pacemaker-fenced
# Documentation: https://man.archlinux.org/search?q=pacemaker-fenced
# Reference accessed: 2026-05-16

# Pacemaker fencing subdaemon (stonithd)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-$,--version}'[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '*::pacemaker-fenced args:_files' && ret=0
return ret
