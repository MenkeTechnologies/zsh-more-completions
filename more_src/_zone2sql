#compdef zone2sql
# Documentation: https://doc.powerdns.com/authoritative/manpages/zone2sql.1.html
# Convert BIND named.conf and zone files into SQL for database backends

local ret=1

_arguments -s -S \
  '--help[display all available options]' \
  '--named-conf=[read BIND configuration from path]:path:_files' \
  '--zone=[parse only the zone file at path]:path:_files' \
  '--zone-name=[zone name for a single zone without $ORIGIN]:name:' \
  '--gmysql[output SQL for Generic MySQL backend]' \
  '--gpgsql[output SQL for Generic PostgreSQL backend]' \
  '--gsqlite[output SQL for Generic SQLite3 backend]' \
  '--json-comments[parse JSON in zonefile comments for disabled/comment fields]' \
  '--transactions[wrap each domain in a transaction]' \
  '--delete-matching-domains[add delete statements for re-importing]' \
  '--filter-duplicate-soa[ignore duplicate SOA records]' \
  '--on-error-resume-next[continue despite missing zone files]' \
  '--secondary[preserve secondary zone status from named.conf]' \
  '--verbose[enable detailed output]' && ret=0

return ret
