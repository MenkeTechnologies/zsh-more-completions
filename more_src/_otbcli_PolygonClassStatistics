#compdef otbcli_PolygonClassStatistics
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_PolygonClassStatistics.html
# Orfeo ToolBox: compute polygon class statistics for sampling

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[support image file]:image:_files' \
  '-mask[validity mask to filter pixels]:image:_files' \
  '-vec[input vector file of geometries]:vector:_files' \
  '-out[output XML statistics file]:output:_files' \
  '-field[attribute field containing class labels]:name:' \
  '-layer[index of the layer to read]:value:' \
  '-elev.dem[directory containing DEM files]:dir:_files -/' \
  '-elev.geoid[geoid grid file]:file:_files' \
  '-elev.default[default elevation value]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
