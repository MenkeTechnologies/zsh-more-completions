#compdef gddrescue gnu-ddrescue
# _gddrescue — GNU GDdrescue CLI for the GNU data recovery tool that copies data from one file or block device to another trying hard to rescue data in case of read errors with rate limits map file resume retry passes (gnu team, C++); getopt
# upstream: https://www.gnu.org/software/ddrescue/

_gddrescue() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-a+[min read rate]:n:' \
        '--min-read-rate=+[N]:n:' \
        '-A[reverse direction]' \
        '--reverse[reverse direction]' \
        '-b+[sector size]:n:' \
        '--sector-size=+[N]:n:' \
        '-B[binary output]' \
        '--binary-prefixes[binary output]' \
        '-c+[cluster size]:n:' \
        '--cluster-size=+[N]:n:' \
        '-C[complete only]' \
        '--complete-only[complete only]' \
        '-d[direct]' \
        '--idirect[direct]' \
        '-D[output direct]' \
        '--odirect[output direct]' \
        '-e+[max errors]:n:' \
        '--max-errors=+[N]:n:' \
        '-E+[max error rate]:n:' \
        '--max-error-rate=+[N]:n:' \
        '-f[force]' \
        '--force[force]' \
        '-F+[fill mode]:m:(?+-)' \
        '--fill-mode=+[mode]:m:(?+-)' \
        '-g[generate map]' \
        '--generate-mode[generate map]' \
        '-H+[test mode log]:file:_files' \
        '-i+[input position]:n:' \
        '--input-position=+[N]:n:' \
        '-I[verify input size]' \
        '--verify-input-size[verify input size]' \
        '-K+[skip size]:n:' \
        '--skip-size=+[N]:n:' \
        '-L[loose domain]' \
        '--loose-domain[loose domain]' \
        '-m+[domain mapfile]:file:_files' \
        '--domain-mapfile=+[file]:file:_files' \
        '-M[retrim]' \
        '--retrim[retrim]' \
        '-n[no scrape]' \
        '--no-scrape[no scrape]' \
        '-N[no trim]' \
        '--no-trim[no trim]' \
        '-o+[output position]:n:' \
        '--output-position=+[N]:n:' \
        '-O[reopen on error]' \
        '--reopen-on-error[reopen on error]' \
        '-p[preallocate]' \
        '--preallocate[preallocate]' \
        '-P+[data preview]:n:' \
        '--data-preview=+[N]:n:' \
        '-r+[max retry passes]:n:' \
        '--retry-passes=+[N]:n:' \
        '-R[reset slow]' \
        '--reset-slow[reset slow]' \
        '-s+[size]:n:' \
        '--size=+[N]:n:' \
        '-S[sparse]' \
        '--sparse[sparse]' \
        '-t[truncate output]' \
        '--truncate[truncate output]' \
        '-T+[timeout]:str:' \
        '--timeout=+[d]:str:' \
        '-u[unidirectional]' \
        '--unidirectional[unidirectional]' \
        '-w[ignore write errors]' \
        '--ignore-write-errors[ignore write errors]' \
        '-x+[extend size]:n:' \
        '--extend-outfile=+[N]:n:' \
        '-X+[exit on error rate]:n:' \
        '--max-exit-time=+[N]:n:' \
        '-y+[synchronous]:str:' \
        '*:infile outfile mapfile:_files'
}

_gddrescue "$@"
