#compdef opencv_traincascade
# Documentation: https://docs.opencv.org/4.x/dc/d88/tutorial_traincascade.html
# opencv_traincascade — train a boosted cascade classifier

local ret=1

_arguments -s -S \
  '-data[where the trained classifier should be stored]:dir:_files -/' \
  '-vec[vec-file with positive samples]:file:_files' \
  '-bg[background description file]:file:_files' \
  '-numPos[number of positive samples per stage]:num' \
  '-numNeg[number of negative samples per stage]:num' \
  '-numStages[number of cascade stages to train]:num' \
  '-precalcValBufSize[buffer size for precalculated feature values (Mb)]:mb' \
  '-precalcIdxBufSize[buffer size for precalculated feature indices (Mb)]:mb' \
  '-baseFormatSave[save cascade in old format for backwards compatibility]' \
  '-numThreads[maximum number of threads to use]:num' \
  '-acceptanceRatioBreakValue[acceptance ratio break value]:value' \
  '-stageType[type of stages]:type:(BOOST)' \
  '-featureType[type of features]:type:(HAAR LBP)' \
  '-w[width of training samples in pixels]:width' \
  '-h[height of training samples in pixels]:height' \
  '-bt[type of boosted classifier]:type:(DAB RAB LB GAB)' \
  '-minHitRate[minimal desired hit rate per stage]:rate' \
  '-maxFalseAlarmRate[maximal desired false alarm rate per stage]:rate' \
  '-weightTrimRate[weight trimming rate]:rate' \
  '-maxDepth[maximal depth of a weak tree]:depth' \
  '-maxWeakCount[maximal count of weak trees per stage]:count' \
  '-mode[Haar features set]:mode:(BASIC CORE ALL)' && ret=0

return ret
