#compdef rsftch
# Documentation: https://github.com/charklie/rsftch
# rsftch - a lightning fast hardware fetch written in Rust

local ret=1

_arguments -s -S \
  '(-h --help --usage)'{-h,--help,--usage}'[bring up the help menu]' \
  '(-v --version)'{-v,--version}'[print version number]' \
  '(-o --override)'{-o,--override}'=[override distribution, affects ASCII and distro info]:distro:' \
  '(-m --margin)'{-m,--margin}'=[add margin to the info sections]:margin:' \
  '--config=[specify another info config file to be used]:file:_files' \
  '--ignore-config[ignore configuration and use the example one]' && ret=0

return ret
