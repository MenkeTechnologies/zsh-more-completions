#compdef ch-fromhost
# Documentation: https://charliecloud.io/latest/ch-fromhost.html
# Charliecloud: inject files from the host into an image directory.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-c --cmd)'{-c,--cmd}'[inject files listed in stdout of command]:command:_command_names' \
  '(-f --file)'{-f,--file}'[inject files listed in the file]:file:_files' \
  '(-p --path)'{-p,--path}'[inject the file at path]:path:_files' \
  '--cray-cxi[inject cray-libfabric for slingshot]' \
  '--cray-gni[inject cray gemini/aries GNI libfabric provider]' \
  '--nvidia[use nvidia-container-cli to find files to inject]' \
  '(-d --dest)'{-d,--dest}'[place later files in IMGDIR/DST]:dest:_files -/' \
  '--print-cray-fi[print inferred destination for libfabric replacement]' \
  '--print-fi[print guest destination path for libfabric providers]' \
  '--print-lib[print guest destination path for shared libraries]' \
  "--no-ldconfig[don't run ldconfig]" \
  '--version[print version and exit]' \
  '*'{-v,--verbose}'[be more verbose; can be repeated]' \
  '*:image directory:_files -/' && ret=0

return ret
