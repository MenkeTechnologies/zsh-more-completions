#compdef rtags
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/utils/html/rtags.html
# R CMD rtags: tag C, R, and Rd files under a directory

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print short help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '(-o --output)'{-o,--output=}'[write output to FILE]:file:_files' \
  '--no-c[do not tag C (.c, .h) files]' \
  '--no-R[do not tag R (.R, .r, .S, .s) files]' \
  '--no-Rd[do not tag Rd (.Rd) files]' \
  '--ctags[write Ctags format (default is Etags)]' \
  '(-a --append)'{-a,--append}'[append to output file (overwrites by default)]' \
  '(-V --verbose)'{-V,--verbose}'[echo the name of files processed]' \
  '*:path:_files -/' && ret=0

return ret
