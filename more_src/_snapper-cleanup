#compdef snapper-cleanup

# snapper cleanup: periodic snapshot cleanup helper (called by systemd timer)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-q[quiet mode]' \
  '-c[snapper config name]:config:' \
  '*:cleanup algorithm:(number timeline empty-pre-post)' && ret=0
return ret
