#compdef terrahash
# Documentation: https://man.archlinux.org/search?q=terrahash
# Reference accessed: 2026-05-16

# Zsh completion for terrahash Terraform lockfile hasher

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:subcommand:(generate check update version)' \
  '*::args:{ _files -g "*.tf" }' && ret=0

return ret
