#compdef dfctl
# _dfctl — Dragonfly task management CLI (dragonflyoss/client)
# upstream: https://github.com/dragonflyoss/client
# Subcommands from dragonfly-client/src/bin/dfctl/main.rs (clap).

_dfctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'task:manage tasks in Dragonfly'
                'persistent-task:manage persistent tasks'
                'persistent-cache-task:manage persistent cache tasks'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                task|persistent-task|persistent-cache-task)
                    _arguments '1:sub:(list get delete stat)' '2:task ID:'
                    ;;
            esac
            ;;
    esac
}

_dfctl "$@"
