#compdef cvanal
# Csound impulse response Fourier analysis for the convolve operator

local ret=1

_arguments -s -S \
  '-s+[override input sampling rate]:rate' \
  '-c+[channel to process (default all)]:channel' \
  '-b+[begin time in seconds]:begin' \
  '-d+[duration in seconds]:duration' \
  '-X[write machine-independent format]' \
  '*:soundfile:_files' && ret=0

return ret
