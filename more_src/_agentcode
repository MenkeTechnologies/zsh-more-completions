#compdef agentcode
# Documentation: https://github.com/vigp17/AgentCode
# Reference accessed: 2026-05-22
# Verified: cli.py argparse definitions.

# Zsh completion for agentcode - multi-model agentic coding CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --model)'{-m,--model}'[LLM model via LiteLLM]:model:' \
  '--no-route[disable cost-aware model routing]' \
  '(-y --auto-approve)'{-y,--auto-approve}'[auto-approve all tool calls]' \
  '(-d --dir)'{-d,--dir}'[project directory]:directory:_directories' \
  '--init-settings[create starter .agentcode/settings.json and exit]' \
  '--server[run JSON stdio server for VS Code extension]' \
  '*:prompt:' && ret=0

return ret
