#compdef torcs
# Documentation: https://manpages.debian.org/bookworm/torcs/torcs.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm torcs(6) manpage / upstream torcs main.cpp.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -B/-r/-R/-e/-t/-T/-m flags (TORCS has only -l/-L/-d and -s).

# torcs: The Open Racing Car Simulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-l[local data directory]:dir:_files -/' \
  '-L[lib directory]:dir:_files -/' \
  '-d[data directory]:dir:_files -/' \
  '-s[disable sound]' && ret=0
return ret
