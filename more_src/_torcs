#compdef torcs
# Documentation: https://man.archlinux.org/search?q=torcs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-l+[localdir]:dir:_files -/' \
  '-L+[libdir]:dir:_files -/' \
  '-d+[datadir]:dir:_files -/' \
  '-B+[bindir]:dir:_files -/' \
  '-s+[no sound]' \
  '-T[no fps cap]' \
  '-m+[memory map]:mb:' \
  '-r+[results file]:file:_files' \
  '-R+[results dir]:dir:_files -/' \
  '-e+[events file]:file:_files' \
  '-t+[telemetry]:n:' && ret=0

return ret
