#compdef pktype pktogf
# Documentation: pktype --help / pktogf --help (TeX Live)
# Source: TeX pktype / pktogf — verify / translate PK bitmap fonts.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '-verbose[show progress reports (pktogf)]' \
    '1:PK font file:_files -g "*.pk"' \
    '2:output GF file (pktogf only):_files -g "*.gf"' \
    && ret=0

return ret
