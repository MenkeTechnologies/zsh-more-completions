#compdef sasa gmx-sasa
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-sasa.html
# Compute solvent accessible surface areas using the Eisenhaber algorithm

local ret=1

_arguments -s -S \
  '-f+[trajectory or configuration file]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-s+[structure file]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-n+[index groups]:index file:_files -g "*.ndx"' \
  '-o+[total area vs time]:xvg file:_files -g "*.xvg"' \
  '-odg+[solvation free energy vs time]:xvg file:_files -g "*.xvg"' \
  '-or+[average area per residue]:xvg file:_files -g "*.xvg"' \
  '-oa+[average area per atom]:xvg file:_files -g "*.xvg"' \
  '-tv+[volume and density vs time]:xvg file:_files -g "*.xvg"' \
  '-q+[PDB file for Connolly surface]:pdb file:_files -g "*.pdb"' \
  '-b+[starting frame time ps]:time:' \
  '-e+[ending frame time ps]:time:' \
  '-dt+[frame selection interval ps]:time:' \
  '-tu+[time unit]:unit:(fs ps ns us ms s)' \
  '-fgroup+[trajectory atom selection]:selection:' \
  '-surface+[surface calculation atoms]:selection:' \
  '-output+[additional output selections]:selection:' \
  '-sf+[selection file]:file:_files' \
  '-selrpos+[reference position type]:position:' \
  '-probe+[solvent probe radius nm]:value:' \
  '-ndots+[dots per sphere for accuracy]:n:' \
  '-dgs+[solvation energy per area]:value:' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-rmpbc[remove PBC artifacts]' \
  '-pbc[use periodic boundaries]' \
  '-prot[include protein in Connolly PDB]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
