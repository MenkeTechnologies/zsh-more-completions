#compdef rustlings

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize rustlings exercises'
      'run:run a specific exercise'
      'hint:show hint for an exercise'
      'list:list all exercises'
      'watch:watch for file changes and run exercises'
      'verify:verify all exercises in order'
      'reset:reset an exercise to its initial state'
      'done:mark an exercise as done'
    )
    _describe -t commands 'rustlings command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run|hint|reset|done)
        _arguments '1:exercise name' && ret=0
        ;;
      list)
        _arguments \
          '--paths[show exercise paths]' \
          '--names[show exercise names]' \
          '--unsolved[only show unsolved]' \
          '--solved[only show solved]' && ret=0
        ;;
    esac
    ;;
esac

return ret
