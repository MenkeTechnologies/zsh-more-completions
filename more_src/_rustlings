#compdef rustlings
# Documentation: https://github.com/rust-lang/rustlings
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (src/cli.rs clap definitions).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-editor[disable automatic opening of the current file in VS Code or Zellij]' \
  '--edit-cmd=[open the current exercise by running EDIT_CMD EXERCISE_PATH]:command' \
  '--manual-run[manually run the current exercise using `r` in watch mode]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize the official Rustlings exercises'
      'run:run a single exercise (next pending if name omitted)'
      'check-all:check all exercises, marking them as done or pending'
      'reset:reset a single exercise'
      'hint:show the hint for an exercise (next pending if name omitted)'
      'dev:commands for developing (community) Rustlings exercises'
    )
    _describe -t commands 'rustlings command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run|reset|hint)
        _arguments '1:exercise name' && ret=0
        ;;
    esac
    ;;
esac

return ret
