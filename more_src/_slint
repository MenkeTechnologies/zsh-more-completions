#compdef slint-viewer slint-lsp

local -a _slint_commands
_slint_commands=(
  'viewer:preview .slint files'
  'lsp:run language server'
)

case "$service" in
  slint-viewer)
    _arguments \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '--auto-reload[auto reload on change]' \
      '--backend[rendering backend]:backend:(winit qt)' \
      '--fullscreen[start in fullscreen]' \
      '(-I --include-path)'{-I,--include-path}'[include path]:dir:_directories' \
      '(-L --library-path)'{-L,--library-path}'[library path]:path' \
      '--style[style]:style:(fluent cupertino material cosmic)' \
      '--save-data[save data to file]:file:_files' \
      '--load-data[load data from file]:file:_files' \
      '--component[component to preview]:component' \
      '*:slint file:_files -g "*.slint"'
    ;;
  slint-lsp)
    _arguments \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '--backend[rendering backend]:backend:(winit qt)' \
      '(-I --include-path)'{-I,--include-path}'[include path]:dir:_directories' \
      '(-L --library-path)'{-L,--library-path}'[library path]:path' \
      '--style[style]:style:(fluent cupertino material cosmic)' \
      '--stdio[communicate via stdio]' \
      '--port[TCP port for LSP]:port'
    ;;
esac
