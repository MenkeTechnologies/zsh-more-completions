#compdef ibhca_self_test
# Documentation: https://man.archlinux.org/search?q=ibhca_self_test
# Reference accessed: 2026-05-16

# ibhca_self_test: self-test of an IB HCA (Mellanox OFED)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '*::ibhca_self_test args:_files' && ret=0
return ret
