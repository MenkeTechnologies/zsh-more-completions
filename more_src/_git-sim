#compdef git-sim

# Zsh completion for git-sim (visually simulate git operations)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--animate[animate the simulation]' \
  '--all[show all branches]' \
  '-n[number of commits to display]:count' \
  '--img-format[image format]:format:(jpg png)' \
  '--light-mode[use light color scheme]' \
  '--dark-mode[use dark color scheme]' \
  '--reverse[reverse commit order]' \
  '--speed[animation speed multiplier]:speed' \
  '--low-quality[lower quality for faster rendering]' \
  '--media-dir[output directory]:directory:_files -/' \
  '(-d --disable-auto-open)'{-d,--disable-auto-open}'[do not auto-open output]' \
  '--stdout[output to stdout]' \
  '--output-only-path[only print output path]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'log:simulate git log'
      'status:simulate git status'
      'add:simulate git add'
      'branch:simulate git branch'
      'checkout:simulate git checkout'
      'cherry-pick:simulate git cherry-pick'
      'clean:simulate git clean'
      'clone:simulate git clone'
      'commit:simulate git commit'
      'diff:simulate git diff'
      'fetch:simulate git fetch'
      'init:simulate git init'
      'merge:simulate git merge'
      'mv:simulate git mv'
      'pull:simulate git pull'
      'push:simulate git push'
      'rebase:simulate git rebase'
      'reset:simulate git reset'
      'restore:simulate git restore'
      'revert:simulate git revert'
      'rm:simulate git rm'
      'stash:simulate git stash'
      'switch:simulate git switch'
      'tag:simulate git tag'
    )
    _describe -t commands 'git-sim command' commands && ret=0
    ;;
esac

return ret
