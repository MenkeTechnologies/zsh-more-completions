#compdef mkbitmap
# Documentation: https://potrace.sourceforge.net/mkbitmap.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-l,--license}'[show license]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-x --nodefaults)'{-x,--nodefaults}'[turn off default filters]' \
  '(-i --invert)'{-i,--invert}'[invert colors]' \
  '(-f --filter)'{-f+,--filter=}'[filter size]:size' \
  '(-n --nofilter)'{-n,--nofilter}'[do not filter]' \
  '(-s --scale)'{-s+,--scale=}'[scale factor]:factor' \
  '(-3 --cubic -1 --linear)'{-3,--cubic}'[cubic interpolation]' \
  '(-1 --linear -3 --cubic)'{-1,--linear}'[linear interpolation]' \
  '(-b --blur)'{-b+,--blur=}'[Gaussian blur radius]:radius' \
  '(-t --threshold)'{-t+,--threshold=}'[threshold]:val' \
  '(-g --grey)'{-g,--grey}'[grey scale output]' \
  '*:file:_files' && ret=0

return ret
