#compdef yabai

_yabai() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-m --message)'{-m,--message}'[Send message]:domain:->domains' \
    '(-c --config)'{-c,--config}'[Config file]:file:_files' \
    '--install-sa[Install scripting addition]' \
    '--uninstall-sa[Uninstall scripting addition]' \
    '--load-sa[Load scripting addition]' \
    '--install-service[Install as service]' \
    '--uninstall-service[Uninstall service]' \
    '--start-service[Start service]' \
    '--restart-service[Restart service]' \
    '--stop-service[Stop service]' \
    '--check-sa[Check scripting addition]' \
    '--verbose[Verbose output]' \
    '--version[Print version]' \
    '--help[Show help]'

  case $state in
    domains)
      local -a domains=(
        'config:Configure settings'
        'display:Manage displays'
        'space:Manage spaces'
        'window:Manage windows'
        'query:Query info'
        'rule:Manage rules'
        'signal:Manage signals'
      )
      _describe 'domain' domains
      # Could add more detailed sub-completion per domain but the
      # message syntax is complex (e.g. --space 2 --toggle float)
      ;;
  esac
}

_yabai "$@"
