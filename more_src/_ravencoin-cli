#compdef ravencoin-cli
# _ravencoin-cli — Ravencoin Core ravencoin-cli JSON-RPC client CLI for the X16R-based asset-issuance fork of Bitcoin daemon issuing wallet getbalance sendtoaddress issue listassets transferfromaddress reissue listmyassets unlockoperations messaging rpc commands (RavenProject team, C++); custom argparse
# upstream: https://github.com/RavenProject/Ravencoin

_ravencoin-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf raven.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-named[use named JSON-RPC]' \
        '-rpcconnect=+[host]:h:_hosts' \
        '-rpcport=+[port]:n:' \
        '-rpcwait[wait for RPC server]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcclienttimeout=+[seconds]:n:' \
        '-rpccookiefile=+[file]:file:_files' \
        '-stdin[read input from stdin]' \
        '-stdinrpcpass[read RPC password from stdin]' \
        '-getinfo[print info]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getnetworkinfo getmempoolinfo getbalance listunspent listtransactions sendtoaddress getnewaddress validateaddress dumpprivkey importprivkey importwallet dumpwallet generate generatetoaddress getrawtransaction sendrawtransaction issue issueunique reissue transfer transferfromaddress listmyassets listassets listassetbalancesbyaddress getassetdata getassetbalances getassetstxids verifyrawtransaction lockunspents sendmessage subscribetochannel addtagtoaddress removetagfromaddress messagechannels)'
}

_ravencoin-cli "$@"
