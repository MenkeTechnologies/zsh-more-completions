#compdef gator
# _gatekeeper-cli — OPA Gatekeeper gator CLI (Open Policy Agent + CNCF, Go); test Gatekeeper constraint templates + constraints
# upstream: https://github.com/open-policy-agent/gatekeeper

_gatekeeper-cli() {
    local -a sub=(
        'test:test constraint templates + constraints against resources'
        'verify:run gator verify on rego policies'
        'expand:expand expansion templates'
        'sync:resync policies'
        'completion:print shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gator subcommand' sub ;;
        args)
            case $words[1] in
                test) _arguments \
                    '-f+[filename]:file:_files' \
                    '--filename+[filename]:file:_files' \
                    '--include-trace[include trace]' \
                    '--output+[output format]:fmt:(yaml json)' \
                    '-o+[output format]:fmt:' \
                    '*:file:_files' ;;
                verify) _arguments \
                    '-f+[filename]:file:_files' \
                    '--filename+[filename]:file:_files' \
                    '-r+[recursive]:bool:(true false)' \
                    '--run+[run regex]:regex:' \
                    '-v[verbose]' \
                    '--verbose[verbose]' \
                    '*:test file:_files' ;;
                expand) _arguments \
                    '-f+[filename]:file:_files' \
                    '--filename+[filename]:file:_files' \
                    '--format+[output format]:fmt:(yaml json)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_gatekeeper-cli "$@"
