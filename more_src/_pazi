#compdef pazi

_pazi_commands() {
  local -a commands=(
    'init:Print shell initialization script'
    'jump:Jump to a directory'
    'view:View frecency database'
    'edit:Edit frecency database'
    'import:Import from other tools'
    'help:Show help'
  )
  _describe 'command' commands
}

_pazi() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '1:command:_pazi_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        init)
          _arguments \
            '1:shell:(bash zsh fish)'
          ;;
        jump)
          _arguments \
            '--interactive[use interactive selection]' \
            '(-p --pipe)'{-p,--pipe}'[pipe mode]' \
            '*:pattern'
          ;;
        view)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        edit)
          _arguments \
            '--delete=[delete a path]:path:_directories' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        import)
          _arguments \
            '1:tool:(autojump fasd z)' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_pazi "$@"
