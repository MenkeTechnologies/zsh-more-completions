#compdef smime_keys
# Documentation: https://gitlab.com/muttmua/mutt/-/blob/master/smime_keys.pl
# Reference accessed: 2026-05-21
# Verified: upstream smime_keys.pl source at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize the .smime directory structure'
  'refresh:refresh certificate and key index files'
  'list:list certificates stored in database'
  'label:change/remove/add label for a keyID'
  'remove:remove a keypair by keyID'
  'verify:verify a certificate chain (and optionally CRL)'
  'add_cert:add a single certificate'
  'add_chain:add key + certificate + intermediate(s)'
  'add_p12:add a PKCS12 keypair'
  'add_pem:add a PEM keypair'
  'add_root:add a PEM root certificate'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'smime_keys subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (add_cert|add_root)
        _files -g "*.(pem|crt|cer)" && ret=0
        ;;
      (add_chain)
        _files -g "*.(pem|key|crt|cer)" && ret=0
        ;;
      (verify)
        _files -g "*.(pem|crt|cer)" && ret=0
        ;;
      (add_p12)
        _files -g "*.(p12|pfx)" && ret=0
        ;;
      (add_pem)
        _files -g "*.pem" && ret=0
        ;;
    esac
    ;;
esac

return ret
