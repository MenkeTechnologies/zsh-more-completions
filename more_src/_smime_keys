#compdef smime_keys

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize the .smime certificate database'
  'list:list certificates'
  'label:set a certificate label'
  'remove:remove a certificate'
  'verify:verify a certificate'
  'add_cert:add a single certificate'
  'add_chain:add a certificate chain'
  'add_p12:add a PKCS12 keypair'
  'add_pem:add a PEM keypair'
  'add_root:add a CA root certificate'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'smime_keys subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (add_cert|add_chain|add_root|verify)
        _files -g "*.(pem|crt|cer)" && ret=0
        ;;
      (add_p12)
        _files -g "*.(p12|pfx)" && ret=0
        ;;
      (add_pem)
        _files -g "*.pem" && ret=0
        ;;
    esac
    ;;
esac

return ret
