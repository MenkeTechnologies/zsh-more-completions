# WHAT IT IS
#   outsmart is "the Solana trading command-line interface — 18
#   DEX adapters, 12 TX landing providers, one unified interface".
#   It abstracts the heterogeneous landscape of Solana DEXes
#   (Raydium AMM v4 / CPMM / CLMM / LaunchLab, Meteora DAMM v1/v2
#   + DLMM + DBC, Orca, Byreal CLMM, PancakeSwap CLMM, Fusion AMM,
#   Futarchy AMM + Launchpad, Pump.fun + Pump.fun-AMM, Jupiter
#   Ultra, DFlow) behind a single `outsmart buy / sell / quote /
#   find-pool / add-liq / remove-liq / claim-fees / positions`
#   surface, with secondary command groups for token creation
#   (`create-pump-coin`, `create-pool`, `create-damm-pool`,
#   `create-damm-config-pool`), discovery (`list-dex`), wallet
#   management (`wallet list/add/switch/remove`), balance
#   reporting (`balance`), perpetuals trading (`perp long/short/
#   close/status/deposit/withdraw/init-user/create-market/crank/
#   set-price/markets/keeper`), and configuration
#   (`config show/env/init`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/cli.ts — Commander
#                       v12 with `new Command()`, addCommand,
#                       requiredOption, option chains)
#   outsmart <SUBCOMMAND> [args...]
#
#   Trading subcommands:
#     buy                            Buy a token via a DEX adapter
#       -d, --dex <NAME>               DEX adapter name (required)
#                                      (e.g. raydium-cpmm,
#                                      jupiter-ultra, meteora-dlmm)
#       -a, --amount <SOL>             Amount of SOL to spend
#                                      (required)
#       -p, --pool <ADDR>              Pool address (required for
#                                      on-chain DEXes)
#       -t, --token <MINT>             Token mint address to buy
#                                      (required for aggregators)
#       --slippage <BPS>               Slippage in basis points
#       --priority <UL>                Priority fee in micro-
#                                      lamports per CU
#       --cu <UNITS>                   Compute unit limit
#       --jito                         Use Jito bundle submission
#       --strategy <MODE>              TX landing strategy
#                                      (concurrent|race|random|
#                                      sequential)
#       --quote <MINT>                 Quote token mint
#                                      [default: WSOL]
#       --dry-run                      Simulate without sending
#
#     sell                           Sell a token via a DEX adapter
#       (same options as buy, but with --pct instead of --amount)
#       --pct <PERCENTAGE>             Percentage of held balance
#                                      to sell (0-100) [required]
#
#     quote                          Get a price quote for a pool
#       -d, --dex <NAME>               DEX adapter (required)
#       -p, --pool <ADDR>              Pool address (required)
#
#     find-pool                      Find a pool by token mint
#       -d, --dex <NAME>               DEX adapter (required)
#       -t, --token <MINT>             Base token mint (required)
#       --quote <MINT>                 Quote token [default: WSOL]
#
#   Liquidity subcommands:
#     add-liq                        Deposit liquidity into a pool
#       -d, --dex <NAME>               DEX adapter (required)
#       -p, --pool <ADDR>              Pool address (required)
#       --amount-sol <AMT>             SOL deposit amount
#       --amount-token <AMT>           Non-SOL token deposit amount
#       -t, --token <MINT>             Token mint
#       --strategy <TYPE>              Distribution (spot|curve|
#                                      bid-ask) [default: spot]
#       --bins <COUNT>                 Bin count (default 50, max 70)
#       --slippage <BPS> / --priority <UL> / --tip <SOL>
#
#     remove-liq                     Remove liquidity
#       -d, --dex <NAME>               DEX adapter (required)
#       -p, --pool <ADDR>              Pool address (required)
#       --pct <PERCENTAGE>             Position percentage (0-100)
#                                      (required)
#       --position <ADDR>              Specific position address
#
#     claim-fees                     Claim accrued LP fees
#     positions                      List held positions
#
#   Token-creation subcommands:
#     create-pump-coin               Create a Pump.fun token
#       --name <NAME>                  Token name (required)
#       --symbol <SYM>                 Token symbol (required)
#       --uri <URI>                    Metadata URI (required)
#     create-pool                    Create a new on-chain pool
#       --base <MINT>                  Base token mint (required)
#       --quote <MINT>                 Quote token mint (required)
#       --base-amount <AMT>            Base initial deposit
#                                      (required)
#       --quote-amount <AMT>           Quote initial deposit
#                                      (required)
#     create-damm-pool               Create a Meteora DAMM pool
#     create-damm-config-pool        Create a Meteora DAMM pool
#                                    from a config
#
#   Discovery / utility subcommands:
#     list-dex                       List registered DEX adapters
#       --cap <NAME>                   Filter by capability (e.g.
#                                      canBuy, canSell, canAddLiq)
#     init                           Initialize a new outsmart
#                                    config
#
#   Wallet management:
#     wallet list                    List wallet labels
#     wallet add                     Add a wallet
#     wallet switch <LABEL>          Switch to a wallet
#     wallet remove <LABEL>          Remove a wallet
#     balance                        Show wallet balances
#
#   Configuration:
#     config show                    Show resolved config
#     config env                     Show env-variable state
#     config init                    Scaffold a config file
#
#   Perpetuals (perp <SUBCOMMAND>):
#     perp long / short / close / status / deposit / withdraw /
#     perp init-user / create-market / crank / set-price /
#     perp markets / keeper
#
#   Standard commander auto-flags:
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `@solana/web3.js ^1.95.0` (the canonical
#   Node.js Solana SDK maintained by anza-xyz / Solana Labs) AND
#   `@solana/kit ^6.1.0` (the @solana/web3.js v2 / Kit rewrite),
#   plus `@solana/spl-token ^0.4.0`, `@solana-program/token
#   ^0.11.0`, `@solana-program/token-2022 ^0.9.0`, and
#   `@solana-program/memo ^0.11.0` declared in package.json —
#   `@solana/web3.js` is THE Node.js Solana SDK:  it exports
#   `Connection`, `PublicKey`, `Keypair`, `Transaction`,
#   `VersionedTransaction`, `TransactionMessage`, `Instruction`,
#   `SystemProgram`, the RPC HTTP + WebSocket subscription client,
#   the address-lookup-table account fetcher, the compute-budget-
#   program builder, the loader-v3 deployment helper, and every
#   typed message-encoding helper for the SPL Token / Token-2022
#   / Memo programs.  outsmart's `src/dex/*.ts` adapters each
#   construct a `Connection` against a configured RPC, build
#   typed instructions through the registry, and submit
#   `VersionedTransaction` bundles via 12 different TX landing
#   providers.  Verified via:
#     gh api repos/outsmartchad/outsmart-cli/contents/package.json
#       → "@solana/web3.js": "^1.95.0"
#       → "@solana/kit": "^6.1.0"
#       → "@solana/spl-token": "^0.4.0"
#       → "@solana-program/token": "^0.11.0"
#       → "@solana-program/memo": "^0.11.0"
#       → "@solana-program/token-2022": "^0.9.0"
#       → "bin": {"outsmart": "./dist/cli.js"}
#     gh api repos/outsmartchad/outsmart-cli/contents/src/cli.ts
#       → const program = new Command();
#         program.addCommand(buyCmd|sellCmd|walletCmd|balanceCmd|
#                             configCmd|perpCmd) + 12 inline
#                             .command() registrations
#   This entry is the TS-Node=141 leader bump that CLOSES Axis 86
#   (Solana SDK Library) at 1/1/1 three-language symmetry —
#   pairing Rust=solana-sdk via solana-foundation/kora (R933
#   _kora), Go=gagliardetto/solana-go via SOL-Strategies/solana-
#   validator-failover (R934 _solana-validator-failover), and
#   TS-Node=@solana/web3.js via outsmartchad/outsmart-cli (this
#   entry).  Triple-141 landmark on commit.  Axis 86 = 79th axis
#   closed.
#
#   No completion for `outsmart` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_outsmart() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_outsmart_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                buy|sell)
                    _arguments \
                        '(-d --dex)'{-d,--dex}'=[DEX adapter name]:adapter:_outsmart_dex_adapters' \
                        '(-a --amount)'{-a,--amount}'=[amount of SOL to spend (buy only)]:sol:' \
                        '--pct=[percentage to sell (0-100, sell only)]:pct:' \
                        '(-p --pool)'{-p,--pool}'=[pool address (on-chain DEXes)]:addr:' \
                        '(-t --token)'{-t,--token}'=[token mint to buy/sell]:mint:' \
                        '--slippage=[slippage in basis points]:bps:' \
                        '--priority=[priority fee in micro-lamports per CU]:ul:' \
                        '--cu=[compute unit limit]:units:' \
                        '--jito[use Jito bundle submission]' \
                        '--strategy=[TX landing strategy]:mode:(concurrent race random sequential)' \
                        '--quote=[quote token mint (default WSOL)]:mint:' \
                        '--dry-run[simulate without sending]' && ret=0 ;;
                quote)
                    _arguments \
                        '(-d --dex)'{-d,--dex}'=[DEX adapter]:adapter:_outsmart_dex_adapters' \
                        '(-p --pool)'{-p,--pool}'=[pool address]:addr:' && ret=0 ;;
                find-pool)
                    _arguments \
                        '(-d --dex)'{-d,--dex}'=[DEX adapter]:adapter:_outsmart_dex_adapters' \
                        '(-t --token)'{-t,--token}'=[base token mint]:mint:' \
                        '--quote=[quote token (default WSOL)]:mint:' && ret=0 ;;
                add-liq)
                    _arguments \
                        '(-d --dex)'{-d,--dex}'=[DEX adapter]:adapter:_outsmart_dex_adapters' \
                        '(-p --pool)'{-p,--pool}'=[pool address]:addr:' \
                        '--amount-sol=[SOL deposit]:amount:' \
                        '--amount-token=[non-SOL token deposit]:amount:' \
                        '(-t --token)'{-t,--token}'=[token mint]:mint:' \
                        '--strategy=[distribution]:type:(spot curve bid-ask)' \
                        '--bins=[bin count (max 70)]:count:' \
                        '--slippage=[slippage bps]:bps:' \
                        '--priority=[priority fee]:ul:' \
                        '--tip=[MEV tip in SOL]:sol:' && ret=0 ;;
                remove-liq)
                    _arguments \
                        '(-d --dex)'{-d,--dex}'=[DEX adapter]:adapter:_outsmart_dex_adapters' \
                        '(-p --pool)'{-p,--pool}'=[pool address]:addr:' \
                        '--pct=[position percentage to remove (0-100)]:pct:' \
                        '--position=[specific position address]:addr:' \
                        '--slippage=[slippage bps]:bps:' \
                        '--priority=[priority fee]:ul:' \
                        '--tip=[MEV tip in SOL]:sol:' && ret=0 ;;
                claim-fees|positions)
                    _arguments \
                        '(-d --dex)'{-d,--dex}'=[DEX adapter]:adapter:_outsmart_dex_adapters' \
                        '(-p --pool)'{-p,--pool}'=[pool address]:addr:' \
                        '--position=[specific position]:addr:' \
                        '--json[output as JSON]' && ret=0 ;;
                create-pump-coin)
                    _arguments \
                        '--name=[token name]:name:' \
                        '--symbol=[token symbol]:symbol:' \
                        '--uri=[metadata URI]:uri:' && ret=0 ;;
                create-pool|create-damm-pool|create-damm-config-pool)
                    _arguments \
                        '--base=[base token mint]:mint:' \
                        '--quote=[quote token mint]:mint:' \
                        '--base-amount=[base initial deposit]:amount:' \
                        '--quote-amount=[quote initial deposit]:amount:' && ret=0 ;;
                list-dex)
                    _arguments \
                        '--cap=[filter by capability]:cap:(canBuy canSell canAddLiq canRemoveLiq canClaimFees canCreatePool)' && ret=0 ;;
                wallet)
                    _arguments \
                        '1:wallet subcommand:(list add switch remove)' \
                        '*::arg:' && ret=0 ;;
                config)
                    _arguments \
                        '1:config subcommand:(show env init)' \
                        '*::arg:' && ret=0 ;;
                perp)
                    _arguments \
                        '1:perp subcommand:(long short close status deposit withdraw init-user create-market crank set-price markets keeper)' \
                        '*::arg:' && ret=0 ;;
                init|balance)
                    _arguments && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_outsmart_commands] )) ||
_outsmart_commands() {
    local -a commands
    commands=(
        'buy:buy a token via a DEX adapter'
        'sell:sell a token via a DEX adapter'
        'quote:get a price quote for a pool'
        'find-pool:find a pool by token mint'
        'add-liq:deposit liquidity into a pool'
        'remove-liq:remove liquidity from a position'
        'claim-fees:claim accrued LP fees'
        'positions:list held positions'
        'create-pump-coin:create a Pump.fun token'
        'create-pool:create a new on-chain pool'
        'create-damm-pool:create a Meteora DAMM pool'
        'create-damm-config-pool:create a Meteora DAMM pool from a config'
        'list-dex:list registered DEX adapters'
        'init:initialize a new outsmart config'
        'wallet:wallet management (list/add/switch/remove)'
        'balance:show wallet balances'
        'config:configuration (show/env/init)'
        'perp:perpetuals trading'
    )
    _describe -t commands 'outsmart command' commands
}

(( $+functions[_outsmart_dex_adapters] )) ||
_outsmart_dex_adapters() {
    local -a adapters
    adapters=(
        raydium-amm-v4 raydium-cpmm raydium-clmm raydium-launchlab
        meteora-damm-v1 meteora-damm-v2 meteora-dlmm meteora-dbc
        orca byreal-clmm pancakeswap-clmm fusion-amm
        futarchy-amm futarchy-launchpad
        pumpfun pumpfun-amm jupiter-ultra dflow
    )
    _describe -t adapters 'DEX adapter' adapters
}

_outsmart "$@"
