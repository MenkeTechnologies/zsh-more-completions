#compdef tio

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --baudrate)'{-b,--baudrate}'[set baud rate]:baud rate:(1200 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600)' \
  '(-d --databits)'{-d,--databits}'[set data bits]:data bits:(5 6 7 8)' \
  '(-f --flow)'{-f,--flow}'[set flow control]:flow:(none hard soft)' \
  '(-s --stopbits)'{-s,--stopbits}'[set stop bits]:stop bits:(1 2)' \
  '(-p --parity)'{-p,--parity}'[set parity]:parity:(none odd even mark space)' \
  '(-o --output-delay)'{-o,--output-delay}'[set output delay in ms]:delay' \
  '(-n --no-autoconnect)'{-n,--no-autoconnect}'[disable automatic connect]' \
  '(-e --local-echo)'{-e,--local-echo}'[enable local echo]' \
  '(-t --timestamp)'{-t,--timestamp}'[enable timestamps]' \
  '--timestamp-format=[set timestamp format]:format' \
  '(-l --log)'{-l,--log}'[enable logging]' \
  '--log-file=[set log file path]:file:_files' \
  '--log-append[append to log file]' \
  '--log-strip[strip escape sequences from log]' \
  '(-m --map)'{-m,--map}'[set character mapping]:map' \
  '(-c --color)'{-c,--color}'[colorize tio text]:color:(none bold 0-255)' \
  '(-S --socket)'{-S,--socket}'[set socket for scripting]:socket:_files' \
  '--rs485[enable RS-485 mode]' \
  '--rs485-config=[RS-485 configuration]:config' \
  '--alert=[set alert type]:alert:(none bell blink)' \
  '--mute[mute tio]' \
  '--script=[run script]:script:_files' \
  '--script-file=[run script from file]:script file:_files' \
  '--script-run=[when to run script]:when:(once always)' \
  '--input-mode=[set input mode]:mode:(normal hex line)' \
  '--output-mode=[set output mode]:mode:(normal hex)' \
  '--line-pulse-duration=[set line pulse duration in ms]:duration' \
  '--response-wait[wait for response]' \
  '--response-timeout=[response timeout in ms]:timeout' \
  '1:device:_files -g "/dev/tty*"' && ret=0

return ret
