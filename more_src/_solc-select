#compdef solc-select
# Documentation: https://man.archlinux.org/search?q=solc-select
# Reference accessed: 2026-05-16

_solc_select() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '(-h --help)'{-h,--help}'[Show help message and exit]'
    )

    subcmds=(
        'install:Install a specific version of solc'
        'use:Set the global solc version'
        'versions:List all installed versions'
        'uninstall:Remove a specific installed version'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'solc-select commands' subcmds
            ;;
        args)
            case $line[1] in
                use)
                    _arguments \
                        '--always-install[Install the version if it is not already present]' \
                        '1:version:'
                    ;;
                install|uninstall)
                    _arguments \
                        '1:version:'
                    ;;
            esac
            ;;
    esac
}

_solc_select "$@"
