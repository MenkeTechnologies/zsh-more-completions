#compdef nixpacks

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'build:build an image from source'
      'plan:generate a build plan'
      'detect:detect project type'
    )
    _describe -t commands 'nixpacks command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      build)
        _arguments -s -S \
          '--name[name for the build]:name' \
          '(-o --out)'{-o,--out}'[output directory]:directory:_files -/' \
          '--config[config file]:config file:_files' \
          '--pkgs[additional Nix packages]:packages' \
          '--apt[additional apt packages]:packages' \
          '--libs[additional libraries]:libraries' \
          '--install-cmd[custom install command]:command' \
          '--build-cmd[custom build command]:command' \
          '--start-cmd[custom start command]:command' \
          '*--env[set environment variable]:VAR=VALUE' \
          '(-t --tag)'{-t,--tag}'[image tag]:tag' \
          '*--label[set image label]:LABEL=VALUE' \
          '--platform[target platform]:platform' \
          '--cache-key[cache key]:key' \
          '--no-cache[disable build cache]' \
          '--inline-cache[enable inline cache]' \
          '--current-dir[use current directory]' \
          '--no-error-without-start[do not error if no start command found]' \
          '--incremental-cache-image[incremental cache image]:image' \
          '--cpu[CPU limit]:cpus' \
          '--memory[memory limit]:memory' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '1:path:_files -/' && ret=0
        ;;
      plan|detect)
        _arguments -s -S \
          '1:path:_files -/' && ret=0
        ;;
    esac
    ;;
esac
return ret
