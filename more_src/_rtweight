#compdef rtweight
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=rtweight&sektion=1
# BRL-CAD mass/volume/centroid computation via raytracing

local ret=1

_arguments -s \
  '-s[rays to fire in X and Y (square grid)]:size' \
  '-g[ray spacing in X and Y, millimeters]:spacing' \
  '-a[select azimuth in degrees]:azimuth' \
  '-e[select elevation in degrees]:elevation' \
  '-d[read density information from file]:density file:_files' \
  '-M[read model2view matrix from stdin]' \
  '-r[report individual region weights]' \
  '-o[send output to file]:output:_files' \
  '-P[max number of processors]:cpus' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
