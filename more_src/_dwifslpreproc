#compdef dwifslpreproc
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwifslpreproc.html
# Source: MRtrix3/mrtrix3 bin/dwifslpreproc — DWI pre-processing via FSL eddy/topup (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-pe_dir+[phase encoding direction]:PE:_default' \
    '-readout_time+[total readout time in seconds]:time:_default' \
    '-se_epi+[additional SE-EPI series for topup]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-align_seepi[align SE-EPI with DWI series]' \
    '-json_import+[import header from JSON]:file:_files -g "*.json"' \
    '-topup_options+[extra topup options]:options:_default' \
    '-eddy_options+[extra eddy options]:options:_default' \
    '-eddy_mask+[processing mask for eddy]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-eddy_slspec+[slice-grouping file for eddy slice-to-volume]:file:_files' \
    '-eddyqc_text+[directory for eddy text outputs]:directory:_files -/' \
    '-eddyqc_all+[directory for ALL eddy outputs]:directory:_files -/' \
    '(-rpe_pair -rpe_all -rpe_header)-rpe_none[no reversed PE; only motion+eddy correction]' \
    '(-rpe_none -rpe_all -rpe_header)-rpe_pair[reversed-PE b=0 pair via -se_epi]' \
    '(-rpe_none -rpe_pair -rpe_header)-rpe_all[full opposing PE DWI series]' \
    '(-rpe_none -rpe_pair -rpe_all)-rpe_header[PE info from image header]' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '-export_grad_mrtrix+[export MRtrix-format gradient table]:file:_files' \
    '-export_grad_fsl+[export FSL bvecs bvals]:files:_files' \
    '-scratch+[scratch directory]:dir:_files -/' \
    '-continue+[continue from a previous scratch dir]:dir:_files -/' \
    '-nocleanup[do not clean up scratch directory]' \
    '-nthreads+[number of threads]:n:_default' \
    '1:input DWI:_files -g "*.{nii,nii.gz,mif}"' \
    '2:output DWI:_files' \
    && ret=0

return ret
