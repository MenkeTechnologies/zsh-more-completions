#compdef nupipeline
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/nupipeline.html
# NuSTAR data analysis pipeline: calibrate, screen and extract products

local ret=1

_arguments -s -S \
  'indir=[input L1 archive directory]:indir:_files -/' \
  'steminputs=[base filename stem for input files]:steminputs:' \
  'outdir=[output directory]:outdir:_files -/' \
  'instrument=[focal plane module]:instrument:(ALL FPMA FPMB)' \
  'entrystage=[processing start stage]:entrystage:(1 2)' \
  'exitstage=[processing end stage]:exitstage:(1 2 3)' \
  'stemoutputs=[output filename stem, DEFAULT for input stem]:stemoutputs:' \
  'obsmode=[observing mode filter]:obsmode:(SCIENCE OCCULTATION SLEW SAA CALIBRATION SCIENCE_SC ALL)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'cleanup=[delete temporary files]:cleanup:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  '*:file:_files' && ret=0

return ret
