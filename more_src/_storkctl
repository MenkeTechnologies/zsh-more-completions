#compdef storkctl
# Documentation: https://github.com/libopenstorage/stork/tree/master/cmd/storkctl
# storkctl - CLI for Stork Storage Orchestration Runtime for Kubernetes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace' \
  '--context=[name of the kubeconfig context to use]:context' \
  '--kubeconfig=[path to the kubeconfig file to use]:file:_files' \
  '--all-namespaces[list requested object(s) across all namespaces]' \
  '*:command:(activate deactivate create delete get generate perform suspend resume version action actionstatus migration migrationschedule applicationbackup applicationbackupschedule applicationrestore applicationclone applicationregistration backuplocation clusterpair groupsnapshot snapshot snapshotschedule schedulepolicy pvc)' && ret=0

return ret
