#compdef siesta tssiesta tssiesta-cli
# _siesta — SIESTA collaboration siesta efficient self-consistent DFT plane-wave with localized atomic orbitals (siesta-project team, Fortran); custom argparse
# upstream: https://gitlab.com/siesta-project/siesta

_siesta() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-V[verbose]' \
        '--verbose[verbose]' \
        '-d[run dryrun pre-flight]' \
        '--dryrun[run dryrun pre-flight]' \
        '-out+[output file]:file:_files -g "*.out"' \
        '--output=+[output file]:file:_files -g "*.out"' \
        '-fdf+[fdf input file]:file:_files -g "*.fdf"' \
        '--fdf=+[fdf input file]:file:_files -g "*.fdf"' \
        '-electrode[run as electrode for TranSIESTA]' \
        '--electrode[run as electrode for TranSIESTA]' \
        '-fdf-only[only fdf parse]' \
        '-noOpenMP[disable OpenMP]' \
        '-OpenMP=+[N]:n:' \
        '-restart=+[restart file]:file:_files' \
        '-system_label=+[label]:str:' \
        '-iolimit=+[MB]:n:' \
        '*:input fdf:_files -g "*.fdf"'
}

_siesta "$@"
