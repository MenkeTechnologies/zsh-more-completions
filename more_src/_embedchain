#compdef embedchain ec mem0 mem0-cli
# _embedchain — Mem0 AI embedchain framework for creating LLM bots over your own dataset rebranded Mem0 memory layer (mem0ai team, Python); argparse
# upstream: https://github.com/mem0ai/mem0

_embedchain() {
    local -a sub=(
        'add:add a data source'
        'query:query the knowledge base'
        'chat:chat session'
        'reset:reset the database'
        'serve:run as web server'
        'export:export to file'
        'import:import from file'
        'config:configuration subcommands'
        'memory:memory subcommands'
        'history:show conversation history'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--app-id=+[app id]:str:' \
        '--user-id=+[user id]:str:' \
        '--agent-id=+[agent id]:str:' \
        '--api-key=+[API key]:str:' \
        '--collection=+[collection name]:str:' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'embedchain subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '--source-type=+[type]:t:(text url pdf youtube docx html json csv mdx web mysql postgres sqlite drupal discord discourse docusaurus google_drive image notion github gitbook beehiiv directory openapi sitemap web_page text_to_speech)' \
                    '*:source:_files' ;;
                query|chat) _arguments \
                    '--user-id=+[user id]:str:' \
                    '--agent-id=+[agent id]:str:' \
                    '--app-id=+[app id]:str:' \
                    '--temperature=+[F]:f:' \
                    '--max-tokens=+[N]:n:' \
                    '--stream[stream output]' \
                    '*:query:' ;;
                serve) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--workers=+[N]:n:' ;;
                export|import) _arguments '*:file:_files' ;;
                memory) _arguments '1:memory cmd:(add get search update delete history get-all)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_embedchain "$@"
