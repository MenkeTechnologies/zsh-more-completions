#compdef icoFoam

# OpenFOAM icoFoam: transient laminar incompressible PISO solver
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-doc[browse online documentation]' \
  '-srcDoc[browse source documentation]' \
  '-case[case directory]:dir:_files -/' \
  '-region[mesh region]:region:' \
  '-decomposeParDict[decomposition dictionary]:file:_files' \
  '-fileHandler[file handler]:handler:(uncollated collated masterUncollated)' \
  '-listFunctionObjects[list function objects]' \
  '-listFvOptions[list fvOptions]' \
  '-listSwitches[list switches]' \
  '-listTurbulenceModels[list turbulence models]' \
  '-listScalarBCs[list scalar BCs]' \
  '-listVectorBCs[list vector BCs]' \
  '-listUnsetSwitches[list unset switches]' \
  '-listRegisteredSwitches[list registered switches]' \
  '-noFunctionObjects[disable function objects]' \
  '-parallel[run in parallel]' \
  '-postProcess[post-process previous time steps]' \
  '*::case args:_files' && ret=0
return ret
