#compdef logseq
# Documentation: https://man.archlinux.org/search?q=logseq
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-sandbox[disable Chromium sandbox]' \
  '--disable-gpu[disable GPU acceleration]' \
  '--user-data-dir=[user data directory]:dir:_files -/' \
  '--ozone-platform=[Ozone platform]:platform:(wayland x11 auto)' \
  '--password-store=[secret store]:store:(basic gnome-libsecret kwallet5 kwallet6)' \
  '*:graph_dir:_files -/' && ret=0

return ret
