#compdef dvitomp
# Documentation: dvitomp --help (TeX Live 2026)
# Source: convert a TeX DVI file to a MetaPost MPX file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-progname=[set program name to STRING]:name:' \
    '-kpathsea-debug=[set path searching debugging flags]:number:' \
    '1:dvi file:_files -g "*.dvi"' \
    '2:mpx output:_files -g "*.mpx"' \
    && ret=0

return ret
