#compdef createuser
# Documentation: https://www.postgresql.org/docs/current/app-createuser.html
# Source: postgres/postgres src/bin/scripts/createuser.c — create a new PostgreSQL role (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-\?,--help}'[show help]' \
    {-a+,--with-admin=}'[grant admin option to role]:role:_default' \
    {-c+,--connection-limit=}'[connection limit]:n:_default' \
    {-d,--createdb}'[role can create databases]' \
    {-D,--no-createdb}'[role cannot create databases]' \
    {-e,--echo}'[show SQL commands]' \
    {-E,--encrypted}'[encrypt stored password (deprecated)]' \
    '*'{-g+,--role=,--member-of=}'[member of role]:role:_default' \
    {-h+,--host=}'[server host]:host:_hosts' \
    {-i,--inherit}'[role inherits privileges]' \
    {-I,--no-inherit}'[role does not inherit privileges]' \
    {-l,--login}'[role can log in]' \
    {-L,--no-login}'[role cannot log in]' \
    '*'{-m+,--with-member=}'[add role as a member]:role:_default' \
    {-p+,--port=}'[server port]:port:_default' \
    {-P,--pwprompt}'[prompt for password]' \
    {-r,--createrole}'[role can create roles]' \
    {-R,--no-createrole}'[role cannot create roles]' \
    {-s,--superuser}'[role is superuser]' \
    {-S,--no-superuser}'[role is not superuser]' \
    {-U+,--username=}'[connect as user]:user:_users' \
    {-v+,--valid-until=}'[password valid until]:timestamp:_default' \
    {-w,--no-password}'[never prompt for password]' \
    {-W,--password}'[force password prompt]' \
    '--replication[role has replication privilege]' \
    '--no-replication[role has no replication privilege]' \
    '--interactive[prompt for missing info]' \
    '--bypassrls[bypass row-level security]' \
    '--no-bypassrls[do not bypass RLS]' \
    '1::role name:_default' \
    && ret=0

return ret
