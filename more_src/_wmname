#compdef wmname
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wmname.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. wmname only documents -v.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-v[show version]' \
  '1:WM name (omit to print current):(LG3D Sawfish KWin Mutter Xfwm4 i3 awesome bspwm dwm openbox xmonad fluxbox icewm jwm metacity Marco Compiz "Window Maker")' && ret=0

return ret
