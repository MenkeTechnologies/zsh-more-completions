#compdef wmname
# Documentation: https://man.archlinux.org/search?q=wmname
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-v[show version]' \
  '1:WM name (omit to print current):(LG3D Sawfish KWin Mutter Xfwm4 i3 awesome bspwm dwm openbox xmonad fluxbox icewm jwm metacity Marco Compiz "Window Maker")' && ret=0

return ret
