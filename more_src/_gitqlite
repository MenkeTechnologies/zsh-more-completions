#compdef gitqlite
# Documentation: https://github.com/OutOfBrain/gitqlite
# Source: OutOfBrain/gitqlite — Go SQL queries over git via SQLite virtual tables and go-git.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--repo=[alternate repository path or remote URL]:repo:_default' \
    '--format=[output format]:format:(ascii json csv)' \
    '(- *)-h[show help]' \
    '*:SQL query:_default' \
    && ret=0

return ret
