#compdef pcp-ipcs

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-i+[print info]:id:' \
  '-m[show shared memory]' \
  '-q[show message queues]' \
  '-s[show semaphores]' \
  '-a[show all]' \
  '-t[show times]' \
  '-p[show pids]' \
  '-c[show creator info]' \
  '-l[show limits]' \
  '-u[show usage]' \
  '-z+[zone]:tz:' \
  '-O+[origin]:time:' \
  '-a-host+[host]:host:_hosts' && ret=0

return ret
