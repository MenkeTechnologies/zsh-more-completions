#compdef h5sign
# Documentation: https://github.com/HDFGroup/hdf5
# Source: HDFGroup/hdf5 tools/src/h5sign/h5sign.c — sign HDF5 plugin binary with RSA (getopt_long, C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    {-V,--version}'[show version]' \
    {-p,--plugin}'+[plugin binary to sign]:file:_files -g "*.{so,dll,dylib}"' \
    {-k,--key}'+[RSA private key in PEM format]:file:_files -g "*.pem"' \
    {-a,--algorithm}'+[hash algorithm]:alg:(sha256 sha384 sha512 sha256-pss sha384-pss sha512-pss)' \
    {-f,--force}'[re-sign already-signed plugin]' \
    {-v,--verbose}'[verbose output]' \
    && ret=0

return ret
