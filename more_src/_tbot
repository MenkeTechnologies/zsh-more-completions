#compdef tbot

# tbot: Teleport identity agent / machine-id
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'start:start tbot agent'
  'configure:write a config file'
  'init:initialize destination'
  'install:install (systemd etc.)'
  'migrate:migrate config'
  'identity-cmd:identity commands'
  'kube:kube credentials'
  'db:database credentials'
  'tsh:proxy tsh commands'
  'tctl:proxy tctl commands'
  'version:show version'
  'completion:emit shell completion'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-d[debug logging]' \
  '--debug[debug logging]' \
  '--log-format=[log format]:fmt:(text json)' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '--auth-server=[auth server]:host:_hosts' \
  '--token=[invite token]:token:' \
  '--ca-pin=[CA pin]:pin:' \
  '--data-dir=[data dir]:dir:_files -/' \
  '--destination-dir=[destination dir]:dir:_files -/' \
  '--certificate-ttl=[cert TTL]:duration:' \
  '--renewal-interval=[renewal interval]:duration:' \
  '--join-method=[join method]:method:(token iam gcp github gitlab circleci kubernetes spacelift ec2 azure tpm)' \
  '--oneshot[run once and exit]' \
  '--insecure[skip TLS verify]' \
  '--diag-addr=[diagnostic addr]:host:' \
  '--fips[enable FIPS]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'tbot command' commands && ret=0 ;;
esac
return ret
