#compdef coot
# Documentation: https://manpages.ubuntu.com/manpages/questing/man1/coot.1.html
# Coot - model building for macromolecular crystallography

local ret=1

_arguments -s -S \
  '(- *)--help[display command line options and exit]' \
  '(- *)--detailed-help[show help with all details and hidden options]' \
  '(- *)--full-help[display help including hidden options]' \
  '(- *)--version[show version information]' \
  '(- *)--version-full[output detailed version specifics]' \
  '(-p --pdb --coords --xyzin)'{-p,--pdb}'[load PDB, SHELX .ins/.res or CIF coordinates]:coordinates file:_files' \
  '(-p --pdb --coords --xyzin)--coords[load coordinates (alias of --pdb)]:coordinates file:_files' \
  '--xyzin[load coordinates (alias of --pdb)]:coordinates file:_files' \
  '(-m --map)'{-m,--map}'[read CCP4-format electron density map]:map file:_files' \
  '(-d --data --hklin)'{-d,--data}'[load MTZ, PHS or mmCIF reflection data]:data file:_files' \
  '--hklin[load reflection data (alias of --data)]:data file:_files' \
  '(-a --auto)'{-a,--auto}'[auto-read MTZ with default column labels]:mtz file:_files' \
  '--code[fetch PDB and MTZ from Electron Density Server]:PDB ident:' \
  '--dictionary[load CIF monomer dictionary]:dictionary file:_files' \
  '(-s --script)'{-s,--script}'[execute script at startup]:script file:_files -g "*.(scm|py)"' \
  '(-c --command)'{-c,--command}'[run command on startup]:command:' \
  '--python[process -c arguments as Python]' \
  '--ccp4-project[define CCP4 project directory]:directory:_files -/' \
  '--directory[set working directory]:directory:_files -/' \
  '--no-state-script[skip state file execution]' \
  '--state-script[load state file without dialog prompt]' \
  '--no-graphics[run without graphics interface]' \
  '--no-guano[omit state/history file creation]' \
  '--no-splash-screen[skip splash screen display]' \
  '--small-screen[optimize for small displays]' \
  '--stereo[enable hardware stereo mode]' \
  '--side-by-side[activate side-by-side stereo]' \
  '--zalman-stereo[use Zalman stereo hardware]' \
  '(--host --hostname)'{--host,--hostname}'[start listener on specified host]:host:_hosts' \
  '--port[define listener port number]:port:' \
  '--update-self[attempt self-update]' \
  '--self-test[run internal tests and exit]' \
  '*:file:_files' && ret=0

return ret
