#compdef tracertstats
# Documentation: https://manpages.debian.org/testing/libtrace-tools/tracertstats.1.en.html
# perform simple filter based analysis on a libtrace trace

local ret=1

_arguments -s -S \
  '(-H --libtrace-help)'{-H,--libtrace-help}'[display libtrace help information]' \
  '*'{-f+,--filter=}'[add a bpf filter expression for analysis]:bpf filter' \
  '(-i --interval)'{-i+,--interval=}'[output results every interval seconds]:interval' \
  '(-c --count)'{-c+,--count=}'[output results every count packets]:count' \
  '(-m --merge-inputs)'{-m,--merge-inputs}'[treat multiple inputs as unified, producing single output]' \
  '(-o --output-format)'{-o+,--output-format=}'[select output type]:format:(txt csv png html)' \
  '*:uri:_files' && ret=0

return ret
