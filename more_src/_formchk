#compdef formchk
# Documentation: https://gaussian.com/formchk/
# Convert a binary Gaussian checkpoint file to ASCII formatted form

local ret=1

_arguments -s -S \
  '-3[produce version 3 formatted checkpoint file]' \
  '-2[produce version 2 (Gaussian 03) formatted checkpoint file]' \
  '-c[output molecular mechanics atom types as strings]' \
  '-r[restore data for general case in ONIOM checkpoint file]' \
  '-matrix[generate Fortran unformatted matrix element file]' \
  '-rawmatrix[write raw binary matrix element file]' \
  '-i4[use 4-byte integers in Fortran unformatted output]' \
  '-i8[use 8-byte integers in Fortran unformatted output]' \
  '-files=[include specified internal Gaussian files in matrix element file]:list' \
  '-m[memory to allocate to the utility]:amount' \
  '*:checkpoint file:_files -g "*.chk"' && ret=0

return ret
