#compdef jdb
# _jdb — OpenJDK Java debugger (Oracle/OpenJDK, Java); custom argparse
# upstream: https://github.com/openjdk/jdk

_jdb() {
    _arguments \
        '--help[show help]' \
        '-help[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-sourcepath+[source path]:list:_files' \
        '-attach+[attach to running VM]:hostport:' \
        '-listen+[listen for VM at port]:hostport:' \
        '-listenany[listen for VM at any port]' \
        '-launch[launch right away]' \
        '-listconnectors[list available connectors]' \
        '-connect+[connect to VM]:str:' \
        '-dbgtrace=+[print info for debugging jdb]:str:' \
        '-tclient[client VM]' \
        '-tserver[server VM]' \
        '-J+[option for VM running jdb]:opt:' \
        '-R+[option for debugged VM]:opt:' \
        '-trackallthreads[track all threads]' \
        '-classpath+[class path]:list:_files' \
        '-cp+[class path]:list:_files' \
        '-module-path+[module path]:list:_files' \
        '-p+[module path]:list:_files' \
        '*:class:'
}

_jdb "$@"
