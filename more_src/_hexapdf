#compdef hexapdf
# Documentation: https://hexapdf.gettalong.org/documentation/hexapdf.1.html
# hexapdf - manipulate and inspect PDF files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '--strict[enable strict parsing validation]' \
  '--verbose[increase verbosity]' \
  '--quiet[suppress all output]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'batch:execute a command on multiple PDF files'
      'files:list, extract or attach embedded files'
      'fonts:list fonts used in a PDF'
      'form:work with interactive forms'
      'help:display help'
      'images:extract or list images'
      'image2pdf:convert images to PDF'
      'info:show general PDF information'
      'inspect:inspect internal PDF structure'
      'merge:combine multiple PDFs'
      'modify:modify page selection, rotation or encryption'
      'optimize:reduce PDF file size'
      'split:divide PDF into multiple files'
      'usage:display space usage statistics'
      'watermark:apply watermarks or stamps'
      'version:show version'
    )
    _describe -t commands 'hexapdf command' cmds && ret=0
    ;;
esac

return ret
