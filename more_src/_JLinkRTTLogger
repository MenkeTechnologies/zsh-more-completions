#compdef JLinkRTTLogger
# Documentation: https://kb.segger.com/J-Link_RTT_Logger
# SEGGER J-Link RTT Logger — stream RTT channel data from target to a log file

local ret=1

_arguments -s -S \
  '-?[show commandline options]' \
  '-Device[set target device]:device:' \
  '-if[set target interface]:interface:(SWD JTAG)' \
  '-Speed[set interface speed in kHz]:khz:' \
  '-USB[connect via USB serial number or nickname]:sn:' \
  '-IP[connect via IP address, hostname, nickname or serial]:host:' \
  '-RTTAddress[set RTT control block address]:address:' \
  '-RTTSearchRanges[set RTT search ranges]:ranges:' \
  '-RTTChannel[set RTT channel]:channel:' \
  '*:output file:_files' && ret=0

return ret
