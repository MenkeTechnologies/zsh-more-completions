#compdef varnishd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-V[display version]' \
  '(- *)-x+[dump parameter documentation]:format:(parameter vsl cli builtin)' \
  '-a+[listen address and port]:listen address\:port:' \
  '-b+[backend server]:host\:port:' \
  '-C[print compiled VCL and exit]' \
  '-d[debug mode]' \
  '-F[run in foreground]' \
  '-f+[VCL configuration file]:VCL file:_files' \
  '-h+[hash algorithm]:algorithm:(classic critbit)' \
  '-I+[CLI commands file]:CLI file:_files' \
  '-i+[set identity for syslog and CLI banner]:identity:' \
  '-j+[jail specification]:jail type:(unix none)' \
  '-l+[set varnishlog shmlog size]:size:' \
  '-M+[reverse CLI address]:address\:port:' \
  '-n+[instance name]:instance name:' \
  '-P+[PID file]:PID file:_files' \
  '-p+[set parameter]:parameter=value:' \
  '-r+[set read-only parameters]:parameters:' \
  '-S+[secret file for CLI authentication]:secret file:_files' \
  '-s+[storage specification]:storage type:(malloc file memfd default)' \
  '-T+[management listen address]:address\:port:' \
  '-t+[default TTL]:seconds:' \
  '-W+[waiter type]:waiter:(poll epoll kqueue)' \
  '-w+[worker thread pool parameters]:min,max,timeout:' && ret=0

return ret
