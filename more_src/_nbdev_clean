#compdef nbdev_clean
# Documentation: https://nbdev.fast.ai/api/clean.html
# nbdev_clean: clean notebooks to avoid merge conflicts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--fname=[notebook name or glob to clean]:fname:_files' \
  '--clear_all[remove all cell metadata and cell outputs]' \
  '--disp[print the cleaned outputs]' \
  '--stdin[read notebook from input stream]' && ret=0

return ret
