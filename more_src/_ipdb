#compdef ipdb
# Documentation: https://man.archlinux.org/search?q=ipdb
# Reference accessed: 2026-05-16

# ipdb: IPython-enhanced Python debugger
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-c[run command on start]:cmd:' \
  '-m[run module as script]:module:' \
  '-p[post-mortem on file]:file:_files' \
  '*:python script:_files -g "*.py"' && ret=0
return ret
