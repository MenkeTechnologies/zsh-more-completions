#compdef proteinortho proteinortho6.pl
# _proteinortho — Marcus Lechner proteinortho CLI fast multi-species orthology detection using reciprocal-best-hit Blast Diamond MMseqs Last UBlast Topaz-based all-vs-all reciprocal connected-component clustering producing TSV summary per-species ortholog tables synteny-aware POFF mode (Marcus Lechner team, Perl); getopt
# upstream: https://gitlab.com/paulklemm_PHD/proteinortho

_proteinortho() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-step=+[N]:n:(0 1 2 3)' \
        '-p=+[program]:p:(blastp+ blastn+ tblastx+ diamond mmseqsp mmseqsn lastp lastn ublast topaz autoblast)' \
        '-e=+[evalue]:str:' \
        '-cpus=+[N]:n:' \
        '-singles[include single-gene orthogroups]' \
        '-selfblast[include self-blast]' \
        '-conn=+[N]:n:' \
        '-minconn=+[N]:n:' \
        '-sim=+[N]:n:' \
        '-identity=+[N]:n:' \
        '-cov=+[N]:n:' \
        '-synteny[POFF synteny mode]' \
        '-keep[keep tmp files]' \
        '-clean[clean tmp files]' \
        '-verbose=+[level]:l:(0 1 2)' \
        '-temp=+[dir]:dir:_files -/' \
        '-project=+[name]:str:' \
        '-graph[output graph]' \
        '-xml[output XML]' \
        '-jobs=+[range]:str:' \
        '-isoform=+[mode]:m:(ncbi uniprot tom)' \
        '-checkfasta[validate fasta inputs]' \
        '-binpath=+[path]:dir:_files -/' \
        '*:fasta file:_files -g "*.fa *.fasta *.faa *.fna"'
}

_proteinortho "$@"
