#compdef ignitevisorcmd ignitevisorcmd.sh
# Documentation: https://apacheignite-tools.readme.io/docs/command-line-interface
# ignitevisorcmd - Apache Ignite Visor command line management console

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-v[verbose mode]' \
  '-np[no pause on exit]' \
  '-cfg=[connect with specified configuration file]:file:_files' \
  '-b=[batch mode, read commands from file]:file:_files' \
  '-e=[batch mode, run semicolon-separated commands]:commands:' && ret=0

return ret
