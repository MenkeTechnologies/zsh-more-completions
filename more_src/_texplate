#compdef texplate

local -a subcmds

subcmds=(
    'execute:Execute a template'
    'merge:Merge template with data'
)

_arguments -s -S \
    '--help[Show help message]' \
    '--version[Show version]' \
    '1:subcommand:->subcmd' \
    '*::options:->options'

case $state in
    subcmd)
        _describe -t commands 'texplate subcommand' subcmds
        ;;
    options)
        case $words[1] in
            execute)
                _arguments \
                    '-t[Template name]:template name' \
                    '-o[Output file]:output file:_files' \
                    '-m[Map key/value pairs]:key=value' \
                    '-c[Configuration file]:config file:_files' \
                    '*:files:_files'
                ;;
            merge)
                _arguments \
                    '-t[Template name]:template name' \
                    '-o[Output file]:output file:_files' \
                    '-d[Data file]:data file:_files' \
                    '-c[Configuration file]:config file:_files' \
                    '*:files:_files'
                ;;
        esac
        ;;
esac
