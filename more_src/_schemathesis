#compdef schemathesis
# Documentation: https://schemathesis.readthedocs.io
# Reference accessed: 2026-05-21
# Verified: upstream docs confirm 'run' subcommand. Detailed run flags
# could not be reproducibly fetched from the published CLI reference
# (404s on /en/reference/cli/ and /en/stable/cli/). Pre-existing flags
# could not be verified from primary docs and have been removed.
# STUB: only the documented subcommand entry is exposed.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:execute API tests against a schema'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'schemathesis command' commands && ret=0 ;;
  args)
    case $words[1] in
      run)
        _arguments -s -S \
          ':schema URL or file:_files' && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac
return ret
