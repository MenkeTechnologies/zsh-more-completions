#compdef schemathesis

local curcontext="$curcontext" state line ret=1

_schemathesis_commands() {
  local -a commands=(
    'run:execute API tests against a schema'
    'replay:replay a saved test case'
  )
  _describe -t commands 'schemathesis command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:_schemathesis_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments -s -S \
          '(-a --auth)'{-a,--auth}'[server auth (user:password)]:auth' \
          '(-A --auth-type)'{-A,--auth-type}'[auth type]:type:(basic digest)' \
          '(-b --base-url)'{-b,--base-url}'[base URL]:url' \
          '(-c --checks)'{-c,--checks}'[checks to run]:checks:(all not_a_server_error status_code_conformance content_type_conformance response_headers_conformance response_schema_conformance negative_data_rejection)' \
          '--cassette-path[save cassette to file]:file:_files' \
          '--code-sample-style[code sample style]:style:(python curl)' \
          '--contrib-unique-data[enable unique data generation]' \
          '--contrib-openapi-formats-uuid[enable UUID format]' \
          '(-D --data-generation-method)'{-D,--data-generation-method}'[data generation]:method:(positive negative)' \
          '--dry-run[do not execute tests]' \
          '(-E --endpoint)'{-E,--endpoint}'[filter endpoints by regex]:pattern' \
          '--exclude-checks[exclude checks]:checks' \
          '--exitfirst[exit on first failure]' \
          '(-H --header)'{-H,--header}'[custom header]:header' \
          '--hypothesis-database[hypothesis database]:path:_files' \
          '--hypothesis-deadline[hypothesis deadline in ms]:ms' \
          '--hypothesis-max-examples[max examples]:count' \
          '--hypothesis-phases[hypothesis phases]:phases' \
          '--hypothesis-seed[random seed]:seed' \
          '--hypothesis-suppress-health-check[suppress health checks]' \
          '(-M --method)'{-M,--method}'[filter by HTTP method]:method:(GET POST PUT PATCH DELETE)' \
          '--rate-limit[requests per second limit]:rate' \
          '--report[generate report]' \
          '--request-timeout[request timeout in ms]:ms' \
          '--show-errors-tracebacks[show error tracebacks]' \
          '--stateful[stateful testing]:mode:(links none)' \
          '(-t --tag)'{-t,--tag}'[filter by tag]:tag' \
          '--validate-schema[validate schema before testing]:enabled:(true false)' \
          '(-w --workers)'{-w,--workers}'[number of workers]:workers' \
          '1:schema URL or file:_files' && ret=0
        ;;
      replay)
        _arguments -s -S \
          '--cassette-path[cassette file]:file:_files' \
          '--id[replay specific interaction by ID]:id' \
          '--status[filter by status code]:code' \
          '--uri[filter by URI]:uri' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
