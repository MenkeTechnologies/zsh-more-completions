#compdef clinplot
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss22.html
# KAPPA: draws a spatial grid of line plots for an array of spectra in a cube NDF

local ret=1

_arguments -s \
  'IN=[input cube NDF]:ndf:_files -g "*.sdf"' \
  'USEAXIS=[axes to use]:axes' \
  'DEVICE=[graphics device]:device' \
  'NX=[number of plots in x]:n' \
  'NY=[number of plots in y]:n' \
  'ALIGN=[align with existing picture]:bool:(TRUE FALSE)' \
  'AXES=[draw annotated axes]:bool:(TRUE FALSE)' \
  'BLANKEDGE=[leave blank edge cells]:bool:(TRUE FALSE)' \
  'CLEAR=[clear the device first]:bool:(TRUE FALSE)' \
  'COMP=[array component to plot]:comp:(Data Variance Error)' \
  'FILL=[stretch plot to fill region]:bool:(TRUE FALSE)' \
  'KEY=[draw a key]:bool:(TRUE FALSE)' \
  'KEYPOS=[key position]:pos' \
  'KEYSTYLE=[key plotting style]:style' \
  'LMODE=[scaling mode for vertical axis]:mode' \
  'MARGIN=[widths of plot margins]:margin' \
  'MARKER=[marker symbol type]:n' \
  'MODE=[how points are drawn]:mode:(Histogram Line Point Mark Step Chain)' \
  'REFLABEL=[label the reference spectrum]:bool:(TRUE FALSE)' \
  'SPECAXES=[draw spectral axes]:bool:(TRUE FALSE)' \
  'SPECSTYLE=[spectral axes style]:style' \
  'STYLE=[plotting style]:style' \
  'YBOT=[lower vertical axis bound]:value' \
  'YTOP=[upper vertical axis bound]:value' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
