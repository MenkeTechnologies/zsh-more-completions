#compdef idf idf.py
# _idf — Espressif Systems idf.py CLI for the ESP-IDF framework managing ESP32 ESP32-S2 ESP32-S3 ESP32-C3 ESP32-H2 build flash monitor menuconfig clean fullclean size erase-flash partition-table reconfigure (espressif team, Python); click
# upstream: https://github.com/espressif/esp-idf

_idf() {
    local -a sub=(
        'all:build all targets'
        'app:build app'
        'app-flash:flash app only'
        'bootloader:build bootloader'
        'bootloader-flash:flash bootloader'
        'build:build firmware'
        'clean:clean build'
        'fullclean:remove all build files'
        'efuse-summary:show eFuse summary'
        'efuse-burn:burn eFuses'
        'erase-flash:erase flash'
        'erase-otadata:erase OTA data'
        'encrypted-flash:flash encrypted'
        'flash:flash firmware'
        'gdb:start GDB'
        'gdbgui:start GDB GUI'
        'monitor:open serial monitor'
        'reconfigure:re-run CMake'
        'set-target:set chip target'
        'show-efuse-table:show eFuse table'
        'size:show binary size'
        'size-components:show component sizes'
        'size-files:show file sizes'
        'partition-table:show partition table'
        'partition-table-flash:flash partition table'
        'python-clean:remove Python virtualenv'
        'qemu:run QEMU'
        'docs:open ESP-IDF documentation'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-C+[project dir]:dir:_files -/' \
        '--project-dir=+[project dir]:dir:_files -/' \
        '-B+[build dir]:dir:_files -/' \
        '--build-dir=+[build dir]:dir:_files -/' \
        '-n+[no warnings]' \
        '--no-warnings[no warnings]' \
        '-p+[serial port]:file:_files -g "/dev/tty* /dev/cu*"' \
        '--port=+[serial port]:file:_files -g "/dev/tty* /dev/cu*"' \
        '-b+[baud]:n:(74880 115200 230400 460800 921600 1500000 2000000)' \
        '--baud=+[baud]:n:(74880 115200 230400 460800 921600 1500000 2000000)' \
        '-D+[define]:str:' \
        '--define-cache-entry=+[define]:str:' \
        '-G+[generator]:g:(Ninja "Unix Makefiles")' \
        '--generator=+[generator]:g:(Ninja "Unix Makefiles")' \
        '--no-ccache[disable ccache]' \
        '--ccache[enable ccache]' \
        '--cmake-warn-uninitialized[warn uninitialized]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'idf subcommand' sub ;;
        args)
            case $words[1] in
                set-target) _arguments '*:target:(esp32 esp32s2 esp32s3 esp32c3 esp32c2 esp32c6 esp32h2 esp32p4 linux)' ;;
                monitor) _arguments \
                    '--no-reset[no reset on connect]' \
                    '--print-filter=+[filter]:str:' \
                    '--encrypted[encrypted]' \
                    '--timestamps[timestamps]' \
                    '--timestamp-format=+[fmt]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_idf "$@"
