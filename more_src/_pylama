#compdef pylama

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose mode]' \
  '--verbose[verbose mode]' \
  '-f+[output format]:format:(pep8 pylint parsable json)' \
  '--format=[output format]:format:(pep8 pylint parsable json)' \
  '-l+[select linters]:linters' \
  '--linters=[select linters]:linters' \
  '-i+[ignore errors and warnings]:codes' \
  '--ignore=[ignore errors and warnings]:codes' \
  '-s+[select errors and warnings]:codes' \
  '--select=[select errors and warnings]:codes' \
  '--sort=[sort results by]:field:(F C D E W N)' \
  '-o+[set configuration file]:config:_files' \
  '--options=[set configuration file]:config:_files' \
  '--skip=[skip files by masks]:patterns' \
  '--max-line-length=[max line length]:length' \
  '-a[async mode]' \
  '--async[async mode]' \
  '-r[parse directories recursively]' \
  '--recursive[parse directories recursively]' \
  '--abspath[show absolute paths]' \
  '--from-stdin[read from stdin]' \
  '*:path:_files' && return 0
