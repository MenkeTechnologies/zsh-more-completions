#compdef sbomqs
# SBOM quality scoring and compliance tool (interlynk-io)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    score:"calculate SBOM quality score"
    compliance:"check regulatory compliance"
    list:"list and filter components"
    share:"generate shareable quality-score report"
    dtrackScore:"score SBOMs in a Dependency-Track project"
    generate:"generate configuration files"
    features:"browse features supported by a profile"
    version:"show version information"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      score)
        _arguments -s \
          '--category[scoring category]:category:' \
          '--profile[scoring profile]:profile:(ntia bsi)' \
          '--configpath[path to custom weights configuration]:file:_files' \
          '--feature[score specific features]:feature:' \
          '--json[output results in JSON]' \
          '-b[brief output mode]' \
          '*:sbom file:_files' && ret=0
        ;;
      compliance)
        _arguments -s \
          '--bsi-v2[BSI TR-03183-2 v2.0 validation]' \
          '--fsct[FSCT v3 compliance check]' \
          '--oct[OpenChain Telco validation]' \
          '*:sbom file:_files' && ret=0
        ;;
      list)
        _arguments -s \
          '--feature[component features to display]:feature:' \
          '--missing[show only components lacking specified data]' \
          '--show[display actual feature values]' \
          '--profile[apply profile-specific field inspection]:profile:' \
          '*:sbom file:_files' && ret=0
        ;;
      features)
        _arguments -s \
          '--profile[profile to inspect]:profile:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
