#compdef muscle5

# MUSCLE 5: rewrite with subcommand interface
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'align:fast MSA via parallel-perturbed alignment'
  'super5:super5 algorithm for very large alignments'
  'efaprobs:per-column posterior probabilities'
  'ensemble:build an ensemble of alternative MSAs'
  'efa:per-column expected-fraction accuracy values'
  'addconfseqs:add confidence values to FASTA sequences'
  'maxcc:select best alignment from an ensemble by max column-confidence'
  'letterconf:write per-letter confidence values'
  'version:print version'
  'help:show help'
)

_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-align[align sequences]' \
  '-super5[super5 large-alignment mode]' \
  '-output[output file]:file:_files' \
  '-perm[permutation method]:perm:(none abc acb bca)' \
  '-perturb[random seed for perturbation]:n:' \
  '-stratified[stratified sampling]' \
  '-diversified[diversified sampling]' \
  '-replicates[ensemble size]:n:' \
  '-consiters[consensus iterations]:n:' \
  '-refineiters[refinement iterations]:n:' \
  '-threads[CPU threads]:n:' \
  '-log[log file]:file:_files' \
  '-amino[force protein]' \
  '-nt[force nucleotide]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'muscle5 command' commands && ret=0 ;;
esac

return ret
