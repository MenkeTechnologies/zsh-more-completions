#compdef muscle5 muscle
# Documentation: https://drive5.com/muscle5/manual/commands.html
# Reference accessed: 2026-05-19
# Verified: upstream MUSCLE v5 command reference at the URL above
# and cmd_super5.html for super5 options.
# Subcommand interface (align, super5, efastats, efa_explode, fa2efa,
# disperse, addconfseq, letterconf, maxcc, resample). All flags single-dash
# long (drive5 style): -output, -threads, -perturb, -perm, -consiters,
# -refineiters, -nt, -amino, -log, -version, -h.

# MUSCLE 5: rewrite with subcommand interface
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'align:align sequences using the PPP algorithm'
  'super5:align large datasets using the Super5 algorithm'
  'efastats:report miscellaneous information about MSAs'
  'efa_explode:extract FASTA files from an EFA file'
  'fa2efa:combine FASTA files into one EFA file'
  'disperse:calculate the dispersion of an ensemble'
  'addconfseq:calculate column confidences'
  'letterconf:calculate letter confidences'
  'maxcc:extract MSA with highest column confidence'
  'resample:generate a resampled ensemble'
  'version:print version'
)

_arguments -C \
  '-help[show help]' \
  '-h[show help]' \
  '-version[show version]' \
  '-align[align sequences (legacy flag form)]:file:_files' \
  '-super5[super5 large-alignment mode (legacy flag form)]:file:_files' \
  '-output[output file]:file:_files' \
  '-perm[permutation method]:perm:(none abc acb bca)' \
  '-perturb[random seed for HMM perturbation]:n:' \
  '-replicates[ensemble size]:n:' \
  '-stratified[stratified ensemble sampling]' \
  '-diversified[diversified ensemble sampling]' \
  '-consiters[consensus iterations]:n:' \
  '-refineiters[refinement iterations]:n:' \
  '-threads[CPU threads]:n:' \
  '-log[log file]:file:_files' \
  '-amino[force amino-acid (protein) alphabet]' \
  '-nt[force nucleotide alphabet]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'muscle5 command' commands && ret=0 ;;
esac

return ret
