#compdef concourse
# Documentation: https://github.com/concourse/concourse
# Source: concourse/concourse cmd/concourse/command.go — concourse CI binary (web, worker, migrate, etc.).
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _conc_cmds
_conc_cmds=(
    'web:run the web UI and build scheduler'
    'worker:run and register a worker'
    'migrate:run database migrations'
    'quickstart:run both web and worker together (not for production)'
    'land-worker:safely drain a worker assignments for temporary downtime'
    'retire-worker:safely remove a worker from the cluster permanently'
    'generate-key:generate RSA key for use with Concourse components'
)

_arguments -C \
    '(- *)'{-v,--version}'[print version of Concourse and exit]' \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'concourse command' _conc_cmds && ret=0
        ;;
esac

return ret
