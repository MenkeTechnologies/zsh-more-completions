#compdef dssi-server
# Documentation: https://man.archlinux.org/search?q=dssi-server
# Reference accessed: 2026-05-16

# dssi-server: DSSI plugin host (JACK + ALSA MIDI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[verbose]' \
  '-i[ignore failed plugins]' \
  '*:plugin .so file:_files -g "*.so"' && ret=0
return ret
