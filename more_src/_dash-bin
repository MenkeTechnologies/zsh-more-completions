#compdef dash
# _dash-bin — Debian Almquist Shell (Herbert Xu, Gerrit Pape); POSIX /bin/sh on Debian/Ubuntu, designed for size and speed
# upstream: https://git.kernel.org/pub/scm/utils/dash/dash.git

_dash-bin() {
    _arguments \
        '-c+[command]:code:' \
        '-i[interactive]' \
        '-l[login shell]' \
        '-s[read from stdin]' \
        '-a[allexport]' \
        '-b[notify]' \
        '-e[errexit]' \
        '-f[noglob]' \
        '-h[hashall]' \
        '-m[monitor]' \
        '-n[noexec]' \
        '-u[nounset]' \
        '-v[verbose]' \
        '-x[xtrace]' \
        '-C[noclobber]' \
        '-E[emacs editing]' \
        '-V[vi editing]' \
        '-o+[option]:option:(allexport errexit ignoreeof monitor noclobber noexec noglob nolog notify nounset verbose vi emacs xtrace pipefail)' \
        '+o+[unset option]:option:' \
        '*:script:_files -g "*.sh"'
}

_dash-bin "$@"
