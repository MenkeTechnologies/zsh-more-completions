#compdef build-cli pyproject-build
# _build-cli — PyPA python-build modern PEP517 builder CLI alias (PyPA, Python); argparse
# upstream: https://github.com/pypa/build

_build-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--sdist[build sdist]' \
        '-s[build sdist]' \
        '--wheel[build wheel]' \
        '-w[build wheel]' \
        '--outdir=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--skip-dependency-check[skip dep check]' \
        '-x[skip dep check]' \
        '--no-isolation[no isolation]' \
        '-n[no isolation]' \
        '--installer=+[installer]:i:(pip uv)' \
        '--config-setting=+[config setting key=value]:str:' \
        '-C+[config setting key=value]:str:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '*:srcdir:_files -/'
}

_build-cli "$@"
