#compdef ceph-osd
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-osd/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Ceph OSD daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --foreground -d)'{-f,--foreground}'[do not daemonize after startup]' \
  '(-d -f --foreground)-d[debug mode: like -f, send log output to stderr]' \
  '--setuser=[set uid after starting]:user or uid:_users' \
  '--setgroup=[set gid after starting]:group or gid:_groups' \
  '--osd-data=[OSD data directory]:dir:_files -/' \
  '--osd-journal=[OSD journal]:file:_files' \
  '--check-wants-journal[check if OSD wants journal]' \
  '--check-allows-journal[check if OSD allows journal]' \
  '--check-needs-journal[check if OSD needs journal]' \
  '--mkfs[create new data store]' \
  '--mkkey[generate authentication key]' \
  '--mkjournal[create new journal]' \
  '--flush-journal[flush journal then exit]' \
  '--get-cluster-fsid[print cluster fsid]' \
  '--get-osd-fsid[print OSD fsid]' \
  '--get-journal-fsid[print journal fsid]' \
  '(-c --conf)'{-c+,--conf=}'[use this ceph.conf instead of default]:file:_files -g "*.conf"' \
  '-m+[connect to specified monitor]:monaddress\:port:' \
  '--osdspec-affinity=[set OSD spec affinity]:value:' \
  '*::ceph-osd args:_files' && ret=0
return ret
