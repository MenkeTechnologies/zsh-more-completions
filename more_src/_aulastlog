#compdef aulastlog
# _aulastlog — Linux audit aulastlog (lastlog(8)-style listing built from audit log records: per-user last login source/time/result, optional inactivity check; -u user filter, -t time format, -n N suppress users older than N days, --version, --help)
# upstream: https://github.com/linux-audit/audit-userspace
# Flags from linux-audit/audit-userspace src/aulastlog.c on tip.

_aulastlog() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-u+[user]:user:_users' \
        '-t+[time format]:fmt:' \
        '-n+[days]:n:' \
        '-i[interpret]'
}

_aulastlog "$@"
