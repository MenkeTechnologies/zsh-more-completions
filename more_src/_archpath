#compdef archpath
# Documentation: https://manpages.debian.org/archpath
# Source: debian/devscripts scripts/archpath.sh — output arch archive names with branch support (bash).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1::branchname:_default' \
    && ret=0

return ret
