#compdef gobang
# Documentation: https://man.archlinux.org/search?q=gobang
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[config file]:config file:_files' \
  '--config=[config file]:config file:_files' && ret=0

return ret
