#compdef xcwd
# _xcwd — Adrien Schildknecht xcwd X11 active-window working-directory tool CLI alias (schischi team, C); custom argparse
# upstream: https://github.com/schischi/xcwd

_xcwd() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-v[verbose]' \
        '*:arg:'
}

_xcwd "$@"
