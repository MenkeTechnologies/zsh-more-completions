#compdef create-agent-docs
# Documentation: https://www.npmjs.com/package/create-agent-docs
# Reference accessed: 2026-05-23
# Verified: npm view create-agent-docs bin; npm readme Commands section.

# Zsh completion for create-agent-docs - AI-ready documentation generator

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-p --preset)'{-p,--preset=}'[stack preset]:preset:(nextjs nextjs-saas t3 vue angular express nestjs mern react-firebase firebase ai-cursor ai-claude ai-codex fastapi)'   '(-f --force)'{-f,--force=}'[overwrite existing files]'   '(-d --dry-run)'{-d,--dry-run=}'[preview without writing files]'   '(-o --output)'{-o,--output=}'[output directory]:directory:_directories'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' init generate presets analyze validate upgrade && ret=0
    ;;
  args)
    case $line[1] in
      generate)
        _arguments -C           '(-p --preset)'{-p,--preset=}'[stack preset]:preset:(nextjs nextjs-saas t3 vue angular express nestjs mern react-firebase firebase ai-cursor ai-claude ai-codex fastapi)'           '(-f --force)'{-f,--force=}'[overwrite existing files]'           '(-d --dry-run)'{-d,--dry-run=}'[preview without writing files]'           '(-o --output)'{-o,--output=}'[output directory]:directory:_directories' && ret=0
        ;;
      init)
        _arguments -C           '(-f --force)'{-f,--force=}'[overwrite existing files]'           '(-d --dry-run)'{-d,--dry-run=}'[preview without writing files]' && ret=0
        ;;
      presets|analyze|validate|upgrade)
        _arguments -C && ret=0
        ;;
    esac
    ;;
esac

return ret
