#compdef affixcompress
# Documentation: https://man.archlinux.org/search?q=affixcompress
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input affix file:_files -g "*.aff"' \
  '2:output compressed affix file:_files -g "*.aff"' && ret=0

return ret
