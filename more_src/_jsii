#compdef jsii

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose compiler output]' \
  '--silence-warnings=[silence warning id; repeatable]:id' \
  '--fail-on-warnings[treat warnings as errors]' \
  '--fixed-output[write stable assembly ordering]' \
  '--watch[watch mode for development]' \
  '--project-info=[path to package.json]:file:_files' \
  '*:TypeScript project root:_directories'
