#compdef uvx

# Zsh completion for uvx - uv tool runner (like npx for Python)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--from[package to install the command from]:package:' \
  '*--with[additional package to install (may be repeated)]:package:' \
  '--with-requirements[install all packages from a requirements file]:file:_files' \
  '--python[Python version to use]:version:' \
  '--index-url[base URL of the Python Package Index]:URL:' \
  '--extra-index-url[extra URLs of package indexes]:URL:' \
  '--no-cache[do not use the cache]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[increase output verbosity]' \
  '--color[control color output]:when:(auto always never)' \
  '--no-color[disable color output]' \
  '--no-progress[disable progress bars]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '1:command:_command_names' \
  '*::args:_default' && ret=0

return ret
