#compdef cdi-controller
# _cdi-controller — Containerized Data Importer (CDI) main controller (DataVolume/DV reconciliation)
# upstream: https://github.com/kubevirt/containerized-data-importer
# Flags from cmd/cdi-controller/controller.go on tip; further config via envconfig.

_cdi-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[(optional) overrides $KUBECONFIG]:file:_files' \
        '--server=[(optional) URL of a remote api server]:url:_urls' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[log to stderr and files]' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files'
}

_cdi-controller "$@"
