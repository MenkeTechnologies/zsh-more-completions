#compdef flashrom-config

# flashrom-config: helper for flashrom programmer/chip configuration
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-p[programmer type]:prog:(internal serprog ch341a_spi dummy buspirate_spi linux_spi linux_mtd ft2232_spi)' \
  '-c[chip type]:chip:' \
  '*::flashrom-config args:_files' && ret=0
return ret
