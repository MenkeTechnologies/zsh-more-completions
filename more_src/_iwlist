#compdef iwlist
# _iwlist — Linux wireless-tools iwlist (query wireless interface state in detail: scan/freq/channel/rate/power/key/encryption/ap/peers/event listings; complement to iwconfig)
# upstream: https://hewlettpackard.github.io/wireless-tools/ (jt@hpl.hp.com)
# Subcommands from wireless-tools iwlist.c on tip.

_iwlist() {
    _arguments \
        '1:interface:_net_interfaces' \
        '2:command:(scanning frequency channel bitrate encryption keys power txpower retry ap accesspoints peers event auth wpakeys genie modulation)'
}

_iwlist "$@"
