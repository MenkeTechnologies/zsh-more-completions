#compdef qemu-riscv32 qemu-system-riscv32
# Documentation: https://www.qemu.org/docs/master/system/invocation.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-M+[machine type]:type:' \
  '-cpu+[cpu model]:cpu:' \
  '-m+[memory MB]:mb:' \
  '-smp+[number of cpus]:n:' \
  '-kernel+[kernel image]:file:_files' \
  '-initrd+[initrd]:file:_files' \
  '-append+[kernel append]:cmdline:' \
  '-bios+[bios file]:file:_files' \
  '-dtb+[device tree]:file:_files -g "*.dtb"' \
  '-nographic[no graphics]' \
  '-display+[display]:disp:(gtk sdl vnc cocoa curses none)' \
  '-serial+[serial dev]:dev:' \
  '-drive+[drive]:opts:' \
  '-cdrom+[cdrom]:file:_files -g "*.iso"' \
  '-netdev+[netdev]:opts:' \
  '-device+[device]:opts:' \
  '-d+[debug]:items:' \
  '-D+[log file]:file:_files' \
  '-snapshot[snapshot mode]' \
  '*:disk image:_files' && ret=0

return ret
