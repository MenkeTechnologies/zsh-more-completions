#compdef simpleaf
# Documentation: https://simpleaf.readthedocs.io/en/latest/
# simpleaf: rust framework for single-cell processing with alevin-fry

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:(set-paths chemistry inspect index quant multiplex-quant refresh-prog-info workflow)' \
  '*::args:_files' && ret=0

return ret
