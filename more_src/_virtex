#compdef virtex
# Documentation: https://man.archlinux.org/man/tex.1.en
# virtex - Web2C TeX engine preloaded with the plain format

local ret=1

_arguments -s \
  '-help[print help message and exit]' \
  '-version[print version information and exit]' \
  '-cnf-line=[parse a line as if it were in texmf.cnf]:string:' \
  '-enc[enable the encTeX extensions (requires -ini)]' \
  '-ini[start in initialization mode for dumping formats]' \
  '(-no-file-line-error)-file-line-error[print errors in file:line:error style]' \
  '(-file-line-error)-no-file-line-error[disable file:line:error style errors]' \
  '-file-line-error-style[older name for -file-line-error]' \
  '-fmt=[use the named format file]:format:' \
  '-halt-on-error[exit with an error code when an error is encountered]' \
  '-interaction=[set the interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)' \
  '-ipc[send DVI output to a socket as well as the usual output file]' \
  '-ipc-start[as -ipc, and also start the server at the other end]' \
  '-jobname=[set the job name and hence the output file names]:name:' \
  '-kpathsea-debug=[set path searching debugging flags (bitmask)]:bitmask:' \
  '-mktex=[enable mktexfmt, where fmt is tex or tfm]:fmt:(tex tfm)' \
  '-no-mktex=[disable mktexfmt, where fmt is tex or tfm]:fmt:(tex tfm)' \
  '-mltex[enable MLTeX extensions such as \charsubdef]' \
  '-output-comment=[use the string for the DVI file comment instead of the date]:string:' \
  '-output-directory=[write output files in the directory]:directory:_files -/' \
  '(-no-parse-first-line)-parse-first-line[enable parsing of the first line of the input file]' \
  '(-parse-first-line)-no-parse-first-line[disable parsing of the first line of the input file]' \
  '-progname=[set the program name for kpathsea]:name:' \
  '-recorder[enable the filename recorder]' \
  '(-no-shell-escape -shell-restricted)-shell-escape[enable \write18{command} (insecure)]' \
  '(-shell-escape -shell-restricted)-no-shell-escape[disable \write18{command}]' \
  '-src-specials=[insert source specials in certain places of the DVI file]::where:' \
  '-translate-file=[use the tcx file to set the translation table]:tcxname:_files' \
  '-default-translate-file=[as -translate-file but may be overridden by %& lines]:tcxname:_files' \
  '-8bit[make all characters printable by default]' \
  '*:input file:_files -g "*.tex(-.)"' && ret=0

return ret
