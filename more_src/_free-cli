#compdef free-cli
# _free-cli — procps free display amount of free and used memory CLI alias (procps team, C); custom argparse
# upstream: https://gitlab.com/procps-ng/procps

_free-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show human-readable]' \
        '--human[show human-readable]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[show bytes]' \
        '--bytes[show bytes]' \
        '-k[show kibibytes]' \
        '--kibi[show kibibytes]' \
        '-m[show mebibytes]' \
        '--mebi[show mebibytes]' \
        '-g[show gibibytes]' \
        '--gibi[show gibibytes]' \
        '--tebi[show tebibytes]' \
        '--pebi[show pebibytes]' \
        '--kilo[show kilobytes]' \
        '--mega[show megabytes]' \
        '--giga[show gigabytes]' \
        '--tera[show terabytes]' \
        '--peta[show petabytes]' \
        '-c+[count]:n:' \
        '--count=+[count]:n:' \
        '-l[show low and high memory]' \
        '--lohi[show low and high memory]' \
        '-L[show line]' \
        '--line[show line]' \
        '-s+[seconds]:n:' \
        '--seconds=+[seconds]:n:' \
        '--si[powers of 1000]' \
        '-t[show totals]' \
        '--total[show totals]' \
        '-v[show committed memory]' \
        '--committed[show committed memory]' \
        '-w[show wide output]' \
        '--wide[show wide output]' \
        '*:arg:'
}

_free-cli "$@"
