#compdef ghc-9.14.1

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--numeric-version[show numeric version]' \
  '--info[show GHC info]' \
  '-c[compile only]' \
  '-no-link[do not run the linker]' \
  '-shared[generate shared library]' \
  '-static[generate static library]' \
  '-dynamic[link dynamically]' \
  '*-package+[use package]:package:' \
  '*-hide-package+[hide package]:package:' \
  '*-package-db+[use package database]:db:_files' \
  '*-i+[add to import path]:dir:_files -/' \
  '*-I+[add to C include path]:dir:_files -/' \
  '*-L+[add library directory]:dir:_files -/' \
  '*-l+[link library]:lib:' \
  '-o+[output file]:file:_files' \
  '-odir+[object output directory]:dir:_files -/' \
  '-hidir+[interface output directory]:dir:_files -/' \
  '-O+[optimization level]:level:(0 1 2)' \
  '-fforce-recomp[force recompilation]' \
  '-Wall[enable all warnings]' \
  '-Werror[turn warnings into errors]' \
  '-prof[enable profiling]' \
  '-threaded[link with threaded RTS]' \
  '*--make[recompile dependent modules]' \
  '-v[verbose]' \
  '*:Haskell source / option:_files -g "*.(hs|lhs|hi|o)"' && ret=0

return ret
