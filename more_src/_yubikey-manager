#compdef yubikey-manager
# _yubikey-manager — Yubico yubikey-manager (Qt GUI entry-point for ykman / YubiKey Manager; the user-facing app exits immediately if invoked with arguments unsupported by the wrapper; --version is supported)
# upstream: https://github.com/Yubico/yubikey-manager-qt
# Argument shape from yubikey-manager-qt main.cpp on tip.

_yubikey-manager() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_yubikey-manager "$@"
