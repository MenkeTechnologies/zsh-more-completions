#compdef ctangle cweave cweb
# Documentation: https://man.archlinux.org/man/ctangle.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Knuth's CWEB literate programming system.

local curcontext="$curcontext" state line ret=1

case $service in
  (ctangle|cweave|cweb)
    _arguments -C \
      '+b[print banner line on terminal]' \
      '-b[suppress banner]' \
      '+h[print success message on completion]' \
      '-h[suppress happy message]' \
      '+p[print progress messages]' \
      '-p[suppress progress]' \
      '+q[quiet shortcut for -bhp]' \
      '-q[quiet]' \
      '--quiet[quiet]' \
      '+v[verbose shortcut for +bhp]' \
      '-v[verbose]' \
      '--verbose[verbose (default)]' \
      '+c[check temporary output for changes]' \
      '+s[print usage statistics]' \
      '+k[keep separators in numeric literals (ctangle)]' \
      '+u[transliterate UTF-8 chars in C code (ctangle)]' \
      '--help[show help]' \
      '--version[show version]' \
      '*: :_files -g "*.w *.ch *.tex *.c *.h"' && ret=0 ;;
esac

return ret
