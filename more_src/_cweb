#compdef ctangle cweave cweb

local curcontext="$curcontext" state line ret=1

case $service in
  (ctangle|cweave|cweb)
    _arguments -C \
      '-b[suppress banner]' \
      '-h[suppress happy message]' \
      '-q[quiet]' \
      '-v[verbose]' \
      '-p[suppress progress]' \
      '+s[print stats]' \
      '+P[output overrides]' \
      '+e[disable change file echoing]' \
      '+f[disable explicit f line]' \
      '+i[no index]' \
      '+m[no module list]' \
      '+t[no table of contents]' \
      '+x[show cross-references]' \
      '*: :_files -g "*.w *.ch *.tex *.c *.h"' && ret=0 ;;
esac

return ret
