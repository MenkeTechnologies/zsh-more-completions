#compdef xrdesktop
# Documentation: https://man.archlinux.org/search?q=xrdesktop
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--mode=+[mode]:mode:(scene mirror dual)' \
  '--debug[debug mode]' \
  '--display=+[X display]:disp:' && ret=0

return ret
