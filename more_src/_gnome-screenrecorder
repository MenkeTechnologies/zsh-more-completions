#compdef gnome-screenrecorder
# Documentation: https://man.archlinux.org/search?q=gnome-screenrecorder
# Reference accessed: 2026-05-16

# gnome-screenrecorder: screen recorder for GNOME Shell (libcheese-based or built-in)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-o[output file]:file:_files -g "*.(webm|mp4)"' \
  '--output=[output file]:file:_files -g "*.(webm|mp4)"' \
  '-l[max length seconds]:seconds:' \
  '--length=[max length seconds]:seconds:' \
  '-f[framerate]:fps:' \
  '-q[quality preset]:q:(low medium high)' \
  '*::gnome-screenrecorder args:_files' && ret=0
return ret
