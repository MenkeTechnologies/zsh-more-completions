#compdef surfaceRedistributePar
# Redistribute a triSurface in parallel running

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-keepNonMapped[preserve surface outside of mesh bounds]' \
  '-parallel[run in parallel]' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' \
  ':surface file:_files' \
  ':distribution type:(decompose follow independent)' && ret=0

return ret
