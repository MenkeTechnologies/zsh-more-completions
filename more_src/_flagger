#compdef flagger

# Zsh completion for flagger - Progressive delivery for Kubernetes

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--master=[Kubernetes API server address]:url:' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--namespace=[target namespace]:namespace:' \
  '--mesh-provider=[service mesh provider]:provider:(istio linkerd appmesh contour gloo nginx skipper traefik osm kuma gatewayapi)' \
  '--metrics-server=[Prometheus URL]:url:' \
  '--include-label-prefix=[label prefix to include in ConfigMaps and Secrets]:prefix:' \
  '--slack-url=[Slack hook URL]:url:' \
  '--slack-channel=[Slack channel]:channel:' \
  '--slack-user=[Slack user name]:user:' \
  '--msteams-url=[Microsoft Teams incoming webhook URL]:url:' \
  '--event-webhook=[event webhook URL]:url:' \
  '--threadhold-primary=[percentage of traffic to route to primary]:percentage:' \
  '--enable-config-tracking[enable ConfigMap and Secret change tracking]' \
  '--port=[metrics server port]:port:' \
  '--level=[log level (alias)]:level:(debug info warn error)' \
  '--server-port=[health check port]:port:' \
  '--control-loop-interval=[wait interval between reconciliations]:duration:' \
  '--enable-leader-election[enable leader election]' && ret=0

return ret
