#compdef flagger
# Documentation: https://github.com/fluxcd/flagger/blob/main/cmd/flagger/main.go
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# flagger: progressive delivery Kubernetes operator (fluxcd/flagger).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--master=[Kubernetes API server address]:url:' \
  '--metrics-server=[Prometheus URL]:url:' \
  '--log-level=[log level]:level:(debug info warning error)' \
  '--zap-encoding=[zap logger encoding]:encoding:(json console)' \
  '--zap-replace-globals[change global zap logger level]' \
  '--port=[port to listen on]:port:' \
  '--namespace=[namespace to watch for canary objects]:namespace:' \
  '--mesh-provider=[service mesh provider]:provider:(istio linkerd appmesh contour gloo nginx skipper traefik osm kuma gatewayapi)' \
  '--selector-labels=[pod labels for selectors]:labels:' \
  '--ingress-annotations-prefix=[annotations prefix for NGINX ingresses]:prefix:' \
  '--ingress-class=[ingress class for HTTPProxy objects]:class:' \
  '--include-label-prefix=[label prefixes to copy to primary deployments]:prefix:' \
  '--slack-url=[Slack hook URL]:url:' \
  '--slack-token=[Slack bot token]:token:' \
  '--slack-proxy-url=[Slack proxy URL]:url:' \
  '--slack-user=[Slack username]:user:' \
  '--slack-channel=[Slack channel]:channel:' \
  '--msteams-url=[Microsoft Teams incoming webhook URL]:url:' \
  '--msteams-proxy-url=[Microsoft Teams proxy URL]:url:' \
  '--event-webhook=[webhook for publishing flagger events]:url:' \
  '--enable-config-tracking[track ConfigMap and Secret changes]' \
  '--enable-leader-election[enable leader election]' \
  '--leader-election-namespace=[namespace for leader election]:namespace:' \
  '--kubeconfig-service-mesh=[kubeconfig for service mesh control plane]:file:_files' \
  '--cluster-name=[cluster name for alert messages]:name:' \
  '--control-loop-interval=[Kubernetes API sync interval]:duration:' \
  '--kubeconfig-qps=[kubeconfig QPS]:n:' \
  '--kubeconfig-burst=[kubeconfig burst]:n:' \
  '--threadiness=[worker concurrency]:n:' \
  '--no-cross-namespace-refs[restrict to same-namespace resources only]' && ret=0

return ret
