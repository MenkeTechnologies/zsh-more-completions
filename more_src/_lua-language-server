#compdef lua-language-server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--configpath=[path to config file]:config file:_files -g "*.lua"' \
  '--logpath=[path to log directory]:directory:_directories' \
  '--metapath=[path to meta directory]:directory:_directories' \
  '--locale=[set language locale]:locale:(en-us zh-cn zh-tw pt-br)' \
  '--loglevel=[set log level]:level:(trace debug info warn error fatal)' \
  '--check[run in check mode and exit]' \
  '--checklevel=[set check level for diagnostics]:level:(Error Warning Information Hint)' \
  '--doc=[run documentation generation]:directory:_directories' \
  '--doc_out_path=[documentation output path]:directory:_directories' \
  '--socket=[listen on socket port]:port' \
  '--develop[enable develop mode]' \
  '--dbgport=[debug port]:port' \
  '--dbgwait[wait for debugger]' \
  '--force-accept-workspace[force accept workspace]' \
  '*:workspace:_directories' && ret=0

return ret
