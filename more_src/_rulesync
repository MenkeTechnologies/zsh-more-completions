#compdef rulesync
# Documentation: https://man.archlinux.org/search?q=rulesync
# Reference accessed: 2026-05-16

# Zsh completion for rulesync — AI rules management

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-c --config)'{-c,--config}'[config]:file:_files' \
  '*:path:_files' && ret=0

return ret
