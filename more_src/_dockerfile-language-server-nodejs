#compdef dockerfile-language-server-nodejs docker-langserver

# Zsh completion for dockerfile-language-server-nodejs (Dockerfile Language Server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--stdio[use stdio transport]' \
  '--node-ipc[use node IPC transport]' \
  '--socket=[use socket transport on port]:port:' && ret=0

return ret
