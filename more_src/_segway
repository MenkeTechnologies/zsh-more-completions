#compdef segway
# Documentation: https://segway.readthedocs.io/en/latest/segway.html
# segway: semi-automated genome annotation with a dynamic Bayesian network

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--num-labels=[number of segment labels to use]:n:' \
  '--num-sublabels=[number of sublabels for hierarchical segmentation]:n:' \
  '*--track=[include only this track]:track:' \
  '--bed=[output location for segmentation results]:file:_files' \
  '--bigBed=[bigBed output file]:file:_files' \
  '--resolution=[downsample data to this resolution]:n:' \
  '--num-instances=[number of randomly-initialized model copies]:n:' \
  '--include-coords=[BED file of regions to include]:file:_files' \
  '--exclude-coords=[BED file of regions to exclude]:file:_files' \
  '--seg-table=[file of min/max segment lengths by label]:file:_files' \
  '--semisupervised=[BED file with supervision labels]:file:_files' \
  '--prior-strength=[strength of length prior relative to data]:float:' \
  '--segtransition-weight-scale=[strength of length prior]:float:' \
  '--ruler-scale=[ruler scale for duration model]:n:' \
  '--mem-usage=[gibibytes of memory to try allocating]:list:' \
  '--max-train-rounds=[maximum number of training rounds]:n:' \
  '--minibatch-fraction=[fraction of genome positions per training iteration]:float:' \
  '--cluster-opt=[pass option to cluster manager]:opt:' \
  '--dry-run[write files but do not run executables]' \
  '--structure=[custom model structure file]:file:_files' \
  '--input-master=[initial parameters file]:file:_files' \
  '--output-label=[output format]:label:(seg subseg full)' \
  '--distribution=[probability distribution]:dist:(norm asinh_norm gamma)' \
  '--mixture-components=[Gaussian mixture components per label]:n:' \
  '--var-floor=[variance floor for model]:float:' \
  '--validation-fraction=[held-out validation set fraction]:float:' \
  '--validation-coords=[BED file for validation coordinates]:file:_files' \
  '--split-sequences=[split sequences larger than this size]:n:' \
  '--virtual-evidence=[file of prior probabilities for labeled regions]:file:_files' \
  '--reverse-world=[world for reverse strand data]:n:' \
  '--dont-train=[file listing parameters not to train]:file:_files' \
  '--recover=[recover from interrupted training or annotation]:dir:_files -/' \
  '--verbosity=[message verbosity level]:n:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a cmds
    cmds=(
      'train:create a model with learned parameters'
      'annotate:label a genome using a model'
      'posterior:infer posterior probabilities of each label'
      'identify:label a genome using a model'
      'train-init:prepare initial models for parallel training'
      'train-run:train initial models to completion in parallel'
      'train-run-round:train models for one round in parallel'
      'train-finish:select best model and prepare for annotate'
      'annotate-init:prepare for parallel annotation'
      'annotate-run:annotate the genome in parallel'
      'annotate-finish:concatenate parallel annotation results'
      'posterior-init:prepare for parallel posterior inference'
      'posterior-run:infer posterior probabilities in parallel'
      'posterior-finish:concatenate parallel posterior results'
    )
    _describe -t commands 'segway task' cmds && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
