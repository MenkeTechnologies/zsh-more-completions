#compdef vshadowinfo vshadowmount
# _libvshadow — libvshadow tools (libyal Volume Shadow Copy parser; vshadowinfo dumps VSS metadata + per-snapshot info, vshadowmount FUSE-mounts every snapshot read-only as numbered directories; -h help, -V version, -v verbose, -o image offset, -p password, -X exclusive; positional argument is the NTFS volume image)
# upstream: https://github.com/libyal/libvshadow
# Flags from libyal/libvshadow vshadowtools/vshadowinfo.c on tip.

_libvshadow() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-p+[password]:password:' \
        '-X[exclusive]' \
        '*:image:_files'
}

_libvshadow "$@"
