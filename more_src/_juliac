#compdef juliac
# Documentation: https://man.archlinux.org/search?q=juliac
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '--sysimage=[system image]:file:_files' \
  '--compile=[compilation mode]:mode:(yes no all min)' \
  '--cpu-target=[target CPU]:cpu:' \
  '--optimize=[optimization level]:level:(0 1 2 3)' \
  '--debug-info=[debug info]:level:(0 1 2)' \
  '--inline=[inline limit]:limit:(yes no)' \
  '--check-bounds=[bounds checking]:check:(yes no auto)' \
  '--math-mode=[math mode]:mode:(ieee fast)' \
  '--trim=[trim unused code]:trim:(yes no safe unsafe)' \
  '--strip-ir[strip IR]' \
  '--strip-metadata[strip metadata]' \
  '-J+[pass option to Julia]:option:' \
  '*:Julia source file:_files -g "*.jl"' && ret=0

return ret
