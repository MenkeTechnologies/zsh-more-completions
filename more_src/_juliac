#compdef juliac
# Documentation: https://github.com/JuliaLang/JuliaC.jl/blob/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for juliac - Julia AOT compiler driver (JuliaLang/JuliaC.jl)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--output-exe=[output native executable name (no path)]:name:' \
  '--output-lib=[output path for shared library]:path:_files' \
  '--output-sysimage=[output path for system image]:path:_files' \
  '--output-o=[output path for object file]:path:_files' \
  '--output-bc=[output path for bitcode file]:path:_files' \
  '--project=[project to instantiate/precompile]:path:_files -/' \
  '--bundle=[copy required Julia libs/stdlibs/artifacts next to the output]:dir:_files -/' \
  '--trim=-[enable code trimming]::mode:(safe unsafe unsafe-warn no)' \
  '--compile-ccallable[export ccallable entrypoints]' \
  '--experimental[forwarded to Julia; required for --trim on some builds]' \
  '--verbose[print underlying commands and timing]' \
  '*:Julia entry file or package:_files' && ret=0

return ret
