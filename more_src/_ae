_ae() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_ae_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init|add)
                    _arguments '1:name:' && ret=0 ;;
                run|build|check)
                    _arguments '::Aether source file:_files -g "*.ae"' && ret=0 ;;
                test)
                    _arguments '::file or directory:_files' && ret=0 ;;
                lib-info)
                    _arguments '1:shared library path:_files -g "*.so *.dylib *.dll"' && ret=0 ;;
                help)
                    _arguments '::script:_files -g "*.ae"' && ret=0 ;;
                version)
                    _arguments \
                        '1::version subcommand:(list install use)' \
                        '*::arg:->ver_args'
                    case $state in
                        ver_args)
                            case $words[1] in
                                install|use)
                                    _arguments '1:version tag:' && ret=0 ;;
                                list)
                                    _arguments '*: :' && ret=0 ;;
                            esac ;;
                    esac
                    ;;
                cache|examples|cflags|lib-path|repl|fmt)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ae_commands] )) ||
_ae_commands() {
    local -a commands
    commands=(
        'init:create a new Aether project'
        'run:compile and run a program'
        'build:compile to executable'
        'check:type-check the program only'
        'test:run tests'
        'repl:start the interactive REPL'
        'fmt:format source code (not yet implemented)'
        'add:add a dependency'
        'cache:manage the local package cache'
        'examples:list bundled examples'
        'cflags:print C compiler flags that ae build would use'
        'lib-info:show AetherLibMeta symbol catalog from a --emit=lib library'
        'lib-path:show resolved module search path chain'
        'version:show / list / install / use Aether toolchain versions'
        'help:show top-level help or per-script diagnostics'
    )
    _describe -t commands 'ae command' commands
}

_ae "$@"
