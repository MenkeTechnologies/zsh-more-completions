#compdef envd
# Documentation: https://man.archlinux.org/search?q=envd
# Reference accessed: 2026-05-16

# Zsh completion for envd (urfave/cli)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--debug[verbose logs]' \
  '--analytics[enable telemetry]' \
  '--analytics-token[telemetry token]:token' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      bootstrap create completion context build destroy environment env image init login pause prune
      run resume up debug version top reference new
    )
    _describe -t commands 'envd command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
