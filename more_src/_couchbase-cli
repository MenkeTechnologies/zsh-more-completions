#compdef couchbase-cli

# Zsh completion for Couchbase CLI

_couchbase-cli() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'bucket-compact:compact a bucket'
    'bucket-create:create a new bucket'
    'bucket-delete:delete a bucket'
    'bucket-edit:edit an existing bucket'
    'bucket-flush:flush all data from a bucket'
    'bucket-list:list all buckets'
    'cluster-edit:edit cluster settings'
    'cluster-init:initialize a cluster'
    'collect-logs-start:start log collection'
    'collect-logs-status:get log collection status'
    'collect-logs-stop:stop log collection'
    'eventing-function-setup:manage eventing functions'
    'failover:failover a node'
    'group-manage:manage server groups'
    'host-list:list all nodes in the cluster'
    'master-password:manage master password'
    'node-init:initialize a node'
    'node-to-node-encryption:manage node-to-node encryption'
    'rebalance:rebalance the cluster'
    'rebalance-status:show rebalance status'
    'rebalance-stop:stop a rebalance'
    'recovery:recover a node'
    'reset-admin-password:reset the admin password'
    'server-add:add a node to the cluster'
    'server-info:show server info'
    'server-list:list servers in the cluster'
    'server-readd:re-add a node to the cluster'
    'setting-alert:set email alerts'
    'setting-audit:manage audit settings'
    'setting-autofailover:manage auto-failover settings'
    'setting-autoreprovision:manage auto-reprovision settings'
    'setting-cluster:manage cluster settings'
    'setting-compaction:manage compaction settings'
    'setting-index:manage index settings'
    'setting-ldap:manage LDAP settings'
    'setting-notification:manage notification settings'
    'setting-password-policy:manage password policy'
    'setting-rebalance:manage rebalance settings'
    'setting-security:manage security settings'
    'setting-xdcr:manage XDCR settings'
    'ssl-manage:manage SSL certificates'
    'user-manage:manage RBAC users'
    'xdcr-replicate:manage XDCR replications'
    'xdcr-setup:manage XDCR remote references'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'couchbase-cli command' commands && ret=0
      ;;
    (args)
      _arguments -s -S \
        '-c+[cluster address]:cluster:' \
        '--cluster=[cluster address]:cluster:' \
        '-u+[username]:username:' \
        '--username=[username]:username:' \
        '-p+[password]:password:' \
        '--password=[password]:password:' \
        '--client-cert=[client certificate]:cert:_files' \
        '--client-cert-password=[client certificate password]:password:' \
        '--client-key=[client key]:key:_files' \
        '--client-key-password=[client key password]:password:' \
        '--cacert=[CA certificate]:cert:_files' \
        '--no-ssl-verify[disable SSL verification]' \
        '--no-cb-verify[disable Couchbase certificate verification]' \
        '-o+[output format]:format:(json)' \
        '--output=[output format]:format:(json)' \
        '-d[debug mode]' \
        '--debug[debug mode]' \
        '-s[ssl]' \
        '--ssl[enable SSL]' \
        '--help[display help]' \
        '*:args:' \
        && ret=0
      ;;
  esac

  return ret
}

_couchbase-cli "$@"
