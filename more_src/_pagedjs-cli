#compdef pagedjs-cli
# Documentation: https://raw.githubusercontent.com/pagedjs/pagedjs-cli/master/README.md
# Paged.js CLI - render HTML to paginated PDF via Paged.js

local ret=1

_arguments -s -S \
  '(-i --inputs)'{-i,--inputs}'=[input HTML/URL]:input:_files' \
  '(-o --output)'{-o,--output}'=[output PDF path]:output:_files' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-l --landscape)'{-l,--landscape}'[landscape orientation]' \
  '(-s --page-size)'{-s,--page-size}'=[page size]:size' \
  '(-w --width)'{-w,--width}'=[print to page width]:width' \
  '(-h --height)'{-h,--height}'=[print to page height]:height' \
  '--forceTransparentBackground[force transparent background]' \
  '(-t --timeout)'{-t,--timeout}'=[timeout in ms]:ms' \
  '(-x --html)'{-x,--html}'[output html]' \
  '(-b --blockLocal)'{-b,--blockLocal}'[disallow access to local files]' \
  '(-r --blockRemote)'{-r,--blockRemote}'[disallow access to remote files]' \
  '*--allowedPath=[allow access to given local path]:path:_files' \
  '*--allowedDomain=[allow access to given remote domain]:domain' \
  '--outline-tags=[generate PDF outline from tags]:tags' \
  '--additional-script=[additional script to inject]:script:_files' \
  '--browserEndpoint=[browser websocket endpoint]:endpoint' \
  '--browserArgs=[comma-separated browser arguments]:args' \
  '--media=[emulate media type]:media:(print screen)' \
  '--style=[additional stylesheet]:style:_files' \
  '--warn[enable warning logging]' \
  '--extra-header=[extra HTTP header]:header' \
  '--disable-script-injection[disable Paged.js script injection]' \
  '--help[show help]' \
  '*:input:_files' && ret=0

return ret
