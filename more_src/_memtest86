#compdef memtest86 memtest86+
# Documentation: https://memtest.org/readme
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: memtest86+ is a bootable image, not an interactive CLI binary.
# Recognised boot-line parameters (passed via bootloader): console=,
# btrace, maxcpus=, onepass, tstlist=, cpumask=, keyboard=.

local curcontext="$curcontext" ret=1

_arguments -C \
  'console=[serial console spec]:tty:' \
  'btrace[enable boot trace]' \
  'maxcpus=[limit number of CPUs]:n:' \
  'onepass[run one pass and exit]' \
  'tstlist=[list of tests to run]:tests:' \
  'cpumask=[CPU selection mask]:mask:' \
  'keyboard=[keyboard mode]:mode:(legacy)' && ret=0

return ret
