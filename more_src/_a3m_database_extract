#compdef a3m_database_extract
# Documentation: https://github.com/soedinglab/hh-suite/wiki
# a3m_database_extract: extract a3m alignments from a packed ca3m ffindex database

local ret=1

_arguments -s -S \
  '-h[show usage]' \
  '-i+[ffindex ca3m database prefix]:prefix:_files' \
  '-o+[ffindex a3m database prefix]:prefix:_files' \
  '-d+[ffindex sequence database prefix]:prefix:_files' \
  '-q+[ffindex header database prefix]:prefix:_files' && ret=0

return ret
