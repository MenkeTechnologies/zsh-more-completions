#compdef simsearch
# Documentation: https://chemfp.readthedocs.io/en/latest/tools.html
# chemfp similarity search against a fingerprint database

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-k+[number of nearest neighbors]:k:' \
  '--threshold=[minimum similarity score]:value:' \
  '-q+[query fingerprint file]:file:_files' \
  '--queries=[read queries from structure or fingerprint file]:file:_files' \
  '--query=[structure string as query]:structure:' \
  '--query-format=[input structure format]:format:' \
  '--query-id=[custom query identifier]:id:' \
  '--NxN[use same fingerprints for queries and targets]' \
  '--out=[output format]:format:(csv tsv)' \
  '-o+[output file]:file:_files' \
  '--empty-target-id=[placeholder for queries with no hits]:value:' \
  '--empty-score=[score for empty results]:value:' \
  '--no-include-empty[omit output lines for queries without hits]' \
  '--times[display performance timing]' \
  '*:target file:_files' && ret=0

return ret
