#compdef pt-variable-advisor
# Documentation: https://docs.percona.com/percona-toolkit/pt-variable-advisor.html
# Analyze MySQL variables and advise on possible problems

local ret=1

_arguments -s -S \
  '(--help)--help[show help and exit]' \
  '(--version)--version[show version and exit]' \
  '--ask-pass[prompt for password when connecting to MySQL]' \
  '--buffer-stdout[enable STDOUT buffering]' \
  '--no-buffer-stdout[disable STDOUT buffering]' \
  '(-A --charset)'{-A,--charset=}'[set default character set]:charset' \
  '--config=[read this comma-separated list of config files]:files:_files' \
  '--daemonize[fork to background and detach from shell]' \
  '(-D --database)'{-D,--database=}'[connect to specified database]:database' \
  '(-F --defaults-file)'{-F,--defaults-file=}'[read MySQL options from given file only]:file:_files' \
  '(-h --host)'{-h,--host=}'[connect to specified host]:host:_hosts' \
  '--ignore-rules=[ignore specific comma-separated rule IDs]:rules' \
  '(-s --mysql_ssl)'{-s,--mysql_ssl=}'[create SSL MySQL connection]:value' \
  '(-p --password)'{-p,--password=}'[password for connection]:password' \
  '--pid=[create PID file at specified path]:file:_files' \
  '(-P --port)'{-P,--port=}'[port number for connection]:port' \
  '--set-vars=[set MySQL variables as variable=value pairs]:vars' \
  '--source-of-variables=[read SHOW VARIABLES from source]:source:(mysql none file)' \
  '(-u --user)'{-u,--user=}'[user for login]:user:_users' \
  '*'{-v,--verbose}'[increase output verbosity]' \
  '--version-check[enable version checking]' \
  '--no-version-check[disable version checking]' \
  '*:dsn or file:_files' && ret=0

return ret
