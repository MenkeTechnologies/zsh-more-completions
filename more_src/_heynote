#compdef heynote
# _heynote — Jon Aiken heynote dedicated scratchpad CLI for the multi-block CodeMirror-based developer scratch notebook with persistent buffer global hotkey and language-aware editing (heyman team, TypeScript/Electron); commander.js
# upstream: https://github.com/heyman/heynote

_heynote() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--no-tray[no tray icon]' \
        '--always-on-top[always on top]' \
        '--show-in-dock[show in dock]' \
        '--no-show-in-dock[no show in dock]' \
        '--hide-on-close[hide on close]' \
        '--theme=+[theme]:t:(light dark system)' \
        '--font-family=+[family]:str:' \
        '--font-size=+[size]:n:' \
        '--tab-spaces=+[N]:n:' \
        '--indent-with-spaces[indent with spaces]' \
        '--indent-with-tabs[indent with tabs]' \
        '--keymap=+[k]:k:(default emacs vim)' \
        '--metakey=+[k]:k:(control alt meta cmd ctrl)' \
        '--auto-update[auto update]' \
        '--no-auto-update[no auto update]' \
        '--buffer=+[file]:file:_files -g "*.txt *.md *.json *.js *.ts *.py *.rb *.go *.rs *.html *.css *.yaml *.toml"' \
        '*:buffer file:_files -g "*.txt *.md *.json *.js *.ts *.py *.rb *.go *.rs *.html *.css *.yaml *.toml"'
}

_heynote "$@"
