#compdef wlangenpmk
# Documentation: https://manpages.debian.org/unstable/hcxkeys/wlangenpmk.1.en.html
# wlangenpmk (hcxkeys) — generate plainmasterkeys from essid and password. Flags from upstream manpage OPTIONS.

local ret=1

_arguments -s -S \
  '-e+[input single essid (networkname 1..32 chars); requires -p or -i]:essid:' \
  '-p+[input single password (8..63 chars); requires -e]:password:' \
  '-i+[input passwordlist]:file:_files' \
  '-I+[input combilist (essid:password)]:file:_files' \
  '-a+[output plainmasterkeys as ASCII file (hash mode 2200x, 1680x, 250x)]:file:_files' \
  '-A+[output plainmasterkeys:password as ASCII file]:file:_files' \
  '-c+[output cowpatty hashfile (existing file will be replaced)]:file:_files' \
  '-h[this help]' \
  && ret=0

return ret
