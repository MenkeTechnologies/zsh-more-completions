#compdef katana
# Documentation: https://github.com/projectdiscovery/katana/blob/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream katana README flag reference.
# Fixed from prior file: corrected goflags short/long names
# (-jc/-js-crawl, -hl/-headless, -jsl, -f/-field, -sf/-store-field,
# -fs/-field-scope, -em/-extension-match), removed invented
# clap-style {-u,--url} pairings and fake -system-chrome long forms.

# katana: next-generation crawling and spidering framework

_arguments -s -S \
  '(-u -list)'{-u,-list}'+[target URL/list to crawl]:target:' \
  '-resume+[resume scan using resume.cfg]:file:_files' \
  '(-e -exclude)'{-e,-exclude}'+[exclude host matching specified filter]:filter:' \
  '(-r -resolvers)'{-r,-resolvers}'+[list of custom resolvers]:resolvers:' \
  '(-d -depth)'{-d,-depth}'+[maximum depth to crawl]:depth:' \
  '(-jc -js-crawl)'{-jc,-js-crawl}'[enable endpoint parsing/crawling in JavaScript file]' \
  '(-jsl -jsluice)'{-jsl,-jsluice}'[enable jsluice parsing in JavaScript file]' \
  '(-ct -crawl-duration)'{-ct,-crawl-duration}'+[maximum duration to crawl the target]:duration:' \
  '(-kf -known-files)'{-kf,-known-files}'+[enable crawling of known files]:mode:(all robotstxt sitemapxml)' \
  '(-mrs -max-response-size)'{-mrs,-max-response-size}'+[maximum response size to read]:bytes:' \
  '-timeout+[time to wait for request in seconds]:seconds:' \
  '(-aff -automatic-form-fill)'{-aff,-automatic-form-fill}'[enable automatic form filling]' \
  '(-fx -form-extraction)'{-fx,-form-extraction}'[extract form, input, textarea & select elements]' \
  '-retry+[number of times to retry the request]:count:' \
  '-proxy+[http/socks5 proxy to use]:proxy:' \
  '(-td -tech-detect)'{-td,-tech-detect}'[enable technology detection]' \
  '*'{-H,-headers}'+[custom header/cookie to include in all http request]:header:' \
  '-config+[path to the katana configuration file]:file:_files' \
  '(-fc -form-config)'{-fc,-form-config}'+[path to custom form configuration file]:file:_files' \
  '(-flc -field-config)'{-flc,-field-config}'+[path to custom field configuration file]:file:_files' \
  '(-s -strategy)'{-s,-strategy}'+[visit strategy]:strategy:(depth-first breadth-first)' \
  '(-iqp -ignore-query-params)'{-iqp,-ignore-query-params}'[ignore crawling same path with different query-param values]' \
  '(-tlsi -tls-impersonate)'{-tlsi,-tls-impersonate}'[enable experimental client hello (ja3) tls randomization]' \
  '(-dr -disable-redirects)'{-dr,-disable-redirects}'[disable following redirects]' \
  '(-hl -headless)'{-hl,-headless}'[enable headless hybrid crawling]' \
  '(-sc -system-chrome)'{-sc,-system-chrome}'[use local installed Chrome browser]' \
  '(-sb -show-browser)'{-sb,-show-browser}'[show the browser on the screen with headless mode]' \
  '*'{-ho,-headless-options}'+[start headless chrome with additional options]:options:' \
  '(-nos -no-sandbox)'{-nos,-no-sandbox}'[start headless chrome in --no-sandbox mode]' \
  '(-cdd -chrome-data-dir)'{-cdd,-chrome-data-dir}'+[path to store chrome browser data]:dir:_files -/' \
  '(-scp -system-chrome-path)'{-scp,-system-chrome-path}'+[use specified chrome browser binary]:path:_files' \
  '(-noi -no-incognito)'{-noi,-no-incognito}'[start headless chrome without incognito mode]' \
  '(-cwu -chrome-ws-url)'{-cwu,-chrome-ws-url}'+[use chrome browser instance launched elsewhere]:url:' \
  '(-xhr -xhr-extraction)'{-xhr,-xhr-extraction}'[extract xhr request url/method in jsonl output]' \
  '*'{-cs,-crawl-scope}'+[in scope url regex to be followed]:regex:' \
  '*'{-cos,-crawl-out-scope}'+[out of scope url regex to be excluded]:regex:' \
  '(-fs -field-scope)'{-fs,-field-scope}'+[pre-defined scope field]:scope:(dn rdn fqdn)' \
  '(-ns -no-scope)'{-ns,-no-scope}'[disables host based default scope]' \
  '(-do -display-out-scope)'{-do,-display-out-scope}'[display external endpoint from scoped crawling]' \
  '*'{-mr,-match-regex}'+[regex or list of regex to match on output url]:regex:' \
  '*'{-fr,-filter-regex}'+[regex or list of regex to filter on output url]:regex:' \
  '(-f -field)'{-f,-field}'+[field to display in output]:field:(url path fqdn rdn rurl qurl qpath file ufile key value kv dir udir)' \
  '(-sf -store-field)'{-sf,-store-field}'+[field to store in per-host output]:field:(url path fqdn rdn rurl qurl qpath file ufile key value kv dir udir)' \
  '*'{-em,-extension-match}'+[match output for given extension]:extensions:' \
  '*'{-ef,-extension-filter}'+[filter output for given extension]:extensions:' \
  '(-mdc -match-condition)'{-mdc,-match-condition}'+[match response with dsl based condition]:condition:' \
  '(-fdc -filter-condition)'{-fdc,-filter-condition}'+[filter response with dsl based condition]:condition:' \
  '(-c -concurrency)'{-c,-concurrency}'+[number of concurrent fetchers to use]:count:' \
  '(-p -parallelism)'{-p,-parallelism}'+[number of concurrent inputs to process]:count:' \
  '(-rd -delay)'{-rd,-delay}'+[request delay between each request in seconds]:seconds:' \
  '(-rl -rate-limit)'{-rl,-rate-limit}'+[maximum requests to send per second]:rate:' \
  '(-rlm -rate-limit-minute)'{-rlm,-rate-limit-minute}'+[maximum number of requests to send per minute]:rate:' \
  '(-o -output)'{-o,-output}'+[file to write output to]:file:_files' \
  '(-sr -store-response)'{-sr,-store-response}'[store http requests/responses]' \
  '(-srd -store-response-dir)'{-srd,-store-response-dir}'+[store http requests/responses to custom directory]:dir:_files -/' \
  '(-or -omit-raw)'{-or,-omit-raw}'[omit raw requests/responses from jsonl output]' \
  '(-ob -omit-body)'{-ob,-omit-body}'[omit response body from jsonl output]' \
  '(-j -jsonl)'{-j,-jsonl}'[write output in jsonl format]' \
  '(-nc -no-color)'{-nc,-no-color}'[disable output content coloring (ANSI escape codes)]' \
  '-silent[display output only]' \
  '(-v -verbose)'{-v,-verbose}'[display verbose output]' \
  '-debug[display debug output]' \
  '-version[display project version]'
