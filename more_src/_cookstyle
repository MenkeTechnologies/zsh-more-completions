#compdef cookstyle
# Documentation: https://docs.chef.io/workstation/cookstyle/
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  {-v,--version}'[display version]' \
  '--auto-correct[auto-correct offenses (safe only)]' \
  '--auto-correct-all[auto-correct offenses (safe and unsafe)]' \
  {-a,--autocorrect}'[auto-correct offenses (safe only)]' \
  {-A,--autocorrect-all}'[auto-correct offenses (safe and unsafe)]' \
  '--parallel[run in parallel using available CPUs]' \
  {-f,--format}'[output format]:format:(progress simple clang fuubar json html pacman emacs files offenses worst tap junit markdown github quiet)' \
  {-o,--out}'[write output to file]:output file:_files' \
  '--display-cop-names[display cop names in output]' \
  '--no-display-cop-names[do not display cop names in output]' \
  {-l,--lint}'[run only lint cops]' \
  {-x,--fix-layout}'[run only layout cops with auto-correct]' \
  '--safe-auto-correct[run safe auto-corrections only]' \
  '--only[run only the specified cops]:cops' \
  '--except[exclude the specified cops]:cops' \
  {-c,--config}'[specify configuration file]:config file:_files' \
  '--force-default-config[use default configuration and ignore project config]' \
  {-d,--debug}'[display debug information]' \
  {-D,--display-all-cops}'[display all available cops]' \
  '--list-target-files[list all target files]' \
  {-L,--show-cops}'[show available cops and their configuration]' \
  '--show-docs[show documentation URL for cops]' \
  {-r,--require}'[require Ruby file]:Ruby file:_files -g "*.rb"' \
  {-s,--stdin}'[read source from stdin]:file name' \
  {-S,--display-style-guide}'[display style guide URLs in output]' \
  {-E,--extra-details}'[display extra details in output]' \
  '--fail-level[minimum severity for exit with error code]:severity:(info refactor convention warning error fatal)' \
  '--force-exclusion[force excluding files specified in config]' \
  '--no-color[disable color output]' \
  '--color[force color output]' \
  '*:file or directory:_files' \
  && return 0
