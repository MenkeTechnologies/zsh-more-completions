#compdef sfdepth2time
# Documentation: http://www.ahay.org/RSF/sfdepth2time.html
# Madagascar: depth-to-time conversion in V(z) media

local ret=1

_arguments -s \
  'velocity=[auxiliary velocity input file]:file:_files' \
  'nt=[number of time samples (default n1)]:nt' \
  'dt=[time sampling (default d1)]:dt' \
  't0=[time origin]:t0' \
  'slow=[y for slowness, n for velocity]:flag:(y n)' \
  'eps=[smoothness parameter]:eps' \
  '*:rsf file:_files' && ret=0

return ret
