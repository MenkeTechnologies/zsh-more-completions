#compdef nats-replicator
# _nats-replicator — replicate messages between NATS systems (nats-io/nats-replicator)
# upstream: https://github.com/nats-io/nats-replicator
# Flags from main.go (flag).

_nats-replicator() {
    _arguments \
        '-c+[configuration file]:file:_files' \
        '-D[turn on debug logging]' \
        '-V[turn on verbose logging]' \
        '-DV[debug and verbose logging]'
}

_nats-replicator "$@"
