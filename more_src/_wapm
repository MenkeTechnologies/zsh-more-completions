#compdef wapm
# Documentation: https://man.archlinux.org/search?q=wapm
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install a package'
  'list:list installed packages'
  'uninstall:remove a package'
  'config:show config'
  'login:login to wapm'
  'logout:logout'
  'whoami:print user'
  'init:initialize wapm.toml'
  'publish:publish package'
  'add:add dependency'
  'remove:remove dependency'
  'completions:print completions'
  'execute:execute a command'
  'run:run package binary'
  'search:search packages'
  'bin:print bin path'
  'keys:manage signing keys'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wapm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '(-g --global)'{-g,--global}'[install globally]' \
          '*: :' && ret=0 ;;
      (publish)
        _arguments \
          '--dry-run[dry run]' \
          '*: :' && ret=0 ;;
      (completions)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
