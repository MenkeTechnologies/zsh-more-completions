#compdef gif2ndf
# Documentation: https://starlink.eao.hawaii.edu/docs/sun55.htx/sun55ss7.html
# CONVERT GIF2NDF - convert a GIF file into an NDF

local ret=1

_arguments -C \
  'IN=[GIF file to be converted]:GIF file:_files -g "*.gif"' \
  'OUT=[output NDF to be generated]:NDF file:_files' \
  '*:GIF file:_files -g "*.gif"' && ret=0

return ret
