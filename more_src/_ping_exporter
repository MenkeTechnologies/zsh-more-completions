#compdef ping_exporter
# Documentation: https://github.com/czerwonk/ping_exporter
# Prometheus exporter for ICMP echo (ping) round-trip metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--version[print version information]' \
  '--web.listen-address=[address on which to expose metrics and web interface]:addr' \
  '--web.telemetry-path=[path under which to expose metrics]:path' \
  '--web.token=[token in HTTP request headers required to expose metrics]:token' \
  '--web.tls.enabled[enable TLS for web server]' \
  '--web.tls.cert-file=[certificate file for the web server]:file:_files' \
  '--web.tls.key-file=[key file for the web server]:file:_files' \
  '--web.tls.mutual-auth-enabled[enable TLS client mutual authentication]' \
  '--web.tls.ca-file=[CA file for client certificate verification]:file:_files' \
  '--config.path=[path to config file]:file:_files' \
  '--ping.interval=[interval for ICMP echo requests]:dur' \
  '--ping.timeout=[timeout for ICMP echo request]:dur' \
  '--ping.size=[payload size for ICMP echo requests]:size' \
  '--ping.fw-mark=[set socket mark (SO_MARK) to this value]:mark' \
  '--ping.history-size=[number of results to remember per target]:n' \
  '--dns.refresh=[interval for refreshing DNS records (0 disables)]:dur' \
  '--dns.nameserver=[DNS server used to resolve target hostnames]:server' \
  '--dns.timeout=[timeout for DNS resolution]:dur' \
  '--options.disable-ipv6[disable resolving IPv6 AAAA records]' \
  '--options.disable-ipv4[disable resolving IPv4 A records]' \
  '--log.level=[only log messages with given severity or above]:level:(debug info warn error fatal)' \
  '--metrics.deprecated=[enable or disable deprecated metrics]:choice:(enable disable)' \
  '--metrics.rttunit=[export ping results unit]:unit:(s ms both)' && ret=0

return ret
