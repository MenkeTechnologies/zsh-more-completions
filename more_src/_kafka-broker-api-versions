# Reference accessed: 2026-05-16
# Verified: Confluent Kafka tools reference for
# kafka.admin.BrokerApiVersionsCommand.
# Removed from prior file: bogus man.archlinux.org search URL.

# kafka-broker-api-versions: show Kafka broker API versions
local curcontext="$curcontext" ret=1
_arguments -C \
  '--bootstrap-server[REQUIRED: comma-separated broker list]:host\:port,...:' \
  '--command-config[property file for Admin Client config]:file:_files' \
  '--help[show usage]' \
  '--version[show version]' && ret=0
return ret
