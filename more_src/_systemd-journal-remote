#compdef systemd-journal-remote
# Documentation: https://man7.org/linux/man-pages/man8/systemd-journal-remote.8.html
# Reference accessed: 2026-05-21
# Verified: upstream systemd-journal-remote(8) manpage.
# Removed: --write-buffer-size (not documented).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--url=[remote URL to fetch from]:url:' \
  '--getter=[program to retrieve journal data]:cmd:' \
  '--listen-raw=[listen address for raw journal stream]:addr:' \
  '--listen-http=[listen address for HTTP]:addr:' \
  '--listen-https=[listen address for HTTPS]:addr:' \
  '--key=[SSL secret key file (PEM)]:file:_files' \
  '--cert=[SSL certificate file (PEM)]:file:_files' \
  '--trust=[CA certificate file (PEM) or "all"]:file:_files' \
  '(-o --output)'{-o,--output}'=[output file or directory]:file:_files' \
  '--compress=[enable XZ compression]:flag:(yes no)' \
  '--seal=[apply forward-secure sealing]:flag:(yes no)' \
  '--gnutls-log=[GnuTLS log categories]:categories:' \
  '--split-mode=[split journal files]:mode:(none host)' \
  '*:input:_files' && ret=0

return ret
