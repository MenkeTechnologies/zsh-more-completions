#compdef vspaero
# Documentation: https://github.com/OpenVSP/OpenVSP/blob/main/src/vsp_aero/Solver/vspaero.C
# VSPAERO - OpenVSP vortex-lattice / panel aerodynamic solver

local ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '(- *)-v[show version]' \
  '(- *)-version[show version]' \
  '-omp[use N processes]:number of processes:' \
  '-stab[calculate stability derivatives]' \
  '-pstab[unsteady roll rate stability derivative analysis]' \
  '-qstab[unsteady pitch rate stability derivative analysis]' \
  '-rstab[unsteady yaw rate stability derivative analysis]' \
  '-acstab[stability derivative analysis]' \
  '-fs[set/override freestream Mach, Alpha, Beta lists]' \
  '-save[save restart file]' \
  '-restart[restart analysis]' \
  '-geom[process and write geometry without solving]' \
  '-fem[load in FEM deformation file]' \
  '-write2dfem[write out 2D FEM load file]' \
  '-groundheight[ground effects analysis at cg height H]:height:' \
  '-rotor[rotor analysis at specified RPM]:rpm:' \
  '-unsteady[run an unsteady analysis (needs .groups file)]' \
  '-interrogate[reload existing solution and interrogate survey points]' \
  '-trim[trim analysis]' \
  '-adjoint[adjoint analysis]' \
  '-implicit[implicit solve]' \
  '-fdtest[finite-difference test]' \
  '-fileinputs[read inputs from file]' \
  '-writetecplot[write Tecplot output]' \
  '-wtf[write to file]' \
  '*:case file name:_files' && ret=0

return ret
