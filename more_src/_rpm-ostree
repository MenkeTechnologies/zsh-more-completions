#compdef rpm-ostree

# Zsh completion for rpm-ostree - hybrid image/package system

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'compose:commands to compose a tree'
  'cleanup:clear cached/pending data'
  'db:commands to query RPM database'
  'deploy:deploy a specific commit'
  'rebase:switch to a different tree'
  'rollback:revert to previously booted tree'
  'status:get deployment status'
  'upgrade:perform system upgrade'
  'reload:reload configuration'
  'cancel:cancel pending transaction'
  'initramfs:enable/disable local initramfs regeneration'
  'initramfs-etc:manage dracut config overlays'
  'install:overlay additional packages'
  'uninstall:remove overlayed packages'
  'override:manage base package overrides'
  'reset:remove all mutations'
  'refresh-md:generate rpm repo metadata'
  'kargs:query or modify kernel arguments'
  'ex:experimental commands'
  'apply-live:apply changes to booted deployment'
  'usroverlay:apply a transient writable overlayfs on /usr'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'rpm-ostree command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      install)
        _arguments \
          '--idempotent[do nothing if package already installed]' \
          '--uninstall[also uninstall a package]:package' \
          '--allow-inactive[allow inactive requests]' \
          '(-n --dry-run)'{-n,--dry-run}'[just print transaction]' \
          '--apply-live[apply changes to booted deployment]' \
          '--reboot[reboot after operation]' \
          '*:package' && ret=0
        ;;
      uninstall)
        _arguments \
          '--install[also install a package]:package' \
          '(-n --dry-run)'{-n,--dry-run}'[just print transaction]' \
          '--apply-live[apply changes to booted deployment]' \
          '--reboot[reboot after operation]' \
          '*:package' && ret=0
        ;;
      upgrade)
        _arguments \
          '--check[just check for updates]' \
          '--preview[preview update]' \
          '(-r --reboot)'{-r,--reboot}'[reboot after upgrade]' \
          '--cache-only[do not download, use cache only]' \
          '--download-only[just download, do not deploy]' \
          '(-n --dry-run)'{-n,--dry-run}'[just print transaction]' && ret=0
        ;;
      rebase)
        _arguments \
          '--skip-purge[do not purge old deployments]' \
          '--reboot[reboot after rebase]' \
          '--cache-only[use cache only]' \
          '--download-only[download only]' \
          '1:refspec' && ret=0
        ;;
      rollback)
        _arguments \
          '(-r --reboot)'{-r,--reboot}'[reboot after rollback]' && ret=0
        ;;
      status)
        _arguments \
          '--verbose[more verbose output]' \
          '--json[output as JSON]' \
          '--jsonpath[filter JSON output]:expression' \
          '(-b --booted)'{-b,--booted}'[only print booted deployment]' \
          '--pending-exit-77[exit 77 if pending deployment exists]' && ret=0
        ;;
      kargs)
        _arguments \
          '--editor[open editor]' \
          '--append[append kernel arg]:arg=value' \
          '--replace[replace kernel arg]:arg=value' \
          '--delete[delete kernel arg]:arg' \
          '--import-proc-cmdline[import from /proc/cmdline]' \
          '--deploy-index[operate on deployment index]:index' && ret=0
        ;;
    esac
    ;;
esac

return ret
