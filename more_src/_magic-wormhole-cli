#compdef magic-wormhole-cli wormhole
# _magic-wormhole-cli — Brian Warner magic-wormhole secure file transfer between computers CLI alias (magic-wormhole team, Python); click
# upstream: https://github.com/magic-wormhole/magic-wormhole

_magic-wormhole-cli() {
    local -a sub=(
        'send:send a file or directory'
        'receive:receive a file or directory'
        'ssh:ssh helper commands'
        'ssh accept:accept ssh wormhole'
        'ssh invite:invite via ssh wormhole'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--appid=+[application id]:str:' \
        '--relay-url=+[url]:url:_urls' \
        '--transit-helper=+[helper]:str:' \
        '--dump-timing=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wormhole subcommand' sub ;;
        args)
            case $words[1] in
                send) _arguments \
                    '--code=+[code]:str:' \
                    '--code-length=+[length]:n:' \
                    '-c+[length]:n:' \
                    '--text=+[text]:str:' \
                    '--ignore-unsendable-files[ignore unsendable]' \
                    '--qr[show QR code]' \
                    '--hide-progress[hide progress]' \
                    '--no-listen[no listen]' \
                    '--verify[verify before send]' \
                    '--tor[use Tor]' \
                    '--launch-tor[launch Tor]' \
                    '--tor-control-port=+[port]:port:' \
                    '*:file or dir:_files' ;;
                receive) _arguments \
                    '--output-file=+[file]:file:_files' \
                    '-o+[file]:file:_files' \
                    '--verify[verify before accept]' \
                    '--accept-file[auto accept]' \
                    '--only-text[only text]' \
                    '--tor[use Tor]' \
                    '--launch-tor[launch Tor]' \
                    '--tor-control-port=+[port]:port:' \
                    '*:code:' ;;
                ssh:accept|ssh:invite) _arguments \
                    '--key-file=+[file]:file:_files' \
                    '--user=+[user]:_users' ;;
            esac
            ;;
    esac
}

_magic-wormhole-cli "$@"
