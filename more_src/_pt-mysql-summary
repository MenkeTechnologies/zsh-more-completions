#compdef pt-mysql-summary
# Documentation: https://docs.percona.com/percona-toolkit/pt-mysql-summary.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--all-databases[run mysqldump and summarize all databases]' \
  '--ask-pass[prompt for password]' \
  '--config=[config file]:config file:_files' \
  '--databases=[databases to inspect]:databases:' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--list-encrypted-tables[include list of encrypted tables]' \
  '--password=[MySQL password]:password:' \
  '--port=[MySQL port]:port:' \
  '--read-samples=[read saved samples]:directory:_directories' \
  '--save-samples=[save samples to directory]:directory:_directories' \
  '--sleep=[sleep time for sampling]:seconds:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--user=[MySQL user]:username:' && ret=0

return ret
