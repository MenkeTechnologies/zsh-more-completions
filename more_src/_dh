#compdef dh
# Documentation: https://manpages.debian.org/dh
# Source: Debian/debhelper dh + lib/Debian/Debhelper/Dh_Getopt.pm — debhelper command sequencer (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*--with=-[load debhelper addon]:addon:_default' \
    '*--without=-[disable debhelper addon]:addon:_default' \
    '(-l --list)'{-l,--list}'[list available addons]' \
    '--no-act[show what would be done]' \
    '(--no-parallel)--parallel[enable parallel building]' \
    '(--parallel)--no-parallel[disable parallel building]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a -arch)'{-a,-arch}'[only operate on arch-dep packages]' \
    '(-i -indep)'{-i,-indep}'[only operate on arch-indep packages]' \
    '-A[apply to all files in -p packages]' \
    '*-p+[apply to named package]:pkg:_default' \
    '*-N+[exclude named package]:pkg:_default' \
    '*-X+[exclude files matching item]:item:_default' \
    '--name=-[suffix for debhelper files]:name:_default' \
    '--dbg-package=-[name of debug package]:pkg:_default' \
    '--error-handler=-[error handler]:handler:_default' \
    '--mainpackage=-[main binary package]:pkg:_default' \
    '--remaining-packages[only act on packages not yet handled]' \
    '*--exclude=-[exclude file pattern]:pattern:_default' \
    '*-O+[option to pass to subordinate dh_*]:opt:_default' \
    '*-u+[option pass-through]:opt:_default' \
    '-d[swap arch/indep semantics]' \
    '-o[output as in old style]' \
    '-n[no install]' \
    '-s[same-arch]' \
    '--same-arch[same architecture]' \
    '--no-scripts[do not run scripts]' \
    '--only-scripts[only run scripts]' \
    '1:sequence:(clean build build-arch build-indep install install-arch install-indep binary binary-arch binary-indep)' \
    '*::passthrough:_default' \
    && ret=0

return ret
