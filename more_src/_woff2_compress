#compdef woff2_compress
# Documentation: https://github.com/google/woff2
# Reference accessed: 2026-05-21
# Verified: upstream main() accepts only one positional input filename, no flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:TTF/OTF font:_files -g "*.(ttf|otf)(-.)"' && ret=0

return ret
