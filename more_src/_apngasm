#compdef apngasm
# _apngasm — animated PNG assembler (apngasm/apngasm)
# upstream: https://github.com/apngasm/apngasm
# Flags from cli/src/options.cpp (boost::program_options).

_apngasm() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-d --delay)'{-d+,--delay=}'[default frame delay (ms or fraction)]:ms:' \
        '(-l --loops)'{-l+,--loops=}'[loop count (0 = infinite)]:n:' \
        '(-f --file)'{-f+,--file=}'[animation directive file]:file:_files -g "*.(xml|json)"' \
        '(-s --skip)'{-s,--skip}'[skip the first frame]' \
        '(-D --disassemble)'{-D+,--disassemble=}'[disassemble file]:file:_files -g "*.png"' \
        '(-o --output)'{-o+,--output=}'[output APNG file]:file:_files -g "*.png"' \
        '(-j --json)'{-j+,--json=}'[output JSON file]:file:_files -g "*.json"' \
        '(-x --xml)'{-x+,--xml=}'[output XML file]:file:_files -g "*.xml"' \
        '(-n --nooverwrite -i --interactive -F --force)'{-n,--nooverwrite}'[exit when overwrite needed]' \
        '(-n --nooverwrite -i --interactive -F --force)'{-i,--interactive}'[prompt before overwrite (default)]' \
        '(-n --nooverwrite -i --interactive -F --force)'{-F,--force}'[always overwrite]' \
        '*:frame PNG files:_files -g "*.png"'
}

_apngasm "$@"
