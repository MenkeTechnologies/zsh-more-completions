#compdef clipman

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'store:listen for clipboard changes and store them'
      'pick:pick an item from clipboard history'
      'clear:clear clipboard history'
      'restore:restore last stored item to clipboard'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (store)
        _arguments \
          '--max-items+[max number of items]:count:' \
          '--histpath+[path to history file]:file:_files' \
          '--no-persist[do not persist history to disk]' \
          '--unix[trim whitespace]' && ret=0
        ;;
      (pick)
        _arguments \
          '--tool+[selector tool to use]:tool:(wofi dmenu rofi bemenu STDOUT CUSTOM)' \
          '--tool-args+[arguments for the selector tool]:args:' \
          '--max-items+[max number of items to show]:count:' \
          '--histpath+[path to history file]:file:_files' \
          '--print0[separate items with null bytes]' && ret=0
        ;;
      (clear)
        _arguments \
          '--histpath+[path to history file]:file:_files' \
          '--all[clear entire history]' && ret=0
        ;;
    esac
    ;;
esac

return ret
