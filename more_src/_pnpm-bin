#compdef pnpm
# _pnpm-bin — pnpm fast disk-space-efficient package manager (Zoltan Kochan); content-addressable store with hard-linked node_modules
# upstream: https://github.com/pnpm/pnpm

_pnpm-bin() {
    local -a sub=(
        'add:add dependency'
        'install:install all'
        'i:alias for install'
        'update:update deps'
        'up:alias for update'
        'remove:remove dependency'
        'rm:alias for remove'
        'audit:audit dependencies'
        'cat-file:print file content from store'
        'cat-index:print index from store'
        'config:get/set config'
        'create:create new project from template'
        'deploy:deploy a workspace'
        'dlx:run package without installing'
        'doctor:diagnose env'
        'env:install + manage Node.js versions'
        'exec:run installed binary'
        'fetch:fetch packages into store'
        'find-hash:find package by hash'
        'help:show help'
        'import:import npm/yarn/bun lockfile'
        'init:create package.json'
        'install-test:install + test'
        'link:link to global / file path'
        'list:list installed packages'
        'ls:alias for list'
        'licenses:list licenses'
        'outdated:show outdated packages'
        'pack:create tarball'
        'patch:create patch'
        'patch-commit:commit patch'
        'patch-remove:remove patch'
        'prune:prune extraneous'
        'publish:publish package'
        'rebuild:rebuild native modules'
        'recursive:run command across workspaces'
        'root:print install root'
        'run:run script'
        'self-update:update pnpm itself'
        'serve:serve registry locally'
        'setup:add pnpm to PATH'
        'start:run start script'
        'store:store commands'
        'test:run test script'
        'unlink:unlink linked package'
        'why:explain why installed'
        'workspace:run command in workspace'
        'completion:print completion'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-C --dir)'{-C,--dir}'+[run as if in dir]:dir:_files -/' \
        '(-w --workspace-root)'{-w,--workspace-root}'[run at workspace root]' \
        '--filter+[filter packages]:filter:' \
        '--filter-prod+[filter prod]:filter:' \
        '--silent[silent]' \
        '--loglevel+[log level]:level:(debug info warn error)' \
        '--reporter+[reporter]:reporter:(default append-only ndjson silent)' \
        '--use-stderr[log to stderr]' \
        '--shamefully-hoist[hoist all transitively]' \
        '--ignore-workspace[ignore workspace]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pnpm subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '(-D --save-dev)'{-D,--save-dev}'[devDep]' \
                    '(-P --save-prod)'{-P,--save-prod}'[prodDep]' \
                    '(-O --save-optional)'{-O,--save-optional}'[optionalDep]' \
                    '(-g --global)'{-g,--global}'[global]' \
                    '(-E --save-exact)'{-E,--save-exact}'[exact version]' \
                    '--save-peer[peerDep]' \
                    '--save-workspace-protocol[use workspace:]' \
                    '--workspace[workspace package]' \
                    '*:package:' ;;
                install|i) _arguments \
                    '--frozen-lockfile[no lockfile changes]' \
                    '--no-frozen-lockfile[allow lockfile changes]' \
                    '--prefer-frozen-lockfile[prefer frozen]' \
                    '--lockfile-only[only update lockfile]' \
                    '(-P --prod)'{-P,--prod}'[only prod deps]' \
                    '(-D --dev)'{-D,--dev}'[only dev deps]' \
                    '--no-optional[skip optional]' \
                    '--offline[offline]' \
                    '--prefer-offline[prefer offline]' ;;
                update|up) _arguments \
                    '(-r --recursive)'{-r,--recursive}'[recursive]' \
                    '(-L --latest)'{-L,--latest}'[upgrade to latest]' \
                    '(-i --interactive)'{-i,--interactive}'[interactive]' \
                    '(-g --global)'{-g,--global}'[global]' \
                    '--workspace[workspace]' \
                    '*:package:' ;;
                workspace) _arguments '1:workspace:' '*:cmd:' ;;
                recursive) _arguments '1:recursive cmd:(add install update remove list outdated rebuild run unlink exec why)' '*:args:' ;;
                store) _arguments '1:store cmd:(status prune add path)' '*:args:' ;;
                env) _arguments '1:env cmd:(use add list remove)' '*:args:' ;;
                run|exec|dlx) _arguments '*::cmd:' ;;
            esac
            ;;
    esac
}

_pnpm-bin "$@"
