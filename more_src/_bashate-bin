#compdef bashate
# _bashate-bin — bashate Bash style enforcer (OpenStack, Python); PEP-8-style checker for Bash scripts
# upstream: https://opendev.org/openstack/bashate

_bashate-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-i --ignore)'{-i,--ignore}'+[error codes to ignore]:codes:' \
        '(-e --error)'{-e,--error}'+[error codes to treat as errors]:codes:' \
        '(-w --warn)'{-w,--warn}'+[error codes to treat as warnings]:codes:' \
        '(-s --max-line-length)'{-s,--max-line-length}'+[max line length]:n:' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '*:file:_files -g "*.(sh|bash)"'
}

_bashate-bin "$@"
