#compdef tplist tplist-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/tplist.py argparse)
# Reference accessed: 2026-05-29
# tplist — display kernel tracepoints and USDT probes (BCC/eBPF). Useful for discovering trace targets.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[list USDT probes in the specified process]:pid:_pids' \
  '(-l --lib)'{-l,--lib=}'[list USDT probes in the specified library or executable]:path:_files' \
  '*-v[increase verbosity (print variables, arguments, etc.; stackable)]' \
  '1:filter (regex of probes/tracepoints to print, optional):' \
  && ret=0

return ret
