#compdef kubectl-relay
# Documentation: https://github.com/knight42/kubectl-relay
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace' \
  '--context=[kube context]:context' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '1:subcommand:(client server)' \
  '*: : _default'
