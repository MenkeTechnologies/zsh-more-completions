#compdef kubectl-relay
# Documentation: https://github.com/knight42/krelay
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-relay (krelay): forward TCP/UDP traffic to a pod/svc/IP/host.
# It uses kubectl-style global flags; no client/server subcommands.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-l --address)'{-l+,--address=}'[address to listen on]:address:' \
  '(-f --file)'{-f+,--file=}'[forward traffic to targets specified in file]:file:_files' \
  '(-p --patch)'{-p+,--patch=}'[merge patch to apply to krelay-server pod]:patch:' \
  '--patch-file=[file containing merge patch for krelay-server pod]:file:_files' \
  '--server.image=[krelay-server image]:image:' \
  '-v+[log verbosity]:level:' \
  '(-n --namespace)'{-n+,--namespace=}'[kubernetes namespace]:namespace:' \
  '--context=[kubeconfig context]:context:' \
  '--cluster=[kubeconfig cluster]:cluster:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '*:target:_default'
