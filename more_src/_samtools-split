#compdef samtools-split
# Documentation: http://www.htslib.org/doc/samtools-split.html
# samtools split: Split a file by read group

local ret=1

_arguments -s -S \
  '(-u)'-u'[Put reads with no tag or an unrecognised tag into FILE1]:FILE1:_files' \
  '(-h)'-h'[Use the header from FILE2 when writing the file given in the -u option]:FILE2:_files' \
  '(-f)'-f'[Output filename format string (see below) \["%*_%#.%."\]]:STRING: ' \
  '(-d)'-d'[Split reads by TAG value into distinct files. Only the TAG key must be]:TAG: ' \
  '(-p)'-p'[Pad numeric values in %# and %! format expansions to this many digits]:NUMBER: ' \
  '(-M --max-split)'{-M,--max-split}'[Limit the number of files created by the -d option to NUM (default 100]:NUM: ' \
  '(-v)'-v'[Verbose output]' \
  '(--no-PG)'--no-PG'[Do not add a @PG line to the header of the output file.]' \
  '(--threads)'--threads'[Number of input/output compression threads to use in addition to main]:INT: ' \
  '*:file:_files' && ret=0

return ret
