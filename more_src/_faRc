#compdef faRc
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# reverse complement a FA file

local ret=1

_arguments -s -S \
  '-keepName[keep name identical (do not prepend RC)]' \
  '-keepCase[works well for ACGTUN in either case]' \
  '-justReverse[prepends R unless asked to keep name]' \
  '-justComplement[prepends C unless asked to keep name]' \
  '1:in fa:_files -g "*.(fa|fasta)"' \
  '2:out fa:_files' && ret=0

return ret
