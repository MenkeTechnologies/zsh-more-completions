#compdef nw_ed
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: tree editor (apply actions to matching nodes).

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-n[do not print the (modified) tree at the end]' \
  '-o[stop processing a clade after first match (preorder)]' \
  '-r[visit tree in preorder]' \
  '*:newick file:_files' && ret=0

return ret
